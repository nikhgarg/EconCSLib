# Lean/Lake build outputs
/.lake/
/.build/
/build/
/lake-packages/
/generated-docs/

# Lean compiler artifacts if generated outside .lake
*.olean
*.ilean
*.c
*.o
*.so
*.a

# Local environment and logs
.env
.env.*
!.env.example
*.log

# Python cache and local tool output
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Keep dashboard caches/logs local, but let human theorem-validation logs be
# committed when reviewers intentionally save them from the dashboard.
**/.review_traces/*
!**/.review_traces/
!**/.review_traces/paper_theorem_validations.jsonl

# Local source-paper extraction caches. Keep extracted paper text out of the
# public repository unless redistribution rights have been checked. Planning,
# audit, handoff, and citation-note `.txt` files are allowed below.
papers/*/*.txt
!papers/*/citation_source.txt
!papers/*/*PLAN*.txt
!papers/*/HANDOFF*.txt
!papers/*/*AUDIT*.txt
!papers/*/PAPER_NOTES.txt

# LaTeX auxiliary files
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz

# Editor and OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
