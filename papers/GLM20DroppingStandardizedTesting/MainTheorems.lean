      ∀ g,
        lowCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g) ∧
          lowTestBasedMerit g (lowCostThreshold g) = lowTestFreeMerit g ∧
            (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
