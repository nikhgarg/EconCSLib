      (scale := scale) (cost := cost) (v1 := v1) (v2 := v2)
      hweight1 hpos1 hcapacity1 hweight2 hpos2 hcapacity2
      (glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos)
      hcost hv1 hdiff_pos hdiff_lt_v1 hcostRatioHigh

/--
Paper Proposition 2, group-indexed source-shaped threshold-equilibrium
existence and uniqueness.

This is the group-aware version of the threshold-equilibrium theorem: the two
school cutoffs are common, while each group has its own cost, projected
precision scale, and low/high application cutoffs from equations (42)--(43).
-/
theorem paper_proposition2_two_school_group_threshold_equilibrium_existsUnique_precision_of_high_cost_ratio
    (Q : StandardGaussianQuantileAPI)
    {Group : Type*}
    {applicantMass1 applicantMass2 : ℝ → ℝ}
    {capacity1 capacity2 totalApplicantMass1 totalApplicantMass2
      v1 v2 : ℝ}
    {priorPrecision subPrecision testPrecision cost : Group → ℝ}
    (hcont1 : Continuous applicantMass1)
    (hanti1 : StrictAnti applicantMass1)
    (hatBot1 :
      Filter.Tendsto applicantMass1 Filter.atBot (nhds totalApplicantMass1))
    (hatTop1 :
      Filter.Tendsto applicantMass1 Filter.atTop (nhds 0))
    (hcapacity1 : capacity1 ∈ Set.Ioo (0 : ℝ) totalApplicantMass1)
    (hcont2 : Continuous applicantMass2)
    (hanti2 : StrictAnti applicantMass2)
    (hatBot2 :
      Filter.Tendsto applicantMass2 Filter.atBot (nhds totalApplicantMass2))
    (hatTop2 :
      Filter.Tendsto applicantMass2 Filter.atTop (nhds 0))
    (hcapacity2 : capacity2 ∈ Set.Ioo (0 : ℝ) totalApplicantMass2)
    (hprior_pos : ∀ g : Group, 0 < priorPrecision g)
    (hsub_pos : ∀ g : Group, 0 < subPrecision g)
    (htest_pos : ∀ g : Group, 0 < testPrecision g)
    (hcost : ∀ g : Group, 0 < cost g)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioHigh :
      ∀ g : Group, cost g / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    let hscale :
      ∀ g : Group,
        0 < glm20StrategicProjectedScale
          (priorPrecision g) (subPrecision g) (testPrecision g) :=
      fun g => glm20StrategicProjectedScale_pos
        (hprior_pos g) (hsub_pos g) (htest_pos g)
    ∃! equilibrium : ℝ × ℝ × (Group → ℝ → Bool),
      glm20Proposition2TwoSchoolGroupThresholdEquilibrium Q
        applicantMass1 applicantMass2 capacity1 capacity2 v1 v2
        priorPrecision subPrecision testPrecision cost hscale equilibrium := by
  intro hscale
  rcases
    paper_proposition2_two_school_selection_thresholds_existUnique_and_capacity_regions_of_strictAnti_applicant_masses
      hcont1 hanti1 hatBot1 hatTop1 hcapacity1
      hcont2 hanti2 hatBot2 hatTop2 hcapacity2 with
    ⟨hschool1, hschool2⟩
  rcases hschool1 with ⟨admissionThreshold, hthreshold1, hunique1⟩
  rcases hschool2 with ⟨school2SubThreshold, hthreshold2, hunique2⟩
  let strategy : Group → ℝ → Bool :=
    fun g q =>
      let lowCutoff :=
        glm20StrategicApplyCutoff Q admissionThreshold
          (glm20StrategicProjectedScale
            (priorPrecision g) (subPrecision g) (testPrecision g))
          (cost g / v1)
      let highCutoff :=
        glm20StrategicApplyCutoff Q admissionThreshold
          (glm20StrategicProjectedScale
            (priorPrecision g) (subPrecision g) (testPrecision g))
          (cost g / (v1 - v2))
      decide
        ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
          (school2SubThreshold ≤ q ∧ highCutoff ≤ q))
  have hbest :
      ∀ g : Group, ∀ q : ℝ, ∀ apply : Bool,
        let lowCutoff :=
          glm20StrategicApplyCutoff Q admissionThreshold
            (glm20StrategicProjectedScale
              (priorPrecision g) (subPrecision g) (testPrecision g))
            (cost g / v1)
        let highCutoff :=
          glm20StrategicApplyCutoff Q admissionThreshold
            (glm20StrategicProjectedScale
              (priorPrecision g) (subPrecision g) (testPrecision g))
            (cost g / (v1 - v2))
        glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2
            (cost g)
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale :=
                  glm20StrategicProjectedScale
                    (priorPrecision g) (subPrecision g) (testPrecision g)
                scale_pos := hscale g }
              admissionThreshold)
            q apply ≤
          glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2
            (cost g)
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale :=
                  glm20StrategicProjectedScale
                    (priorPrecision g) (subPrecision g) (testPrecision g)
                scale_pos := hscale g }
              admissionThreshold)
            q (strategy g q) := by
    intro g q apply
    rcases
      paper_proposition2_two_school_application_region_bestResponse_precision_standardGaussian_of_high_cost_ratio
        Q (admissionThreshold := admissionThreshold)
        (school2SubThreshold := school2SubThreshold)
        (priorPrecision := priorPrecision g)
        (subPrecision := subPrecision g)
        (testPrecision := testPrecision g)
        (cost := cost g) (v1 := v1) (v2 := v2)
        (hprior_pos g) (hsub_pos g) (htest_pos g)
        (hcost g) hv1 hdiff_pos hdiff_lt_v1 (hcostRatioHigh g) with
      ⟨lowCutoff, highCutoff, hlow, hhigh, _hlt, hbest_g⟩
    have h := hbest_g q apply
    simpa [strategy, glm20StrategicApplyCutoff, hlow, hhigh] using h
  have hwitness :
      glm20Proposition2TwoSchoolGroupThresholdEquilibrium Q
        applicantMass1 applicantMass2 capacity1 capacity2 v1 v2
        priorPrecision subPrecision testPrecision cost hscale
        (admissionThreshold, school2SubThreshold, strategy) := by
    refine ⟨hthreshold1, hthreshold2, hbest, rfl⟩
  refine ⟨(admissionThreshold, school2SubThreshold, strategy), hwitness, ?_⟩
  intro equilibrium heq
  rcases equilibrium with ⟨admissionThreshold', school2SubThreshold', strategy'⟩
  rcases heq with ⟨hthreshold1', hthreshold2', _hbest', hstrategy'⟩
  have hadmission :
      admissionThreshold' = admissionThreshold :=
    hunique1 admissionThreshold' hthreshold1'
  have hschool2 :
      school2SubThreshold' = school2SubThreshold :=
    hunique2 school2SubThreshold' hthreshold2'
  subst admissionThreshold'
  subst school2SubThreshold'
  have hstrategy : strategy' = strategy := by
    simpa [strategy, glm20StrategicApplyCutoff] using hstrategy'
  subst strategy'
  rfl

/--
Paper Proposition 2, group-indexed finite standard-Gaussian mixture
source-surface endpoint.

The school cutoffs are the unique capacity cutoffs for the two finite Gaussian
applicant mixtures, and each group uses its own equation (42)--(43) application
region with the paper's projected precision scale.
