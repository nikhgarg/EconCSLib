/--
The binary weighted-academic-merit surface has exactly the paper's weighted
academic-merit objectives as its two-school objective functions.
-/
theorem glm20WeightedAcademicMeritBinaryPolicySurface_policyPairIsEquilibrium_iff
    {Group Policy School : Type*}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull P1 P2 : Policy} {J1 J2 : School}
    {groupA groupB : Group} {populationShare : Group → ℝ} :
    (glm20WeightedAcademicMeritBinaryPolicySurface massTestTaking
        admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
        groupB populationShare).policyPairIsEquilibrium P1 P2 ↔
      glm20TwoSchoolBinaryPolicyEquilibrium
        (glm20TwoGroupWeightedAcademicMeritObjective
          (glm20WeightedAcademicMeritBinaryPolicySurface massTestTaking
            admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
            groupB populationShare)
          policyPair J1 groupA groupB populationShare)
        (glm20TwoGroupWeightedAcademicMeritObjective
          (glm20WeightedAcademicMeritBinaryPolicySurface massTestTaking
            admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
            groupB populationShare)
          policyPair J2 groupA groupB populationShare)
        Psub Pfull P1 P2 := by
  rfl

/--
The concrete policy-state Theorem 3 surface has exactly the weighted
academic-merit binary best-response predicate.
-/
theorem glm20Theorem3PolicyStateWeightedAcademicMeritSurface_policyPairIsEquilibrium_iff
    {Group School : Type*}
    {api : StandardGaussianCDFAPI}
    {subEstimateLaw : Group → GaussianScaleLaw}
    {subSubMass subFullMass : Group → ℝ}
    {fullFullCutoff fullSubCutoff : Group → ℝ}
    {admittedAcademicMerit :
      School → Group → GLM20StrategicPolicyState → ℝ}
    {diversity : School → GLM20StrategicPolicyState → ℝ}
    {J1 J2 : School} {groupA groupB : Group}
    {populationShare : Group → ℝ} {P1 P2 : GLM20StrategicPolicyState} :
    (glm20Theorem3PolicyStateWeightedAcademicMeritSurface api
        subEstimateLaw subSubMass subFullMass fullFullCutoff fullSubCutoff
        admittedAcademicMerit diversity J1 J2 groupA groupB
        populationShare).policyPairIsEquilibrium P1 P2 ↔
      glm20TwoSchoolBinaryPolicyEquilibrium
        (glm20TwoGroupWeightedAcademicMeritObjective
          (glm20Theorem3PolicyStateWeightedAcademicMeritSurface api
            subEstimateLaw subSubMass subFullMass fullFullCutoff
            fullSubCutoff admittedAcademicMerit diversity J1 J2 groupA
            groupB populationShare)
          glm20StrategicPolicyStatePair J1 groupA groupB populationShare)
        (glm20TwoGroupWeightedAcademicMeritObjective
          (glm20Theorem3PolicyStateWeightedAcademicMeritSurface api
            subEstimateLaw subSubMass subFullMass fullFullCutoff
            fullSubCutoff admittedAcademicMerit diversity J1 J2 groupA
            groupB populationShare)
          glm20StrategicPolicyStatePair J2 groupA groupB populationShare)
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull P1 P2 :=
    glm20WeightedAcademicMeritBinaryPolicySurface_policyPairIsEquilibrium_iff

theorem
    glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface_subFull_equilibrium_iff_components
    {Group School : Type*}
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ)
    (subSubMerit subFullMerit fullSubMerit fullFullMerit :
      School → Group → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ) :
    (glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface api
        subEstimateLaw subSubMass subFullMass fullFullCutoff fullSubCutoff
        subSubMerit subFullMerit fullSubMerit fullFullMerit diversity J1 J2
        groupA groupB populationShare).policyPairIsEquilibrium
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull ↔
      (populationShare groupA * fullFullMerit J1 groupA +
          populationShare groupB * fullFullMerit J1 groupB ≤
        populationShare groupA * subFullMerit J1 groupA +
          populationShare groupB * subFullMerit J1 groupB) ∧
        (populationShare groupA * subSubMerit J2 groupA +
            populationShare groupB * subSubMerit J2 groupB ≤
          populationShare groupA * subFullMerit J2 groupA +
            populationShare groupB * subFullMerit J2 groupB) := by
  simp [glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface,
    glm20Theorem3PolicyStateWeightedAcademicMeritSurface,
    glm20WeightedAcademicMeritBinaryPolicySurface,
    glm20TwoSchoolBinaryPolicyEquilibrium_subFull_iff,
    glm20StrategicPolicyStateAdmittedMerit]

theorem
    glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface_fullSub_equilibrium_iff_components
    {Group School : Type*}
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ)
    (subSubMerit subFullMerit fullSubMerit fullFullMerit :
      School → Group → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ) :
    (glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface api
        subEstimateLaw subSubMass subFullMass fullFullCutoff fullSubCutoff
        subSubMerit subFullMerit fullSubMerit fullFullMerit diversity J1 J2
        groupA groupB populationShare).policyPairIsEquilibrium
        GLM20StrategicPolicyState.singleFull
        GLM20StrategicPolicyState.singleSub ↔
      (populationShare groupA * subSubMerit J1 groupA +
          populationShare groupB * subSubMerit J1 groupB ≤
        populationShare groupA * fullSubMerit J1 groupA +
          populationShare groupB * fullSubMerit J1 groupB) ∧
        (populationShare groupA * fullFullMerit J2 groupA +
            populationShare groupB * fullFullMerit J2 groupB ≤
          populationShare groupA * fullSubMerit J2 groupA +
            populationShare groupB * fullSubMerit J2 groupB) := by
  simp [glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface,
    glm20Theorem3PolicyStateWeightedAcademicMeritSurface,
    glm20WeightedAcademicMeritBinaryPolicySurface,
    glm20TwoSchoolBinaryPolicyEquilibrium_fullSub_iff,
    glm20StrategicPolicyStateAdmittedMerit]

theorem
    glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface_fullFull_equilibrium_iff_components
    {Group School : Type*}
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ)
    (subSubMerit subFullMerit fullSubMerit fullFullMerit :
      School → Group → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ) :
    (glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface api
        subEstimateLaw subSubMass subFullMass fullFullCutoff fullSubCutoff
        subSubMerit subFullMerit fullSubMerit fullFullMerit diversity J1 J2
        groupA groupB populationShare).policyPairIsEquilibrium
        GLM20StrategicPolicyState.singleFull
        GLM20StrategicPolicyState.singleFull ↔
      (populationShare groupA * subFullMerit J1 groupA +
          populationShare groupB * subFullMerit J1 groupB ≤
        populationShare groupA * fullFullMerit J1 groupA +
          populationShare groupB * fullFullMerit J1 groupB) ∧
        (populationShare groupA * fullSubMerit J2 groupA +
            populationShare groupB * fullSubMerit J2 groupB ≤
          populationShare groupA * fullFullMerit J2 groupA +
            populationShare groupB * fullFullMerit J2 groupB) := by
