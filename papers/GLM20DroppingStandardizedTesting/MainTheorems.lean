    (hfull_precision_order : subB + testB < subA + testA)
    (hsub_precision_order : subB < subA)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_sub :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_sub.posteriorMeanScaleLaw thresholdSub +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_sub.posteriorMeanScaleLaw thresholdSub)
    (hcapacity_full :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_full.posteriorMeanScaleLaw thresholdFull +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_full.posteriorMeanScaleLaw thresholdFull)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ)) :
    let interceptAFull :=
