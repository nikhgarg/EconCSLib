        academicMeritImproves γg ↔ γg ≤ γbar :=
  paper_theorem1_academic_merit_access_threshold_of_groupB_beta_le
    Q hcapacity_pos hown_pos hother_pos hone_lt_rho hselective
    hbeta_zero hbeta_one
    (paper_theorem1_academic_merit_hazard_condition_iff_beta_le_delta_on_Icc
      H hxi_pos hhazard)

/--
Theorem 1(ii), group-B academic-merit threshold from the hazard inequality,
without endpoint-crossing assumptions.
-/
theorem paper_theorem1_academic_merit_access_threshold_of_groupB_hazard_main
    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    {capacity ownShare otherEligibleMass rho xi benchmark : ℝ}
    {academicMeritImproves : ℝ → Prop}
    (hxi_pos : 0 < xi)
    (hcapacity_pos : 0 < capacity)
    (hown_pos : 0 < ownShare)
    (hother_pos : 0 < otherEligibleMass)
    (hone_lt_rho : 1 < rho)
    (hselective :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShare * γ + otherEligibleMass)
    (hhazard :
      ∀ γg ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γg ↔
          H.hazard
              (theorem1BetaGroupB Q capacity ownShare otherEligibleMass rho γg) ≤
            xi * H.hazard benchmark) :
    ∃ γbar : ℝ,
      ∀ γg ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γg ↔ γg ≤ γbar :=
  paper_theorem1_academic_merit_access_threshold_of_groupB_beta_le_main
    Q hcapacity_pos hown_pos hother_pos hone_lt_rho hselective
    (paper_theorem1_academic_merit_hazard_condition_iff_beta_le_delta_on_Icc
      H hxi_pos hhazard)

/--
Theorem 1(ii), group-B academic-merit threshold from Gaussian upper-tail mean
formulas.

This theorem discharges the source Step 1 reduction from admitted academic
merits to the hazard inequality, then applies the proved `HR⁻¹` and `β_B`
threshold route.
-/
theorem paper_theorem1_academic_merit_access_threshold_of_groupB_tail_mean
    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    {capacity ownShare otherEligibleMass rho xi benchmark base scale : ℝ}
    {fullMerit : ℝ → ℝ} {subMerit : ℝ}
    {academicMeritImproves : ℝ → Prop}
    (hxi_pos : 0 < xi)
    (hscale_pos : 0 < scale)
    (hfull :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMerit γ =
          base + scale *
            H.hazard
              (theorem1BetaGroupB Q capacity ownShare otherEligibleMass rho γ))
    (hsub :
      subMerit = base + scale * (xi * H.hazard benchmark))
    (himproves :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γ ↔ fullMerit γ ≤ subMerit)
    (hcapacity_pos : 0 < capacity)
    (hown_pos : 0 < ownShare)
    (hother_pos : 0 < otherEligibleMass)
    (hone_lt_rho : 1 < rho)
    (hselective :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShare * γ + otherEligibleMass)
    (hbeta_zero :
      theorem1BetaGroupB Q capacity ownShare otherEligibleMass rho 0 <
        theorem1AcademicMeritDelta H xi benchmark)
    (hbeta_one :
      theorem1AcademicMeritDelta H xi benchmark <
        theorem1BetaGroupB Q capacity ownShare otherEligibleMass rho 1) :
    ∃ γbar : ℝ, γbar ∈ Set.Ioo (0 : ℝ) 1 ∧
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γ ↔ γ ≤ γbar :=
  paper_theorem1_academic_merit_access_threshold_of_groupB_hazard
    H Q hxi_pos hcapacity_pos hown_pos hother_pos hone_lt_rho hselective
    hbeta_zero hbeta_one
    (paper_theorem1_academic_merit_improves_iff_hazard_of_tail_mean_on_Icc
      H hscale_pos hfull hsub himproves)

/--
Theorem 1(ii), group-B academic-merit threshold from Gaussian upper-tail mean
formulas, without endpoint-crossing assumptions.
-/
theorem paper_theorem1_academic_merit_access_threshold_of_groupB_tail_mean_main
    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    {capacity ownShare otherEligibleMass rho xi benchmark base scale : ℝ}
