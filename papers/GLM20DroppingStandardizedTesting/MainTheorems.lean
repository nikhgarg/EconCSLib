/--
Binary-policy strategic surface for the paper's two-school diversity-only game.

This is the Proposition 6 analogue of
`glm20WeightedAcademicMeritBinaryPolicySurface`: the observables are the same,
but each school maximizes its own diversity field instead of the weighted
academic-merit objective.
-/
def glm20DiversityBinaryPolicySurface
    {Group Policy School : Type*}
    (massTestTaking : Group → Policy → ℝ)
    (admittedAcademicMerit : School → Group → Policy → ℝ)
    (diversity : School → Policy → ℝ)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J1 J2 : School) :
    GLM20StrategicPolicySurface Group Policy School (Policy × Policy) where
  massTestTaking := massTestTaking
  admittedAcademicMerit := admittedAcademicMerit
  diversity := diversity
  policyPairIsEquilibrium := fun P1 P2 =>
    glm20TwoSchoolBinaryPolicyEquilibrium
      (fun P1 P2 => diversity J1 (policyPair P1 P2))
      (fun P1 P2 => diversity J2 (policyPair P1 P2))
      Psub Pfull P1 P2
  equilibriumPredicate := fun E =>
    glm20TwoSchoolBinaryPolicyEquilibrium
      (fun P1 P2 => diversity J1 (policyPair P1 P2))
      (fun P1 P2 => diversity J2 (policyPair P1 P2))
      Psub Pfull E.1 E.2

/-- The binary diversity-only surface uses exactly the two diversity objectives. -/
