        admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
        groupB populationShare feasible1 feasible2).policyPairIsEquilibrium
        Psub Pfull ↔
      feasible1 Psub Pfull ∧ feasible2 Psub Pfull ∧
        (feasible1 Pfull Pfull →
          glm20TwoGroupWeightedAcademicMeritObjective
              (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
                massTestTaking admittedAcademicMerit diversity policyPair Psub
                Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
              policyPair J1 groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective
              (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
                massTestTaking admittedAcademicMerit diversity policyPair Psub
                Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
              policyPair J1 groupA groupB populationShare Psub Pfull) ∧
          (feasible2 Psub Psub →
            glm20TwoGroupWeightedAcademicMeritObjective
                (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
                  massTestTaking admittedAcademicMerit diversity policyPair Psub
                  Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
                policyPair J2 groupA groupB populationShare Psub Psub ≤
              glm20TwoGroupWeightedAcademicMeritObjective
                (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
                  massTestTaking admittedAcademicMerit diversity policyPair Psub
                  Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
                policyPair J2 groupA groupB populationShare Psub Pfull) := by
  simpa [glm20FeasibleWeightedAcademicMeritBinaryPolicySurface_policyPairIsEquilibrium_iff]
    using
      (glm20TwoSchoolBinaryPolicyFeasibleEquilibrium_subFull_iff
        (glm20TwoGroupWeightedAcademicMeritObjective
          (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
            massTestTaking admittedAcademicMerit diversity policyPair Psub
            Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
          policyPair J1 groupA groupB populationShare)
        (glm20TwoGroupWeightedAcademicMeritObjective
          (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
            massTestTaking admittedAcademicMerit diversity policyPair Psub
            Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
          policyPair J2 groupA groupB populationShare)
        feasible1 feasible2 Psub Pfull)

/-- Specialized feasible weighted-surface characterization for `(P_full, P_sub)`. -/
theorem glm20FeasibleWeightedAcademicMeritBinaryPolicySurface_fullSub_iff
    {Group Policy School : Type*}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School}
    {groupA groupB : Group} {populationShare : Group → ℝ}
    {feasible1 feasible2 : Policy → Policy → Prop} :
    (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
        admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
        groupB populationShare feasible1 feasible2).policyPairIsEquilibrium
        Pfull Psub ↔
      feasible1 Pfull Psub ∧ feasible2 Pfull Psub ∧
        (feasible1 Psub Psub →
          glm20TwoGroupWeightedAcademicMeritObjective
              (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
                massTestTaking admittedAcademicMerit diversity policyPair Psub
                Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
              policyPair J1 groupA groupB populationShare Psub Psub ≤
            glm20TwoGroupWeightedAcademicMeritObjective
              (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
                massTestTaking admittedAcademicMerit diversity policyPair Psub
                Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
              policyPair J1 groupA groupB populationShare Pfull Psub) ∧
          (feasible2 Pfull Pfull →
            glm20TwoGroupWeightedAcademicMeritObjective
                (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
                  massTestTaking admittedAcademicMerit diversity policyPair Psub
                  Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
                policyPair J2 groupA groupB populationShare Pfull Pfull ≤
              glm20TwoGroupWeightedAcademicMeritObjective
                (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
                  massTestTaking admittedAcademicMerit diversity policyPair Psub
                  Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
                policyPair J2 groupA groupB populationShare Pfull Psub) := by
  simpa [glm20FeasibleWeightedAcademicMeritBinaryPolicySurface_policyPairIsEquilibrium_iff]
    using
      (glm20TwoSchoolBinaryPolicyFeasibleEquilibrium_fullSub_iff
        (glm20TwoGroupWeightedAcademicMeritObjective
          (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
            massTestTaking admittedAcademicMerit diversity policyPair Psub
            Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
          policyPair J1 groupA groupB populationShare)
        (glm20TwoGroupWeightedAcademicMeritObjective
          (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
            massTestTaking admittedAcademicMerit diversity policyPair Psub
            Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
          policyPair J2 groupA groupB populationShare)
        feasible1 feasible2 Psub Pfull)

/-- Specialized feasible weighted-surface characterization for `(P_full, P_full)`. -/
theorem glm20FeasibleWeightedAcademicMeritBinaryPolicySurface_fullFull_iff
    {Group Policy School : Type*}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
