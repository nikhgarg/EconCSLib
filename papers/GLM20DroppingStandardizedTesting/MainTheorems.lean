  exact paper_theorem1_dropping_tests_with_barriers_canonical_source_surfaces
    H Q hP_ne hthreshold_cont hcapacity_pos hgroupA_pos hgroupB_pos C.holds
    hscaleA_pos hxiA_pos hownA_pos hotherA_pos hrhoA_nonneg hrhoA_lt_one
