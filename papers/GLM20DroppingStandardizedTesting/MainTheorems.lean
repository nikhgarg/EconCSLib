theorem paper_theorem1_dropping_tests_with_barriers_canonical_of_capacity_range
    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    (hcdf_atBot : Filter.Tendsto H.api.cdf Filter.atBot (nhds 0))
    (hcdf_atTop : Filter.Tendsto H.api.cdf Filter.atTop (nhds 1))
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    {Pfull Psub : Policy} (hP_ne : Pfull ≠ Psub)
    {groupA groupB : Group}
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw}
    {ownShareA otherEligibleMassA rhoA xiA benchmarkA baseA scaleA : ℝ}
    {ownShareB otherEligibleMassB rhoB xiB benchmarkB baseB scaleB : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hcapacity_mem :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity ∈ Set.Ioo (0 : ℝ) (groupAEligibleMass + groupBShare * γB))
    (hscaleA_pos : 0 < scaleA)
    (hxiA_pos : 0 < xiA)
    (hownA_pos : 0 < ownShareA)
    (hotherA_pos : 0 < otherEligibleMassA)
    (hrhoA_nonneg : 0 ≤ rhoA) (hrhoA_lt_one : rhoA < 1)
    (hselectiveA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareA * γ + otherEligibleMassA)
    (hscaleB_pos : 0 < scaleB)
    (hxiB_pos : 0 < xiB)
    (hownB_pos : 0 < ownShareB)
    (hotherB_pos : 0 < otherEligibleMassB)
    (hone_lt_rhoB : 1 < rhoB)
    (hselectiveB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareB * γ + otherEligibleMassB) :
    let threshold :=
      theorem1BarrierCapacityThresholdOnUnit H.api hcdf_atBot hcdf_atTop
        capacity groupAEligibleMass groupBShare L_A L_B
        hgroupA_pos hgroupB_pos.le hcapacity_mem
    let Sdiv :=
      theorem1DiversitySourceSurface H.api Pfull Psub groupB
        capacity groupBShare diversitySub L_B threshold
    let SA :=
      theorem1AcademicMeritSourceSurface H Pfull Psub groupA
        capacity baseA scaleA xiA hscaleA_pos hxiA_pos benchmarkA
        (theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA)
    let SB :=
      theorem1AcademicMeritSourceSurface H Pfull Psub groupB
        capacity baseB scaleB xiB hscaleB_pos hxiB_pos benchmarkB
        (theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB)
    (∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        theorem1SourceDiversityImproves Sdiv Pfull Psub γB ↔ γB < γbar) ∧
      (∃ γbarA : ℝ,
        ∀ γA ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SA groupA Pfull Psub γA ↔
            γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SB groupB Pfull Psub γB ↔
            γB ≤ γbarB) := by
  dsimp only
  exact
    paper_theorem1_dropping_tests_with_barriers_canonical_of_mixture_capacity
      H Q hP_ne hcapacity_pos hgroupA_pos hgroupB_pos
      (threshold :=
        theorem1BarrierCapacityThresholdOnUnit H.api hcdf_atBot hcdf_atTop
          capacity groupAEligibleMass groupBShare L_A L_B
          hgroupA_pos hgroupB_pos.le hcapacity_mem)
      (theorem1BarrierCapacityThresholdOnUnit_mixtureTailMass_eq
        H.api hcdf_atBot hcdf_atTop hgroupA_pos hgroupB_pos.le hcapacity_mem)
      hscaleA_pos hxiA_pos hownA_pos hotherA_pos hrhoA_nonneg hrhoA_lt_one
      hselectiveA hscaleB_pos hxiB_pos hownB_pos hotherB_pos hone_lt_rhoB
      hselectiveB

/--
Theorem 1, canonical source surfaces with the concrete mathlib-backed standard
normal.

Compared with `paper_theorem1_dropping_tests_with_barriers_canonical_of_capacity_range`,
this wrapper discharges the Gaussian CDF tail-limit, quantile, and hazard-inverse
API arguments using `GaussianMathlib`; the remaining mathematical premise is
the paper's capacity-feasibility condition for every access level.
-/
theorem paper_theorem1_dropping_tests_with_barriers_canonical_standardGaussian_of_capacity_range
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    {Pfull Psub : Policy} (hP_ne : Pfull ≠ Psub)
