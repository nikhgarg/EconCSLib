/--
Paper Theorem 3 source-shaped endpoint from the Proposition 5 proof seams.

This theorem composes the binary two-school objective bridge with the paper's
own Proposition 5 decomposition:

* Part (i): school `J1` drops iff condition (10) holds for exactly one group,
  and then school `J2` keeps iff conditions (11)--(12) hold for the other
  group.
* Part (ii): school `J2` drops iff condition (13) holds for exactly one group,
  and then school `J1` keeps iff condition (14) holds for that group.

The remaining premises are now exactly those Proposition 5 analytic claims for
the concrete Gaussian strategic model, plus positive group test costs for the
abstract part (iii) boundary statement.
-/
theorem paper_theorem3_source_conditions_of_proposition5_objective_bridges
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost subFullCostThreshold
      fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (hpolicySubFull :
      S.policyPairIsEquilibrium Psub Pfull ↔
        glm20TwoSchoolBinaryPolicyEquilibrium objective1 objective2
          Psub Pfull Psub Pfull)
    (hpolicyFullSub :
      S.policyPairIsEquilibrium Pfull Psub ↔
        glm20TwoSchoolBinaryPolicyEquilibrium objective1 objective2
          Psub Pfull Pfull Psub)
    (hsubFullJ1 :
      (objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3SubFullGroupExpandsByDropping S policyPair
            Psub Pfull testCost subFullCostThreshold q1Sub K))
    (hsubFullJ2A :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost subFullCostThreshold q1Sub K groupA →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull
            J2 groupA groupB populationShare capacity2 groupB))
    (hsubFullJ2B :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost subFullCostThreshold q1Sub K groupB →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull
            J2 groupA groupB populationShare capacity2 groupA))
    (hfullSubJ2 :
      (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3FullSubSchool2DropsCondition S policyPair
            Psub Pfull testCost fullSubLowCostThreshold
            fullSubHighCostThreshold q1Sub q2Sub K))
    (hfullSubJ1A :
      glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
          testCost fullSubLowCostThreshold fullSubHighCostThreshold q1Sub q2Sub
          K groupA →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          glm20Theorem3FullSubSchool1KeepsTestCondition S policyPair
            Psub Pfull testCost fullSubHighCostThreshold q1Sub K groupA))
    (hfullSubJ1B :
      glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
          testCost fullSubLowCostThreshold fullSubHighCostThreshold q1Sub q2Sub
          K groupB →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          glm20Theorem3FullSubSchool1KeepsTestCondition S policyPair
            Psub Pfull testCost fullSubHighCostThreshold q1Sub K groupB))
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    (S.policyPairIsEquilibrium Psub Pfull ↔
      glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
        groupA groupB populationShare testCost subFullCostThreshold
        capacity2 q1Sub K) ∧
      (S.policyPairIsEquilibrium Pfull Psub ↔
        glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
          testCost fullSubLowCostThreshold fullSubHighCostThreshold
          q1Sub q2Sub K) ∧
        glm20Theorem3FullFullCondition S Pfull groupA groupB testCost := by
  have hsubFullObjective :
      (objective1 Pfull Pfull ≤ objective1 Psub Pfull ∧
        objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
        glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
          groupA groupB populationShare testCost subFullCostThreshold
          capacity2 q1Sub K :=
    paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition
      (S := S) (policyPair := policyPair) (Psub := Psub) (Pfull := Pfull)
      (J2 := J2) (groupA := groupA) (groupB := groupB)
      (populationShare := populationShare) (testCost := testCost)
      (costThreshold := subFullCostThreshold) (capacity2 := capacity2)
      (q1Sub := q1Sub) (K := K) objective1 objective2
      hsubFullJ1 hsubFullJ2A hsubFullJ2B
  have hfullSubObjective :
      (objective1 Psub Psub ≤ objective1 Pfull Psub ∧
        objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
        glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
          testCost fullSubLowCostThreshold fullSubHighCostThreshold
          q1Sub q2Sub K :=
    paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_source_condition
      (S := S) (policyPair := policyPair) (Psub := Psub) (Pfull := Pfull)
      (groupA := groupA) (groupB := groupB) (testCost := testCost)
      (lowCostThreshold := fullSubLowCostThreshold)
      (highCostThreshold := fullSubHighCostThreshold) (q1Sub := q1Sub)
      (q2Sub := q2Sub) (K := K) objective1 objective2 hfullSubJ2
      hfullSubJ1A hfullSubJ1B
  exact
    paper_theorem3_source_conditions_of_binary_policy_objective_conditions
      objective1 objective2 hpolicySubFull hpolicyFullSub hsubFullObjective
      hfullSubObjective hcostA hcostB

