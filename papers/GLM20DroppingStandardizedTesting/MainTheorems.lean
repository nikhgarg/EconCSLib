    continuous_const.mul hcore

/--
Continuity of the GLM20 bivariate application-and-admission mass for the
concrete correlated standard-Gaussian CDF.
-/
theorem glm20BivariateApplyAdmitMass_standardBivariate_continuous_along
    {populationShare sigmaTilde b mu : ℝ}
    {aOfApply qApply qAdmit : ℝ → ℝ}
    (ha : Continuous aOfApply)
    (hqApply : Continuous qApply)
    (hqAdmit : Continuous qAdmit) :
    Continuous fun z : ℝ =>
      glm20BivariateApplyAdmitMass standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare sigmaTilde aOfApply b mu
        (qApply z) (qAdmit z) := by
  let rho : ℝ :=
    -(sigmaTilde * b) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  have hrho : rho ^ 2 ≤ 1 :=
    le_of_lt (by
      simpa [rho] using paper_proposition3_rho_sq_lt_one sigmaTilde b)
  have hbivar :
      Continuous fun p : ℝ × ℝ =>
        standardBivariateGaussianCDF p.1 p.2 rho :=
    standardBivariateGaussianCDF_continuous_of_rho_sq_le_one hrho
