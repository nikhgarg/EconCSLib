  paper_lemma3_full_policy_threshold_equilibrium_existsUnique_of_strategic_applicant_components
    Q jointApplyAdmitMass hcont hanti hatBot hatTop hcapacity hprior_pos
    hsub_pos htest_pos hvalue
    (fun g =>
      paper_lemma3_cost_ratio_mem_Ioo_of_cost_bounds
        (hcost_pos g) (hcost_lt_value g))

/--
Proposition 2 support: because the marginal value `v1 - v2` is smaller than
`v1`, the high cutoff for students already admitted to school `J2` is strictly
above the low cutoff for students not admitted to `J2`.
-/
theorem paper_proposition2_low_cutoff_lt_high_cutoff_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold scale cost v1 v2 : ℝ}
    (hscale : 0 < scale) (hcost : 0 < cost)
    (hdiff_pos : 0 < v1 - v2) (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioLow : cost / v1 ∈ Set.Ioo (0 : ℝ) 1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    glm20StrategicApplyCutoff Q admissionThreshold scale (cost / v1) <
      glm20StrategicApplyCutoff Q admissionThreshold scale (cost / (v1 - v2)) := by
  have hv1_pos : 0 < v1 := lt_trans hdiff_pos hdiff_lt_v1
  have hratio_lt : cost / v1 < cost / (v1 - v2) := by
    rw [div_lt_div_iff₀ hv1_pos hdiff_pos]
    nlinarith [hcost, hdiff_lt_v1]
  have hargHigh : 1 - cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1 :=
    ⟨by linarith [hcostRatioHigh.2], by linarith [hcostRatioHigh.1]⟩
  have hargLow : 1 - cost / v1 ∈ Set.Ioo (0 : ℝ) 1 :=
    ⟨by linarith [hcostRatioLow.2], by linarith [hcostRatioLow.1]⟩
  have harg_lt : 1 - cost / (v1 - v2) < 1 - cost / v1 := by
    linarith
  have hquantile_lt :
      Q.quantile (1 - cost / (v1 - v2)) <
        Q.quantile (1 - cost / v1) :=
    Q.quantile_strictMonoOn hargHigh hargLow harg_lt
  unfold glm20StrategicApplyCutoff
  nlinarith [mul_lt_mul_of_pos_left hquantile_lt hscale]

/--
Proposition 2 domain support: the high-cutoff probability-domain condition
`c_g / (v1 - v2) ∈ (0,1)` already implies the low-cutoff condition
`c_g / v1 ∈ (0,1)` when `0 < v1 - v2 < v1`.
-/
theorem paper_proposition2_cost_ratio_low_of_high
    {cost v1 v2 : ℝ}
    (hcost : 0 < cost) (hv1 : 0 < v1)
    (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    cost / v1 ∈ Set.Ioo (0 : ℝ) 1 := by
  constructor
  · exact div_pos hcost hv1
  · have hcost_lt_diff : cost < v1 - v2 :=
      (div_lt_one hdiff_pos).mp hcostRatioHigh.2
    have hcost_lt_v1 : cost < v1 := lt_trans hcost_lt_diff hdiff_lt_v1
    exact (div_lt_one hv1).mpr hcost_lt_v1

/--
Proposition 2 domain support: the paper-readable bound `0 < c < v1 - v2`
is exactly the high-cutoff inverse-CDF domain `c / (v1 - v2) ∈ (0,1)`.
-/
theorem paper_proposition2_cost_ratio_high_of_cost_bounds
    {cost v1 v2 : ℝ}
    (hcost : 0 < cost) (hcost_lt_diff : cost < v1 - v2) :
    cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1 := paper_proposition5_cost_ratio_mem_Ioo_of_pos_lt hcost hcost_lt_diff

/--
Proposition 2 support with the nonredundant cost-ratio assumption.

The source conditions only need the high-cutoff domain
`c_g / (v1 - v2) ∈ (0,1)` plus `0 < v1 - v2 < v1`; the low-cutoff domain is
derived by `paper_proposition2_cost_ratio_low_of_high`.
-/
theorem paper_proposition2_low_cutoff_lt_high_cutoff_standardGaussian_of_high_cost_ratio
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold scale cost v1 v2 : ℝ}
    (hscale : 0 < scale) (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    glm20StrategicApplyCutoff Q admissionThreshold scale (cost / v1) <
      glm20StrategicApplyCutoff Q admissionThreshold scale (cost / (v1 - v2)) := by
  have hcostRatioLow :
      cost / v1 ∈ Set.Ioo (0 : ℝ) 1 :=
    paper_proposition2_cost_ratio_low_of_high
      hcost hv1 hdiff_pos hdiff_lt_v1 hcostRatioHigh
  exact
    paper_proposition2_low_cutoff_lt_high_cutoff_standardGaussian
      Q hscale hcost hdiff_pos hdiff_lt_v1 hcostRatioLow hcostRatioHigh

/--
Proposition 2 student-region support.

Paper statement: with two schools, group-`g` students take the test and apply
to `J1` iff either their preliminary skill is below `J2`'s test-free cutoff and
above the low cutoff `q_l^g`, or their preliminary skill is above both `J2`'s
cutoff and the high cutoff `q_h^g`.  The displayed formulas for `q_l^g` and
`q_h^g` are the same Gaussian cutoff formula with cost ratios `c_g / v1` and
`c_g / (v1 - v2)`.
-/
theorem paper_proposition2_two_school_application_region_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold school2SubThreshold scale cost v1 v2 : ℝ}
    (hscale : 0 < scale) (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioLow : cost / v1 ∈ Set.Ioo (0 : ℝ) 1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ lowCutoff highCutoff : ℝ,
      lowCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / v1) ∧
      highCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / (v1 - v2)) ∧
      lowCutoff < highCutoff ∧
      ∀ q : ℝ,
        ((q < school2SubThreshold ∧
            0 ≤ v1 *
              Q.cdfAPI.thresholdPassProb
                { mean := q, scale := scale, scale_pos := hscale }
                admissionThreshold - cost) ∨
          (school2SubThreshold ≤ q ∧
            0 ≤ (v1 - v2) *
              Q.cdfAPI.thresholdPassProb
                { mean := q, scale := scale, scale_pos := hscale }
                admissionThreshold - cost)) ↔
        ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
          max highCutoff school2SubThreshold ≤ q) := by
  let lowCutoff :=
    glm20StrategicApplyCutoff Q admissionThreshold scale (cost / v1)
  let highCutoff :=
    glm20StrategicApplyCutoff Q admissionThreshold scale (cost / (v1 - v2))
  refine ⟨lowCutoff, highCutoff, rfl, rfl, ?_, ?_⟩
  · exact
      paper_proposition2_low_cutoff_lt_high_cutoff_standardGaussian
        Q hscale hcost hdiff_pos hdiff_lt_v1 hcostRatioLow hcostRatioHigh
  · intro q
    have hlow :
        0 ≤ v1 *
            Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold - cost ↔
          lowCutoff ≤ q :=
              paper_lemma3_apply_payoff_nonnegative_iff_above_gaussian_cutoff
          Q hscale hv1 hcostRatioLow
    have hhigh :
        0 ≤ (v1 - v2) *
            Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold - cost ↔
          highCutoff ≤ q :=
              paper_lemma3_apply_payoff_nonnegative_iff_above_gaussian_cutoff
          Q hscale hdiff_pos hcostRatioHigh
    constructor
    · intro hregion
      rcases hregion with ⟨hbelow, hpayoff⟩ | ⟨habove, hpayoff⟩
      · exact Or.inl ⟨hbelow, hlow.mp hpayoff⟩
      · exact Or.inr (by
          rw [max_le_iff]
          exact ⟨hhigh.mp hpayoff, habove⟩)
    · intro hregion
      rcases hregion with ⟨hbelow, hcutoff⟩ | hmax
      · exact Or.inl ⟨hbelow, hlow.mpr hcutoff⟩
      · have hcutoffs : highCutoff ≤ q ∧ school2SubThreshold ≤ q := by
          simpa [max_le_iff] using hmax
        exact Or.inr ⟨hcutoffs.2, hhigh.mpr hcutoffs.1⟩

/--
Proposition 2 student-region support with the low cost-ratio domain derived
from the high cost-ratio domain and `0 < v1 - v2 < v1`.
-/
theorem paper_proposition2_two_school_application_region_standardGaussian_of_high_cost_ratio
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold school2SubThreshold scale cost v1 v2 : ℝ}
    (hscale : 0 < scale) (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ lowCutoff highCutoff : ℝ,
      lowCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / v1) ∧
      highCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / (v1 - v2)) ∧
      lowCutoff < highCutoff ∧
      ∀ q : ℝ,
        ((q < school2SubThreshold ∧
            0 ≤ v1 *
              Q.cdfAPI.thresholdPassProb
                { mean := q, scale := scale, scale_pos := hscale }
                admissionThreshold - cost) ∨
          (school2SubThreshold ≤ q ∧
            0 ≤ (v1 - v2) *
              Q.cdfAPI.thresholdPassProb
                { mean := q, scale := scale, scale_pos := hscale }
                admissionThreshold - cost)) ↔
        ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
          max highCutoff school2SubThreshold ≤ q) := by
  have hcostRatioLow :
      cost / v1 ∈ Set.Ioo (0 : ℝ) 1 :=
    paper_proposition2_cost_ratio_low_of_high
      hcost hv1 hdiff_pos hdiff_lt_v1 hcostRatioHigh
  exact
    paper_proposition2_two_school_application_region_standardGaussian
      Q (admissionThreshold := admissionThreshold)
      (school2SubThreshold := school2SubThreshold) (scale := scale)
      (cost := cost) (v1 := v1) (v2 := v2)
      hscale hcost hv1 hdiff_pos hdiff_lt_v1
      hcostRatioLow hcostRatioHigh

/--
Proposition 2 qualitative implication: when `J2`'s test-free cutoff lies
strictly between the low and high `J1` application cutoffs, the application
region is non-monotone in the preliminary skill estimate.

There are projected-skill values `q_low < q_mid < q_high` such that students
apply at `q_low`, do not apply at `q_mid`, and apply again at `q_high`.
-/
theorem paper_proposition2_two_school_application_region_nonmonotone_between_cutoffs
    {school2SubThreshold lowCutoff highCutoff : ℝ}
    (hlow_school2 : lowCutoff < school2SubThreshold)
    (hschool2_high : school2SubThreshold < highCutoff) :
    ∃ qApplyLow qNoApply qApplyHigh : ℝ,
      qApplyLow < qNoApply ∧ qNoApply < qApplyHigh ∧
        glm20StrategicTwoSchoolApplicationRegion
          school2SubThreshold lowCutoff highCutoff qApplyLow ∧
          ¬ glm20StrategicTwoSchoolApplicationRegion
            school2SubThreshold lowCutoff highCutoff qNoApply ∧
            glm20StrategicTwoSchoolApplicationRegion
              school2SubThreshold lowCutoff highCutoff qApplyHigh := by
  let qApplyLow := (lowCutoff + school2SubThreshold) / 2
  let qNoApply := (school2SubThreshold + highCutoff) / 2
  let qApplyHigh := highCutoff
  refine ⟨qApplyLow, qNoApply, qApplyHigh, ?_, ?_, ?_, ?_, ?_⟩
  · dsimp [qApplyLow, qNoApply]
    linarith
  · dsimp [qNoApply, qApplyHigh]
    linarith
  · left
    constructor
    · dsimp [qApplyLow]
      linarith
    · dsimp [qApplyLow]
      linarith
  · intro hregion
    rcases hregion with ⟨hbelow, _hlow⟩ | ⟨_habove, hhigh⟩
    · dsimp [qNoApply] at hbelow
      linarith
    · dsimp [qNoApply] at hhigh
      linarith
  · right
    constructor
    · exact le_trans hschool2_high.le le_rfl
    · exact le_rfl

/--
Proposition 2 student-region best-response support.

The two-school region from `paper_proposition2_two_school_application_region_standardGaussian`
is not merely an algebraic description of nonnegative incremental utility: the
indicator of that region pointwise maximizes the binary apply/not-apply payoff.
-/
theorem paper_proposition2_two_school_application_region_bestResponse_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold school2SubThreshold scale cost v1 v2 : ℝ}
    (hscale : 0 < scale) (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioLow : cost / v1 ∈ Set.Ioo (0 : ℝ) 1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ lowCutoff highCutoff : ℝ,
      lowCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / v1) ∧
      highCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / (v1 - v2)) ∧
      lowCutoff < highCutoff ∧
      ∀ q : ℝ, ∀ apply : Bool,
        glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold)
            q apply ≤
          glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold)
            q
            (decide
              ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
                (school2SubThreshold ≤ q ∧ highCutoff ≤ q))) := by
  rcases
    paper_proposition2_two_school_application_region_standardGaussian
      Q (admissionThreshold := admissionThreshold)
      (school2SubThreshold := school2SubThreshold) (scale := scale)
      (cost := cost) (v1 := v1) (v2 := v2)
      hscale hcost hv1 hdiff_pos hdiff_lt_v1
      hcostRatioLow hcostRatioHigh with
    ⟨lowCutoff, highCutoff, hlow_eq, hhigh_eq, hlt, hregion⟩
  refine ⟨lowCutoff, highCutoff, hlow_eq, hhigh_eq, hlt, ?_⟩
  intro q apply
  let admissionProbability :=
    Q.cdfAPI.thresholdPassProb
      { mean := q, scale := scale, scale_pos := hscale }
      admissionThreshold
  have hlow :
      0 ≤ v1 * admissionProbability - cost ↔ lowCutoff ≤ q := by
    rw [hlow_eq]
    exact
      paper_lemma3_apply_payoff_nonnegative_iff_above_gaussian_cutoff
        Q hscale hv1 hcostRatioLow
  have hhigh :
      0 ≤ (v1 - v2) * admissionProbability - cost ↔ highCutoff ≤ q := by
    rw [hhigh_eq]
    exact
      paper_lemma3_apply_payoff_nonnegative_iff_above_gaussian_cutoff
        Q hscale hdiff_pos hcostRatioHigh
  by_cases hchosen :
      (q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
        (school2SubThreshold ≤ q ∧ highCutoff ≤ q)
  · have hdecide :
        decide
          ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
            (school2SubThreshold ≤ q ∧ highCutoff ≤ q)) = true := by
      simp [hchosen]
    cases apply
    · rcases hchosen with ⟨hbelow, hcutoff⟩ | ⟨habove, hcutoff⟩
      · have hpayoff : 0 ≤ v1 * admissionProbability - cost :=
          hlow.mpr hcutoff
        have hcond :
            lowCutoff ≤ q ∨ school2SubThreshold ≤ q ∧ highCutoff ≤ q :=
          Or.inl hcutoff
        simp [glm20StrategicTwoSchoolApplyPayoff, hbelow, hcond]
        linarith
      · have hnot_below : ¬ q < school2SubThreshold := not_lt.mpr habove
        have hpayoff : 0 ≤ (v1 - v2) * admissionProbability - cost :=
          hhigh.mpr hcutoff
        have hcond : school2SubThreshold ≤ q ∧ highCutoff ≤ q :=
          ⟨habove, hcutoff⟩
        simp [glm20StrategicTwoSchoolApplyPayoff, hnot_below, hcond]
        linarith
    · simp [glm20StrategicTwoSchoolApplyPayoff, hdecide]
  · have hdecide :
        decide
          ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
            (school2SubThreshold ≤ q ∧ highCutoff ≤ q)) = false := by
      simp [hchosen]
    cases apply
    · simp [glm20StrategicTwoSchoolApplyPayoff, hdecide]
    · by_cases hbelow : q < school2SubThreshold
      · have hnlow : ¬ lowCutoff ≤ q := by
          intro hcut
          exact hchosen (Or.inl ⟨hbelow, hcut⟩)
        have hpayoff_lt : v1 * admissionProbability - cost < 0 := by
          have hnot_nonneg : ¬ 0 ≤ v1 * admissionProbability - cost := by
            intro hnonneg
            exact hnlow (hlow.mp hnonneg)
          exact not_le.mp hnot_nonneg
        have hnot_above : ¬ school2SubThreshold ≤ q := not_le.mpr hbelow
        simp [glm20StrategicTwoSchoolApplyPayoff, hbelow, hnlow, hnot_above]
        linarith
      · have habove : school2SubThreshold ≤ q := le_of_not_gt hbelow
        have hnhigh : ¬ highCutoff ≤ q := by
          intro hcut
          exact hchosen (Or.inr ⟨habove, hcut⟩)
        have hpayoff_lt : (v1 - v2) * admissionProbability - cost < 0 := by
          have hnot_nonneg :
              ¬ 0 ≤ (v1 - v2) * admissionProbability - cost := by
            intro hnonneg
            exact hnhigh (hhigh.mp hnonneg)
          exact not_le.mp hnot_nonneg
        simp [glm20StrategicTwoSchoolApplyPayoff, hbelow, hnhigh]
        linarith

/--
Proposition 2 student-region best-response support with the low cost-ratio
domain derived from the high cost-ratio domain and `0 < v1 - v2 < v1`.
-/
theorem paper_proposition2_two_school_application_region_bestResponse_standardGaussian_of_high_cost_ratio
    (Q : StandardGaussianQuantileAPI)
