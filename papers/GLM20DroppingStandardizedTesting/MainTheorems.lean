/--
Proposition 5(ii), standard-Gaussian equation-(46) version of the low/high
threshold construction.

This theorem no longer asks callers to provide selected full/full
zero-payoff cutoff functions.  Lean constructs the low and high selected
cutoffs from equation (46), proves their regularity from the zero-payoff
equation, and then packages the endpoint-crossing assumptions needed to obtain
the paper's two thresholds and their ordering.
-/
theorem
    paper_proposition5_low_and_high_cost_thresholds_of_standardGaussian_twoFull_merit_crossings_interval
    {Group : Type*}
    {leftCost rightCost : Group → ℝ}
    {lowQ1Full lowQ2Full lowScale lowV1 lowV2 : Group → ℝ}
    {highQ1Full highQ2Full highScale highV1 highV2 : Group → ℝ}
    (lowMeritOfCutoff : Group → ℝ → ℝ)
    (lowTestFreeMerit : Group → ℝ)
    (highMeritOfCutoff : Group → ℝ → ℝ)
    (highTestFreeMerit : Group → ℝ)
    (hleft_right : ∀ g, leftCost g < rightCost g)
    (hleft_pos : ∀ g, 0 < leftCost g)
    (hlowScale : ∀ g, 0 < lowScale g)
    (hlowV2Pos : ∀ g, 0 < lowV2 g)
    (hlowV2LtV1 : ∀ g, lowV2 g < lowV1 g)
    (hlowRightLtV1 : ∀ g, rightCost g < lowV1 g)
    (hlowMeritCont : ∀ g, Continuous (lowMeritOfCutoff g))
    (hlowMeritAnti : ∀ g, StrictAnti (lowMeritOfCutoff g))
    (hhighScale : ∀ g, 0 < highScale g)
    (hhighV2Pos : ∀ g, 0 < highV2 g)
    (hhighV2LtV1 : ∀ g, highV2 g < highV1 g)
    (hhighRightLtV1 : ∀ g, rightCost g < highV1 g)
    (hhighMeritCont : ∀ g, Continuous (highMeritOfCutoff g))
    (hhighMeritAnti : ∀ g, StrictAnti (highMeritOfCutoff g)) :
    ∃ lowCutoffOfCost highCutoffOfCost : Group → ℝ → ℝ,
      (∀ g cost, cost ∈ Set.Icc (leftCost g) (rightCost g) →
        glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          (lowQ1Full g) (lowQ2Full g) (lowScale g) (lowV1 g)
          (lowV2 g) cost (lowCutoffOfCost g cost) = 0 ∧
          ∀ q : ℝ,
            0 ≤
                glm20StrategicTwoFullPolicyApplyPayoffValue
                  standardGaussianCDFAPI (lowQ1Full g) (lowQ2Full g)
                  (lowScale g) (lowV1 g) (lowV2 g) cost q ↔
              lowCutoffOfCost g cost ≤ q) ∧
        (∀ g cost, cost ∈ Set.Icc (leftCost g) (rightCost g) →
          glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
            (highQ1Full g) (highQ2Full g) (highScale g) (highV1 g)
            (highV2 g) cost (highCutoffOfCost g cost) = 0 ∧
            ∀ q : ℝ,
              0 ≤
                  glm20StrategicTwoFullPolicyApplyPayoffValue
                    standardGaussianCDFAPI (highQ1Full g) (highQ2Full g)
                    (highScale g) (highV1 g) (highV2 g) cost q ↔
                highCutoffOfCost g cost ≤ q) ∧
          (∀ g,
            ContinuousOn (lowCutoffOfCost g)
              (Set.Icc (leftCost g) (rightCost g))) ∧
            (∀ g,
              ContinuousOn (highCutoffOfCost g)
                (Set.Icc (leftCost g) (rightCost g))) ∧
              (∀ g,
                StrictMonoOn (lowCutoffOfCost g)
                  (Set.Icc (leftCost g) (rightCost g))) ∧
                (∀ g,
                  StrictMonoOn (highCutoffOfCost g)
                    (Set.Icc (leftCost g) (rightCost g))) ∧
                  ((∀ g,
                    lowTestFreeMerit g <
                      lowMeritOfCutoff g
                        (lowCutoffOfCost g (leftCost g))) →
                    (∀ g,
                      lowMeritOfCutoff g
                          (lowCutoffOfCost g (rightCost g)) <
                        lowTestFreeMerit g) →
                    (∀ g,
                      highTestFreeMerit g <
                        highMeritOfCutoff g
                          (highCutoffOfCost g (leftCost g))) →
                    (∀ g,
                      highMeritOfCutoff g
                          (highCutoffOfCost g (rightCost g)) <
                        highTestFreeMerit g) →
                    (∀ g c,
                      c ∈ Set.Ioo (leftCost g) (rightCost g) →
                        lowMeritOfCutoff g (lowCutoffOfCost g c) =
                            lowTestFreeMerit g →
                          highTestFreeMerit g <
                            highMeritOfCutoff g
                              (highCutoffOfCost g c)) →
                    ∃ lowCostThreshold highCostThreshold : Group → ℝ,
                      (∀ g, lowCostThreshold g ∈
                        Set.Ioo (leftCost g) (rightCost g)) ∧
                        (∀ g, highCostThreshold g ∈
                          Set.Ioo (leftCost g) (rightCost g)) ∧
                          (∀ g,
                            lowMeritOfCutoff g
                                (lowCutoffOfCost g
                                  (lowCostThreshold g)) =
                              lowTestFreeMerit g) ∧
                            (∀ g,
                              highMeritOfCutoff g
                                  (highCutoffOfCost g
                                    (highCostThreshold g)) =
                                highTestFreeMerit g) ∧
                              (∀ g c, c ∈
                                  Set.Icc (leftCost g) (rightCost g) →
                                (lowMeritOfCutoff g
                                      (lowCutoffOfCost g c) ≤
                                    lowTestFreeMerit g ↔
                                  lowCostThreshold g ≤ c)) ∧
                                (∀ g c, c ∈
                                    Set.Icc (leftCost g) (rightCost g) →
                                  (highTestFreeMerit g <
                                      highMeritOfCutoff g
                                        (highCutoffOfCost g c) ↔
                                    c < highCostThreshold g)) ∧
                                  (∀ g c, c ∈
                                      Set.Icc (leftCost g) (rightCost g) →
                                    (highTestFreeMerit g ≤
                                        highMeritOfCutoff g
                                          (highCutoffOfCost g c) ↔
                                      c ≤ highCostThreshold g)) ∧
                                    (∀ g, 0 < lowCostThreshold g) ∧
                                      (∀ g,
                                        lowCostThreshold g <
                                          highCostThreshold g)) := by
  classical
  rcases
    paper_proposition5_standardGaussian_twoFull_cost_merit_regular_of_global_regular_cost_bounds
      (q1Full := lowQ1Full) (q2Full := lowQ2Full)
      (scale := lowScale) (v1 := lowV1) (v2 := lowV2)
      (left := leftCost) (right := rightCost)
      (meritOfCutoff := lowMeritOfCutoff)
      hlowScale hlowV2Pos hlowV2LtV1 hleft_pos hlowRightLtV1
      hlowMeritCont hlowMeritAnti with
    ⟨lowCutoffOfCost, hlowZero, hlowCont, hlowMono,
      _hlowMeritContOn, _hlowMeritAntiOn⟩
  rcases
    paper_proposition5_standardGaussian_twoFull_cost_merit_regular_of_global_regular_cost_bounds
      (q1Full := highQ1Full) (q2Full := highQ2Full)
      (scale := highScale) (v1 := highV1) (v2 := highV2)
      (left := leftCost) (right := rightCost)
      (meritOfCutoff := highMeritOfCutoff)
      hhighScale hhighV2Pos hhighV2LtV1 hleft_pos hhighRightLtV1
      hhighMeritCont hhighMeritAnti with
    ⟨highCutoffOfCost, hhighZero, hhighCont, hhighMono,
      _hhighMeritContOn, _hhighMeritAntiOn⟩
  refine
    ⟨lowCutoffOfCost, highCutoffOfCost, hlowZero, hhighZero, hlowCont,
      hhighCont, hlowMono, hhighMono, ?_⟩
  intro hlowAtLeft hlowAtRight hhighAtLeft hhighAtRight hhighAtLowRoot
  exact
    paper_proposition5_low_and_high_cost_thresholds_of_selected_twoFull_merit_crossings_interval
      (lowCutoffOfCost := lowCutoffOfCost)
      (highCutoffOfCost := highCutoffOfCost)
      (lowMeritOfCutoff := lowMeritOfCutoff)
      (lowTestFreeMerit := lowTestFreeMerit)
      (highMeritOfCutoff := highMeritOfCutoff)
      (highTestFreeMerit := highTestFreeMerit)
      hleft_right hleft_pos hlowScale hlowV2Pos hlowV2LtV1
      (fun g cost hcost => (hlowZero g cost hcost).1)
      hlowMeritCont hlowMeritAnti hhighScale hhighV2Pos hhighV2LtV1
      (fun g cost hcost => (hhighZero g cost hcost).1)
      hhighMeritCont hhighMeritAnti hlowAtLeft hlowAtRight hhighAtLeft
      hhighAtRight hhighAtLowRoot

/--
Proposition 5(ii), school-`J2`, with both condition-(13) thresholds
constructed from merit crossings.

Compared with
`paper_proposition5_part_ii_school2_cutoff_objective_iff_exactly_one_cost_case_of_low_merit_crossings`,
this theorem no longer takes an externally supplied high threshold or a
separate `c_hat'_g < c_hat''_g` premise.  It constructs both roots and proves
the ordering from the source proof's high-merit-at-low-root comparison.
-/
theorem
    paper_proposition5_part_ii_school2_cutoff_objective_iff_exactly_one_cost_case_of_low_and_high_merit_crossings
    {Group Policy : Type*}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost maxCost : Group → ℝ} {q2Sub : ℝ}
    {fullFullCutoff : Group → ℝ}
    (objective2 : Policy → Policy → ℝ)
    (lowTestBasedMerit : Group → ℝ → ℝ) (lowTestFreeMerit : Group → ℝ)
    (highTestBasedMerit : Group → ℝ → ℝ) (highTestFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hlowCont :
      ∀ g, ContinuousOn (lowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAnti :
