      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False)
    (honlyA_J1_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            meritOfCutoff groupA
                (q2Full groupA -
                  scale groupA *
                    Q.quantile (1 - testCost groupA / v2 groupA)) ≤
