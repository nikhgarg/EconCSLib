theorem
    paper_proposition5_part_i_school1_cutoff_objective_iff_exactly_one_cost_case_of_merit_crossings_interval
    {Group Policy : Type*}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost leftCost rightCost : Group → ℝ} {q1Sub : ℝ}
