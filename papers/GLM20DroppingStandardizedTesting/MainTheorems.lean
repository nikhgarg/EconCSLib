              priorPrecision subPrecisionSum fullPrecisionSum)
            mu q1Full /
          glm20Proposition2J2MassBetweenCutoffs standardGaussianCDFAPI
            standardBivariateGaussianCDF
            populationShare mu priorSigma priorPrecision subPrecisionSum
            q2Sub
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            q1Full :=
  paper_proposition2_part_iii_diversity_criterion_between_cutoffs_of_subEligibleMass
    hmore hj1 hj2 hcapacity1 hcapacity2 hpopulation hsigma hA hsub

/--
Paper Proposition 2(iii), above-high-cutoff case, with `\tilde\sigma_g > 0`
discharged from the source precision assumptions.
-/
theorem
    paper_proposition2_part_iii_diversity_criterion_above_high_cutoff_source_parameters_of_positive_precisions_and_subEligibleMass
    {j1MoreDiverse : Prop}
    {j1Diversity j2Diversity capacity1 capacity2 : ℝ}
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum qLow q2Sub q1Full : ℝ}
    (hmore : j1MoreDiverse ↔ j2Diversity < j1Diversity)
    (hj1 :
      j1Diversity =
        glm20Proposition2J1MassAboveHighCutoff standardGaussianCDFAPI
            standardBivariateGaussianCDF
            populationShare
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu qLow)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            mu q1Full /
          capacity1)
    (hj2 :
      j2Diversity =
        glm20Proposition2J2MassAboveHighCutoff standardGaussianCDFAPI
            standardBivariateGaussianCDF
            populationShare mu priorSigma priorPrecision subPrecisionSum
            q2Sub
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            q1Full /
          capacity2)
    (hcapacity1 : 0 < capacity1)
    (hcapacity2 : 0 < capacity2)
    (hpopulation : 0 < populationShare)
    (hpriorSigma : 0 < priorSigma)
    (hpriorPrecision : 0 < priorPrecision)
    (hfullPrecision : 0 < fullPrecisionSum)
    (hsub :
      glm20Proposition2SubEligibleMassFormula standardGaussianCDFAPI
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub =
          populationShare *
            glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum *
            standardGaussianCDF
              ((glm20Proposition2AHatSource
                    priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub +
                  glm20Proposition3BSource
                    priorPrecision subPrecisionSum fullPrecisionSum * mu) /
                Real.sqrt
                  (1 +
                    glm20Proposition3SigmaTildeSource
                        priorSigma priorPrecision fullPrecisionSum ^ 2 *
                      glm20Proposition3BSource
                        priorPrecision subPrecisionSum fullPrecisionSum ^ 2))) :
    j1MoreDiverse ↔
      capacity1 / capacity2 <
        glm20Proposition2J1MassAboveHighCutoff standardGaussianCDFAPI
            standardBivariateGaussianCDF
            populationShare
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu qLow)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            mu q1Full /
          glm20Proposition2J2MassAboveHighCutoff standardGaussianCDFAPI
            standardBivariateGaussianCDF
            populationShare mu priorSigma priorPrecision subPrecisionSum
            q2Sub
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            q1Full :=
  paper_proposition2_part_iii_diversity_criterion_above_high_cutoff_source_parameters_of_subEligibleMass
    hmore hj1 hj2 hcapacity1 hcapacity2 hpopulation
    (glm20Proposition3SigmaTildeSource_pos
      hpriorSigma hpriorPrecision hfullPrecision)
    hsub

/--
Paper Proposition 2(iii), between-cutoffs case, with both residual source
premises discharged except the source eligible-mass substitution itself:
`\tilde\sigma_g > 0` follows from positive precisions, and the affine CDF
argument order follows from `q_{2,sub}^* <= q_h^g`.
-/
theorem
    paper_proposition2_part_iii_diversity_criterion_between_cutoffs_source_parameters_of_positive_precisions_ordered_cutoffs_and_subEligibleMass
    {j1MoreDiverse : Prop}
    {j1Diversity j2Diversity capacity1 capacity2 : ℝ}
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum qLow qHigh q2Sub q1Full : ℝ}
    (hmore : j1MoreDiverse ↔ j2Diversity < j1Diversity)
    (hj1 :
      j1Diversity =
        glm20Proposition2J1MassBetweenCutoffs standardGaussianCDFAPI
            standardBivariateGaussianCDF
            populationShare
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu qLow)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            mu q1Full /
          capacity1)
    (hj2 :
      j2Diversity =
        glm20Proposition2J2MassBetweenCutoffs standardGaussianCDFAPI
            standardBivariateGaussianCDF
            populationShare mu priorSigma priorPrecision subPrecisionSum
            q2Sub
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            q1Full /
          capacity2)
    (hcapacity1 : 0 < capacity1)
    (hcapacity2 : 0 < capacity2)
    (hpopulation : 0 < populationShare)
    (hpriorSigma : 0 < priorSigma)
    (hpriorPrecision : 0 < priorPrecision)
    (hsubPrecision : 0 < subPrecisionSum)
    (hfullPrecision : 0 < fullPrecisionSum)
    (hq2_le_high : q2Sub ≤ qHigh)
    (hsub :
      glm20Proposition2SubEligibleMassFormula standardGaussianCDFAPI
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub =
          populationShare *
            glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum *
            standardGaussianCDF
              ((glm20Proposition2AHatSource
                    priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub +
                  glm20Proposition3BSource
                    priorPrecision subPrecisionSum fullPrecisionSum * mu) /
                Real.sqrt
                  (1 +
                    glm20Proposition3SigmaTildeSource
                        priorSigma priorPrecision fullPrecisionSum ^ 2 *
                      glm20Proposition3BSource
                        priorPrecision subPrecisionSum fullPrecisionSum ^ 2))) :
    j1MoreDiverse ↔
      capacity1 / capacity2 <
        glm20Proposition2J1MassBetweenCutoffs standardGaussianCDFAPI
            standardBivariateGaussianCDF
            populationShare
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu qLow)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
            (glm20Proposition2AHatSource
              priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
