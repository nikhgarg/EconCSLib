        Q (hscale g) hv2 hcostRatio (by intro cost hcost; simp)
        (hmerit_cont g).continuousOn
        (by
          intro x _hx y _hy hxy
          exact hmerit_anti g hxy)).1
  · intro g
    have hv2 : 0 < v2 g := by
      linarith [hleft_pos g, hleft_right g, hright_lt_v2 g]
