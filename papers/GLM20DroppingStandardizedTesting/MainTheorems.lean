/--
Proposition 5 support: the "both groups satisfy the full/full cutoff case"
branch is impossible when capacity is filled by the full/full applicant pool.

Source proof line: if both full/full cutoffs lie above the test-free admission
threshold, then strict antitonicity of the upper-tail mass `K_g` makes the
weighted full/full applicant mass strictly smaller than the capacity equation
computed at the test-free threshold, contradicting the filled-capacity premise.
-/
theorem paper_proposition5_both_fullFull_cutoff_cases_impossible_of_weighted_capacity
    {Group : Type*} {groupA groupB : Group}
    {populationShare : Group → ℝ} {capacity qSub : ℝ}
    {K : Group → ℝ → ℝ} {fullFullCutoff massFullFull : Group → ℝ}
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hKantiA : StrictAnti (K groupA))
    (hKantiB : StrictAnti (K groupB))
    (hmassA : massFullFull groupA = K groupA (fullFullCutoff groupA))
    (hmassB : massFullFull groupB = K groupB (fullFullCutoff groupB))
    (hcapacity :
      capacity =
        populationShare groupA * K groupA qSub +
          populationShare groupB * K groupB qSub)
    (hfill :
      capacity ≤
        populationShare groupA * massFullFull groupA +
          populationShare groupB * massFullFull groupB)
    (hcutoffA : qSub < fullFullCutoff groupA)
    (hcutoffB : qSub < fullFullCutoff groupB) : False := by
  have hltA : K groupA (fullFullCutoff groupA) < K groupA qSub :=
    hKantiA hcutoffA
  have hltB : K groupB (fullFullCutoff groupB) < K groupB qSub :=
    hKantiB hcutoffB
  have hmass_ltA :
      populationShare groupA * massFullFull groupA <
        populationShare groupA * K groupA qSub := by
    rw [hmassA]
    exact mul_lt_mul_of_pos_left hltA hshareA
  have hmass_ltB :
      populationShare groupB * massFullFull groupB <
        populationShare groupB * K groupB qSub := by
    rw [hmassB]
    exact mul_lt_mul_of_pos_left hltB hshareB
  have hsum_lt :
      populationShare groupA * massFullFull groupA +
          populationShare groupB * massFullFull groupB <
        capacity := by
    rw [hcapacity]
    exact add_lt_add hmass_ltA hmass_ltB
  linarith

