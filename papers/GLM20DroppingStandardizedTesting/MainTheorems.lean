        intro hcut hnot
        simpa [testBasedMerit] using honlyA_J1_merit hcut hnot)
      (by
        intro hcut hnot
        simpa [testBasedMerit] using honlyB_J1_merit hcut hnot)
      hJ2ObjectiveSubSub hJ2ObjectiveSubFullB hJ2MassB hJ2NotTieB
      hJ2ObjectiveSubFullA hJ2MassA hJ2NotTieA)

/--
Proposition 5(i) / Theorem 3(i), equation-(50) source form with the
paper's full/full capacity-fill contradiction.

This combines the equation-(50) Gaussian cutoff substitution with the source
capacity equation at `q^*_{1,sub}`.  Thus the both-groups full/full branch is
derived from capacity rather than passed as a separate case-analysis premise.
-/
theorem
    paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_equation50_merit_crossings_interval_and_capacity
    (Q : StandardGaussianQuantileAPI)
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost leftCost rightCost q2Full scale v2 :
      Group → ℝ}
    {capacity1 capacity2 q1Sub : ℝ}
    (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (meritOfCutoff : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hleftRight : ∀ g, leftCost g < rightCost g)
    (hscale : ∀ g, 0 < scale g)
    (hleftPos : ∀ g, 0 < leftCost g)
    (hrightLtV2 : ∀ g, rightCost g < v2 g)
    (hcostMem :
      ∀ g, testCost g ∈ Set.Icc (leftCost g) (rightCost g))
    (hmerit_cont : ∀ g, Continuous (meritOfCutoff g))
    (hmerit_anti : ∀ g, StrictAnti (meritOfCutoff g))
    (hlowCost :
      ∀ g,
        testFreeMerit g <
          meritOfCutoff g
            (q2Full g - scale g * Q.quantile (1 - leftCost g / v2 g)))
    (hhighCost :
      ∀ g,
        meritOfCutoff g
            (q2Full g -
              scale g * Q.quantile (1 - rightCost g / v2 g)) <
          testFreeMerit g)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove Q.cdfAPI
          (subEstimateLaw groupA) (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove Q.cdfAPI
          (subEstimateLaw groupB) (fullFullCutoff groupB))
    (hcapacity1 :
      capacity1 =
        populationShare groupA *
            glm20StrategicSubEstimateMassAbove Q.cdfAPI
              (subEstimateLaw groupA) q1Sub +
          populationShare groupB *
            glm20StrategicSubEstimateMassAbove Q.cdfAPI
              (subEstimateLaw groupB) q1Sub)
    (hfillFullFull1 :
      capacity1 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hnoneJ1 :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ objective1 Pfull Pfull ≤ objective1 Psub Pfull)
    (honlyA_J1_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            meritOfCutoff groupA
                (q2Full groupA -
                  scale groupA *
                    Q.quantile (1 - testCost groupA / v2 groupA)) ≤
              testFreeMerit groupA))
    (honlyB_J1_merit :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            meritOfCutoff groupB
                (q2Full groupB -
                  scale groupB *
                    Q.quantile (1 - testCost groupB / v2 groupB)) ≤
              testFreeMerit groupB))
    (hJ2ObjectiveSubSub :
      objective2 Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove Q.cdfAPI
              (subEstimateLaw g) q)
          groupA →
        objective2 Psub Pfull =
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull))
    (hJ2MassB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove Q.cdfAPI
              (subEstimateLaw g) q)
          groupA →
        S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2)
    (hJ2NotTieB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove Q.cdfAPI
              (subEstimateLaw g) q)
          groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove Q.cdfAPI
              (subEstimateLaw g) q)
          groupB →
        objective2 Psub Pfull =
          populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull))
    (hJ2MassA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove Q.cdfAPI
              (subEstimateLaw g) q)
          groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2)
    (hJ2NotTieA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove Q.cdfAPI
              (subEstimateLaw g) q)
          groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :
    ∃ costThreshold : Group → ℝ,
      (∀ g, costThreshold g ∈ Set.Ioo (leftCost g) (rightCost g)) ∧
        (∀ g,
          meritOfCutoff g
              (q2Full g -
                scale g * Q.quantile (1 - costThreshold g / v2 g)) =
            testFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (leftCost g) (rightCost g) →
            (meritOfCutoff g
                (q2Full g - scale g * Q.quantile (1 - c / v2 g)) ≤
                testFreeMerit g ↔
              costThreshold g ≤ c)) ∧
            ((objective1 Pfull Pfull ≤ objective1 Psub Pfull ∧
                objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
              glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
                groupA groupB populationShare testCost costThreshold
                capacity2 q1Sub
                (fun g q =>
                  glm20StrategicSubEstimateMassAbove Q.cdfAPI
                    (subEstimateLaw g) q)) := by
  have hbothJ1_impossible :
      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False :=
    paper_proposition5_part_i_both_fullFull_cutoff_cases_impossible_of_capacity
      (S := S) (policyPair := policyPair) (Pfull := Pfull)
      (populationShare := populationShare) (capacity1 := capacity1)
      (q1Sub := q1Sub) Q.cdfAPI subEstimateLaw hshareA hshareB
      hmassFullFullA hmassFullFullB hcapacity1 hfillFullFull1
  exact
    paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_equation50_merit_crossings_interval
      Q (S := S) (policyPair := policyPair) (Psub := Psub)
      (Pfull := Pfull) (J2 := J2) (groupA := groupA)
      (groupB := groupB) (populationShare := populationShare)
      (testCost := testCost) (leftCost := leftCost)
      (rightCost := rightCost) (q2Full := q2Full) (scale := scale)
      (v2 := v2) (capacity2 := capacity2) (q1Sub := q1Sub)
      subEstimateLaw (fullFullCutoff := fullFullCutoff) objective1
      objective2 meritOfCutoff testFreeMerit hleftRight hscale hleftPos
      hrightLtV2 hcostMem hmerit_cont hmerit_anti hlowCost hhighCost
      hmassFullFullA hmassFullFullB hnoneJ1 hbothJ1_impossible
      honlyA_J1_merit honlyB_J1_merit hJ2ObjectiveSubSub
      hJ2ObjectiveSubFullB hJ2MassB hJ2NotTieB hJ2ObjectiveSubFullA
      hJ2MassA hJ2NotTieA

/--
Proposition 5(i) / Theorem 3(i) positive-interval objective bridge, with
condition (12)'s strict school-`J2` merit comparison as the input.

This is the interval-domain analogue of
`paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_strict_merit`.
It discharges the no-tie side condition from the paper's strict weighted-merit
inequality while keeping the school-`J1` cutoff threshold on
`[leftCost_g,rightCost_g]`.
-/
abbrev
    paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_interval_strict_merit
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost leftCost rightCost : Group → ℝ}
    {capacity2 q1Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hleftRight : ∀ g, leftCost g < rightCost g)
    (hleftPos : ∀ g, 0 < leftCost g)
    (hcostMem :
      ∀ g, testCost g ∈ Set.Icc (leftCost g) (rightCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g)
        (Set.Icc (leftCost g) (rightCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g)
        (Set.Icc (leftCost g) (rightCost g)))
    (hlowCost :
      ∀ g, testFreeMerit g < testBasedMerit g (leftCost g))
    (hhighCost :
      ∀ g, testBasedMerit g (rightCost g) < testFreeMerit g)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hnoneJ1 :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ objective1 Pfull Pfull ≤ objective1 Psub Pfull)
    (hbothJ1_impossible :
      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False)
    (honlyA_J1_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupA (testCost groupA) ≤
              testFreeMerit groupA))
    (honlyB_J1_merit :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupB (testCost groupB) ≤
              testFreeMerit groupB))
    (hJ2ObjectiveSubSub :
      objective2 Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        objective2 Psub Pfull =
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull))
    (hJ2MassB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2)
    (hJ2MeritGtB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) >
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        objective2 Psub Pfull =
          populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull))
    (hJ2MassA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2)
    (hJ2MeritGtA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) >
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :=
  paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_interval
    (S := S) (policyPair := policyPair) (Psub := Psub) (Pfull := Pfull)
    (J2 := J2) (groupA := groupA) (groupB := groupB)
    (populationShare := populationShare) (testCost := testCost)
    (leftCost := leftCost) (rightCost := rightCost)
    (capacity2 := capacity2) (q1Sub := q1Sub) api subEstimateLaw
    objective1 objective2 testBasedMerit testFreeMerit hleftRight
    hleftPos hcostMem hcont hanti hlowCost hhighCost hmassFullFullA
    hmassFullFullB hnoneJ1 hbothJ1_impossible honlyA_J1_merit
    honlyB_J1_merit hJ2ObjectiveSubSub hJ2ObjectiveSubFullB hJ2MassB
    (by
      intro costThreshold hdropA
      exact ne_of_gt (hJ2MeritGtB costThreshold hdropA))
    hJ2ObjectiveSubFullA hJ2MassA
    (by
      intro costThreshold hdropB
      exact ne_of_gt (hJ2MeritGtA costThreshold hdropB))

/--
Proposition 5(i) / Theorem 3(i) bridge with mass feasibility split from the
school-`J2` merit objective.

This is the capacity-aware variant needed for the concrete strategic game:
condition (11) should be carried by the school-`J2` feasibility part of the
policy-pair equilibrium, while condition (12) is carried by the `J2` objective
comparison.  Unlike
`paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition`, this
lemma does not assume the other group's mass condition as a premise of the
objective comparison bridge.
-/
theorem paper_proposition5_part_i_objective_mass_pair_iff_theorem3_subFull_condition
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost costThreshold : Group → ℝ}
    {capacity2 q1Sub : ℝ} {K : Group → ℝ → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (hJ1 :
      (objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3SubFullGroupExpandsByDropping S policyPair
            Psub Pfull testCost costThreshold q1Sub K))
    (hJ2A_merit :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupA →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) >
            populationShare groupA *
                S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
              populationShare groupB *
                S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)))
    (hJ2B_merit :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupB →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) >
            populationShare groupA *
                S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
              populationShare groupB *
                S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))) :
    (objective1 Pfull Pfull ≤ objective1 Psub Pfull ∧
        (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
            testCost costThreshold q1Sub K groupA →
          S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2) ∧
        (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
            testCost costThreshold q1Sub K groupB →
          S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2) ∧
        objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
      glm20Theorem3SubFullCondition S policyPair Psub Pfull J2 groupA groupB
        populationShare testCost costThreshold capacity2 q1Sub K := by
  let expands :=
    glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
      testCost costThreshold q1Sub K
  let keeps :=
    glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull J2
      groupA groupB populationShare capacity2
  change
    (objective1 Pfull Pfull ≤ objective1 Psub Pfull ∧
        (expands groupA →
          S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2) ∧
        (expands groupB →
          S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2) ∧
        objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
      glm20ExactlyOneOfTwo groupA groupB expands ∧
        (expands groupA → keeps groupB) ∧
          (expands groupB → keeps groupA)
  constructor
  · rintro ⟨hobj1, hmassB, hmassA, hobj2⟩
    have hexact : glm20ExactlyOneOfTwo groupA groupB expands := by
      simpa [expands] using hJ1.mp hobj1
    refine ⟨hexact, ?_, ?_⟩
    · intro hA
      have hA' :
          glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
            testCost costThreshold q1Sub K groupA := by
        simpa [expands] using hA
      exact ⟨hmassB hA,
        by simpa [keeps, expands] using (hJ2A_merit hA').mp hobj2⟩
    · intro hB
      have hB' :
          glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
            testCost costThreshold q1Sub K groupB := by
        simpa [expands] using hB
      exact ⟨hmassA hB,
        by simpa [keeps, expands] using (hJ2B_merit hB').mp hobj2⟩
  · rintro ⟨hexact, hAkeeps, hBkeeps⟩
    have hobj1 : objective1 Pfull Pfull ≤ objective1 Psub Pfull :=
      hJ1.mpr (by simpa [expands] using hexact)
    have hmassB : expands groupA →
        S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2 := by
      intro hA
      exact (hAkeeps hA).1
    have hmassA : expands groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2 := by
      intro hB
      exact (hBkeeps hB).1
    have hobj2 : objective2 Psub Psub ≤ objective2 Psub Pfull := by
      rcases hexact with ⟨hA, _hnotB⟩ | ⟨hB, _hnotA⟩
      · have hA' :
            glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
              testCost costThreshold q1Sub K groupA := by
          simpa [expands] using hA
        exact (hJ2A_merit hA').mpr (hAkeeps hA).2
      · have hB' :
            glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
              testCost costThreshold q1Sub K groupB := by
          simpa [expands] using hB
        exact (hJ2B_merit hB').mpr (hBkeeps hB).2
    exact ⟨hobj1, hmassB, hmassA, hobj2⟩

/--
Theorem 3(i) bridge for the feasibility-aware weighted binary surface.

This composes the feasible-surface characterization with
`paper_proposition5_part_i_objective_mass_pair_iff_theorem3_subFull_condition`.
The school-`J2` current feasibility predicate at `(P_sub,P_full)` is required
to be exactly the pair of condition-(11) mass implications, while the school-`J2`
objective comparison is required to be exactly the condition-(12) merit
comparison in the active exactly-one branch.
-/
theorem paper_theorem3_subFull_condition_of_feasible_weighted_surface_objective_mass_bridges
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost costThreshold : Group → ℝ}
    {capacity2 q1Sub : ℝ} {K : Group → ℝ → ℝ}
    {feasible1 feasible2 : Policy → Policy → Prop}
    (hS :
      S =
        glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
          groupB populationShare feasible1 feasible2)
    (hfeasible1SubFull : feasible1 Psub Pfull)
    (hfeasible1FullFull : feasible1 Pfull Pfull)
    (hfeasible2SubSub : feasible2 Psub Psub)
    (hfeasible2SubFull :
      feasible2 Psub Pfull ↔
        (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
            testCost costThreshold q1Sub K groupA →
          S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2) ∧
        (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
            testCost costThreshold q1Sub K groupB →
          S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2))
    (hJ1 :
      (glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare Pfull Pfull ≤
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare Psub Pfull) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3SubFullGroupExpandsByDropping S policyPair
            Psub Pfull testCost costThreshold q1Sub K))
    (hJ2A_merit :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupA →
        ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare Psub Psub ≤
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare Psub Pfull) ↔
          populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) >
            populationShare groupA *
                S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
              populationShare groupB *
                S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)))
    (hJ2B_merit :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupB →
        ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare Psub Psub ≤
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare Psub Pfull) ↔
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) >
            populationShare groupA *
                S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
              populationShare groupB *
                S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))) :
    S.policyPairIsEquilibrium Psub Pfull ↔
      glm20Theorem3SubFullCondition S policyPair Psub Pfull J2 groupA groupB
        populationShare testCost costThreshold capacity2 q1Sub K := by
  subst S
  let Surf :=
    glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
      admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
      groupB populationShare feasible1 feasible2
  let objective1 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective Surf policyPair J1 groupA
      groupB populationShare
  let objective2 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective Surf policyPair J2 groupA
      groupB populationShare
  have hsplit :
      (objective1 Pfull Pfull ≤ objective1 Psub Pfull ∧
          (glm20Theorem3SubFullGroupExpandsByDropping Surf policyPair Psub
              Pfull testCost costThreshold q1Sub K groupA →
            Surf.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2) ∧
          (glm20Theorem3SubFullGroupExpandsByDropping Surf policyPair Psub
              Pfull testCost costThreshold q1Sub K groupB →
            Surf.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2) ∧
          objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
        glm20Theorem3SubFullCondition Surf policyPair Psub Pfull J2
          groupA groupB populationShare testCost costThreshold capacity2
          q1Sub K :=
    paper_proposition5_part_i_objective_mass_pair_iff_theorem3_subFull_condition
      (S := Surf) (policyPair := policyPair) (Psub := Psub)
      (Pfull := Pfull) (J2 := J2) (groupA := groupA) (groupB := groupB)
      (populationShare := populationShare) (testCost := testCost)
      (costThreshold := costThreshold) (capacity2 := capacity2)
      (q1Sub := q1Sub) (K := K) objective1 objective2 hJ1 hJ2A_merit
      hJ2B_merit
  have hsurface :
      Surf.policyPairIsEquilibrium Psub Pfull ↔
        feasible1 Psub Pfull ∧ feasible2 Psub Pfull ∧
          (feasible1 Pfull Pfull → objective1 Pfull Pfull ≤
            objective1 Psub Pfull) ∧
            (feasible2 Psub Psub → objective2 Psub Psub ≤
              objective2 Psub Pfull) := by
    simpa [Surf, objective1, objective2] using
      (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface_subFull_iff
        (massTestTaking := massTestTaking)
        (admittedAcademicMerit := admittedAcademicMerit)
        (diversity := diversity) (policyPair := policyPair)
        (Psub := Psub) (Pfull := Pfull) (J1 := J1) (J2 := J2)
        (groupA := groupA) (groupB := groupB)
        (populationShare := populationShare) (feasible1 := feasible1)
        (feasible2 := feasible2))
  refine hsurface.trans ?_
  refine Iff.trans ?_ hsplit
  constructor
  · rintro ⟨_hf1cur, hf2cur, hobj1_of_feas, hobj2_of_feas⟩
    have hmass := hfeasible2SubFull.mp hf2cur
    exact ⟨hobj1_of_feas hfeasible1FullFull, hmass.1, hmass.2,
      hobj2_of_feas hfeasible2SubSub⟩
  · rintro ⟨hobj1, hmassB, hmassA, hobj2⟩
    exact ⟨hfeasible1SubFull, hfeasible2SubFull.mpr ⟨hmassB, hmassA⟩,
      (fun _ => hobj1), (fun _ => hobj2)⟩

/--
Theorem 3(i) bridge for a feasible weighted binary surface from an already
assembled objective-pair equivalence.

Use this when a Proposition 5(i) wrapper has already proved that the two school
objective comparisons are equivalent to the full Theorem 3(i) condition.  The
bridge adds the surface feasibility bookkeeping, including the condition-(11)
mass implications encoded in school `J2`'s current feasibility predicate.
-/
theorem
    paper_theorem3_subFull_condition_of_feasible_weighted_surface_objective_pair_bridge
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost costThreshold : Group → ℝ}
    {capacity2 q1Sub : ℝ} {K : Group → ℝ → ℝ}
    {feasible1 feasible2 : Policy → Policy → Prop}
    (hS :
      S =
        glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
          groupB populationShare feasible1 feasible2)
    (hfeasible1SubFull : feasible1 Psub Pfull)
    (hfeasible1FullFull : feasible1 Pfull Pfull)
    (hfeasible2SubSub : feasible2 Psub Psub)
    (hfeasible2SubFull :
      feasible2 Psub Pfull ↔
        (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
            testCost costThreshold q1Sub K groupA →
          S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2) ∧
        (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
            testCost costThreshold q1Sub K groupB →
          S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2))
    (hobjective :
      ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare Pfull Pfull ≤
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare Psub Pfull) ∧
        (glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare Psub Psub ≤
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare Psub Pfull)) ↔
        glm20Theorem3SubFullCondition S policyPair Psub Pfull J2 groupA
          groupB populationShare testCost costThreshold capacity2 q1Sub K) :
    S.policyPairIsEquilibrium Psub Pfull ↔
      glm20Theorem3SubFullCondition S policyPair Psub Pfull J2 groupA groupB
        populationShare testCost costThreshold capacity2 q1Sub K := by
  subst S
  let Surf :=
    glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
      admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
      groupB populationShare feasible1 feasible2
  let objective1 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective Surf policyPair J1 groupA
      groupB populationShare
  let objective2 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective Surf policyPair J2 groupA
      groupB populationShare
  let expands :=
    glm20Theorem3SubFullGroupExpandsByDropping Surf policyPair Psub Pfull
      testCost costThreshold q1Sub K
  let keeps :=
    glm20Theorem3SubFullOtherGroupKeepsTest Surf policyPair Psub Pfull J2
      groupA groupB populationShare capacity2
  have hsurface :
      Surf.policyPairIsEquilibrium Psub Pfull ↔
        feasible1 Psub Pfull ∧ feasible2 Psub Pfull ∧
          (feasible1 Pfull Pfull → objective1 Pfull Pfull ≤
            objective1 Psub Pfull) ∧
            (feasible2 Psub Psub → objective2 Psub Psub ≤
              objective2 Psub Pfull) := by
    simpa [Surf, objective1, objective2] using
      (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface_subFull_iff
        (massTestTaking := massTestTaking)
        (admittedAcademicMerit := admittedAcademicMerit)
        (diversity := diversity) (policyPair := policyPair)
        (Psub := Psub) (Pfull := Pfull) (J1 := J1) (J2 := J2)
        (groupA := groupA) (groupB := groupB)
        (populationShare := populationShare) (feasible1 := feasible1)
        (feasible2 := feasible2))
  refine hsurface.trans ?_
  constructor
  · rintro ⟨_hf1cur, _hf2cur, hobj1_of_feas, hobj2_of_feas⟩
    exact hobjective.mp
      ⟨hobj1_of_feas hfeasible1FullFull,
        hobj2_of_feas hfeasible2SubSub⟩
  · intro hcond
    have hobj := hobjective.mpr hcond
    have hcond_expanded :
        glm20ExactlyOneOfTwo groupA groupB expands ∧
          (expands groupA → keeps groupB) ∧
            (expands groupB → keeps groupA) := by
      simpa [expands, keeps, glm20Theorem3SubFullCondition] using hcond
    have hmassB : expands groupA →
        Surf.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2 := by
      intro hA
      exact (hcond_expanded.2.1 hA).1
    have hmassA : expands groupB →
        Surf.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2 := by
      intro hB
      exact (hcond_expanded.2.2 hB).1
    exact ⟨hfeasible1SubFull, hfeasible2SubFull.mpr ⟨hmassB, hmassA⟩,
      (fun _ => hobj.1), (fun _ => hobj.2)⟩

/--
Proposition 5(i) / Theorem 3(i), feasibility-aware cost-threshold endpoint.

This constructs the positive condition-(10) threshold from the Proposition 5(i)
merit crossing, proves the school-`J1` cutoff case, and then uses the
feasibility-aware weighted surface to represent condition (11) as school-`J2`
current feasibility.  The only school-`J2` objective assumption left is the
condition-(12) no-tie/merit comparison after rewriting objective values to the
paper's weighted admitted-merit formulas.
-/
theorem
    paper_theorem3_subFull_condition_of_feasible_weighted_surface_merit_crossings_capacity_fixed_pool_and_group_merit_formulas
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity1 capacity2 q1Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff : Group → ℝ}
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    {feasible1 feasible2 : Policy → Policy → Prop}
    (hS :
      S =
        glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
          groupB populationShare feasible1 feasible2)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowCost : ∀ g, testFreeMerit g < testBasedMerit g 0)
    (hhighCost : ∀ g, testBasedMerit g (maxCost g) < testFreeMerit g)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hcapacity1 :
      capacity1 =
        populationShare groupA *
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
              q1Sub +
          populationShare groupB *
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
              q1Sub)
    (hfillFullFull1 :
      capacity1 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hfixedPoolMeritA :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull) <
            S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull))
    (hfixedPoolMeritB :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull) <
            S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull))
    (honlyA_J1_groupB_eq :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull) =
            S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull))
    (honlyA_J1_groupA_testBased :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull) =
            testBasedMerit groupA (testCost groupA))
    (honlyA_J1_groupA_testFree :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull) =
            testFreeMerit groupA)
    (honlyB_J1_groupA_eq :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull) =
            S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull))
    (honlyB_J1_groupB_testBased :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull) =
            testBasedMerit groupB (testCost groupB))
    (honlyB_J1_groupB_testFree :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull) =
            testFreeMerit groupB)
    (hfeasible1SubFull : feasible1 Psub Pfull)
    (hfeasible1FullFull : feasible1 Pfull Pfull)
    (hfeasible2SubSub : feasible2 Psub Psub)
    (hfeasible2SubFull :
      ∀ costThreshold : Group → ℝ,
        feasible2 Psub Pfull ↔
          (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
              testCost costThreshold q1Sub
              (fun g q =>
                glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
              groupA →
            S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2) ∧
          (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
              testCost costThreshold q1Sub
              (fun g q =>
                glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
              groupB →
            S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2))
    (hJ2ZeroA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        populationShare groupA *
          S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) = 0)
    (hJ2NotTieB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ZeroB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        populationShare groupB *
          S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) = 0)
    (hJ2NotTieA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :
    ∃ costThreshold : Group → ℝ,
      (∀ g, costThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, testBasedMerit g (costThreshold g) = testFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (testBasedMerit g c ≤ testFreeMerit g ↔
              costThreshold g ≤ c)) ∧
            (S.policyPairIsEquilibrium Psub Pfull ↔
              glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
                groupA groupB populationShare testCost costThreshold
                capacity2 q1Sub
                (fun g q =>
                  glm20StrategicSubEstimateMassAbove api
                    (subEstimateLaw g) q)) := by
  subst S
  let Surf :=
    glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
      admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
      groupB populationShare feasible1 feasible2
  let K := fun g q =>
    glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q
  let objective1 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective Surf policyPair J1 groupA
      groupB populationShare
  let objective2 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective Surf policyPair J2 groupA
      groupB populationShare
  have hbothJ1_impossible :
      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False :=
    paper_proposition5_part_i_both_fullFull_cutoff_cases_impossible_of_capacity
      (S := Surf) (policyPair := policyPair) (Pfull := Pfull)
      (populationShare := populationShare) (capacity1 := capacity1)
      (q1Sub := q1Sub) api subEstimateLaw hshareA hshareB
      hmassFullFullA hmassFullFullB hcapacity1 hfillFullFull1
  have hnoneJ1 :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ objective1 Pfull Pfull ≤ objective1 Psub Pfull :=
    paper_proposition5_no_group_expands_no_drop_of_weighted_groupwise_merit_lt
      (S := Surf) (policyPair := policyPair) (J := J1) (groupA := groupA)
      (groupB := groupB) (populationShare := populationShare)
      (Pdrop1 := Psub) (Pdrop2 := Pfull) (Pkeep1 := Pfull)
      (Pkeep2 := Pfull) (q := q1Sub) (cutoff := fullFullCutoff)
      hshareA hshareB hfixedPoolMeritA hfixedPoolMeritB
  have honlyA_J1_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupA (testCost groupA) ≤
              testFreeMerit groupA) := by
    intro hcut hnot
    exact
      glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupA_formula_of_groupB_eq
        Surf policyPair J1 groupA groupB populationShare Pfull Pfull Psub
        Pfull hshareA (honlyA_J1_groupB_eq hcut hnot)
        (honlyA_J1_groupA_testBased hcut hnot)
        (honlyA_J1_groupA_testFree hcut hnot)
  have honlyB_J1_merit :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupB (testCost groupB) ≤
              testFreeMerit groupB) := by
    intro hcut hnot
    exact
      glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupB_formula_of_groupA_eq
        Surf policyPair J1 groupA groupB populationShare Pfull Pfull Psub
        Pfull hshareB (honlyB_J1_groupA_eq hcut hnot)
        (honlyB_J1_groupB_testBased hcut hnot)
        (honlyB_J1_groupB_testFree hcut hnot)
  rcases
    paper_proposition5_part_i_school1_cutoff_objective_iff_exactly_one_cost_case_of_merit_crossings
      objective1 testBasedMerit testFreeMerit hmaxCost hcostMem hcont hanti
      hlowCost hhighCost hnoneJ1 hbothJ1_impossible honlyA_J1_merit
      honlyB_J1_merit with
    ⟨costThreshold, hmem, heq, hle, hJ1Cutoff⟩
  have hJ1 :
      (objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3SubFullGroupExpandsByDropping Surf policyPair
            Psub Pfull testCost costThreshold q1Sub K) :=
    paper_proposition5_part_i_school1_objective_iff_condition10_of_cutoff_cases
      Surf policyPair Psub Pfull api subEstimateLaw objective1
      hmassFullFullA hmassFullFullB hJ1Cutoff
  have hJ2A_merit :
      glm20Theorem3SubFullGroupExpandsByDropping Surf policyPair Psub Pfull
          testCost costThreshold q1Sub K groupA →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          populationShare groupB *
              Surf.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) >
            populationShare groupA *
                Surf.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
              populationShare groupB *
                Surf.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) := by
    intro hdropA
    exact
      paper_theorem3_school2_objective_iff_single_group_merit_gt_of_no_tie
        Surf policyPair Psub Pfull J2 groupA groupB groupB populationShare
        objective2
        (glm20TwoGroupWeightedAcademicMeritObjective_eq_groupB_of_groupA_zero
          Surf policyPair J2 groupA groupB populationShare Psub Pfull
          (hJ2ZeroA costThreshold hdropA))
        (by rfl) (hJ2NotTieB costThreshold hdropA)
  have hJ2B_merit :
      glm20Theorem3SubFullGroupExpandsByDropping Surf policyPair Psub Pfull
          testCost costThreshold q1Sub K groupB →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          populationShare groupA *
              Surf.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) >
            populationShare groupA *
                Surf.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
              populationShare groupB *
                Surf.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) := by
    intro hdropB
    exact
      paper_theorem3_school2_objective_iff_single_group_merit_gt_of_no_tie
        Surf policyPair Psub Pfull J2 groupA groupB groupA populationShare
        objective2
        (glm20TwoGroupWeightedAcademicMeritObjective_eq_groupA_of_groupB_zero
          Surf policyPair J2 groupA groupB populationShare Psub Pfull
          (hJ2ZeroB costThreshold hdropB))
        (by rfl) (hJ2NotTieA costThreshold hdropB)
  have hsubFull :
      Surf.policyPairIsEquilibrium Psub Pfull ↔
        glm20Theorem3SubFullCondition Surf policyPair Psub Pfull J2 groupA
          groupB populationShare testCost costThreshold capacity2 q1Sub K :=
    paper_theorem3_subFull_condition_of_feasible_weighted_surface_objective_mass_bridges
      (S := Surf) (massTestTaking := massTestTaking)
      (admittedAcademicMerit := admittedAcademicMerit) (diversity := diversity)
      (policyPair := policyPair) (Psub := Psub) (Pfull := Pfull)
      (J1 := J1) (J2 := J2) (groupA := groupA) (groupB := groupB)
      (populationShare := populationShare) (testCost := testCost)
      (costThreshold := costThreshold) (capacity2 := capacity2)
      (q1Sub := q1Sub) (K := K) (feasible1 := feasible1)
      (feasible2 := feasible2) rfl hfeasible1SubFull hfeasible1FullFull
      hfeasible2SubSub (hfeasible2SubFull costThreshold) hJ1 hJ2A_merit
      hJ2B_merit
  exact ⟨costThreshold, hmem, heq, hle, hsubFull⟩

/--
Theorem 3(i), feasibility-aware positive-interval cost-threshold endpoint.

This is the source-Gaussian-friendly version of
`paper_theorem3_subFull_condition_of_feasible_weighted_surface_merit_crossings_capacity_fixed_pool_and_group_merit_formulas`:
the Proposition 5(i) merit crossing is carried on
`Set.Icc (leftCost g) (rightCost g)` rather than on the closed interval from
zero, so it can receive inverse-CDF formulas whose regularity is available only
away from the boundary.
-/
theorem
    paper_theorem3_subFull_condition_of_feasible_weighted_surface_merit_crossings_interval_capacity_fixed_pool_and_group_merit_formulas
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost leftCost rightCost : Group → ℝ}
    {capacity1 capacity2 q1Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff : Group → ℝ}
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    {feasible1 feasible2 : Policy → Policy → Prop}
    (hS :
      S =
        glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
          groupB populationShare feasible1 feasible2)
    (hleftRight : ∀ g, leftCost g < rightCost g)
    (hleftPos : ∀ g, 0 < leftCost g)
    (hcostMem :
      ∀ g, testCost g ∈ Set.Icc (leftCost g) (rightCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g)
        (Set.Icc (leftCost g) (rightCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g)
        (Set.Icc (leftCost g) (rightCost g)))
    (hlowCost :
      ∀ g, testFreeMerit g < testBasedMerit g (leftCost g))
    (hhighCost :
      ∀ g, testBasedMerit g (rightCost g) < testFreeMerit g)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hcapacity1 :
      capacity1 =
        populationShare groupA *
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
              q1Sub +
          populationShare groupB *
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
              q1Sub)
    (hfillFullFull1 :
      capacity1 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hfixedPoolMeritA :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull) <
            S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull))
    (hfixedPoolMeritB :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull) <
            S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull))
    (honlyA_J1_groupB_eq :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull) =
            S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull))
    (honlyA_J1_groupA_testBased :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull) =
            testBasedMerit groupA (testCost groupA))
    (honlyA_J1_groupA_testFree :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull) =
            testFreeMerit groupA)
    (honlyB_J1_groupA_eq :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull) =
            S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull))
    (honlyB_J1_groupB_testBased :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull) =
            testBasedMerit groupB (testCost groupB))
    (honlyB_J1_groupB_testFree :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull) =
            testFreeMerit groupB)
    (hfeasible1SubFull : feasible1 Psub Pfull)
    (hfeasible1FullFull : feasible1 Pfull Pfull)
    (hfeasible2SubSub : feasible2 Psub Psub)
    (hfeasible2SubFull :
      ∀ costThreshold : Group → ℝ,
        feasible2 Psub Pfull ↔
          (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
              testCost costThreshold q1Sub
              (fun g q =>
                glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
              groupA →
            S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2) ∧
          (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
              testCost costThreshold q1Sub
              (fun g q =>
                glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
              groupB →
            S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2))
    (hJ2ZeroA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        populationShare groupA *
          S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) = 0)
    (hJ2NotTieB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ZeroB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        populationShare groupB *
          S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) = 0)
    (hJ2NotTieA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :
    ∃ costThreshold : Group → ℝ,
      (∀ g, costThreshold g ∈ Set.Ioo (leftCost g) (rightCost g)) ∧
        (∀ g, testBasedMerit g (costThreshold g) = testFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (leftCost g) (rightCost g) →
            (testBasedMerit g c ≤ testFreeMerit g ↔
              costThreshold g ≤ c)) ∧
            (S.policyPairIsEquilibrium Psub Pfull ↔
              glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
                groupA groupB populationShare testCost costThreshold
                capacity2 q1Sub
                (fun g q =>
                  glm20StrategicSubEstimateMassAbove api
                    (subEstimateLaw g) q)) := by
  subst S
  let Surf :=
    glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
      admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
      groupB populationShare feasible1 feasible2
  let K := fun g q =>
    glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q
  let objective1 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective Surf policyPair J1 groupA
      groupB populationShare
  let objective2 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective Surf policyPair J2 groupA
      groupB populationShare
  have hbothJ1_impossible :
      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False :=
    paper_proposition5_part_i_both_fullFull_cutoff_cases_impossible_of_capacity
      (S := Surf) (policyPair := policyPair) (Pfull := Pfull)
      (populationShare := populationShare) (capacity1 := capacity1)
      (q1Sub := q1Sub) api subEstimateLaw hshareA hshareB
      hmassFullFullA hmassFullFullB hcapacity1 hfillFullFull1
  have hnoneJ1 :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ objective1 Pfull Pfull ≤ objective1 Psub Pfull :=
    paper_proposition5_no_group_expands_no_drop_of_weighted_groupwise_merit_lt
      (S := Surf) (policyPair := policyPair) (J := J1) (groupA := groupA)
      (groupB := groupB) (populationShare := populationShare)
      (Pdrop1 := Psub) (Pdrop2 := Pfull) (Pkeep1 := Pfull)
      (Pkeep2 := Pfull) (q := q1Sub) (cutoff := fullFullCutoff)
      hshareA hshareB hfixedPoolMeritA hfixedPoolMeritB
  have honlyA_J1_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupA (testCost groupA) ≤
              testFreeMerit groupA) := by
    intro hcut hnot
    exact
      glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupA_formula_of_groupB_eq
        Surf policyPair J1 groupA groupB populationShare Pfull Pfull Psub
        Pfull hshareA (honlyA_J1_groupB_eq hcut hnot)
        (honlyA_J1_groupA_testBased hcut hnot)
        (honlyA_J1_groupA_testFree hcut hnot)
  have honlyB_J1_merit :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupB (testCost groupB) ≤
              testFreeMerit groupB) := by
    intro hcut hnot
    exact
      glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupB_formula_of_groupA_eq
        Surf policyPair J1 groupA groupB populationShare Pfull Pfull Psub
        Pfull hshareB (honlyB_J1_groupA_eq hcut hnot)
        (honlyB_J1_groupB_testBased hcut hnot)
        (honlyB_J1_groupB_testFree hcut hnot)
  rcases
    paper_proposition5_part_i_school1_cutoff_objective_iff_exactly_one_cost_case_of_merit_crossings_interval
      objective1 testBasedMerit testFreeMerit hleftRight hleftPos
      hcostMem hcont hanti hlowCost hhighCost hnoneJ1
      hbothJ1_impossible honlyA_J1_merit honlyB_J1_merit with
    ⟨costThreshold, hmem, heq, hle, hJ1Cutoff⟩
  have hJ1 :
      (objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3SubFullGroupExpandsByDropping Surf policyPair
            Psub Pfull testCost costThreshold q1Sub K) :=
    paper_proposition5_part_i_school1_objective_iff_condition10_of_cutoff_cases
      Surf policyPair Psub Pfull api subEstimateLaw objective1
      hmassFullFullA hmassFullFullB hJ1Cutoff
  have hJ2A_merit :
      glm20Theorem3SubFullGroupExpandsByDropping Surf policyPair Psub Pfull
          testCost costThreshold q1Sub K groupA →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          populationShare groupB *
              Surf.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) >
            populationShare groupA *
                Surf.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
              populationShare groupB *
                Surf.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) := by
    intro hdropA
    exact
      paper_theorem3_school2_objective_iff_single_group_merit_gt_of_no_tie
        Surf policyPair Psub Pfull J2 groupA groupB groupB populationShare
        objective2
        (glm20TwoGroupWeightedAcademicMeritObjective_eq_groupB_of_groupA_zero
          Surf policyPair J2 groupA groupB populationShare Psub Pfull
          (hJ2ZeroA costThreshold hdropA))
        (by rfl) (hJ2NotTieB costThreshold hdropA)
  have hJ2B_merit :
      glm20Theorem3SubFullGroupExpandsByDropping Surf policyPair Psub Pfull
          testCost costThreshold q1Sub K groupB →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          populationShare groupA *
              Surf.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) >
            populationShare groupA *
                Surf.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
              populationShare groupB *
                Surf.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) := by
    intro hdropB
    exact
      paper_theorem3_school2_objective_iff_single_group_merit_gt_of_no_tie
        Surf policyPair Psub Pfull J2 groupA groupB groupA populationShare
        objective2
        (glm20TwoGroupWeightedAcademicMeritObjective_eq_groupA_of_groupB_zero
          Surf policyPair J2 groupA groupB populationShare Psub Pfull
          (hJ2ZeroB costThreshold hdropB))
        (by rfl) (hJ2NotTieA costThreshold hdropB)
  have hsubFull :
      Surf.policyPairIsEquilibrium Psub Pfull ↔
        glm20Theorem3SubFullCondition Surf policyPair Psub Pfull J2 groupA
          groupB populationShare testCost costThreshold capacity2 q1Sub K :=
    paper_theorem3_subFull_condition_of_feasible_weighted_surface_objective_mass_bridges
      (S := Surf) (massTestTaking := massTestTaking)
      (admittedAcademicMerit := admittedAcademicMerit) (diversity := diversity)
      (policyPair := policyPair) (Psub := Psub) (Pfull := Pfull)
      (J1 := J1) (J2 := J2) (groupA := groupA) (groupB := groupB)
      (populationShare := populationShare) (testCost := testCost)
      (costThreshold := costThreshold) (capacity2 := capacity2)
      (q1Sub := q1Sub) (K := K) (feasible1 := feasible1)
      (feasible2 := feasible2) rfl hfeasible1SubFull hfeasible1FullFull
      hfeasible2SubSub (hfeasible2SubFull costThreshold) hJ1 hJ2A_merit
      hJ2B_merit
  exact ⟨costThreshold, hmem, heq, hle, hsubFull⟩

/--
Proposition 5(i) / Theorem 3(i) objective bridge from merit crossings, with
condition (12)'s strict school-`J2` merit comparison as the input.

This has the same conclusion as
`paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings`;
the only difference is that the no-tie side condition is discharged from the
paper's strict weighted-merit inequality.
-/
abbrev
    paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_strict_merit
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity2 q1Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowCost : ∀ g, testFreeMerit g < testBasedMerit g 0)
    (hhighCost : ∀ g, testBasedMerit g (maxCost g) < testFreeMerit g)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hnoneJ1 :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ objective1 Pfull Pfull ≤ objective1 Psub Pfull)
    (hbothJ1_impossible :
      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False)
    (honlyA_J1_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupA (testCost groupA) ≤
              testFreeMerit groupA))
    (honlyB_J1_merit :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupB (testCost groupB) ≤
              testFreeMerit groupB))
    (hJ2ObjectiveSubSub :
      objective2 Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        objective2 Psub Pfull =
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull))
    (hJ2MassB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2)
    (hJ2MeritGtB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) >
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        objective2 Psub Pfull =
          populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull))
    (hJ2MassA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2)
    (hJ2MeritGtA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) >
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :=
  paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings
    (S := S) (policyPair := policyPair) (Psub := Psub) (Pfull := Pfull)
    (J2 := J2) (groupA := groupA) (groupB := groupB)
    (populationShare := populationShare) (testCost := testCost)
    (maxCost := maxCost) (capacity2 := capacity2) (q1Sub := q1Sub)
    api subEstimateLaw objective1 objective2 testBasedMerit testFreeMerit
    hmaxCost hcostMem hcont hanti hlowCost hhighCost hmassFullFullA
    hmassFullFullB hnoneJ1 hbothJ1_impossible honlyA_J1_merit
    honlyB_J1_merit hJ2ObjectiveSubSub hJ2ObjectiveSubFullB hJ2MassB
    (by
      intro costThreshold hdropA
      exact ne_of_gt (hJ2MeritGtB costThreshold hdropA))
    hJ2ObjectiveSubFullA hJ2MassA
    (by
      intro costThreshold hdropB
      exact ne_of_gt (hJ2MeritGtA costThreshold hdropB))

/--
Proposition 5(i) / Theorem 3(i) objective bridge from merit crossings and
the paper's full/full capacity-fill contradiction.

Compared with
`paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings`,
this theorem does not assume the both-groups cutoff branch is impossible.  It
derives that branch from positive population shares, the full/full mass
identities, and the capacity equation at `q^*_{1,sub}`.
-/
theorem
    paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_and_capacity
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity1 capacity2 q1Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
