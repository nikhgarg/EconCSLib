theorem
    paper_proposition6_policyState_j1_strict_diversity_best_response_iff_paper_formulas
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
