      hP_ne hcapacity_pos hgroupA_pos hgroupB_pos hcapacity_mem
      hscaleA_pos hxiA_pos hownA_pos hotherA_pos hrhoA_nonneg hrhoA_lt_one
      hselectiveA hscaleB_pos hxiB_pos hownB_pos hotherB_pos hone_lt_rhoB
      hselectiveB

/--
Theorem 1, canonical source surfaces with concrete standard-normal APIs and
scalar worst-case capacity bounds.

This wrapper derives the repeated paper-facing feasibility hypotheses from
three scalar conditions: capacity is below group A's eligible mass, and the
two group-specific selectivity margins hold at the lowest own-access level.
-/
theorem paper_theorem1_dropping_tests_with_barriers_canonical_standardGaussian_of_worst_case_capacity
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    {Pfull Psub : Policy} (hP_ne : Pfull ≠ Psub)
    {groupA groupB : Group}
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw}
    {ownShareA otherEligibleMassA rhoA xiA benchmarkA baseA scaleA : ℝ}
    {ownShareB otherEligibleMassB rhoB xiB benchmarkB baseB scaleB : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hcapacity_lt_groupA : capacity < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hscaleA_pos : 0 < scaleA)
    (hxiA_pos : 0 < xiA)
    (hownA_pos : 0 < ownShareA)
    (hotherA_pos : 0 < otherEligibleMassA)
    (hrhoA_nonneg : 0 ≤ rhoA) (hrhoA_lt_one : rhoA < 1)
    (hselectiveA_worst : 2 * capacity < otherEligibleMassA)
    (hscaleB_pos : 0 < scaleB)
    (hxiB_pos : 0 < xiB)
    (hownB_pos : 0 < ownShareB)
    (hotherB_pos : 0 < otherEligibleMassB)
    (hone_lt_rhoB : 1 < rhoB)
    (hselectiveB_worst : 2 * capacity < otherEligibleMassB) :
    let threshold :=
      theorem1BarrierCapacityThresholdOnUnit standardGaussianCDFAPI
        standardGaussianCDF_tendsto_atBot standardGaussianCDF_tendsto_atTop
        capacity groupAEligibleMass groupBShare L_A L_B
        (lt_trans hcapacity_pos hcapacity_lt_groupA) hgroupB_pos.le
        (theorem1_capacity_mem_on_unit_of_capacity_lt_groupAEligibleMass
          hcapacity_pos hcapacity_lt_groupA hgroupB_pos.le)
    let Sdiv :=
      theorem1DiversitySourceSurface standardGaussianCDFAPI Pfull Psub groupB
        capacity groupBShare diversitySub L_B threshold
    let SA :=
      theorem1AcademicMeritSourceSurface standardGaussianHazardInverseCertificate
        Pfull Psub groupA capacity baseA scaleA xiA hscaleA_pos hxiA_pos
        benchmarkA
        (theorem1BetaGroupA standardGaussianQuantileAPI
          capacity ownShareA otherEligibleMassA rhoA)
    let SB :=
      theorem1AcademicMeritSourceSurface standardGaussianHazardInverseCertificate
        Pfull Psub groupB capacity baseB scaleB xiB hscaleB_pos hxiB_pos
        benchmarkB
        (theorem1BetaGroupB standardGaussianQuantileAPI
          capacity ownShareB otherEligibleMassB rhoB)
    (∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        theorem1SourceDiversityImproves Sdiv Pfull Psub γB ↔ γB < γbar) ∧
      (∃ γbarA : ℝ,
        ∀ γA ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SA groupA Pfull Psub γA ↔
            γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SB groupB Pfull Psub γB ↔
            γB ≤ γbarB) :=
    paper_theorem1_dropping_tests_with_barriers_canonical_standardGaussian_of_capacity_range
      hP_ne hcapacity_pos (lt_trans hcapacity_pos hcapacity_lt_groupA)
      hgroupB_pos
      (theorem1_capacity_mem_on_unit_of_capacity_lt_groupAEligibleMass
        hcapacity_pos hcapacity_lt_groupA hgroupB_pos.le)
      hscaleA_pos hxiA_pos hownA_pos hotherA_pos hrhoA_nonneg hrhoA_lt_one
      (theorem1_selective_on_unit_of_two_capacity_lt_otherEligibleMass
        hownA_pos.le hselectiveA_worst)
      hscaleB_pos hxiB_pos hownB_pos hotherB_pos hone_lt_rhoB
      (theorem1_selective_on_unit_of_two_capacity_lt_otherEligibleMass
        hownB_pos.le hselectiveB_worst)

/--
Theorem 1 with the paper's population and access notation wired into the
canonical source surfaces.

Here group A's fixed eligible mass is `(1 - pi) * gammaA`, group B's population
share is `pi`, and the group-specific academic-merit formulas use the other
group's fixed eligible mass exactly as in the displayed `β_g` expressions.
-/
theorem paper_theorem1_dropping_tests_with_barriers_canonical_standardGaussian_of_population_access_bounds
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    {Pfull Psub : Policy} (hP_ne : Pfull ≠ Psub)
    {groupA groupB : Group}
    {diversitySub capacity pi gammaA gammaB : ℝ}
    {L_A L_B : GaussianScaleLaw}
    {rhoA xiA benchmarkA baseA scaleA : ℝ}
    {rhoB xiB benchmarkB baseB scaleB : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hgammaA_pos : 0 < gammaA) (hgammaB_pos : 0 < gammaB)
    (hcapacity_lt_groupA : capacity < (1 - pi) * gammaA)
    (hselectiveA_worst : 2 * capacity < pi * gammaB)
    (hselectiveB_worst : 2 * capacity < (1 - pi) * gammaA)
    (hscaleA_pos : 0 < scaleA)
    (hxiA_pos : 0 < xiA)
    (hrhoA_nonneg : 0 ≤ rhoA) (hrhoA_lt_one : rhoA < 1)
    (hscaleB_pos : 0 < scaleB)
    (hxiB_pos : 0 < xiB)
    (hone_lt_rhoB : 1 < rhoB) :
    let groupAEligibleMass := (1 - pi) * gammaA
    let groupBShare := pi
    let ownShareA := 1 - pi
    let otherEligibleMassA := pi * gammaB
    let ownShareB := pi
    let otherEligibleMassB := (1 - pi) * gammaA
    let threshold :=
      theorem1BarrierCapacityThresholdOnUnit standardGaussianCDFAPI
        standardGaussianCDF_tendsto_atBot standardGaussianCDF_tendsto_atTop
        capacity groupAEligibleMass groupBShare L_A L_B
        (lt_trans hcapacity_pos hcapacity_lt_groupA) hpi_pos.le
        (theorem1_capacity_mem_on_unit_of_capacity_lt_groupAEligibleMass
          hcapacity_pos hcapacity_lt_groupA hpi_pos.le)
    let Sdiv :=
      theorem1DiversitySourceSurface standardGaussianCDFAPI Pfull Psub groupB
        capacity groupBShare diversitySub L_B threshold
    let SA :=
      theorem1AcademicMeritSourceSurface standardGaussianHazardInverseCertificate
        Pfull Psub groupA capacity baseA scaleA xiA hscaleA_pos hxiA_pos
        benchmarkA
        (theorem1BetaGroupA standardGaussianQuantileAPI
          capacity ownShareA otherEligibleMassA rhoA)
    let SB :=
      theorem1AcademicMeritSourceSurface standardGaussianHazardInverseCertificate
        Pfull Psub groupB capacity baseB scaleB xiB hscaleB_pos hxiB_pos
        benchmarkB
        (theorem1BetaGroupB standardGaussianQuantileAPI
          capacity ownShareB otherEligibleMassB rhoB)
    (∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        theorem1SourceDiversityImproves Sdiv Pfull Psub γB ↔ γB < γbar) ∧
      (∃ γbarA : ℝ,
        ∀ γA ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SA groupA Pfull Psub γA ↔
            γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SB groupB Pfull Psub γB ↔
            γB ≤ γbarB) := by
  have hownA_pos : 0 < 1 - pi := by linarith
  have hotherA_pos : 0 < pi * gammaB := mul_pos hpi_pos hgammaB_pos
  have hotherB_pos : 0 < (1 - pi) * gammaA :=
    mul_pos hownA_pos hgammaA_pos
  exact
    paper_theorem1_dropping_tests_with_barriers_canonical_standardGaussian_of_worst_case_capacity
      (groupAEligibleMass := (1 - pi) * gammaA)
      (groupBShare := pi)
      (ownShareA := 1 - pi)
      (otherEligibleMassA := pi * gammaB)
      (ownShareB := pi)
      (otherEligibleMassB := (1 - pi) * gammaA)
      hP_ne hcapacity_pos hcapacity_lt_groupA hpi_pos hscaleA_pos hxiA_pos
      hownA_pos hotherA_pos hrhoA_nonneg hrhoA_lt_one hselectiveA_worst
      hscaleB_pos hxiB_pos hpi_pos hotherB_pos hone_lt_rhoB hselectiveB_worst

/--
Theorem 1 source-model domain for the full access-comparative-static sweep.

The main text assumes a selective, over-demanded market at the current
parameters.  The appendix proof sweeps access levels through the full interval
`[0,1]`, so the formal source model records the stronger domain actually needed
for that sweep: capacity can be cleared even when group-B access is zero, and
the group-specific quantile terms stay in their selective interior domains.
-/
structure GLM20Theorem1BarrierCanonicalSourceModel
    (Group Policy : Type*) where
  Pfull : Policy
  Psub : Policy
  P_ne : Pfull ≠ Psub
  groupA : Group
  groupB : Group
  diversitySub : ℝ
  capacity : ℝ
  pi : ℝ
  gammaA : ℝ
  gammaB : ℝ
  L_A : GaussianScaleLaw
  L_B : GaussianScaleLaw
  rhoA : ℝ
  xiA : ℝ
  benchmarkA : ℝ
  baseA : ℝ
  scaleA : ℝ
  rhoB : ℝ
  xiB : ℝ
  benchmarkB : ℝ
  baseB : ℝ
  scaleB : ℝ
  capacity_pos : 0 < capacity
  pi_pos : 0 < pi
  pi_lt_one : pi < 1
  gammaA_pos : 0 < gammaA
  gammaB_pos : 0 < gammaB
  selectiveA_worst : 2 * capacity < pi * gammaB
  selectiveB_worst : 2 * capacity < (1 - pi) * gammaA
  scaleA_pos : 0 < scaleA
  xiA_pos : 0 < xiA
  rhoA_nonneg : 0 ≤ rhoA
  rhoA_lt_one : rhoA < 1
  scaleB_pos : 0 < scaleB
  xiB_pos : 0 < xiB
  one_lt_rhoB : 1 < rhoB

/-- Paper-facing conclusion package for the canonical Theorem 1 source model. -/
def GLM20Theorem1BarrierCanonicalSourceModelConclusion
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (M : GLM20Theorem1BarrierCanonicalSourceModel Group Policy) : Prop :=
  let capacity_lt_groupA_eligible : M.capacity < (1 - M.pi) * M.gammaA :=
    theorem1_capacity_lt_groupA_eligible_of_selectiveB_worst
      M.capacity_pos M.selectiveB_worst
  let groupAEligibleMass := (1 - M.pi) * M.gammaA
  let groupBShare := M.pi
  let ownShareA := 1 - M.pi
  let otherEligibleMassA := M.pi * M.gammaB
  let ownShareB := M.pi
  let otherEligibleMassB := (1 - M.pi) * M.gammaA
  let threshold :=
    theorem1BarrierCapacityThresholdOnUnit standardGaussianCDFAPI
      standardGaussianCDF_tendsto_atBot standardGaussianCDF_tendsto_atTop
      M.capacity groupAEligibleMass groupBShare M.L_A M.L_B
      (lt_trans M.capacity_pos capacity_lt_groupA_eligible)
      M.pi_pos.le
      (theorem1_capacity_mem_on_unit_of_capacity_lt_groupAEligibleMass
        M.capacity_pos capacity_lt_groupA_eligible M.pi_pos.le)
  let Sdiv :=
    theorem1DiversitySourceSurface standardGaussianCDFAPI M.Pfull M.Psub
      M.groupB M.capacity groupBShare M.diversitySub M.L_B threshold
  let SA :=
    theorem1AcademicMeritSourceSurface standardGaussianHazardInverseCertificate
      M.Pfull M.Psub M.groupA M.capacity M.baseA M.scaleA M.xiA
      M.scaleA_pos M.xiA_pos M.benchmarkA
      (theorem1BetaGroupA standardGaussianQuantileAPI
        M.capacity ownShareA otherEligibleMassA M.rhoA)
  let SB :=
    theorem1AcademicMeritSourceSurface standardGaussianHazardInverseCertificate
      M.Pfull M.Psub M.groupB M.capacity M.baseB M.scaleB M.xiB
      M.scaleB_pos M.xiB_pos M.benchmarkB
      (theorem1BetaGroupB standardGaussianQuantileAPI
        M.capacity ownShareB otherEligibleMassB M.rhoB)
  (∃ γbar : ℝ,
    ∀ γB ∈ Set.Icc (0 : ℝ) 1,
      theorem1SourceDiversityImproves Sdiv M.Pfull M.Psub γB ↔ γB < γbar) ∧
    (∃ γbarA : ℝ,
      ∀ γA ∈ Set.Icc (0 : ℝ) 1,
        theorem1SourceAcademicMeritImproves SA M.groupA M.Pfull M.Psub γA ↔
          γA ≤ γbarA) ∧
    (∃ γbarB : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        theorem1SourceAcademicMeritImproves SB M.groupB M.Pfull M.Psub γB ↔
          γB ≤ γbarB)

/--
Theorem 1, canonical standard-Gaussian source model.

Paper statement: "With barriers, holding other parameters fixed, there exists
a threshold `γbar` such that diversity improves under `P_sub` iff group-B test
access `γ_B < γbar`; for each group `g`, holding other parameters fixed, there
exists a threshold `γbar_g` such that academic merit of group `g` increases
under `P_sub` iff `γ_g < γbar_g`."

This theorem packages the fully expanded paper source model in one structure.
The remaining domain fields of `M` are not proof certificates; they are the
well-definedness assumptions needed by the source proof's full `[0,1]` access
sweep.
-/
theorem paper_theorem1_dropping_tests_with_barriers_canonical_standardGaussian_source_model
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (M : GLM20Theorem1BarrierCanonicalSourceModel Group Policy) :
    GLM20Theorem1BarrierCanonicalSourceModelConclusion M :=
    paper_theorem1_dropping_tests_with_barriers_canonical_standardGaussian_of_population_access_bounds
      (Pfull := M.Pfull) (Psub := M.Psub) (groupA := M.groupA)
      (groupB := M.groupB) (diversitySub := M.diversitySub)
      (capacity := M.capacity) (pi := M.pi) (gammaA := M.gammaA)
      (gammaB := M.gammaB) (L_A := M.L_A) (L_B := M.L_B)
      (rhoA := M.rhoA) (xiA := M.xiA) (benchmarkA := M.benchmarkA)
      (baseA := M.baseA) (scaleA := M.scaleA) (rhoB := M.rhoB)
      (xiB := M.xiB) (benchmarkB := M.benchmarkB) (baseB := M.baseB)
      (scaleB := M.scaleB) M.P_ne M.capacity_pos M.pi_pos M.pi_lt_one
      M.gammaA_pos M.gammaB_pos
      (theorem1_capacity_lt_groupA_eligible_of_selectiveB_worst
        M.capacity_pos M.selectiveB_worst)
      M.selectiveA_worst M.selectiveB_worst M.scaleA_pos M.xiA_pos
      M.rhoA_nonneg M.rhoA_lt_one M.scaleB_pos M.xiB_pos M.one_lt_rhoB

