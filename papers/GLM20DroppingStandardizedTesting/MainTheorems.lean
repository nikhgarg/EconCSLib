/--
Proposition 5(i) school-`J1` bridge from cutoff-case proof language to the
paper's condition (10).

If the concrete Gaussian proof shows that `J1` weakly prefers dropping the
test exactly when there is exactly one group satisfying the cost-threshold
comparison and cutoff case `q^*_{1,sub} < q^g_{full,full}`, then the same
objective comparison is equivalent to Theorem 3(i)'s displayed condition (10)
for exactly one group.
-/
theorem paper_proposition5_part_i_school1_objective_iff_condition10_of_cutoff_cases
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy)
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {groupA groupB : Group}
    {testCost costThreshold : Group → ℝ} {q1Sub : ℝ}
    {fullFullCutoff : Group → ℝ}
    (objective1 : Policy → Policy → ℝ)
    (hmassA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hobjectiveCutoff :
      (objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (fun g =>
            testCost g ≥ costThreshold g ∧
              0 < costThreshold g ∧ q1Sub < fullFullCutoff g)) :
    (objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
      glm20ExactlyOneOfTwo groupA groupB
        (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)) := by
  let cutoffCondition := fun g : Group =>
    testCost g ≥ costThreshold g ∧
      0 < costThreshold g ∧ q1Sub < fullFullCutoff g
  let condition10 :=
    glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
      testCost costThreshold q1Sub
      (fun g q => glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
  have hA : cutoffCondition groupA ↔ condition10 groupA :=
    (paper_proposition5_condition10_iff_cost_and_fullFull_cutoff_case
      S policyPair Psub Pfull api subEstimateLaw hmassA).symm
  have hB : cutoffCondition groupB ↔ condition10 groupB :=
    (paper_proposition5_condition10_iff_cost_and_fullFull_cutoff_case
      S policyPair Psub Pfull api subEstimateLaw hmassB).symm
  exact hobjectiveCutoff.trans (glm20ExactlyOneOfTwo_congr hA hB)

/--
Proposition 5(i) school-`J1` case-analysis bridge.

This packages the paper's three cases before translating to the displayed mass
condition: if no group expands then `J1` does not drop; if both groups would
expand then the case is impossible under the capacity assumptions; and if
exactly one group expands, dropping is equivalent to that group's positive
cost-threshold comparison.
-/
theorem paper_proposition5_part_i_school1_cutoff_objective_iff_exactly_one_cost_case
    {Group Policy : Type*}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost costThreshold : Group → ℝ} {q1Sub : ℝ}
    {fullFullCutoff : Group → ℝ}
    (objective1 : Policy → Policy → ℝ)
    (hnone :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ objective1 Pfull Pfull ≤ objective1 Psub Pfull)
    (hboth_impossible :
      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False)
    (honlyA :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testCost groupA ≥ costThreshold groupA ∧
              0 < costThreshold groupA))
    (honlyB :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testCost groupB ≥ costThreshold groupB ∧
              0 < costThreshold groupB)) :
    (objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
      glm20ExactlyOneOfTwo groupA groupB
        (fun g =>
          (testCost g ≥ costThreshold g ∧ 0 < costThreshold g) ∧
            q1Sub < fullFullCutoff g) :=
  glm20ExactlyOneOfTwo_qualified_cutoff_iff_of_case_analysis
    (a := groupA) (b := groupB)
    (deviationProfitable :=
      objective1 Pfull Pfull ≤ objective1 Psub Pfull)
    (cutoffCase := fun g => q1Sub < fullFullCutoff g)
    (qualifier := fun g => testCost g ≥ costThreshold g ∧ 0 < costThreshold g)
    hnone hboth_impossible honlyA honlyB

/--
Proposition 5(i), school-`J1`, with the cost thresholds derived from the
source proof's monotonicity argument.

In the exactly-one-expanding-group case, the source proof compares a
test-based admitted-merit term, continuous and strictly decreasing in that
group's test cost, against the test-free admitted merit.  Opposite endpoint
comparisons give a positive threshold by the intermediate value theorem, and
the deviation comparison is equivalent to being at or above that threshold.
-/
theorem
    paper_proposition5_part_i_school1_cutoff_objective_iff_exactly_one_cost_case_of_merit_crossings
    {Group Policy : Type*}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost maxCost : Group → ℝ} {q1Sub : ℝ}
    {fullFullCutoff : Group → ℝ}
    (objective1 : Policy → Policy → ℝ)
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g) (Set.Icc (0 : ℝ) (maxCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g) (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowCost : ∀ g, testFreeMerit g < testBasedMerit g 0)
    (hhighCost : ∀ g, testBasedMerit g (maxCost g) < testFreeMerit g)
    (hnone :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ objective1 Pfull Pfull ≤ objective1 Psub Pfull)
    (hboth_impossible :
      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False)
    (honlyA_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
