            standardBivariateGaussianCDF sigmaTildeB aB bB mu qFull
    (glm20Proposition3AdmittedShareFromSelectionMass
        standardGaussianCDFAPI standardBivariateGaussianCDF
        groupBPopulationShare capacity sigmaTildeB aB bB mu qFull <
          groupBPopulationShare ↔
      sigmaTildeB / sigmaTildeA <
        glm20Proposition3SelectionCore standardGaussianCDFAPI
            standardBivariateGaussianCDF sigmaTildeA aA bA mu qFull /
          glm20Proposition3SelectionCore standardGaussianCDFAPI
            standardBivariateGaussianCDF sigmaTildeB aB bB mu qFull) ∧
      (glm20Proposition3OwenStandardizedAdmittedAcademicMerit
          aB bB sigmaTildeB tauB mu qFull <
        glm20Proposition3OwenStandardizedAdmittedAcademicMerit
          aA bA sigmaTildeA tauA mu qFull ↔
        glm20Proposition3OwenStandardizedAdmittedAcademicMerit
          aB bB sigmaTildeB tauB mu qFull <
        glm20Proposition3OwenStandardizedAdmittedAcademicMerit
          aA bA sigmaTildeA tauA mu qFull) := by
  intro capacity
  exact
    paper_proposition3_full_policy_selectionMassShare_ratio_and_standardizedAdmittedAcademicMerit_formulas_standardBivariate
      hpopulation_pos hpopulation_lt_one hsigmaA_pos hsigmaB_pos rfl

/--
