/--
Strict decrease of the concrete standard-bivariate selection mass along an
arbitrary cutoff path.

The analytic content is the vertical-strip measure lemma:
`Phi(A(q))-Phi_2(A(q),B(q);rho)` is
`P(X <= A(q), B(q) <= Y)`, so it strictly falls when `A` strictly falls and
`B` weakly rises.
-/
theorem glm20BivariateApplyAdmitMass_standardBivariate_strictAnti_along
    {populationShare sigmaTilde b mu : ℝ}
    {aOfApply qApply qAdmit : ℝ → ℝ}
    (hpopulation : 0 < populationShare)
    (hsigma : 0 < sigmaTilde)
    (hA :
      StrictAnti fun z : ℝ =>
        (aOfApply (qApply z) + b * mu) /
          Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
    (hB :
      Monotone fun z : ℝ => (qAdmit z - mu) / sigmaTilde) :
    StrictAnti fun z : ℝ =>
      glm20BivariateApplyAdmitMass standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare sigmaTilde aOfApply b mu
        (qApply z) (qAdmit z) := by
  let rho : ℝ :=
    -(sigmaTilde * b) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let A : ℝ → ℝ := fun z =>
    (aOfApply (qApply z) + b * mu) /
      Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let B : ℝ → ℝ := fun z => (qAdmit z - mu) / sigmaTilde
  have hrho : rho ^ 2 < 1 := by
    simpa [rho] using paper_proposition3_rho_sq_lt_one sigmaTilde b
  letI : Measure.IsOpenPosMeasure (correlatedStandardGaussianLaw rho) :=
    correlatedStandardGaussianLaw_isOpenPosMeasure hrho
  have hstrip :
      StrictAnti fun z : ℝ =>
        verticalUpperStripMass (correlatedStandardGaussianLaw rho)
          (A z) (B z) :=
    verticalUpperStripMass_strictAnti_of_strictAnti_left_monotone_right
      (correlatedStandardGaussianLaw rho)
      (by simpa [A] using hA) (by simpa [B] using hB)
  intro z₁ z₂ hz
  have hlt :=
    mul_lt_mul_of_pos_left (hstrip hz) (mul_pos hpopulation hsigma)
  simpa [A, B, rho,
    glm20BivariateApplyAdmitMass_eq_correlatedStandardGaussian_verticalUpperStripMass]
    using hlt

/--
Upper endpoint of the concrete standard-bivariate selection mass along a
cutoff path: if the admitted-score standardized cutoff tends to `+∞`, selected
mass tends to zero.
-/
theorem glm20BivariateApplyAdmitMass_standardBivariate_tendsto_atTop_zero_along
    {populationShare sigmaTilde b mu : ℝ}
    {aOfApply qApply qAdmit : ℝ → ℝ}
    (hB :
      Filter.Tendsto
        (fun z : ℝ => (qAdmit z - mu) / sigmaTilde)
        Filter.atTop Filter.atTop) :
    Filter.Tendsto
      (fun z : ℝ =>
        glm20BivariateApplyAdmitMass standardGaussianCDFAPI
          standardBivariateGaussianCDF populationShare sigmaTilde aOfApply
          b mu (qApply z) (qAdmit z))
      Filter.atTop (nhds 0) := by
  let rho : ℝ :=
    -(sigmaTilde * b) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let A : ℝ → ℝ := fun z =>
    (aOfApply (qApply z) + b * mu) /
      Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let B : ℝ → ℝ := fun z => (qAdmit z - mu) / sigmaTilde
  have hstrip :
      Filter.Tendsto
        (fun z : ℝ =>
          verticalUpperStripMass (correlatedStandardGaussianLaw rho)
            (A z) (B z))
        Filter.atTop (nhds 0) :=
    verticalUpperStripMass_tendsto_zero_of_right_tendsto_atTop
      (correlatedStandardGaussianLaw rho) (by simpa [B] using hB)
  have hscaled :
      Filter.Tendsto
        (fun z : ℝ =>
          populationShare * sigmaTilde *
            verticalUpperStripMass (correlatedStandardGaussianLaw rho)
              (A z) (B z))
        Filter.atTop (nhds 0) := by
    simpa using tendsto_const_nhds.mul hstrip
  simpa [A, B, rho,
    glm20BivariateApplyAdmitMass_eq_correlatedStandardGaussian_verticalUpperStripMass]
    using hscaled

/--
Lower endpoint of the concrete standard-bivariate selection mass along a
cutoff path: if the left cutoff tends to `+∞` and the right cutoff tends to
`-∞`, selected mass tends to the population share times `sigmaTilde`.
-/
theorem glm20BivariateApplyAdmitMass_standardBivariate_tendsto_atBot_total_along
    {populationShare sigmaTilde b mu : ℝ}
    {aOfApply qApply qAdmit : ℝ → ℝ}
    (hA :
