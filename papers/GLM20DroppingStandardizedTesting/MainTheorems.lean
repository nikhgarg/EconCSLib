  rfl

/-- Specialized feasible weighted-surface characterization for `(P_sub, P_full)`. -/
theorem glm20FeasibleWeightedAcademicMeritBinaryPolicySurface_subFull_iff
    {Group Policy School : Type*}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School}
    {groupA groupB : Group} {populationShare : Group → ℝ}
    {feasible1 feasible2 : Policy → Policy → Prop} :
