Specialized equilibrium characterization for `(P_sub,P_full)` on the
diversity-only binary-policy surface.
-/
theorem glm20DiversityBinaryPolicySurface_subFull_iff
    {Group Policy School : Type*}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} :
    (glm20DiversityBinaryPolicySurface massTestTaking admittedAcademicMerit
        diversity policyPair Psub Pfull J1 J2).policyPairIsEquilibrium
        Psub Pfull ↔
      diversity J1 (policyPair Pfull Pfull) ≤
        diversity J1 (policyPair Psub Pfull) ∧
      diversity J2 (policyPair Psub Psub) ≤
        diversity J2 (policyPair Psub Pfull) := by
  simpa [glm20DiversityBinaryPolicySurface_policyPairIsEquilibrium_iff]
    using
      (glm20TwoSchoolBinaryPolicyEquilibrium_subFull_iff
        (fun P1 P2 => diversity J1 (policyPair P1 P2))
        (fun P1 P2 => diversity J2 (policyPair P1 P2))
        Psub Pfull)

/--
If school `J1` strictly improves diversity by dropping the test and school
`J2` weakly prefers keeping the test against `P_sub`, then `(P_sub,P_full)` is
an equilibrium of the diversity-only binary game.
-/
theorem glm20DiversityBinaryPolicySurface_subFull_of_j1_strict_and_j2_weak
    {Group Policy School : Type*}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School}
    (hJ1 :
      diversity J1 (policyPair Pfull Pfull) <
        diversity J1 (policyPair Psub Pfull))
    (hJ2 :
      diversity J2 (policyPair Psub Psub) ≤
        diversity J2 (policyPair Psub Pfull)) :
    (glm20DiversityBinaryPolicySurface massTestTaking admittedAcademicMerit
        diversity policyPair Psub Pfull J1 J2).policyPairIsEquilibrium
        Psub Pfull := by
  rw [glm20DiversityBinaryPolicySurface_subFull_iff]
  exact ⟨le_of_lt hJ1, hJ2⟩

/--
Two-school binary-policy equilibrium with policy-pair feasibility.

This refines `glm20TwoSchoolBinaryPolicyEquilibrium` for the parts of
Section 5 where a school can keep a test-based policy only if the relevant
applicant mass can fill capacity.  Each school must be feasible at the current
policy pair, and unilateral deviations are compared only when the deviating
policy pair is feasible for that school.
-/
def glm20TwoSchoolBinaryPolicyFeasibleEquilibrium
    {Policy : Type*} (objective1 objective2 : Policy → Policy → ℝ)
    (feasible1 feasible2 : Policy → Policy → Prop)
    (Psub Pfull P1 P2 : Policy) : Prop :=
  feasible1 P1 P2 ∧
    feasible2 P1 P2 ∧
      (∀ P1' : Policy, P1' = Psub ∨ P1' = Pfull →
        feasible1 P1' P2 → objective1 P1' P2 ≤ objective1 P1 P2) ∧
        (∀ P2' : Policy, P2' = Psub ∨ P2' = Pfull →
          feasible2 P1 P2' → objective2 P1 P2' ≤ objective2 P1 P2)

/-- Feasible binary-policy equilibrium characterization for `(P_sub, P_full)`. -/
theorem glm20TwoSchoolBinaryPolicyFeasibleEquilibrium_subFull_iff
    {Policy : Type*} (objective1 objective2 : Policy → Policy → ℝ)
    (feasible1 feasible2 : Policy → Policy → Prop)
    (Psub Pfull : Policy) :
    glm20TwoSchoolBinaryPolicyFeasibleEquilibrium objective1 objective2
        feasible1 feasible2 Psub Pfull Psub Pfull ↔
      feasible1 Psub Pfull ∧ feasible2 Psub Pfull ∧
        (feasible1 Pfull Pfull →
          objective1 Pfull Pfull ≤ objective1 Psub Pfull) ∧
          (feasible2 Psub Psub →
            objective2 Psub Psub ≤ objective2 Psub Pfull) := by
  constructor
  · rintro ⟨hcur1, hcur2, hbest1, hbest2⟩
    exact ⟨hcur1, hcur2,
      fun hfeas => hbest1 Pfull (Or.inr rfl) hfeas,
      fun hfeas => hbest2 Psub (Or.inl rfl) hfeas⟩
  · rintro ⟨hcur1, hcur2, hbest1, hbest2⟩
    refine ⟨hcur1, hcur2, ?_, ?_⟩
    · intro P1' hmem hfeas
      rcases hmem with rfl | rfl
      · exact le_rfl
      · exact hbest1 hfeas
    · intro P2' hmem hfeas
      rcases hmem with rfl | rfl
      · exact hbest2 hfeas
      · exact le_rfl

/-- Feasible binary-policy equilibrium characterization for `(P_full, P_sub)`. -/
theorem glm20TwoSchoolBinaryPolicyFeasibleEquilibrium_fullSub_iff
    {Policy : Type*} (objective1 objective2 : Policy → Policy → ℝ)
    (feasible1 feasible2 : Policy → Policy → Prop)
    (Psub Pfull : Policy) :
    glm20TwoSchoolBinaryPolicyFeasibleEquilibrium objective1 objective2
        feasible1 feasible2 Psub Pfull Pfull Psub ↔
      feasible1 Pfull Psub ∧ feasible2 Pfull Psub ∧
        (feasible1 Psub Psub →
          objective1 Psub Psub ≤ objective1 Pfull Psub) ∧
          (feasible2 Pfull Pfull →
            objective2 Pfull Pfull ≤ objective2 Pfull Psub) := by
  constructor
  · rintro ⟨hcur1, hcur2, hbest1, hbest2⟩
    exact ⟨hcur1, hcur2,
      fun hfeas => hbest1 Psub (Or.inl rfl) hfeas,
      fun hfeas => hbest2 Pfull (Or.inr rfl) hfeas⟩
  · rintro ⟨hcur1, hcur2, hbest1, hbest2⟩
    refine ⟨hcur1, hcur2, ?_, ?_⟩
    · intro P1' hmem hfeas
      rcases hmem with rfl | rfl
      · exact hbest1 hfeas
      · exact le_rfl
    · intro P2' hmem hfeas
      rcases hmem with rfl | rfl
      · exact le_rfl
      · exact hbest2 hfeas

/-- Feasible binary-policy equilibrium characterization for `(P_full, P_full)`. -/
theorem glm20TwoSchoolBinaryPolicyFeasibleEquilibrium_fullFull_iff
    {Policy : Type*} (objective1 objective2 : Policy → Policy → ℝ)
    (feasible1 feasible2 : Policy → Policy → Prop)
    (Psub Pfull : Policy) :
    glm20TwoSchoolBinaryPolicyFeasibleEquilibrium objective1 objective2
        feasible1 feasible2 Psub Pfull Pfull Pfull ↔
      feasible1 Pfull Pfull ∧ feasible2 Pfull Pfull ∧
        (feasible1 Psub Pfull →
          objective1 Psub Pfull ≤ objective1 Pfull Pfull) ∧
          (feasible2 Pfull Psub →
            objective2 Pfull Psub ≤ objective2 Pfull Pfull) := by
  constructor
  · rintro ⟨hcur1, hcur2, hbest1, hbest2⟩
    exact ⟨hcur1, hcur2,
      fun hfeas => hbest1 Psub (Or.inl rfl) hfeas,
      fun hfeas => hbest2 Psub (Or.inl rfl) hfeas⟩
  · rintro ⟨hcur1, hcur2, hbest1, hbest2⟩
    refine ⟨hcur1, hcur2, ?_, ?_⟩
    · intro P1' hmem hfeas
      rcases hmem with rfl | rfl
      · exact hbest1 hfeas
      · exact le_rfl
    · intro P2' hmem hfeas
      rcases hmem with rfl | rfl
      · exact hbest2 hfeas
      · exact le_rfl

/--
Capacity/feasibility-aware weighted academic-merit binary-policy surface.

The school objectives are the paper's weighted academic-merit objectives.
The extra `feasible1` and `feasible2` predicates are policy-pair feasibility
conditions for the two schools; in the concrete strategic model these are where
capacity-fill conditions such as Theorem 3(i)'s condition (11) belong.
-/
def glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
    {Group Policy School : Type*}
    (massTestTaking : Group → Policy → ℝ)
    (admittedAcademicMerit : School → Group → Policy → ℝ)
    (diversity : School → Policy → ℝ)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J1 J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ)
    (feasible1 feasible2 : Policy → Policy → Prop) :
    GLM20StrategicPolicySurface Group Policy School (Policy × Policy) where
  massTestTaking := massTestTaking
  admittedAcademicMerit := admittedAcademicMerit
  diversity := diversity
  policyPairIsEquilibrium := fun P1 P2 =>
    glm20TwoSchoolBinaryPolicyFeasibleEquilibrium
      (fun P1 P2 =>
        populationShare groupA * admittedAcademicMerit J1 groupA
            (policyPair P1 P2) +
          populationShare groupB * admittedAcademicMerit J1 groupB
            (policyPair P1 P2))
      (fun P1 P2 =>
        populationShare groupA * admittedAcademicMerit J2 groupA
            (policyPair P1 P2) +
          populationShare groupB * admittedAcademicMerit J2 groupB
            (policyPair P1 P2))
      feasible1 feasible2 Psub Pfull P1 P2
  equilibriumPredicate := fun E =>
    glm20TwoSchoolBinaryPolicyFeasibleEquilibrium
      (fun P1 P2 =>
        populationShare groupA * admittedAcademicMerit J1 groupA
            (policyPair P1 P2) +
          populationShare groupB * admittedAcademicMerit J1 groupB
            (policyPair P1 P2))
      (fun P1 P2 =>
        populationShare groupA * admittedAcademicMerit J2 groupA
            (policyPair P1 P2) +
          populationShare groupB * admittedAcademicMerit J2 groupB
            (policyPair P1 P2))
      feasible1 feasible2 Psub Pfull E.1 E.2

/--
The feasible weighted surface unfolds to the feasible binary best-response game
with the paper's weighted academic-merit objectives.
-/
theorem glm20FeasibleWeightedAcademicMeritBinaryPolicySurface_policyPairIsEquilibrium_iff
    {Group Policy School : Type*}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull P1 P2 : Policy} {J1 J2 : School}
    {groupA groupB : Group} {populationShare : Group → ℝ}
