/--
Lower endpoint of the Lemma 3 standard-bivariate component after substituting
the Eq. (7) application cutoff.
-/
theorem glm20Lemma3StrategicApplicantComponent_standardBivariate_tendsto_atBot_total
    (Q : StandardGaussianQuantileAPI)
    {Group : Type*}
    {populationShare sigmaTilde b mu : Group → ℝ}
    {aOfApply : Group → ℝ → ℝ}
    {priorPrecision subPrecision testPrecision cost : Group → ℝ}
    {value : ℝ} (g : Group)
    (hsigma : 0 < sigmaTilde g)
    (hA :
      Filter.Tendsto
        (fun qAdmit : ℝ =>
          (aOfApply g
              (qAdmit -
                glm20StrategicProjectedScale
                  (priorPrecision g) (subPrecision g) (testPrecision g) *
                Q.quantile (1 - cost g / value)) +
            b g * mu g) /
            Real.sqrt (1 + sigmaTilde g ^ 2 * b g ^ 2))
        Filter.atBot Filter.atTop) :
    Filter.Tendsto
      (glm20Lemma3StrategicApplicantComponent Q
        (fun g qApply qAdmit =>
          glm20BivariateApplyAdmitMass standardGaussianCDFAPI
            standardBivariateGaussianCDF
            (populationShare g) (sigmaTilde g) (aOfApply g)
            (b g) (mu g) qApply qAdmit)
        priorPrecision subPrecision testPrecision cost value g)
      Filter.atBot (nhds (populationShare g * sigmaTilde g)) := by
  let qApply : ℝ → ℝ :=
    fun qAdmit =>
      qAdmit -
        glm20StrategicProjectedScale
          (priorPrecision g) (subPrecision g) (testPrecision g) *
