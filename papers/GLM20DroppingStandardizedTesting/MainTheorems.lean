    {q2Full scale v2 : ℝ}
    (hscale : 0 < scale) (hv2 : 0 < v2) :
    StrictMonoOn
      (fun cost : ℝ =>
        q2Full - scale * Q.quantile (1 - cost / v2))
      (Set.Ioo (0 : ℝ) v2) :=
    paper_proposition5_equation50_subFull_apply_cutoff_strictMonoOn_cost
      Q hscale hv2 (by
        intro cost hcost
        exact
          paper_proposition5_cost_ratio_mem_Ioo_of_pos_lt
            hcost.1 hcost.2)

/--
Proposition 5 / equation (50): interval version of the source-domain
monotonicity.  This is the form used by the monotone crossing proof on a
closed cost interval.
-/
theorem paper_proposition5_equation50_subFull_apply_cutoff_strictMonoOn_cost_interval
    (Q : StandardGaussianQuantileAPI)
    {q2Full scale v2 left right : ℝ}
    (hscale : 0 < scale) (hv2 : 0 < v2) (hleft_pos : 0 < left)
    (hright_lt_v2 : right < v2) :
    StrictMonoOn
      (fun cost : ℝ =>
        q2Full - scale * Q.quantile (1 - cost / v2))
      (Set.Icc left right) :=
    paper_proposition5_equation50_subFull_apply_cutoff_strictMonoOn_cost
      Q hscale hv2 (by
        intro cost hcost
        exact
          paper_proposition5_cost_ratio_mem_Ioo_of_pos_lt
            (by linarith [hcost.1, hleft_pos])
            (by linarith [hcost.2, hright_lt_v2]))

/--
Proposition 5 / equation (50) support: composing the explicit
`(P_sub,P_full)` application cutoff with a merit term that is continuous and
strictly decreasing in the cutoff yields a merit term that is continuous and
strictly decreasing in cost.
-/
theorem paper_proposition5_equation50_subFull_cost_merit_continuous_strictAntiOn
    (Q : StandardGaussianQuantileAPI)
    {q2Full scale v2 : ℝ} {costDomain cutoffDomain : Set ℝ}
    {meritOfCutoff : ℝ → ℝ}
    (hscale : 0 < scale) (hv2 : 0 < v2)
    (hcostRatio : ∀ cost ∈ costDomain, cost / v2 ∈ Set.Ioo (0 : ℝ) 1)
    (hcutoff_maps :
      Set.MapsTo
        (fun cost : ℝ => q2Full - scale * Q.quantile (1 - cost / v2))
        costDomain cutoffDomain)
    (hmerit_cont : ContinuousOn meritOfCutoff cutoffDomain)
    (hmerit_anti : StrictAntiOn meritOfCutoff cutoffDomain) :
    ContinuousOn
        (fun cost : ℝ =>
          meritOfCutoff (q2Full - scale * Q.quantile (1 - cost / v2)))
        costDomain ∧
      StrictAntiOn
        (fun cost : ℝ =>
          meritOfCutoff (q2Full - scale * Q.quantile (1 - cost / v2)))
        costDomain := by
  have harg_cont :
      ContinuousOn (fun cost : ℝ => 1 - cost / v2) costDomain := by
    fun_prop
  have harg_mem :
      ∀ cost ∈ costDomain, 1 - cost / v2 ∈ Set.Ioo (0 : ℝ) 1 := by
    intro cost hcost
    have hratio := hcostRatio cost hcost
    constructor <;> linarith [hratio.1, hratio.2]
  have hquant_cont :
      ContinuousOn (fun cost : ℝ => Q.quantile (1 - cost / v2))
        costDomain :=
    Q.quantile_continuous.comp harg_cont harg_mem
  have hcutoff_cont :
      ContinuousOn
        (fun cost : ℝ => q2Full - scale * Q.quantile (1 - cost / v2))
        costDomain :=
    continuousOn_const.sub (continuousOn_const.mul hquant_cont)
  have hcutoff_mono :
      StrictMonoOn
        (fun cost : ℝ => q2Full - scale * Q.quantile (1 - cost / v2))
        costDomain :=
    paper_proposition5_equation50_subFull_apply_cutoff_strictMonoOn_cost
      Q hscale hv2 hcostRatio
  exact
    ⟨continuousOn_comp_of_mapsTo hmerit_cont hcutoff_cont hcutoff_maps,
      strictAntiOn_comp_strictMonoOn hmerit_anti hcutoff_mono hcutoff_maps⟩

/--
Proposition 5 / equation (50) support: the explicit `(P_sub,P_full)` cutoff
formula and a cutoff-level merit crossing construct a cost threshold on any
closed interval contained in the valid inverse-CDF domain.

This is the source proof's monotone-crossing step with the equation-(50)
cutoff substituted.  The interval is stated as `[left,right]` rather than
hard-coding `[0,maxCost]`, since the inverse-CDF expression itself requires
`c/v_2 ∈ (0,1)`.
-/
theorem paper_proposition5_equation50_subFull_cost_threshold_of_cutoff_merit_crossing_interval
    (Q : StandardGaussianQuantileAPI)
    {q2Full scale v2 left right testFreeMerit : ℝ}
    {cutoffDomain : Set ℝ} {meritOfCutoff : ℝ → ℝ}
    (hleft_right : left < right)
    (hscale : 0 < scale) (hv2 : 0 < v2)
    (hcostRatio :
      ∀ cost ∈ Set.Icc left right, cost / v2 ∈ Set.Ioo (0 : ℝ) 1)
    (hcutoff_maps :
      Set.MapsTo
        (fun cost : ℝ => q2Full - scale * Q.quantile (1 - cost / v2))
        (Set.Icc left right) cutoffDomain)
    (hmerit_cont : ContinuousOn meritOfCutoff cutoffDomain)
    (hmerit_anti : StrictAntiOn meritOfCutoff cutoffDomain)
    (hleft :
      testFreeMerit <
        meritOfCutoff (q2Full - scale * Q.quantile (1 - left / v2)))
    (hright :
      meritOfCutoff (q2Full - scale * Q.quantile (1 - right / v2)) <
        testFreeMerit) :
    ∃ costThreshold : ℝ,
      costThreshold ∈ Set.Ioo left right ∧
        meritOfCutoff
            (q2Full - scale * Q.quantile (1 - costThreshold / v2)) =
          testFreeMerit ∧
          (∀ cost ∈ Set.Icc left right,
            testFreeMerit <
                meritOfCutoff
                  (q2Full - scale * Q.quantile (1 - cost / v2)) ↔
              cost < costThreshold) ∧
            (∀ cost ∈ Set.Icc left right,
              meritOfCutoff
                  (q2Full - scale * Q.quantile (1 - cost / v2)) <
                testFreeMerit ↔
                costThreshold < cost) ∧
              (∀ cost ∈ Set.Icc left right,
                testFreeMerit ≤
                    meritOfCutoff
                      (q2Full - scale * Q.quantile (1 - cost / v2)) ↔
                  cost ≤ costThreshold) ∧
                (∀ cost ∈ Set.Icc left right,
                  meritOfCutoff
                      (q2Full - scale * Q.quantile (1 - cost / v2)) ≤
                    testFreeMerit ↔
                    costThreshold ≤ cost) := by
  let costMerit : ℝ → ℝ := fun cost =>
    meritOfCutoff (q2Full - scale * Q.quantile (1 - cost / v2))
  have hcostMerit :
      ContinuousOn costMerit (Set.Icc left right) ∧
        StrictAntiOn costMerit (Set.Icc left right) :=
    paper_proposition5_equation50_subFull_cost_merit_continuous_strictAntiOn
      Q hscale hv2 hcostRatio hcutoff_maps hmerit_cont hmerit_anti
  exact
    exists_threshold_of_continuous_strictAntiOn_Icc_crossing_interval
      (f := costMerit) (level := testFreeMerit) hleft_right
      hcostMerit.1 hcostMerit.2 hleft hright

/--
Proposition 5 / equation (50) support for real-valued merit functions.

This all-`ℝ` cutoff-domain specialization removes the mechanical
`Set.MapsTo` premise from
`paper_proposition5_equation50_subFull_cost_threshold_of_cutoff_merit_crossing_interval`.
It is the preferred entry point when the concrete admitted-merit formula is a
continuous strictly decreasing function of the student cutoff on all real
cutoffs.
-/
theorem paper_proposition5_equation50_subFull_cost_threshold_of_cutoff_merit_crossing_interval_univ
    (Q : StandardGaussianQuantileAPI)
    {q2Full scale v2 left right testFreeMerit : ℝ}
    {meritOfCutoff : ℝ → ℝ}
    (hleft_right : left < right)
    (hscale : 0 < scale) (hv2 : 0 < v2)
    (hcostRatio :
      ∀ cost ∈ Set.Icc left right, cost / v2 ∈ Set.Ioo (0 : ℝ) 1)
    (hmerit_cont : ContinuousOn meritOfCutoff Set.univ)
    (hmerit_anti : StrictAntiOn meritOfCutoff Set.univ)
    (hleft :
