      (q2Sub := q2Sub) standardGaussianCDFAPI subEstimateLaw hshareA
      hshareB hmassFullFullA hmassFullFullB hcapacity2 hfillFullFull2
  exact
    paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_selected_twoFull_merit_crossings_interval
      (S := S) (policyPair := policyPair) (Psub := Psub)
      (Pfull := Pfull) (groupA := groupA) (groupB := groupB)
      (testCost := testCost) (leftCost := leftCost)
      (rightCost := rightCost) (q1Sub := q1Sub) (q2Sub := q2Sub)
      subEstimateLaw (fullFullCutoff := fullFullCutoff)
      (fullSubCutoff := fullSubCutoff) objective1 objective2
      (lowQ1Full := lowQ1Full) (lowQ2Full := lowQ2Full)
      (lowScale := lowScale) (lowV1 := lowV1) (lowV2 := lowV2)
      (highQ1Full := highQ1Full) (highQ2Full := highQ2Full)
      (highScale := highScale) (highV1 := highV1) (highV2 := highV2)
      lowCutoffOfCost highCutoffOfCost lowMeritOfCutoff
      lowTestFreeMerit highMeritOfCutoff highTestFreeMerit hleft_right
