    (hweight2 : ∀ g, 0 ≤ weight2 g) (hpos2 : ∃ g, 0 < weight2 g)
    (hcapacity2 : capacity2 ∈ Set.Ioo (0 : ℝ) (∑ g : Group2, weight2 g))
