    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ) (g : Group) :
    glm20Theorem3PolicyStateCutoffMass api subEstimateLaw subSubMass
        subFullMass fullFullCutoff fullSubCutoff g
        (glm20StrategicPolicyStatePair
          GLM20StrategicPolicyState.singleFull
          GLM20StrategicPolicyState.singleFull) =
      api.thresholdPassProb (subEstimateLaw g) (fullFullCutoff g) := rfl

@[simp] theorem glm20Theorem3PolicyStateCutoffMass_fullSub
    {Group : Type*}
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ) (g : Group) :
