/--
Override one school's scalar table entry while leaving the other rows as a
fallback table.
-/
def glm20OverrideSchoolValue
    {School : Type*} [DecidableEq School]
    (target : School) (value : ℝ) (fallback : School → ℝ) : School → ℝ := fun J => if J = target then value else fallback J

@[simp] theorem glm20OverrideSchoolValue_self
    {School : Type*} [DecidableEq School]
    (target : School) (value : ℝ) (fallback : School → ℝ) :
    glm20OverrideSchoolValue target value fallback target = value := by
  simp [glm20OverrideSchoolValue]

theorem glm20OverrideSchoolValue_of_ne
    {School : Type*} [DecidableEq School]
    {target J : School} (hJ : J ≠ target) (value : ℝ)
    (fallback : School → ℝ) :
    glm20OverrideSchoolValue target value fallback J = fallback J := by
  simp [glm20OverrideSchoolValue, hJ]

/--
Override one school's admitted-merit row while leaving the other rows as a
fallback table.  This is useful for source-family endpoints where only one
school's row has already been identified with a Gaussian upper-tail mean.
-/
def glm20OverrideSchoolMeritRow
    {Group School : Type*} [DecidableEq School]
    (target : School) (value : Group → ℝ)
    (fallback : School → Group → ℝ) : School → Group → ℝ := fun J g => if J = target then value g else fallback J g

@[simp] theorem glm20OverrideSchoolMeritRow_self
    {Group School : Type*} [DecidableEq School]
    (target : School) (value : Group → ℝ)
    (fallback : School → Group → ℝ) (g : Group) :
    glm20OverrideSchoolMeritRow target value fallback target g = value g := by
  simp [glm20OverrideSchoolMeritRow]

theorem glm20OverrideSchoolMeritRow_of_ne
    {Group School : Type*} [DecidableEq School]
    {target J : School} (hJ : J ≠ target) (value : Group → ℝ)
    (fallback : School → Group → ℝ) (g : Group) :
    glm20OverrideSchoolMeritRow target value fallback J g = fallback J g := by
  simp [glm20OverrideSchoolMeritRow, hJ]

/--
Theorem 3 fixed-pool admitted-merit table for `(P_sub,P_full)`: the row for
school `J1` is the source Gaussian tail mean, while all other rows are kept in
the fallback table.
-/
def glm20Theorem3SourceFamilySubFullMeritTable
    {Group School FeatureDrop : Type*} [DecidableEq School]
    [Fintype FeatureDrop] [Nonempty FeatureDrop]
    (C : GaussianHazardCertificate) (J1 : School)
    (J1DropFamily : Group → GaussianOffsetSignalFamily FeatureDrop)
    (J1DropThreshold : Group → ℝ)
    (fallback : School → Group → ℝ) : School → Group → ℝ :=
  glm20OverrideSchoolMeritRow J1
    (fun g =>
      C.normalUpperTailMean
        (J1DropFamily g).posteriorMeanScaleLaw
        (J1DropThreshold g))
    fallback

/--
Theorem 3 fixed-pool admitted-merit table for `(P_full,P_sub)`: the row for
school `J2` is the source Gaussian tail mean, while all other rows are kept in
the fallback table.
-/
def glm20Theorem3SourceFamilyFullSubMeritTable
    {Group School FeatureDrop : Type*} [DecidableEq School]
    [Fintype FeatureDrop] [Nonempty FeatureDrop]
    (C : GaussianHazardCertificate) (J2 : School)
    (J2DropFamily : Group → GaussianOffsetSignalFamily FeatureDrop)
    (J2DropThreshold : Group → ℝ)
    (fallback : School → Group → ℝ) : School → Group → ℝ :=
  glm20OverrideSchoolMeritRow J2
    (fun g =>
      C.normalUpperTailMean
        (J2DropFamily g).posteriorMeanScaleLaw
        (J2DropThreshold g))
    fallback

/--
Theorem 3 fixed-pool admitted-merit table for `(P_full,P_full)`: the two
school rows are the source Gaussian tail means for the corresponding
full-policy families.
-/
def glm20Theorem3SourceFamilyFullFullMeritTable
    {Group School FeatureKeep : Type*} [DecidableEq School]
    [Fintype FeatureKeep] [Nonempty FeatureKeep]
    (C : GaussianHazardCertificate) (J1 J2 : School)
    (J1KeepFamily J2KeepFamily :
      Group → GaussianOffsetSignalFamily FeatureKeep)
    (J1KeepThreshold J2KeepThreshold : Group → ℝ)
    (fallback : School → Group → ℝ) : School → Group → ℝ :=
  glm20OverrideSchoolMeritRow J2
    (fun g =>
      C.normalUpperTailMean
        (J2KeepFamily g).posteriorMeanScaleLaw
        (J2KeepThreshold g))
    (glm20OverrideSchoolMeritRow J1
      (fun g =>
        C.normalUpperTailMean
          (J1KeepFamily g).posteriorMeanScaleLaw
          (J1KeepThreshold g))
      fallback)

/--
Standard-Gaussian fixed-pool admitted-merit table for `(P_sub,P_full)`.

This is the mathlib-backed specialization of
`glm20Theorem3SourceFamilySubFullMeritTable`: school `J1`'s row is the
standard-normal Gaussian upper-tail mean generated by the dropped-feature
source family.
-/
abbrev glm20Theorem3StandardGaussianSourceFamilySubFullMeritTable
    {Group School FeatureDrop : Type*} [DecidableEq School]
    [Fintype FeatureDrop] [Nonempty FeatureDrop]
    (J1 : School)
    (J1DropFamily : Group → GaussianOffsetSignalFamily FeatureDrop)
    (J1DropThreshold : Group → ℝ)
    (fallback : School → Group → ℝ) : School → Group → ℝ :=
  glm20Theorem3SourceFamilySubFullMeritTable
    standardGaussianHazardInverseCertificate.toGaussianHazardCertificate J1
    J1DropFamily J1DropThreshold fallback

