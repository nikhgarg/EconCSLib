/--
Theorem 3 source mass table with the paper's `K_g` cutoff formulas wired into
the full/full and full/sub policy states.
-/
def glm20Theorem3PolicyStateCutoffMass
    {Group : Type*}
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ) :
    Group → GLM20StrategicPolicyState → ℝ :=
  glm20StrategicPolicyStateMass subSubMass subFullMass
    (fun g =>
      api.thresholdPassProb (subEstimateLaw g) (fullSubCutoff g))
    (fun g =>
      api.thresholdPassProb (subEstimateLaw g) (fullFullCutoff g))

