/--
Proposition 5(ii) school-`J1` bridge from cutoff-case proof language to the
paper's condition (14).

The first branch says dropping the test would not expand `J1`'s pool; the
second branch is the high-cost merit-loss threshold.
-/
theorem paper_proposition5_part_ii_school1_objective_iff_condition14_of_cutoff_case
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy)
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {testCost highCostThreshold : Group → ℝ}
    {q1Sub : ℝ} {fullSubCutoff : Group → ℝ} {g : Group}
    (objective1 : Policy → Policy → ℝ)
    (hmass :
      S.massTestTaking g (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw g)
          (fullSubCutoff g))
    (hobjectiveCutoff :
      (objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
        fullSubCutoff g < q1Sub ∨ testCost g ≤ highCostThreshold g) :
    (objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
      glm20Theorem3FullSubSchool1KeepsTestCondition S policyPair Psub Pfull
        testCost highCostThreshold q1Sub
        (fun g q =>
          glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q) g :=
  hobjectiveCutoff.trans
    (paper_proposition5_condition14_iff_fullSub_cutoff_case_or_low_cost
      S policyPair Psub Pfull api subEstimateLaw hmass).symm

/--
Proposition 5(ii) school-`J1` cutoff-case analysis.

The source proof splits condition (14): if dropping does not expand `J1`'s
pool, then `J1` keeps the test; otherwise keeping the test is equivalent to
the high cost-threshold comparison.
-/
theorem paper_proposition5_part_ii_school1_cutoff_objective_iff_no_expand_or_low_cost
    {Group Policy : Type*}
    {Psub Pfull : Policy} {g : Group}
    {testCost highCostThreshold : Group → ℝ}
    {q1Sub : ℝ} {fullSubCutoff : Group → ℝ}
    (objective1 : Policy → Policy → ℝ)
    (hnoExpand :
      fullSubCutoff g < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpand :
      ¬ fullSubCutoff g < q1Sub →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          testCost g ≤ highCostThreshold g)) :
    (objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
      fullSubCutoff g < q1Sub ∨ testCost g ≤ highCostThreshold g := by
  by_cases hcutoff : fullSubCutoff g < q1Sub
  · constructor
    · intro _hobjective
      exact Or.inl hcutoff
    · intro _hcondition
      exact hnoExpand hcutoff
  · have hiff :
        (objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          testCost g ≤ highCostThreshold g :=
      hexpand hcutoff
    constructor
    · intro hobjective
      exact Or.inr (hiff.mp hobjective)
    · intro hcondition
      rcases hcondition with hcutoff' | hcost
      · exact False.elim (hcutoff hcutoff')
      · exact hiff.mpr hcost

/--
Proposition 5(ii), school-`J1`, with condition (14)'s high-cost threshold
derived from the source proof's monotone merit comparison.

When dropping the test would not expand `J1`'s pool, the school keeps the test
immediately.  In the expanding case, the source proof compares a continuous
strictly decreasing test-based merit term against the test-free merit, yielding
a positive threshold `c''_g`; keeping the test is equivalent to
`c_g ≤ c''_g`.
-/
theorem
    paper_proposition5_part_ii_school1_cutoff_objective_iff_no_expand_or_low_cost_of_merit_crossing
    {Group Policy : Type*}
    {Psub Pfull : Policy} {g : Group}
    {testCost maxCost : Group → ℝ}
    {q1Sub : ℝ} {fullSubCutoff : Group → ℝ}
    (objective1 : Policy → Policy → ℝ)
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g) (Set.Icc (0 : ℝ) (maxCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g) (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowCost : ∀ g, testFreeMerit g < testBasedMerit g 0)
    (hhighCost : ∀ g, testBasedMerit g (maxCost g) < testFreeMerit g)
    (hnoExpand :
      fullSubCutoff g < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpand_merit :
      ¬ fullSubCutoff g < q1Sub →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          testFreeMerit g ≤ testBasedMerit g (testCost g))) :
    ∃ highCostThreshold : Group → ℝ,
      (∀ g, highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, testBasedMerit g (highCostThreshold g) = testFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (testFreeMerit g ≤ testBasedMerit g c ↔
              c ≤ highCostThreshold g)) ∧
            ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
              fullSubCutoff g < q1Sub ∨ testCost g ≤ highCostThreshold g) := by
  classical
  have hthreshold :
      ∀ g : Group, ∃ highCostThreshold : ℝ,
        highCostThreshold ∈ Set.Ioo (0 : ℝ) (maxCost g) ∧
          testBasedMerit g highCostThreshold = testFreeMerit g ∧
            (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
              testFreeMerit g < testBasedMerit g c ↔
                c < highCostThreshold) ∧
              (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                testBasedMerit g c < testFreeMerit g ↔
                  highCostThreshold < c) ∧
                (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                  testFreeMerit g ≤ testBasedMerit g c ↔
                    c ≤ highCostThreshold) ∧
                  (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                    testBasedMerit g c ≤ testFreeMerit g ↔
                      highCostThreshold ≤ c) := by
    intro g
    exact
      exists_threshold_of_continuous_strictAntiOn_Icc_crossing_interval
        (f := testBasedMerit g) (level := testFreeMerit g)
        (left := 0) (right := maxCost g) (hmaxCost g) (hcont g) (hanti g)
        (hlowCost g) (hhighCost g)
  let highCostThreshold : Group → ℝ :=
    fun g => Classical.choose (hthreshold g)
  have hspec :
      ∀ g,
        highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g) ∧
          testBasedMerit g (highCostThreshold g) = testFreeMerit g ∧
            (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
              testFreeMerit g < testBasedMerit g c ↔
                c < highCostThreshold g) ∧
              (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                testBasedMerit g c < testFreeMerit g ↔
                  highCostThreshold g < c) ∧
                (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                  testFreeMerit g ≤ testBasedMerit g c ↔
                    c ≤ highCostThreshold g) ∧
                  (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                    testBasedMerit g c ≤ testFreeMerit g ↔
                      highCostThreshold g ≤ c) := by
    intro g
    exact Classical.choose_spec (hthreshold g)
  have hmem :
      ∀ g, highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g) :=
    fun g => (hspec g).1
  have heq :
      ∀ g, testBasedMerit g (highCostThreshold g) = testFreeMerit g :=
    fun g => (hspec g).2.1
  have hge :
      ∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
        (testFreeMerit g ≤ testBasedMerit g c ↔
          c ≤ highCostThreshold g) :=
    fun g => (hspec g).2.2.2.2.1
  have hexpand :
      ¬ fullSubCutoff g < q1Sub →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          testCost g ≤ highCostThreshold g) := by
    intro hcutoff
    exact (hexpand_merit hcutoff).trans
      (hge g (testCost g) (hcostMem g))
  refine ⟨highCostThreshold, hmem, heq, hge, ?_⟩
  exact
    paper_proposition5_part_ii_school1_cutoff_objective_iff_no_expand_or_low_cost
      objective1 hnoExpand hexpand

/--
Proposition 5(ii), school-`J1`, high-threshold construction from explicit
objective-value formulas.

In the expanding case, it is enough to identify the deviation objective with
the test-free merit formula and the keep-test objective with the test-based
merit formula.  The theorem then rewrites the objective comparison and
constructs condition (14)'s high threshold.
-/
theorem
    paper_proposition5_part_ii_school1_cutoff_objective_iff_no_expand_or_low_cost_of_merit_formulas
    {Group Policy : Type*}
    {Psub Pfull : Policy} {g : Group}
    {testCost maxCost : Group → ℝ}
    {q1Sub : ℝ} {fullSubCutoff : Group → ℝ}
    (objective1 : Policy → Policy → ℝ)
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g) (Set.Icc (0 : ℝ) (maxCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g) (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowCost : ∀ g, testFreeMerit g < testBasedMerit g 0)
    (hhighCost : ∀ g, testBasedMerit g (maxCost g) < testFreeMerit g)
    (hnoExpand :
      fullSubCutoff g < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpand_testFree :
      ¬ fullSubCutoff g < q1Sub →
        objective1 Psub Psub = testFreeMerit g)
    (hexpand_testBased :
      ¬ fullSubCutoff g < q1Sub →
        objective1 Pfull Psub = testBasedMerit g (testCost g)) :
    ∃ highCostThreshold : Group → ℝ,
      (∀ g, highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, testBasedMerit g (highCostThreshold g) = testFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (testFreeMerit g ≤ testBasedMerit g c ↔
              c ≤ highCostThreshold g)) ∧
            ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
              fullSubCutoff g < q1Sub ∨ testCost g ≤ highCostThreshold g) :=
  paper_proposition5_part_ii_school1_cutoff_objective_iff_no_expand_or_low_cost_of_merit_crossing
    objective1 testBasedMerit testFreeMerit hmaxCost hcostMem hcont hanti
    hlowCost hhighCost hnoExpand
    (by
      intro hcutoff
      exact
        glm20_policy_pair_objective_le_iff_of_value_eq objective1
          (hexpand_testFree hcutoff) (hexpand_testBased hcutoff))

/--
Proposition 5(ii), school-`J1`, condition-(14) high-threshold bridges at an
already constructed high threshold.

This form is designed for the combined Theorem 3(ii) proof, where the high
threshold is constructed together with the school-`J2` lower threshold.  It
does not choose a new threshold; it only proves that the weighted objective
comparison is equivalent to the paper's no-expansion-or-low-cost condition for
both candidate groups.
-/
theorem
    paper_proposition5_part_ii_school1_weighted_objective_cutoff_bridges_of_group_merit_formulas_at_threshold
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 : School} {groupA groupB : Group}
    {populationShare testCost maxCost highCostThreshold : Group → ℝ}
    {q1Sub : ℝ} {fullSubCutoff : Group → ℝ}
    (highTestBasedMerit : Group → ℝ → ℝ)
    (highTestFreeMerit : Group → ℝ)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hhighGe :
      ∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
        (highTestFreeMerit g ≤ highTestBasedMerit g c ↔
          c ≤ highCostThreshold g))
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandA_groupB_eq :
      ¬ fullSubCutoff groupA < q1Sub →
        S.admittedAcademicMerit J1 groupB (policyPair Psub Psub) =
          S.admittedAcademicMerit J1 groupB (policyPair Pfull Psub))
    (hexpandA_groupA_testFree :
      ¬ fullSubCutoff groupA < q1Sub →
        S.admittedAcademicMerit J1 groupA (policyPair Psub Psub) =
          highTestFreeMerit groupA)
    (hexpandA_groupA_testBased :
      ¬ fullSubCutoff groupA < q1Sub →
        S.admittedAcademicMerit J1 groupA (policyPair Pfull Psub) =
          highTestBasedMerit groupA (testCost groupA))
    (hnoExpandB :
      fullSubCutoff groupB < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandB_groupA_eq :
      ¬ fullSubCutoff groupB < q1Sub →
        S.admittedAcademicMerit J1 groupA (policyPair Psub Psub) =
          S.admittedAcademicMerit J1 groupA (policyPair Pfull Psub))
    (hexpandB_groupB_testFree :
      ¬ fullSubCutoff groupB < q1Sub →
        S.admittedAcademicMerit J1 groupB (policyPair Psub Psub) =
          highTestFreeMerit groupB)
    (hexpandB_groupB_testBased :
      ¬ fullSubCutoff groupB < q1Sub →
        S.admittedAcademicMerit J1 groupB (policyPair Pfull Psub) =
          highTestBasedMerit groupB (testCost groupB)) :
    (((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare Psub Psub ≤
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare Pfull Psub) ↔
        fullSubCutoff groupA < q1Sub ∨
          testCost groupA ≤ highCostThreshold groupA) ∧
      ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare Psub Psub ≤
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare Pfull Psub) ↔
        fullSubCutoff groupB < q1Sub ∨
          testCost groupB ≤ highCostThreshold groupB)) := by
  let objective1 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1 groupA groupB
