/--
Section 5 projected-skill scale in the paper's precision notation.

For a student who observes the non-test features before deciding whether to
take the test, this is the scale multiplying
`Phi^{-1}(1 - cost/value)` in Lemma 3's displayed cutoff.
-/
def glm20StrategicProjectedScale
    (priorPrecision subPrecision testPrecision : ℝ) : ℝ :=
  Real.sqrt
      ((priorPrecision + testPrecision) /
        (priorPrecision + subPrecision + testPrecision)) *
    Real.sqrt (1 / (priorPrecision + subPrecision))

/-- The Section 5 projected-skill scale is positive under positive precisions. -/
theorem glm20StrategicProjectedScale_pos
    {priorPrecision subPrecision testPrecision : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision) :
    0 < glm20StrategicProjectedScale
      priorPrecision subPrecision testPrecision := by
  have hnum_pos : 0 < priorPrecision + testPrecision := by linarith
  have hden_pos : 0 < priorPrecision + subPrecision + testPrecision := by
    linarith
  have hsubden_pos : 0 < priorPrecision + subPrecision := by linarith
  dsimp [glm20StrategicProjectedScale]
  exact mul_pos
    (Real.sqrt_pos.mpr (div_pos hnum_pos hden_pos))
    (Real.sqrt_pos.mpr (one_div_pos.mpr hsubden_pos))

/--
Proposition 5 support for equation (46) in the paper's displayed
precision-scale notation.

Under positive source precisions and `0 < c_g < v_1`, the full/full payoff
has a unique zero-payoff projected-skill cutoff, and applying is weakly
optimal exactly above it.
-/
theorem paper_proposition5_standardGaussian_twoFull_apply_payoff_cutoff_existsUnique_precision
    {q1Full q2Full priorPrecision subPrecision testPrecision v1 v2 cost : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hcost_pos : 0 < cost) (hcost_lt_v1 : cost < v1)
    (hv2_pos : 0 < v2) (hv2_lt_v1 : v2 < v1) :
    ∃! cutoff : ℝ,
      glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          q1Full q2Full
          (glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision)
          v1 v2 cost cutoff = 0 ∧
        ∀ q : ℝ,
          0 ≤ glm20StrategicTwoFullPolicyApplyPayoffValue
              standardGaussianCDFAPI q1Full q2Full
              (glm20StrategicProjectedScale
                priorPrecision subPrecision testPrecision)
              v1 v2 cost q ↔
            cutoff ≤ q :=
    paper_proposition5_standardGaussian_twoFull_apply_payoff_cutoff_existsUnique
      (q1Full := q1Full) (q2Full := q2Full)
      (scale :=
        glm20StrategicProjectedScale
          priorPrecision subPrecision testPrecision)
      (v1 := v1) (v2 := v2) (cost := cost)
      (glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos)
      hcost_pos hcost_lt_v1 hv2_pos hv2_lt_v1

/--
Proposition 2 group-indexed threshold-equilibrium object.

The equilibrium data are the school-`J1` full-score cutoff, the school-`J2`
test-free cutoff, and a group-indexed student application strategy.  Each group
has its own projected precision scale and cost, while the school cutoffs are
shared.  The strategy is the paper's low/high cutoff region from equations
(42)--(43).
-/
def glm20Proposition2TwoSchoolGroupThresholdEquilibrium
    {Group : Type*}
    (Q : StandardGaussianQuantileAPI)
    (applicantMass1 applicantMass2 : ℝ → ℝ)
    (capacity1 capacity2 v1 v2 : ℝ)
    (priorPrecision subPrecision testPrecision cost : Group → ℝ)
    (hscale :
      ∀ g : Group,
        0 < glm20StrategicProjectedScale
          (priorPrecision g) (subPrecision g) (testPrecision g))
    (equilibrium : ℝ × ℝ × (Group → ℝ → Bool)) : Prop :=
  let admissionThreshold := equilibrium.1
  let school2SubThreshold := equilibrium.2.1
  let strategy := equilibrium.2.2
  glm20CapacityThreshold applicantMass1 capacity1 admissionThreshold ∧
    glm20CapacityThreshold applicantMass2 capacity2 school2SubThreshold ∧
      (∀ g : Group, ∀ q : ℝ, ∀ apply : Bool,
        let lowCutoff :=
          glm20StrategicApplyCutoff Q admissionThreshold
            (glm20StrategicProjectedScale
              (priorPrecision g) (subPrecision g) (testPrecision g))
            (cost g / v1)
        let highCutoff :=
          glm20StrategicApplyCutoff Q admissionThreshold
            (glm20StrategicProjectedScale
              (priorPrecision g) (subPrecision g) (testPrecision g))
            (cost g / (v1 - v2))
        glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2
            (cost g)
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale :=
                  glm20StrategicProjectedScale
                    (priorPrecision g) (subPrecision g) (testPrecision g)
                scale_pos := hscale g }
              admissionThreshold)
            q apply ≤
          glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2
            (cost g)
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale :=
                  glm20StrategicProjectedScale
                    (priorPrecision g) (subPrecision g) (testPrecision g)
                scale_pos := hscale g }
              admissionThreshold)
            q (strategy g q)) ∧
        strategy =
          fun g q =>
            let lowCutoff :=
              glm20StrategicApplyCutoff Q admissionThreshold
                (glm20StrategicProjectedScale
                  (priorPrecision g) (subPrecision g) (testPrecision g))
                (cost g / v1)
            let highCutoff :=
              glm20StrategicApplyCutoff Q admissionThreshold
                (glm20StrategicProjectedScale
                  (priorPrecision g) (subPrecision g) (testPrecision g))
                (cost g / (v1 - v2))
            decide
              ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
                (school2SubThreshold ≤ q ∧ highCutoff ≤ q))

/--
Lemma 3 support: under the projected Gaussian admission law from Appendix
D.6, clearing the application value/cost threshold is exactly being above the
paper's displayed projected-skill cutoff.
-/
theorem paper_lemma3_gaussian_admission_probability_ge_cost_ratio_iff_cutoff_le
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold scale costRatio q : ℝ}
    (hscale : 0 < scale)
    (hcostRatio : costRatio ∈ Set.Ioo (0 : ℝ) 1) :
    costRatio ≤
        Q.cdfAPI.thresholdPassProb
          { mean := q, scale := scale, scale_pos := hscale }
          admissionThreshold ↔
      glm20StrategicApplyCutoff Q admissionThreshold scale costRatio ≤ q := by
  have htail :=
    Q.le_standardTail_iff_le_quantile_one_sub
      (alpha := costRatio) (z := (admissionThreshold - q) / scale)
      hcostRatio
  constructor
  · intro hprob
    have hstd :
        (admissionThreshold - q) / scale ≤
          Q.quantile (1 - costRatio) :=
      htail.mp (by
        simpa [StandardGaussianCDFAPI.thresholdPassProb,
          StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
          GaussianScaleLaw.standardize] using hprob)
    have hmul :
        admissionThreshold - q ≤
          scale * Q.quantile (1 - costRatio) := by
      have := (div_le_iff₀ hscale).mp hstd
      simpa [mul_comm] using this
    unfold glm20StrategicApplyCutoff
    linarith
  · intro hcutoff
    have hstd :
        (admissionThreshold - q) / scale ≤
          Q.quantile (1 - costRatio) := by
      rw [div_le_iff₀ hscale]
      unfold glm20StrategicApplyCutoff at hcutoff
      linarith
    have hprob := htail.mpr hstd
    simpa [StandardGaussianCDFAPI.thresholdPassProb,
      StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
      GaussianScaleLaw.standardize] using hprob

/--
Section 5 payoff algebra: applying is weakly optimal against a zero outside
option exactly when admission probability is at least `cost / value`.
-/
theorem paper_lemma3_apply_payoff_nonnegative_iff_cost_ratio_le_probability
    {value cost admissionProbability : ℝ} (hvalue : 0 < value) :
    0 ≤ value * admissionProbability - cost ↔
      cost / value ≤ admissionProbability := by
  constructor
  · intro hpayoff
    have hcost : cost ≤ value * admissionProbability := by
      linarith
    have := (div_le_iff₀ hvalue).mpr (by
      simpa [mul_comm] using hcost)
    exact this
  · intro hprob
    have hcost : cost ≤ value * admissionProbability := by
      have := (div_le_iff₀ hvalue).mp hprob
      simpa [mul_comm] using this
    linarith

/--
Section 5 payoff algebra, strict upper side: applying is strictly better than
the zero outside option exactly when the admission probability is strictly above
`cost / value`.
-/
theorem paper_lemma3_apply_payoff_positive_iff_cost_ratio_lt_probability
    {value cost admissionProbability : ℝ} (hvalue : 0 < value) :
    0 < value * admissionProbability - cost ↔
      cost / value < admissionProbability := by
  constructor
  · intro hpayoff
    rw [div_lt_iff₀ hvalue]
    nlinarith
  · intro hprob
    have hcost : cost < value * admissionProbability := by
      have := (div_lt_iff₀ hvalue).mp hprob
      simpa [mul_comm] using this
    linarith

/--
Section 5 payoff algebra, strict lower side: applying is strictly worse than
the zero outside option exactly when the admission probability is strictly below
`cost / value`.
-/
theorem paper_lemma3_apply_payoff_negative_iff_probability_lt_cost_ratio
    {value cost admissionProbability : ℝ} (hvalue : 0 < value) :
    value * admissionProbability - cost < 0 ↔
      admissionProbability < cost / value := by
  constructor
  · intro hpayoff
    rw [lt_div_iff₀ hvalue]
    nlinarith
  · intro hprob
    have hcost : value * admissionProbability < cost := by
      have := (lt_div_iff₀ hvalue).mp hprob
      simpa [mul_comm] using this
    linarith

/--
Lemma 3 support, payoff form: a strategic student under the one-school
full-test policy applies iff their projected skill is above the paper's
Gaussian cutoff.
-/
theorem paper_lemma3_apply_payoff_nonnegative_iff_above_gaussian_cutoff
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold scale value cost q : ℝ}
    (hscale : 0 < scale) (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    0 ≤ value *
        Q.cdfAPI.thresholdPassProb
          { mean := q, scale := scale, scale_pos := hscale }
          admissionThreshold - cost ↔
      glm20StrategicApplyCutoff Q admissionThreshold scale (cost / value) ≤ q :=
  (paper_lemma3_apply_payoff_nonnegative_iff_cost_ratio_le_probability
      (value := value) (cost := cost)
      (admissionProbability :=
        Q.cdfAPI.thresholdPassProb
          { mean := q, scale := scale, scale_pos := hscale }
          admissionThreshold)
      hvalue).trans
    (paper_lemma3_gaussian_admission_probability_ge_cost_ratio_iff_cutoff_le
      Q hscale hcostRatio)

/--
Proposition 5 / equation (50) support.

Paper statement: under `(P_sub,P_full)`, the group-`g` cutoff for applying to
school `J2` is
`q^g_{sub,full} = q^*_{2,full} - rho_g * Phi^{-1}(1 - c_g / v_2)`.

This is the Lemma 3 one-school cutoff formula specialized to school `J2`'s
value `v_2`, together with the exact weak-payoff iff.
