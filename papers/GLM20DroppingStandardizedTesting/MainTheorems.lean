      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        (lowBasedLaw g c).mean = (highBasedLaw g c).mean)
    (hbasedScale :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
