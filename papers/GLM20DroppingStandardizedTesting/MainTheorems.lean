/--
Condition (12) bookkeeping on the concrete table surface: a strict weighted
single-surviving-group comparison stated on the paper's admitted-merit tables
is exactly the surface-level comparison used by the Theorem 3 wrapper.
-/
theorem
    glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface_subFull_weighted_merit_gt_subSub_of_component
    {Group School : Type*}
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ)
    (subSubMerit subFullMerit fullSubMerit fullFullMerit :
      School → Group → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 J : School) (groupA groupB survivingGroup : Group)
    (populationShare : Group → ℝ)
    (hgt :
      populationShare survivingGroup * subFullMerit J survivingGroup >
        populationShare groupA * subSubMerit J groupA +
          populationShare groupB * subSubMerit J groupB) :
    populationShare survivingGroup *
        (glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface api
          subEstimateLaw subSubMass subFullMass fullFullCutoff fullSubCutoff
          subSubMerit subFullMerit fullSubMerit fullFullMerit diversity J1
          J2 groupA groupB populationShare).admittedAcademicMerit J
          survivingGroup
          (glm20StrategicPolicyStatePair
            GLM20StrategicPolicyState.singleSub
            GLM20StrategicPolicyState.singleFull) >
      populationShare groupA *
          (glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface api
            subEstimateLaw subSubMass subFullMass fullFullCutoff
            fullSubCutoff subSubMerit subFullMerit fullSubMerit
            fullFullMerit diversity J1 J2 groupA groupB
            populationShare).admittedAcademicMerit J groupA
            (glm20StrategicPolicyStatePair
              GLM20StrategicPolicyState.singleSub
              GLM20StrategicPolicyState.singleSub) +
        populationShare groupB *
          (glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface api
            subEstimateLaw subSubMass subFullMass fullFullCutoff
            fullSubCutoff subSubMerit subFullMerit fullSubMerit
            fullFullMerit diversity J1 J2 groupA groupB
            populationShare).admittedAcademicMerit J groupB
            (glm20StrategicPolicyStatePair
              GLM20StrategicPolicyState.singleSub
              GLM20StrategicPolicyState.singleSub) := by
  simpa using hgt


/-- Binary-policy equilibrium characterization for `(P_sub, P_full)`. -/
theorem glm20TwoSchoolBinaryPolicyEquilibrium_subFull_iff
    {Policy : Type*} (objective1 objective2 : Policy → Policy → ℝ)
    (Psub Pfull : Policy) :
    glm20TwoSchoolBinaryPolicyEquilibrium objective1 objective2
        Psub Pfull Psub Pfull ↔
      objective1 Pfull Pfull ≤ objective1 Psub Pfull ∧
        objective2 Psub Psub ≤ objective2 Psub Pfull := by
  constructor
  · intro h
    exact ⟨h.1 Pfull (Or.inr rfl), h.2 Psub (Or.inl rfl)⟩
  · rintro ⟨h1, h2⟩
    constructor
    · intro P1' hmem
      rcases hmem with rfl | rfl
      · exact le_rfl
      · exact h1
    · intro P2' hmem
      rcases hmem with rfl | rfl
      · exact h2
      · exact le_rfl

/-- Binary-policy equilibrium characterization for `(P_full, P_sub)`. -/
theorem glm20TwoSchoolBinaryPolicyEquilibrium_fullSub_iff
    {Policy : Type*} (objective1 objective2 : Policy → Policy → ℝ)
