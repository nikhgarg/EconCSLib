        glm20Proposition3LambdaFormula api aB bB sigmaTildeB tauB mu qFull <
          glm20Proposition3LambdaFormula api aA bA sigmaTildeA tauA mu qFull) := by
  constructor
  · rw [hdiversity_formula]
  · rw [hmeritA_formula, hmeritB_formula]

