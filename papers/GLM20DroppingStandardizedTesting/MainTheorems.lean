      (leftCost := leftCost) (rightCost := rightCost)
      (fun g c => lowMeritOfCutoff g (lowCutoffOfCost g c))
      lowTestFreeMerit
      (fun g c => highMeritOfCutoff g (highCutoffOfCost g c))
