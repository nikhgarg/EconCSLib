/--
Proposition 5(ii), selected equation-(46) cutoff version of the low/high
threshold construction.

The full-sub branch uses two merit crossings in which the test-based merit is
the admitted-merit formula evaluated at a selected full/full zero-payoff
student cutoff.  This theorem derives the continuity and strict decrease of
those cost-indexed merit terms from the selected equation-(46) cutoff
equations, then applies the generic low/high crossing construction.
-/
theorem
    paper_proposition5_low_and_high_cost_thresholds_of_selected_twoFull_merit_crossings_interval
    {Group : Type*}
    {leftCost rightCost : Group → ℝ}
    {lowQ1Full lowQ2Full lowScale lowV1 lowV2 : Group → ℝ}
    {highQ1Full highQ2Full highScale highV1 highV2 : Group → ℝ}
    (lowCutoffOfCost highCutoffOfCost : Group → ℝ → ℝ)
    (lowMeritOfCutoff : Group → ℝ → ℝ)
    (lowTestFreeMerit : Group → ℝ)
    (highMeritOfCutoff : Group → ℝ → ℝ)
    (highTestFreeMerit : Group → ℝ)
    (hleft_right : ∀ g, leftCost g < rightCost g)
    (hleft_pos : ∀ g, 0 < leftCost g)
    (hlowScale : ∀ g, 0 < lowScale g)
    (hlowV2Pos : ∀ g, 0 < lowV2 g)
    (hlowV2LtV1 : ∀ g, lowV2 g < lowV1 g)
    (hlowZero :
      ∀ g cost, cost ∈ Set.Icc (leftCost g) (rightCost g) →
        glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          (lowQ1Full g) (lowQ2Full g) (lowScale g) (lowV1 g)
          (lowV2 g) cost (lowCutoffOfCost g cost) = 0)
    (hlowMeritCont : ∀ g, Continuous (lowMeritOfCutoff g))
    (hlowMeritAnti : ∀ g, StrictAnti (lowMeritOfCutoff g))
    (hhighScale : ∀ g, 0 < highScale g)
    (hhighV2Pos : ∀ g, 0 < highV2 g)
    (hhighV2LtV1 : ∀ g, highV2 g < highV1 g)
    (hhighZero :
      ∀ g cost, cost ∈ Set.Icc (leftCost g) (rightCost g) →
        glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          (highQ1Full g) (highQ2Full g) (highScale g) (highV1 g)
          (highV2 g) cost (highCutoffOfCost g cost) = 0)
    (hhighMeritCont : ∀ g, Continuous (highMeritOfCutoff g))
    (hhighMeritAnti : ∀ g, StrictAnti (highMeritOfCutoff g))
    (hlowAtLeft :
      ∀ g,
        lowTestFreeMerit g <
          lowMeritOfCutoff g (lowCutoffOfCost g (leftCost g)))
    (hlowAtRight :
      ∀ g,
        lowMeritOfCutoff g (lowCutoffOfCost g (rightCost g)) <
          lowTestFreeMerit g)
    (hhighAtLeft :
      ∀ g,
        highTestFreeMerit g <
          highMeritOfCutoff g (highCutoffOfCost g (leftCost g)))
    (hhighAtRight :
      ∀ g,
        highMeritOfCutoff g (highCutoffOfCost g (rightCost g)) <
          highTestFreeMerit g)
    (hhighAtLowRoot :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        lowMeritOfCutoff g (lowCutoffOfCost g c) = lowTestFreeMerit g →
          highTestFreeMerit g <
            highMeritOfCutoff g (highCutoffOfCost g c)) :
    ∃ lowCostThreshold highCostThreshold : Group → ℝ,
      (∀ g, lowCostThreshold g ∈
        Set.Ioo (leftCost g) (rightCost g)) ∧
        (∀ g, highCostThreshold g ∈
          Set.Ioo (leftCost g) (rightCost g)) ∧
          (∀ g,
            lowMeritOfCutoff g (lowCutoffOfCost g (lowCostThreshold g)) =
              lowTestFreeMerit g) ∧
            (∀ g,
              highMeritOfCutoff g
                  (highCutoffOfCost g (highCostThreshold g)) =
                highTestFreeMerit g) ∧
              (∀ g c, c ∈ Set.Icc (leftCost g) (rightCost g) →
                (lowMeritOfCutoff g (lowCutoffOfCost g c) ≤
                    lowTestFreeMerit g ↔
                  lowCostThreshold g ≤ c)) ∧
                (∀ g c, c ∈ Set.Icc (leftCost g) (rightCost g) →
                  (highTestFreeMerit g <
                      highMeritOfCutoff g (highCutoffOfCost g c) ↔
                    c < highCostThreshold g)) ∧
                  (∀ g c, c ∈ Set.Icc (leftCost g) (rightCost g) →
                    (highTestFreeMerit g ≤
                        highMeritOfCutoff g (highCutoffOfCost g c) ↔
                      c ≤ highCostThreshold g)) ∧
                    (∀ g, 0 < lowCostThreshold g) ∧
                      (∀ g, lowCostThreshold g < highCostThreshold g) := by
  let lowTestBasedMerit : Group → ℝ → ℝ := fun g cost =>
    lowMeritOfCutoff g (lowCutoffOfCost g cost)
  let highTestBasedMerit : Group → ℝ → ℝ := fun g cost =>
    highMeritOfCutoff g (highCutoffOfCost g cost)
  have hlowRegular :
      ∀ g,
        ContinuousOn (lowTestBasedMerit g)
            (Set.Icc (leftCost g) (rightCost g)) ∧
          StrictAntiOn (lowTestBasedMerit g)
            (Set.Icc (leftCost g) (rightCost g)) := by
    intro g
    exact
      paper_proposition5_twoFull_cost_merit_continuous_strictAntiOn_of_zero_payoff_cutoff
        standardGaussianCDFAPI
        (q1Full := lowQ1Full g) (q2Full := lowQ2Full g)
        (scale := lowScale g) (v1 := lowV1 g) (v2 := lowV2 g)
        (costDomain := Set.Icc (leftCost g) (rightCost g))
        (cutoffDomain := Set.univ)
        (cutoffOfCost := lowCutoffOfCost g)
        (meritOfCutoff := lowMeritOfCutoff g)
        (hlowScale g) (hlowV2Pos g) (hlowV2LtV1 g)
        (by
          intro cost hcost
          exact hlowZero g cost hcost)
        (by intro cost hcost; simp)
        (hlowMeritCont g).continuousOn
        (by
          intro x _hx y _hy hxy
          exact hlowMeritAnti g hxy)
  have hhighRegular :
      ∀ g,
        ContinuousOn (highTestBasedMerit g)
            (Set.Icc (leftCost g) (rightCost g)) ∧
          StrictAntiOn (highTestBasedMerit g)
            (Set.Icc (leftCost g) (rightCost g)) := by
    intro g
    exact
      paper_proposition5_twoFull_cost_merit_continuous_strictAntiOn_of_zero_payoff_cutoff
        standardGaussianCDFAPI
        (q1Full := highQ1Full g) (q2Full := highQ2Full g)
        (scale := highScale g) (v1 := highV1 g) (v2 := highV2 g)
        (costDomain := Set.Icc (leftCost g) (rightCost g))
        (cutoffDomain := Set.univ)
        (cutoffOfCost := highCutoffOfCost g)
        (meritOfCutoff := highMeritOfCutoff g)
        (hhighScale g) (hhighV2Pos g) (hhighV2LtV1 g)
        (by
          intro cost hcost
          exact hhighZero g cost hcost)
        (by intro cost hcost; simp)
        (hhighMeritCont g).continuousOn
        (by
          intro x _hx y _hy hxy
          exact hhighMeritAnti g hxy)
  simpa [lowTestBasedMerit, highTestBasedMerit] using
    (paper_proposition5_low_and_high_cost_thresholds_of_merit_crossings_interval
      lowTestBasedMerit lowTestFreeMerit highTestBasedMerit
      highTestFreeMerit hleft_right hleft_pos
      (fun g => (hlowRegular g).1) (fun g => (hlowRegular g).2)
      hlowAtLeft hlowAtRight
      (fun g => (hhighRegular g).1) (fun g => (hhighRegular g).2)
      hhighAtLeft hhighAtRight hhighAtLowRoot)

/--
