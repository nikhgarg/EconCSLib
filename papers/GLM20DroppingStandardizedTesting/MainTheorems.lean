    glm20BivariateApplyAdmitMass_continuous_along_of_rho_continuous
      standardGaussianCDFAPI standardBivariateGaussianCDF
      (populationShare := populationShare)
      (sigmaTilde := sigmaTilde)
      (b := b) (mu := mu)
      (aOfApply := aOfApply)
      (qApply := qApply) (qAdmit := qAdmit)
      ha hqApply hqAdmit hbivar

/--
Continuity of the Lemma 3 bivariate component after substituting the Eq. (7)
application cutoff.
-/
theorem glm20Lemma3StrategicApplicantComponent_bivariate_continuous
    (Q : StandardGaussianQuantileAPI)
    {Group : Type*}
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {populationShare sigmaTilde b mu : Group → ℝ}
    {aOfApply : Group → ℝ → ℝ}
    {priorPrecision subPrecision testPrecision cost : Group → ℝ}
    {value : ℝ} (g : Group)
    (ha : Continuous (aOfApply g))
    (hbivar :
      ∀ rho : ℝ,
        Continuous fun p : ℝ × ℝ => bivariateCDF p.1 p.2 rho) :
    Continuous
      (glm20Lemma3StrategicApplicantComponent Q
        (fun g qApply qAdmit =>
          glm20BivariateApplyAdmitMass Q.cdfAPI bivariateCDF
            (populationShare g) (sigmaTilde g) (aOfApply g)
            (b g) (mu g) qApply qAdmit)
        priorPrecision subPrecision testPrecision cost value g) := by
  let qApply : ℝ → ℝ :=
    fun qAdmit =>
