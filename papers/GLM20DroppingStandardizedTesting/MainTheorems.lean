/--
Proposition 5 / equation (50) support: the `(P_sub,P_full)` application
cutoff is strictly increasing in the test cost on any domain where
`c/v_2 ∈ (0,1)`.
-/
theorem paper_proposition5_equation50_subFull_apply_cutoff_strictMonoOn_cost
    (Q : StandardGaussianQuantileAPI)
    {q2Full scale v2 : ℝ} {costDomain : Set ℝ}
    (hscale : 0 < scale) (hv2 : 0 < v2)
    (hcostRatio : ∀ cost ∈ costDomain, cost / v2 ∈ Set.Ioo (0 : ℝ) 1) :
    StrictMonoOn
      (fun cost : ℝ =>
        q2Full - scale * Q.quantile (1 - cost / v2))
      costDomain := by
  intro costLow hcostLow costHigh hcostHigh hlt
  have hratio_low := hcostRatio costLow hcostLow
  have hratio_high := hcostRatio costHigh hcostHigh
  have hratio_lt : costLow / v2 < costHigh / v2 :=
    (div_lt_div_iff_of_pos_right hv2).mpr hlt
  have harg_low : 1 - costLow / v2 ∈ Set.Ioo (0 : ℝ) 1 := by
    constructor <;> linarith [hratio_low.1, hratio_low.2]
  have harg_high : 1 - costHigh / v2 ∈ Set.Ioo (0 : ℝ) 1 := by
    constructor <;> linarith [hratio_high.1, hratio_high.2]
  have harg_lt : 1 - costHigh / v2 < 1 - costLow / v2 := by
    linarith
  have hquant :
      Q.quantile (1 - costHigh / v2) <
        Q.quantile (1 - costLow / v2) :=
    Q.quantile_strictMonoOn harg_high harg_low harg_lt
  nlinarith [mul_lt_mul_of_pos_left hquant hscale]

