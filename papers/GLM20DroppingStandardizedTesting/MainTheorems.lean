    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    {capacity ownShare otherEligibleMass rho xi benchmark base scale : ℝ}
    {Lfull : ℝ → GaussianScaleLaw} {thresholdFull : ℝ → ℝ}
    {Lsub : GaussianScaleLaw} {thresholdSub subMerit : ℝ}
    {fullMerit : ℝ → ℝ} {academicMeritImproves : ℝ → Prop}
    (hfullMerit :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMerit γ = H.normalUpperTailMean (Lfull γ) (thresholdFull γ))
    (hfull_mean :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, (Lfull γ).mean = base)
    (hfull_scale :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, (Lfull γ).scale = scale)
    (hfull_standardize :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        (Lfull γ).standardize (thresholdFull γ) =
          theorem1BetaGroupA Q capacity ownShare otherEligibleMass rho γ)
    (hsubMerit :
      subMerit = H.normalUpperTailMean Lsub thresholdSub)
    (hsub_mean : Lsub.mean = base)
    (hsub_scale : Lsub.scale = scale * xi)
    (hsub_standardize : Lsub.standardize thresholdSub = benchmark)
    (himproves :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γ ↔ fullMerit γ ≤ subMerit)
    (hscale_pos : 0 < scale)
    (hxi_pos : 0 < xi)
    (hcapacity_pos : 0 < capacity)
    (hown_pos : 0 < ownShare)
    (hother_pos : 0 < otherEligibleMass)
    (hrho_nonneg : 0 ≤ rho) (hrho_lt_one : rho < 1)
    (hselective :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShare * γ + otherEligibleMass) :
    ∃ γbar : ℝ,
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γ ↔ γ ≤ γbar := by
  have hfull :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMerit γ =
          base + scale *
            H.hazard
              (theorem1BetaGroupA Q capacity ownShare otherEligibleMass rho γ) := by
    intro γ hγ
    rw [hfullMerit γ hγ, GaussianHazardCertificate.normalUpperTailMean,
      hfull_mean γ hγ, hfull_scale γ hγ, hfull_standardize γ hγ]
  have hsub :
      subMerit = base + scale * (xi * H.hazard benchmark) := by
    rw [hsubMerit, GaussianHazardCertificate.normalUpperTailMean,
      hsub_mean, hsub_scale, hsub_standardize]
    ring
  exact
    paper_theorem1_academic_merit_access_threshold_of_groupA_tail_mean_main
      H Q hxi_pos hscale_pos hfull hsub himproves hcapacity_pos hown_pos hother_pos
      hrho_nonneg hrho_lt_one hselective

