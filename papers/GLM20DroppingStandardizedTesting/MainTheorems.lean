    refine Filter.tendsto_atBot.2 ?_
    intro R
    filter_upwards
      [Filter.eventually_lt_atBot (sigmaTilde g * R + mu g)]
      with q hq
    rw [div_le_iff₀ hsigma]
    nlinarith
  simpa [glm20Lemma3StrategicApplicantComponent, qApply] using
    glm20BivariateApplyAdmitMass_standardBivariate_tendsto_atBot_total_along
      (populationShare := populationShare g)
      (sigmaTilde := sigmaTilde g)
      (b := b g) (mu := mu g)
      (aOfApply := aOfApply g)
      (qApply := qApply) (qAdmit := fun qAdmit : ℝ => qAdmit)
      (by simpa [qApply] using hA) hB

