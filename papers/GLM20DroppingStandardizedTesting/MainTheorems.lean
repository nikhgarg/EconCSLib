    ∃ costThreshold : Group → ℝ,
      (∀ g, costThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, testBasedMerit g (costThreshold g) = testFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (testBasedMerit g c ≤ testFreeMerit g ↔
