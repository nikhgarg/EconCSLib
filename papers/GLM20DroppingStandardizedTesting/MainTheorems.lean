/--
Proposition 2 source-shaped threshold-equilibrium existence and uniqueness.

This combines the two school capacity-cutoff fixed points with the local
student best-response uniqueness theorem.  It is still abstract in the two
school applicant-mass functions, but the endpoint is no longer an opaque
`Prop`: the unique object is the paper's pair of school thresholds together
with the low/high application-region strategy.
-/
theorem paper_proposition2_two_school_threshold_equilibrium_existsUnique_standardGaussian_of_high_cost_ratio
    (Q : StandardGaussianQuantileAPI)
    {applicantMass1 applicantMass2 : ℝ → ℝ}
    {capacity1 capacity2 totalApplicantMass1 totalApplicantMass2
      scale cost v1 v2 : ℝ}
    (hcont1 : Continuous applicantMass1)
    (hanti1 : StrictAnti applicantMass1)
    (hatBot1 :
      Filter.Tendsto applicantMass1 Filter.atBot (nhds totalApplicantMass1))
    (hatTop1 :
      Filter.Tendsto applicantMass1 Filter.atTop (nhds 0))
    (hcapacity1 : capacity1 ∈ Set.Ioo (0 : ℝ) totalApplicantMass1)
    (hcont2 : Continuous applicantMass2)
    (hanti2 : StrictAnti applicantMass2)
    (hatBot2 :
      Filter.Tendsto applicantMass2 Filter.atBot (nhds totalApplicantMass2))
    (hatTop2 :
      Filter.Tendsto applicantMass2 Filter.atTop (nhds 0))
    (hcapacity2 : capacity2 ∈ Set.Ioo (0 : ℝ) totalApplicantMass2)
    (hscale : 0 < scale) (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃! equilibrium : ℝ × ℝ × (ℝ → Bool),
      glm20Proposition2TwoSchoolThresholdEquilibrium Q
        applicantMass1 applicantMass2 capacity1 capacity2
        scale cost v1 v2 hscale equilibrium := by
  rcases
    paper_proposition2_two_school_selection_thresholds_existUnique_and_capacity_regions_of_strictAnti_applicant_masses
      hcont1 hanti1 hatBot1 hatTop1 hcapacity1
      hcont2 hanti2 hatBot2 hatTop2 hcapacity2 with
    ⟨hschool1, hschool2⟩
  rcases hschool1 with ⟨admissionThreshold, hthreshold1, hunique1⟩
  rcases hschool2 with ⟨school2SubThreshold, hthreshold2, hunique2⟩
  let lowCutoff :=
    glm20StrategicApplyCutoff Q admissionThreshold scale (cost / v1)
  let highCutoff :=
    glm20StrategicApplyCutoff Q admissionThreshold scale (cost / (v1 - v2))
  let strategy : ℝ → Bool :=
    fun q : ℝ =>
      decide
        ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
          (school2SubThreshold ≤ q ∧ highCutoff ≤ q))
  have hbest :
      ∀ q : ℝ, ∀ apply : Bool,
        glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold)
            q apply ≤
          glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold)
            q (strategy q) := by
    rcases
      paper_proposition2_two_school_application_region_bestResponse_standardGaussian_of_high_cost_ratio
        Q (admissionThreshold := admissionThreshold)
        (school2SubThreshold := school2SubThreshold) (scale := scale)
        (cost := cost) (v1 := v1) (v2 := v2)
        hscale hcost hv1 hdiff_pos hdiff_lt_v1 hcostRatioHigh with
      ⟨lowCutoff', highCutoff', hlow, hhigh, _hlt, hbest'⟩
    intro q apply
    have h := hbest' q apply
    simpa [strategy, lowCutoff, highCutoff, hlow, hhigh] using h
  have hwitness :
      glm20Proposition2TwoSchoolThresholdEquilibrium Q
        applicantMass1 applicantMass2 capacity1 capacity2
        scale cost v1 v2 hscale
        (admissionThreshold, school2SubThreshold, strategy) := by
    refine ⟨hthreshold1, hthreshold2, hbest, ?_, ?_⟩
    · rfl
    · rfl
  refine ⟨(admissionThreshold, school2SubThreshold, strategy), hwitness, ?_⟩
  intro equilibrium heq
  rcases equilibrium with ⟨admissionThreshold', school2SubThreshold', strategy'⟩
  rcases heq with ⟨hthreshold1', hthreshold2', hbest', htieLow', htieHigh'⟩
  have hadmission :
      admissionThreshold' = admissionThreshold :=
    hunique1 admissionThreshold' hthreshold1'
  have hschool2 :
      school2SubThreshold' = school2SubThreshold :=
    hunique2 school2SubThreshold' hthreshold2'
  subst admissionThreshold'
  subst school2SubThreshold'
  rcases
    paper_proposition2_two_school_application_region_unique_strategy_standardGaussian_of_high_cost_ratio
      Q (admissionThreshold := admissionThreshold)
      (school2SubThreshold := school2SubThreshold) (scale := scale)
      (cost := cost) (v1 := v1) (v2 := v2)
      hscale hcost hv1 hdiff_pos hdiff_lt_v1 hcostRatioHigh with
    ⟨lowCutoff', highCutoff', hlow, hhigh, _hlt, huniqueStrategy⟩
  have htieLowFormula :
      strategy' lowCutoff' =
        decide
          ((lowCutoff' < school2SubThreshold ∧ lowCutoff' ≤ lowCutoff') ∨
            (school2SubThreshold ≤ lowCutoff' ∧ highCutoff' ≤ lowCutoff')) := by
    rw [hlow, hhigh]
    simpa [glm20StrategicTwoSchoolApplicationRegion] using htieLow'
  have htieHighFormula :
      strategy' highCutoff' =
        decide
          ((highCutoff' < school2SubThreshold ∧ lowCutoff' ≤ highCutoff') ∨
            (school2SubThreshold ≤ highCutoff' ∧ highCutoff' ≤ highCutoff')) := by
    rw [hlow, hhigh]
    simpa [glm20StrategicTwoSchoolApplicationRegion] using htieHigh'
  have hstrategy' :
      strategy' =
        fun q : ℝ =>
          decide
            ((q < school2SubThreshold ∧ lowCutoff' ≤ q) ∨
              (school2SubThreshold ≤ q ∧ highCutoff' ≤ q)) :=
    huniqueStrategy strategy' hbest' htieLowFormula htieHighFormula
  have hstrategy_eq : strategy' = strategy := by
    rw [hstrategy']
    funext q
    simp [strategy, lowCutoff, highCutoff, hlow, hhigh]
  exact Prod.ext rfl (Prod.ext rfl hstrategy_eq)

/--
Proposition 2 source-shaped threshold-equilibrium existence and uniqueness for
finite standard-Gaussian applicant mixtures.

This instantiates the abstract applicant-mass hypotheses with finite mixtures
of Gaussian upper tails for each school.  The remaining paper-specific
strategic work is then to identify the two schools' applicant pools with these
mixture masses.
-/
theorem paper_proposition2_standardGaussian_mixture_threshold_equilibrium_existsUnique_of_high_cost_ratio
    {Group1 Group2 : Type*} [Fintype Group1] [Fintype Group2]
    {weight1 : Group1 → ℝ} {law1 : Group1 → GaussianScaleLaw}
    {weight2 : Group2 → ℝ} {law2 : Group2 → GaussianScaleLaw}
    {capacity1 capacity2 scale cost v1 v2 : ℝ}
    (hweight1 : ∀ g, 0 ≤ weight1 g) (hpos1 : ∃ g, 0 < weight1 g)
    (hcapacity1 : capacity1 ∈ Set.Ioo (0 : ℝ) (∑ g : Group1, weight1 g))
    (hweight2 : ∀ g, 0 ≤ weight2 g) (hpos2 : ∃ g, 0 < weight2 g)
    (hcapacity2 : capacity2 ∈ Set.Ioo (0 : ℝ) (∑ g : Group2, weight2 g))
