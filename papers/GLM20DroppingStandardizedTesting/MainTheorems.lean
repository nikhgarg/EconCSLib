            ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
              glm20ExactlyOneOfTwo groupA groupB
                (fun g =>
                  testCost g ≥ costThreshold g ∧
                    0 < costThreshold g ∧ q1Sub < fullFullCutoff g)) := by
  classical
  have hthreshold :
      ∀ g : Group, ∃ costThreshold : ℝ,
        costThreshold ∈ Set.Ioo (0 : ℝ) (maxCost g) ∧
          testBasedMerit g costThreshold = testFreeMerit g ∧
            (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
              testFreeMerit g < testBasedMerit g c ↔ c < costThreshold) ∧
              (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                testBasedMerit g c < testFreeMerit g ↔
                  costThreshold < c) ∧
                (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                  testBasedMerit g c ≤ testFreeMerit g ↔
                    costThreshold ≤ c) := by
    intro g
    exact
      paper_proposition5_cost_threshold_of_continuous_strictAntiOn_cost_interval
        (testBasedMerit := testBasedMerit g) (testFreeMerit := testFreeMerit g)
        (maxCost := maxCost g) (hmaxCost g) (hcont g) (hanti g)
        (hlowCost g) (hhighCost g)
  let costThreshold : Group → ℝ := fun g => Classical.choose (hthreshold g)
  have hspec :
      ∀ g,
        costThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g) ∧
          testBasedMerit g (costThreshold g) = testFreeMerit g ∧
            (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
              testFreeMerit g < testBasedMerit g c ↔ c < costThreshold g) ∧
              (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                testBasedMerit g c < testFreeMerit g ↔
                  costThreshold g < c) ∧
                (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                  testBasedMerit g c ≤ testFreeMerit g ↔
                    costThreshold g ≤ c) := by
    intro g
    exact Classical.choose_spec (hthreshold g)
  have hmem : ∀ g, costThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g) :=
