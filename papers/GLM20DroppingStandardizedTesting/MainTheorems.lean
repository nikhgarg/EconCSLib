/--
Proposition 3 common selection-core expression.

This is the shared bracket
`Φ(A_g) - Φ₂(A_g,B_g;ρ_g)` appearing in the displayed `τ_g` formula, with
`A_g = (a_g + b_g μ) / sqrt(1 + σtilde_g^2 b_g^2)`,
`B_g = (q_full^* - μ) / σtilde_g`, and
`ρ_g = -σtilde_g b_g / sqrt(1 + σtilde_g^2 b_g^2)`.
-/
def glm20Proposition3SelectionCore
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (sigmaTilde a b mu qFull : ℝ) : ℝ :=
  let denom := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let A := (a + b * mu) / denom
  let B := (qFull - mu) / sigmaTilde
  let rho := -(sigmaTilde * b) / denom
  api.cdf A - bivariateCDF A B rho

/--
Proposition 3 / Appendix D CDF bookkeeping.

If `api.cdf A` is the first marginal lower CDF and `bivariateCDF A B rho`
is the lower-left bivariate CDF, then the expression
`api.cdf A - bivariateCDF A B rho` is the mass of the vertical strip
`{Z_1 <= A, B <= Z_2}`, provided the horizontal boundary at `B` has zero mass.
-/
theorem paper_proposition3_selection_core_expr_eq_verticalUpperStripMass_of_cdf_identities
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (jointLaw : Measure (ℝ × ℝ)) [IsFiniteMeasure jointLaw]
    {A B rho : ℝ}
    (hfirst :
      firstCoordinateLowerMass jointLaw A = api.cdf A)
    (hbivar :
      lowerLeftRectangleMass jointLaw A B = bivariateCDF A B rho)
    (hboundary :
      jointLaw.real {p : ℝ × ℝ | p.1 ≤ A ∧ p.2 = B} = 0) :
    api.cdf A - bivariateCDF A B rho =
      verticalUpperStripMass jointLaw A B := by
  rw [← hfirst, ← hbivar]
  exact
    (verticalUpperStripMass_eq_firstCoordinateLowerMass_sub_lowerLeftRectangleMass
      jointLaw A B hboundary).symm

/--
Proposition 3 selection-core measure identity for the paper's displayed
`A_g`, `B_g`, and `rho_g`.

This is not yet the full Owen/bivariate-normal proof.  It proves the reusable
measure-theoretic step: once the transformed joint law has standard-normal
first marginal CDF `Phi(A_g)` and bivariate CDF `Phi_2(A_g,B_g;rho_g)`, the
paper's bracket `Phi(A_g)-Phi_2(A_g,B_g;rho_g)` is exactly the source event
mass `{Z_1 <= A_g, B_g <= Z_2}`.
-/
theorem paper_proposition3_selection_core_eq_verticalUpperStripMass_of_cdf_identities
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (jointLaw : Measure (ℝ × ℝ)) [IsFiniteMeasure jointLaw]
    {sigmaTilde a b mu qFull : ℝ}
    (hfirst :
      firstCoordinateLowerMass jointLaw
          ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)) =
        api.cdf
          ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
    (hbivar :
      lowerLeftRectangleMass jointLaw
          ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((qFull - mu) / sigmaTilde) =
        bivariateCDF
          ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((qFull - mu) / sigmaTilde)
          (-(sigmaTilde * b) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
    (hboundary :
      jointLaw.real
          {p : ℝ × ℝ |
            p.1 ≤ (a + b * mu) /
                Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2) ∧
              p.2 = (qFull - mu) / sigmaTilde} = 0) :
    glm20Proposition3SelectionCore api bivariateCDF sigmaTilde a b mu qFull =
      verticalUpperStripMass jointLaw
        ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
        ((qFull - mu) / sigmaTilde) := by
  let denom := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let A := (a + b * mu) / denom
  let B := (qFull - mu) / sigmaTilde
  let rho := -(sigmaTilde * b) / denom
  have hfirst' : firstCoordinateLowerMass jointLaw A = api.cdf A := by
    simpa [A, denom] using hfirst
  have hbivar' : lowerLeftRectangleMass jointLaw A B = bivariateCDF A B rho := by
    simpa [A, B, rho, denom] using hbivar
  have hboundary' :
      jointLaw.real {p : ℝ × ℝ | p.1 ≤ A ∧ p.2 = B} = 0 := by
    simpa [A, B, denom] using hboundary
  simpa [glm20Proposition3SelectionCore, A, B, rho, denom] using
    paper_proposition3_selection_core_expr_eq_verticalUpperStripMass_of_cdf_identities
      api bivariateCDF jointLaw hfirst' hbivar' hboundary'

/--
Proposition 3 correlation parameter support.

For the paper's
`rho_g = -sigma_tilde_g b_g / sqrt(1 + sigma_tilde_g^2 b_g^2)`,
the nondegenerate correlated-Gaussian law condition `rho_g^2 < 1` is automatic.
-/
theorem paper_proposition3_rho_sq_lt_one (sigmaTilde b : ℝ) :
    (-(sigmaTilde * b) /
        Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)) ^ 2 < 1 := by
  simpa [mul_pow] using
    (neg_div_sqrt_one_add_sq_sq_lt_one (sigmaTilde * b))

/--
Proposition 3 selection-core identity for the concrete correlated standard
Gaussian CDF.

Here `Phi_2` is no longer an uninterpreted bivariate CDF: it is
`standardBivariateGaussianCDF`, the lower-left rectangle mass of
`correlatedStandardGaussianLaw rho`.  The theorem proves that the paper's
`Phi(A_g)-Phi_2(A_g,B_g;rho_g)` bracket is the vertical strip mass under that
correlated standard-Gaussian law.
-/
theorem paper_proposition3_selection_core_eq_correlatedStandardGaussian_verticalUpperStripMass
    {sigmaTilde a b mu qFull : ℝ} :
    glm20Proposition3SelectionCore standardGaussianCDFAPI
        standardBivariateGaussianCDF sigmaTilde a b mu qFull =
      verticalUpperStripMass
        (correlatedStandardGaussianLaw
          (-(sigmaTilde * b) /
            Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
        ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
        ((qFull - mu) / sigmaTilde) := by
  let denom := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let A := (a + b * mu) / denom
  let B := (qFull - mu) / sigmaTilde
  let rho := -(sigmaTilde * b) / denom
  have hrho : rho ^ 2 < 1 := by
    simpa [rho, denom] using paper_proposition3_rho_sq_lt_one sigmaTilde b
  have hfirst :
      firstCoordinateLowerMass (correlatedStandardGaussianLaw rho) A =
        standardGaussianCDFAPI.cdf A := by
    simpa [standardGaussianCDFAPI] using
      correlatedStandardGaussianLaw_firstCoordinateLowerMass rho A
  have hbivar :
      lowerLeftRectangleMass (correlatedStandardGaussianLaw rho) A B =
        standardBivariateGaussianCDF A B rho := rfl
  have hboundary :
      (correlatedStandardGaussianLaw rho).real
          {p : ℝ × ℝ | p.1 ≤ A ∧ p.2 = B} = 0 :=
    correlatedStandardGaussianLaw_horizontalBoundaryLeft_real_eq_zero
      hrho A B
  simpa [glm20Proposition3SelectionCore, A, B, rho, denom] using
    paper_proposition3_selection_core_expr_eq_verticalUpperStripMass_of_cdf_identities
      standardGaussianCDFAPI standardBivariateGaussianCDF
      (correlatedStandardGaussianLaw rho) hfirst hbivar hboundary

/--
Proposition 3 / Appendix D source affine mass.

This is the standardized Owen-integral event
`P(X <= A_g * sqrt(1 + (sigma_tilde_g b_g)^2)
    + sigma_tilde_g b_g Z, B_g <= Z)`
for independent standard normals `(X,Z)`, where
`A_g = (a_g + b_g μ)/sqrt(1 + sigma_tilde_g^2 b_g^2)` and
`B_g = (q_full^* - μ)/sigma_tilde_g`.
-/
def glm20Proposition3OwenAffineSelectionMass
    (sigmaTilde a b mu qFull : ℝ) : ℝ :=
  owenAffineUpperSelectionMass (sigmaTilde * b)
    ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
    ((qFull - mu) / sigmaTilde)

/--
Proposition 3 / Appendix D Owen identity, mass form.

Paper proof role: this is the formal source bridge behind Owen (10,010.1).
The affine application probability integrated over the standardized full-score
tail equals the displayed bivariate-normal bracket
`Phi(A_g) - Phi_2(A_g,B_g;rho_g)`.
-/
theorem paper_proposition3_selection_core_eq_owenAffineSelectionMass
    {sigmaTilde a b mu qFull : ℝ} :
    glm20Proposition3SelectionCore standardGaussianCDFAPI
        standardBivariateGaussianCDF sigmaTilde a b mu qFull =
      glm20Proposition3OwenAffineSelectionMass
        sigmaTilde a b mu qFull := by
  rw [paper_proposition3_selection_core_eq_correlatedStandardGaussian_verticalUpperStripMass]
  rw [glm20Proposition3OwenAffineSelectionMass,
    owenAffineUpperSelectionMass_eq_correlatedStandardGaussian_verticalUpperStripMass]
  simp [mul_pow]

/--
Proposition 3 selection-core positivity for the concrete bivariate Gaussian
CDF.

The displayed bracket `Phi(A_g)-Phi_2(A_g,B_g;rho_g)` is positive because it
is a nonempty vertical upper strip under a nondegenerate correlated
standard-Gaussian law.
-/
theorem glm20Proposition3SelectionCore_standardBivariate_pos
    (sigmaTilde a b mu qFull : ℝ) :
    0 <
      glm20Proposition3SelectionCore standardGaussianCDFAPI
        standardBivariateGaussianCDF sigmaTilde a b mu qFull := by
  let denom := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let A := (a + b * mu) / denom
  let B := (qFull - mu) / sigmaTilde
  let rho := -(sigmaTilde * b) / denom
  have hrho : rho ^ 2 < 1 := by
    simpa [rho, denom] using paper_proposition3_rho_sq_lt_one sigmaTilde b
  have hpos :
      0 < verticalUpperStripMass (correlatedStandardGaussianLaw rho) A B :=
    correlatedStandardGaussianLaw_verticalUpperStripMass_pos hrho A B
  simpa [A, B, rho, denom] using
    (by
      rw [paper_proposition3_selection_core_eq_correlatedStandardGaussian_verticalUpperStripMass
        (sigmaTilde := sigmaTilde) (a := a) (b := b) (mu := mu)
        (qFull := qFull)]
      exact hpos)

/--
Lemma 3 / Proposition 3 bivariate application-and-admission mass.

For a group with population share `populationShare`, projected-score scale
`sigmaTilde`, linear application boundary parameter `aOfApply qApply`, slope
`b`, and prior mean `mu`, this is the paper's bivariate-normal selection mass
`π_g * σtilde_g * (Φ(A_g)-Φ₂(A_g,B_g;ρ_g))`.
-/
def glm20BivariateApplyAdmitMass
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (populationShare sigmaTilde : ℝ) (aOfApply : ℝ → ℝ)
    (b mu qApply qAdmit : ℝ) : ℝ :=
  populationShare * sigmaTilde *
    glm20Proposition3SelectionCore api bivariateCDF sigmaTilde
      (aOfApply qApply) b mu qAdmit

/--
Lemma 3 / Proposition 3 bivariate application-and-admission mass for the
concrete correlated standard-Gaussian CDF.

This rewrites the displayed
`pi_g sigma_tilde_g (Phi(A_g)-Phi_2(A_g,B_g;rho_g))` expression as a
correlated-standard-Gaussian vertical strip mass.  It isolates the remaining
paper-model task to the affine transformation from the original
`(q_sub,q_full)` source variables into this standardized correlated pair.
-/
theorem glm20BivariateApplyAdmitMass_eq_correlatedStandardGaussian_verticalUpperStripMass
    {populationShare sigmaTilde : ℝ} {aOfApply : ℝ → ℝ}
    {b mu qApply qAdmit : ℝ} :
    glm20BivariateApplyAdmitMass standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare sigmaTilde aOfApply
        b mu qApply qAdmit =
      populationShare * sigmaTilde *
        verticalUpperStripMass
          (correlatedStandardGaussianLaw
            (-(sigmaTilde * b) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
          (((aOfApply qApply) + b * mu) /
            Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((qAdmit - mu) / sigmaTilde) := by
  rw [glm20BivariateApplyAdmitMass,
    paper_proposition3_selection_core_eq_correlatedStandardGaussian_verticalUpperStripMass]

/--
Lemma 3 / Proposition 3 bivariate application-and-admission mass from the
source affine Owen event.

This is the mass-level bridge used after substituting a group's application
cutoff: the displayed `π_g σtilde_g (Phi(A_g)-Phi_2(...))` mass is the same
as the standardized affine event mass for independent standard normals.
-/
theorem glm20BivariateApplyAdmitMass_eq_owenAffineSelectionMass
    {populationShare sigmaTilde : ℝ} {aOfApply : ℝ → ℝ}
    {b mu qApply qAdmit : ℝ} :
    glm20BivariateApplyAdmitMass standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare sigmaTilde aOfApply
        b mu qApply qAdmit =
      populationShare * sigmaTilde *
        glm20Proposition3OwenAffineSelectionMass sigmaTilde
          (aOfApply qApply) b mu qAdmit := by
  rw [glm20BivariateApplyAdmitMass,
    paper_proposition3_selection_core_eq_owenAffineSelectionMass]

/--
Proposition 2(iii) admitted group mass `D_g(a_hat_g(q_a))`.

Paper statement:
`D_g(a_hat_g(q_a)) := pi_g sigma_tilde_g
  (Phi(A_g(q_a)) - Phi_2(A_g(q_a), B_g; rho_g))`, where
`A_g(q_a) = (a_hat_g(q_a) + b_g mu) /
sqrt(1 + sigma_tilde_g^2 b_g^2)`,
`B_g = (q_{1,full}^* - mu) / sigma_tilde_g`, and
`rho_g = -sigma_tilde_g b_g / sqrt(1 + sigma_tilde_g^2 b_g^2)`.
-/
def glm20Proposition2AdmittedMassFormula
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (populationShare sigmaTilde aHat b mu q1Full : ℝ) : ℝ :=
  populationShare * sigmaTilde *
    glm20Proposition3SelectionCore api bivariateCDF
      sigmaTilde aHat b mu q1Full

/--
Proposition 2(iii) admitted group mass formula for the concrete correlated
standard-Gaussian CDF.
-/
theorem glm20Proposition2AdmittedMassFormula_eq_correlatedStandardGaussian_verticalUpperStripMass
    {populationShare sigmaTilde aHat b mu q1Full : ℝ} :
    glm20Proposition2AdmittedMassFormula standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare sigmaTilde aHat b mu
        q1Full =
      populationShare * sigmaTilde *
        verticalUpperStripMass
          (correlatedStandardGaussianLaw
            (-(sigmaTilde * b) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
          ((aHat + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((q1Full - mu) / sigmaTilde) := by
  rw [glm20Proposition2AdmittedMassFormula,
    paper_proposition3_selection_core_eq_correlatedStandardGaussian_verticalUpperStripMass]

/--
Proposition 2(iii) admitted group mass formula from the source affine Owen
event.
-/
theorem glm20Proposition2AdmittedMassFormula_eq_owenAffineSelectionMass
    {populationShare sigmaTilde aHat b mu q1Full : ℝ} :
    glm20Proposition2AdmittedMassFormula standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare sigmaTilde aHat b mu
        q1Full =
      populationShare * sigmaTilde *
        glm20Proposition3OwenAffineSelectionMass sigmaTilde aHat b mu
          q1Full := by
  rw [glm20Proposition2AdmittedMassFormula,
    paper_proposition3_selection_core_eq_owenAffineSelectionMass]

/--
Proposition 2(iv) lower affine source-selection mass.

This is the standardized event behind the `J2` academic-merit calculation:
students clear the test-free cutoff but fall below `J1`'s full-test admission
cutoff.  It is the lower-rectangle counterpart of
`glm20Proposition3OwenAffineSelectionMass`.
-/
noncomputable def glm20Proposition2OwenAffineLowerSelectionMass
    (sigmaTilde a b mu qFull : ℝ) : ℝ :=
  let c := sigmaTilde * b
  let denom := Real.sqrt (1 + c ^ 2)
  let A := (a + b * mu) / denom
  let B := (qFull - mu) / sigmaTilde
  (standardGaussianMeasure.prod standardGaussianMeasure).real
    {p : ℝ × ℝ | p.1 ≤ A * denom + c * p.2 ∧ p.2 ≤ B}

/--
Proposition 2(iv) lower affine source-selection mass equals the concrete
correlated-standard-Gaussian lower-left rectangle.

This closes the measure/CDF side of the Owen identity for the lower-tail
source event used by `kappa`; the remaining analytic seam is identifying the
source integral `paperProposition2OwenSelectionLowerTail` with this event mass.
-/
theorem glm20Proposition2OwenAffineLowerSelectionMass_eq_correlatedStandardGaussian_lowerLeftRectangleMass
    (sigmaTilde a b mu qFull : ℝ) :
    glm20Proposition2OwenAffineLowerSelectionMass
        sigmaTilde a b mu qFull =
      lowerLeftRectangleMass
        (correlatedStandardGaussianLaw
          (-(sigmaTilde * b) /
            Real.sqrt (1 + (sigmaTilde * b) ^ 2)))
        ((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2))
        ((qFull - mu) / sigmaTilde) := by
  let c : ℝ := sigmaTilde * b
  let denom : ℝ := Real.sqrt (1 + c ^ 2)
  let A : ℝ := (a + b * mu) / denom
  let B : ℝ := (qFull - mu) / sigmaTilde
  let base : Measure (ℝ × ℝ) :=
    standardGaussianMeasure.prod standardGaussianMeasure
  have hpos : 0 < 1 + c ^ 2 := by nlinarith [sq_nonneg c]
  have hdenom_pos : 0 < denom := by
    dsimp [denom]
    exact Real.sqrt_pos.2 hpos
  have hpre :
      (owenStandardizingGaussianCLM c) ⁻¹'
          {p : ℝ × ℝ | p.1 ≤ A ∧ p.2 ≤ B} =
        {p : ℝ × ℝ | p.1 ≤ A * denom + c * p.2 ∧ p.2 ≤ B} := by
    ext p
    constructor
    · intro hp
      constructor
      · have hle : (p.1 - c * p.2) / denom ≤ A := by
          simpa [denom] using hp.1
        have hle' : p.1 - c * p.2 ≤ A * denom :=
          (div_le_iff₀ hdenom_pos).mp hle
        linarith
      · simpa using hp.2
    · intro hp
      constructor
      · have hle' : p.1 - c * p.2 ≤ A * denom := by linarith [hp.1]
        have hle : (p.1 - c * p.2) / denom ≤ A :=
          (div_le_iff₀ hdenom_pos).mpr hle'
        simpa [denom] using hle
      · simpa using hp.2
  calc
    glm20Proposition2OwenAffineLowerSelectionMass
        sigmaTilde a b mu qFull
        =
          (base.map (owenStandardizingGaussianCLM c)).real
            {p : ℝ × ℝ | p.1 ≤ A ∧ p.2 ≤ B} := by
          rw [glm20Proposition2OwenAffineLowerSelectionMass, measureReal_def,
            measureReal_def, Measure.map_apply (by fun_prop)
              (measurableSet_lowerLeftRectangle A B), hpre]
    _ =
          (correlatedStandardGaussianLaw ((-c) / Real.sqrt (1 + c ^ 2))).real
            {p : ℝ × ℝ | p.1 ≤ A ∧ p.2 ≤ B} := by
          rw [owenStandardizingGaussianLaw_eq_correlatedStandardGaussianLaw c]
    _ =
          lowerLeftRectangleMass
            (correlatedStandardGaussianLaw ((-c) / Real.sqrt (1 + c ^ 2))) A B := rfl
    _ =
          lowerLeftRectangleMass
            (correlatedStandardGaussianLaw
              (-(sigmaTilde * b) /
                Real.sqrt (1 + (sigmaTilde * b) ^ 2)))
            ((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2))
            ((qFull - mu) / sigmaTilde) := by
          simp [c, denom, A, B]

/--
Proposition 2(iii)/(iv) standardized total-mass partition.

For the same affine threshold, the students admitted by `J1` (the vertical
upper strip) and the lower-tail students available to `J2` (the lower-left
rectangle) add up to the one-dimensional affine total mass
`pi_g sigma_tilde_g Phi(A_g)`.
-/
theorem glm20Proposition2AdmittedMassFormula_add_lowerLeftRectangle_eq_affineTotalMass
    (populationShare sigmaTilde aHat b mu q1Full : ℝ) :
    glm20Proposition2AdmittedMassFormula standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare sigmaTilde aHat b mu
        q1Full +
      populationShare * sigmaTilde *
        lowerLeftRectangleMass
          (correlatedStandardGaussianLaw
            (-(sigmaTilde * b) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
          ((aHat + b * mu) /
            Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((q1Full - mu) / sigmaTilde) =
      populationShare * sigmaTilde *
        standardGaussianCDF
          ((aHat + b * mu) /
            Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)) := by
  let A : ℝ := (aHat + b * mu) /
    Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let B : ℝ := (q1Full - mu) / sigmaTilde
  let rho : ℝ := -(sigmaTilde * b) /
    Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  have hrho : rho ^ 2 < 1 := by
    simpa [rho] using paper_proposition3_rho_sq_lt_one sigmaTilde b
  have hboundary :
      (correlatedStandardGaussianLaw rho).real
          {p : ℝ × ℝ | p.1 ≤ A ∧ p.2 = B} = 0 :=
    correlatedStandardGaussianLaw_horizontalBoundaryLeft_real_eq_zero
      hrho A B
  have hpartition :
      verticalUpperStripMass (correlatedStandardGaussianLaw rho) A B =
        firstCoordinateLowerMass (correlatedStandardGaussianLaw rho) A -
          lowerLeftRectangleMass (correlatedStandardGaussianLaw rho) A B :=
    verticalUpperStripMass_eq_firstCoordinateLowerMass_sub_lowerLeftRectangleMass
      (correlatedStandardGaussianLaw rho) A B hboundary
  have hfirst :
      firstCoordinateLowerMass (correlatedStandardGaussianLaw rho) A =
        standardGaussianCDF A := by
    simpa [standardGaussianCDFAPI] using
      correlatedStandardGaussianLaw_firstCoordinateLowerMass rho A
  rw [glm20Proposition2AdmittedMassFormula_eq_correlatedStandardGaussian_verticalUpperStripMass]
  change
      populationShare * sigmaTilde *
          verticalUpperStripMass (correlatedStandardGaussianLaw rho) A B +
        populationShare * sigmaTilde *
          lowerLeftRectangleMass (correlatedStandardGaussianLaw rho) A B =
        populationShare * sigmaTilde * standardGaussianCDF A
  rw [hpartition, hfirst]
  ring

/--
The concrete correlated-Gaussian lower-left residual mass in Proposition 2 is
strictly positive.
-/
theorem glm20Proposition2_correlatedLowerLeftRectangleMass_pos
    (sigmaTilde aHat b mu q1Full : ℝ) :
    0 <
      lowerLeftRectangleMass
        (correlatedStandardGaussianLaw
          (-(sigmaTilde * b) /
            Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
        ((aHat + b * mu) /
          Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
        ((q1Full - mu) / sigmaTilde) := by
  let A : ℝ := (aHat + b * mu) /
    Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let B : ℝ := (q1Full - mu) / sigmaTilde
  let rho : ℝ := -(sigmaTilde * b) /
    Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  have hrho : rho ^ 2 < 1 := by
    simpa [rho] using paper_proposition3_rho_sq_lt_one sigmaTilde b
  letI : Measure.IsOpenPosMeasure (correlatedStandardGaussianLaw rho) :=
    correlatedStandardGaussianLaw_isOpenPosMeasure hrho
  simpa [A, B, rho] using
    lowerLeftRectangleMass_pos_of_isOpenPosMeasure
      (correlatedStandardGaussianLaw rho) A B

/--
Product-measure form of the Proposition 2(iv) lower affine source-selection
mass.

Conditioning on the standardized full-score coordinate `z`, the inner
standard-normal mass is the affine CDF `Phi(A D + c z)`.  This is the
measure-theoretic event/integral bridge before rewriting the outer Gaussian
measure by its density.
-/
theorem glm20Proposition2OwenAffineLowerSelectionMass_eq_standardGaussianIntegral
    (sigmaTilde a b mu qFull : ℝ) :
    glm20Proposition2OwenAffineLowerSelectionMass
        sigmaTilde a b mu qFull =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       let B := (qFull - mu) / sigmaTilde
       ∫ z in Set.Iic B,
         standardGaussianCDF (A * denom + c * z) ∂standardGaussianMeasure) := by
  let c : ℝ := sigmaTilde * b
  let denom : ℝ := Real.sqrt (1 + c ^ 2)
  let A : ℝ := (a + b * mu) / denom
  let B : ℝ := (qFull - mu) / sigmaTilde
  let s : Set (ℝ × ℝ) :=
    {p : ℝ × ℝ | p.1 ≤ A * denom + c * p.2 ∧ p.2 ≤ B}
  have hs : MeasurableSet s :=
          (isClosed_le continuous_fst (by fun_prop)).measurableSet.inter
        (isClosed_le continuous_snd continuous_const).measurableSet
  have hfinite :
      ∀ᵐ z ∂standardGaussianMeasure,
        standardGaussianMeasure ((fun x : ℝ => (x, z)) ⁻¹' s) < ∞ :=
    Filter.Eventually.of_forall fun z =>
      lt_of_le_of_lt (measure_mono (Set.subset_univ _))
        IsFiniteMeasure.measure_univ_lt_top
  have hsection :
      ∀ z : ℝ,
        (standardGaussianMeasure ((fun x : ℝ => (x, z)) ⁻¹' s)).toReal =
          (Set.Iic B).indicator
            (fun z => standardGaussianCDF (A * denom + c * z)) z := by
    intro z
    by_cases hz : z ≤ B
    · have hpre :
          ((fun x : ℝ => (x, z)) ⁻¹' s) =
            Set.Iic (A * denom + c * z) := by
        ext x
        simp [s, hz]
      have hzmem : z ∈ Set.Iic B := hz
      rw [hpre, Set.indicator_of_mem hzmem, standardGaussianCDF,
        ProbabilityTheory.cdf_eq_real, measureReal_def]
    · have hpre :
          ((fun x : ℝ => (x, z)) ⁻¹' s) = (∅ : Set ℝ) := by
        ext x
        simp [s, hz]
      have hzmem : z ∉ Set.Iic B := by simpa using hz
      rw [hpre, Set.indicator_of_notMem hzmem]
      simp
  calc
    glm20Proposition2OwenAffineLowerSelectionMass
        sigmaTilde a b mu qFull
        =
          ((standardGaussianMeasure.prod standardGaussianMeasure) s).toReal := by
          simp [glm20Proposition2OwenAffineLowerSelectionMass, s, c, denom, A, B,
            measureReal_def]
    _ =
          (∫⁻ z,
            standardGaussianMeasure
              ((fun x : ℝ => (x, z)) ⁻¹' s) ∂standardGaussianMeasure).toReal := by
          rw [Measure.prod_apply_symm hs]
    _ =
          ∫ z,
            (standardGaussianMeasure
              ((fun x : ℝ => (x, z)) ⁻¹' s)).toReal ∂standardGaussianMeasure := by
          rw [← MeasureTheory.integral_toReal
            (measurable_measure_prodMk_right hs).aemeasurable hfinite]
    _ =
          ∫ z,
            (Set.Iic B).indicator
              (fun z => standardGaussianCDF (A * denom + c * z)) z
              ∂standardGaussianMeasure :=
          MeasureTheory.integral_congr_ae
            (Filter.Eventually.of_forall hsection)
    _ =
          ∫ z in Set.Iic B,
            standardGaussianCDF (A * denom + c * z)
            ∂standardGaussianMeasure := by
          rw [MeasureTheory.integral_indicator measurableSet_Iic]
    _ =
          (let c := sigmaTilde * b
           let denom := Real.sqrt (1 + c ^ 2)
           let A := (a + b * mu) / denom
           let B := (qFull - mu) / sigmaTilde
           ∫ z in Set.Iic B,
             standardGaussianCDF (A * denom + c * z)
             ∂standardGaussianMeasure) := by
          simp [c, denom, A, B]

/--
Proposition 2(iii) test-free eligible group mass above the `J2` subscore
cutoff.

This is the source's factor
`pi_g Phi((mu - q_{2,sub}^*) / sigma *
sqrt(sum_sub_precision_g / (prior_precision + sum_sub_precision_g)))`.
-/
def glm20Proposition2SubEligibleMassFormula
    (api : StandardGaussianCDFAPI)
    (populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub : ℝ) :
    ℝ :=
  populationShare *
    api.cdf
      ((mu - q2Sub) / priorSigma *
        Real.sqrt (subPrecisionSum / (priorPrecision + subPrecisionSum)))

/--
Proposition 3 / Section 5 source definition of
`\tilde\sigma_g`.

Paper source (`source_tex/proofs.tex:948`):
`\tilde\sigma_g = \sigma
 \sqrt{\sum_{k\in full}\sigma_{gk}^{-2}/
   (\sigma^{-2}+\sum_{k\in full}\sigma_{gk}^{-2})}`.
-/
def glm20Proposition3SigmaTildeSource
    (priorSigma priorPrecision fullPrecisionSum : ℝ) : ℝ :=
  priorSigma *
    Real.sqrt (fullPrecisionSum / (priorPrecision + fullPrecisionSum))

/--
Proposition 3 / Section 5 source definition of `b_g`.

Paper source (`source_tex/proofs.tex:952`):
`b_g = sqrt(sum_sub * (sigma^{-2}+sum_full) /
  (sigma^{-2}+sum_sub+sum_full))`.
-/
def glm20Proposition3BSource
    (priorPrecision subPrecisionSum fullPrecisionSum : ℝ) : ℝ :=
  Real.sqrt
    (subPrecisionSum * (priorPrecision + fullPrecisionSum) /
      (priorPrecision + subPrecisionSum + fullPrecisionSum))

/-- The paper's `\tilde\sigma_g` is positive under positive precisions. -/
theorem glm20Proposition3SigmaTildeSource_pos
    {priorSigma priorPrecision fullPrecisionSum : ℝ}
    (hsigma : 0 < priorSigma) (hprior : 0 < priorPrecision)
    (hfull : 0 < fullPrecisionSum) :
    0 <
      glm20Proposition3SigmaTildeSource
        priorSigma priorPrecision fullPrecisionSum := by
  have hden : 0 < priorPrecision + fullPrecisionSum := by linarith
  exact
    mul_pos hsigma
      (Real.sqrt_pos.2 (div_pos hfull hden))

/-- The paper's `b_g` is positive under positive precisions. -/
theorem glm20Proposition3BSource_pos
    {priorPrecision subPrecisionSum fullPrecisionSum : ℝ}
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    0 <
      glm20Proposition3BSource
        priorPrecision subPrecisionSum fullPrecisionSum := by
  have hnum : 0 < subPrecisionSum * (priorPrecision + fullPrecisionSum) :=
    mul_pos hsub (by linarith)
  have hden : 0 < priorPrecision + subPrecisionSum + fullPrecisionSum := by
    linarith
  exact Real.sqrt_pos.2 (div_pos hnum hden)

/-- Square simplification for the source `\tilde\sigma_g`. -/
theorem glm20Proposition3SigmaTildeSource_sq
    {priorSigma priorPrecision fullPrecisionSum : ℝ}
    (hprior : 0 < priorPrecision) (hfull : 0 ≤ fullPrecisionSum) :
    glm20Proposition3SigmaTildeSource
        priorSigma priorPrecision fullPrecisionSum ^ 2 =
      priorSigma ^ 2 *
        (fullPrecisionSum / (priorPrecision + fullPrecisionSum)) := by
  have hden : 0 < priorPrecision + fullPrecisionSum := by linarith
  have hratio_nonneg :
      0 ≤ fullPrecisionSum / (priorPrecision + fullPrecisionSum) :=
    div_nonneg hfull hden.le
  simp [glm20Proposition3SigmaTildeSource, mul_pow,
    Real.sq_sqrt hratio_nonneg]

/-- Square simplification for the source `b_g`. -/
theorem glm20Proposition3BSource_sq
    {priorPrecision subPrecisionSum fullPrecisionSum : ℝ}
    (hprior : 0 < priorPrecision) (hsub : 0 ≤ subPrecisionSum)
    (hfull : 0 ≤ fullPrecisionSum) :
    glm20Proposition3BSource
        priorPrecision subPrecisionSum fullPrecisionSum ^ 2 =
      subPrecisionSum * (priorPrecision + fullPrecisionSum) /
        (priorPrecision + subPrecisionSum + fullPrecisionSum) := by
  have hprior_full_nonneg :
      0 ≤ priorPrecision + fullPrecisionSum := by linarith
  have hnum_nonneg :
      0 ≤ subPrecisionSum * (priorPrecision + fullPrecisionSum) :=
    mul_nonneg hsub hprior_full_nonneg
  have hden : 0 < priorPrecision + subPrecisionSum + fullPrecisionSum := by
    linarith
  have hratio_nonneg :
      0 ≤
        subPrecisionSum * (priorPrecision + fullPrecisionSum) /
          (priorPrecision + subPrecisionSum + fullPrecisionSum) :=
    div_nonneg hnum_nonneg hden.le
  simp [glm20Proposition3BSource, Real.sq_sqrt hratio_nonneg]

/--
Source precision algebra for the denominator `sqrt(1+\tilde\sigma_g^2 b_g^2)`.

Under the paper identification `priorPrecision = sigma^{-2}`, the expression
inside the square root expands to the raw precision ratio below.  This is the
algebraic bridge used before applying the bivariate Gaussian formulas.
-/
theorem glm20Proposition3_source_denominator_sq_eq_precision_ratio
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum : ℝ}
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 ≤ subPrecisionSum)
    (hfull : 0 ≤ fullPrecisionSum) :
    1 +
        glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum ^ 2 *
          glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum ^ 2 =
      (priorPrecision + subPrecisionSum) *
          (priorPrecision + fullPrecisionSum) /
        (priorPrecision *
          (priorPrecision + subPrecisionSum + fullPrecisionSum)) := by
  have hden_full : priorPrecision + fullPrecisionSum ≠ 0 :=
    ne_of_gt (by linarith)
  have hden_total :
      priorPrecision + subPrecisionSum + fullPrecisionSum ≠ 0 :=
    ne_of_gt (by linarith)
  have hprior_ne : priorPrecision ≠ 0 := ne_of_gt hprior
  rw [glm20Proposition3SigmaTildeSource_sq hprior hfull,
    glm20Proposition3BSource_sq hprior hsub hfull, hsigma_sq]
  field_simp [hprior_ne, hden_full, hden_total]
  ring

/--
The source `\Phi_2` correlation parameter is valid for the paper's
`\tilde\sigma_g` and `b_g` definitions.
-/
theorem glm20Proposition3_source_rho_sq_lt_one
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum : ℝ} :
    ((-(glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum *
            glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)) /
        Real.sqrt
          (1 +
            glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum ^ 2 *
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum ^ 2)) ^ 2 <
      1 := by
  simpa [pow_two, mul_assoc] using
    paper_proposition3_rho_sq_lt_one
      (glm20Proposition3SigmaTildeSource
        priorSigma priorPrecision fullPrecisionSum)
      (glm20Proposition3BSource
        priorPrecision subPrecisionSum fullPrecisionSum)

/--
Proposition 2(iii) source `\hat a_g(q_a)` denominator.

Paper source (`source_tex/proofs.tex`):
`sqrt(sum_sub)/(sigma^{-2}+sum_sub) *
 sqrt(1 + sum_sub/(sigma^{-2}+sum_full))`.
-/
def glm20Proposition2AHatSourceDenominator
    (priorPrecision subPrecisionSum fullPrecisionSum : ℝ) : ℝ :=
  (Real.sqrt subPrecisionSum / (priorPrecision + subPrecisionSum)) *
    Real.sqrt (1 + subPrecisionSum / (priorPrecision + fullPrecisionSum))

/--
The source `\hat a_g(q_a)` denominator is positive under positive precisions.
-/
theorem glm20Proposition2AHatSourceDenominator_pos
    {priorPrecision subPrecisionSum fullPrecisionSum : ℝ}
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    0 <
      glm20Proposition2AHatSourceDenominator
        priorPrecision subPrecisionSum fullPrecisionSum := by
  have hprior_sub : 0 < priorPrecision + subPrecisionSum := by linarith
  have hprior_full : 0 < priorPrecision + fullPrecisionSum := by linarith
  have hratio : 0 < subPrecisionSum / (priorPrecision + fullPrecisionSum) :=
    div_pos hsub hprior_full
  exact
    mul_pos
      (div_pos (Real.sqrt_pos.2 hsub) hprior_sub)
      (Real.sqrt_pos.2 (by linarith))

/--
Proposition 2(iii) source definition of `\hat a_g(q_a)`.

Paper source (`source_tex/proofs.tex:1238`):
`\hat a_g(q_a) =
 (\mu sigma^{-2} - q_a) /
  ((sqrt(sum_sub)/(sigma^{-2}+sum_sub)) *
   sqrt(1 + sum_sub/(sigma^{-2}+sum_full)))`.
-/
def glm20Proposition2AHatSource
    (priorPrecision subPrecisionSum fullPrecisionSum mu qA : ℝ) : ℝ :=
  (mu * priorPrecision - qA) /
    glm20Proposition2AHatSourceDenominator
      priorPrecision subPrecisionSum fullPrecisionSum

/--
Proposition 2(iii) corrected source `\hat a_g(q_a)` denominator from the
conditional-Gaussian application probability.

The displayed statement in `source_tex/proofs.tex:1238` omits the factor
`priorPrecision + subPrecisionSum` multiplying the cutoff.  The conditional
probability formula in the proof has numerator
`(mu * priorPrecision + q_full * subPrecisionSum) /
  (priorPrecision + subPrecisionSum) - q_a`; after multiplying numerator and
denominator by `priorPrecision + subPrecisionSum`, the affine intercept uses
this denominator.
-/
def glm20Proposition2AHatConditionalSourceDenominator
    (priorPrecision subPrecisionSum fullPrecisionSum : ℝ) : ℝ :=
  Real.sqrt subPrecisionSum *
    Real.sqrt (1 + subPrecisionSum / (priorPrecision + fullPrecisionSum))

/--
Proposition 2(iii) corrected source `\hat a_g(q_a)` from the conditional
application-probability line of the proof.
-/
def glm20Proposition2AHatConditionalSource
    (priorPrecision subPrecisionSum fullPrecisionSum mu qA : ℝ) : ℝ :=
  (mu * priorPrecision - qA * (priorPrecision + subPrecisionSum)) /
    glm20Proposition2AHatConditionalSourceDenominator
      priorPrecision subPrecisionSum fullPrecisionSum

/-- Proposition 2(iii) `A_g(q) = (a_hat_g(q)+b_g mu)/sqrt(1+sigma_tilde_g^2 b_g^2)`. -/
def glm20Proposition2AArgument
    (sigmaTilde aHat b mu : ℝ) : ℝ := (aHat + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)

/--
Proposition 2(iii)/(iv) source-parameter total-mass partition.

This specializes the standardized admitted-mass plus lower-left-residual
identity to the paper's displayed source definitions of `\tilde\sigma_g`,
`\hat a_g(q)`, and `b_g`.
-/
theorem
    glm20Proposition2AdmittedMassFormula_add_lowerLeftRectangle_eq_affineTotalMass_sourceParameters
    (populationShare priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum mu qApply q1Full : ℝ) :
    glm20Proposition2AdmittedMassFormula standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare
        (glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum)
        (glm20Proposition2AHatSource
          priorPrecision subPrecisionSum fullPrecisionSum mu qApply)
        (glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum)
        mu q1Full +
      populationShare *
        glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum *
        lowerLeftRectangleMass
          (correlatedStandardGaussianLaw
            (-((glm20Proposition3SigmaTildeSource
                    priorSigma priorPrecision fullPrecisionSum) *
                glm20Proposition3BSource
                  priorPrecision subPrecisionSum fullPrecisionSum) /
              Real.sqrt
                (1 +
                  (glm20Proposition3SigmaTildeSource
                      priorSigma priorPrecision fullPrecisionSum) ^ 2 *
                    (glm20Proposition3BSource
                      priorPrecision subPrecisionSum fullPrecisionSum) ^ 2)))
          (((glm20Proposition2AHatSource
                priorPrecision subPrecisionSum fullPrecisionSum mu qApply) +
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum * mu) /
            Real.sqrt
              (1 +
                (glm20Proposition3SigmaTildeSource
                    priorSigma priorPrecision fullPrecisionSum) ^ 2 *
                  (glm20Proposition3BSource
                    priorPrecision subPrecisionSum fullPrecisionSum) ^ 2))
          ((q1Full - mu) /
            glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum) =
      populationShare *
        glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum *
        standardGaussianCDF
          (((glm20Proposition2AHatSource
                priorPrecision subPrecisionSum fullPrecisionSum mu qApply) +
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum * mu) /
            Real.sqrt
              (1 +
                (glm20Proposition3SigmaTildeSource
                    priorSigma priorPrecision fullPrecisionSum) ^ 2 *
                  (glm20Proposition3BSource
                    priorPrecision subPrecisionSum fullPrecisionSum) ^ 2)) :=
  glm20Proposition2AdmittedMassFormula_add_lowerLeftRectangle_eq_affineTotalMass
    populationShare
    (glm20Proposition3SigmaTildeSource
      priorSigma priorPrecision fullPrecisionSum)
    (glm20Proposition2AHatSource
      priorPrecision subPrecisionSum fullPrecisionSum mu qApply)
    (glm20Proposition3BSource
      priorPrecision subPrecisionSum fullPrecisionSum)
    mu q1Full

/--
Proposition 2(iii)/(iv) conditional-source total-mass partition.

This is the same source-parameter mass partition as
`glm20Proposition2AdmittedMassFormula_add_lowerLeftRectangle_eq_affineTotalMass_sourceParameters`,
but using the conditional-application `\hat a_g(q)` row consumed by the Lemma 3
strategic applicant-pool substitution.
-/
theorem
    glm20Proposition2AdmittedMassFormula_add_lowerLeftRectangle_eq_affineTotalMass_conditionalSourceParameters
    (populationShare priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum mu qApply q1Full : ℝ) :
    glm20Proposition2AdmittedMassFormula standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare
        (glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum)
        (glm20Proposition2AHatConditionalSource
          priorPrecision subPrecisionSum fullPrecisionSum mu qApply)
        (glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum)
        mu q1Full +
      populationShare *
        glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum *
        lowerLeftRectangleMass
          (correlatedStandardGaussianLaw
            (-((glm20Proposition3SigmaTildeSource
                    priorSigma priorPrecision fullPrecisionSum) *
                glm20Proposition3BSource
                  priorPrecision subPrecisionSum fullPrecisionSum) /
              Real.sqrt
                (1 +
                  (glm20Proposition3SigmaTildeSource
                      priorSigma priorPrecision fullPrecisionSum) ^ 2 *
                    (glm20Proposition3BSource
                      priorPrecision subPrecisionSum fullPrecisionSum) ^ 2)))
          (((glm20Proposition2AHatConditionalSource
                priorPrecision subPrecisionSum fullPrecisionSum mu qApply) +
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum * mu) /
            Real.sqrt
              (1 +
                (glm20Proposition3SigmaTildeSource
                    priorSigma priorPrecision fullPrecisionSum) ^ 2 *
                  (glm20Proposition3BSource
                    priorPrecision subPrecisionSum fullPrecisionSum) ^ 2))
          ((q1Full - mu) /
            glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum) =
      populationShare *
        glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum *
        standardGaussianCDF
          (((glm20Proposition2AHatConditionalSource
                priorPrecision subPrecisionSum fullPrecisionSum mu qApply) +
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum * mu) /
            Real.sqrt
              (1 +
                (glm20Proposition3SigmaTildeSource
                    priorSigma priorPrecision fullPrecisionSum) ^ 2 *
                  (glm20Proposition3BSource
                    priorPrecision subPrecisionSum fullPrecisionSum) ^ 2)) :=
  glm20Proposition2AdmittedMassFormula_add_lowerLeftRectangle_eq_affineTotalMass
    populationShare
    (glm20Proposition3SigmaTildeSource
      priorSigma priorPrecision fullPrecisionSum)
    (glm20Proposition2AHatConditionalSource
      priorPrecision subPrecisionSum fullPrecisionSum mu qApply)
    (glm20Proposition3BSource
      priorPrecision subPrecisionSum fullPrecisionSum)
    mu q1Full

/--
Proposition 2(iii) corrected test-free eligible mass, in the unnormalized
Owen-integral convention used by the displayed `D_g` formula.

The standardization divides by the test-free estimated-skill scale
`priorSigma * sqrt(subPrecisionSum / (priorPrecision + subPrecisionSum))`.
The literal TeX display misses these parentheses; this definition records the
Gaussian-algebra version needed by the source proof.
-/
def glm20Proposition2SubEligibleUnnormalizedMassFormula
    (api : StandardGaussianCDFAPI)
    (populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum q2Sub : ℝ) : ℝ :=
  populationShare *
    glm20Proposition3SigmaTildeSource
      priorSigma priorPrecision fullPrecisionSum *
    api.cdf
      ((mu - q2Sub) /
        (priorSigma *
          Real.sqrt (subPrecisionSum / (priorPrecision + subPrecisionSum))))

/--
Proposition 2(iii) corrected-source denominator algebra.

This is the algebra behind rewriting the conditional-application affine
threshold into the one-dimensional test-free score standardization.
-/
theorem glm20Proposition2AHatConditionalSourceDenominator_mul_selectionDenom_eq
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum : ℝ}
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    glm20Proposition2AHatConditionalSourceDenominator
        priorPrecision subPrecisionSum fullPrecisionSum *
      Real.sqrt
        (1 +
          glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum ^ 2 *
            glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum ^ 2) =
      (priorPrecision + subPrecisionSum) * priorSigma *
        Real.sqrt
          (subPrecisionSum / (priorPrecision + subPrecisionSum)) := by
  have hprior_sub : 0 < priorPrecision + subPrecisionSum := by linarith
  have hprior_full : 0 < priorPrecision + fullPrecisionSum := by linarith
  have htotal : 0 < priorPrecision + subPrecisionSum + fullPrecisionSum := by
    linarith
  have hratio_sub_nonneg :
      0 ≤ subPrecisionSum / (priorPrecision + subPrecisionSum) :=
    div_nonneg hsub.le hprior_sub.le
  have hratio_full_nonneg :
      0 ≤ subPrecisionSum / (priorPrecision + fullPrecisionSum) :=
    div_nonneg hsub.le hprior_full.le
  have hdenA_nonneg :
      0 ≤
        glm20Proposition2AHatConditionalSourceDenominator
          priorPrecision subPrecisionSum fullPrecisionSum :=
    mul_nonneg (Real.sqrt_nonneg _)
      (Real.sqrt_nonneg _)
  have hsel_nonneg :
      0 ≤
        Real.sqrt
          (1 +
            glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum ^ 2 *
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum ^ 2) :=
    Real.sqrt_nonneg _
  have hrhs_nonneg :
      0 ≤
        (priorPrecision + subPrecisionSum) * priorSigma *
          Real.sqrt
            (subPrecisionSum / (priorPrecision + subPrecisionSum)) :=
    mul_nonneg (mul_nonneg hprior_sub.le hsigma.le)
      (Real.sqrt_nonneg _)
  apply (sq_eq_sq₀ (mul_nonneg hdenA_nonneg hsel_nonneg) hrhs_nonneg).mp
  have hdenA_sq :
      glm20Proposition2AHatConditionalSourceDenominator
          priorPrecision subPrecisionSum fullPrecisionSum ^ 2 =
        subPrecisionSum *
          (1 + subPrecisionSum / (priorPrecision + fullPrecisionSum)) := by
    simp [glm20Proposition2AHatConditionalSourceDenominator, mul_pow,
      Real.sq_sqrt hsub.le, Real.sq_sqrt (by linarith : 0 ≤ 1 + subPrecisionSum /
        (priorPrecision + fullPrecisionSum))]
  calc
    (glm20Proposition2AHatConditionalSourceDenominator
          priorPrecision subPrecisionSum fullPrecisionSum *
        Real.sqrt
          (1 +
            glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum ^ 2 *
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum ^ 2)) ^ 2
        =
        glm20Proposition2AHatConditionalSourceDenominator
            priorPrecision subPrecisionSum fullPrecisionSum ^ 2 *
          (1 +
            glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum ^ 2 *
            glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum ^ 2) := by
      rw [mul_pow,
        Real.sq_sqrt
          (add_nonneg zero_le_one
            (mul_nonneg (sq_nonneg _) (sq_nonneg _)))]
    _ =
        subPrecisionSum *
          (1 + subPrecisionSum / (priorPrecision + fullPrecisionSum)) *
          (1 +
            priorSigma ^ 2 *
              (fullPrecisionSum / (priorPrecision + fullPrecisionSum)) *
              (subPrecisionSum * (priorPrecision + fullPrecisionSum) /
                (priorPrecision + subPrecisionSum + fullPrecisionSum))) := by
      rw [hdenA_sq,
        glm20Proposition3SigmaTildeSource_sq hprior hfull.le,
        glm20Proposition3BSource_sq hprior hsub.le hfull.le]
    _ = subPrecisionSum * (priorPrecision + subPrecisionSum) /
        priorPrecision := by
      rw [hsigma_sq]
      field_simp [ne_of_gt hprior, ne_of_gt hprior_full, ne_of_gt htotal]
      ring
    _ =
        ((priorPrecision + subPrecisionSum) * priorSigma *
          Real.sqrt
            (subPrecisionSum / (priorPrecision + subPrecisionSum))) ^ 2 := by
      rw [mul_pow, mul_pow, hsigma_sq,
        Real.sq_sqrt hratio_sub_nonneg]
      field_simp [ne_of_gt hprior, ne_of_gt hprior_sub]

/--
Proposition 2(iii) corrected-source numerator algebra.

The corrected denominator for `\hat a_g(q)` is chosen so that multiplying by
the paper's `b_g` leaves exactly the test-free precision sum.
-/
theorem glm20Proposition2AHatConditionalSourceDenominator_mul_b_eq
    {priorPrecision subPrecisionSum fullPrecisionSum : ℝ}
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    glm20Proposition2AHatConditionalSourceDenominator
        priorPrecision subPrecisionSum fullPrecisionSum *
      glm20Proposition3BSource
        priorPrecision subPrecisionSum fullPrecisionSum =
      subPrecisionSum := by
  have hprior_full : 0 < priorPrecision + fullPrecisionSum := by linarith
  have htotal : 0 < priorPrecision + subPrecisionSum + fullPrecisionSum := by
    linarith
  have hdenA_nonneg :
      0 ≤
        glm20Proposition2AHatConditionalSourceDenominator
          priorPrecision subPrecisionSum fullPrecisionSum :=
    mul_nonneg (Real.sqrt_nonneg _) (Real.sqrt_nonneg _)
  have hb_nonneg :
      0 ≤
        glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum :=
    Real.sqrt_nonneg _
  apply
    (sq_eq_sq₀
      (mul_nonneg hdenA_nonneg hb_nonneg) hsub.le).mp
  have hdenA_sq :
      glm20Proposition2AHatConditionalSourceDenominator
          priorPrecision subPrecisionSum fullPrecisionSum ^ 2 =
        subPrecisionSum *
          (1 + subPrecisionSum / (priorPrecision + fullPrecisionSum)) := by
    have hratio_nonneg :
        0 ≤ subPrecisionSum / (priorPrecision + fullPrecisionSum) :=
      div_nonneg hsub.le hprior_full.le
    have hsecond_nonneg :
        0 ≤ 1 + subPrecisionSum / (priorPrecision + fullPrecisionSum) := by
      linarith
    rw [glm20Proposition2AHatConditionalSourceDenominator, mul_pow,
      Real.sq_sqrt hsub.le, Real.sq_sqrt hsecond_nonneg]
  calc
    (glm20Proposition2AHatConditionalSourceDenominator
          priorPrecision subPrecisionSum fullPrecisionSum *
        glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum) ^ 2
        =
        glm20Proposition2AHatConditionalSourceDenominator
            priorPrecision subPrecisionSum fullPrecisionSum ^ 2 *
          glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum ^ 2 := by
      ring
    _ =
        subPrecisionSum *
          (1 + subPrecisionSum / (priorPrecision + fullPrecisionSum)) *
          (subPrecisionSum * (priorPrecision + fullPrecisionSum) /
            (priorPrecision + subPrecisionSum + fullPrecisionSum)) := by
      rw [hdenA_sq,
        glm20Proposition3BSource_sq hprior hsub.le hfull.le]
    _ = subPrecisionSum ^ 2 := by
      field_simp [ne_of_gt hprior_full, ne_of_gt htotal]
      ring

/--
Proposition 2(iii) corrected-source standardization.

After substituting the conditional-probability version of `\hat a_g(q)`, the
paper's `A_g(q)` argument is the one-dimensional test-free estimated-skill
standardization.
-/
theorem glm20Proposition2AArgument_conditional_source_eq_subEligibleStandardization
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub : ℝ}
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    glm20Proposition2AArgument
        (glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum)
        (glm20Proposition2AHatConditionalSource
          priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
        (glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum)
        mu =
      (mu - q2Sub) /
        (priorSigma *
          Real.sqrt
            (subPrecisionSum / (priorPrecision + subPrecisionSum))) := by
  let denA :=
    glm20Proposition2AHatConditionalSourceDenominator
      priorPrecision subPrecisionSum fullPrecisionSum
  let b :=
    glm20Proposition3BSource
      priorPrecision subPrecisionSum fullPrecisionSum
  let selD :=
    Real.sqrt
      (1 +
        glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum ^ 2 *
          glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum ^ 2)
  let scale :=
    priorSigma *
      Real.sqrt (subPrecisionSum / (priorPrecision + subPrecisionSum))
  have hprior_sub : 0 < priorPrecision + subPrecisionSum := by linarith
  have hprior_full : 0 < priorPrecision + fullPrecisionSum := by linarith
  have hratio_sub_pos :
      0 < subPrecisionSum / (priorPrecision + subPrecisionSum) :=
    div_pos hsub hprior_sub
  have hdenA_pos : 0 < denA := by
    have hratio_full_pos :
        0 < subPrecisionSum / (priorPrecision + fullPrecisionSum) :=
      div_pos hsub hprior_full
    exact
      mul_pos (Real.sqrt_pos.2 hsub)
        (Real.sqrt_pos.2 (by linarith))
  have hselD_pos : 0 < selD := by
    have hprod_nonneg :
        0 ≤
          glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum ^ 2 *
            glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum ^ 2 :=
      mul_nonneg (sq_nonneg _) (sq_nonneg _)
    exact Real.sqrt_pos.2 (by linarith)
  have hscale_pos : 0 < scale :=
    mul_pos hsigma (Real.sqrt_pos.2 hratio_sub_pos)
  have hbden : denA * b = subPrecisionSum := by
    simpa [denA, b] using
      glm20Proposition2AHatConditionalSourceDenominator_mul_b_eq
        hprior hsub hfull
  have hprod : denA * selD =
      (priorPrecision + subPrecisionSum) * scale := by
    simpa [denA, selD, scale, mul_assoc] using
      glm20Proposition2AHatConditionalSourceDenominator_mul_selectionDenom_eq
        hsigma hsigma_sq hprior hsub hfull
  have hnum :
      glm20Proposition2AHatConditionalSource
          priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub +
        b * mu =
      (priorPrecision + subPrecisionSum) * (mu - q2Sub) / denA := by
    have hdenA_ne : denA ≠ 0 := ne_of_gt hdenA_pos
    rw [glm20Proposition2AHatConditionalSource]
    change
      (mu * priorPrecision - q2Sub * (priorPrecision + subPrecisionSum)) /
            denA +
          b * mu =
        (priorPrecision + subPrecisionSum) * (mu - q2Sub) / denA
    field_simp [hdenA_ne]
    rw [mul_assoc, hbden]
    ring
  rw [glm20Proposition2AArgument]
  simp only [denA, b, selD, scale] at hnum hprod hdenA_pos hselD_pos hscale_pos
  rw [hnum]
  have hdenA_ne :
      glm20Proposition2AHatConditionalSourceDenominator
          priorPrecision subPrecisionSum fullPrecisionSum ≠ 0 := by
    simpa [denA] using ne_of_gt hdenA_pos
  have hselD_ne :
      Real.sqrt
        (1 +
          glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum ^ 2 *
            glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum ^ 2) ≠ 0 := by
    simpa [selD] using ne_of_gt hselD_pos
  have hscale_ne :
      priorSigma *
          Real.sqrt
            (subPrecisionSum / (priorPrecision + subPrecisionSum)) ≠ 0 := by
    simpa [scale] using ne_of_gt hscale_pos
  have hprod' :
      glm20Proposition2AHatConditionalSourceDenominator
          priorPrecision subPrecisionSum fullPrecisionSum *
        Real.sqrt
          (1 +
            glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum ^ 2 *
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum ^ 2) =
        (priorPrecision + subPrecisionSum) *
          (priorSigma *
            Real.sqrt
              (subPrecisionSum / (priorPrecision + subPrecisionSum))) := by
    simpa [denA, selD, scale] using hprod
  field_simp [hdenA_ne, hselD_ne, hscale_ne]
  rw [mul_assoc (mu - q2Sub)
    (glm20Proposition2AHatConditionalSourceDenominator
      priorPrecision subPrecisionSum fullPrecisionSum)
    (Real.sqrt
      (1 +
        glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum ^ 2 *
          glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum ^ 2))]
  rw [hprod']
  ring

/--
Proposition 2(iii) corrected-source eligible mass equals the affine
one-dimensional selection mass after substituting the conditional-source
`A_g(q)` argument.
-/
theorem glm20Proposition2SubEligibleUnnormalizedMassFormula_eq_conditional_affineArgument
    (api : StandardGaussianCDFAPI)
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum q2Sub : ℝ}
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    glm20Proposition2SubEligibleUnnormalizedMassFormula api
        populationShare mu priorSigma priorPrecision subPrecisionSum
        fullPrecisionSum q2Sub =
      populationShare *
        glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum *
        api.cdf
          (glm20Proposition2AArgument
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatConditionalSource
              priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            mu) := by
  rw [glm20Proposition2AArgument_conditional_source_eq_subEligibleStandardization
    hsigma hsigma_sq hprior hsub hfull]
  rfl

/--
Proposition 2(iii) corrected-source eligible mass as the unnormalized
test-free applicant-pool upper tail.

This connects the corrected display formula to the source-model event that a
test-free estimated skill exceeds the sub-school cutoff `q2Sub`.
-/
theorem glm20Proposition2SubEligibleUnnormalizedMassFormula_eq_scaled_testFreeTail
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum q2Sub : ℝ}
    (hsigma : 0 < priorSigma)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum) :
    glm20Proposition2SubEligibleUnnormalizedMassFormula standardGaussianCDFAPI
        populationShare mu priorSigma priorPrecision subPrecisionSum
        fullPrecisionSum q2Sub =
      populationShare *
        glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum *
        standardGaussianCDFAPI.thresholdPassProb
          { mean := mu
            scale :=
              priorSigma *
                Real.sqrt
                  (subPrecisionSum / (priorPrecision + subPrecisionSum))
            scale_pos :=
              mul_pos hsigma
                (Real.sqrt_pos.2 (div_pos hsub (by linarith))) }
          q2Sub := by
  let scale :=
    priorSigma *
      Real.sqrt (subPrecisionSum / (priorPrecision + subPrecisionSum))
  have htail :
      standardGaussianCDFAPI.cdf ((mu - q2Sub) / scale) =
        standardGaussianCDFAPI.thresholdPassProb
          { mean := mu
            scale := scale
            scale_pos := by
              dsimp [scale]
              exact mul_pos hsigma
                (Real.sqrt_pos.2 (div_pos hsub (by linarith))) }
          q2Sub := by
    dsimp [StandardGaussianCDFAPI.thresholdPassProb,
      StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
      GaussianScaleLaw.standardize, standardGaussianCDFAPI]
    have harg :
        (mu - q2Sub) / scale = -((q2Sub - mu) / scale) := by
      ring
    rw [harg, standardGaussianCDF_neg_eq_one_sub]
  unfold glm20Proposition2SubEligibleUnnormalizedMassFormula
  simpa [scale] using
    congrArg
      (fun tail =>
        populationShare *
          glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum *
          tail)
      htail

/--
Proposition 2(iii) corrected-source affine argument monotonicity.
-/
theorem glm20Proposition2AArgument_conditional_source_le_of_q_le
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum mu
      qHigh q2Sub : ℝ}
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum)
    (hq : q2Sub ≤ qHigh) :
    glm20Proposition2AArgument
        (glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum)
        (glm20Proposition2AHatConditionalSource
          priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
        (glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum)
        mu ≤
      glm20Proposition2AArgument
        (glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum)
        (glm20Proposition2AHatConditionalSource
          priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
        (glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum)
        mu := by
  have hprior_sub : 0 < priorPrecision + subPrecisionSum := by linarith
  have hscale_nonneg :
      0 ≤
        priorSigma *
          Real.sqrt
            (subPrecisionSum / (priorPrecision + subPrecisionSum)) :=
          (mul_pos hsigma
        (Real.sqrt_pos.2 (div_pos hsub hprior_sub))).le
  rw [
    glm20Proposition2AArgument_conditional_source_eq_subEligibleStandardization
      hsigma hsigma_sq hprior hsub hfull,
    glm20Proposition2AArgument_conditional_source_eq_subEligibleStandardization
      hsigma hsigma_sq hprior hsub hfull]
  exact div_le_div_of_nonneg_right (by linarith) hscale_nonneg

/-- The corrected-source `\hat a_g(q)` is continuous in the cutoff. -/
theorem glm20Proposition2AHatConditionalSource_continuous
    (priorPrecision subPrecisionSum fullPrecisionSum mu : ℝ) :
    Continuous fun q : ℝ =>
      glm20Proposition2AHatConditionalSource
        priorPrecision subPrecisionSum fullPrecisionSum mu q := by
  dsimp [glm20Proposition2AHatConditionalSource]
  exact
    (continuous_const.sub
      (continuous_id.mul continuous_const)).div_const
        (glm20Proposition2AHatConditionalSourceDenominator
          priorPrecision subPrecisionSum fullPrecisionSum)

/--
The corrected-source affine argument is strictly decreasing after composing
with any constant-offset application cutoff.
-/
theorem glm20Proposition2AArgument_conditional_source_strictAnti_along_offset
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum mu offset : ℝ}
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    StrictAnti fun q : ℝ =>
      glm20Proposition2AArgument
        (glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum)
        (glm20Proposition2AHatConditionalSource
          priorPrecision subPrecisionSum fullPrecisionSum mu (q - offset))
        (glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum)
        mu := by
  have hprior_sub : 0 < priorPrecision + subPrecisionSum := by linarith
  have hscale_pos :
      0 <
        priorSigma *
          Real.sqrt (subPrecisionSum / (priorPrecision + subPrecisionSum)) :=
    mul_pos hsigma (Real.sqrt_pos.2 (div_pos hsub hprior_sub))
  intro x y hxy
  change
      glm20Proposition2AArgument
          (glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum)
          (glm20Proposition2AHatConditionalSource
            priorPrecision subPrecisionSum fullPrecisionSum mu (y - offset))
          (glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum)
          mu <
        glm20Proposition2AArgument
          (glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum)
          (glm20Proposition2AHatConditionalSource
            priorPrecision subPrecisionSum fullPrecisionSum mu (x - offset))
          (glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum)
          mu
  rw [
    glm20Proposition2AArgument_conditional_source_eq_subEligibleStandardization
      hsigma hsigma_sq hprior hsub hfull,
    glm20Proposition2AArgument_conditional_source_eq_subEligibleStandardization
      hsigma hsigma_sq hprior hsub hfull]
  exact div_lt_div_of_pos_right (by linarith) hscale_pos

/--
Along any constant-offset application cutoff, the corrected-source affine
argument tends to `+∞` as the admission cutoff tends to `-∞`.
-/
theorem glm20Proposition2AArgument_conditional_source_tendsto_atBot_atTop_along_offset
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum mu offset : ℝ}
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    Filter.Tendsto
      (fun q : ℝ =>
        glm20Proposition2AArgument
          (glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum)
          (glm20Proposition2AHatConditionalSource
            priorPrecision subPrecisionSum fullPrecisionSum mu (q - offset))
          (glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum)
          mu)
      Filter.atBot Filter.atTop := by
  have hprior_sub : 0 < priorPrecision + subPrecisionSum := by linarith
  let scale : ℝ :=
    priorSigma *
      Real.sqrt (subPrecisionSum / (priorPrecision + subPrecisionSum))
  have hscale_pos : 0 < scale := by
    dsimp [scale]
    exact mul_pos hsigma (Real.sqrt_pos.2 (div_pos hsub hprior_sub))
  refine Filter.tendsto_atTop.2 ?_
  intro R
  filter_upwards [Filter.eventually_lt_atBot (mu + offset - scale * R)]
    with q hq
  rw [glm20Proposition2AArgument_conditional_source_eq_subEligibleStandardization
      hsigma hsigma_sq hprior hsub hfull]
  rw [le_div_iff₀ hscale_pos]
  dsimp [scale] at hq ⊢
  nlinarith

/--
Proposition 2(iii) source affine argument monotonicity.

The source `\hat a_g(q)` is decreasing in the cutoff `q_a`, while the
standardizing denominator is positive.  Hence the paper's cutoff order
`q_{2,sub}^* <= q_h^g` implies the affine CDF argument at `q_h^g` is weakly
below the one at `q_{2,sub}^*`.
-/
theorem glm20Proposition2AArgument_source_le_of_q_le
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum mu
      qHigh q2Sub : ℝ}
    (hprior : 0 < priorPrecision)
    (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum)
    (hq : q2Sub ≤ qHigh) :
    (glm20Proposition2AHatSource
          priorPrecision subPrecisionSum fullPrecisionSum mu qHigh +
        glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum * mu) /
        Real.sqrt
          (1 +
            glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum ^ 2 *
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum ^ 2) ≤
      (glm20Proposition2AHatSource
          priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub +
        glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum * mu) /
        Real.sqrt
          (1 +
            glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum ^ 2 *
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum ^ 2) := by
  have hAden_pos :
      0 <
        glm20Proposition2AHatSourceDenominator
          priorPrecision subPrecisionSum fullPrecisionSum :=
    glm20Proposition2AHatSourceDenominator_pos hprior hsub hfull
  have hsqrt_pos :
      0 <
        Real.sqrt
          (1 +
            glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum ^ 2 *
              glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum ^ 2) := by
    have hprod_nonneg :
        0 ≤
          glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum ^ 2 *
            glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum ^ 2 :=
      mul_nonneg (sq_nonneg _) (sq_nonneg _)
    exact Real.sqrt_pos.2 (by linarith)
  have hnum :
      mu * priorPrecision - qHigh ≤ mu * priorPrecision - q2Sub := by
    linarith
  have hahat :
      glm20Proposition2AHatSource
          priorPrecision subPrecisionSum fullPrecisionSum mu qHigh ≤
        glm20Proposition2AHatSource
          priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub :=
    div_le_div_of_nonneg_right hnum hAden_pos.le
  have hnum_arg :
      glm20Proposition2AHatSource
            priorPrecision subPrecisionSum fullPrecisionSum mu qHigh +
          glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum * mu ≤
        glm20Proposition2AHatSource
            priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub +
          glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum * mu := by
    linarith
  exact div_le_div_of_nonneg_right hnum_arg hsqrt_pos.le

/--
Proposition 2(iii), case `q_{2,sub}^* > q_h^B`: group-B mass admitted by
school `J1`.
-/
def glm20Proposition2J1MassAboveHighCutoff
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (populationShare sigmaTilde aHatLow b mu q1Full : ℝ) : ℝ :=
  glm20Proposition2AdmittedMassFormula api bivariateCDF
    populationShare sigmaTilde aHatLow b mu q1Full

/--
Proposition 2(iii), case `q_{2,sub}^* > q_h^B`: group-B mass enrolled by
school `J2`.

It is the test-free eligible mass above `q_{2,sub}^*` minus the students from
the same tail who are admitted by `J1`.
-/
def glm20Proposition2J2MassAboveHighCutoff
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
      sigmaTilde aHatQ2 b q1Full : ℝ) : ℝ :=
  glm20Proposition2SubEligibleMassFormula api
      populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub -
    glm20Proposition2AdmittedMassFormula api bivariateCDF
      populationShare sigmaTilde aHatQ2 b mu q1Full

/--
Proposition 2(iii)/(iv) mass bookkeeping for the case
`q_{2,sub}^* > q_h^g`.

If the test-free eligible mass is the affine total-selection mass
`pi_g sigma_tilde_g Phi(A_g(q_{2,sub}^*))`, then subtracting the admitted
`D_g(a_hat_g(q_{2,sub}^*))` mass leaves exactly the correlated-Gaussian
lower-left rectangle.  This is the mass event used in the `J2` merit
calculation.
-/
theorem glm20Proposition2J2MassAboveHighCutoff_eq_lowerLeftRectangle_of_subEligibleMass
    {populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
      sigmaTilde aHatQ2 b q1Full : ℝ}
    (hsub :
      glm20Proposition2SubEligibleMassFormula standardGaussianCDFAPI
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub =
          populationShare * sigmaTilde *
            standardGaussianCDF
              ((aHatQ2 + b * mu) /
                Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))) :
    glm20Proposition2J2MassAboveHighCutoff standardGaussianCDFAPI
        standardBivariateGaussianCDF
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
        sigmaTilde aHatQ2 b q1Full =
      populationShare * sigmaTilde *
        lowerLeftRectangleMass
          (correlatedStandardGaussianLaw
            (-(sigmaTilde * b) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
          ((aHatQ2 + b * mu) /
            Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((q1Full - mu) / sigmaTilde) := by
  rw [glm20Proposition2J2MassAboveHighCutoff, hsub]
  simp [glm20Proposition2AdmittedMassFormula, glm20Proposition3SelectionCore,
    standardBivariateGaussianCDF, standardGaussianCDFAPI]
  ring_nf

/--
Proposition 2(iii), case `q_{2,sub}^* > q_h^g`: the residual `J2` mass is
positive once the test-free eligible mass is the affine total mass and the
population share and scale are positive.
-/
theorem glm20Proposition2J2MassAboveHighCutoff_pos_of_subEligibleMass
    {populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
      sigmaTilde aHatQ2 b q1Full : ℝ}
    (hpopulation : 0 < populationShare)
    (hsigma : 0 < sigmaTilde)
    (hsub :
      glm20Proposition2SubEligibleMassFormula standardGaussianCDFAPI
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub =
          populationShare * sigmaTilde *
            standardGaussianCDF
              ((aHatQ2 + b * mu) /
                Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))) :
    0 <
      glm20Proposition2J2MassAboveHighCutoff standardGaussianCDFAPI
        standardBivariateGaussianCDF
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
        sigmaTilde aHatQ2 b q1Full := by
  rw [glm20Proposition2J2MassAboveHighCutoff_eq_lowerLeftRectangle_of_subEligibleMass
    hsub]
  exact
    mul_pos (mul_pos hpopulation hsigma)
      (glm20Proposition2_correlatedLowerLeftRectangleMass_pos
        sigmaTilde aHatQ2 b mu q1Full)

/--
Proposition 2(iii), complementary case `q_h^B >= q_{2,sub}^* > q_l^B`:
group-B mass admitted by school `J1`.

Paper expression:
`D_B(a(q_l^B)) - D_B(a(q_h^B)) + D_B(a(q_{2,sub}^*))
 + pi_B sigma_tilde_B (Phi(A_B(q_h^B)) - Phi(A_B(q_{2,sub}^*)))`.
-/
def glm20Proposition2J1MassBetweenCutoffs
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (populationShare sigmaTilde aHatLow aHatHigh aHatQ2 b mu q1Full : ℝ) :
    ℝ :=
  glm20Proposition2AdmittedMassFormula api bivariateCDF
      populationShare sigmaTilde aHatLow b mu q1Full -
    glm20Proposition2AdmittedMassFormula api bivariateCDF
      populationShare sigmaTilde aHatHigh b mu q1Full +
    glm20Proposition2AdmittedMassFormula api bivariateCDF
      populationShare sigmaTilde aHatQ2 b mu q1Full +
    populationShare * sigmaTilde *
      (api.cdf (glm20Proposition2AArgument sigmaTilde aHatHigh b mu) -
        api.cdf (glm20Proposition2AArgument sigmaTilde aHatQ2 b mu))

/--
Proposition 2(iii), complementary case `q_h^B >= q_{2,sub}^* > q_l^B`:
group-B mass enrolled by school `J2`.
-/
def glm20Proposition2J2MassBetweenCutoffs
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
      sigmaTilde aHatHigh b q1Full : ℝ) : ℝ :=
  glm20Proposition2SubEligibleMassFormula api
      populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub -
    glm20Proposition2AdmittedMassFormula api bivariateCDF
      populationShare sigmaTilde aHatHigh b mu q1Full

/--
Proposition 2(iii), corrected-source case `q_{2,sub}^* > q_h^g`: group mass
admitted by school `J1`.
-/
def glm20Proposition2J1MassAboveHighCutoffCorrectedSource
    (populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum qLow q1Full : ℝ) : ℝ :=
  glm20Proposition2J1MassAboveHighCutoff standardGaussianCDFAPI
    standardBivariateGaussianCDF populationShare
    (glm20Proposition3SigmaTildeSource
      priorSigma priorPrecision fullPrecisionSum)
    (glm20Proposition2AHatConditionalSource
      priorPrecision subPrecisionSum fullPrecisionSum mu qLow)
    (glm20Proposition3BSource
      priorPrecision subPrecisionSum fullPrecisionSum)
    mu q1Full

/--
Proposition 2(iii), corrected-source case `q_{2,sub}^* > q_h^g`: group mass
enrolled by school `J2`.
-/
def glm20Proposition2J2MassAboveHighCutoffCorrectedSource
    (populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum q2Sub q1Full : ℝ) : ℝ :=
  glm20Proposition2SubEligibleUnnormalizedMassFormula standardGaussianCDFAPI
      populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum q2Sub -
    glm20Proposition2AdmittedMassFormula standardGaussianCDFAPI
      standardBivariateGaussianCDF populationShare
      (glm20Proposition3SigmaTildeSource
        priorSigma priorPrecision fullPrecisionSum)
      (glm20Proposition2AHatConditionalSource
        priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
      (glm20Proposition3BSource
        priorPrecision subPrecisionSum fullPrecisionSum)
      mu q1Full

/--
Proposition 2(iii), corrected-source complementary case: group mass admitted by
school `J1`.
-/
def glm20Proposition2J1MassBetweenCutoffsCorrectedSource
    (populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum qLow qHigh q2Sub q1Full : ℝ) : ℝ :=
  glm20Proposition2J1MassBetweenCutoffs standardGaussianCDFAPI
    standardBivariateGaussianCDF populationShare
    (glm20Proposition3SigmaTildeSource
      priorSigma priorPrecision fullPrecisionSum)
    (glm20Proposition2AHatConditionalSource
      priorPrecision subPrecisionSum fullPrecisionSum mu qLow)
    (glm20Proposition2AHatConditionalSource
      priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
    (glm20Proposition2AHatConditionalSource
      priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
    (glm20Proposition3BSource
      priorPrecision subPrecisionSum fullPrecisionSum)
    mu q1Full

/--
Proposition 2(iii), corrected-source complementary case: group mass enrolled by
school `J2`.
-/
def glm20Proposition2J2MassBetweenCutoffsCorrectedSource
    (populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum qHigh q2Sub q1Full : ℝ) : ℝ :=
  glm20Proposition2SubEligibleUnnormalizedMassFormula standardGaussianCDFAPI
      populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum q2Sub -
    glm20Proposition2AdmittedMassFormula standardGaussianCDFAPI
      standardBivariateGaussianCDF populationShare
      (glm20Proposition3SigmaTildeSource
        priorSigma priorPrecision fullPrecisionSum)
      (glm20Proposition2AHatConditionalSource
        priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
      (glm20Proposition3BSource
        priorPrecision subPrecisionSum fullPrecisionSum)
      mu q1Full

/--
Proposition 2(iii), corrected-source above-high case: the residual `J2` mass
is exactly the correlated-Gaussian lower-left rectangle.
-/
theorem glm20Proposition2J2MassAboveHighCutoffCorrectedSource_eq_lowerLeftRectangle
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum q2Sub q1Full : ℝ}
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    glm20Proposition2J2MassAboveHighCutoffCorrectedSource
        populationShare mu priorSigma priorPrecision subPrecisionSum
        fullPrecisionSum q2Sub q1Full =
      populationShare *
        glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum *
        lowerLeftRectangleMass
          (correlatedStandardGaussianLaw
            (-(glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum *
                glm20Proposition3BSource
                  priorPrecision subPrecisionSum fullPrecisionSum) /
              Real.sqrt
                (1 +
                  glm20Proposition3SigmaTildeSource
                      priorSigma priorPrecision fullPrecisionSum ^ 2 *
                    glm20Proposition3BSource
                      priorPrecision subPrecisionSum fullPrecisionSum ^ 2)))
          (glm20Proposition2AArgument
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatConditionalSource
              priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            mu)
          ((q1Full - mu) /
            glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum) := by
  rw [glm20Proposition2J2MassAboveHighCutoffCorrectedSource,
    glm20Proposition2SubEligibleUnnormalizedMassFormula_eq_conditional_affineArgument
      standardGaussianCDFAPI hsigma hsigma_sq hprior hsub hfull]
  simp [glm20Proposition2AdmittedMassFormula, glm20Proposition3SelectionCore,
    glm20Proposition2AArgument, standardBivariateGaussianCDF,
    standardGaussianCDFAPI]
  ring_nf

/--
Proposition 2(iii), corrected-source complementary case: the residual `J2`
mass is the lower-left rectangle plus the CDF gap.
-/
theorem glm20Proposition2J2MassBetweenCutoffsCorrectedSource_eq_lowerLeftRectangle_add_cdfGap
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum qHigh q2Sub q1Full : ℝ}
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    glm20Proposition2J2MassBetweenCutoffsCorrectedSource
        populationShare mu priorSigma priorPrecision subPrecisionSum
        fullPrecisionSum qHigh q2Sub q1Full =
      populationShare *
        glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum *
        (lowerLeftRectangleMass
          (correlatedStandardGaussianLaw
            (-(glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum *
                glm20Proposition3BSource
                  priorPrecision subPrecisionSum fullPrecisionSum) /
              Real.sqrt
                (1 +
                  glm20Proposition3SigmaTildeSource
                      priorSigma priorPrecision fullPrecisionSum ^ 2 *
                    glm20Proposition3BSource
                      priorPrecision subPrecisionSum fullPrecisionSum ^ 2)))
          (glm20Proposition2AArgument
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatConditionalSource
              priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            mu)
          ((q1Full - mu) /
            glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum) +
        (standardGaussianCDF
          (glm20Proposition2AArgument
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatConditionalSource
              priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            mu) -
          standardGaussianCDF
            (glm20Proposition2AArgument
              (glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum)
              (glm20Proposition2AHatConditionalSource
                priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
              (glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum)
              mu))) := by
  rw [glm20Proposition2J2MassBetweenCutoffsCorrectedSource,
    glm20Proposition2SubEligibleUnnormalizedMassFormula_eq_conditional_affineArgument
      standardGaussianCDFAPI hsigma hsigma_sq hprior hsub hfull]
  simp [glm20Proposition2AdmittedMassFormula, glm20Proposition3SelectionCore,
    glm20Proposition2AArgument, standardBivariateGaussianCDF,
    standardGaussianCDFAPI]
  ring_nf

/--
Proposition 2(iii), corrected-source above-high case: the residual `J2` mass
is positive.
-/
theorem glm20Proposition2J2MassAboveHighCutoffCorrectedSource_pos
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum q2Sub q1Full : ℝ}
    (hpopulation : 0 < populationShare)
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    0 <
      glm20Proposition2J2MassAboveHighCutoffCorrectedSource
        populationShare mu priorSigma priorPrecision subPrecisionSum
        fullPrecisionSum q2Sub q1Full := by
  rw [glm20Proposition2J2MassAboveHighCutoffCorrectedSource_eq_lowerLeftRectangle
    hsigma hsigma_sq hprior hsub hfull]
  exact
    mul_pos
      (mul_pos hpopulation
        (glm20Proposition3SigmaTildeSource_pos hsigma hprior hfull))
      (glm20Proposition2_correlatedLowerLeftRectangleMass_pos
        (glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum)
        (glm20Proposition2AHatConditionalSource
          priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
        (glm20Proposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum)
        mu q1Full)

/--
Proposition 2(iii), corrected-source complementary case: the residual `J2`
mass is positive when `q_{2,sub}^* <= q_h^g`.
-/
theorem glm20Proposition2J2MassBetweenCutoffsCorrectedSource_pos
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum qHigh q2Sub q1Full : ℝ}
    (hpopulation : 0 < populationShare)
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum)
    (hq2_le_high : q2Sub ≤ qHigh) :
    0 <
      glm20Proposition2J2MassBetweenCutoffsCorrectedSource
        populationShare mu priorSigma priorPrecision subPrecisionSum
        fullPrecisionSum qHigh q2Sub q1Full := by
  rw [glm20Proposition2J2MassBetweenCutoffsCorrectedSource_eq_lowerLeftRectangle_add_cdfGap
    hsigma hsigma_sq hprior hsub hfull]
  have hA :
      glm20Proposition2AArgument
          (glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum)
          (glm20Proposition2AHatConditionalSource
            priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
          (glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum)
          mu ≤
        glm20Proposition2AArgument
          (glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum)
          (glm20Proposition2AHatConditionalSource
            priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
          (glm20Proposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum)
          mu :=
    glm20Proposition2AArgument_conditional_source_le_of_q_le
      hsigma hsigma_sq hprior hsub hfull hq2_le_high
  have hrect :
      0 <
        lowerLeftRectangleMass
          (correlatedStandardGaussianLaw
            (-(glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum *
                glm20Proposition3BSource
                  priorPrecision subPrecisionSum fullPrecisionSum) /
              Real.sqrt
                (1 +
                  glm20Proposition3SigmaTildeSource
                      priorSigma priorPrecision fullPrecisionSum ^ 2 *
                    glm20Proposition3BSource
                      priorPrecision subPrecisionSum fullPrecisionSum ^ 2)))
          (glm20Proposition2AArgument
            (glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (glm20Proposition2AHatConditionalSource
              priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
            (glm20Proposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            mu)
          ((q1Full - mu) /
            glm20Proposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum) :=
    glm20Proposition2_correlatedLowerLeftRectangleMass_pos
      (glm20Proposition3SigmaTildeSource
        priorSigma priorPrecision fullPrecisionSum)
      (glm20Proposition2AHatConditionalSource
        priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
      (glm20Proposition3BSource
        priorPrecision subPrecisionSum fullPrecisionSum)
      mu q1Full
  have hgap_nonneg :
      0 ≤
        standardGaussianCDF
            (glm20Proposition2AArgument
              (glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum)
              (glm20Proposition2AHatConditionalSource
                priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
              (glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum)
              mu) -
          standardGaussianCDF
            (glm20Proposition2AArgument
              (glm20Proposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum)
              (glm20Proposition2AHatConditionalSource
                priorPrecision subPrecisionSum fullPrecisionSum mu qHigh)
              (glm20Proposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum)
              mu) :=
    sub_nonneg.mpr (standardGaussianCDF_mono hA)
  exact
    mul_pos
      (mul_pos hpopulation
        (glm20Proposition3SigmaTildeSource_pos hsigma hprior hfull))
      (add_pos_of_pos_of_nonneg hrect hgap_nonneg)

/--
Proposition 2(iii), complementary case
`q_h^g >= q_{2,sub}^* > q_l^g`: residual `J2` mass as a lower-left rectangle
plus the CDF gap between the `q_{2,sub}^*` and high-cutoff affine arguments.
-/
theorem glm20Proposition2J2MassBetweenCutoffs_eq_lowerLeftRectangle_add_cdfGap_of_subEligibleMass
    {populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
      sigmaTilde aHatHigh aHatQ2 b q1Full : ℝ}
    (hsub :
      glm20Proposition2SubEligibleMassFormula standardGaussianCDFAPI
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub =
          populationShare * sigmaTilde *
            standardGaussianCDF
              ((aHatQ2 + b * mu) /
                Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))) :
    glm20Proposition2J2MassBetweenCutoffs standardGaussianCDFAPI
        standardBivariateGaussianCDF
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
        sigmaTilde aHatHigh b q1Full =
      populationShare * sigmaTilde *
        (lowerLeftRectangleMass
          (correlatedStandardGaussianLaw
            (-(sigmaTilde * b) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
          ((aHatHigh + b * mu) /
            Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((q1Full - mu) / sigmaTilde) +
        (standardGaussianCDF
          ((aHatQ2 + b * mu) /
            Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)) -
          standardGaussianCDF
            ((aHatHigh + b * mu) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))) := by
  rw [glm20Proposition2J2MassBetweenCutoffs, hsub]
  simp [glm20Proposition2AdmittedMassFormula, glm20Proposition3SelectionCore,
    standardBivariateGaussianCDF, standardGaussianCDFAPI]
  ring_nf

/--
Proposition 2(iii), complementary case: the residual `J2` mass is positive
when the affine `q_{2,sub}^*` argument is at least the high-cutoff argument.
-/
theorem glm20Proposition2J2MassBetweenCutoffs_pos_of_subEligibleMass
    {populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
      sigmaTilde aHatHigh aHatQ2 b q1Full : ℝ}
    (hpopulation : 0 < populationShare)
    (hsigma : 0 < sigmaTilde)
    (hA :
      (aHatHigh + b * mu) /
          Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2) ≤
        (aHatQ2 + b * mu) /
          Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
    (hsub :
      glm20Proposition2SubEligibleMassFormula standardGaussianCDFAPI
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub =
          populationShare * sigmaTilde *
            standardGaussianCDF
              ((aHatQ2 + b * mu) /
                Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))) :
    0 <
      glm20Proposition2J2MassBetweenCutoffs standardGaussianCDFAPI
        standardBivariateGaussianCDF
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
        sigmaTilde aHatHigh b q1Full := by
  rw [glm20Proposition2J2MassBetweenCutoffs_eq_lowerLeftRectangle_add_cdfGap_of_subEligibleMass
    hsub]
  have hrect :
      0 <
        lowerLeftRectangleMass
          (correlatedStandardGaussianLaw
            (-(sigmaTilde * b) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
          ((aHatHigh + b * mu) /
            Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((q1Full - mu) / sigmaTilde) :=
    glm20Proposition2_correlatedLowerLeftRectangleMass_pos
      sigmaTilde aHatHigh b mu q1Full
  have hgap_nonneg :
      0 ≤
        standardGaussianCDF
            ((aHatQ2 + b * mu) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)) -
          standardGaussianCDF
            ((aHatHigh + b * mu) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)) :=
    sub_nonneg.mpr (standardGaussianCDF_mono hA)
  exact
    mul_pos (mul_pos hpopulation hsigma)
      (add_pos_of_pos_of_nonneg hrect hgap_nonneg)

/--
Proposition 2(iii) algebra: comparing diversity shares is equivalent to the
paper's mass-ratio inequality.

If school `J_i`'s group-B diversity share is `mass_i / C_i`, then
`J1` is more diverse than `J2` exactly when
`mass_1 / mass_2 > C_1 / C_2`.
-/
theorem paper_proposition2_diversity_share_gt_iff_mass_ratio_gt
    {capacity1 capacity2 j1GroupMass j2GroupMass
      j1Diversity j2Diversity : ℝ}
    (hcapacity1 : 0 < capacity1)
    (hcapacity2 : 0 < capacity2)
    (hj2Mass : 0 < j2GroupMass)
    (hj1 : j1Diversity = j1GroupMass / capacity1)
    (hj2 : j2Diversity = j2GroupMass / capacity2) :
    j2Diversity < j1Diversity ↔
      capacity1 / capacity2 < j1GroupMass / j2GroupMass := by
  rw [hj1, hj2]
  constructor
  · intro hshare
    rw [div_lt_div_iff₀ hcapacity2 hcapacity1] at hshare
    rw [div_lt_div_iff₀ hcapacity2 hj2Mass]
    nlinarith
  · intro hratio
    rw [div_lt_div_iff₀ hcapacity2 hj2Mass] at hratio
    rw [div_lt_div_iff₀ hcapacity2 hcapacity1]
    nlinarith

/--
Paper Proposition 2(iii), case `q_{2,sub}^* > q_h^B`.

Once the model derivation identifies the two school diversity shares with the
displayed `D_B` and test-free-tail masses, Lean proves the paper's criterion:
school `J1` is more diverse than `J2` iff
`D_B(a(q_l^B)) /
 (pi_B Phi(...) - D_B(a(q_{2,sub}^*))) > C_1 / C_2`.
-/
theorem paper_proposition2_part_iii_diversity_criterion_above_high_cutoff
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {j1MoreDiverse : Prop}
    {j1Diversity j2Diversity capacity1 capacity2 : ℝ}
    {populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
      sigmaTilde aHatLow aHatQ2 b q1Full : ℝ}
    (hmore : j1MoreDiverse ↔ j2Diversity < j1Diversity)
    (hj1 :
      j1Diversity =
        glm20Proposition2J1MassAboveHighCutoff api bivariateCDF
            populationShare sigmaTilde aHatLow b mu q1Full /
          capacity1)
    (hj2 :
      j2Diversity =
        glm20Proposition2J2MassAboveHighCutoff api bivariateCDF
            populationShare mu priorSigma priorPrecision subPrecisionSum
            q2Sub sigmaTilde aHatQ2 b q1Full /
          capacity2)
    (hcapacity1 : 0 < capacity1)
    (hcapacity2 : 0 < capacity2)
    (hj2Mass :
      0 <
        glm20Proposition2J2MassAboveHighCutoff api bivariateCDF
          populationShare mu priorSigma priorPrecision subPrecisionSum
          q2Sub sigmaTilde aHatQ2 b q1Full) :
    j1MoreDiverse ↔
      capacity1 / capacity2 <
        glm20Proposition2J1MassAboveHighCutoff api bivariateCDF
            populationShare sigmaTilde aHatLow b mu q1Full /
          glm20Proposition2J2MassAboveHighCutoff api bivariateCDF
            populationShare mu priorSigma priorPrecision subPrecisionSum
            q2Sub sigmaTilde aHatQ2 b q1Full := by
  rw [hmore]
  exact
    paper_proposition2_diversity_share_gt_iff_mass_ratio_gt
      hcapacity1 hcapacity2 hj2Mass hj1 hj2

/--
Paper Proposition 2(iii), corrected-source case `q_{2,sub}^* > q_h^g`.

This is the same diversity-ratio criterion as the paper statement, but the
test-free eligible mass is the corrected unnormalized source formula derived
from the conditional Gaussian line of Appendix D.6.
-/
theorem
    paper_proposition2_part_iii_diversity_criterion_above_high_cutoff_corrected_source_parameters
    {j1MoreDiverse : Prop}
    {j1Diversity j2Diversity capacity1 capacity2 : ℝ}
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum qLow q2Sub q1Full : ℝ}
    (hmore : j1MoreDiverse ↔ j2Diversity < j1Diversity)
    (hj1 :
      j1Diversity =
        glm20Proposition2J1MassAboveHighCutoffCorrectedSource
            populationShare mu priorSigma priorPrecision subPrecisionSum
            fullPrecisionSum qLow q1Full /
          capacity1)
    (hj2 :
      j2Diversity =
        glm20Proposition2J2MassAboveHighCutoffCorrectedSource
            populationShare mu priorSigma priorPrecision subPrecisionSum
            fullPrecisionSum q2Sub q1Full /
          capacity2)
    (hcapacity1 : 0 < capacity1)
    (hcapacity2 : 0 < capacity2)
    (hpopulation : 0 < populationShare)
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision)
    (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    j1MoreDiverse ↔
      capacity1 / capacity2 <
        glm20Proposition2J1MassAboveHighCutoffCorrectedSource
            populationShare mu priorSigma priorPrecision subPrecisionSum
            fullPrecisionSum qLow q1Full /
          glm20Proposition2J2MassAboveHighCutoffCorrectedSource
            populationShare mu priorSigma priorPrecision subPrecisionSum
            fullPrecisionSum q2Sub q1Full := by
  rw [hmore]
  exact
    paper_proposition2_diversity_share_gt_iff_mass_ratio_gt
      hcapacity1 hcapacity2
      (glm20Proposition2J2MassAboveHighCutoffCorrectedSource_pos
        hpopulation hsigma hsigma_sq hprior hsub hfull)
      hj1 hj2

/--
Paper Proposition 2(iii), corrected-source case `q_{2,sub}^* > q_h^g`,
with diversity rows defined directly from the corrected source masses.

Compared with
`paper_proposition2_part_iii_diversity_criterion_above_high_cutoff_corrected_source_parameters`,
this theorem removes the model-side row-identification premises `hmore`,
`hj1`, and `hj2`; the diversity comparison is stated directly for the
source-row values.
-/
abbrev
    paper_proposition2_part_iii_diversity_criterion_above_high_cutoff_corrected_source_rows
    {capacity1 capacity2 : ℝ}
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum qLow q2Sub q1Full : ℝ}
    (hcapacity1 : 0 < capacity1)
    (hcapacity2 : 0 < capacity2)
    (hpopulation : 0 < populationShare)
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision)
    (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :=
  let j1Diversity :=
    glm20Proposition2J1MassAboveHighCutoffCorrectedSource
        populationShare mu priorSigma priorPrecision subPrecisionSum
        fullPrecisionSum qLow q1Full /
      capacity1
  let j2Diversity :=
    glm20Proposition2J2MassAboveHighCutoffCorrectedSource
        populationShare mu priorSigma priorPrecision subPrecisionSum
        fullPrecisionSum q2Sub q1Full /
      capacity2
  paper_proposition2_part_iii_diversity_criterion_above_high_cutoff_corrected_source_parameters
    (j1MoreDiverse := j2Diversity < j1Diversity)
    (j1Diversity := j1Diversity) (j2Diversity := j2Diversity)
    (capacity1 := capacity1) (capacity2 := capacity2)
    (populationShare := populationShare) (mu := mu)
    (priorSigma := priorSigma) (priorPrecision := priorPrecision)
    (subPrecisionSum := subPrecisionSum)
    (fullPrecisionSum := fullPrecisionSum) (qLow := qLow)
