threshold" statement follows from the affine crossing cutoff.
-/
theorem paper_theorem2_group_admission_probability_decreases_iff_above_cutoff
    (A : StandardGaussianDerivativeAPI)
    {probFull probSub : ℝ → ℝ}
    {interceptFull slopeFull interceptSub slopeSub cutoff q : ℝ}
    (hprobFull :
      ∀ x : ℝ, probFull x =
        A.affineUpperTail interceptFull slopeFull x)
    (hprobSub :
      ∀ x : ℝ, probSub x =
        A.affineUpperTail interceptSub slopeSub x)
    (hcutoff :
      cutoff = (interceptFull - interceptSub) / (slopeFull - slopeSub))
    (hslope : slopeSub < slopeFull) :
    probFull q > probSub q ↔ cutoff < q := by
  rw [hprobFull q, hprobSub q, hcutoff]
  exact paper_theorem2_affine_admission_probability_full_gt_sub_iff_cutoff_lt
    A hslope

/--
Theorem 2(ii) individual-fairness-gap aggregation: if the full-policy
admission advantage over the test-free policy is larger for group A than for
group B, then the full-policy individual-fairness gap is larger.
-/
theorem paper_theorem2_individual_fairness_gap_full_gt_sub_of_delta_gt
    {gapFull gapSub probAFull probBFull probASub probBSub : ℝ}
    (hgapFull : gapFull = probAFull - probBFull)
    (hgapSub : gapSub = probASub - probBSub)
    (hdelta : probAFull - probASub > probBFull - probBSub) :
    gapFull > gapSub := by
  rw [hgapFull, hgapSub]
  linarith

/--
Theorem 2(ii) individual-fairness-gap aggregation in the main-text direction:
if the full-minus-sub admission gain is smaller for group A than group B, then
the test-free individual-fairness gap is larger.
-/
theorem paper_theorem2_individual_fairness_gap_sub_gt_full_of_delta_lt
    {gapFull gapSub probAFull probBFull probASub probBSub : ℝ}
    (hgapFull : gapFull = probAFull - probBFull)
    (hgapSub : gapSub = probASub - probBSub)
    (hdelta : probAFull - probASub < probBFull - probBSub) :
    gapSub > gapFull := by
  rw [hgapFull, hgapSub]
  linarith

/--
Theorem 2(ii) interval support: if group A's admission probability is higher
under the full policy while group B's is lower under the full policy, then the
full-policy individual-fairness gap is larger than the test-free gap.
-/
theorem paper_theorem2_individual_fairness_gap_full_gt_sub_of_opposite_group_crossings
    {gapFull gapSub probAFull probBFull probASub probBSub : ℝ}
    (hgapFull : gapFull = probAFull - probBFull)
    (hgapSub : gapSub = probASub - probBSub)
    (hA : probAFull > probASub)
    (hB : probBFull < probBSub) :
    gapFull > gapSub := by
  apply paper_theorem2_individual_fairness_gap_full_gt_sub_of_delta_gt
    hgapFull hgapSub
  linarith

/--
Theorem 2(ii) high-skill threshold wrapper: if the paper's remaining
large-skill analytic comparison shows that the full-minus-sub admission change
for group A is eventually larger than the corresponding change for group B,
then there exists a threshold `qhat ≥ max qA qB` above which the full-policy
individual-fairness gap is larger than the test-free gap.
-/
theorem paper_theorem2_exists_high_skill_threshold_individual_fairness_gap_full_gt_sub
    {gapFull gapSub probAFull probBFull probASub probBSub : ℝ → ℝ}
    {qA qB qDelta : ℝ}
    (hgapFull :
      ∀ q : ℝ, gapFull q = probAFull q - probBFull q)
    (hgapSub :
      ∀ q : ℝ, gapSub q = probASub q - probBSub q)
    (hdelta :
      ∀ q : ℝ, qDelta < q →
        probAFull q - probASub q > probBFull q - probBSub q) :
    ∃ qhat : ℝ, max qA qB ≤ qhat ∧
      ∀ q : ℝ, qhat < q → gapFull q > gapSub q := by
  refine ⟨max qDelta (max qA qB), ?_, ?_⟩
  · exact le_max_right qDelta (max qA qB)
  · intro q hq
    have hqDelta : qDelta < q :=
      lt_of_le_of_lt (le_max_left qDelta (max qA qB)) hq
    exact
      paper_theorem2_individual_fairness_gap_full_gt_sub_of_delta_gt
        (hgapFull q) (hgapSub q) (hdelta q hqDelta)

/--
Theorem 2(ii) high-skill threshold wrapper in the main-text direction.

If the paper's remaining large-skill analytic comparison shows that the
full-minus-sub admission change for group B is eventually larger than the
corresponding change for group A, then there exists a threshold
`qhat ≥ max qA qB` above which the test-free individual-fairness gap is larger
than the full-policy gap.
-/
theorem paper_theorem2_exists_high_skill_threshold_individual_fairness_gap_sub_gt_full
    {gapFull gapSub probAFull probBFull probASub probBSub : ℝ → ℝ}
    {qA qB qDelta : ℝ}
    (hgapFull :
      ∀ q : ℝ, gapFull q = probAFull q - probBFull q)
    (hgapSub :
      ∀ q : ℝ, gapSub q = probASub q - probBSub q)
    (hdelta :
      ∀ q : ℝ, qDelta < q →
        probAFull q - probASub q < probBFull q - probBSub q) :
    ∃ qhat : ℝ, max qA qB ≤ qhat ∧
      ∀ q : ℝ, qhat < q → gapSub q > gapFull q := by
  refine ⟨max qDelta (max qA qB), ?_, ?_⟩
  · exact le_max_right qDelta (max qA qB)
  · intro q hq
    have hqDelta : qDelta < q :=
      lt_of_le_of_lt (le_max_left qDelta (max qA qB)) hq
    exact
      paper_theorem2_individual_fairness_gap_sub_gt_full_of_delta_lt
        (hgapFull q) (hgapSub q) (hdelta q hqDelta)

/--
Theorem 2 canonical no-barrier source surface.

The surface records exactly the paper's no-barrier comparison primitives:
closed-form diversity for `P_sub` and `P_full`, affine standard-normal
admission probabilities for the two groups under both policies, and
standard-normal upper-tail means for group academic merit.
-/
def theorem2NoBarrierSourceSurface
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) (Psub Pfull : Policy)
    (pi capacity quantile leftWeight priorPrecision subA subB testA testB : ℝ)
    (interceptAFull slopeAFull interceptASub slopeASub
      interceptBFull slopeBFull interceptBSub slopeBSub : ℝ)
    (L_A_sub L_A_full L_B_sub L_B_full : GaussianScaleLaw)
    (thresholdSub thresholdFull : ℝ) :
    GLM20SourcePolicySurface Group Policy where
  populationShareB := pi
  capacity := capacity
  precision := fun _ _ => 0
  accessLevel := fun _ => 1
  estimatedSkillMean := fun _ _ => 0
  estimatedSkillVariance := fun _ _ => 0
  admissionThreshold := fun P =>
    if P = Psub then thresholdSub else if P = Pfull then thresholdFull else 0
  diversity := fun P =>
    if P = Psub then
      1 - standardGaussianCDFAPI.cdf
        (quantile * Real.sqrt
          (leftWeight *
              ((subA / (priorPrecision + subA)) /
                (subB / (priorPrecision + subB))) +
            pi))
    else if P = Pfull then
      1 - standardGaussianCDFAPI.cdf
        (quantile * Real.sqrt
          (leftWeight *
              (((subA + testA) /
                  (priorPrecision + subA + testA)) /
                ((subB + testB) /
                  (priorPrecision + subB + testB))) +
            pi))
    else
      0
  individualFairnessGap := fun P q =>
    if P = Pfull then
      standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q -
        standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q
    else if P = Psub then
      standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q -
        standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q
    else
      0
  academicMerit := fun g P =>
    if P = Pfull then
      if g = groupA then
        standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          |>.normalUpperTailMean L_A_full thresholdFull
      else if g = groupB then
        standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          |>.normalUpperTailMean L_B_full thresholdFull
      else
        0
    else if P = Psub then
      if g = groupA then
        standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          |>.normalUpperTailMean L_A_sub thresholdSub
      else if g = groupB then
        standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          |>.normalUpperTailMean L_B_sub thresholdSub
      else
        0
    else
      0

/--
Theorem 2(ii), high-skill individual-fairness statement in the main-text
direction.

This wrapper matches the theorem text's claim that, above a high-skill
threshold, the individual-fairness gap is larger after dropping tests.  It
therefore assumes the corresponding eventual delta inequality directly.  The
appendix proof in the cached source instead derives the opposite direction,
which is formalized separately by
`paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_surface`.
-/
theorem paper_theorem2_high_skill_individual_fairness_gap_sub_gt_full_source_surface
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) {Psub Pfull : Policy}
    {pi capacity quantile leftWeight priorPrecision subA subB testA testB : ℝ}
    {interceptAFull slopeAFull interceptASub slopeASub
      interceptBFull slopeBFull interceptBSub slopeBSub : ℝ}
    {L_A_sub L_A_full L_B_sub L_B_full : GaussianScaleLaw}
    {thresholdSub thresholdFull qDelta : ℝ}
    (hP_ne : Psub ≠ Pfull)
    (hslopeA : slopeASub < slopeAFull)
    (hslopeB : slopeBSub < slopeBFull)
    (hdelta :
      ∀ q : ℝ, qDelta < q →
        standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q -
            standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q <
          standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q -
            standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q) :
    let S : GLM20SourcePolicySurface Group Policy :=
      theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
        pi capacity quantile leftWeight priorPrecision subA subB testA testB
        interceptAFull slopeAFull interceptASub slopeASub
        interceptBFull slopeBFull interceptBSub slopeBSub
        L_A_sub L_A_full L_B_sub L_B_full thresholdSub thresholdFull
    ∃ qA qB : ℝ,
      (∀ q : ℝ,
        standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q >
            standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q ↔
          qA < q) ∧
      (∀ q : ℝ,
        standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q >
            standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q ↔
          qB < q) ∧
      ∃ qhat : ℝ, max qA qB ≤ qhat ∧
        ∀ q : ℝ, qhat < q →
          S.individualFairnessGap Psub q >
            S.individualFairnessGap Pfull q := by
  dsimp only
  let S : GLM20SourcePolicySurface Group Policy :=
    theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
      pi capacity quantile leftWeight priorPrecision subA subB testA testB
      interceptAFull slopeAFull interceptASub slopeASub
      interceptBFull slopeBFull interceptBSub slopeBSub
      L_A_sub L_A_full L_B_sub L_B_full thresholdSub thresholdFull
  let qA := (interceptAFull - interceptASub) / (slopeAFull - slopeASub)
  let qB := (interceptBFull - interceptBSub) / (slopeBFull - slopeBSub)
  refine ⟨qA, qB, ?_, ?_, ?_⟩
  · intro q
    exact
      paper_theorem2_affine_admission_probability_full_gt_sub_iff_cutoff_lt
        standardGaussianDerivativeAPI hslopeA
  · intro q
    exact
      paper_theorem2_affine_admission_probability_full_gt_sub_iff_cutoff_lt
        standardGaussianDerivativeAPI hslopeB
  · have hgapFull :
      ∀ q : ℝ, S.individualFairnessGap Pfull q =
        standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q -
          standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q := by
      intro q
      simp [S, theorem2NoBarrierSourceSurface]
    have hgapSub :
      ∀ q : ℝ, S.individualFairnessGap Psub q =
        standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q -
          standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q := by
      intro q
      simp [S, theorem2NoBarrierSourceSurface, hP_ne]
    exact
      paper_theorem2_exists_high_skill_threshold_individual_fairness_gap_sub_gt_full
        (qA := qA) (qB := qB) (qDelta := qDelta)
        hgapFull hgapSub hdelta

/--
Theorem 2(ii), main-text high-skill delta comparison from same-side Gaussian
tail order.

If the test-free precision still favors group A (`slopeBSub < slopeASub`) and
adding the test raises group B's precision (`slopeBSub < slopeBFull`), then the
test-free group gap eventually dominates the full-policy group gap.  The proof
uses Gaussian left-tail dominance, not just CDF monotonicity: the larger-slope
left tails become negligible relative to the slower group-B test-free left
tail.
-/
theorem paper_theorem2_affineUpperTail_delta_lt_eventually_of_same_side_slope_order
    {interceptAFull slopeAFull interceptASub slopeASub
      interceptBFull slopeBFull interceptBSub slopeBSub : ℝ}
    (hslopeBSub_pos : 0 < slopeBSub)
    (hsubSlope : slopeBSub < slopeASub)
    (hBPolicySlope : slopeBSub < slopeBFull) :
    ∃ qDelta : ℝ, ∀ q : ℝ, qDelta < q →
      standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q -
          standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q <
        standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q -
          standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q :=
  standardGaussian_affineUpperTail_delta_lt_eventually_of_same_side_slope_order
    hslopeBSub_pos hsubSlope hBPolicySlope

/--
Theorem 2(ii), high-skill individual-fairness statement in the main-text
direction, with the large-skill comparison proved from same-side slope order.

This is the source-surface form of the prose-consistent repair: both the full
policy and the test-free policy may favor group A in precision, and the
test-free group-B left tail is the slow tail that eventually controls the
individual-fairness gap.
-/
theorem paper_theorem2_high_skill_individual_fairness_gap_sub_gt_full_source_surface_of_same_side_slope_order
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) {Psub Pfull : Policy}
    {pi capacity quantile leftWeight priorPrecision subA subB testA testB : ℝ}
    {interceptAFull slopeAFull interceptASub slopeASub
      interceptBFull slopeBFull interceptBSub slopeBSub : ℝ}
    {L_A_sub L_A_full L_B_sub L_B_full : GaussianScaleLaw}
    {thresholdSub thresholdFull : ℝ}
    (hP_ne : Psub ≠ Pfull)
    (hslopeA : slopeASub < slopeAFull)
    (hslopeB : slopeBSub < slopeBFull)
    (_hfullSlope : slopeBFull < slopeAFull)
    (hsubSlope : slopeBSub < slopeASub)
    (hslopeBSub_pos : 0 < slopeBSub) :
    let S : GLM20SourcePolicySurface Group Policy :=
      theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
        pi capacity quantile leftWeight priorPrecision subA subB testA testB
        interceptAFull slopeAFull interceptASub slopeASub
        interceptBFull slopeBFull interceptBSub slopeBSub
        L_A_sub L_A_full L_B_sub L_B_full thresholdSub thresholdFull
    ∃ qA qB : ℝ,
      (∀ q : ℝ,
        standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q >
            standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q ↔
          qA < q) ∧
      (∀ q : ℝ,
        standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q >
            standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q ↔
          qB < q) ∧
      ∃ qhat : ℝ, max qA qB ≤ qhat ∧
        ∀ q : ℝ, qhat < q →
          S.individualFairnessGap Psub q >
            S.individualFairnessGap Pfull q := by
  obtain ⟨qDelta, hdelta⟩ :=
    paper_theorem2_affineUpperTail_delta_lt_eventually_of_same_side_slope_order
      (interceptAFull := interceptAFull) (slopeAFull := slopeAFull)
      (interceptASub := interceptASub) (slopeASub := slopeASub)
      (interceptBFull := interceptBFull) (slopeBFull := slopeBFull)
      (interceptBSub := interceptBSub) (slopeBSub := slopeBSub)
      hslopeBSub_pos hsubSlope hslopeB
  exact
    paper_theorem2_high_skill_individual_fairness_gap_sub_gt_full_source_surface
      (qDelta := qDelta) groupA groupB hP_ne hslopeA hslopeB hdelta

/--
Theorem 2(ii), high-skill individual-fairness main-text direction in paper
precision notation.

The extra assumption relative to the theorem statement is
`subB < subA`: after dropping the test, the remaining features still give group
A higher total precision than group B.  Together with the paper's full-policy
precision order `subB + testB < subA + testA`, this matches the prose/model
reading but not the theorem statement's literal hypotheses.
-/
theorem paper_theorem2_high_skill_individual_fairness_gap_sub_gt_full_source_surface_of_precision_order
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) {Psub Pfull : Policy}
    {pi capacity quantile leftWeight priorPrecision mean subA subB testA testB : ℝ}
    {L_A_sub L_A_full L_B_sub L_B_full : GaussianScaleLaw}
    {thresholdSub thresholdFull : ℝ}
    (hP_ne : Psub ≠ Pfull)
    (hsubA_pos : 0 < subA) (hsubB_pos : 0 < subB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB)
    (hfull_precision_order : subB + testB < subA + testA)
    (hsub_precision_order : subB < subA) :
    let interceptAFull :=
      (priorPrecision * (thresholdFull - mean) +
          (subA + testA) * thresholdFull) /
        Real.sqrt (subA + testA)
    let slopeAFull := Real.sqrt (subA + testA)
    let interceptASub :=
      (priorPrecision * (thresholdSub - mean) + subA * thresholdSub) /
        Real.sqrt subA
    let slopeASub := Real.sqrt subA
    let interceptBFull :=
      (priorPrecision * (thresholdFull - mean) +
          (subB + testB) * thresholdFull) /
        Real.sqrt (subB + testB)
    let slopeBFull := Real.sqrt (subB + testB)
    let interceptBSub :=
      (priorPrecision * (thresholdSub - mean) + subB * thresholdSub) /
        Real.sqrt subB
    let slopeBSub := Real.sqrt subB
    let S : GLM20SourcePolicySurface Group Policy :=
      theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
        pi capacity quantile leftWeight priorPrecision subA subB testA testB
        interceptAFull slopeAFull interceptASub slopeASub
        interceptBFull slopeBFull interceptBSub slopeBSub
        L_A_sub L_A_full L_B_sub L_B_full thresholdSub thresholdFull
    ∃ qA qB : ℝ,
      (∀ q : ℝ,
        standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q >
            standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q ↔
          qA < q) ∧
      (∀ q : ℝ,
        standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q >
            standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q ↔
          qB < q) ∧
      ∃ qhat : ℝ, max qA qB ≤ qhat ∧
        ∀ q : ℝ, qhat < q →
          S.individualFairnessGap Psub q >
            S.individualFairnessGap Pfull q := by
  have hfullA_pos : 0 < subA + testA := by linarith
  have hfullB_pos : 0 < subB + testB := by linarith
  have hslopeA : Real.sqrt subA < Real.sqrt (subA + testA) := by
    apply Real.sqrt_lt_sqrt hsubA_pos.le
    linarith
  have hslopeB : Real.sqrt subB < Real.sqrt (subB + testB) := by
    apply Real.sqrt_lt_sqrt hsubB_pos.le
    linarith
  have hfullSlope :
      Real.sqrt (subB + testB) < Real.sqrt (subA + testA) :=
    Real.sqrt_lt_sqrt hfullB_pos.le hfull_precision_order
  have hsubSlope : Real.sqrt subB < Real.sqrt subA :=
    Real.sqrt_lt_sqrt hsubB_pos.le hsub_precision_order
  have hslopeBSub_pos : 0 < Real.sqrt subB := Real.sqrt_pos.mpr hsubB_pos
  exact
    paper_theorem2_high_skill_individual_fairness_gap_sub_gt_full_source_surface_of_same_side_slope_order
      (groupA := groupA) (groupB := groupB) (Psub := Psub) (Pfull := Pfull)
      (pi := pi) (capacity := capacity) (quantile := quantile)
      (leftWeight := leftWeight) (priorPrecision := priorPrecision)
      (subA := subA) (subB := subB) (testA := testA) (testB := testB)
      (interceptAFull :=
        (priorPrecision * (thresholdFull - mean) +
            (subA + testA) * thresholdFull) /
          Real.sqrt (subA + testA))
      (slopeAFull := Real.sqrt (subA + testA))
      (interceptASub :=
        (priorPrecision * (thresholdSub - mean) + subA * thresholdSub) /
          Real.sqrt subA)
      (slopeASub := Real.sqrt subA)
      (interceptBFull :=
        (priorPrecision * (thresholdFull - mean) +
            (subB + testB) * thresholdFull) /
          Real.sqrt (subB + testB))
      (slopeBFull := Real.sqrt (subB + testB))
      (interceptBSub :=
        (priorPrecision * (thresholdSub - mean) + subB * thresholdSub) /
          Real.sqrt subB)
      (slopeBSub := Real.sqrt subB)
      (L_A_sub := L_A_sub) (L_A_full := L_A_full)
      (L_B_sub := L_B_sub) (L_B_full := L_B_full)
      (thresholdSub := thresholdSub) (thresholdFull := thresholdFull)
      hP_ne hslopeA hslopeB hfullSlope hsubSlope hslopeBSub_pos

/--
Theorem 2 validation check: the two high-skill directions cannot both be true.

The main statement says that, eventually, the individual-fairness gap is larger
under `P_sub`; Appendix D.4 proves the opposite eventual direction for the
same gap.  This theorem records the formal contradiction if both eventual
claims are imposed on one source surface.
-/
theorem paper_theorem2_eventual_high_skill_gap_directions_inconsistent
    {Group Policy : Type*}
    (S : GLM20SourcePolicySurface Group Policy) (Psub Pfull : Policy)
    {qhatMain qhatAppendix : ℝ}
    (hmain :
      ∀ q : ℝ, qhatMain < q →
        S.individualFairnessGap Psub q >
          S.individualFairnessGap Pfull q)
    (happendix :
      ∀ q : ℝ, qhatAppendix < q →
        S.individualFairnessGap Pfull q >
          S.individualFairnessGap Psub q) :
    False := by
  let q := max qhatMain qhatAppendix + 1
  have hq_main : qhatMain < q := by
    have hle : qhatMain ≤ max qhatMain qhatAppendix := le_max_left _ _
    dsimp [q]
    linarith
  have hq_appendix : qhatAppendix < q := by
    have hle : qhatAppendix ≤ max qhatMain qhatAppendix := le_max_right _ _
    dsimp [q]
    linarith
  have hmain_q := hmain q hq_main
  have happendix_q := happendix q hq_appendix
  linarith

/--
Theorem 2, direct standard-Gaussian no-barrier bundle.

This paper-facing endpoint removes the old opaque no-barrier certificate for
the currently formalized static part.  The one remaining hypothesis for part
(ii)'s high-skill statement is the paper's eventual delta comparison
`hdelta`; the theorem turns it into the displayed threshold `qhat ≥ max(qA,qB)`.
-/
theorem paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_surface
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) {Psub Pfull : Policy}
    {pi capacity quantile leftWeight priorPrecision subA subB testA testB : ℝ}
    {interceptAFull slopeAFull interceptASub slopeASub
      interceptBFull slopeBFull interceptBSub slopeBSub : ℝ}
    {L_A_sub L_A_full L_B_sub L_B_full : GaussianScaleLaw}
    {thresholdSub thresholdFull qDelta : ℝ}
    (hgroups : groupA ≠ groupB) (hP_ne : Psub ≠ Pfull)
    (hquantile_pos : 0 < quantile)
    (hleftWeight_pos : 0 < leftWeight)
    (htermSub_nonneg :
      0 ≤
        leftWeight *
            ((subA / (priorPrecision + subA)) /
              (subB / (priorPrecision + subB))) +
          pi)
    (htermFull_nonneg :
      0 ≤
        leftWeight *
            (((subA + testA) /
                (priorPrecision + subA + testA)) /
              ((subB + testB) /
                (priorPrecision + subB + testB))) +
          pi)
    (hprior_pos : 0 < priorPrecision)
    (hsubA_pos : 0 < subA) (hsubB_pos : 0 < subB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB)
    (hslopeA : slopeASub < slopeAFull)
    (hslopeB : slopeBSub < slopeBFull)
    (hdelta :
      ∀ q : ℝ, qDelta < q →
        standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q -
            standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q >
          standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q -
            standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hmean_sub : L_A_sub.mean = L_B_sub.mean)
    (hmean_A : L_A_sub.mean = L_A_full.mean)
    (hmean_B : L_B_sub.mean = L_B_full.mean)
    (hscale_A : L_A_sub.scale < L_A_full.scale)
    (hscale_B : L_B_sub.scale < L_B_full.scale)
    (hcapacity_sub :
      capacity =
        (1 - pi) * standardGaussianCDFAPI.thresholdPassProb L_A_sub thresholdSub +
          pi * standardGaussianCDFAPI.thresholdPassProb L_B_sub thresholdSub)
    (hcapacity_full :
      capacity =
        (1 - pi) * standardGaussianCDFAPI.thresholdPassProb L_A_full thresholdFull +
          pi * standardGaussianCDFAPI.thresholdPassProb L_B_full thresholdFull)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ)) :
    let S : GLM20SourcePolicySurface Group Policy :=
      theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
        pi capacity quantile leftWeight priorPrecision subA subB testA testB
        interceptAFull slopeAFull interceptASub slopeASub
        interceptBFull slopeBFull interceptBSub slopeBSub
        L_A_sub L_A_full L_B_sub L_B_full thresholdSub thresholdFull
    (S.diversity Psub > S.diversity Pfull ↔
      (subA * (priorPrecision + subA + testA)) /
          (subB * (priorPrecision + subB + testB)) <
        testA / testB) ∧
      (∃ qA qB : ℝ,
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q >
              standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q ↔
            qA < q) ∧
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q >
              standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q ↔
            qB < q) ∧
        ∃ qhat : ℝ, max qA qB ≤ qhat ∧
          ∀ q : ℝ, qhat < q →
            S.individualFairnessGap Pfull q >
              S.individualFairnessGap Psub q) ∧
      S.academicMerit groupA Psub < S.academicMerit groupA Pfull ∧
        S.academicMerit groupB Psub < S.academicMerit groupB Pfull := by
  dsimp only
  let S : GLM20SourcePolicySurface Group Policy :=
    theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
      pi capacity quantile leftWeight priorPrecision subA subB testA testB
      interceptAFull slopeAFull interceptASub slopeASub
      interceptBFull slopeBFull interceptBSub slopeBSub
      L_A_sub L_A_full L_B_sub L_B_full thresholdSub thresholdFull
  have hthreshold_lt :
      thresholdSub < thresholdFull :=
    paper_theorem2_admission_threshold_full_gt_sub_of_scale_increases
      standardGaussianCDFAPI hpi_pos hpi_lt_one hmean_sub hmean_A hmean_B
      hscale_A hscale_B hcapacity_sub hcapacity_full hcapacity_lt_half
  have hthreshold_le : thresholdSub ≤ thresholdFull := le_of_lt hthreshold_lt
  have hthreshold_B_sub : L_B_sub.mean < thresholdSub :=
