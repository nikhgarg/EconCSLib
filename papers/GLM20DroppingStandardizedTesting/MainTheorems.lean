    · intro hcost
      exact hobjective_merit.mpr (hmerit_cost.mpr hcost.1)
  have hJ2Cutoff :
      (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (fun g =>
            testCost g ≥ lowCostThreshold g ∧
              0 < lowCostThreshold g ∧
                lowCostThreshold g < highCostThreshold g ∧
                  q2Sub < fullFullCutoff g) := by
    have hcase :
        (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
          glm20ExactlyOneOfTwo groupA groupB
            (fun g =>
              (testCost g ≥ lowCostThreshold g ∧
                  0 < lowCostThreshold g ∧
                    lowCostThreshold g < highCostThreshold g) ∧
                q2Sub < fullFullCutoff g) :=
      paper_proposition5_part_ii_school2_cutoff_objective_iff_exactly_one_cost_case
        objective2 hnoneJ2 hbothJ2_impossible honlyA_J2 honlyB_J2
    exact hcase.trans
      (glm20ExactlyOneOfTwo_congr (by simp [and_assoc]) (by simp [and_assoc]))
  have hJ2 :
      (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3FullSubSchool2DropsCondition S policyPair
            Psub Pfull testCost lowCostThreshold highCostThreshold
            q1Sub q2Sub K) :=
    paper_proposition5_part_ii_school2_objective_iff_condition13_of_cutoff_cases
      S policyPair Psub Pfull api subEstimateLaw objective2
      hmassFullFullA hmassFullFullB hJ2Cutoff
  have hJ1CutoffA :
      (objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
        fullSubCutoff groupA < q1Sub ∨
