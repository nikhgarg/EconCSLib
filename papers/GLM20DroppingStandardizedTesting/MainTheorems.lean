          rw [hdensity_integral g]
          exact ENNReal.one_ne_top)
  have hreal_univ : ∀ g : Group, (jointLaw g).real Set.univ = 1 := by
    intro g
    simp [jointLaw, Measure.real, hdensity_integral g]
  have hcont :
      ∀ g : Group,
        Continuous
          (glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
            priorPrecision subPrecision testPrecision cost value g) := by
    intro g
    letI : IsFiniteMeasure (jointLaw g) := hfinite g
    let offset : ℝ :=
      glm20StrategicProjectedScale
        (priorPrecision g) (subPrecision g) (testPrecision g) *
        Q.quantile (1 - cost g / value)
    simpa [jointApplyAdmitMass, jointLaw,
        glm20Lemma3StrategicApplicantComponent, offset] using
      glm20MeasureApplyAdmitMass_continuous_diagonal_of_volume_density
        (density g) (populationShare g) offset
  have hanti :
      ∀ g : Group,
        StrictAnti
          (glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
            priorPrecision subPrecision testPrecision cost value g) := by
    intro g
    letI : IsFiniteMeasure (jointLaw g) := hfinite g
    let offset : ℝ :=
      glm20StrategicProjectedScale
        (priorPrecision g) (subPrecision g) (testPrecision g) *
        Q.quantile (1 - cost g / value)
    simpa [jointApplyAdmitMass, jointLaw,
        glm20Lemma3StrategicApplicantComponent, offset] using
      glm20MeasureApplyAdmitMass_strictAnti_diagonal_of_volume_density
        (density g) (hdensity g) (hdensity_ne_zero g)
        (populationShare := populationShare g) (offset := offset)
        (hpopulation g)
  have hatBot :
      ∀ g : Group,
        Filter.Tendsto
          (glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
            priorPrecision subPrecision testPrecision cost value g)
          Filter.atBot (nhds (populationShare g)) := by
    intro g
    letI : IsFiniteMeasure (jointLaw g) := hfinite g
    let offset : ℝ :=
      glm20StrategicProjectedScale
        (priorPrecision g) (subPrecision g) (testPrecision g) *
        Q.quantile (1 - cost g / value)
    have hlim :
        Filter.Tendsto
          (fun q : ℝ =>
            glm20MeasureApplyAdmitMass (populationShare g) (jointLaw g)
              (q - offset) q)
          Filter.atBot
          (nhds (populationShare g * (jointLaw g).real Set.univ)) :=
      glm20MeasureApplyAdmitMass_tendsto_atBot_diagonal
        (jointLaw g) (populationShare g) offset
    simpa [jointApplyAdmitMass, jointLaw,
        glm20Lemma3StrategicApplicantComponent, offset, hreal_univ g] using hlim
  have hatTop :
      ∀ g : Group,
        Filter.Tendsto
          (glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
            priorPrecision subPrecision testPrecision cost value g)
          Filter.atTop (nhds 0) := by
    intro g
    letI : IsFiniteMeasure (jointLaw g) := hfinite g
    let offset : ℝ :=
      glm20StrategicProjectedScale
        (priorPrecision g) (subPrecision g) (testPrecision g) *
        Q.quantile (1 - cost g / value)
    have hlim :
        Filter.Tendsto
          (fun q : ℝ =>
            glm20MeasureApplyAdmitMass (populationShare g) (jointLaw g)
              (q - offset) q)
          Filter.atTop (nhds 0) :=
      glm20MeasureApplyAdmitMass_tendsto_atTop_diagonal
        (jointLaw g) (populationShare g) offset
    simpa [jointApplyAdmitMass, jointLaw,
        glm20Lemma3StrategicApplicantComponent, offset] using hlim
  exact
    paper_lemma3_full_policy_threshold_equilibrium_existsUnique_of_strategic_applicant_components
      Q jointApplyAdmitMass
      (totalApplicantMass := populationShare)
      hcont hanti hatBot hatTop hcapacity hprior_pos hsub_pos htest_pos
      hvalue hcostRatio

/--
Continuity of the displayed bivariate application-and-admission mass along a
continuous pair of application/admission thresholds.

This discharges the topological part of the Lemma 3 bivariate component
obligation from a standard continuity premise for the bivariate normal CDF.
-/
theorem glm20BivariateApplyAdmitMass_continuous_along
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {populationShare sigmaTilde b mu : ℝ}
    {aOfApply qApply qAdmit : ℝ → ℝ}
    (ha : Continuous aOfApply)
    (hqApply : Continuous qApply)
    (hqAdmit : Continuous qAdmit)
    (hbivar :
      ∀ rho : ℝ,
        Continuous fun p : ℝ × ℝ => bivariateCDF p.1 p.2 rho) :
    Continuous fun z : ℝ =>
      glm20BivariateApplyAdmitMass api bivariateCDF populationShare
        sigmaTilde aOfApply b mu (qApply z) (qAdmit z) := by
  let denom : ℝ := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let rho : ℝ := -(sigmaTilde * b) / denom
  let A : ℝ → ℝ := fun z => (aOfApply (qApply z) + b * mu) / denom
  let B : ℝ → ℝ := fun z => (qAdmit z - mu) / sigmaTilde
  have hA : Continuous A := by
    dsimp [A]
    exact ((ha.comp hqApply).add continuous_const).div_const denom
  have hB : Continuous B := by
    dsimp [B]
    exact (hqAdmit.sub continuous_const).div_const sigmaTilde
  have hbivar_comp :
      Continuous fun z : ℝ => bivariateCDF (A z) (B z) rho :=
    (hbivar rho).comp (hA.prodMk hB)
  have hcore :
      Continuous fun z : ℝ =>
        glm20Proposition3SelectionCore api bivariateCDF sigmaTilde
          (aOfApply (qApply z)) b mu (qAdmit z) := by
    have hcdf : Continuous fun z : ℝ => api.cdf (A z) :=
      api.cdf_continuous.comp hA
    simpa [glm20Proposition3SelectionCore, A, B, denom, rho] using
      hcdf.sub hbivar_comp
  simpa [glm20BivariateApplyAdmitMass] using
    continuous_const.mul hcore

/--
Continuity of the displayed bivariate application-and-admission mass when the
needed bivariate-CDF continuity is supplied only at the paper's fixed
correlation parameter.
-/
theorem glm20BivariateApplyAdmitMass_continuous_along_of_rho_continuous
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {populationShare sigmaTilde b mu : ℝ}
    {aOfApply qApply qAdmit : ℝ → ℝ}
