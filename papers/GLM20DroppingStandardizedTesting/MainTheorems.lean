        ∀ q : ℝ, S.individualFairnessGap Psub q =
          standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q -
            standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q := by
          intro q
          simp [S, theorem2NoBarrierSourceSurface, hP_ne]
      exact
        paper_theorem2_exists_high_skill_threshold_individual_fairness_gap_full_gt_sub
          (qA := qA) (qB := qB) (qDelta := qDelta)
          hgapFull hgapSub hdelta
  · constructor
    · exact
        paper_theorem2_group_academic_merit_full_gt_sub_of_tail_mean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          (S := S) groupA hmean_A hscale_A hthreshold_A_sub hthreshold_le
