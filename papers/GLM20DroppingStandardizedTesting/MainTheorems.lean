/--
Theorem 3(iii)'s full/full equilibrium condition.

Paper statement: there exist functions `c_A, c_B : R_+ -> R_+` such that
`(P_full, P_full)` is an equilibrium iff
`c_A <= c_A(c_B)` and `c_B <= c_B(c_A)`.  We encode the codomain positivity
with explicit positivity predicates over positive real inputs.
-/
def glm20Theorem3FullFullCondition
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (Pfull : Policy) (groupA groupB : Group)
    (testCost : Group → ℝ) : Prop :=
  ∃ boundaryA boundaryB : ℝ → ℝ,
    (∀ x : ℝ, 0 < x → 0 < boundaryA x) ∧
      (∀ x : ℝ, 0 < x → 0 < boundaryB x) ∧
        (S.policyPairIsEquilibrium Pfull Pfull ↔
          testCost groupA ≤ boundaryA (testCost groupB) ∧
            testCost groupB ≤ boundaryB (testCost groupA))

/--
Theorem 3(iii)'s full/full equilibrium condition as a cost-family statement.

This version is closer to the paper's source proof: the boundary functions
characterize the full/full equilibrium region for every positive pair of group
test costs, not only for the currently fixed costs inside a single surface.
-/
def glm20Theorem3FullFullCostFamilyCondition
    {Group : Type*} (groupA groupB : Group)
    (equilibriumAtCost : (Group → ℝ) → Prop) : Prop :=
  ∃ boundaryA boundaryB : ℝ → ℝ,
    (∀ x : ℝ, 0 < x → 0 < boundaryA x) ∧
      (∀ x : ℝ, 0 < x → 0 < boundaryB x) ∧
        ∀ testCost : Group → ℝ,
          0 < testCost groupA →
            0 < testCost groupB →
              (equilibriumAtCost testCost ↔
                testCost groupA ≤ boundaryA (testCost groupB) ∧
                  testCost groupB ≤ boundaryB (testCost groupA))

/--
Theorem 3(iii) source proof composition.

If school `J1` keeps the test exactly on a two-sided boundary region and
school `J2` keeps the test exactly on another two-sided boundary region, then
the full/full equilibrium region is characterized by the pointwise minima of
the corresponding cost boundaries.
-/
theorem paper_theorem3_fullFull_cost_family_condition_of_two_school_keep_regions
    {Group : Type*} {groupA groupB : Group}
    {equilibriumAtCost school1Keeps school2Keeps : (Group → ℝ) → Prop}
    (boundary1A boundary1B boundary2A boundary2B : ℝ → ℝ)
    (hboundary1A_pos : ∀ x : ℝ, 0 < x → 0 < boundary1A x)
    (hboundary1B_pos : ∀ x : ℝ, 0 < x → 0 < boundary1B x)
    (hboundary2A_pos : ∀ x : ℝ, 0 < x → 0 < boundary2A x)
    (hboundary2B_pos : ∀ x : ℝ, 0 < x → 0 < boundary2B x)
    (hequilibrium :
      ∀ testCost : Group → ℝ,
        0 < testCost groupA →
          0 < testCost groupB →
            (equilibriumAtCost testCost ↔
              school1Keeps testCost ∧ school2Keeps testCost))
    (hschool1 :
      ∀ testCost : Group → ℝ,
        0 < testCost groupA →
          0 < testCost groupB →
            (school1Keeps testCost ↔
              testCost groupA ≤ boundary1A (testCost groupB) ∧
                testCost groupB ≤ boundary1B (testCost groupA)))
    (hschool2 :
      ∀ testCost : Group → ℝ,
        0 < testCost groupA →
          0 < testCost groupB →
            (school2Keeps testCost ↔
              testCost groupA ≤ boundary2A (testCost groupB) ∧
                testCost groupB ≤ boundary2B (testCost groupA))) :
    glm20Theorem3FullFullCostFamilyCondition groupA groupB equilibriumAtCost := by
  refine
    ⟨fun x => min (boundary1A x) (boundary2A x),
      fun x => min (boundary1B x) (boundary2B x), ?_, ?_, ?_⟩
  · intro x hx
    exact lt_min (hboundary1A_pos x hx) (hboundary2A_pos x hx)
  · intro x hx
    exact lt_min (hboundary1B_pos x hx) (hboundary2B_pos x hx)
  · intro testCost hcostA hcostB
    constructor
    · intro heq
      have hkeeps := (hequilibrium testCost hcostA hcostB).mp heq
      have hkeep1 := (hschool1 testCost hcostA hcostB).mp hkeeps.1
      have hkeep2 := (hschool2 testCost hcostA hcostB).mp hkeeps.2
      exact ⟨le_min hkeep1.1 hkeep2.1, le_min hkeep1.2 hkeep2.2⟩
    · rintro ⟨hcostA_bound, hcostB_bound⟩
      have hkeep1 :
          school1Keeps testCost :=
        (hschool1 testCost hcostA hcostB).mpr
          ⟨le_trans hcostA_bound (min_le_left _ _),
            le_trans hcostB_bound (min_le_left _ _)⟩
      have hkeep2 :
          school2Keeps testCost :=
        (hschool2 testCost hcostA hcostB).mpr
          ⟨le_trans hcostA_bound (min_le_right _ _),
            le_trans hcostB_bound (min_le_right _ _)⟩
      exact (hequilibrium testCost hcostA hcostB).mpr ⟨hkeep1, hkeep2⟩

/--
Theorem 3(iii) binary-objective specialization.

For a cost-parametric binary two-school game, the full/full policy pair is an
equilibrium exactly when school `J1` does not profit by switching to `P_sub`
and school `J2` does not profit by switching to `P_sub`.  If those two
keep-test regions each have the source proof's two-sided boundary form, then
the full/full equilibrium region has the paper's boundary functions.
-/
theorem paper_theorem3_fullFull_cost_family_condition_of_binary_objective_keep_regions
    {Group Policy : Type*} {groupA groupB : Group} {Psub Pfull : Policy}
    (objective1 objective2 : (Group → ℝ) → Policy → Policy → ℝ)
    (boundary1A boundary1B boundary2A boundary2B : ℝ → ℝ)
    (hboundary1A_pos : ∀ x : ℝ, 0 < x → 0 < boundary1A x)
    (hboundary1B_pos : ∀ x : ℝ, 0 < x → 0 < boundary1B x)
    (hboundary2A_pos : ∀ x : ℝ, 0 < x → 0 < boundary2A x)
    (hboundary2B_pos : ∀ x : ℝ, 0 < x → 0 < boundary2B x)
    (hschool1 :
      ∀ testCost : Group → ℝ,
        0 < testCost groupA →
          0 < testCost groupB →
            (objective1 testCost Psub Pfull ≤
                objective1 testCost Pfull Pfull ↔
              testCost groupA ≤ boundary1A (testCost groupB) ∧
                testCost groupB ≤ boundary1B (testCost groupA)))
    (hschool2 :
      ∀ testCost : Group → ℝ,
        0 < testCost groupA →
          0 < testCost groupB →
            (objective2 testCost Pfull Psub ≤
                objective2 testCost Pfull Pfull ↔
              testCost groupA ≤ boundary2A (testCost groupB) ∧
                testCost groupB ≤ boundary2B (testCost groupA))) :
    glm20Theorem3FullFullCostFamilyCondition groupA groupB
      (fun testCost =>
        glm20TwoSchoolBinaryPolicyEquilibrium (objective1 testCost)
          (objective2 testCost) Psub Pfull Pfull Pfull) :=
    paper_theorem3_fullFull_cost_family_condition_of_two_school_keep_regions
      (boundary1A := boundary1A) (boundary1B := boundary1B)
      (boundary2A := boundary2A) (boundary2B := boundary2B)
      hboundary1A_pos hboundary1B_pos hboundary2A_pos hboundary2B_pos
      (by
        intro testCost _hcostA _hcostB
        exact
          glm20TwoSchoolBinaryPolicyEquilibrium_fullFull_iff
            (objective1 testCost) (objective2 testCost) Psub Pfull)
      hschool1 hschool2

/--
Convert a cost-family full/full characterization into the fixed-cost
condition used by the source-shaped Theorem 3 wrapper.
-/
theorem paper_theorem3_fullFull_condition_of_cost_family_condition
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {Pfull : Policy} {groupA groupB : Group} {testCost : Group → ℝ}
    {equilibriumAtCost : (Group → ℝ) → Prop}
    (hfamily :
      glm20Theorem3FullFullCostFamilyCondition groupA groupB
        equilibriumAtCost)
    (hfixed :
      S.policyPairIsEquilibrium Pfull Pfull ↔ equilibriumAtCost testCost)
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    glm20Theorem3FullFullCondition S Pfull groupA groupB testCost := by
  rcases hfamily with
    ⟨boundaryA, boundaryB, hboundaryA_pos, hboundaryB_pos, hiff⟩
  exact
    ⟨boundaryA, boundaryB, hboundaryA_pos, hboundaryB_pos,
      hfixed.trans (hiff testCost hcostA hcostB)⟩

/--
Theorem 3(iii) fixed-cost bridge for the paper's weighted binary surface.

If a cost-parametric binary objective family has the source boundary
characterization, and at the realized costs its two objectives are exactly the
weighted academic-merit objectives of the paper surface, then the fixed
`(P_full,P_full)` policy pair satisfies the paper's full/full condition.
-/
theorem paper_theorem3_fullFull_condition_of_binary_objective_cost_family_at_weighted_surface
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost : Group → ℝ}
    (objective1 objective2 : (Group → ℝ) → Policy → Policy → ℝ)
    (hS :
      S =
        glm20WeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2
          groupA groupB populationShare)
    (hfamily :
      glm20Theorem3FullFullCostFamilyCondition groupA groupB
        (fun cost =>
          glm20TwoSchoolBinaryPolicyEquilibrium (objective1 cost)
            (objective2 cost) Psub Pfull Pfull Pfull))
    (hobjective1 :
      ∀ P1 P2 : Policy,
        objective1 testCost P1 P2 =
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare P1 P2)
    (hobjective2 :
      ∀ P1 P2 : Policy,
        objective2 testCost P1 P2 =
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare P1 P2)
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    glm20Theorem3FullFullCondition S Pfull groupA groupB testCost := by
  refine
    paper_theorem3_fullFull_condition_of_cost_family_condition
      (S := S) (Pfull := Pfull) (groupA := groupA) (groupB := groupB)
      (testCost := testCost) hfamily ?_ hcostA hcostB
  subst S
  have hobj1 :
      objective1 testCost =
        glm20TwoGroupWeightedAcademicMeritObjective
          (glm20WeightedAcademicMeritBinaryPolicySurface massTestTaking
            admittedAcademicMerit diversity policyPair Psub Pfull J1 J2
            groupA groupB populationShare)
          policyPair J1 groupA groupB populationShare := by
    funext P1 P2
    exact hobjective1 P1 P2
  have hobj2 :
      objective2 testCost =
        glm20TwoGroupWeightedAcademicMeritObjective
          (glm20WeightedAcademicMeritBinaryPolicySurface massTestTaking
            admittedAcademicMerit diversity policyPair Psub Pfull J1 J2
            groupA groupB populationShare)
          policyPair J2 groupA groupB populationShare := by
    funext P1 P2
    exact hobjective2 P1 P2
  rw [glm20WeightedAcademicMeritBinaryPolicySurface_policyPairIsEquilibrium_iff]
  constructor
  · intro h
    simpa [hobj1, hobj2] using h
  · intro h
    simpa [hobj1, hobj2] using h

/--
Theorem 3(iii) direct weighted-surface endpoint from binary keep-region
boundary functions.

This composes the binary-objective cost-family theorem with the fixed-cost
weighted-surface bridge, so the concrete strategic model only has to prove the
two school-specific full/full keep inequalities have the paper's boundary
forms.
-/
theorem paper_theorem3_fullFull_condition_of_binary_objective_keep_regions_at_weighted_surface
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost : Group → ℝ}
    (objective1 objective2 : (Group → ℝ) → Policy → Policy → ℝ)
    (boundary1A boundary1B boundary2A boundary2B : ℝ → ℝ)
    (hS :
      S =
        glm20WeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2
          groupA groupB populationShare)
    (hboundary1A_pos : ∀ x : ℝ, 0 < x → 0 < boundary1A x)
    (hboundary1B_pos : ∀ x : ℝ, 0 < x → 0 < boundary1B x)
    (hboundary2A_pos : ∀ x : ℝ, 0 < x → 0 < boundary2A x)
    (hboundary2B_pos : ∀ x : ℝ, 0 < x → 0 < boundary2B x)
    (hschool1 :
      ∀ cost : Group → ℝ,
        0 < cost groupA →
          0 < cost groupB →
            (objective1 cost Psub Pfull ≤ objective1 cost Pfull Pfull ↔
              cost groupA ≤ boundary1A (cost groupB) ∧
                cost groupB ≤ boundary1B (cost groupA)))
    (hschool2 :
      ∀ cost : Group → ℝ,
        0 < cost groupA →
          0 < cost groupB →
            (objective2 cost Pfull Psub ≤ objective2 cost Pfull Pfull ↔
              cost groupA ≤ boundary2A (cost groupB) ∧
                cost groupB ≤ boundary2B (cost groupA)))
    (hobjective1 :
      ∀ P1 P2 : Policy,
        objective1 testCost P1 P2 =
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare P1 P2)
    (hobjective2 :
      ∀ P1 P2 : Policy,
        objective2 testCost P1 P2 =
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare P1 P2)
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    glm20Theorem3FullFullCondition S Pfull groupA groupB testCost := by
  have hfamily :
      glm20Theorem3FullFullCostFamilyCondition groupA groupB
        (fun cost =>
          glm20TwoSchoolBinaryPolicyEquilibrium (objective1 cost)
            (objective2 cost) Psub Pfull Pfull Pfull) :=
    paper_theorem3_fullFull_cost_family_condition_of_binary_objective_keep_regions
      objective1 objective2 boundary1A boundary1B boundary2A boundary2B
      hboundary1A_pos hboundary1B_pos hboundary2A_pos hboundary2B_pos
      hschool1 hschool2
  exact
    paper_theorem3_fullFull_condition_of_binary_objective_cost_family_at_weighted_surface
      objective1 objective2 hS hfamily hobjective1 hobjective2 hcostA hcostB

/--
Theorem 3(iii) as an existential boundary-function statement.

The source statement only asserts that there exist positive functions
`c_A, c_B : R_+ -> R_+` whose threshold inequalities characterize the
`(P_full,P_full)` equilibrium.  At this level of abstraction, positive group
test costs alone are enough to build such boundary functions: if
`(P_full,P_full)` is an equilibrium, choose generous constant boundaries; if it
is not, choose a positive boundary below group A's current cost.
-/
theorem paper_theorem3_fullFull_condition_exists_boundary_functions_of_positive_costs
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (Pfull : Policy) (groupA groupB : Group) (testCost : Group → ℝ)
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    glm20Theorem3FullFullCondition S Pfull groupA groupB testCost := by
  by_cases heq : S.policyPairIsEquilibrium Pfull Pfull
  · refine ⟨fun _ => testCost groupA + 1,
      fun _ => testCost groupB + 1, ?_, ?_, ?_⟩
    · intro _ _
      linarith
    · intro _ _
      linarith
    · constructor
      · intro _
        constructor <;> linarith
      · intro _
        exact heq
  · refine ⟨fun _ => testCost groupA / 2,
      fun _ => testCost groupB / 2, ?_, ?_, ?_⟩
    · intro _ _
      linarith
    · intro _ _
      linarith
    · constructor
      · intro h
        exact False.elim (heq h)
      · intro hbounds
        exfalso
        have hA : testCost groupA ≤ testCost groupA / 2 := hbounds.1
        nlinarith [hcostA]

/--
Paper-facing Theorem 3 certificate with the actual displayed conditions
(10)--(14), rather than opaque proposition fields.
-/
structure GLM20Theorem3AcademicMeritSourceCertificate
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J2 : School) (groupA groupB : Group)
    (populationShare testCost subFullCostThreshold
      fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ)
    (capacity2 q1Sub q2Sub : ℝ) (K : Group → ℝ → ℝ) where
  subFullEquilibrium_iff :
    S.policyPairIsEquilibrium Psub Pfull ↔
      glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
        groupA groupB populationShare testCost subFullCostThreshold
        capacity2 q1Sub K
  fullSubEquilibrium_iff :
    S.policyPairIsEquilibrium Pfull Psub ↔
      glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
        testCost fullSubLowCostThreshold fullSubHighCostThreshold
        q1Sub q2Sub K
  fullFullEquilibrium_conditions :
    glm20Theorem3FullFullCondition S Pfull groupA groupB testCost

/--
Paper Theorem 3, source-shaped version.

This theorem exposes the displayed `(P_sub,P_full)`, `(P_full,P_sub)`, and
`(P_full,P_full)` conditions in the order of the paper.  The remaining
strategic fixed-point work is exactly the certificate proving that the concrete
two-school Gaussian game satisfies these source-shaped conditions.
-/
theorem paper_theorem3_two_school_academic_merit_source_conditions
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost subFullCostThreshold
      fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    (C : GLM20Theorem3AcademicMeritSourceCertificate S policyPair Psub Pfull
      J2 groupA groupB populationShare testCost subFullCostThreshold
      fullSubLowCostThreshold fullSubHighCostThreshold capacity2 q1Sub q2Sub K) :
    (S.policyPairIsEquilibrium Psub Pfull ↔
      glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
        groupA groupB populationShare testCost subFullCostThreshold
        capacity2 q1Sub K) ∧
      (S.policyPairIsEquilibrium Pfull Psub ↔
        glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
          testCost fullSubLowCostThreshold fullSubHighCostThreshold
          q1Sub q2Sub K) ∧
        glm20Theorem3FullFullCondition S Pfull groupA groupB testCost :=
   ⟨C.subFullEquilibrium_iff, C.fullSubEquilibrium_iff,
    C.fullFullEquilibrium_conditions⟩

/--
Paper Theorem 3 source-shaped endpoint with part (iii) discharged from the
positive-cost theorem.

This leaves only the substantive policy-pair equivalences in parts (i) and
(ii) as premises.
-/
theorem paper_theorem3_two_school_academic_merit_source_conditions_of_i_ii_and_positive_costs
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost subFullCostThreshold
      fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    (hsubFull :
      S.policyPairIsEquilibrium Psub Pfull ↔
        glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
          groupA groupB populationShare testCost subFullCostThreshold
          capacity2 q1Sub K)
    (hfullSub :
      S.policyPairIsEquilibrium Pfull Psub ↔
        glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
          testCost fullSubLowCostThreshold fullSubHighCostThreshold
          q1Sub q2Sub K)
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    (S.policyPairIsEquilibrium Psub Pfull ↔
      glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
        groupA groupB populationShare testCost subFullCostThreshold
        capacity2 q1Sub K) ∧
      (S.policyPairIsEquilibrium Pfull Psub ↔
        glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
          testCost fullSubLowCostThreshold fullSubHighCostThreshold
          q1Sub q2Sub K) ∧
        glm20Theorem3FullFullCondition S Pfull groupA groupB testCost :=
   ⟨hsubFull, hfullSub,
    paper_theorem3_fullFull_condition_exists_boundary_functions_of_positive_costs
      S Pfull groupA groupB testCost hcostA hcostB⟩

/--
Paper Theorem 3 source-shaped endpoint from completed threshold endpoints for
parts (i) and (ii).

This is the composition surface used after Proposition 5 has already produced
the sub-full threshold, the full-sub low/high thresholds, and the two
policy-equilibrium iff statements.
-/
theorem paper_theorem3_source_conditions_of_threshold_equilibrium_endpoints
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    (subFullTestBasedMerit : Group → ℝ → ℝ)
    (subFullTestFreeMerit : Group → ℝ)
    (fullSubLowTestBasedMerit : Group → ℝ → ℝ)
    (fullSubLowTestFreeMerit : Group → ℝ)
    (fullSubHighTestBasedMerit : Group → ℝ → ℝ)
    (fullSubHighTestFreeMerit : Group → ℝ)
    (hsubFull :
      ∃ subFullCostThreshold : Group → ℝ,
        (∀ g, subFullCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
          (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
            subFullTestFreeMerit g) ∧
            (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
              (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
                subFullCostThreshold g ≤ c)) ∧
              (S.policyPairIsEquilibrium Psub Pfull ↔
                glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
                  groupA groupB populationShare testCost subFullCostThreshold
                  capacity2 q1Sub K))
    (hfullSub :
      ∃ fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ,
        (∀ g, fullSubLowCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
          (∀ g, fullSubHighCostThreshold g ∈
            Set.Ioo (0 : ℝ) (maxCost g)) ∧
            (∀ g, fullSubLowTestBasedMerit g
                (fullSubLowCostThreshold g) =
              fullSubLowTestFreeMerit g) ∧
              (∀ g, fullSubHighTestBasedMerit g
                  (fullSubHighCostThreshold g) =
                fullSubHighTestFreeMerit g) ∧
                (∀ g, fullSubLowCostThreshold g <
                  fullSubHighCostThreshold g) ∧
                  (S.policyPairIsEquilibrium Pfull Psub ↔
                    glm20Theorem3FullSubCondition S policyPair Psub Pfull
                      groupA groupB testCost fullSubLowCostThreshold
                      fullSubHighCostThreshold q1Sub q2Sub K))
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    ∃ subFullCostThreshold fullSubLowCostThreshold
        fullSubHighCostThreshold : Group → ℝ,
      (∀ g, subFullCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
          subFullTestFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
              subFullCostThreshold g ≤ c)) ∧
            (∀ g, fullSubLowCostThreshold g ∈
              Set.Ioo (0 : ℝ) (maxCost g)) ∧
              (∀ g, fullSubHighCostThreshold g ∈
                Set.Ioo (0 : ℝ) (maxCost g)) ∧
                (∀ g, fullSubLowTestBasedMerit g
                    (fullSubLowCostThreshold g) =
                  fullSubLowTestFreeMerit g) ∧
                  (∀ g, fullSubHighTestBasedMerit g
                      (fullSubHighCostThreshold g) =
                    fullSubHighTestFreeMerit g) ∧
                    (∀ g,
                      fullSubLowCostThreshold g <
                        fullSubHighCostThreshold g) ∧
                      ((S.policyPairIsEquilibrium Psub Pfull ↔
                          glm20Theorem3SubFullCondition S policyPair
                            Psub Pfull J2 groupA groupB populationShare
                            testCost subFullCostThreshold capacity2 q1Sub K) ∧
                        (S.policyPairIsEquilibrium Pfull Psub ↔
                          glm20Theorem3FullSubCondition S policyPair Psub
                            Pfull groupA groupB testCost
                            fullSubLowCostThreshold fullSubHighCostThreshold
                            q1Sub q2Sub K) ∧
                          glm20Theorem3FullFullCondition S Pfull groupA
                            groupB testCost) := by
  rcases hsubFull with
    ⟨subFullCostThreshold, hsubFullMem, hsubFullEq, hsubFullLe,
      hsubFullIff⟩
  rcases hfullSub with
    ⟨fullSubLowCostThreshold, fullSubHighCostThreshold, hlowMem, hhighMem,
      hlowEq, hhighEq, hlowHigh, hfullSubIff⟩
  have hsource :
      (S.policyPairIsEquilibrium Psub Pfull ↔
        glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
          groupA groupB populationShare testCost subFullCostThreshold
          capacity2 q1Sub K) ∧
        (S.policyPairIsEquilibrium Pfull Psub ↔
          glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
            testCost fullSubLowCostThreshold fullSubHighCostThreshold
            q1Sub q2Sub K) ∧
          glm20Theorem3FullFullCondition S Pfull groupA groupB testCost :=
    paper_theorem3_two_school_academic_merit_source_conditions_of_i_ii_and_positive_costs
      hsubFullIff hfullSubIff hcostA hcostB
  exact
    ⟨subFullCostThreshold, fullSubLowCostThreshold, fullSubHighCostThreshold,
      hsubFullMem, hsubFullEq, hsubFullLe, hlowMem, hhighMem, hlowEq,
      hhighEq, hlowHigh, hsource⟩

/--
Paper Theorem 3 source-shaped endpoint from completed threshold endpoints,
with the full-sub cost thresholds constructed on a positive interior interval.

The sub-full branch remains on the paper's existing `[0,maxCost]` cost domain.
The full-sub branch is stated on `Set.Icc (fullSubLeftCost g)
(fullSubRightCost g)`, which is the form needed by the equation-(50)
inverse-CDF route.
-/
theorem
    paper_theorem3_source_conditions_of_threshold_equilibrium_endpoints_fullSub_interval
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost fullSubLeftCost
      fullSubRightCost : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    (subFullTestBasedMerit : Group → ℝ → ℝ)
    (subFullTestFreeMerit : Group → ℝ)
    (fullSubLowTestBasedMerit : Group → ℝ → ℝ)
    (fullSubLowTestFreeMerit : Group → ℝ)
    (fullSubHighTestBasedMerit : Group → ℝ → ℝ)
    (fullSubHighTestFreeMerit : Group → ℝ)
    (hsubFull :
      ∃ subFullCostThreshold : Group → ℝ,
        (∀ g, subFullCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
          (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
            subFullTestFreeMerit g) ∧
            (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
              (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
                subFullCostThreshold g ≤ c)) ∧
              (S.policyPairIsEquilibrium Psub Pfull ↔
                glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
                  groupA groupB populationShare testCost subFullCostThreshold
                  capacity2 q1Sub K))
    (hfullSub :
      ∃ fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ,
        (∀ g, fullSubLowCostThreshold g ∈
          Set.Ioo (fullSubLeftCost g) (fullSubRightCost g)) ∧
          (∀ g, fullSubHighCostThreshold g ∈
            Set.Ioo (fullSubLeftCost g) (fullSubRightCost g)) ∧
            (∀ g, fullSubLowTestBasedMerit g
                (fullSubLowCostThreshold g) =
              fullSubLowTestFreeMerit g) ∧
              (∀ g, fullSubHighTestBasedMerit g
                  (fullSubHighCostThreshold g) =
                fullSubHighTestFreeMerit g) ∧
                (∀ g, 0 < fullSubLowCostThreshold g) ∧
                  (∀ g, fullSubLowCostThreshold g <
                    fullSubHighCostThreshold g) ∧
                    (S.policyPairIsEquilibrium Pfull Psub ↔
                      glm20Theorem3FullSubCondition S policyPair Psub Pfull
                        groupA groupB testCost fullSubLowCostThreshold
                        fullSubHighCostThreshold q1Sub q2Sub K))
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    ∃ subFullCostThreshold fullSubLowCostThreshold
        fullSubHighCostThreshold : Group → ℝ,
      (∀ g, subFullCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
          subFullTestFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
              subFullCostThreshold g ≤ c)) ∧
            (∀ g, fullSubLowCostThreshold g ∈
              Set.Ioo (fullSubLeftCost g) (fullSubRightCost g)) ∧
              (∀ g, fullSubHighCostThreshold g ∈
                Set.Ioo (fullSubLeftCost g) (fullSubRightCost g)) ∧
                (∀ g, fullSubLowTestBasedMerit g
                    (fullSubLowCostThreshold g) =
                  fullSubLowTestFreeMerit g) ∧
                  (∀ g, fullSubHighTestBasedMerit g
                      (fullSubHighCostThreshold g) =
                    fullSubHighTestFreeMerit g) ∧
                    (∀ g, 0 < fullSubLowCostThreshold g) ∧
                      (∀ g,
                        fullSubLowCostThreshold g <
                          fullSubHighCostThreshold g) ∧
                        ((S.policyPairIsEquilibrium Psub Pfull ↔
                            glm20Theorem3SubFullCondition S policyPair
                              Psub Pfull J2 groupA groupB populationShare
                              testCost subFullCostThreshold capacity2 q1Sub
                              K) ∧
                          (S.policyPairIsEquilibrium Pfull Psub ↔
                            glm20Theorem3FullSubCondition S policyPair Psub
                              Pfull groupA groupB testCost
                              fullSubLowCostThreshold fullSubHighCostThreshold
                              q1Sub q2Sub K) ∧
                            glm20Theorem3FullFullCondition S Pfull groupA
                              groupB testCost) := by
  rcases hsubFull with
    ⟨subFullCostThreshold, hsubFullMem, hsubFullEq, hsubFullLe,
      hsubFullIff⟩
  rcases hfullSub with
    ⟨fullSubLowCostThreshold, fullSubHighCostThreshold, hlowMem, hhighMem,
      hlowEq, hhighEq, hlowPos, hlowHigh, hfullSubIff⟩
  have hsource :
      (S.policyPairIsEquilibrium Psub Pfull ↔
        glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
          groupA groupB populationShare testCost subFullCostThreshold
          capacity2 q1Sub K) ∧
        (S.policyPairIsEquilibrium Pfull Psub ↔
          glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
            testCost fullSubLowCostThreshold fullSubHighCostThreshold
            q1Sub q2Sub K) ∧
          glm20Theorem3FullFullCondition S Pfull groupA groupB testCost :=
    paper_theorem3_two_school_academic_merit_source_conditions_of_i_ii_and_positive_costs
      hsubFullIff hfullSubIff hcostA hcostB
  exact
    ⟨subFullCostThreshold, fullSubLowCostThreshold, fullSubHighCostThreshold,
      hsubFullMem, hsubFullEq, hsubFullLe, hlowMem, hhighMem, hlowEq,
      hhighEq, hlowPos, hlowHigh, hsource⟩

/--
Paper Theorem 3 source-shaped endpoint from completed threshold endpoints,
with both the sub-full and full-sub cost thresholds constructed on positive
interior intervals.

This is the source-Gaussian-friendly packaging surface: both branches may use
inverse-CDF formulas whose regularity is available on
`Set.Icc (leftCost g) (rightCost g)` rather than at the zero boundary.
-/
theorem
    paper_theorem3_source_conditions_of_threshold_equilibrium_endpoints_subFull_fullSub_interval
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost subFullLeftCost subFullRightCost
      fullSubLeftCost fullSubRightCost : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    (subFullTestBasedMerit : Group → ℝ → ℝ)
    (subFullTestFreeMerit : Group → ℝ)
    (fullSubLowTestBasedMerit : Group → ℝ → ℝ)
    (fullSubLowTestFreeMerit : Group → ℝ)
    (fullSubHighTestBasedMerit : Group → ℝ → ℝ)
    (fullSubHighTestFreeMerit : Group → ℝ)
    (hsubFull :
      ∃ subFullCostThreshold : Group → ℝ,
        (∀ g, subFullCostThreshold g ∈
          Set.Ioo (subFullLeftCost g) (subFullRightCost g)) ∧
          (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
            subFullTestFreeMerit g) ∧
            (∀ g c, c ∈
              Set.Icc (subFullLeftCost g) (subFullRightCost g) →
              (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
                subFullCostThreshold g ≤ c)) ∧
              (S.policyPairIsEquilibrium Psub Pfull ↔
                glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
                  groupA groupB populationShare testCost subFullCostThreshold
                  capacity2 q1Sub K))
    (hfullSub :
      ∃ fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ,
        (∀ g, fullSubLowCostThreshold g ∈
          Set.Ioo (fullSubLeftCost g) (fullSubRightCost g)) ∧
          (∀ g, fullSubHighCostThreshold g ∈
            Set.Ioo (fullSubLeftCost g) (fullSubRightCost g)) ∧
            (∀ g, fullSubLowTestBasedMerit g
                (fullSubLowCostThreshold g) =
              fullSubLowTestFreeMerit g) ∧
              (∀ g, fullSubHighTestBasedMerit g
                  (fullSubHighCostThreshold g) =
                fullSubHighTestFreeMerit g) ∧
                (∀ g, 0 < fullSubLowCostThreshold g) ∧
                  (∀ g, fullSubLowCostThreshold g <
                    fullSubHighCostThreshold g) ∧
                    (S.policyPairIsEquilibrium Pfull Psub ↔
                      glm20Theorem3FullSubCondition S policyPair Psub Pfull
                        groupA groupB testCost fullSubLowCostThreshold
                        fullSubHighCostThreshold q1Sub q2Sub K))
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    ∃ subFullCostThreshold fullSubLowCostThreshold
        fullSubHighCostThreshold : Group → ℝ,
      (∀ g, subFullCostThreshold g ∈
        Set.Ioo (subFullLeftCost g) (subFullRightCost g)) ∧
        (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
          subFullTestFreeMerit g) ∧
          (∀ g c, c ∈
            Set.Icc (subFullLeftCost g) (subFullRightCost g) →
            (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
              subFullCostThreshold g ≤ c)) ∧
            (∀ g, fullSubLowCostThreshold g ∈
              Set.Ioo (fullSubLeftCost g) (fullSubRightCost g)) ∧
              (∀ g, fullSubHighCostThreshold g ∈
                Set.Ioo (fullSubLeftCost g) (fullSubRightCost g)) ∧
                (∀ g, fullSubLowTestBasedMerit g
                    (fullSubLowCostThreshold g) =
                  fullSubLowTestFreeMerit g) ∧
                  (∀ g, fullSubHighTestBasedMerit g
                      (fullSubHighCostThreshold g) =
                    fullSubHighTestFreeMerit g) ∧
                    (∀ g, 0 < fullSubLowCostThreshold g) ∧
                      (∀ g,
                        fullSubLowCostThreshold g <
                          fullSubHighCostThreshold g) ∧
                        ((S.policyPairIsEquilibrium Psub Pfull ↔
                            glm20Theorem3SubFullCondition S policyPair
                              Psub Pfull J2 groupA groupB populationShare
                              testCost subFullCostThreshold capacity2 q1Sub
                              K) ∧
                          (S.policyPairIsEquilibrium Pfull Psub ↔
                            glm20Theorem3FullSubCondition S policyPair Psub
                              Pfull groupA groupB testCost
                              fullSubLowCostThreshold fullSubHighCostThreshold
                              q1Sub q2Sub K) ∧
                            glm20Theorem3FullFullCondition S Pfull groupA
                              groupB testCost) := by
  rcases hsubFull with
    ⟨subFullCostThreshold, hsubFullMem, hsubFullEq, hsubFullLe,
      hsubFullIff⟩
  rcases hfullSub with
    ⟨fullSubLowCostThreshold, fullSubHighCostThreshold, hlowMem, hhighMem,
      hlowEq, hhighEq, hlowPos, hlowHigh, hfullSubIff⟩
  have hsource :
      (S.policyPairIsEquilibrium Psub Pfull ↔
        glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
          groupA groupB populationShare testCost subFullCostThreshold
          capacity2 q1Sub K) ∧
        (S.policyPairIsEquilibrium Pfull Psub ↔
          glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
            testCost fullSubLowCostThreshold fullSubHighCostThreshold
            q1Sub q2Sub K) ∧
          glm20Theorem3FullFullCondition S Pfull groupA groupB testCost :=
    paper_theorem3_two_school_academic_merit_source_conditions_of_i_ii_and_positive_costs
      hsubFullIff hfullSubIff hcostA hcostB
  exact
    ⟨subFullCostThreshold, fullSubLowCostThreshold, fullSubHighCostThreshold,
      hsubFullMem, hsubFullEq, hsubFullLe, hlowMem, hhighMem, hlowEq,
      hhighEq, hlowPos, hlowHigh, hsource⟩

/--
Paper Theorem 3 source-shaped endpoint from completed threshold endpoints, with
part (iii) supplied by the source proof's full/full cost-family boundary
condition.

Compared with `paper_theorem3_source_conditions_of_threshold_equilibrium_endpoints`,
this does not use the fixed-cost positive-cost shortcut for the full/full case.
-/
theorem
    paper_theorem3_source_conditions_of_threshold_equilibrium_endpoints_of_fullFull_cost_family
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    {equilibriumAtCost : (Group → ℝ) → Prop}
    (subFullTestBasedMerit : Group → ℝ → ℝ)
    (subFullTestFreeMerit : Group → ℝ)
    (fullSubLowTestBasedMerit : Group → ℝ → ℝ)
    (fullSubLowTestFreeMerit : Group → ℝ)
    (fullSubHighTestBasedMerit : Group → ℝ → ℝ)
    (fullSubHighTestFreeMerit : Group → ℝ)
    (hsubFull :
      ∃ subFullCostThreshold : Group → ℝ,
        (∀ g, subFullCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
          (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
            subFullTestFreeMerit g) ∧
            (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
              (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
                subFullCostThreshold g ≤ c)) ∧
              (S.policyPairIsEquilibrium Psub Pfull ↔
                glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
                  groupA groupB populationShare testCost subFullCostThreshold
                  capacity2 q1Sub K))
    (hfullSub :
      ∃ fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ,
        (∀ g, fullSubLowCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
          (∀ g, fullSubHighCostThreshold g ∈
            Set.Ioo (0 : ℝ) (maxCost g)) ∧
            (∀ g, fullSubLowTestBasedMerit g
                (fullSubLowCostThreshold g) =
              fullSubLowTestFreeMerit g) ∧
              (∀ g, fullSubHighTestBasedMerit g
                  (fullSubHighCostThreshold g) =
                fullSubHighTestFreeMerit g) ∧
                (∀ g, fullSubLowCostThreshold g <
                  fullSubHighCostThreshold g) ∧
                  (S.policyPairIsEquilibrium Pfull Psub ↔
                    glm20Theorem3FullSubCondition S policyPair Psub Pfull
                      groupA groupB testCost fullSubLowCostThreshold
                      fullSubHighCostThreshold q1Sub q2Sub K))
    (hfamily :
      glm20Theorem3FullFullCostFamilyCondition groupA groupB
        equilibriumAtCost)
    (hfixed :
      S.policyPairIsEquilibrium Pfull Pfull ↔ equilibriumAtCost testCost)
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    ∃ subFullCostThreshold fullSubLowCostThreshold
        fullSubHighCostThreshold : Group → ℝ,
      (∀ g, subFullCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
          subFullTestFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
              subFullCostThreshold g ≤ c)) ∧
            (∀ g, fullSubLowCostThreshold g ∈
              Set.Ioo (0 : ℝ) (maxCost g)) ∧
              (∀ g, fullSubHighCostThreshold g ∈
                Set.Ioo (0 : ℝ) (maxCost g)) ∧
                (∀ g, fullSubLowTestBasedMerit g
                    (fullSubLowCostThreshold g) =
                  fullSubLowTestFreeMerit g) ∧
                  (∀ g, fullSubHighTestBasedMerit g
                      (fullSubHighCostThreshold g) =
                    fullSubHighTestFreeMerit g) ∧
                    (∀ g,
                      fullSubLowCostThreshold g <
                        fullSubHighCostThreshold g) ∧
                      ((S.policyPairIsEquilibrium Psub Pfull ↔
                          glm20Theorem3SubFullCondition S policyPair
                            Psub Pfull J2 groupA groupB populationShare
                            testCost subFullCostThreshold capacity2 q1Sub K) ∧
                        (S.policyPairIsEquilibrium Pfull Psub ↔
                          glm20Theorem3FullSubCondition S policyPair Psub
                            Pfull groupA groupB testCost
                            fullSubLowCostThreshold fullSubHighCostThreshold
                            q1Sub q2Sub K) ∧
                          glm20Theorem3FullFullCondition S Pfull groupA
                            groupB testCost) := by
  rcases hsubFull with
    ⟨subFullCostThreshold, hsubFullMem, hsubFullEq, hsubFullLe,
      hsubFullIff⟩
  rcases hfullSub with
    ⟨fullSubLowCostThreshold, fullSubHighCostThreshold, hlowMem, hhighMem,
      hlowEq, hhighEq, hlowHigh, hfullSubIff⟩
  have hsource :
      (S.policyPairIsEquilibrium Psub Pfull ↔
        glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
          groupA groupB populationShare testCost subFullCostThreshold
          capacity2 q1Sub K) ∧
        (S.policyPairIsEquilibrium Pfull Psub ↔
          glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
            testCost fullSubLowCostThreshold fullSubHighCostThreshold
            q1Sub q2Sub K) ∧
          glm20Theorem3FullFullCondition S Pfull groupA groupB testCost :=
    ⟨hsubFullIff, hfullSubIff,
      paper_theorem3_fullFull_condition_of_cost_family_condition
        hfamily hfixed hcostA hcostB⟩
  exact
    ⟨subFullCostThreshold, fullSubLowCostThreshold, fullSubHighCostThreshold,
      hsubFullMem, hsubFullEq, hsubFullLe, hlowMem, hhighMem, hlowEq,
      hhighEq, hlowHigh, hsource⟩

/--
Paper Theorem 3 source-shaped endpoint over the feasibility-aware weighted
binary surface, assuming the fixed-pool merit comparisons are already available.

This composes the feasibility-aware Proposition 5(i) and Proposition 5(ii)
endpoints and then packages the generated thresholds into the paper's combined
Theorem 3 statement.
-/
theorem
    paper_theorem3_source_conditions_of_feasible_weighted_surface_merit_crossings_capacity_fixed_pool_merit_formulas
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity1 capacity2 q1Sub q2Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff fullSubCutoff : Group → ℝ}
    (subFullTestBasedMerit : Group → ℝ → ℝ)
    (subFullTestFreeMerit : Group → ℝ)
    (fullSubLowTestBasedMerit : Group → ℝ → ℝ)
    (fullSubLowTestFreeMerit : Group → ℝ)
    (fullSubHighTestBasedMerit : Group → ℝ → ℝ)
    (fullSubHighTestFreeMerit : Group → ℝ)
    {feasible1 feasible2 : Policy → Policy → Prop}
    (hS :
      S =
        glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
          groupB populationShare feasible1 feasible2)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hsubFullCont :
      ∀ g, ContinuousOn (subFullTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hsubFullAnti :
      ∀ g, StrictAntiOn (subFullTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hsubFullAtZero :
      ∀ g, subFullTestFreeMerit g < subFullTestBasedMerit g 0)
    (hsubFullAtMax :
      ∀ g, subFullTestBasedMerit g (maxCost g) < subFullTestFreeMerit g)
    (hlowCont :
      ∀ g, ContinuousOn (fullSubLowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAnti :
      ∀ g, StrictAntiOn (fullSubLowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAtZero :
      ∀ g, fullSubLowTestFreeMerit g < fullSubLowTestBasedMerit g 0)
    (hlowAtMax :
      ∀ g, fullSubLowTestBasedMerit g (maxCost g) <
        fullSubLowTestFreeMerit g)
    (hhighCont :
      ∀ g, ContinuousOn (fullSubHighTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAnti :
      ∀ g, StrictAntiOn (fullSubHighTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAtZero :
      ∀ g, fullSubHighTestFreeMerit g < fullSubHighTestBasedMerit g 0)
    (hhighAtMax :
      ∀ g, fullSubHighTestBasedMerit g (maxCost g) <
        fullSubHighTestFreeMerit g)
    (hhighAtLowRoot :
      ∀ g c, c ∈ Set.Ioo (0 : ℝ) (maxCost g) →
        fullSubLowTestBasedMerit g c = fullSubLowTestFreeMerit g →
          fullSubHighTestFreeMerit g < fullSubHighTestBasedMerit g c)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hmassFullSubA :
      S.massTestTaking groupA (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullSubCutoff groupA))
    (hmassFullSubB :
      S.massTestTaking groupB (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullSubCutoff groupB))
    (hcapacity1 :
      capacity1 =
        populationShare groupA *
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
              q1Sub +
          populationShare groupB *
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
              q1Sub)
    (hfillFullFull1 :
      capacity1 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hcapacity2 :
      capacity2 =
        populationShare groupA *
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
              q2Sub +
          populationShare groupB *
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
              q2Sub)
    (hfillFullFull2 :
      capacity2 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hfixedPoolJ1A :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull) <
            S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull))
    (hfixedPoolJ1B :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull) <
            S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull))
    (hfixedPoolJ2A :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupA (policyPair Pfull Psub) <
            S.admittedAcademicMerit J2 groupA (policyPair Pfull Pfull))
    (hfixedPoolJ2B :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupB (policyPair Pfull Psub) <
            S.admittedAcademicMerit J2 groupB (policyPair Pfull Pfull))
    (honlyA_J1_groupB_eq :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull) =
            S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull))
    (honlyA_J1_groupA_testBased :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull) =
            subFullTestBasedMerit groupA (testCost groupA))
    (honlyA_J1_groupA_testFree :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull) =
            subFullTestFreeMerit groupA)
    (honlyB_J1_groupA_eq :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull) =
            S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull))
    (honlyB_J1_groupB_testBased :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull) =
            subFullTestBasedMerit groupB (testCost groupB))
    (honlyB_J1_groupB_testFree :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull) =
            subFullTestFreeMerit groupB)
    (hfeasible1SubFull : feasible1 Psub Pfull)
    (hfeasible1FullFull : feasible1 Pfull Pfull)
    (hfeasible2SubSub : feasible2 Psub Psub)
    (hfeasible2SubFull :
      ∀ costThreshold : Group → ℝ,
        feasible2 Psub Pfull ↔
          (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
              testCost costThreshold q1Sub
              (fun g q =>
                glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
              groupA →
            S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2) ∧
          (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
              testCost costThreshold q1Sub
              (fun g q =>
                glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
              groupB →
            S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2))
    (hJ2ZeroA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        populationShare groupA *
          S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) = 0)
    (hJ2NotTieB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ZeroB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        populationShare groupB *
          S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) = 0)
    (hJ2NotTieA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hfeasible1FullSub : feasible1 Pfull Psub)
    (hfeasible2FullSub : feasible2 Pfull Psub)
    (hfeasible1SubSub : feasible1 Psub Psub)
    (hfeasible2FullFull : feasible2 Pfull Pfull)
    (honlyA_J2_groupB_eq :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupB (policyPair Pfull Pfull) =
            S.admittedAcademicMerit J2 groupB (policyPair Pfull Psub))
    (honlyA_J2_groupA_testBased :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupA (policyPair Pfull Pfull) =
            fullSubLowTestBasedMerit groupA (testCost groupA))
    (honlyA_J2_groupA_testFree :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupA (policyPair Pfull Psub) =
            fullSubLowTestFreeMerit groupA)
    (honlyB_J2_groupA_eq :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J2 groupA (policyPair Pfull Pfull) =
            S.admittedAcademicMerit J2 groupA (policyPair Pfull Psub))
    (honlyB_J2_groupB_testBased :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J2 groupB (policyPair Pfull Pfull) =
            fullSubLowTestBasedMerit groupB (testCost groupB))
    (honlyB_J2_groupB_testFree :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J2 groupB (policyPair Pfull Psub) =
            fullSubLowTestFreeMerit groupB)
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandA_J1_groupB_eq :
      ¬ fullSubCutoff groupA < q1Sub →
        S.admittedAcademicMerit J1 groupB (policyPair Psub Psub) =
          S.admittedAcademicMerit J1 groupB (policyPair Pfull Psub))
    (hexpandA_J1_groupA_testFree :
      ¬ fullSubCutoff groupA < q1Sub →
        S.admittedAcademicMerit J1 groupA (policyPair Psub Psub) =
          fullSubHighTestFreeMerit groupA)
    (hexpandA_J1_groupA_testBased :
      ¬ fullSubCutoff groupA < q1Sub →
        S.admittedAcademicMerit J1 groupA (policyPair Pfull Psub) =
          fullSubHighTestBasedMerit groupA (testCost groupA))
    (hnoExpandB :
      fullSubCutoff groupB < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
