/--
Two-school binary-policy equilibrium helper.

The strategic sections of the paper compare only `P_sub` and `P_full` for each
school.  This predicate says each school weakly prefers its current policy to
the other admissible policy, holding the other school's policy fixed.
-/
def glm20TwoSchoolBinaryPolicyEquilibrium
    {Policy : Type*} (objective1 objective2 : Policy → Policy → ℝ)
    (Psub Pfull P1 P2 : Policy) : Prop :=
  (∀ P1' : Policy, P1' = Psub ∨ P1' = Pfull →
    objective1 P1' P2 ≤ objective1 P1 P2) ∧
    (∀ P2' : Policy, P2' = Psub ∨ P2' = Pfull →
      objective2 P1 P2' ≤ objective2 P1 P2)

/--
Binary-policy strategic surface for the paper's two-school academic-merit
game.

The surface keeps the paper observables (`M_g(P)`, `L_i^g(P)`, and diversity)
as supplied functions, but defines the equilibrium predicate directly as the
binary best-response condition for the two weighted academic-merit objectives
`π_A L_i^A(P)+π_B L_i^B(P)`.  This is a paper-local adapter: the concrete
Gaussian work still has to instantiate the mass and merit functions, but no
additional proof is needed to connect `policyPairIsEquilibrium` to the
two-policy normal-form game.
-/
def glm20WeightedAcademicMeritBinaryPolicySurface
    {Group Policy School : Type*}
    (massTestTaking : Group → Policy → ℝ)
    (admittedAcademicMerit : School → Group → Policy → ℝ)
    (diversity : School → Policy → ℝ)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J1 J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ) :
    GLM20StrategicPolicySurface Group Policy School (Policy × Policy) where
  massTestTaking := massTestTaking
  admittedAcademicMerit := admittedAcademicMerit
  diversity := diversity
  policyPairIsEquilibrium := fun P1 P2 =>
    glm20TwoSchoolBinaryPolicyEquilibrium
      (fun P1 P2 =>
        populationShare groupA * admittedAcademicMerit J1 groupA
            (policyPair P1 P2) +
          populationShare groupB * admittedAcademicMerit J1 groupB
            (policyPair P1 P2))
      (fun P1 P2 =>
        populationShare groupA * admittedAcademicMerit J2 groupA
            (policyPair P1 P2) +
          populationShare groupB * admittedAcademicMerit J2 groupB
            (policyPair P1 P2))
      Psub Pfull P1 P2
  equilibriumPredicate := fun E =>
    glm20TwoSchoolBinaryPolicyEquilibrium
      (fun P1 P2 =>
        populationShare groupA * admittedAcademicMerit J1 groupA
            (policyPair P1 P2) +
          populationShare groupB * admittedAcademicMerit J1 groupB
            (policyPair P1 P2))
      (fun P1 P2 =>
        populationShare groupA * admittedAcademicMerit J2 groupA
            (policyPair P1 P2) +
          populationShare groupB * admittedAcademicMerit J2 groupB
            (policyPair P1 P2))
      Psub Pfull E.1 E.2

/--
Theorem 3 concrete policy-state surface for schools maximizing weighted
academic merit.

This is the source-model adapter for Section 5: the policy type is the
six-constructor `GLM20StrategicPolicyState`, `P_sub` and `P_full` are the two
single-school states, `policyPair` is `glm20StrategicPolicyStatePair`, and the
full/full and full/sub masses are wired to the paper's `K_g` cutoff formulas.
-/
def glm20Theorem3PolicyStateWeightedAcademicMeritSurface
    {Group School : Type*}
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ)
    (admittedAcademicMerit :
      School → Group → GLM20StrategicPolicyState → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ) :
    GLM20StrategicPolicySurface Group GLM20StrategicPolicyState School
      (GLM20StrategicPolicyState × GLM20StrategicPolicyState) :=
  glm20WeightedAcademicMeritBinaryPolicySurface
    (glm20Theorem3PolicyStateCutoffMass api subEstimateLaw subSubMass
      subFullMass fullFullCutoff fullSubCutoff)
    admittedAcademicMerit diversity glm20StrategicPolicyStatePair
    GLM20StrategicPolicyState.singleSub
    GLM20StrategicPolicyState.singleFull J1 J2 groupA groupB populationShare

/--
Theorem 3 concrete policy-state surface with admitted merit supplied as the
four paper policy-pair tables `L_i^g(P_sub,P_sub)`,
`L_i^g(P_sub,P_full)`, `L_i^g(P_full,P_sub)`, and
`L_i^g(P_full,P_full)`.
-/
def glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface
    {Group School : Type*}
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ)
    (subSubMerit subFullMerit fullSubMerit fullFullMerit :
      School → Group → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ) :
    GLM20StrategicPolicySurface Group GLM20StrategicPolicyState School
      (GLM20StrategicPolicyState × GLM20StrategicPolicyState) :=
  glm20Theorem3PolicyStateWeightedAcademicMeritSurface api subEstimateLaw
    subSubMass subFullMass fullFullCutoff fullSubCutoff
    (glm20StrategicPolicyStateAdmittedMerit subSubMerit subFullMerit
      fullSubMerit fullFullMerit)
    diversity J1 J2 groupA groupB populationShare

/--
Theorem 3 concrete policy-state table surface with the fixed-pool rows
generated directly from the Gaussian source families.

This is only a bookkeeping abbreviation, but it keeps later source-facing
condition statements in the paper's table language rather than the fully
expanded generated-surface term.
-/
abbrev glm20Theorem3SourceFamilyPolicyStateTableSurface
    {Group School FeatureDrop FeatureKeep : Type*}
    [DecidableEq School]
    [Fintype FeatureDrop] [Nonempty FeatureDrop]
    [Fintype FeatureKeep] [Nonempty FeatureKeep]
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (subSubMerit subFullMeritFallback fullSubMeritFallback
      fullFullMeritFallback : School → Group → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ)
    (C : GaussianHazardCertificate)
    (J1DropFamily J2DropFamily :
      Group → GaussianOffsetSignalFamily FeatureDrop)
    (J1KeepFamily J2KeepFamily :
      Group → GaussianOffsetSignalFamily FeatureKeep)
    (J1DropThreshold J1KeepThreshold J2DropThreshold
      J2KeepThreshold : Group → ℝ) :
    GLM20StrategicPolicySurface Group GLM20StrategicPolicyState School
      (GLM20StrategicPolicyState × GLM20StrategicPolicyState) :=
  glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface api
    subEstimateLaw subSubMass subFullMass fullFullCutoff fullSubCutoff
    subSubMerit
    (glm20Theorem3SourceFamilySubFullMeritTable C J1 J1DropFamily
      J1DropThreshold subFullMeritFallback)
    (glm20Theorem3SourceFamilyFullSubMeritTable C J2 J2DropFamily
      J2DropThreshold fullSubMeritFallback)
    (glm20Theorem3SourceFamilyFullFullMeritTable C J1 J2 J1KeepFamily
