/--
Theorem 2, direct standard-Gaussian no-barrier bundle in precision notation.

This wrapper fixes the affine-tail slopes and intercepts to the paper's
conditional posterior-score standardizations.  Its high-skill comparison is
derived from precision order: group A has the larger full-policy total
precision, while group B has the larger test-free total precision.
-/
theorem paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_surface_of_precision_order
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) {Psub Pfull : Policy}
    {pi capacity quantile leftWeight priorPrecision mean subA subB testA testB : ℝ}
    {L_A_sub L_A_full L_B_sub L_B_full : GaussianScaleLaw}
    {thresholdSub thresholdFull : ℝ}
    (hgroups : groupA ≠ groupB) (hP_ne : Psub ≠ Pfull)
    (hquantile_pos : 0 < quantile)
    (hleftWeight_pos : 0 < leftWeight)
    (htermSub_nonneg :
      0 ≤
        leftWeight *
            ((subA / (priorPrecision + subA)) /
              (subB / (priorPrecision + subB))) +
          pi)
    (htermFull_nonneg :
      0 ≤
        leftWeight *
            (((subA + testA) /
                (priorPrecision + subA + testA)) /
              ((subB + testB) /
                (priorPrecision + subB + testB))) +
          pi)
    (hprior_pos : 0 < priorPrecision)
    (hsubA_pos : 0 < subA) (hsubB_pos : 0 < subB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB)
    (hfull_precision_order : subB + testB < subA + testA)
    (hsub_precision_order : subA < subB)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hmean_sub : L_A_sub.mean = L_B_sub.mean)
    (hmean_A : L_A_sub.mean = L_A_full.mean)
    (hmean_B : L_B_sub.mean = L_B_full.mean)
    (hscale_A : L_A_sub.scale < L_A_full.scale)
    (hscale_B : L_B_sub.scale < L_B_full.scale)
    (hcapacity_sub :
      capacity =
        (1 - pi) * standardGaussianCDFAPI.thresholdPassProb L_A_sub thresholdSub +
          pi * standardGaussianCDFAPI.thresholdPassProb L_B_sub thresholdSub)
    (hcapacity_full :
      capacity =
        (1 - pi) * standardGaussianCDFAPI.thresholdPassProb L_A_full thresholdFull +
          pi * standardGaussianCDFAPI.thresholdPassProb L_B_full thresholdFull)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ)) :
    let interceptAFull :=
      (priorPrecision * (thresholdFull - mean) +
          (subA + testA) * thresholdFull) /
        Real.sqrt (subA + testA)
    let slopeAFull := Real.sqrt (subA + testA)
    let interceptASub :=
      (priorPrecision * (thresholdSub - mean) + subA * thresholdSub) /
        Real.sqrt subA
    let slopeASub := Real.sqrt subA
    let interceptBFull :=
      (priorPrecision * (thresholdFull - mean) +
          (subB + testB) * thresholdFull) /
        Real.sqrt (subB + testB)
    let slopeBFull := Real.sqrt (subB + testB)
    let interceptBSub :=
      (priorPrecision * (thresholdSub - mean) + subB * thresholdSub) /
        Real.sqrt subB
    let slopeBSub := Real.sqrt subB
    let S : GLM20SourcePolicySurface Group Policy :=
      theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
        pi capacity quantile leftWeight priorPrecision subA subB testA testB
        interceptAFull slopeAFull interceptASub slopeASub
        interceptBFull slopeBFull interceptBSub slopeBSub
        L_A_sub L_A_full L_B_sub L_B_full thresholdSub thresholdFull
    (S.diversity Psub > S.diversity Pfull ↔
      (subA * (priorPrecision + subA + testA)) /
          (subB * (priorPrecision + subB + testB)) <
        testA / testB) ∧
      (∃ qA qB : ℝ,
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q >
              standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q ↔
            qA < q) ∧
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q >
              standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q ↔
            qB < q) ∧
        ∃ qhat : ℝ, max qA qB ≤ qhat ∧
          ∀ q : ℝ, qhat < q →
            S.individualFairnessGap Pfull q >
              S.individualFairnessGap Psub q) ∧
      S.academicMerit groupA Psub < S.academicMerit groupA Pfull ∧
        S.academicMerit groupB Psub < S.academicMerit groupB Pfull := by
  have hfullA_pos : 0 < subA + testA := by linarith
  have hfullB_pos : 0 < subB + testB := by linarith
  have hslopeA : Real.sqrt subA < Real.sqrt (subA + testA) := by
    apply Real.sqrt_lt_sqrt hsubA_pos.le
    linarith
  have hslopeB : Real.sqrt subB < Real.sqrt (subB + testB) := by
    apply Real.sqrt_lt_sqrt hsubB_pos.le
    linarith
  have hfullSlope :
      Real.sqrt (subB + testB) < Real.sqrt (subA + testA) :=
    Real.sqrt_lt_sqrt hfullB_pos.le hfull_precision_order
  have hsubSlope : Real.sqrt subA < Real.sqrt subB :=
    Real.sqrt_lt_sqrt hsubA_pos.le hsub_precision_order
  exact
    paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_surface_of_slope_order
      (groupA := groupA) (groupB := groupB) (Psub := Psub) (Pfull := Pfull)
      (pi := pi) (capacity := capacity) (quantile := quantile)
      (leftWeight := leftWeight) (priorPrecision := priorPrecision)
      (subA := subA) (subB := subB) (testA := testA) (testB := testB)
      (interceptAFull :=
        (priorPrecision * (thresholdFull - mean) +
            (subA + testA) * thresholdFull) /
          Real.sqrt (subA + testA))
      (slopeAFull := Real.sqrt (subA + testA))
      (interceptASub :=
        (priorPrecision * (thresholdSub - mean) + subA * thresholdSub) /
          Real.sqrt subA)
      (slopeASub := Real.sqrt subA)
      (interceptBFull :=
        (priorPrecision * (thresholdFull - mean) +
            (subB + testB) * thresholdFull) /
          Real.sqrt (subB + testB))
      (slopeBFull := Real.sqrt (subB + testB))
      (interceptBSub :=
        (priorPrecision * (thresholdSub - mean) + subB * thresholdSub) /
          Real.sqrt subB)
      (slopeBSub := Real.sqrt subB)
      (L_A_sub := L_A_sub) (L_A_full := L_A_full)
      (L_B_sub := L_B_sub) (L_B_full := L_B_full)
      (thresholdSub := thresholdSub) (thresholdFull := thresholdFull)
      hgroups hP_ne hquantile_pos hleftWeight_pos htermSub_nonneg
      htermFull_nonneg hprior_pos hsubA_pos hsubB_pos htestA_pos
      htestB_pos hslopeA hslopeB hfullSlope hsubSlope hpi_pos hpi_lt_one
      hmean_sub hmean_A hmean_B hscale_A hscale_B hcapacity_sub
      hcapacity_full hcapacity_lt_half

/-- Theorem 2 diversity square-root term is nonnegative for positive precisions. -/
theorem theorem2_diversity_sqrt_term_nonneg
    {pi leftWeight priorPrecision precisionA precisionB : ℝ}
    (hpi_pos : 0 < pi)
    (hleftWeight_nonneg : 0 ≤ leftWeight)
    (hprior_pos : 0 < priorPrecision)
    (hprecisionA_pos : 0 < precisionA)
    (hprecisionB_pos : 0 < precisionB) :
    0 ≤
      leftWeight *
          ((precisionA / (priorPrecision + precisionA)) /
            (precisionB / (priorPrecision + precisionB))) +
        pi := by
  have hdenA_pos : 0 < priorPrecision + precisionA := by linarith
  have hdenB_pos : 0 < priorPrecision + precisionB := by linarith
  have hratioA_pos : 0 < precisionA / (priorPrecision + precisionA) :=
    div_pos hprecisionA_pos hdenA_pos
  have hratioB_pos : 0 < precisionB / (priorPrecision + precisionB) :=
    div_pos hprecisionB_pos hdenB_pos
  have hratio_nonneg :
      0 ≤
        (precisionA / (priorPrecision + precisionA)) /
          (precisionB / (priorPrecision + precisionB)) :=
    (div_pos hratioA_pos hratioB_pos).le
  exact add_nonneg (mul_nonneg hleftWeight_nonneg hratio_nonneg) hpi_pos.le

