/--
Proposition 5(ii), school-`J1`, condition-(14) high-threshold bridges from
group-level admitted-merit formulas.

This is the weighted-objective version of
`paper_proposition5_part_ii_school1_cutoff_objective_iff_no_expand_or_low_cost_of_merit_formulas`.
It constructs the shared high threshold `c''_g` and, in each expanding case,
uses unchanged non-focal admitted merit plus the focal group's displayed
test-free/test-based admitted-merit formulas to reduce the weighted objective
comparison to the paper's one-dimensional high-merit comparison.
-/
theorem
    paper_proposition5_part_ii_school1_weighted_objective_cutoff_bridges_of_group_merit_formulas
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {q1Sub : ℝ} {fullSubCutoff : Group → ℝ}
    (highTestBasedMerit : Group → ℝ → ℝ)
    (highTestFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hcont :
      ∀ g, ContinuousOn (highTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hanti :
      ∀ g, StrictAntiOn (highTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowCost :
      ∀ g, highTestFreeMerit g < highTestBasedMerit g 0)
    (hhighCost :
      ∀ g, highTestBasedMerit g (maxCost g) <
        highTestFreeMerit g)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandA_groupB_eq :
      ¬ fullSubCutoff groupA < q1Sub →
        S.admittedAcademicMerit J1 groupB (policyPair Psub Psub) =
          S.admittedAcademicMerit J1 groupB (policyPair Pfull Psub))
    (hexpandA_groupA_testFree :
      ¬ fullSubCutoff groupA < q1Sub →
        S.admittedAcademicMerit J1 groupA (policyPair Psub Psub) =
          highTestFreeMerit groupA)
    (hexpandA_groupA_testBased :
      ¬ fullSubCutoff groupA < q1Sub →
        S.admittedAcademicMerit J1 groupA (policyPair Pfull Psub) =
          highTestBasedMerit groupA (testCost groupA))
    (hnoExpandB :
      fullSubCutoff groupB < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandB_groupA_eq :
      ¬ fullSubCutoff groupB < q1Sub →
        S.admittedAcademicMerit J1 groupA (policyPair Psub Psub) =
          S.admittedAcademicMerit J1 groupA (policyPair Pfull Psub))
    (hexpandB_groupB_testFree :
      ¬ fullSubCutoff groupB < q1Sub →
        S.admittedAcademicMerit J1 groupB (policyPair Psub Psub) =
          highTestFreeMerit groupB)
    (hexpandB_groupB_testBased :
      ¬ fullSubCutoff groupB < q1Sub →
        S.admittedAcademicMerit J1 groupB (policyPair Pfull Psub) =
          highTestBasedMerit groupB (testCost groupB)) :
    ∃ highCostThreshold : Group → ℝ,
      (∀ g, highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, highTestBasedMerit g (highCostThreshold g) =
          highTestFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (highTestFreeMerit g ≤ highTestBasedMerit g c ↔
              c ≤ highCostThreshold g)) ∧
            (((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
                    groupA groupB populationShare Psub Psub ≤
                  glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
                    groupA groupB populationShare Pfull Psub) ↔
                fullSubCutoff groupA < q1Sub ∨
                  testCost groupA ≤ highCostThreshold groupA) ∧
              ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
                    groupA groupB populationShare Psub Psub ≤
                  glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
                    groupA groupB populationShare Pfull Psub) ↔
                fullSubCutoff groupB < q1Sub ∨
                  testCost groupB ≤ highCostThreshold groupB)) := by
  classical
  have hthreshold :
      ∀ g : Group, ∃ highCostThreshold : ℝ,
        highCostThreshold ∈ Set.Ioo (0 : ℝ) (maxCost g) ∧
          highTestBasedMerit g highCostThreshold = highTestFreeMerit g ∧
            (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
              highTestFreeMerit g < highTestBasedMerit g c ↔
                c < highCostThreshold) ∧
              (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                highTestBasedMerit g c < highTestFreeMerit g ↔
                  highCostThreshold < c) ∧
                (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                  highTestFreeMerit g ≤ highTestBasedMerit g c ↔
                    c ≤ highCostThreshold) ∧
                  (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                    highTestBasedMerit g c ≤ highTestFreeMerit g ↔
                      highCostThreshold ≤ c) := by
    intro g
    exact
      exists_threshold_of_continuous_strictAntiOn_Icc_crossing_interval
        (f := highTestBasedMerit g) (level := highTestFreeMerit g)
        (left := 0) (right := maxCost g) (hmaxCost g) (hcont g) (hanti g)
        (hlowCost g) (hhighCost g)
  let highCostThreshold : Group → ℝ :=
    fun g => Classical.choose (hthreshold g)
  have hspec :
      ∀ g,
        highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g) ∧
          highTestBasedMerit g (highCostThreshold g) =
            highTestFreeMerit g ∧
            (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
              highTestFreeMerit g < highTestBasedMerit g c ↔
                c < highCostThreshold g) ∧
              (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                highTestBasedMerit g c < highTestFreeMerit g ↔
                  highCostThreshold g < c) ∧
                (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                  highTestFreeMerit g ≤ highTestBasedMerit g c ↔
                    c ≤ highCostThreshold g) ∧
                  (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                    highTestBasedMerit g c ≤ highTestFreeMerit g ↔
                      highCostThreshold g ≤ c) := by
    intro g
    exact Classical.choose_spec (hthreshold g)
  have hmem :
      ∀ g, highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g) :=
    fun g => (hspec g).1
  have heq :
      ∀ g, highTestBasedMerit g (highCostThreshold g) =
        highTestFreeMerit g :=
    fun g => (hspec g).2.1
  have hge :
      ∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
        (highTestFreeMerit g ≤ highTestBasedMerit g c ↔
          c ≤ highCostThreshold g) :=
    fun g => (hspec g).2.2.2.2.1
  let objective1 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1 groupA groupB
      populationShare
  have hcutoffA :
      (objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
        fullSubCutoff groupA < q1Sub ∨
          testCost groupA ≤ highCostThreshold groupA := by
    refine
      paper_proposition5_part_ii_school1_cutoff_objective_iff_no_expand_or_low_cost
        objective1 hnoExpandA ?_
    intro hnot
    have hobjective_merit :
        (objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          highTestFreeMerit groupA ≤
            highTestBasedMerit groupA (testCost groupA) :=
      glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupA_formula_of_groupB_eq
        S policyPair J1 groupA groupB populationShare Psub Psub Pfull Psub
        hshareA (hexpandA_groupB_eq hnot)
        (hexpandA_groupA_testFree hnot)
        (hexpandA_groupA_testBased hnot)
    exact hobjective_merit.trans
      (hge groupA (testCost groupA) (hcostMem groupA))
  have hcutoffB :
      (objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
        fullSubCutoff groupB < q1Sub ∨
          testCost groupB ≤ highCostThreshold groupB := by
    refine
      paper_proposition5_part_ii_school1_cutoff_objective_iff_no_expand_or_low_cost
        objective1 hnoExpandB ?_
    intro hnot
    have hobjective_merit :
        (objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          highTestFreeMerit groupB ≤
            highTestBasedMerit groupB (testCost groupB) :=
      glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupB_formula_of_groupA_eq
        S policyPair J1 groupA groupB populationShare Psub Psub Pfull Psub
        hshareB (hexpandB_groupA_eq hnot)
        (hexpandB_groupB_testFree hnot)
        (hexpandB_groupB_testBased hnot)
    exact hobjective_merit.trans
      (hge groupB (testCost groupB) (hcostMem groupB))
  exact ⟨highCostThreshold, hmem, heq, hge, hcutoffA, hcutoffB⟩

/--
Proposition 5(ii) / Theorem 3(ii) objective bridge.

Paper statement: school `J2` drops the test exactly when condition (13) holds
for exactly one group; conditional on such a drop, school `J1` keeps the test
exactly when condition (14) holds for that same group.  Therefore the two
binary unilateral objective comparisons are equivalent to Theorem 3(ii)'s
`(P_full,P_sub)` condition.
-/
theorem paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost lowCostThreshold highCostThreshold : Group → ℝ}
    {q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (hJ2 :
      (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3FullSubSchool2DropsCondition S policyPair
            Psub Pfull testCost lowCostThreshold highCostThreshold
            q1Sub q2Sub K))
    (hJ1A :
      glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
          testCost lowCostThreshold highCostThreshold q1Sub q2Sub K groupA →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          glm20Theorem3FullSubSchool1KeepsTestCondition S policyPair
            Psub Pfull testCost highCostThreshold q1Sub K groupA))
    (hJ1B :
      glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
          testCost lowCostThreshold highCostThreshold q1Sub q2Sub K groupB →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          glm20Theorem3FullSubSchool1KeepsTestCondition S policyPair
            Psub Pfull testCost highCostThreshold q1Sub K groupB)) :
    (objective1 Psub Psub ≤ objective1 Pfull Psub ∧
        objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
      glm20ExactlyOneOfTwo groupA groupB
        (glm20Theorem3FullSubGroupCondition S policyPair Psub Pfull
          testCost lowCostThreshold highCostThreshold q1Sub q2Sub K) := by
  let drops :=
    glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
      testCost lowCostThreshold highCostThreshold q1Sub q2Sub K
  let keeps :=
    glm20Theorem3FullSubSchool1KeepsTestCondition S policyPair Psub Pfull
      testCost highCostThreshold q1Sub K
  let combined := fun g => drops g ∧ keeps g
  change
    (objective1 Psub Psub ≤ objective1 Pfull Psub ∧
        objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
      glm20ExactlyOneOfTwo groupA groupB combined
  constructor
  · rintro ⟨h1, h2⟩
    have hexactDrops : glm20ExactlyOneOfTwo groupA groupB drops := by
      simpa [drops] using hJ2.mp h2
    rcases hexactDrops with ⟨hdropA, hnotDropB⟩ | ⟨hdropB, hnotDropA⟩
    · refine Or.inl ⟨?_, ?_⟩
      · refine ⟨hdropA, ?_⟩
        have hdropA' :
            glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
              testCost lowCostThreshold highCostThreshold q1Sub q2Sub K
              groupA := by
          simpa [drops] using hdropA
        simpa [keeps] using (hJ1A hdropA').mp h1
      · intro hcombinedB
        exact hnotDropB hcombinedB.1
    · refine Or.inr ⟨?_, ?_⟩
      · refine ⟨hdropB, ?_⟩
        have hdropB' :
            glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
              testCost lowCostThreshold highCostThreshold q1Sub q2Sub K
              groupB := by
          simpa [drops] using hdropB
        simpa [keeps] using (hJ1B hdropB').mp h1
      · intro hcombinedA
        exact hnotDropA hcombinedA.1
  · intro hexactCombined
    rcases hexactCombined with ⟨hcombinedA, hnotCombinedB⟩ |
      ⟨hcombinedB, hnotCombinedA⟩
    · have hdropA : drops groupA := hcombinedA.1
      have hkeepA : keeps groupA := hcombinedA.2
      have hdropA' :
          glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
            testCost lowCostThreshold highCostThreshold q1Sub q2Sub K
            groupA := by
        simpa [drops] using hdropA
      have h1 : objective1 Psub Psub ≤ objective1 Pfull Psub :=
        (hJ1A hdropA').mpr (by simpa [keeps] using hkeepA)
      have hnotDropB : ¬ drops groupB := by
        intro hdropB
        have hdropB' :
            glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
              testCost lowCostThreshold highCostThreshold q1Sub q2Sub K
              groupB := by
          simpa [drops] using hdropB
        have hkeepB : keeps groupB := by
          simpa [keeps] using (hJ1B hdropB').mp h1
        exact hnotCombinedB ⟨hdropB, hkeepB⟩
      have h2 : objective2 Pfull Pfull ≤ objective2 Pfull Psub :=
        hJ2.mpr (by
          refine Or.inl ⟨?_, ?_⟩
          · simpa [drops] using hdropA
          · simpa [drops] using hnotDropB)
      exact ⟨h1, h2⟩
    · have hdropB : drops groupB := hcombinedB.1
      have hkeepB : keeps groupB := hcombinedB.2
      have hdropB' :
          glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
            testCost lowCostThreshold highCostThreshold q1Sub q2Sub K
            groupB := by
        simpa [drops] using hdropB
      have h1 : objective1 Psub Psub ≤ objective1 Pfull Psub :=
        (hJ1B hdropB').mpr (by simpa [keeps] using hkeepB)
      have hnotDropA : ¬ drops groupA := by
        intro hdropA
        have hdropA' :
            glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
              testCost lowCostThreshold highCostThreshold q1Sub q2Sub K
              groupA := by
          simpa [drops] using hdropA
        have hkeepA : keeps groupA := by
          simpa [keeps] using (hJ1A hdropA').mp h1
        exact hnotCombinedA ⟨hdropA, hkeepA⟩
      have h2 : objective2 Pfull Pfull ≤ objective2 Pfull Psub :=
        hJ2.mpr (by
          refine Or.inr ⟨?_, ?_⟩
          · simpa [drops] using hdropB
          · simpa [drops] using hnotDropA)
      exact ⟨h1, h2⟩

/--
Theorem 3(ii)'s conditions for `(P_full, P_sub)`.

Paper statement: `(P_full, P_sub)` is an equilibrium iff, for exactly one
group `g`, `c_g ≥ c_hat'_g`,
`M_g(P_full, P_full) < K_g(q^*_{2,sub})`, and either
`M_g(P_full, P_sub) > K_g(q^*_{1,sub})` or `c_g ≤ c_hat''_g`, with
`c_hat''_g > c_hat'_g > 0`.
-/
def glm20Theorem3FullSubCondition
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (groupA groupB : Group)
    (testCost lowCostThreshold highCostThreshold : Group → ℝ)
    (q1Sub q2Sub : ℝ) (K : Group → ℝ → ℝ) : Prop :=
  let groupCondition :=
    glm20Theorem3FullSubGroupCondition S policyPair Psub Pfull testCost
      lowCostThreshold highCostThreshold q1Sub q2Sub K
  glm20ExactlyOneOfTwo groupA groupB groupCondition

/--
Theorem 3(ii), expanded two-group form.

Paper wording: `(P_full,P_sub)` is an equilibrium iff exactly one group
satisfies conditions (13)--(14).  This unfolds the source condition into the
two mutually exclusive group cases.
-/
theorem glm20Theorem3FullSubCondition_iff_groupA_or_groupB
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost lowCostThreshold highCostThreshold : Group → ℝ}
    {q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ} :
    glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
        testCost lowCostThreshold highCostThreshold q1Sub q2Sub K ↔
      (glm20Theorem3FullSubGroupCondition S policyPair Psub Pfull testCost
          lowCostThreshold highCostThreshold q1Sub q2Sub K groupA ∧
        ¬ glm20Theorem3FullSubGroupCondition S policyPair Psub Pfull
          testCost lowCostThreshold highCostThreshold q1Sub q2Sub K groupB) ∨
      (glm20Theorem3FullSubGroupCondition S policyPair Psub Pfull testCost
          lowCostThreshold highCostThreshold q1Sub q2Sub K groupB ∧
        ¬ glm20Theorem3FullSubGroupCondition S policyPair Psub Pfull
          testCost lowCostThreshold highCostThreshold q1Sub q2Sub K groupA) := by
  rfl

/--
Policy-state Theorem 3(ii) two-group bridge: on the concrete policy-state
surface, the named `(P_full,P_sub)` condition is exactly the paper's
exactly-one group satisfying conditions (13)--(14), rewritten as cutoff and
cost cases.
-/
theorem
    paper_proposition5_policyState_fullSubCondition_iff_cutoff_cases
    {Group School : Type*}
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (admittedAcademicMerit :
      School → Group → GLM20StrategicPolicyState → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ)
    {testCost lowCostThreshold highCostThreshold : Group → ℝ}
    {q1Sub q2Sub : ℝ} {fullFullCutoff fullSubCutoff : Group → ℝ} :
    glm20Theorem3FullSubCondition
        (glm20Theorem3PolicyStateWeightedAcademicMeritSurface api
          subEstimateLaw subSubMass subFullMass fullFullCutoff fullSubCutoff
          admittedAcademicMerit diversity J1 J2 groupA groupB
          populationShare)
        glm20StrategicPolicyStatePair
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull
        groupA groupB testCost lowCostThreshold highCostThreshold q1Sub q2Sub
        (fun h q => glm20StrategicSubEstimateMassAbove api
          (subEstimateLaw h) q) ↔
      (((testCost groupA ≥ lowCostThreshold groupA ∧
          0 < lowCostThreshold groupA ∧
            lowCostThreshold groupA < highCostThreshold groupA ∧
              q2Sub < fullFullCutoff groupA) ∧
          (fullSubCutoff groupA < q1Sub ∨
            testCost groupA ≤ highCostThreshold groupA)) ∧
        ¬ ((testCost groupB ≥ lowCostThreshold groupB ∧
          0 < lowCostThreshold groupB ∧
            lowCostThreshold groupB < highCostThreshold groupB ∧
              q2Sub < fullFullCutoff groupB) ∧
          (fullSubCutoff groupB < q1Sub ∨
            testCost groupB ≤ highCostThreshold groupB))) ∨
      (((testCost groupB ≥ lowCostThreshold groupB ∧
          0 < lowCostThreshold groupB ∧
            lowCostThreshold groupB < highCostThreshold groupB ∧
              q2Sub < fullFullCutoff groupB) ∧
          (fullSubCutoff groupB < q1Sub ∨
            testCost groupB ≤ highCostThreshold groupB)) ∧
        ¬ ((testCost groupA ≥ lowCostThreshold groupA ∧
          0 < lowCostThreshold groupA ∧
            lowCostThreshold groupA < highCostThreshold groupA ∧
              q2Sub < fullFullCutoff groupA) ∧
          (fullSubCutoff groupA < q1Sub ∨
            testCost groupA ≤ highCostThreshold groupA))) := by
  rw [glm20Theorem3FullSubCondition_iff_groupA_or_groupB]
  rw [
    paper_proposition5_policyState_fullSubGroupCondition_iff_cutoff_cases
      (g := groupA)]
  rw [
    paper_proposition5_policyState_fullSubGroupCondition_iff_cutoff_cases
      (g := groupB)]

/--
Policy-state table Theorem 3(ii) bridge: when admitted merit is supplied by
the four paper policy-pair tables, the named `(P_full,P_sub)` condition is
still exactly the two-group cutoff/cost case split for conditions (13)--(14).
-/
theorem
    paper_proposition5_policyStateTable_fullSubCondition_iff_cutoff_component_cases
    {Group School : Type*}
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ)
    (subSubMerit subFullMerit fullSubMerit fullFullMerit :
      School → Group → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ)
    {testCost lowCostThreshold highCostThreshold : Group → ℝ}
    {q1Sub q2Sub : ℝ} :
    glm20Theorem3FullSubCondition
        (glm20Theorem3PolicyStateTableWeightedAcademicMeritSurface api
          subEstimateLaw subSubMass subFullMass fullFullCutoff fullSubCutoff
          subSubMerit subFullMerit fullSubMerit fullFullMerit diversity J1
          J2 groupA groupB populationShare)
        glm20StrategicPolicyStatePair
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull
        groupA groupB testCost lowCostThreshold highCostThreshold q1Sub q2Sub
        (fun h q => glm20StrategicSubEstimateMassAbove api
          (subEstimateLaw h) q) ↔
      (((testCost groupA ≥ lowCostThreshold groupA ∧
          0 < lowCostThreshold groupA ∧
            lowCostThreshold groupA < highCostThreshold groupA ∧
              q2Sub < fullFullCutoff groupA) ∧
          (fullSubCutoff groupA < q1Sub ∨
            testCost groupA ≤ highCostThreshold groupA)) ∧
        ¬ ((testCost groupB ≥ lowCostThreshold groupB ∧
          0 < lowCostThreshold groupB ∧
            lowCostThreshold groupB < highCostThreshold groupB ∧
              q2Sub < fullFullCutoff groupB) ∧
          (fullSubCutoff groupB < q1Sub ∨
            testCost groupB ≤ highCostThreshold groupB))) ∨
      (((testCost groupB ≥ lowCostThreshold groupB ∧
          0 < lowCostThreshold groupB ∧
            lowCostThreshold groupB < highCostThreshold groupB ∧
              q2Sub < fullFullCutoff groupB) ∧
          (fullSubCutoff groupB < q1Sub ∨
            testCost groupB ≤ highCostThreshold groupB)) ∧
        ¬ ((testCost groupA ≥ lowCostThreshold groupA ∧
          0 < lowCostThreshold groupA ∧
            lowCostThreshold groupA < highCostThreshold groupA ∧
              q2Sub < fullFullCutoff groupA) ∧
          (fullSubCutoff groupA < q1Sub ∨
            testCost groupA ≤ highCostThreshold groupA))) :=
  paper_proposition5_policyState_fullSubCondition_iff_cutoff_cases
    api subEstimateLaw subSubMass subFullMass
    (glm20StrategicPolicyStateAdmittedMerit subSubMerit subFullMerit
      fullSubMerit fullFullMerit)
    diversity J1 J2 groupA groupB populationShare

/--
Source-family policy-state table Theorem 3(ii) bridge.

For the generated Section 5 source-family table, the named
`(P_full,P_sub)` condition is exactly the paper's two-group cutoff/cost case
split for conditions (13)--(14).
-/
theorem
    paper_proposition5_sourceFamilyPolicyStateTable_fullSubCondition_iff_cutoff_component_cases
    {Group School FeatureDrop FeatureKeep : Type*}
    [DecidableEq School]
    [Fintype FeatureDrop] [Nonempty FeatureDrop]
    [Fintype FeatureKeep] [Nonempty FeatureKeep]
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (subSubMerit subFullMeritFallback fullSubMeritFallback
      fullFullMeritFallback : School → Group → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 : School) (groupA groupB : Group)
    (populationShare testCost lowCostThreshold
      highCostThreshold : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ)
    (C : GaussianHazardCertificate)
    (J1DropFamily J2DropFamily :
      Group → GaussianOffsetSignalFamily FeatureDrop)
    (J1KeepFamily J2KeepFamily :
      Group → GaussianOffsetSignalFamily FeatureKeep)
    (J1DropThreshold J1KeepThreshold J2DropThreshold
      J2KeepThreshold : Group → ℝ)
    {q1Sub q2Sub : ℝ} :
    glm20Theorem3FullSubCondition
        (glm20Theorem3SourceFamilyPolicyStateTableSurface api
          subEstimateLaw subSubMass subFullMass subSubMerit
          subFullMeritFallback fullSubMeritFallback fullFullMeritFallback
          diversity J1 J2 groupA groupB populationShare fullFullCutoff
          fullSubCutoff C J1DropFamily J2DropFamily J1KeepFamily
          J2KeepFamily J1DropThreshold J1KeepThreshold J2DropThreshold
          J2KeepThreshold)
        glm20StrategicPolicyStatePair
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull
        groupA groupB testCost lowCostThreshold highCostThreshold q1Sub q2Sub
        (fun h q => glm20StrategicSubEstimateMassAbove api
          (subEstimateLaw h) q) ↔
      (((testCost groupA ≥ lowCostThreshold groupA ∧
          0 < lowCostThreshold groupA ∧
            lowCostThreshold groupA < highCostThreshold groupA ∧
              q2Sub < fullFullCutoff groupA) ∧
          (fullSubCutoff groupA < q1Sub ∨
            testCost groupA ≤ highCostThreshold groupA)) ∧
        ¬ ((testCost groupB ≥ lowCostThreshold groupB ∧
          0 < lowCostThreshold groupB ∧
            lowCostThreshold groupB < highCostThreshold groupB ∧
              q2Sub < fullFullCutoff groupB) ∧
          (fullSubCutoff groupB < q1Sub ∨
            testCost groupB ≤ highCostThreshold groupB))) ∨
      (((testCost groupB ≥ lowCostThreshold groupB ∧
          0 < lowCostThreshold groupB ∧
            lowCostThreshold groupB < highCostThreshold groupB ∧
              q2Sub < fullFullCutoff groupB) ∧
          (fullSubCutoff groupB < q1Sub ∨
            testCost groupB ≤ highCostThreshold groupB)) ∧
        ¬ ((testCost groupA ≥ lowCostThreshold groupA ∧
          0 < lowCostThreshold groupA ∧
            lowCostThreshold groupA < highCostThreshold groupA ∧
              q2Sub < fullFullCutoff groupA) ∧
          (fullSubCutoff groupA < q1Sub ∨
            testCost groupA ≤ highCostThreshold groupA))) := by
  simpa [glm20Theorem3SourceFamilyPolicyStateTableSurface] using
    (paper_proposition5_policyStateTable_fullSubCondition_iff_cutoff_component_cases
      api subEstimateLaw subSubMass subFullMass fullFullCutoff
      fullSubCutoff subSubMerit
      (glm20Theorem3SourceFamilySubFullMeritTable C J1 J1DropFamily
        J1DropThreshold subFullMeritFallback)
      (glm20Theorem3SourceFamilyFullSubMeritTable C J2 J2DropFamily
        J2DropThreshold fullSubMeritFallback)
      (glm20Theorem3SourceFamilyFullFullMeritTable C J1 J2 J1KeepFamily
        J2KeepFamily J1KeepThreshold J2KeepThreshold fullFullMeritFallback)
      diversity J1 J2 groupA groupB populationShare
      (testCost := testCost) (lowCostThreshold := lowCostThreshold)
      (highCostThreshold := highCostThreshold) (q1Sub := q1Sub)
      (q2Sub := q2Sub))

/--
Proposition 5(ii) / Theorem 3(ii) objective bridge, stated directly with the
paper's named `(P_full,P_sub)` condition.
-/
theorem paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_source_condition
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost lowCostThreshold highCostThreshold : Group → ℝ}
    {q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (hJ2 :
      (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3FullSubSchool2DropsCondition S policyPair
            Psub Pfull testCost lowCostThreshold highCostThreshold
            q1Sub q2Sub K))
    (hJ1A :
      glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
          testCost lowCostThreshold highCostThreshold q1Sub q2Sub K groupA →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          glm20Theorem3FullSubSchool1KeepsTestCondition S policyPair
            Psub Pfull testCost highCostThreshold q1Sub K groupA))
    (hJ1B :
      glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
          testCost lowCostThreshold highCostThreshold q1Sub q2Sub K groupB →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          glm20Theorem3FullSubSchool1KeepsTestCondition S policyPair
            Psub Pfull testCost highCostThreshold q1Sub K groupB)) :
    (objective1 Psub Psub ≤ objective1 Pfull Psub ∧
        objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
      glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
        testCost lowCostThreshold highCostThreshold q1Sub q2Sub K := by
  simpa [glm20Theorem3FullSubCondition]
    using
      (paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition
        (S := S) (policyPair := policyPair) (Psub := Psub) (Pfull := Pfull)
        (groupA := groupA) (groupB := groupB) (testCost := testCost)
        (lowCostThreshold := lowCostThreshold)
        (highCostThreshold := highCostThreshold) (q1Sub := q1Sub)
        (q2Sub := q2Sub) (K := K) objective1 objective2 hJ2 hJ1A hJ1B)

/--
Theorem 3(ii) bridge for the feasibility-aware weighted binary surface.

When the current `(P_full,P_sub)` pair and the two unilateral deviations used
in the binary characterization are feasible, the feasible surface reduces to
the existing fullSub objective-pair bridge.
-/
theorem paper_theorem3_fullSub_condition_of_feasible_weighted_surface_objective_bridge
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost lowCostThreshold highCostThreshold : Group → ℝ}
    {q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    {feasible1 feasible2 : Policy → Policy → Prop}
    (hS :
      S =
        glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
          groupB populationShare feasible1 feasible2)
    (hfeasible1FullSub : feasible1 Pfull Psub)
    (hfeasible2FullSub : feasible2 Pfull Psub)
    (hfeasible1SubSub : feasible1 Psub Psub)
    (hfeasible2FullFull : feasible2 Pfull Pfull)
    (hfullSubObjective :
      (glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare Psub Psub ≤
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare Pfull Psub ∧
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare Pfull Pfull ≤
          glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare Pfull Psub) ↔
        glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
          testCost lowCostThreshold highCostThreshold q1Sub q2Sub K) :
    S.policyPairIsEquilibrium Pfull Psub ↔
      glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
        testCost lowCostThreshold highCostThreshold q1Sub q2Sub K := by
  subst S
  let Surf :=
    glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
      admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
      groupB populationShare feasible1 feasible2
  let objective1 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective Surf policyPair J1 groupA
      groupB populationShare
  let objective2 : Policy → Policy → ℝ :=
    glm20TwoGroupWeightedAcademicMeritObjective Surf policyPair J2 groupA
      groupB populationShare
  have hsurface :
      Surf.policyPairIsEquilibrium Pfull Psub ↔
        feasible1 Pfull Psub ∧ feasible2 Pfull Psub ∧
          (feasible1 Psub Psub → objective1 Psub Psub ≤
            objective1 Pfull Psub) ∧
            (feasible2 Pfull Pfull → objective2 Pfull Pfull ≤
              objective2 Pfull Psub) := by
    simpa [Surf, objective1, objective2] using
      (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface_fullSub_iff
        (massTestTaking := massTestTaking)
        (admittedAcademicMerit := admittedAcademicMerit)
        (diversity := diversity) (policyPair := policyPair)
        (Psub := Psub) (Pfull := Pfull) (J1 := J1) (J2 := J2)
        (groupA := groupA) (groupB := groupB)
        (populationShare := populationShare) (feasible1 := feasible1)
        (feasible2 := feasible2))
  refine hsurface.trans ?_
  refine Iff.trans ?_ hfullSubObjective
  constructor
  · rintro ⟨_hf1cur, _hf2cur, hobj1_of_feas, hobj2_of_feas⟩
    exact ⟨hobj1_of_feas hfeasible1SubSub,
      hobj2_of_feas hfeasible2FullFull⟩
  · rintro ⟨hobj1, hobj2⟩
    exact ⟨hfeasible1FullSub, hfeasible2FullSub,
      (fun _ => hobj1), (fun _ => hobj2)⟩

/--
Proposition 5(ii) / Theorem 3(ii) objective bridge from merit crossings.

This is the source-proof route for `(P_full,P_sub)`: construct both
condition-(13) thresholds from the lower and high monotone merit crossings,
use the mass/cutoff identities to recover the paper's `K_g` conditions, and
use the no-expansion/high-threshold split to recover condition (14).
-/
theorem
    paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_merit_crossings
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost maxCost : Group → ℝ} {q1Sub q2Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff fullSubCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (lowTestBasedMerit : Group → ℝ → ℝ) (lowTestFreeMerit : Group → ℝ)
    (highTestBasedMerit : Group → ℝ → ℝ) (highTestFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hlowCont :
      ∀ g, ContinuousOn (lowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAnti :
      ∀ g, StrictAntiOn (lowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAtZero : ∀ g, lowTestFreeMerit g < lowTestBasedMerit g 0)
    (hlowAtMax :
      ∀ g, lowTestBasedMerit g (maxCost g) < lowTestFreeMerit g)
    (hhighCont :
      ∀ g, ContinuousOn (highTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAnti :
      ∀ g, StrictAntiOn (highTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAtZero : ∀ g, highTestFreeMerit g < highTestBasedMerit g 0)
    (hhighAtMax :
      ∀ g, highTestBasedMerit g (maxCost g) < highTestFreeMerit g)
    (hhighAtLowRoot :
      ∀ g c, c ∈ Set.Ioo (0 : ℝ) (maxCost g) →
        lowTestBasedMerit g c = lowTestFreeMerit g →
          highTestFreeMerit g < highTestBasedMerit g c)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hmassFullSubA :
      S.massTestTaking groupA (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullSubCutoff groupA))
    (hmassFullSubB :
      S.massTestTaking groupB (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullSubCutoff groupB))
    (hnoneJ2 :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ¬ objective2 Pfull Pfull ≤ objective2 Pfull Psub)
    (hbothJ2_impossible :
      q2Sub < fullFullCutoff groupA →
        q2Sub < fullFullCutoff groupB → False)
    (honlyA_J2_merit :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            lowTestBasedMerit groupA (testCost groupA) ≤
              lowTestFreeMerit groupA))
    (honlyB_J2_merit :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            lowTestBasedMerit groupB (testCost groupB) ≤
              lowTestFreeMerit groupB))
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpandA_testFree :
      ¬ fullSubCutoff groupA < q1Sub →
        objective1 Psub Psub = highTestFreeMerit groupA)
    (hexpandA_testBased :
      ¬ fullSubCutoff groupA < q1Sub →
        objective1 Pfull Psub =
          highTestBasedMerit groupA (testCost groupA))
    (hnoExpandB :
      fullSubCutoff groupB < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpandB_testFree :
      ¬ fullSubCutoff groupB < q1Sub →
        objective1 Psub Psub = highTestFreeMerit groupB)
    (hexpandB_testBased :
      ¬ fullSubCutoff groupB < q1Sub →
        objective1 Pfull Psub =
          highTestBasedMerit groupB (testCost groupB)) :
    ∃ lowCostThreshold highCostThreshold : Group → ℝ,
      (∀ g, lowCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
          (∀ g, lowTestBasedMerit g (lowCostThreshold g) =
            lowTestFreeMerit g) ∧
            (∀ g, highTestBasedMerit g (highCostThreshold g) =
              highTestFreeMerit g) ∧
              (∀ g, lowCostThreshold g < highCostThreshold g) ∧
                ((objective1 Psub Psub ≤ objective1 Pfull Psub ∧
                    objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
                  glm20Theorem3FullSubCondition S policyPair Psub Pfull
                    groupA groupB testCost lowCostThreshold highCostThreshold
                    q1Sub q2Sub
                    (fun g q =>
                      glm20StrategicSubEstimateMassAbove api
                        (subEstimateLaw g) q)) := by
  rcases
    paper_proposition5_low_and_high_cost_thresholds_of_merit_crossings
      lowTestBasedMerit lowTestFreeMerit highTestBasedMerit highTestFreeMerit
      hmaxCost hlowCont hlowAnti hlowAtZero hlowAtMax hhighCont hhighAnti
      hhighAtZero hhighAtMax hhighAtLowRoot with
    ⟨lowCostThreshold, highCostThreshold, hlowMem, hhighMem, hlowEq,
      hhighEq, hlowLe, _hhighStrict, hhighGe, hlowHigh⟩
  let K := fun g q =>
    glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q
  have honlyA_J2 :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            testCost groupA ≥ lowCostThreshold groupA ∧
              0 < lowCostThreshold groupA ∧
                lowCostThreshold groupA < highCostThreshold groupA) := by
    intro hcut hnot
