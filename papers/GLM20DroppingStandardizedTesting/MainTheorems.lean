    (hsub_pos : ∀ g : Group, 0 < subPrecision g)
    (htest_pos : ∀ g : Group, 0 < testPrecision g)
    (hvalue : 0 < value)
    (hcostRatio :
      ∀ g : Group, cost g / value ∈ Set.Ioo (0 : ℝ) 1) :
    let hscale :
      ∀ g : Group,
        0 < glm20StrategicProjectedScale
          (priorPrecision g) (subPrecision g) (testPrecision g) :=
      fun g => glm20StrategicProjectedScale_pos
        (hprior_pos g) (hsub_pos g) (htest_pos g)
    ∃! equilibrium : ℝ × (Group → ℝ) × (Group → ℝ → Bool),
      glm20Lemma3FullPolicyThresholdEquilibrium standardGaussianQuantileAPI
        (standardGaussianCDFAPI.mixtureTailMass weight law) capacity value
        priorPrecision subPrecision testPrecision cost hscale equilibrium := by
  intro hscale
  exact
    paper_lemma3_full_policy_threshold_equilibrium_existsUnique_standardGaussian
      standardGaussianQuantileAPI
      (applicantMass := standardGaussianCDFAPI.mixtureTailMass weight law)
      (capacity := capacity) (totalApplicantMass := ∑ g : Group, weight g)
      (value := value) (priorPrecision := priorPrecision)
      (subPrecision := subPrecision) (testPrecision := testPrecision)
      (cost := cost)
      (standardGaussianCDFAPI.mixtureTailMass_continuous weight law)
      (standardGaussianCDFAPI.mixtureTailMass_strictAnti_threshold
        (law := law) hweight hpos)
      (standardGaussianCDFAPI.mixtureTailMass_tendsto_atBot_sum_weights
        standardGaussianCDF_tendsto_atBot weight law)
      (standardGaussianCDFAPI.mixtureTailMass_tendsto_atTop_zero
        standardGaussianCDF_tendsto_atTop weight law)
      hcapacity hprior_pos hsub_pos htest_pos hvalue hcostRatio

