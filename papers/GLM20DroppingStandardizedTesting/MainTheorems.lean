          0 ≤ glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
              q1Full q2Full scale v1 v2 cost q ↔
            cutoff ≤ q :=
  paper_proposition5_twoFull_apply_payoff_cutoff_existsUnique_of_tail_limits
    standardGaussianCDFAPI standardGaussianCDF_tendsto_atBot
    standardGaussianCDF_tendsto_atTop hscale hcost_pos hcost_lt_v1
    hv2_pos hv2_lt_v1

/--
Proposition 5 support for the source statement that the full/full
test-taking cutoff `\underline q^g_{full,full}` is strictly increasing in the
group cost.

On any cost domain contained in `(0,v1)`, the standard-Gaussian payoff
crossing theorem selects a zero-payoff cutoff for each cost.  The selected
cutoff is strictly increasing in cost by the two-point comparison lemma.
-/
theorem paper_proposition5_standardGaussian_twoFull_apply_payoff_cutoff_function_strictMonoOn_cost
    {q1Full q2Full scale v1 v2 : ℝ} {costDomain : Set ℝ}
    (hscale : 0 < scale) (hv2_pos : 0 < v2) (hv2_lt_v1 : v2 < v1)
    (hcost_pos : ∀ cost ∈ costDomain, 0 < cost)
    (hcost_lt_v1 : ∀ cost ∈ costDomain, cost < v1) :
    ∃ cutoffOfCost : ℝ → ℝ,
      (∀ cost ∈ costDomain,
        glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          q1Full q2Full scale v1 v2 cost (cutoffOfCost cost) = 0 ∧
          ∀ q : ℝ,
