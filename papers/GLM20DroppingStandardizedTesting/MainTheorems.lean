/--
Paper Proposition 3, model-side standard-bivariate endpoint with capacity
defined as the total admitted selection mass.

This removes the capacity-identity premise from the formula-level wrapper:
`capacity` is exactly the sum of admitted group masses at the full-policy
cutoff.
-/
theorem
    paper_proposition3_full_policy_selectionCapacity_ratio_and_standardizedAdmittedAcademicMerit_formulas_standardBivariate
    {groupBPopulationShare mu qFull : ℝ}
    {sigmaTildeA sigmaTildeB aA aB bA bB tauA tauB : ℝ}
    (hpopulation_pos : 0 < groupBPopulationShare)
    (hpopulation_lt_one : groupBPopulationShare < 1)
    (hsigmaA_pos : 0 < sigmaTildeA)
    (hsigmaB_pos : 0 < sigmaTildeB) :
    let capacity :=
      (1 - groupBPopulationShare) * sigmaTildeA *
          glm20Proposition3SelectionCore standardGaussianCDFAPI
