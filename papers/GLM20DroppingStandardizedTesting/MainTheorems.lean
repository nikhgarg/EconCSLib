/--
Proposition 5(ii) / Theorem 3(ii), selected equation-(46) cutoff version of
the full-sub objective bridge.

This specializes
`paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_merit_crossings_interval`
to the source proof's full/full zero-payoff cutoffs.  The low and high
test-based merit functions are admitted-merit formulas composed with selected
equation-(46) cutoffs, so their continuity and strict decrease in test cost
are proved here rather than assumed.
-/
theorem
    paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_selected_twoFull_merit_crossings_interval
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost leftCost rightCost : Group → ℝ} {q1Sub q2Sub : ℝ}
    (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff fullSubCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    {lowQ1Full lowQ2Full lowScale lowV1 lowV2 : Group → ℝ}
    {highQ1Full highQ2Full highScale highV1 highV2 : Group → ℝ}
    (lowCutoffOfCost highCutoffOfCost : Group → ℝ → ℝ)
    (lowMeritOfCutoff : Group → ℝ → ℝ)
    (lowTestFreeMerit : Group → ℝ)
    (highMeritOfCutoff : Group → ℝ → ℝ)
    (highTestFreeMerit : Group → ℝ)
    (hleft_right : ∀ g, leftCost g < rightCost g)
    (hleft_pos : ∀ g, 0 < leftCost g)
    (hcostMem :
      ∀ g, testCost g ∈ Set.Icc (leftCost g) (rightCost g))
    (hlowScale : ∀ g, 0 < lowScale g)
    (hlowV2Pos : ∀ g, 0 < lowV2 g)
    (hlowV2LtV1 : ∀ g, lowV2 g < lowV1 g)
    (hlowZero :
      ∀ g cost, cost ∈ Set.Icc (leftCost g) (rightCost g) →
        glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          (lowQ1Full g) (lowQ2Full g) (lowScale g) (lowV1 g)
          (lowV2 g) cost (lowCutoffOfCost g cost) = 0)
    (hlowMeritCont : ∀ g, Continuous (lowMeritOfCutoff g))
    (hlowMeritAnti : ∀ g, StrictAnti (lowMeritOfCutoff g))
    (hhighScale : ∀ g, 0 < highScale g)
    (hhighV2Pos : ∀ g, 0 < highV2 g)
    (hhighV2LtV1 : ∀ g, highV2 g < highV1 g)
    (hhighZero :
      ∀ g cost, cost ∈ Set.Icc (leftCost g) (rightCost g) →
        glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          (highQ1Full g) (highQ2Full g) (highScale g) (highV1 g)
          (highV2 g) cost (highCutoffOfCost g cost) = 0)
    (hhighMeritCont : ∀ g, Continuous (highMeritOfCutoff g))
    (hhighMeritAnti : ∀ g, StrictAnti (highMeritOfCutoff g))
    (hlowAtLeft :
      ∀ g,
        lowTestFreeMerit g <
          lowMeritOfCutoff g (lowCutoffOfCost g (leftCost g)))
    (hlowAtRight :
      ∀ g,
        lowMeritOfCutoff g (lowCutoffOfCost g (rightCost g)) <
          lowTestFreeMerit g)
    (hhighAtLeft :
      ∀ g,
        highTestFreeMerit g <
          highMeritOfCutoff g (highCutoffOfCost g (leftCost g)))
    (hhighAtRight :
      ∀ g,
        highMeritOfCutoff g (highCutoffOfCost g (rightCost g)) <
          highTestFreeMerit g)
    (hhighAtLowRoot :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        lowMeritOfCutoff g (lowCutoffOfCost g c) = lowTestFreeMerit g →
          highTestFreeMerit g <
            highMeritOfCutoff g (highCutoffOfCost g c))
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove standardGaussianCDFAPI
          (subEstimateLaw groupA) (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove standardGaussianCDFAPI
          (subEstimateLaw groupB) (fullFullCutoff groupB))
    (hmassFullSubA :
      S.massTestTaking groupA (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove standardGaussianCDFAPI
          (subEstimateLaw groupA) (fullSubCutoff groupA))
    (hmassFullSubB :
      S.massTestTaking groupB (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove standardGaussianCDFAPI
          (subEstimateLaw groupB) (fullSubCutoff groupB))
    (hnoneJ2 :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ¬ objective2 Pfull Pfull ≤ objective2 Pfull Psub)
    (hbothJ2_impossible :
      q2Sub < fullFullCutoff groupA →
        q2Sub < fullFullCutoff groupB → False)
    (honlyA_J2_merit :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            lowMeritOfCutoff groupA
                (lowCutoffOfCost groupA (testCost groupA)) ≤
              lowTestFreeMerit groupA))
    (honlyB_J2_merit :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            lowMeritOfCutoff groupB
                (lowCutoffOfCost groupB (testCost groupB)) ≤
              lowTestFreeMerit groupB))
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpandA_testFree :
      ¬ fullSubCutoff groupA < q1Sub →
        objective1 Psub Psub = highTestFreeMerit groupA)
    (hexpandA_testBased :
      ¬ fullSubCutoff groupA < q1Sub →
        objective1 Pfull Psub =
          highMeritOfCutoff groupA
            (highCutoffOfCost groupA (testCost groupA)))
    (hnoExpandB :
      fullSubCutoff groupB < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpandB_testFree :
      ¬ fullSubCutoff groupB < q1Sub →
        objective1 Psub Psub = highTestFreeMerit groupB)
    (hexpandB_testBased :
      ¬ fullSubCutoff groupB < q1Sub →
        objective1 Pfull Psub =
          highMeritOfCutoff groupB
            (highCutoffOfCost groupB (testCost groupB))) :
    ∃ lowCostThreshold highCostThreshold : Group → ℝ,
      (∀ g, lowCostThreshold g ∈
        Set.Ioo (leftCost g) (rightCost g)) ∧
        (∀ g, highCostThreshold g ∈
          Set.Ioo (leftCost g) (rightCost g)) ∧
          (∀ g,
            lowMeritOfCutoff g
                (lowCutoffOfCost g (lowCostThreshold g)) =
              lowTestFreeMerit g) ∧
            (∀ g,
              highMeritOfCutoff g
                  (highCutoffOfCost g (highCostThreshold g)) =
                highTestFreeMerit g) ∧
              (∀ g, 0 < lowCostThreshold g) ∧
                (∀ g, lowCostThreshold g < highCostThreshold g) ∧
                  ((objective1 Psub Psub ≤ objective1 Pfull Psub ∧
                      objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
                    glm20Theorem3FullSubCondition S policyPair Psub Pfull
                      groupA groupB testCost lowCostThreshold
                      highCostThreshold q1Sub q2Sub
                      (fun g q =>
                        glm20StrategicSubEstimateMassAbove
                          standardGaussianCDFAPI (subEstimateLaw g) q)) := by
  let lowTestBasedMerit : Group → ℝ → ℝ := fun g cost =>
    lowMeritOfCutoff g (lowCutoffOfCost g cost)
  let highTestBasedMerit : Group → ℝ → ℝ := fun g cost =>
    highMeritOfCutoff g (highCutoffOfCost g cost)
  have hlowRegular :
      ∀ g,
        ContinuousOn (lowTestBasedMerit g)
            (Set.Icc (leftCost g) (rightCost g)) ∧
          StrictAntiOn (lowTestBasedMerit g)
            (Set.Icc (leftCost g) (rightCost g)) := by
    intro g
    exact
      paper_proposition5_twoFull_cost_merit_continuous_strictAntiOn_of_zero_payoff_cutoff
        standardGaussianCDFAPI
        (q1Full := lowQ1Full g) (q2Full := lowQ2Full g)
        (scale := lowScale g) (v1 := lowV1 g) (v2 := lowV2 g)
        (costDomain := Set.Icc (leftCost g) (rightCost g))
        (cutoffDomain := Set.univ)
        (cutoffOfCost := lowCutoffOfCost g)
        (meritOfCutoff := lowMeritOfCutoff g)
        (hlowScale g) (hlowV2Pos g) (hlowV2LtV1 g)
        (by
          intro cost hcost
          exact hlowZero g cost hcost)
        (by intro cost hcost; simp)
        (hlowMeritCont g).continuousOn
        (by
          intro x _hx y _hy hxy
          exact hlowMeritAnti g hxy)
  have hhighRegular :
      ∀ g,
        ContinuousOn (highTestBasedMerit g)
            (Set.Icc (leftCost g) (rightCost g)) ∧
          StrictAntiOn (highTestBasedMerit g)
            (Set.Icc (leftCost g) (rightCost g)) := by
    intro g
    exact
      paper_proposition5_twoFull_cost_merit_continuous_strictAntiOn_of_zero_payoff_cutoff
        standardGaussianCDFAPI
        (q1Full := highQ1Full g) (q2Full := highQ2Full g)
        (scale := highScale g) (v1 := highV1 g) (v2 := highV2 g)
        (costDomain := Set.Icc (leftCost g) (rightCost g))
        (cutoffDomain := Set.univ)
        (cutoffOfCost := highCutoffOfCost g)
        (meritOfCutoff := highMeritOfCutoff g)
        (hhighScale g) (hhighV2Pos g) (hhighV2LtV1 g)
        (by
          intro cost hcost
          exact hhighZero g cost hcost)
        (by intro cost hcost; simp)
        (hhighMeritCont g).continuousOn
        (by
          intro x _hx y _hy hxy
          exact hhighMeritAnti g hxy)
  simpa [lowTestBasedMerit, highTestBasedMerit] using
    (paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_merit_crossings_interval
      (S := S) (policyPair := policyPair) (Psub := Psub)
      (Pfull := Pfull) (groupA := groupA) (groupB := groupB)
      (testCost := testCost) (leftCost := leftCost)
      (rightCost := rightCost) (q1Sub := q1Sub) (q2Sub := q2Sub)
      standardGaussianCDFAPI subEstimateLaw
      (fullFullCutoff := fullFullCutoff) (fullSubCutoff := fullSubCutoff)
      objective1 objective2 lowTestBasedMerit lowTestFreeMerit
      highTestBasedMerit highTestFreeMerit hleft_right hleft_pos
      hcostMem (fun g => (hlowRegular g).1)
      (fun g => (hlowRegular g).2) hlowAtLeft hlowAtRight
      (fun g => (hhighRegular g).1) (fun g => (hhighRegular g).2)
      hhighAtLeft hhighAtRight hhighAtLowRoot hmassFullFullA
      hmassFullFullB hmassFullSubA hmassFullSubB hnoneJ2
      hbothJ2_impossible
      (by
        intro hcut hnot
        simpa [lowTestBasedMerit] using honlyA_J2_merit hcut hnot)
      (by
        intro hcut hnot
        simpa [lowTestBasedMerit] using honlyB_J2_merit hcut hnot)
      hnoExpandA
      (by
        intro hnot
        simpa [highTestBasedMerit] using hexpandA_testFree hnot)
      (by
        intro hnot
        simpa [highTestBasedMerit] using hexpandA_testBased hnot)
      hnoExpandB
      (by
        intro hnot
        simpa [highTestBasedMerit] using hexpandB_testFree hnot)
      (by
        intro hnot
        simpa [highTestBasedMerit] using hexpandB_testBased hnot))

/--
Proposition 5(ii) / Theorem 3(ii), selected equation-(46) cutoff version with
the paper's full/full capacity-fill contradiction.

This combines the selected full/full zero-payoff cutoffs with the source
capacity equation at `q^*_{2,sub}`.  Thus the both-groups condition-(13)
branch is derived from capacity rather than passed as an opaque case split.
-/
theorem
    paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_selected_twoFull_merit_crossings_interval_and_capacity
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
