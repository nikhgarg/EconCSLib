            (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
              lowTestFreeMerit g < lowTestBasedMerit g c ↔
                c < lowCostThreshold) ∧
              (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
                lowTestBasedMerit g c < lowTestFreeMerit g ↔
                  lowCostThreshold < c) ∧
                (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
