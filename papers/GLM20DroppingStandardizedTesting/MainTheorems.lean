  have hanti :
      ∀ g : Group,
        StrictAnti
          (glm20Lemma3StrategicApplicantComponent standardGaussianQuantileAPI
            jointApplyAdmitMass priorPrecision subPrecision testPrecision cost
            value g) := by
    intro g
    simpa [jointApplyAdmitMass] using
