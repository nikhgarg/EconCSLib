        hlowPos groupA, hlowHigh groupA⟩
    · intro hcost
      exact hobjective_merit.mpr (hmerit_cost.mpr hcost.1)
  have honlyB_J2 :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            testCost groupB ≥ lowCostThreshold groupB ∧
              0 < lowCostThreshold groupB ∧
                lowCostThreshold groupB < highCostThreshold groupB) := by
    intro hcut hnot
    have hobjective_merit := honlyB_J2_merit hcut hnot
    have hmerit_cost := hlowLe groupB (testCost groupB) (hcostMem groupB)
    constructor
    · intro hobjective
      exact ⟨hmerit_cost.mp (hobjective_merit.mp hobjective),
