/--
Lemma 3 full-policy threshold-equilibrium object.

The equilibrium data are the school's full-policy admission cutoff, the
group-specific student application cutoffs, and the student application
strategy.  The predicate expands the paper's content: the school cutoff
realizes capacity, each group cutoff has the displayed inverse-CDF formula, and
the student strategy is the threshold rule that pointwise maximizes the
apply/not-apply payoff.
-/
def glm20Lemma3FullPolicyThresholdEquilibrium
    {Group : Type*}
    (Q : StandardGaussianQuantileAPI)
    (applicantMass : ℝ → ℝ) (capacity value : ℝ)
    (priorPrecision subPrecision testPrecision cost : Group → ℝ)
    (hscale :
      ∀ g : Group,
        0 < glm20StrategicProjectedScale
          (priorPrecision g) (subPrecision g) (testPrecision g))
    (equilibrium : ℝ × (Group → ℝ) × (Group → ℝ → Bool)) : Prop :=
  let admissionThreshold := equilibrium.1
  let groupCutoff := equilibrium.2.1
  let strategy := equilibrium.2.2
  glm20CapacityThreshold applicantMass capacity admissionThreshold ∧
    (∀ g : Group,
      groupCutoff g =
        admissionThreshold -
          glm20StrategicProjectedScale
            (priorPrecision g) (subPrecision g) (testPrecision g) *
            Q.quantile (1 - cost g / value)) ∧
      (∀ g : Group, ∀ q : ℝ, ∀ apply : Bool,
        glm20StrategicApplyPayoff value (cost g)
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale :=
                  glm20StrategicProjectedScale
                    (priorPrecision g) (subPrecision g) (testPrecision g)
                scale_pos := hscale g }
              admissionThreshold)
            apply ≤
          glm20StrategicApplyPayoff value (cost g)
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale :=
                  glm20StrategicProjectedScale
                    (priorPrecision g) (subPrecision g) (testPrecision g)
                scale_pos := hscale g }
              admissionThreshold)
            (strategy g q)) ∧
        strategy = fun g q => decide (groupCutoff g ≤ q)

/--
Lemma 3 strategic applicant mass after substituting the student cutoff formula.

`jointApplyAdmitMass g qApply qAdmit` is the source-model mass of group-`g`
students who apply when the group application threshold is `qApply` and would
be admitted by the school cutoff `qAdmit`.  Lemma 3's school fixed point uses
this mass with
`qApply = qAdmit - scale_g * Phi^{-1}(1 - c_g / v)`.
-/
def glm20Lemma3StrategicApplicantComponent
    {Group : Type*}
    (Q : StandardGaussianQuantileAPI)
    (jointApplyAdmitMass : Group → ℝ → ℝ → ℝ)
    (priorPrecision subPrecision testPrecision cost : Group → ℝ)
    (value : ℝ) (g : Group) (qAdmit : ℝ) : ℝ :=
  jointApplyAdmitMass g
    (qAdmit -
      glm20StrategicProjectedScale
        (priorPrecision g) (subPrecision g) (testPrecision g) *
        Q.quantile (1 - cost g / value))
    qAdmit

/-- Eq. (35) aggregate strategic applicant mass, after substituting Eq. (7). -/
def glm20Lemma3StrategicApplicantMass
    {Group : Type*} [Fintype Group]
    (Q : StandardGaussianQuantileAPI)
    (jointApplyAdmitMass : Group → ℝ → ℝ → ℝ)
    (priorPrecision subPrecision testPrecision cost : Group → ℝ)
    (value qAdmit : ℝ) : ℝ :=
  ∑ g : Group,
    glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
      priorPrecision subPrecision testPrecision cost value g qAdmit

/--
Eq. (35) regularity bridge for Lemma 3.

The paper's fixed point uses a finite sum over groups after substituting the
group application cutoff from Eq. (7).  This theorem reduces the global
continuity, strict decrease, and endpoint hypotheses for that fixed point to
the corresponding component facts for each group.
-/
theorem glm20Lemma3StrategicApplicantMass_regular_of_components
    (Q : StandardGaussianQuantileAPI)
    {Group : Type*} [Fintype Group] [Nonempty Group]
    (jointApplyAdmitMass : Group → ℝ → ℝ → ℝ)
    {totalApplicantMass : Group → ℝ}
    {priorPrecision subPrecision testPrecision cost : Group → ℝ}
    {value : ℝ}
    (hcont :
      ∀ g : Group,
        Continuous
          (glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
            priorPrecision subPrecision testPrecision cost value g))
    (hanti :
      ∀ g : Group,
        StrictAnti
          (glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
            priorPrecision subPrecision testPrecision cost value g))
    (hatBot :
      ∀ g : Group,
        Filter.Tendsto
          (glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
            priorPrecision subPrecision testPrecision cost value g)
          Filter.atBot (nhds (totalApplicantMass g)))
    (hatTop :
      ∀ g : Group,
        Filter.Tendsto
          (glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
            priorPrecision subPrecision testPrecision cost value g)
          Filter.atTop (nhds 0)) :
    Continuous
        (glm20Lemma3StrategicApplicantMass Q jointApplyAdmitMass
          priorPrecision subPrecision testPrecision cost value) ∧
      StrictAnti
        (glm20Lemma3StrategicApplicantMass Q jointApplyAdmitMass
          priorPrecision subPrecision testPrecision cost value) ∧
      Filter.Tendsto
        (glm20Lemma3StrategicApplicantMass Q jointApplyAdmitMass
          priorPrecision subPrecision testPrecision cost value)
        Filter.atBot (nhds (∑ g : Group, totalApplicantMass g)) ∧
      Filter.Tendsto
        (glm20Lemma3StrategicApplicantMass Q jointApplyAdmitMass
          priorPrecision subPrecision testPrecision cost value)
        Filter.atTop (nhds 0) := by
  classical
  refine ⟨?_, ?_, ?_, ?_⟩
  · dsimp [glm20Lemma3StrategicApplicantMass]
    exact continuous_finset_sum (Finset.univ : Finset Group)
      (fun g _ => hcont g)
  · intro x y hxy
    dsimp [glm20Lemma3StrategicApplicantMass]
    refine Finset.sum_lt_sum (by
      intro g _hg
      exact (hanti g hxy).le) ?_
    let g0 : Group := Classical.choice (inferInstance : Nonempty Group)
    exact ⟨g0, Finset.mem_univ g0, hanti g0 hxy⟩
  · dsimp [glm20Lemma3StrategicApplicantMass]
    exact tendsto_finset_sum (Finset.univ : Finset Group)
      (fun g _ => hatBot g)
  · dsimp [glm20Lemma3StrategicApplicantMass]
    simpa [Finset.sum_const_zero] using
      (tendsto_finset_sum (Finset.univ : Finset Group)
        (fun g _ => hatTop g))

/--
Paper Lemma 3, source-shaped full-policy equilibrium theorem.

Paper statement: under `P_full`, there is a unique equilibrium
`(α*,Y*)`; the school uses a full-score cutoff solving the capacity equation,
and each group has a cutoff `q^g` such that students test iff
`\tilde q_sub >= q^g`, with the inverse-CDF formula in Equation (7).

This theorem closes that statement for a source-model applicant-mass function
whose capacity cutoff is continuous, strictly decreasing, and has the source
endpoint limits.  Unlike the legacy certificate endpoint, the conclusion is an
actual unique equilibrium object with the displayed cutoffs and threshold
strategy.
-/
theorem paper_lemma3_full_policy_threshold_equilibrium_existsUnique_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {Group : Type*}
    {applicantMass : ℝ → ℝ} {capacity totalApplicantMass value : ℝ}
    {priorPrecision subPrecision testPrecision cost : Group → ℝ}
    (hcont : Continuous applicantMass)
    (hanti : StrictAnti applicantMass)
    (hatBot :
      Filter.Tendsto applicantMass Filter.atBot (nhds totalApplicantMass))
    (hatTop :
      Filter.Tendsto applicantMass Filter.atTop (nhds 0))
    (hcapacity : capacity ∈ Set.Ioo (0 : ℝ) totalApplicantMass)
    (hprior_pos : ∀ g : Group, 0 < priorPrecision g)
    (hsub_pos : ∀ g : Group, 0 < subPrecision g)
    (htest_pos : ∀ g : Group, 0 < testPrecision g)
    (hvalue : 0 < value)
    (hcostRatio :
      ∀ g : Group, cost g / value ∈ Set.Ioo (0 : ℝ) 1) :
    let hscale :
      ∀ g : Group,
        0 < glm20StrategicProjectedScale
          (priorPrecision g) (subPrecision g) (testPrecision g) :=
      fun g => glm20StrategicProjectedScale_pos
        (hprior_pos g) (hsub_pos g) (htest_pos g)
    ∃! equilibrium : ℝ × (Group → ℝ) × (Group → ℝ → Bool),
      glm20Lemma3FullPolicyThresholdEquilibrium Q applicantMass capacity value
        priorPrecision subPrecision testPrecision cost hscale equilibrium := by
  intro hscale
  rcases
    paper_lemma3_school_cutoff_existsUnique_and_capacity_region_of_strictAnti_applicant_mass
      hcont hanti hatBot hatTop hcapacity with
    ⟨admissionThreshold, hthreshold, huniqueThreshold⟩
  let groupCutoff : Group → ℝ :=
    fun g =>
      admissionThreshold -
        glm20StrategicProjectedScale
          (priorPrecision g) (subPrecision g) (testPrecision g) *
          Q.quantile (1 - cost g / value)
  let strategy : Group → ℝ → Bool :=
    fun g q => decide (groupCutoff g ≤ q)
  have hbest :
      ∀ g : Group, ∀ q : ℝ, ∀ apply : Bool,
        glm20StrategicApplyPayoff value (cost g)
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale :=
                  glm20StrategicProjectedScale
                    (priorPrecision g) (subPrecision g) (testPrecision g)
                scale_pos := hscale g }
              admissionThreshold)
            apply ≤
          glm20StrategicApplyPayoff value (cost g)
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale :=
                  glm20StrategicProjectedScale
                    (priorPrecision g) (subPrecision g) (testPrecision g)
                scale_pos := hscale g }
              admissionThreshold)
            (strategy g q) := by
    intro g q apply
    have hbest_g :=
      paper_lemma3_precision_cutoff_apply_bestResponse_standardGaussian
        Q (admissionThreshold := admissionThreshold)
        (priorPrecision := priorPrecision g)
        (subPrecision := subPrecision g)
        (testPrecision := testPrecision g)
        (value := value) (cost := cost g)
        (hprior_pos g) (hsub_pos g) (htest_pos g)
        hvalue (hcostRatio g)
    simpa [strategy, groupCutoff] using hbest_g q apply
  have hwitness :
      glm20Lemma3FullPolicyThresholdEquilibrium Q applicantMass capacity value
        priorPrecision subPrecision testPrecision cost hscale
        (admissionThreshold, groupCutoff, strategy) := by
    refine ⟨hthreshold, ?_, hbest, rfl⟩
    intro g
    rfl
  refine ⟨(admissionThreshold, groupCutoff, strategy), hwitness, ?_⟩
  intro equilibrium heq
  rcases equilibrium with ⟨admissionThreshold', groupCutoff', strategy'⟩
  rcases heq with ⟨hthreshold', hcutoff', _hbest', hstrategy'⟩
  have hadmission : admissionThreshold' = admissionThreshold :=
    huniqueThreshold admissionThreshold' hthreshold'
  subst admissionThreshold'
  have hgroupCutoff : groupCutoff' = groupCutoff := by
    funext g
    simpa [groupCutoff] using hcutoff' g
  subst groupCutoff'
  have hstrategy : strategy' = strategy := by
    simpa [strategy] using hstrategy'
  subst strategy'
  rfl

/--
Paper Lemma 3, finite standard-Gaussian applicant-mixture source surface.

This instantiates the source-shaped equilibrium theorem with a concrete finite
Gaussian applicant-score mixture for the school's capacity equation.  The
remaining richer Appendix D.6 task is to identify the paper's application-gated
strategic applicant pool with such a mass expression when that is the intended
source surface.
-/
theorem paper_lemma3_full_policy_threshold_equilibrium_existsUnique_standardGaussian_mixture
    {Group : Type*} [Fintype Group]
    {weight : Group → ℝ} {law : Group → GaussianScaleLaw}
    {capacity value : ℝ}
    {priorPrecision subPrecision testPrecision cost : Group → ℝ}
    (hweight : ∀ g : Group, 0 ≤ weight g)
    (hpos : ∃ g : Group, 0 < weight g)
    (hcapacity : capacity ∈ Set.Ioo (0 : ℝ) (∑ g : Group, weight g))
