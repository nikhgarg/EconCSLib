/--
Paper Lemma 3 standard-bivariate-selection endpoint with the corrected
Appendix-D.6 source precision definitions substituted.

Here `a_g(q)` is the corrected conditional-source affine cutoff,
`\tilde\sigma_g` and `b_g` are the paper's source precision transforms, and
the capacity interval is expressed in the resulting total applicant masses
`π_g \tilde\sigma_g`.
-/
theorem paper_lemma3_full_policy_threshold_equilibrium_existsUnique_of_standardBivariate_conditional_source_components
    {Group : Type*} [Fintype Group] [Nonempty Group]
    {capacity value : ℝ}
    {populationShare priorSigma priorPrecision subPrecision testPrecision
      cost mu : Group → ℝ}
    (hpopulation : ∀ g : Group, 0 < populationShare g)
    (hsigma : ∀ g : Group, 0 < priorSigma g)
    (hsigma_sq : ∀ g : Group, priorSigma g ^ 2 = 1 / priorPrecision g)
    (hcapacity :
      capacity ∈ Set.Ioo (0 : ℝ)
        (∑ g : Group,
          populationShare g *
            glm20Proposition3SigmaTildeSource
              (priorSigma g) (priorPrecision g) (testPrecision g)))
    (hprior_pos : ∀ g : Group, 0 < priorPrecision g)
    (hsub_pos : ∀ g : Group, 0 < subPrecision g)
    (htest_pos : ∀ g : Group, 0 < testPrecision g)
    (hvalue : 0 < value)
    (hcostRatio :
      ∀ g : Group, cost g / value ∈ Set.Ioo (0 : ℝ) 1) :
    let sigmaTilde : Group → ℝ :=
      fun g =>
        glm20Proposition3SigmaTildeSource
          (priorSigma g) (priorPrecision g) (testPrecision g)
    let b : Group → ℝ :=
      fun g =>
        glm20Proposition3BSource
          (priorPrecision g) (subPrecision g) (testPrecision g)
    let aOfApply : Group → ℝ → ℝ :=
      fun g qApply =>
        glm20Proposition2AHatConditionalSource
          (priorPrecision g) (subPrecision g) (testPrecision g) (mu g)
          qApply
    let jointApplyAdmitMass : Group → ℝ → ℝ → ℝ :=
      fun g qApply qAdmit =>
        glm20BivariateApplyAdmitMass standardGaussianCDFAPI
          standardBivariateGaussianCDF
          (populationShare g) (sigmaTilde g) (aOfApply g)
          (b g) (mu g) qApply qAdmit
    let hscale :
      ∀ g : Group,
        0 < glm20StrategicProjectedScale
          (priorPrecision g) (subPrecision g) (testPrecision g) :=
      fun g => glm20StrategicProjectedScale_pos
        (hprior_pos g) (hsub_pos g) (htest_pos g)
    ∃! equilibrium : ℝ × (Group → ℝ) × (Group → ℝ → Bool),
      glm20Lemma3FullPolicyThresholdEquilibrium standardGaussianQuantileAPI
        (glm20Lemma3StrategicApplicantMass standardGaussianQuantileAPI
          jointApplyAdmitMass priorPrecision subPrecision testPrecision cost
          value)
        capacity value priorPrecision subPrecision testPrecision cost hscale
        equilibrium := by
  intro sigmaTilde b aOfApply jointApplyAdmitMass hscale
  have hsigmaTilde_pos : ∀ g : Group, 0 < sigmaTilde g := by
    intro g
    exact
      glm20Proposition3SigmaTildeSource_pos
        (hsigma g) (hprior_pos g) (htest_pos g)
  have hAanti :
      ∀ g : Group,
        StrictAnti fun qAdmit : ℝ =>
          (aOfApply g
              (qAdmit -
                glm20StrategicProjectedScale
                  (priorPrecision g) (subPrecision g) (testPrecision g) *
                standardGaussianQuantileAPI.quantile
                  (1 - cost g / value)) +
            b g * mu g) /
            Real.sqrt (1 + sigmaTilde g ^ 2 * b g ^ 2) := by
    intro g
    let offset : ℝ :=
      glm20StrategicProjectedScale
        (priorPrecision g) (subPrecision g) (testPrecision g) *
        standardGaussianQuantileAPI.quantile (1 - cost g / value)
    simpa [sigmaTilde, b, aOfApply, offset, glm20Proposition2AArgument] using
      glm20Proposition2AArgument_conditional_source_strictAnti_along_offset
        (priorSigma := priorSigma g)
        (priorPrecision := priorPrecision g)
        (subPrecisionSum := subPrecision g)
        (fullPrecisionSum := testPrecision g)
        (mu := mu g) (offset := offset)
        (hsigma g) (hsigma_sq g) (hprior_pos g) (hsub_pos g)
        (htest_pos g)
  have hAatBot :
      ∀ g : Group,
        Filter.Tendsto
          (fun qAdmit : ℝ =>
            (aOfApply g
                (qAdmit -
                  glm20StrategicProjectedScale
                    (priorPrecision g) (subPrecision g) (testPrecision g) *
                  standardGaussianQuantileAPI.quantile
                    (1 - cost g / value)) +
              b g * mu g) /
              Real.sqrt (1 + sigmaTilde g ^ 2 * b g ^ 2))
          Filter.atBot Filter.atTop := by
    intro g
    let offset : ℝ :=
      glm20StrategicProjectedScale
        (priorPrecision g) (subPrecision g) (testPrecision g) *
        standardGaussianQuantileAPI.quantile (1 - cost g / value)
    simpa [sigmaTilde, b, aOfApply, offset, glm20Proposition2AArgument] using
      glm20Proposition2AArgument_conditional_source_tendsto_atBot_atTop_along_offset
        (priorSigma := priorSigma g)
        (priorPrecision := priorPrecision g)
        (subPrecisionSum := subPrecision g)
        (fullPrecisionSum := testPrecision g)
        (mu := mu g) (offset := offset)
        (hsigma g) (hsigma_sq g) (hprior_pos g) (hsub_pos g)
        (htest_pos g)
  exact
    paper_lemma3_full_policy_threshold_equilibrium_existsUnique_of_standardBivariate_selection_components_regular
      (populationShare := populationShare)
      (sigmaTilde := sigmaTilde)
      (b := b) (mu := mu)
      (aOfApply := aOfApply)
      (priorPrecision := priorPrecision)
      (subPrecision := subPrecision)
      (testPrecision := testPrecision)
      (cost := cost)
      (capacity := capacity) (value := value)
      (fun g =>
        by
          simpa [aOfApply] using
            glm20Proposition2AHatConditionalSource_continuous
              (priorPrecision g) (subPrecision g) (testPrecision g) (mu g))
      hpopulation hsigmaTilde_pos hAanti hAatBot
      (by simpa [sigmaTilde] using hcapacity)
      hprior_pos hsub_pos htest_pos hvalue hcostRatio

