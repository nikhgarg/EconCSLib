/--
Proposition 2 local uniqueness support.

For fixed school cutoffs, any pointwise best-response application strategy that
uses the paper's apply-on-indifference convention at the two displayed student
cutoffs is exactly the two-school application-region indicator.
-/
theorem paper_proposition2_two_school_application_region_unique_strategy_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold school2SubThreshold scale cost v1 v2 : ℝ}
    (hscale : 0 < scale) (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioLow : cost / v1 ∈ Set.Ioo (0 : ℝ) 1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ lowCutoff highCutoff : ℝ,
      lowCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / v1) ∧
      highCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / (v1 - v2)) ∧
      lowCutoff < highCutoff ∧
      ∀ strategy : ℝ → Bool,
        (∀ q : ℝ, ∀ apply : Bool,
          glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
              (Q.cdfAPI.thresholdPassProb
                { mean := q, scale := scale, scale_pos := hscale }
                admissionThreshold)
              q apply ≤
            glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
              (Q.cdfAPI.thresholdPassProb
                { mean := q, scale := scale, scale_pos := hscale }
                admissionThreshold)
              q (strategy q)) →
        strategy lowCutoff =
          decide
            ((lowCutoff < school2SubThreshold ∧ lowCutoff ≤ lowCutoff) ∨
              (school2SubThreshold ≤ lowCutoff ∧ highCutoff ≤ lowCutoff)) →
        strategy highCutoff =
          decide
            ((highCutoff < school2SubThreshold ∧ lowCutoff ≤ highCutoff) ∨
              (school2SubThreshold ≤ highCutoff ∧ highCutoff ≤ highCutoff)) →
        strategy =
          fun q : ℝ =>
            decide
              ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
                (school2SubThreshold ≤ q ∧ highCutoff ≤ q)) := by
  rcases
    paper_proposition2_two_school_application_region_standardGaussian
      Q (admissionThreshold := admissionThreshold)
      (school2SubThreshold := school2SubThreshold) (scale := scale)
      (cost := cost) (v1 := v1) (v2 := v2)
      hscale hcost hv1 hdiff_pos hdiff_lt_v1
      hcostRatioLow hcostRatioHigh with
    ⟨lowCutoff, highCutoff, hlow_eq, hhigh_eq, hlt, _hregion⟩
  refine ⟨lowCutoff, highCutoff, hlow_eq, hhigh_eq, hlt, ?_⟩
  intro strategy hbest htieLow htieHigh
  funext q
  let admissionProbability :=
    Q.cdfAPI.thresholdPassProb
      { mean := q, scale := scale, scale_pos := hscale }
      admissionThreshold
  have hlow_pos :
      0 < v1 * admissionProbability - cost ↔ lowCutoff < q := by
    rw [hlow_eq]
    exact
      paper_lemma3_apply_payoff_positive_iff_above_gaussian_cutoff
        Q hscale hv1 hcostRatioLow
  have hlow_neg :
      v1 * admissionProbability - cost < 0 ↔ q < lowCutoff := by
    rw [hlow_eq]
    exact
      paper_lemma3_apply_payoff_negative_iff_below_gaussian_cutoff
        Q hscale hv1 hcostRatioLow
  have hhigh_pos :
      0 < (v1 - v2) * admissionProbability - cost ↔ highCutoff < q := by
    rw [hhigh_eq]
    exact
      paper_lemma3_apply_payoff_positive_iff_above_gaussian_cutoff
        Q hscale hdiff_pos hcostRatioHigh
  have hhigh_neg :
      (v1 - v2) * admissionProbability - cost < 0 ↔ q < highCutoff := by
    rw [hhigh_eq]
    exact
      paper_lemma3_apply_payoff_negative_iff_below_gaussian_cutoff
        Q hscale hdiff_pos hcostRatioHigh
  by_cases hbelowSchool2 : q < school2SubThreshold
  · by_cases haboveLow : lowCutoff < q
    · have hstrategy : strategy q = true := by
        cases hs : strategy q
        · have hle := hbest q true
          rw [hs] at hle
          simp [glm20StrategicTwoSchoolApplyPayoff, hbelowSchool2] at hle
          have hpayoff : 0 < v1 * admissionProbability - cost :=
            hlow_pos.mpr haboveLow
          linarith
        · rfl
      have hregion :
          (q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
            (school2SubThreshold ≤ q ∧ highCutoff ≤ q) :=
        Or.inl ⟨hbelowSchool2, haboveLow.le⟩
      rw [hstrategy]
      simp [hregion]
    · by_cases hbelowLow : q < lowCutoff
      · have hstrategy : strategy q = false := by
          cases hs : strategy q
          · rfl
          · have hle := hbest q false
            rw [hs] at hle
            simp [glm20StrategicTwoSchoolApplyPayoff, hbelowSchool2] at hle
            have hpayoff : v1 * admissionProbability - cost < 0 :=
              hlow_neg.mpr hbelowLow
            linarith
        have hnotRegion :
            ¬ ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
              (school2SubThreshold ≤ q ∧ highCutoff ≤ q)) := by
          rintro (⟨_, hlow_le⟩ | ⟨haboveSchool2, _⟩)
          · exact (not_le.mpr hbelowLow) hlow_le
          · exact (not_le.mpr hbelowSchool2) haboveSchool2
        rw [hstrategy]
        simp [hnotRegion]
      · have hq : q = lowCutoff :=
          le_antisymm (le_of_not_gt haboveLow) (le_of_not_gt hbelowLow)
        subst q
        exact htieLow
  · have haboveSchool2 : school2SubThreshold ≤ q :=
      le_of_not_gt hbelowSchool2
    by_cases haboveHigh : highCutoff < q
    · have hstrategy : strategy q = true := by
        cases hs : strategy q
        · have hle := hbest q true
          rw [hs] at hle
          simp [glm20StrategicTwoSchoolApplyPayoff, hbelowSchool2] at hle
          have hpayoff : 0 < (v1 - v2) * admissionProbability - cost :=
            hhigh_pos.mpr haboveHigh
          linarith
        · rfl
      have hregion :
          (q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
            (school2SubThreshold ≤ q ∧ highCutoff ≤ q) :=
        Or.inr ⟨haboveSchool2, haboveHigh.le⟩
      rw [hstrategy]
      simp [hregion]
    · by_cases hbelowHigh : q < highCutoff
      · have hstrategy : strategy q = false := by
          cases hs : strategy q
          · rfl
          · have hle := hbest q false
            rw [hs] at hle
            simp [glm20StrategicTwoSchoolApplyPayoff, hbelowSchool2] at hle
            have hpayoff : (v1 - v2) * admissionProbability - cost < 0 :=
              hhigh_neg.mpr hbelowHigh
            linarith
        have hnotRegion :
            ¬ ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
              (school2SubThreshold ≤ q ∧ highCutoff ≤ q)) := by
          rintro (⟨hbelow, _⟩ | ⟨_, hhigh_le⟩)
          · exact hbelowSchool2 hbelow
          · exact (not_le.mpr hbelowHigh) hhigh_le
        rw [hstrategy]
        simp [hnotRegion]
      · have hq : q = highCutoff :=
          le_antisymm (le_of_not_gt haboveHigh) (le_of_not_gt hbelowHigh)
        subst q
        exact htieHigh

