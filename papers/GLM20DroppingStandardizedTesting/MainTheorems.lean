/--
Paper Proposition 3 source-row endpoint.

This specializes the source-parameter ratio theorem to the displayed capacity,
admitted-share rows `tau_A`/`tau_B`, and displayed `lambda` academic-merit rows.
Thus the public statement no longer asks callers to supply separate
capacity/diversity/merit row-identification hypotheses.
-/
abbrev
    paper_proposition3_full_policy_diversity_ratio_and_academic_merit_formulas_source_rows
    {groupBPopulationShare mu qFull : ℝ}
    {priorSigmaA priorPrecisionA subPrecisionSumA fullPrecisionSumA : ℝ}
    {priorSigmaB priorPrecisionB subPrecisionSumB fullPrecisionSumB : ℝ}
    {aA aB : ℝ}
    (hpopulation_pos : 0 < groupBPopulationShare)
    (hpopulation_lt_one : groupBPopulationShare < 1)
    (hsigmaA_pos : 0 < priorSigmaA)
    (hpriorA_pos : 0 < priorPrecisionA)
    (hfullA_pos : 0 < fullPrecisionSumA)
    (hsigmaB_pos : 0 < priorSigmaB)
    (hpriorB_pos : 0 < priorPrecisionB)
    (hfullB_pos : 0 < fullPrecisionSumB) :=
  let sigmaTildeA :=
    glm20Proposition3SigmaTildeSource
      priorSigmaA priorPrecisionA fullPrecisionSumA
  let sigmaTildeB :=
    glm20Proposition3SigmaTildeSource
      priorSigmaB priorPrecisionB fullPrecisionSumB
  let bA :=
    glm20Proposition3BSource
      priorPrecisionA subPrecisionSumA fullPrecisionSumA
  let bB :=
    glm20Proposition3BSource
      priorPrecisionB subPrecisionSumB fullPrecisionSumB
  let capacity :=
    (1 - groupBPopulationShare) * sigmaTildeA *
        glm20Proposition3SelectionCore standardGaussianCDFAPI
          standardBivariateGaussianCDF sigmaTildeA aA bA mu qFull +
      groupBPopulationShare * sigmaTildeB *
        glm20Proposition3SelectionCore standardGaussianCDFAPI
          standardBivariateGaussianCDF sigmaTildeB aB bB mu qFull
  let tauA :=
    glm20Proposition3TauFormula standardGaussianCDFAPI
      standardBivariateGaussianCDF (1 - groupBPopulationShare) capacity
      sigmaTildeA aA bA mu qFull
  let tauB :=
    glm20Proposition3TauFormula standardGaussianCDFAPI
      standardBivariateGaussianCDF groupBPopulationShare capacity
      sigmaTildeB aB bB mu qFull
  let academicMeritA :=
    glm20Proposition3LambdaFormula standardGaussianCDFAPI
      aA bA sigmaTildeA tauA mu qFull
  let academicMeritB :=
    glm20Proposition3LambdaFormula standardGaussianCDFAPI
      aB bB sigmaTildeB tauB mu qFull
  paper_proposition3_full_policy_diversity_ratio_and_academic_merit_formulas_source_parameters
    (diversityLevel := tauB) (groupBPopulationShare := groupBPopulationShare)
    (capacity := capacity) (mu := mu) (qFull := qFull)
    (priorSigmaA := priorSigmaA) (priorPrecisionA := priorPrecisionA)
    (subPrecisionSumA := subPrecisionSumA)
    (fullPrecisionSumA := fullPrecisionSumA)
    (priorSigmaB := priorSigmaB) (priorPrecisionB := priorPrecisionB)
    (subPrecisionSumB := subPrecisionSumB)
    (fullPrecisionSumB := fullPrecisionSumB)
    (aA := aA) (aB := aB) (tauA := tauA) (tauB := tauB)
    (academicMeritA := academicMeritA) (academicMeritB := academicMeritB)
    hpopulation_pos hpopulation_lt_one hsigmaA_pos hpriorA_pos hfullA_pos
    hsigmaB_pos hpriorB_pos hfullB_pos rfl rfl rfl rfl

/--
Proposition 6 full-policy diversity formula for school `J1`.

The paper reuses the Proposition 3 bivariate-normal expression for group-B
admitted share at `J1` under `(P_full,P_full)`.
-/
def glm20Proposition6FullDiversityFormula
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full : ℝ) : ℝ :=
  glm20Proposition3TauFormula api bivariateCDF
    groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full

/--
Proposition 6 full-policy diversity formula from the source affine Owen mass.

The Proposition 6 full-policy diversity expression reuses Proposition 3's
admitted-share formula for school `J1`, so the same affine Owen mass bridge
applies directly.
-/
theorem glm20Proposition6FullDiversityFormula_eq_owenAffineSelectionMass
    {groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full : ℝ} :
    glm20Proposition6FullDiversityFormula standardGaussianCDFAPI
        standardBivariateGaussianCDF groupBPopulationShare capacity1
        sigmaTildeB aB bB mu q1Full =
      groupBPopulationShare * sigmaTildeB / capacity1 *
        glm20Proposition3OwenAffineSelectionMass sigmaTildeB aB bB mu
          q1Full := by
  rw [glm20Proposition6FullDiversityFormula,
    paper_proposition3_tau_formula_eq_owenAffineSelectionMass]

/--
Proposition 6 full-policy diversity formula for the concrete correlated
standard-Gaussian CDF.

This is the same displayed left-hand side as Proposition 6, but rewritten as
the underlying vertical-strip probability.  It gives the model-identification
target for the full-policy strategic applicant pool.
-/
theorem glm20Proposition6FullDiversityFormula_eq_correlatedStandardGaussian_verticalUpperStripMass
    {groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full : ℝ} :
    glm20Proposition6FullDiversityFormula standardGaussianCDFAPI
        standardBivariateGaussianCDF groupBPopulationShare capacity1
        sigmaTildeB aB bB mu q1Full =
      groupBPopulationShare * sigmaTildeB / capacity1 *
        verticalUpperStripMass
          (correlatedStandardGaussianLaw
            (-(sigmaTildeB * bB) /
              Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2)))
          ((aB + bB * mu) / Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2))
          ((q1Full - mu) / sigmaTildeB) := by
  rw [glm20Proposition6FullDiversityFormula,
    paper_proposition3_tau_formula_eq_correlatedStandardGaussian_verticalUpperStripMass]

/--
Proposition 6 full-policy diversity formula with group B's raw source
precision parameters substituted.
-/
theorem
    glm20Proposition6FullDiversityFormula_sourceParameters_eq_correlatedStandardGaussian_verticalUpperStripMass
    {groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
      subPrecisionSumB fullPrecisionSumB aB mu q1Full : ℝ} :
    glm20Proposition6FullDiversityFormula standardGaussianCDFAPI
        standardBivariateGaussianCDF groupBPopulationShare capacity1
        (glm20Proposition3SigmaTildeSource
          priorSigmaB priorPrecisionB fullPrecisionSumB)
        aB
        (glm20Proposition3BSource
          priorPrecisionB subPrecisionSumB fullPrecisionSumB)
        mu q1Full =
      groupBPopulationShare *
          glm20Proposition3SigmaTildeSource
            priorSigmaB priorPrecisionB fullPrecisionSumB /
        capacity1 *
        verticalUpperStripMass
          (correlatedStandardGaussianLaw
            (-(glm20Proposition3SigmaTildeSource
                  priorSigmaB priorPrecisionB fullPrecisionSumB *
                glm20Proposition3BSource
                  priorPrecisionB subPrecisionSumB fullPrecisionSumB) /
              Real.sqrt
                (1 +
                  glm20Proposition3SigmaTildeSource
                      priorSigmaB priorPrecisionB fullPrecisionSumB ^ 2 *
                    glm20Proposition3BSource
                      priorPrecisionB subPrecisionSumB fullPrecisionSumB ^ 2)))
          ((aB +
              glm20Proposition3BSource
                priorPrecisionB subPrecisionSumB fullPrecisionSumB * mu) /
            Real.sqrt
              (1 +
                glm20Proposition3SigmaTildeSource
                    priorSigmaB priorPrecisionB fullPrecisionSumB ^ 2 *
                  glm20Proposition3BSource
                    priorPrecisionB subPrecisionSumB fullPrecisionSumB ^ 2))
          ((q1Full - mu) /
            glm20Proposition3SigmaTildeSource
              priorSigmaB priorPrecisionB fullPrecisionSumB) :=
  glm20Proposition6FullDiversityFormula_eq_correlatedStandardGaussian_verticalUpperStripMass

/--
Proposition 6 test-free diversity formula for school `J1`.

Paper expression:
`1 - Φ(Φ^{-1}((1-C_1)(1-π)+π) * σtilde_{A,sub}/σtilde_{B,sub})`.
-/
def glm20Proposition6SubDiversityFormula
    (Q : StandardGaussianQuantileAPI)
    (capacity1 groupBPopulationShare sigmaTildeASub sigmaTildeBSub : ℝ) : ℝ :=
  1 - Q.cdfAPI.cdf
    (Q.quantile ((1 - capacity1) * (1 - groupBPopulationShare) +
        groupBPopulationShare) * sigmaTildeASub / sigmaTildeBSub)

/--
Proposition 6 test-free diversity formula as written in the TeX statement.

Paper expression:
`1 - Phi(Phi^{-1}(1-C_1) *
  sqrt((1-pi) * sigmaTildeASubOverBSub + pi))`.

The repository also keeps `glm20Proposition6SubDiversityFormula`, the
standardized-tail formula used by the existing model-identification helper.
This definition is intentionally paper-facing: it mirrors
`source_tex/proofs_twoschools_revision.tex` directly.
-/
def glm20Proposition6PaperSubDiversityFormula
    (Q : StandardGaussianQuantileAPI)
    (capacity1 groupBPopulationShare sigmaTildeASubOverBSub : ℝ) : ℝ :=
  1 - Q.cdfAPI.cdf
    (Q.quantile (1 - capacity1) *
      Real.sqrt
        ((1 - groupBPopulationShare) * sigmaTildeASubOverBSub +
          groupBPopulationShare))

/--
Proposition 6 source definition of the test-free scale
`\tilde{\sigma}_{g,\sub}` as it appears in
`source_tex/proofs_twoschools_revision.tex`.

Paper source:
`\tilde{\sigma}_{g,\sub} :=
  \sigma \frac{\sum_{k\in\sub}\sigma_{gk}^{-2}}
    {\sigma^{-2}+\sum_{k\in\sub}\sigma_{gk}^{-2}}`.
-/
def glm20Proposition6SubSigmaTildeSource
    (priorSigma priorPrecision subPrecisionSum : ℝ) : ℝ := priorSigma * (subPrecisionSum / (priorPrecision + subPrecisionSum))

/-- The Proposition 6 source test-free scale is positive under positive precisions. -/
theorem glm20Proposition6SubSigmaTildeSource_pos
    {priorSigma priorPrecision subPrecisionSum : ℝ}
    (hsigma : 0 < priorSigma) (hprior : 0 < priorPrecision)
    (hsub : 0 < subPrecisionSum) :
    0 <
      glm20Proposition6SubSigmaTildeSource
        priorSigma priorPrecision subPrecisionSum := by
  have hden : 0 < priorPrecision + subPrecisionSum := by linarith
  exact mul_pos hsigma (div_pos hsub hden)

/--
Proposition 6 source test-free scale ratio
`\tilde{\sigma}_{A,\sub}/\tilde{\sigma}_{B,\sub}`.
-/
def glm20Proposition6SubSigmaTildeSourceRatio
    (priorSigmaA priorPrecisionA subPrecisionSumA
      priorSigmaB priorPrecisionB subPrecisionSumB : ℝ) : ℝ :=
  glm20Proposition6SubSigmaTildeSource
      priorSigmaA priorPrecisionA subPrecisionSumA /
    glm20Proposition6SubSigmaTildeSource
      priorSigmaB priorPrecisionB subPrecisionSumB

/-- The Proposition 6 source test-free scale ratio is positive. -/
theorem glm20Proposition6SubSigmaTildeSourceRatio_pos
    {priorSigmaA priorPrecisionA subPrecisionSumA
      priorSigmaB priorPrecisionB subPrecisionSumB : ℝ}
    (hsigmaA : 0 < priorSigmaA) (hpriorA : 0 < priorPrecisionA)
    (hsubA : 0 < subPrecisionSumA)
    (hsigmaB : 0 < priorSigmaB) (hpriorB : 0 < priorPrecisionB)
    (hsubB : 0 < subPrecisionSumB) :
    0 <
      glm20Proposition6SubSigmaTildeSourceRatio
        priorSigmaA priorPrecisionA subPrecisionSumA
        priorSigmaB priorPrecisionB subPrecisionSumB :=
    div_pos
      (glm20Proposition6SubSigmaTildeSource_pos hsigmaA hpriorA hsubA)
      (glm20Proposition6SubSigmaTildeSource_pos hsigmaB hpriorB hsubB)

/--
Proposition 6 test-free formula as a standardized Gaussian tail.

If the test-free group-B score law has mean `mu` and scale
`sigmaTildeBSub`, and the displayed no-test cutoff is
`mu + sigmaTildeASub * Phi^{-1}((1-C_1)(1-pi)+pi)`, then the group-B upper
tail at that cutoff is exactly the right-hand side of Proposition 6.
-/
theorem glm20Proposition6SubDiversityFormula_eq_testFreeGroupBTail
    (Q : StandardGaussianQuantileAPI)
    {capacity1 groupBPopulationShare mu sigmaTildeASub sigmaTildeBSub : ℝ}
    (hsigmaB_pos : 0 < sigmaTildeBSub) :
    let threshold :=
      mu + sigmaTildeASub *
        Q.quantile ((1 - capacity1) * (1 - groupBPopulationShare) +
          groupBPopulationShare)
    let groupBLaw : GaussianScaleLaw :=
      { mean := mu, scale := sigmaTildeBSub, scale_pos := hsigmaB_pos }
    Q.cdfAPI.thresholdPassProb groupBLaw threshold =
      glm20Proposition6SubDiversityFormula Q capacity1 groupBPopulationShare
        sigmaTildeASub sigmaTildeBSub := by
  intro threshold groupBLaw
  have hstd :
      groupBLaw.standardize threshold =
        Q.quantile ((1 - capacity1) * (1 - groupBPopulationShare) +
            groupBPopulationShare) *
          sigmaTildeASub / sigmaTildeBSub := by
    simp [groupBLaw, threshold, GaussianScaleLaw.standardize]
    field_simp [ne_of_gt hsigmaB_pos]
  simp [glm20Proposition6SubDiversityFormula,
    StandardGaussianCDFAPI.thresholdPassProb, StandardGaussianCDFAPI.normalTail,
    StandardGaussianCDFAPI.normalCDF, hstd]

/--
Paper Proposition 6, formula-level diversity criterion.

If the full-policy and test-free diversity levels are identified with the
paper's displayed formulas, and dropping the test is exactly the choice that
strictly improves school `J1` diversity, then Proposition 6's displayed
inequality follows by rewriting.
-/
theorem paper_proposition6_j1_drops_test_iff_diversity_formulas
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {schoolJ1DropsTest : Prop}
    {fullDiversity subDiversity groupBPopulationShare capacity1
      sigmaTildeB aB bB mu q1Full sigmaTildeASub sigmaTildeBSub : ℝ}
    (hdrop_iff : schoolJ1DropsTest ↔ fullDiversity < subDiversity)
    (hfull :
      fullDiversity =
        glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full)
    (hsub :
      subDiversity =
        glm20Proposition6SubDiversityFormula Q
          capacity1 groupBPopulationShare sigmaTildeASub sigmaTildeBSub) :
    schoolJ1DropsTest ↔
      glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full <
        glm20Proposition6SubDiversityFormula Q
          capacity1 groupBPopulationShare sigmaTildeASub sigmaTildeBSub := by
  rw [hdrop_iff, hfull, hsub]

/--
Paper Proposition 6, displayed criterion from a test-free group-B tail
identification.

This version exposes the model-identification premise for the test-free side
as an actual group-B upper-tail probability.  The previous theorem then
standardizes that upper tail to the source's displayed right-hand side.
-/
theorem paper_proposition6_j1_drops_test_iff_full_formula_lt_testFreeGroupBTail
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {schoolJ1DropsTest : Prop}
    {fullDiversity subDiversity groupBPopulationShare capacity1
      sigmaTildeB aB bB mu q1Full sigmaTildeASub sigmaTildeBSub : ℝ}
    (hsigmaBSub_pos : 0 < sigmaTildeBSub)
    (hdrop_iff : schoolJ1DropsTest ↔ fullDiversity < subDiversity)
    (hfull :
      fullDiversity =
        glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full)
    (hsub :
      let threshold :=
        mu + sigmaTildeASub *
          Q.quantile ((1 - capacity1) * (1 - groupBPopulationShare) +
            groupBPopulationShare)
      let groupBLaw : GaussianScaleLaw :=
        { mean := mu, scale := sigmaTildeBSub, scale_pos := hsigmaBSub_pos }
      subDiversity = Q.cdfAPI.thresholdPassProb groupBLaw threshold) :
    schoolJ1DropsTest ↔
      glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full <
        glm20Proposition6SubDiversityFormula Q
          capacity1 groupBPopulationShare sigmaTildeASub sigmaTildeBSub := by
  refine
    paper_proposition6_j1_drops_test_iff_diversity_formulas
      api Q bivariateCDF hdrop_iff hfull ?_
  exact hsub.trans
    (glm20Proposition6SubDiversityFormula_eq_testFreeGroupBTail
      Q (capacity1 := capacity1)
      (groupBPopulationShare := groupBPopulationShare) (mu := mu)
      (sigmaTildeASub := sigmaTildeASub)
      (sigmaTildeBSub := sigmaTildeBSub) hsigmaBSub_pos)

/--
Proposition 6 source-surface predicate: school `J1` drops the test for
diversity when its diversity under `(P_sub,P_full)` is strictly higher than
under `(P_full,P_full)`.
-/
def glm20Proposition6J1DropsTestForDiversity
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J1 : School) (Psub Pfull : Policy) : Prop :=
  S.diversity J1 (policyPair Pfull Pfull) <
    S.diversity J1 (policyPair Psub Pfull)

/--
Proposition 6 source-surface predicate: when school `J1` optimizes only for
diversity and school `J2` keeps the test, `J1` strictly chooses to drop the test
within the binary policy menu `{P_sub, P_full}`.

The strict clause records that `P_sub` is selected because it strictly improves
diversity over staying at `(P_full,P_full)`, while the weak best-response clause
records binary optimality.
-/
def glm20Proposition6J1StrictDiversityBestResponseDropsTest
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J1 : School) (Psub Pfull : Policy) : Prop :=
  (∀ P1' : Policy, P1' = Psub ∨ P1' = Pfull →
    S.diversity J1 (policyPair P1' Pfull) ≤
      S.diversity J1 (policyPair Psub Pfull)) ∧
    S.diversity J1 (policyPair Pfull Pfull) <
      S.diversity J1 (policyPair Psub Pfull)

/--
The Proposition 6 strict diversity-best-response predicate is equivalent to the
plain diversity-improvement comparison because the school has only two policies.
-/
theorem glm20Proposition6J1StrictDiversityBestResponseDropsTest_iff
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J1 : School) {Psub Pfull : Policy} :
    glm20Proposition6J1StrictDiversityBestResponseDropsTest S policyPair J1
        Psub Pfull ↔
      glm20Proposition6J1DropsTestForDiversity S policyPair J1 Psub Pfull := by
  unfold glm20Proposition6J1StrictDiversityBestResponseDropsTest
    glm20Proposition6J1DropsTestForDiversity
  constructor
  · exact And.right
  · intro hdrop
    constructor
    · intro P1' hmem
      rcases hmem with rfl | rfl
      · exact le_rfl
      · exact le_of_lt hdrop
    · exact hdrop

/--
Paper Proposition 6, source-surface diversity criterion.

This version removes the abstract `hdrop_iff` premise: the drop-test event is
defined directly as the school-`J1` diversity improvement from
`(P_full,P_full)` to `(P_sub,P_full)`.
-/
theorem paper_proposition6_j1_drops_test_iff_source_diversity_formulas
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J1 : School) {Psub Pfull : Policy}
    {groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full
      sigmaTildeASub sigmaTildeBSub : ℝ}
    (hfull :
      S.diversity J1 (policyPair Pfull Pfull) =
        glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full)
    (hsub :
      S.diversity J1 (policyPair Psub Pfull) =
        glm20Proposition6SubDiversityFormula Q
          capacity1 groupBPopulationShare sigmaTildeASub sigmaTildeBSub) :
    glm20Proposition6J1DropsTestForDiversity S policyPair J1 Psub Pfull ↔
      glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full <
        glm20Proposition6SubDiversityFormula Q
          capacity1 groupBPopulationShare sigmaTildeASub sigmaTildeBSub := by
  unfold glm20Proposition6J1DropsTestForDiversity
  rw [hfull, hsub]

/--
Paper Proposition 6, source-surface criterion from a test-free group-B tail.

The full-policy side is the displayed Proposition 6 bivariate formula; the
test-free side is identified first as the group-B Gaussian upper tail and then
standardized to the displayed right-hand side.
-/
theorem
    paper_proposition6_j1_drops_test_iff_source_full_formula_lt_testFreeGroupBTail
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J1 : School) {Psub Pfull : Policy}
    {groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full
      sigmaTildeASub sigmaTildeBSub : ℝ}
    (hsigmaBSub_pos : 0 < sigmaTildeBSub)
    (hfull :
      S.diversity J1 (policyPair Pfull Pfull) =
        glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full)
    (hsub :
      let threshold :=
        mu + sigmaTildeASub *
          Q.quantile ((1 - capacity1) * (1 - groupBPopulationShare) +
            groupBPopulationShare)
      let groupBLaw : GaussianScaleLaw :=
        { mean := mu, scale := sigmaTildeBSub, scale_pos := hsigmaBSub_pos }
      S.diversity J1 (policyPair Psub Pfull) =
        Q.cdfAPI.thresholdPassProb groupBLaw threshold) :
    glm20Proposition6J1DropsTestForDiversity S policyPair J1 Psub Pfull ↔
      glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full <
        glm20Proposition6SubDiversityFormula Q
          capacity1 groupBPopulationShare sigmaTildeASub sigmaTildeBSub := by
  refine
    paper_proposition6_j1_drops_test_iff_source_diversity_formulas
      api Q bivariateCDF S policyPair J1 hfull ?_
  exact hsub.trans
    (glm20Proposition6SubDiversityFormula_eq_testFreeGroupBTail
      Q (capacity1 := capacity1)
      (groupBPopulationShare := groupBPopulationShare) (mu := mu)
      (sigmaTildeASub := sigmaTildeASub)
      (sigmaTildeBSub := sigmaTildeBSub) hsigmaBSub_pos)

/--
Paper Proposition 6, source-surface criterion with the full-policy side
identified as the concrete correlated-Gaussian vertical-strip event.

This is the direct model-facing version of the displayed Proposition 6
criterion: school `J1` drops the test for diversity exactly when the verified
full-policy source event expression is below the verified test-free group-B
tail expression.
-/
theorem
    paper_proposition6_j1_drops_test_iff_source_verticalStrip_lt_testFreeFormula
    (Q : StandardGaussianQuantileAPI)
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J1 : School) {Psub Pfull : Policy}
    {groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full
      sigmaTildeASub sigmaTildeBSub : ℝ}
    (hsigmaBSub_pos : 0 < sigmaTildeBSub)
    (hfull :
      S.diversity J1 (policyPair Pfull Pfull) =
        groupBPopulationShare * sigmaTildeB / capacity1 *
          verticalUpperStripMass
            (correlatedStandardGaussianLaw
              (-(sigmaTildeB * bB) /
                Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2)))
            ((aB + bB * mu) / Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2))
            ((q1Full - mu) / sigmaTildeB))
    (hsub :
      let threshold :=
        mu + sigmaTildeASub *
          Q.quantile ((1 - capacity1) * (1 - groupBPopulationShare) +
            groupBPopulationShare)
      let groupBLaw : GaussianScaleLaw :=
        { mean := mu, scale := sigmaTildeBSub, scale_pos := hsigmaBSub_pos }
      S.diversity J1 (policyPair Psub Pfull) =
        Q.cdfAPI.thresholdPassProb groupBLaw threshold) :
    glm20Proposition6J1DropsTestForDiversity S policyPair J1 Psub Pfull ↔
      groupBPopulationShare * sigmaTildeB / capacity1 *
          verticalUpperStripMass
            (correlatedStandardGaussianLaw
              (-(sigmaTildeB * bB) /
                Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2)))
            ((aB + bB * mu) / Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2))
            ((q1Full - mu) / sigmaTildeB) <
        glm20Proposition6SubDiversityFormula Q
          capacity1 groupBPopulationShare sigmaTildeASub sigmaTildeBSub := by
  have hfullFormula :
      S.diversity J1 (policyPair Pfull Pfull) =
        glm20Proposition6FullDiversityFormula standardGaussianCDFAPI
          standardBivariateGaussianCDF groupBPopulationShare capacity1
          sigmaTildeB aB bB mu q1Full :=
    hfull.trans (by
      symm
      exact
        glm20Proposition6FullDiversityFormula_eq_correlatedStandardGaussian_verticalUpperStripMass)
  have hcriterion :=
    paper_proposition6_j1_drops_test_iff_source_full_formula_lt_testFreeGroupBTail
      standardGaussianCDFAPI Q standardBivariateGaussianCDF S policyPair J1
      hsigmaBSub_pos hfullFormula hsub
  rw [glm20Proposition6FullDiversityFormula_eq_correlatedStandardGaussian_verticalUpperStripMass]
    at hcriterion
  exact hcriterion

/--
Paper Proposition 6, source-surface strict diversity-best-response criterion.

This is the theorem-facing version of the paper sentence "when schools optimize
for diversity only, school `J1` drops the test": the left-hand side says
`P_sub` is a strict binary diversity best response against school `J2` keeping
the test, and the right-hand side is the displayed Proposition 6 inequality
with the full-policy term identified as a concrete correlated-Gaussian vertical
strip.
-/
theorem
    paper_proposition6_j1_strict_diversity_best_response_iff_source_verticalStrip_lt_testFreeFormula
    (Q : StandardGaussianQuantileAPI)
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J1 : School) {Psub Pfull : Policy}
    {groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full
      sigmaTildeASub sigmaTildeBSub : ℝ}
    (hsigmaBSub_pos : 0 < sigmaTildeBSub)
    (hfull :
      S.diversity J1 (policyPair Pfull Pfull) =
        groupBPopulationShare * sigmaTildeB / capacity1 *
          verticalUpperStripMass
            (correlatedStandardGaussianLaw
              (-(sigmaTildeB * bB) /
                Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2)))
            ((aB + bB * mu) / Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2))
            ((q1Full - mu) / sigmaTildeB))
    (hsub :
      let threshold :=
        mu + sigmaTildeASub *
          Q.quantile ((1 - capacity1) * (1 - groupBPopulationShare) +
            groupBPopulationShare)
      let groupBLaw : GaussianScaleLaw :=
        { mean := mu, scale := sigmaTildeBSub, scale_pos := hsigmaBSub_pos }
      S.diversity J1 (policyPair Psub Pfull) =
        Q.cdfAPI.thresholdPassProb groupBLaw threshold) :
    glm20Proposition6J1StrictDiversityBestResponseDropsTest S policyPair J1
        Psub Pfull ↔
      groupBPopulationShare * sigmaTildeB / capacity1 *
          verticalUpperStripMass
            (correlatedStandardGaussianLaw
              (-(sigmaTildeB * bB) /
                Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2)))
            ((aB + bB * mu) / Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2))
            ((q1Full - mu) / sigmaTildeB) <
        glm20Proposition6SubDiversityFormula Q
          capacity1 groupBPopulationShare sigmaTildeASub sigmaTildeBSub :=
    (glm20Proposition6J1StrictDiversityBestResponseDropsTest_iff S
      policyPair J1).trans
      (paper_proposition6_j1_drops_test_iff_source_verticalStrip_lt_testFreeFormula
        Q S policyPair J1 hsigmaBSub_pos hfull hsub)

/--
Paper Proposition 6, direct TeX-formula version.

This wrapper mirrors the displayed proposition statement: the full-policy side
is the paper's `Phi - Phi_2` formula and the test-free side is the TeX
`Phi^{-1}(1-C_1)` square-root expression.  The hypotheses are exactly the two
model-identification equations for those displayed diversity levels.
-/
theorem
    paper_proposition6_j1_strict_diversity_best_response_iff_paper_formulas
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J1 : School) {Psub Pfull : Policy}
    {groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full
      sigmaTildeASubOverBSub : ℝ}
    (hfull :
      S.diversity J1 (policyPair Pfull Pfull) =
        glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full)
    (hsub :
      S.diversity J1 (policyPair Psub Pfull) =
        glm20Proposition6PaperSubDiversityFormula Q capacity1
          groupBPopulationShare sigmaTildeASubOverBSub) :
    glm20Proposition6J1StrictDiversityBestResponseDropsTest S policyPair J1
        Psub Pfull ↔
      glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1 sigmaTildeB aB bB mu q1Full <
        glm20Proposition6PaperSubDiversityFormula Q capacity1
          groupBPopulationShare sigmaTildeASubOverBSub := by
  refine
    (glm20Proposition6J1StrictDiversityBestResponseDropsTest_iff S
      policyPair J1).trans ?_
  unfold glm20Proposition6J1DropsTestForDiversity
  rw [hfull, hsub]

/--
Paper Proposition 6, direct TeX-formula version with the paper's raw source
precision parameters substituted for group B's full-policy
`\tilde\sigma_B`, `b_B`, and for the no-test
`\tilde\sigma_{A,\sub}/\tilde\sigma_{B,\sub}` ratio.
-/
theorem
    paper_proposition6_j1_strict_diversity_best_response_iff_source_parameter_formulas
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J1 : School) {Psub Pfull : Policy}
    {groupBPopulationShare capacity1 priorSigmaA priorPrecisionA
      subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB
      fullPrecisionSumB aB mu q1Full : ℝ}
    (hfull :
      S.diversity J1 (policyPair Pfull Pfull) =
        glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1
          (glm20Proposition3SigmaTildeSource
            priorSigmaB priorPrecisionB fullPrecisionSumB)
          aB
          (glm20Proposition3BSource
            priorPrecisionB subPrecisionSumB fullPrecisionSumB)
          mu q1Full)
    (hsub :
      S.diversity J1 (policyPair Psub Pfull) =
        glm20Proposition6PaperSubDiversityFormula Q capacity1
          groupBPopulationShare
          (glm20Proposition6SubSigmaTildeSourceRatio
            priorSigmaA priorPrecisionA subPrecisionSumA
            priorSigmaB priorPrecisionB subPrecisionSumB)) :
    glm20Proposition6J1StrictDiversityBestResponseDropsTest S policyPair J1
        Psub Pfull ↔
      glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1
          (glm20Proposition3SigmaTildeSource
            priorSigmaB priorPrecisionB fullPrecisionSumB)
          aB
          (glm20Proposition3BSource
            priorPrecisionB subPrecisionSumB fullPrecisionSumB)
          mu q1Full <
        glm20Proposition6PaperSubDiversityFormula Q capacity1
          groupBPopulationShare
          (glm20Proposition6SubSigmaTildeSourceRatio
            priorSigmaA priorPrecisionA subPrecisionSumA
            priorSigmaB priorPrecisionB subPrecisionSumB) :=
  paper_proposition6_j1_strict_diversity_best_response_iff_paper_formulas
    api Q bivariateCDF S policyPair J1 hfull hsub

/--
Proposition 6 source-parameter full-policy diversity value.

This is the left-hand side of the displayed Proposition 6 inequality after
substituting the raw source precision parameters for
`\tilde\sigma_B` and `b_B`.
-/
abbrev glm20Proposition6SourceParameterFullDiversityValue
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
      subPrecisionSumB fullPrecisionSumB aB mu q1Full : ℝ) : ℝ :=
  glm20Proposition6FullDiversityFormula api bivariateCDF
    groupBPopulationShare capacity1
    (glm20Proposition3SigmaTildeSource
      priorSigmaB priorPrecisionB fullPrecisionSumB)
    aB
    (glm20Proposition3BSource
      priorPrecisionB subPrecisionSumB fullPrecisionSumB)
    mu q1Full

/--
Proposition 6 source-parameter test-free diversity value.

This is the right-hand side of the displayed Proposition 6 inequality after
substituting the raw source precision parameters for
`\tilde\sigma_{A,sub}/\tilde\sigma_{B,sub}`.
-/
abbrev glm20Proposition6SourceParameterSubDiversityValue
    (Q : StandardGaussianQuantileAPI)
    (capacity1 groupBPopulationShare priorSigmaA priorPrecisionA
      subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB : ℝ) : ℝ :=
  glm20Proposition6PaperSubDiversityFormula Q capacity1
    groupBPopulationShare
    (glm20Proposition6SubSigmaTildeSourceRatio
      priorSigmaA priorPrecisionA subPrecisionSumA
      priorSigmaB priorPrecisionB subPrecisionSumB)

/--
Concrete Proposition 6 full/full diversity row: school `J1`'s entry is the
displayed full-policy source-parameter formula; other schools use `fallback`.
-/
abbrev glm20Proposition6SourceParameterFullFullDiversityRow
    {School : Type*} [DecidableEq School]
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (J1 : School) (fallback : School → ℝ)
    (groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
      subPrecisionSumB fullPrecisionSumB aB mu q1Full : ℝ) : School → ℝ :=
  glm20OverrideSchoolValue J1
    (glm20Proposition6SourceParameterFullDiversityValue api bivariateCDF
      groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
      subPrecisionSumB fullPrecisionSumB aB mu q1Full)
    fallback

/--
Concrete Proposition 6 sub/full diversity row: school `J1`'s entry is the
displayed test-free source-parameter formula; other schools use `fallback`.
-/
abbrev glm20Proposition6SourceParameterSubFullDiversityRow
    {School : Type*} [DecidableEq School]
    (Q : StandardGaussianQuantileAPI)
    (J1 : School) (fallback : School → ℝ)
    (capacity1 groupBPopulationShare priorSigmaA priorPrecisionA
      subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB : ℝ) :
    School → ℝ :=
  glm20OverrideSchoolValue J1
    (glm20Proposition6SourceParameterSubDiversityValue Q capacity1
      groupBPopulationShare priorSigmaA priorPrecisionA subPrecisionSumA
      priorSigmaB priorPrecisionB subPrecisionSumB)
    fallback

/--
Proposition 6 row value: the generated sub/full source-parameter diversity row
has the displayed test-free diversity value at school `J1`.
-/
theorem
    paper_proposition6_source_parameter_subFullDiversityRow_eq_source_value_at_j1
    (Q : StandardGaussianQuantileAPI)
    {School : Type*} [DecidableEq School]
    (fallback : School → ℝ) (J1 : School)
    {capacity1 groupBPopulationShare priorSigmaA priorPrecisionA
      subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB : ℝ} :
    glm20Proposition6SourceParameterSubFullDiversityRow Q J1 fallback
        capacity1 groupBPopulationShare priorSigmaA priorPrecisionA
        subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB J1 =
      glm20Proposition6SourceParameterSubDiversityValue Q capacity1
        groupBPopulationShare priorSigmaA priorPrecisionA subPrecisionSumA
        priorSigmaB priorPrecisionB subPrecisionSumB := by
  simpa [glm20Proposition6SourceParameterSubFullDiversityRow] using
    (glm20OverrideSchoolValue_self
      (target := J1)
      (value :=
        glm20Proposition6SourceParameterSubDiversityValue Q capacity1
          groupBPopulationShare priorSigmaA priorPrecisionA subPrecisionSumA
          priorSigmaB priorPrecisionB subPrecisionSumB)
      fallback)

/--
Proposition 6 row value: the generated full/full source-parameter diversity row
has the displayed full-policy diversity value at school `J1`.
-/
theorem
    paper_proposition6_source_parameter_fullFullDiversityRow_eq_source_value_at_j1
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {School : Type*} [DecidableEq School]
    (fallback : School → ℝ) (J1 : School)
    {groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
      subPrecisionSumB fullPrecisionSumB aB mu q1Full : ℝ} :
    glm20Proposition6SourceParameterFullFullDiversityRow api bivariateCDF J1
        fallback groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
        subPrecisionSumB fullPrecisionSumB aB mu q1Full J1 =
      glm20Proposition6SourceParameterFullDiversityValue api bivariateCDF
        groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
        subPrecisionSumB fullPrecisionSumB aB mu q1Full := by
  simpa [glm20Proposition6SourceParameterFullFullDiversityRow] using
    (glm20OverrideSchoolValue_self
      (target := J1)
      (value :=
        glm20Proposition6SourceParameterFullDiversityValue api bivariateCDF
          groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
          subPrecisionSumB fullPrecisionSumB aB mu q1Full)
      fallback)

/--
Proposition 6 row identity: if the fallback row already has the displayed
test-free diversity value at school `J1`, then generating the source-parameter
sub/full row leaves the whole row unchanged.
-/
theorem paper_proposition6_source_parameter_subFullDiversityRow_eq_of_j1_formula
    (Q : StandardGaussianQuantileAPI)
    {School : Type*} [DecidableEq School]
    (subFullDiversity : School → ℝ) (J1 : School)
    {capacity1 groupBPopulationShare priorSigmaA priorPrecisionA
      subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB : ℝ}
    (hsub :
      subFullDiversity J1 =
        glm20Proposition6SourceParameterSubDiversityValue Q capacity1
          groupBPopulationShare priorSigmaA priorPrecisionA subPrecisionSumA
          priorSigmaB priorPrecisionB subPrecisionSumB) :
    glm20Proposition6SourceParameterSubFullDiversityRow Q J1
        subFullDiversity capacity1 groupBPopulationShare priorSigmaA
        priorPrecisionA subPrecisionSumA priorSigmaB priorPrecisionB
        subPrecisionSumB =
      subFullDiversity := by
  funext J
  by_cases hJ : J = J1
  · subst hJ
    simpa [glm20Proposition6SourceParameterSubFullDiversityRow,
      glm20Proposition6SourceParameterSubDiversityValue] using hsub.symm
  · simpa [glm20Proposition6SourceParameterSubFullDiversityRow,
      glm20OverrideSchoolValue, hJ]

/--
Proposition 6 row identity: if the fallback row already has the displayed
full/full diversity value at school `J1`, then generating the source-parameter
full/full row leaves the whole row unchanged.
-/
theorem paper_proposition6_source_parameter_fullFullDiversityRow_eq_of_j1_formula
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {School : Type*} [DecidableEq School]
    (fullFullDiversity : School → ℝ) (J1 : School)
    {groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
      subPrecisionSumB fullPrecisionSumB aB mu q1Full : ℝ}
    (hfull :
      fullFullDiversity J1 =
        glm20Proposition6SourceParameterFullDiversityValue api bivariateCDF
          groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
          subPrecisionSumB fullPrecisionSumB aB mu q1Full) :
    glm20Proposition6SourceParameterFullFullDiversityRow api bivariateCDF J1
        fullFullDiversity groupBPopulationShare capacity1 priorSigmaB
        priorPrecisionB subPrecisionSumB fullPrecisionSumB aB mu q1Full =
      fullFullDiversity := by
  funext J
  by_cases hJ : J = J1
  · subst hJ
    simpa [glm20Proposition6SourceParameterFullFullDiversityRow,
      glm20Proposition6SourceParameterFullDiversityValue] using hfull.symm
  · simpa [glm20Proposition6SourceParameterFullFullDiversityRow,
      glm20OverrideSchoolValue, hJ]

/--
Paper Proposition 6 on a source-parameter diversity table.

The `J1` full/full and sub/full diversity rows are generated by the displayed
source formulas, so the theorem has no separate `hfull`/`hsub` formula
identification premises.  A human checker only needs to compare the generated
right-hand side with the displayed Proposition 6 inequality.
-/
theorem
    paper_proposition6_policyState_j1_strict_diversity_best_response_iff_source_parameter_diversity_rows
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {Group School : Type*} [DecidableEq School]
    {massTestTaking : Group → GLM20StrategicPolicyState → ℝ}
    {admittedAcademicMerit :
      School → Group → GLM20StrategicPolicyState → ℝ}
    (subSubDiversity subFullDiversityFallback fullSubDiversity
      fullFullDiversityFallback : School → ℝ)
    (J1 J2 : School)
    {groupBPopulationShare capacity1 priorSigmaA priorPrecisionA
      subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB
      fullPrecisionSumB aB mu q1Full : ℝ} :
    glm20Proposition6J1StrictDiversityBestResponseDropsTest
        (glm20DiversityBinaryPolicySurface massTestTaking
          admittedAcademicMerit
          (glm20StrategicPolicyStateDiversity subSubDiversity
            (glm20Proposition6SourceParameterSubFullDiversityRow Q J1
              subFullDiversityFallback capacity1 groupBPopulationShare
              priorSigmaA priorPrecisionA subPrecisionSumA priorSigmaB
              priorPrecisionB subPrecisionSumB)
            fullSubDiversity
            (glm20Proposition6SourceParameterFullFullDiversityRow api
              bivariateCDF J1 fullFullDiversityFallback
              groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
              subPrecisionSumB fullPrecisionSumB aB mu q1Full))
          glm20StrategicPolicyStatePair GLM20StrategicPolicyState.singleSub
          GLM20StrategicPolicyState.singleFull J1 J2)
        glm20StrategicPolicyStatePair J1
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull ↔
      glm20Proposition6SourceParameterFullDiversityValue api bivariateCDF
          groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
          subPrecisionSumB fullPrecisionSumB aB mu q1Full <
        glm20Proposition6SourceParameterSubDiversityValue Q capacity1
          groupBPopulationShare priorSigmaA priorPrecisionA subPrecisionSumA
          priorSigmaB priorPrecisionB subPrecisionSumB := by
  let subFullDiversity :=
    glm20Proposition6SourceParameterSubFullDiversityRow Q J1
      subFullDiversityFallback capacity1 groupBPopulationShare priorSigmaA
      priorPrecisionA subPrecisionSumA priorSigmaB priorPrecisionB
      subPrecisionSumB
  let fullFullDiversity :=
    glm20Proposition6SourceParameterFullFullDiversityRow api bivariateCDF J1
      fullFullDiversityFallback groupBPopulationShare capacity1 priorSigmaB
      priorPrecisionB subPrecisionSumB fullPrecisionSumB aB mu q1Full
  have hfull :
      fullFullDiversity J1 =
        glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1
          (glm20Proposition3SigmaTildeSource
            priorSigmaB priorPrecisionB fullPrecisionSumB)
          aB
          (glm20Proposition3BSource
            priorPrecisionB subPrecisionSumB fullPrecisionSumB)
          mu q1Full := by
    simp [fullFullDiversity,
      glm20Proposition6SourceParameterFullFullDiversityRow,
      glm20Proposition6SourceParameterFullDiversityValue]
  have hsub :
      subFullDiversity J1 =
        glm20Proposition6PaperSubDiversityFormula Q capacity1
          groupBPopulationShare
          (glm20Proposition6SubSigmaTildeSourceRatio
            priorSigmaA priorPrecisionA subPrecisionSumA
            priorSigmaB priorPrecisionB subPrecisionSumB) := by
    simp [subFullDiversity,
      glm20Proposition6SourceParameterSubFullDiversityRow,
      glm20Proposition6SourceParameterSubDiversityValue]
  have hfull_surface :
      (glm20DiversityBinaryPolicySurface massTestTaking
        admittedAcademicMerit
        (glm20StrategicPolicyStateDiversity subSubDiversity subFullDiversity
          fullSubDiversity fullFullDiversity)
        glm20StrategicPolicyStatePair GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull J1 J2).diversity J1
        (glm20StrategicPolicyStatePair GLM20StrategicPolicyState.singleFull
          GLM20StrategicPolicyState.singleFull) =
        glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1
          (glm20Proposition3SigmaTildeSource
            priorSigmaB priorPrecisionB fullPrecisionSumB)
          aB
          (glm20Proposition3BSource
            priorPrecisionB subPrecisionSumB fullPrecisionSumB)
          mu q1Full := by
    simpa [glm20DiversityBinaryPolicySurface,
      glm20StrategicPolicyStateDiversity] using hfull
  have hsub_surface :
      (glm20DiversityBinaryPolicySurface massTestTaking
        admittedAcademicMerit
        (glm20StrategicPolicyStateDiversity subSubDiversity subFullDiversity
          fullSubDiversity fullFullDiversity)
        glm20StrategicPolicyStatePair GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull J1 J2).diversity J1
        (glm20StrategicPolicyStatePair GLM20StrategicPolicyState.singleSub
          GLM20StrategicPolicyState.singleFull) =
        glm20Proposition6PaperSubDiversityFormula Q capacity1
          groupBPopulationShare
          (glm20Proposition6SubSigmaTildeSourceRatio
            priorSigmaA priorPrecisionA subPrecisionSumA
            priorSigmaB priorPrecisionB subPrecisionSumB) := by
    simpa [glm20DiversityBinaryPolicySurface,
      glm20StrategicPolicyStateDiversity] using hsub
  simpa [subFullDiversity, fullFullDiversity,
    glm20Proposition6SourceParameterFullDiversityValue,
    glm20Proposition6SourceParameterSubDiversityValue] using
    (paper_proposition6_j1_strict_diversity_best_response_iff_source_parameter_formulas
      api Q bivariateCDF
      (glm20DiversityBinaryPolicySurface massTestTaking admittedAcademicMerit
        (glm20StrategicPolicyStateDiversity subSubDiversity subFullDiversity
          fullSubDiversity fullFullDiversity)
        glm20StrategicPolicyStatePair GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull J1 J2)
      glm20StrategicPolicyStatePair J1 hfull_surface hsub_surface)

/--
Paper Proposition 6, drop-test criterion on a source-parameter diversity table.

This is the exact paper-language version of the preceding strict-best-response
theorem: school `J1` drops the test for diversity if and only if the displayed
source-parameter diversity inequality holds.
-/
theorem
    paper_proposition6_policyState_j1_drops_test_iff_source_parameter_diversity_rows
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {Group School : Type*} [DecidableEq School]
    {massTestTaking : Group → GLM20StrategicPolicyState → ℝ}
    {admittedAcademicMerit :
      School → Group → GLM20StrategicPolicyState → ℝ}
    (subSubDiversity subFullDiversityFallback fullSubDiversity
      fullFullDiversityFallback : School → ℝ)
    (J1 J2 : School)
    {groupBPopulationShare capacity1 priorSigmaA priorPrecisionA
      subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB
      fullPrecisionSumB aB mu q1Full : ℝ} :
    glm20Proposition6J1DropsTestForDiversity
        (glm20DiversityBinaryPolicySurface massTestTaking
          admittedAcademicMerit
          (glm20StrategicPolicyStateDiversity subSubDiversity
            (glm20Proposition6SourceParameterSubFullDiversityRow Q J1
              subFullDiversityFallback capacity1 groupBPopulationShare
              priorSigmaA priorPrecisionA subPrecisionSumA priorSigmaB
              priorPrecisionB subPrecisionSumB)
            fullSubDiversity
            (glm20Proposition6SourceParameterFullFullDiversityRow api
              bivariateCDF J1 fullFullDiversityFallback
              groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
              subPrecisionSumB fullPrecisionSumB aB mu q1Full))
          glm20StrategicPolicyStatePair GLM20StrategicPolicyState.singleSub
          GLM20StrategicPolicyState.singleFull J1 J2)
        glm20StrategicPolicyStatePair J1
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull ↔
      glm20Proposition6SourceParameterFullDiversityValue api bivariateCDF
          groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
          subPrecisionSumB fullPrecisionSumB aB mu q1Full <
        glm20Proposition6SourceParameterSubDiversityValue Q capacity1
          groupBPopulationShare priorSigmaA priorPrecisionA subPrecisionSumA
          priorSigmaB priorPrecisionB subPrecisionSumB := by
  let diversityRows :=
    glm20StrategicPolicyStateDiversity subSubDiversity
      (glm20Proposition6SourceParameterSubFullDiversityRow Q J1
        subFullDiversityFallback capacity1 groupBPopulationShare priorSigmaA
        priorPrecisionA subPrecisionSumA priorSigmaB priorPrecisionB
        subPrecisionSumB)
      fullSubDiversity
      (glm20Proposition6SourceParameterFullFullDiversityRow api bivariateCDF
        J1 fullFullDiversityFallback groupBPopulationShare capacity1
        priorSigmaB priorPrecisionB subPrecisionSumB fullPrecisionSumB aB
        mu q1Full)
  let S :=
    glm20DiversityBinaryPolicySurface massTestTaking admittedAcademicMerit
      diversityRows glm20StrategicPolicyStatePair
      GLM20StrategicPolicyState.singleSub
      GLM20StrategicPolicyState.singleFull J1 J2
  have hstrict_drop :
      glm20Proposition6J1StrictDiversityBestResponseDropsTest S
          glm20StrategicPolicyStatePair J1
          GLM20StrategicPolicyState.singleSub
          GLM20StrategicPolicyState.singleFull ↔
        glm20Proposition6J1DropsTestForDiversity S
          glm20StrategicPolicyStatePair J1
          GLM20StrategicPolicyState.singleSub
          GLM20StrategicPolicyState.singleFull :=
    glm20Proposition6J1StrictDiversityBestResponseDropsTest_iff S
      glm20StrategicPolicyStatePair J1
  have hstrict_ineq :
      glm20Proposition6J1StrictDiversityBestResponseDropsTest S
          glm20StrategicPolicyStatePair J1
          GLM20StrategicPolicyState.singleSub
          GLM20StrategicPolicyState.singleFull ↔
        glm20Proposition6SourceParameterFullDiversityValue api bivariateCDF
            groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
            subPrecisionSumB fullPrecisionSumB aB mu q1Full <
          glm20Proposition6SourceParameterSubDiversityValue Q capacity1
            groupBPopulationShare priorSigmaA priorPrecisionA
            subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB := by
    simpa [S, diversityRows] using
      (paper_proposition6_policyState_j1_strict_diversity_best_response_iff_source_parameter_diversity_rows
        api Q bivariateCDF subSubDiversity subFullDiversityFallback
        fullSubDiversity fullFullDiversityFallback J1 J2
        (groupBPopulationShare := groupBPopulationShare)
        (capacity1 := capacity1) (priorSigmaA := priorSigmaA)
        (priorPrecisionA := priorPrecisionA)
        (subPrecisionSumA := subPrecisionSumA)
        (priorSigmaB := priorSigmaB)
        (priorPrecisionB := priorPrecisionB)
        (subPrecisionSumB := subPrecisionSumB)
        (fullPrecisionSumB := fullPrecisionSumB)
        (aB := aB) (mu := mu) (q1Full := q1Full))
  simpa [S, diversityRows] using hstrict_drop.symm.trans hstrict_ineq

/--
Paper Proposition 6 equilibrium consequence on the source-parameter diversity
table.

If the displayed strict Proposition 6 inequality holds for school `J1`, and
school `J2` weakly prefers keeping the test when `J1` drops, then
`(P_sub,P_full)` is an equilibrium on the diversity-only policy-state surface
whose `J1` diversity rows are generated by the displayed source formulas.
-/
theorem
    paper_proposition6_policyState_source_parameter_diversity_rows_inequality_implies_subFull_equilibrium
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {Group School : Type*} [DecidableEq School]
    {massTestTaking : Group → GLM20StrategicPolicyState → ℝ}
    {admittedAcademicMerit :
      School → Group → GLM20StrategicPolicyState → ℝ}
    (subSubDiversity subFullDiversityFallback fullSubDiversity
      fullFullDiversityFallback : School → ℝ)
    (J1 J2 : School)
    {groupBPopulationShare capacity1 priorSigmaA priorPrecisionA
      subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB
      fullPrecisionSumB aB mu q1Full : ℝ}
    (hJ2 :
      subSubDiversity J2 ≤
        glm20Proposition6SourceParameterSubFullDiversityRow Q J1
          subFullDiversityFallback capacity1 groupBPopulationShare
          priorSigmaA priorPrecisionA subPrecisionSumA priorSigmaB
          priorPrecisionB subPrecisionSumB J2)
    (hineq :
      glm20Proposition6SourceParameterFullDiversityValue api bivariateCDF
          groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
          subPrecisionSumB fullPrecisionSumB aB mu q1Full <
        glm20Proposition6SourceParameterSubDiversityValue Q capacity1
          groupBPopulationShare priorSigmaA priorPrecisionA subPrecisionSumA
          priorSigmaB priorPrecisionB subPrecisionSumB) :
    (glm20DiversityBinaryPolicySurface massTestTaking admittedAcademicMerit
        (glm20StrategicPolicyStateDiversity subSubDiversity
          (glm20Proposition6SourceParameterSubFullDiversityRow Q J1
            subFullDiversityFallback capacity1 groupBPopulationShare
            priorSigmaA priorPrecisionA subPrecisionSumA priorSigmaB
            priorPrecisionB subPrecisionSumB)
          fullSubDiversity
          (glm20Proposition6SourceParameterFullFullDiversityRow api
            bivariateCDF J1 fullFullDiversityFallback groupBPopulationShare
            capacity1 priorSigmaB priorPrecisionB subPrecisionSumB
            fullPrecisionSumB aB mu q1Full))
        glm20StrategicPolicyStatePair GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull J1 J2).policyPairIsEquilibrium
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull := by
  let subFullDiversity :=
    glm20Proposition6SourceParameterSubFullDiversityRow Q J1
      subFullDiversityFallback capacity1 groupBPopulationShare priorSigmaA
      priorPrecisionA subPrecisionSumA priorSigmaB priorPrecisionB
      subPrecisionSumB
  let fullFullDiversity :=
    glm20Proposition6SourceParameterFullFullDiversityRow api bivariateCDF J1
      fullFullDiversityFallback groupBPopulationShare capacity1 priorSigmaB
      priorPrecisionB subPrecisionSumB fullPrecisionSumB aB mu q1Full
  refine
    glm20DiversityBinaryPolicySurface_subFull_of_j1_strict_and_j2_weak
      (massTestTaking := massTestTaking)
      (admittedAcademicMerit := admittedAcademicMerit)
      (diversity := glm20StrategicPolicyStateDiversity subSubDiversity
        subFullDiversity fullSubDiversity fullFullDiversity)
      (policyPair := glm20StrategicPolicyStatePair)
      (Psub := GLM20StrategicPolicyState.singleSub)
      (Pfull := GLM20StrategicPolicyState.singleFull)
      (J1 := J1) (J2 := J2) ?_ ?_
  · simpa [subFullDiversity, fullFullDiversity,
      glm20StrategicPolicyStateDiversity,
      glm20Proposition6SourceParameterFullDiversityValue,
      glm20Proposition6SourceParameterSubDiversityValue] using hineq
  · simpa [subFullDiversity, glm20StrategicPolicyStateDiversity] using hJ2

/--
Paper Proposition 6 generated-row equilibrium consequence with school `J2`'s
no-deviation condition stated on the ordinary fallback row.

Because the generated Proposition 6 diversity table overrides only school
`J1`, the `J2` row is definitionally the fallback row whenever `J1 ≠ J2`.
-/
theorem
    paper_proposition6_policyState_source_parameter_diversity_rows_inequality_implies_subFull_equilibrium_of_J2_fallback
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {Group School : Type*} [DecidableEq School]
    {massTestTaking : Group → GLM20StrategicPolicyState → ℝ}
    {admittedAcademicMerit :
      School → Group → GLM20StrategicPolicyState → ℝ}
    (subSubDiversity subFullDiversityFallback fullSubDiversity
      fullFullDiversityFallback : School → ℝ)
    (J1 J2 : School)
    {groupBPopulationShare capacity1 priorSigmaA priorPrecisionA
      subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB
      fullPrecisionSumB aB mu q1Full : ℝ}
    (hJ1_ne_J2 : J1 ≠ J2)
    (hJ2 : subSubDiversity J2 ≤ subFullDiversityFallback J2)
    (hineq :
      glm20Proposition6SourceParameterFullDiversityValue api bivariateCDF
          groupBPopulationShare capacity1 priorSigmaB priorPrecisionB
          subPrecisionSumB fullPrecisionSumB aB mu q1Full <
        glm20Proposition6SourceParameterSubDiversityValue Q capacity1
          groupBPopulationShare priorSigmaA priorPrecisionA subPrecisionSumA
          priorSigmaB priorPrecisionB subPrecisionSumB) :
    (glm20DiversityBinaryPolicySurface massTestTaking admittedAcademicMerit
        (glm20StrategicPolicyStateDiversity subSubDiversity
          (glm20Proposition6SourceParameterSubFullDiversityRow Q J1
            subFullDiversityFallback capacity1 groupBPopulationShare
            priorSigmaA priorPrecisionA subPrecisionSumA priorSigmaB
            priorPrecisionB subPrecisionSumB)
          fullSubDiversity
          (glm20Proposition6SourceParameterFullFullDiversityRow api
            bivariateCDF J1 fullFullDiversityFallback groupBPopulationShare
            capacity1 priorSigmaB priorPrecisionB subPrecisionSumB
            fullPrecisionSumB aB mu q1Full))
        glm20StrategicPolicyStatePair GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull J1 J2).policyPairIsEquilibrium
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull := by
  refine
    paper_proposition6_policyState_source_parameter_diversity_rows_inequality_implies_subFull_equilibrium
      api Q bivariateCDF subSubDiversity subFullDiversityFallback
      fullSubDiversity fullFullDiversityFallback J1 J2 ?_ hineq
  have hJ2_ne_J1 : J2 ≠ J1 := by
    intro h
    exact hJ1_ne_J2 h.symm
  simpa [glm20Proposition6SourceParameterSubFullDiversityRow,
    glm20OverrideSchoolValue, hJ2_ne_J1] using hJ2

/--
Paper Proposition 6 generated-row equilibrium consequence when school `J2`'s
ordinary fallback sub/full diversity row is the same as its sub/sub row.

In this specialization the remaining `J2` weak no-deviation premise from the
fallback-row theorem is discharged by reflexivity.
-/
theorem
