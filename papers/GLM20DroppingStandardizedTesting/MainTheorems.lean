/-!
# Paper-Facing Theorems: Dropping Standardized Testing for Admissions

This file currently exposes the finite admissions-accounting layer used as
support for the future source-faithful formalization of
*Dropping Standardized Testing for Admissions Trades Off Information and Access*.

## Main declarations

- `GLM20Model`: shared finite prior with with-test and without-test signal
  kernels.
- `GLM20SourcePolicySurface`, `glm20GroupFair`, `glm20IndividualFair`:
  source-facing metric surface for the Gaussian admissions policy statements.
- `GLM20StrategicEquilibriumData`, `glm20StrategicEquilibrium`: abstract
  strategic-student/school equilibrium interface for Section 5.
- `paper_lemma1_estimated_skill_of_certificate`,
  `paper_theorem1_dropping_tests_with_barriers_of_certificate`,
  `paper_theorem2_dropping_tests_without_barriers_of_certificate`, and related
  declarations: paper-facing conditional wrappers for the source-named
  Gaussian and strategic results.
- `glm20TwoSignalAdmissionsModel`: adapter to the reusable two-signal
  admissions comparison interface.
- `glm20WithTestModel`, `glm20WithoutTestModel`: wrappers into the reusable
  `AdmissionsModel`.
- `glm20_with_test_exp_decompose`, `glm20_no_test_exp_decompose`: finite
  expectation decompositions for selected and unselected applicants.
-/

namespace GLM20DroppingStandardizedTesting

noncomputable section

/-!
Core abstraction used by early formalization:
the same prior over student type can induce two finite signal channels,
one with a standardized-test channel and one without.
-/
structure GLM20Model (Θ ΩTest ΩNo : Type*) [Fintype Θ] [DecidableEq Θ]
    [Fintype ΩTest] [DecidableEq ΩTest] [Fintype ΩNo] [DecidableEq ΩNo] where
  (prior : PMF Θ)
  (withTest : Θ → PMF ΩTest)
  (withoutTest : Θ → PMF ΩNo)
  (quality : Θ → ℝ)

/-- Paper groups, named only for paper-facing examples and human inspection. -/
inductive GLM20Group where
  | groupA
  | groupB
deriving DecidableEq, Repr

/-- Paper policies: `full` uses the test feature and `sub` drops it. -/
inductive GLM20Policy where
  | full
  | sub
deriving DecidableEq, Repr

/-- Paper notation for the test-based policy `P_full`. -/
def glm20PFull : GLM20Policy := GLM20Policy.full

/-- Paper notation for the test-free policy `P_sub`. -/
def glm20PSub : GLM20Policy := GLM20Policy.sub

/--
Source-facing metric surface for Sections 3--4.

The source paper instantiates these fields from Gaussian feature precisions,
group-dependent access levels, and admissions thresholds.  The field names are
kept close to the paper so theorem wrappers can state diversity, individual
fairness, and academic-merit conclusions without hiding the remaining Gaussian
analytic bridge behind the finite admissions helper layer.
-/
structure GLM20SourcePolicySurface (Group Policy : Type*) where
  populationShareB : ℝ
  capacity : ℝ
  precision : Group → Policy → ℝ
  accessLevel : Group → ℝ
  estimatedSkillMean : Group → Policy → ℝ
  estimatedSkillVariance : Group → Policy → ℝ
  admissionThreshold : Policy → ℝ
  diversity : Policy → ℝ
  individualFairnessGap : Policy → ℝ → ℝ
  academicMerit : Group → Policy → ℝ

/-- Group fairness from the source: admitted group-B share matches population share. -/
def glm20GroupFair {Group Policy : Type*}
    (S : GLM20SourcePolicySurface Group Policy) (P : Policy) : Prop := S.diversity P = S.populationShareB

/-- Individual fairness from the source: no skill-level admission-probability gap. -/
def glm20IndividualFair {Group Policy : Type*}
    (S : GLM20SourcePolicySurface Group Policy) (P : Policy) : Prop := ∀ q : ℝ, S.individualFairnessGap P q = 0

theorem glm20_not_groupFair_of_diversity_ne
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (hne : S.diversity P ≠ S.populationShareB) :
    ¬ glm20GroupFair S P := by
  intro hfair
  exact hne hfair

theorem glm20_not_groupFair_of_diversity_lt
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (hlt : S.diversity P < S.populationShareB) :
    ¬ glm20GroupFair S P := glm20_not_groupFair_of_diversity_ne (ne_of_lt hlt)

theorem glm20_not_individualFair_of_gap_ne
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (q : ℝ) (hne : S.individualFairnessGap P q ≠ 0) :
    ¬ glm20IndividualFair S P := by
  intro hfair
  exact hne (hfair q)

/-- Academic merit for a group weakly improves when moving from one policy to another. -/
def glm20GroupAcademicMeritWeaklyImproves {Group Policy : Type*}
    (S : GLM20SourcePolicySurface Group Policy) (g : Group) (fromPolicy toPolicy : Policy) :
    Prop := S.academicMerit g fromPolicy ≤ S.academicMerit g toPolicy

/-- Diversity weakly improves when moving from one policy to another. -/
def glm20DiversityWeaklyImproves {Group Policy : Type*}
    (S : GLM20SourcePolicySurface Group Policy) (fromPolicy toPolicy : Policy) : Prop := S.diversity fromPolicy ≤ S.diversity toPolicy

/--
Lemma 1, concrete Gaussian algebra.

Paper statement: for feature set `S`, group `g`, and observed feature values
`θ = (θ_k)`, the estimated skill is the precision-weighted posterior mean

`(μ σ^{-2} + ∑_{k∈S} (θ_k - μ_{gk}) σ_{gk}^{-2}) /
  (σ^{-2} + ∑_{k∈S} σ_{gk}^{-2})`,

and the marginal law of estimated skill in the group is normal with mean `μ`
and variance `σ^2 * (∑_{k∈S} σ_{gk}^{-2}) /
  (σ^{-2} + ∑_{k∈S} σ_{gk}^{-2})`.

The Lean statement uses `GaussianOffsetSignalFamily`: `priorVar = σ^2`,
`noiseMean k = μ_{gk}`, and `signalPrecision k = σ_{gk}^{-2}`.
-/
theorem paper_lemma1_estimated_skill_gaussian
    {Feature : Type*} [Fintype Feature] [Nonempty Feature]
    (M : GaussianOffsetSignalFamily Feature) (theta : Feature → ℝ) :
    M.posteriorMean theta =
        (M.centeredFamily.priorPrecision * M.priorMean +
          ∑ k : Feature,
            M.centeredFamily.signalPrecision k * (theta k - M.noiseMean k)) /
          M.centeredFamily.posteriorPrecision ∧
      (M.posteriorMeanLaw).mean = M.priorMean ∧
        (M.posteriorMeanLaw).variance =
          M.priorVar *
              (∑ k : Feature, M.centeredFamily.signalPrecision k) /
            M.centeredFamily.posteriorPrecision := by
  refine ⟨?_, ?_, ?_⟩
  · exact M.posteriorMean_eq_precision_weighted_div theta
  · rfl
  · simpa [GaussianOffsetSignalFamily.posteriorMeanLaw] using
      M.posteriorMeanVariance_eq_priorVar_mul_sum_signalPrecision_div_posteriorPrecision

/--
Lemma 1 canonical source surface.

For every group/policy pair, the surface is generated by the corresponding
`GaussianOffsetSignalFamily`.  The `precision` field stores the source-paper
feature signal precision sum, while `estimatedSkillMean` and
`estimatedSkillVariance` store the marginal law of the Bayesian estimated skill.
The other metric fields are neutral because Lemma 1 is only about estimated
skill.
-/
def lemma1GaussianSourceSurface
    {Group Policy Feature : Type*} [Fintype Feature] [Nonempty Feature]
    (M : Group → Policy → GaussianOffsetSignalFamily Feature)
    (populationShareB capacity : ℝ) :
    GLM20SourcePolicySurface Group Policy where
  populationShareB := populationShareB
  capacity := capacity
  precision := fun g P => (M g P).centeredFamily.signalPrecisionSum
  accessLevel := fun _ => 1
  estimatedSkillMean := fun g P => ((M g P).posteriorMeanLaw).mean
  estimatedSkillVariance := fun g P => ((M g P).posteriorMeanLaw).variance
  admissionThreshold := fun _ => 0
  diversity := fun _ => 0
  individualFairnessGap := fun _ _ => 0
  academicMerit := fun _ _ => 0

/--
Lemma 1, source-surface endpoint.

Paper statement: estimated skill is the precision-weighted posterior mean and,
for each group/policy pair, the estimated-skill distribution is normal with
mean `μ` and variance
`σ^2 * sum_signal_precision / posterior_precision`.

This theorem wires the concrete Gaussian algebra into the source policy
surface: the surface fields for precision, estimated-skill mean, and
estimated-skill variance are definitionally the Lemma 1 quantities generated by
`GaussianOffsetSignalFamily`.
-/
theorem paper_lemma1_estimated_skill_source_surface
    {Group Policy Feature : Type*} [Fintype Feature] [Nonempty Feature]
    (M : Group → Policy → GaussianOffsetSignalFamily Feature)
    (populationShareB capacity : ℝ) (g : Group) (P : Policy)
    (theta : Feature → ℝ) :
    let S := lemma1GaussianSourceSurface M populationShareB capacity
    (M g P).posteriorMean theta =
        ((M g P).centeredFamily.priorPrecision * (M g P).priorMean +
          ∑ k : Feature,
            (M g P).centeredFamily.signalPrecision k *
              (theta k - (M g P).noiseMean k)) /
          (M g P).centeredFamily.posteriorPrecision ∧
      S.precision g P = (M g P).centeredFamily.signalPrecisionSum ∧
        S.estimatedSkillMean g P = (M g P).priorMean ∧
          S.estimatedSkillVariance g P =
            (M g P).priorVar *
                (∑ k : Feature, (M g P).centeredFamily.signalPrecision k) /
              (M g P).centeredFamily.posteriorPrecision := by
  dsimp only
  obtain ⟨hmeanFormula, hmeanLaw, hvarLaw⟩ :=
    paper_lemma1_estimated_skill_gaussian (M g P) theta
  refine ⟨hmeanFormula, ?_, ?_, ?_⟩
  · rfl
  · simpa [lemma1GaussianSourceSurface] using hmeanLaw
  · simpa [lemma1GaussianSourceSurface] using hvarLaw

/--
Lemma 1 support: holding all other application features fixed, the Bayesian
estimated skill is strictly increasing in any one observed feature value.
-/
theorem paper_lemma1_estimated_skill_strictMono_feature
    {Feature : Type*} [Fintype Feature] [DecidableEq Feature]
    (M : GaussianOffsetSignalFamily Feature) (theta : Feature → ℝ) (k : Feature) :
    StrictMono (fun value : ℝ =>
      M.posteriorMean (Function.update theta k value)) := M.posteriorMean_update_strictMono theta k

/--
Threshold support for fixed-policy admissions: a positive-slope affine
estimated-skill score clears an admissions threshold exactly above its cutoff.
-/
theorem paper_fixed_policy_affine_score_threshold_iff_cutoff
    {intercept slope threshold score : ℝ} (hslope : 0 < slope) :
    threshold ≤ intercept + slope * score ↔
      affineCutoff intercept slope threshold ≤ score := threshold_le_affine_iff_cutoff_le hslope

/--
Gaussian fixed-feature threshold support: with all other features fixed,
admission by posterior estimated skill is equivalent to the selected feature
clearing an explicit affine cutoff.
-/
theorem paper_fixed_feature_gaussian_threshold_iff_cutoff
    {Feature : Type*} [Fintype Feature] [DecidableEq Feature]
    (M : GaussianOffsetSignalFamily Feature) (theta : Feature → ℝ) (k : Feature)
    (base threshold value : ℝ) :
    threshold ≤ M.posteriorMean (Function.update theta k value) ↔
      affineCutoff
        (M.posteriorMean (Function.update theta k base) -
          M.centeredFamily.signalWeight k * base)
        (M.centeredFamily.signalWeight k) threshold ≤ value :=
  M.threshold_le_posteriorMean_update_iff_cutoff_le theta k base threshold value

/--
Proposition 1 support: if two group estimated-skill Gaussian laws have unequal
variance, they are unequal laws.
-/
theorem paper_proposition1_gaussian_laws_differ_of_variance_lt
    {Llow Lhigh : GaussianVarianceLaw} (hvar : Llow.variance < Lhigh.variance) :
    Llow ≠ Lhigh := GaussianVarianceLaw.ne_of_variance_lt hvar

/--
Proposition 1 equal-precision support: equal estimated-skill mean and variance
give identical Gaussian score laws.
-/
theorem paper_proposition1_gaussian_laws_equal_of_mean_eq_variance_eq
    {L₁ L₂ : GaussianVarianceLaw}
    (hmean : L₁.mean = L₂.mean) (hvar : L₁.variance = L₂.variance) :
    L₁ = L₂ := GaussianVarianceLaw.eq_of_mean_eq_variance hmean hvar

/--
Proposition 1 precision support: with the same prior variance, a strictly
larger total signal precision gives a strictly larger marginal variance of the
Bayesian estimated skill.
-/
theorem paper_proposition1_estimated_skill_variance_lt_of_total_precision_lt
    {Feature : Type*} [Fintype Feature]
    {Mlow Mhigh : GaussianOffsetSignalFamily Feature}
    (hpriorVar : Mlow.priorVar = Mhigh.priorVar)
    (hsum :
      (∑ k : Feature, Mlow.centeredFamily.signalPrecision k) <
        ∑ k : Feature, Mhigh.centeredFamily.signalPrecision k) :
    Mlow.posteriorMeanVariance < Mhigh.posteriorMeanVariance :=
  GaussianOffsetSignalFamily.posteriorMeanVariance_lt_of_priorVar_eq_sum_signalPrecision_lt
    hpriorVar hsum

/--
Proposition 1 precision support: with the same prior variance, a strictly
larger total signal precision gives a strictly larger Gaussian scale for the
Bayesian estimated skill.
-/
theorem paper_proposition1_estimated_skill_scale_lt_of_total_precision_lt
    {Feature : Type*} [Fintype Feature] [Nonempty Feature]
    {Mlow Mhigh : GaussianOffsetSignalFamily Feature}
    (hpriorVar : Mlow.priorVar = Mhigh.priorVar)
    (hsum :
      (∑ k : Feature, Mlow.centeredFamily.signalPrecision k) <
        ∑ k : Feature, Mhigh.centeredFamily.signalPrecision k) :
    (Mlow.posteriorMeanScaleLaw).scale <
      (Mhigh.posteriorMeanScaleLaw).scale :=
  GaussianOffsetSignalFamily.posteriorMeanScaleLaw_scale_lt_of_priorVar_eq_sum_signalPrecision_lt
    hpriorVar hsum

/--
Proposition 1 precision support: a strict total-precision gap produces
different estimated-skill Gaussian laws.
-/
theorem paper_proposition1_estimated_skill_laws_differ_of_total_precision_lt
    {Feature : Type*} [Fintype Feature] [Nonempty Feature]
    {Mlow Mhigh : GaussianOffsetSignalFamily Feature}
    (hpriorVar : Mlow.priorVar = Mhigh.priorVar)
    (hsum :
      (∑ k : Feature, Mlow.centeredFamily.signalPrecision k) <
        ∑ k : Feature, Mhigh.centeredFamily.signalPrecision k) :
    Mlow.posteriorMeanLaw ≠ Mhigh.posteriorMeanLaw :=
  GaussianVarianceLaw.ne_of_variance_lt
    (paper_proposition1_estimated_skill_variance_lt_of_total_precision_lt
      hpriorVar hsum)

/--
Proposition 1 tail-comparison support: above the common mean, the larger-scale
Gaussian score law has weakly larger upper-tail admission probability.
-/
theorem paper_proposition1_upper_tail_le_of_same_mean_scale_le_above_mean
    (api : StandardGaussianCDFAPI)
    {Lsmall Llarge : GaussianScaleLaw}
    (hmean : Lsmall.mean = Llarge.mean)
    (hscale : Lsmall.scale ≤ Llarge.scale)
    {threshold : ℝ} (hthreshold : Lsmall.mean ≤ threshold) :
    api.thresholdPassProb Lsmall threshold ≤
      api.thresholdPassProb Llarge threshold :=
  api.thresholdPassProb_le_of_same_mean_scale_le_of_mean_le
    hmean hscale hthreshold

/--
Proposition 1 strict tail-comparison support: strictly above the common mean,
the strictly larger-scale Gaussian score law has strictly larger upper-tail
admission probability.
-/
theorem paper_proposition1_upper_tail_lt_of_same_mean_scale_lt_above_mean
    (api : StandardGaussianCDFAPI)
    {Lsmall Llarge : GaussianScaleLaw}
    (hmean : Lsmall.mean = Llarge.mean)
    (hscale : Lsmall.scale < Llarge.scale)
    {threshold : ℝ} (hthreshold : Lsmall.mean < threshold) :
    api.thresholdPassProb Lsmall threshold <
      api.thresholdPassProb Llarge threshold :=
  api.thresholdPassProb_lt_of_same_mean_scale_lt_of_mean_lt
    hmean hscale hthreshold

/--
Proposition 1 individual-fairness support: an admission-probability tail gap is
positive exactly when the first group's standardized threshold is lower.
-/
theorem paper_proposition1_tail_gap_pos_iff_standardized_threshold_lt
    (api : StandardGaussianCDFAPI)
    {L_A L_B : GaussianScaleLaw} {threshold : ℝ} :
    0 < api.thresholdPassProb L_A threshold -
        api.thresholdPassProb L_B threshold ↔
      L_A.standardize threshold < L_B.standardize threshold :=  api.thresholdPassProb_sub_pos_iff_standardize_lt

/--
Proposition 1 individual-fairness algebra: when group A has the larger
square-root precision (`sqrtPrecB < sqrtPrecA`), the standardized-threshold
comparison is equivalent to the paper's skill cutoff inequality.
-/
theorem paper_proposition1_standardized_threshold_lt_iff_skill_above_cutoff
    {priorPrecision sqrtPrecB sqrtPrecA threshold mean q : ℝ}
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hgap : sqrtPrecB < sqrtPrecA) :
    priorPrecision * (threshold - mean) / sqrtPrecA +
        sqrtPrecA * (threshold - q) <
      priorPrecision * (threshold - mean) / sqrtPrecB +
        sqrtPrecB * (threshold - q) ↔
      threshold -
          priorPrecision * (threshold - mean) / (sqrtPrecB * sqrtPrecA) <
        q :=
  precisionStandardizedSameThreshold_lt_iff_cutoff_lt_skill
    hsqrtB_pos hsqrtA_pos hgap

/--
Proposition 1 individual-fairness-gap core: after rewriting the two groups'
standardized admission thresholds into the paper's precision form, the
admission-probability gap is positive exactly above the skill cutoff.
-/
theorem paper_proposition1_tail_gap_pos_iff_skill_above_cutoff
    (api : StandardGaussianCDFAPI)
    {L_A L_B : GaussianScaleLaw}
    {priorPrecision sqrtPrecB sqrtPrecA threshold mean q : ℝ}
    (hstdA :
      L_A.standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecA +
          sqrtPrecA * (threshold - q))
    (hstdB :
      L_B.standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecB +
          sqrtPrecB * (threshold - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hgap : sqrtPrecB < sqrtPrecA) :
    0 < api.thresholdPassProb L_A threshold -
        api.thresholdPassProb L_B threshold ↔
      threshold -
          priorPrecision * (threshold - mean) / (sqrtPrecB * sqrtPrecA) <
        q := by
  rw [paper_proposition1_tail_gap_pos_iff_standardized_threshold_lt api,
    hstdA, hstdB]
  exact paper_proposition1_standardized_threshold_lt_iff_skill_above_cutoff
    hsqrtB_pos hsqrtA_pos hgap

/--
Proposition 1 individual-fairness-gap characterization: if the policy surface's
individual-fairness gap is the Gaussian admission-tail difference, then the gap
is positive exactly above the paper's skill cutoff.
-/
theorem paper_proposition1_individual_fairness_gap_pos_iff_skill_above_cutoff
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {L_A L_B : GaussianScaleLaw}
    {priorPrecision sqrtPrecB sqrtPrecA threshold mean q : ℝ}
    (hgap_eq :
      S.individualFairnessGap P q =
        api.thresholdPassProb L_A threshold -
          api.thresholdPassProb L_B threshold)
    (hstdA :
      L_A.standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecA +
          sqrtPrecA * (threshold - q))
    (hstdB :
      L_B.standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecB +
          sqrtPrecB * (threshold - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hprecision_gap : sqrtPrecB < sqrtPrecA) :
    0 < S.individualFairnessGap P q ↔
      threshold -
          priorPrecision * (threshold - mean) /
            (sqrtPrecB * sqrtPrecA) <
        q := by
  rw [hgap_eq]
  exact paper_proposition1_tail_gap_pos_iff_skill_above_cutoff
    api hstdA hstdB hsqrtB_pos hsqrtA_pos hprecision_gap

/--
Proposition 1 individual-fairness failure core: if some skill level lies above
the paper's cutoff and the source gap is the Gaussian tail difference, then
individual fairness fails.
-/
theorem paper_proposition1_not_individual_fair_of_skill_above_cutoff
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {L_A L_B : GaussianScaleLaw}
    {priorPrecision sqrtPrecB sqrtPrecA threshold mean q : ℝ}
    (hgap_eq :
      S.individualFairnessGap P q =
        api.thresholdPassProb L_A threshold -
          api.thresholdPassProb L_B threshold)
    (hstdA :
      L_A.standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecA +
          sqrtPrecA * (threshold - q))
    (hstdB :
      L_B.standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecB +
          sqrtPrecB * (threshold - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hprecision_gap : sqrtPrecB < sqrtPrecA)
    (hskill :
      threshold -
          priorPrecision * (threshold - mean) /
            (sqrtPrecB * sqrtPrecA) <
        q) :
    ¬ glm20IndividualFair S P := by
  apply glm20_not_individualFair_of_gap_ne q
  exact ne_of_gt
    ((paper_proposition1_individual_fairness_gap_pos_iff_skill_above_cutoff
      api hgap_eq hstdA hstdB hsqrtB_pos hsqrtA_pos hprecision_gap).mpr hskill)

/--
Proposition 1 individual-fairness failure with quantified Gaussian tail
formulas: since the real line contains skill levels above the cutoff, the
policy cannot have zero individual-fairness gap at every skill.
-/
theorem paper_proposition1_not_individual_fair_of_precision_tail_formulas
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {lawA lawB : ℝ → GaussianScaleLaw}
    {priorPrecision sqrtPrecB sqrtPrecA threshold mean : ℝ}
    (hgap_eq : ∀ q,
      S.individualFairnessGap P q =
        api.thresholdPassProb (lawA q) threshold -
          api.thresholdPassProb (lawB q) threshold)
    (hstdA : ∀ q,
      (lawA q).standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecA +
          sqrtPrecA * (threshold - q))
    (hstdB : ∀ q,
      (lawB q).standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecB +
          sqrtPrecB * (threshold - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hprecision_gap : sqrtPrecB < sqrtPrecA) :
    ¬ glm20IndividualFair S P := by
  let cutoff :=
    threshold -
      priorPrecision * (threshold - mean) / (sqrtPrecB * sqrtPrecA)
  let q₀ := cutoff + 1
  have hskill : cutoff < q₀ := by
    dsimp [q₀]
    linarith
  exact paper_proposition1_not_individual_fair_of_skill_above_cutoff
    api (hgap_eq q₀) (hstdA q₀) (hstdB q₀)
    hsqrtB_pos hsqrtA_pos hprecision_gap hskill

/--
Proposition 1 comparative-statics algebra: if group A's admission probability
strictly rises while group B's admission probability strictly falls, then the
individual-fairness gap `A - B` strictly increases.
-/
theorem paper_proposition1_individual_gap_increases_of_probability_monotonicity
    {oldA newA oldB newB : ℝ}
    (hA : oldA < newA) (hB : newB < oldB) :
    oldA - oldB < newA - newB := by
  linarith

/--
Proposition 1 group-B comparative-statics support: for a fixed group-B score
law, raising the common admissions threshold strictly decreases group B's
admission probability.
-/
theorem paper_proposition1_groupB_admission_probability_decreases_of_threshold_increases
    (api : StandardGaussianCDFAPI)
    {L_B : GaussianScaleLaw} {thresholdLow thresholdHigh : ℝ}
    (hthreshold : thresholdLow < thresholdHigh) :
    api.thresholdPassProb L_B thresholdHigh <
      api.thresholdPassProb L_B thresholdLow := api.thresholdPassProb_strictAnti_threshold L_B hthreshold

/--
Proposition 1 group-A comparative-statics support: if a larger
informativeness gap lowers group A's standardized admission cutoff for skill
`q`, then group A's admission probability for that skill strictly increases.
-/
theorem paper_proposition1_groupA_admission_probability_increases_of_standardized_decreases
    (api : StandardGaussianCDFAPI)
    {L_A_low L_A_high : GaussianScaleLaw}
    {thresholdLow thresholdHigh : ℝ}
    (hstd :
      L_A_high.standardize thresholdHigh <
        L_A_low.standardize thresholdLow) :
    api.thresholdPassProb L_A_low thresholdLow <
      api.thresholdPassProb L_A_high thresholdHigh :=  (api.thresholdPassProb_gt_iff_standardize_lt_of_thresholds).mpr hstd

/--
Proposition 1 individual-fairness comparative statics: comparing two
informativeness-gap parameter values, if the group-B law is fixed, the common
threshold rises, and group A's standardized cutoff falls, then the
individual-fairness gap strictly increases.
-/
theorem paper_proposition1_individual_fairness_gap_increases_of_threshold_and_standardized_monotonicity
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P_low P_high : Policy}
    {L_A_low L_A_high L_B : GaussianScaleLaw}
    {thresholdLow thresholdHigh q : ℝ}
    (hgap_low :
      S.individualFairnessGap P_low q =
        api.thresholdPassProb L_A_low thresholdLow -
          api.thresholdPassProb L_B thresholdLow)
    (hgap_high :
      S.individualFairnessGap P_high q =
        api.thresholdPassProb L_A_high thresholdHigh -
          api.thresholdPassProb L_B thresholdHigh)
    (hthreshold : thresholdLow < thresholdHigh)
    (hstd :
      L_A_high.standardize thresholdHigh <
        L_A_low.standardize thresholdLow) :
    S.individualFairnessGap P_low q <
      S.individualFairnessGap P_high q := by
  rw [hgap_low, hgap_high]
  exact
    paper_proposition1_individual_gap_increases_of_probability_monotonicity
      (paper_proposition1_groupA_admission_probability_increases_of_standardized_decreases
        api hstd)
      (paper_proposition1_groupB_admission_probability_decreases_of_threshold_increases
        api hthreshold)

/--
Proposition 1 high-skill Gaussian algebra: in the paper's standardized
group-A cutoff expression, a precision scale increase strictly lowers the
standardized cutoff whenever true skill is above the perfect-information
cutoff represented by `quantileScale`.
-/
theorem paper_proposition1_groupA_standardized_cutoff_decreases_of_high_skill
    {a c d quantileScale skillGap sqrtPrecLow sqrtPrecHigh : ℝ}
    (ha_pos : 0 < a) (ha_le_one : a ≤ 1)
    (hc_nonneg : 0 ≤ c) (hd_nonneg : 0 ≤ d)
    (hquantileScale_pos : 0 < quantileScale)
    (hhighSkill : quantileScale < skillGap)
    (hsqrtLow_pos : 0 < sqrtPrecLow)
    (hprecision : sqrtPrecLow < sqrtPrecHigh) :
    quantileScale *
        Real.sqrt (a * sqrtPrecHigh ^ 2 + c + d / sqrtPrecHigh ^ 2) -
        sqrtPrecHigh * skillGap <
      quantileScale *
        Real.sqrt (a * sqrtPrecLow ^ 2 + c + d / sqrtPrecLow ^ 2) -
        sqrtPrecLow * skillGap :=
  scaledSqrtQuadraticInvSubLinear_decreases
    ha_pos ha_le_one hc_nonneg hd_nonneg hquantileScale_pos hhighSkill
    hsqrtLow_pos hprecision

/--
Proposition 1 individual-fairness comparative statics for high-skilled
students: once group A's standardized cutoff is put in the paper's
`sqrt(a s^2 + c + d/s^2) - s(q-μ)` form, increasing group A precision raises
the individual-fairness gap.
-/
theorem paper_proposition1_individual_fairness_gap_increases_of_high_skill_standardized_formula
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P_low P_high : Policy}
    {L_A_low L_A_high L_B : GaussianScaleLaw}
    {thresholdLow thresholdHigh q mean a c d quantileScale
      sqrtPrecLow sqrtPrecHigh : ℝ}
    (hgap_low :
      S.individualFairnessGap P_low q =
        api.thresholdPassProb L_A_low thresholdLow -
          api.thresholdPassProb L_B thresholdLow)
    (hgap_high :
      S.individualFairnessGap P_high q =
        api.thresholdPassProb L_A_high thresholdHigh -
          api.thresholdPassProb L_B thresholdHigh)
    (hstd_low :
      L_A_low.standardize thresholdLow =
        quantileScale *
            Real.sqrt (a * sqrtPrecLow ^ 2 + c + d / sqrtPrecLow ^ 2) -
          sqrtPrecLow * (q - mean))
    (hstd_high :
      L_A_high.standardize thresholdHigh =
        quantileScale *
            Real.sqrt (a * sqrtPrecHigh ^ 2 + c + d / sqrtPrecHigh ^ 2) -
          sqrtPrecHigh * (q - mean))
    (hthreshold : thresholdLow < thresholdHigh)
    (ha_pos : 0 < a) (ha_le_one : a ≤ 1)
    (hc_nonneg : 0 ≤ c) (hd_nonneg : 0 ≤ d)
    (hquantileScale_pos : 0 < quantileScale)
    (hhighSkill : quantileScale < q - mean)
    (hsqrtLow_pos : 0 < sqrtPrecLow)
    (hprecision : sqrtPrecLow < sqrtPrecHigh) :
    S.individualFairnessGap P_low q <
      S.individualFairnessGap P_high q := by
  apply
    paper_proposition1_individual_fairness_gap_increases_of_threshold_and_standardized_monotonicity
      api hgap_low hgap_high hthreshold
  rw [hstd_high, hstd_low]
  exact
    paper_proposition1_groupA_standardized_cutoff_decreases_of_high_skill
      ha_pos ha_le_one hc_nonneg hd_nonneg hquantileScale_pos hhighSkill
      hsqrtLow_pos hprecision

/--
Proposition 1 admitted-merit support: above a common mean, the larger-scale
Gaussian score law has weakly larger upper-tail mean under the scaled-hazard
monotonicity certificate.
-/
theorem paper_proposition1_upper_tail_mean_le_of_same_mean_scale_le_above_mean
    (C : GaussianHazardCertificate)
    {Lsmall Llarge : GaussianScaleLaw}
    (hmean : Lsmall.mean = Llarge.mean)
    (hscale : Lsmall.scale ≤ Llarge.scale)
    {threshold : ℝ} (hthreshold : Lsmall.mean < threshold) :
    C.normalUpperTailMean Lsmall threshold ≤
      C.normalUpperTailMean Llarge threshold :=
  C.normalUpperTailMean_le_of_same_mean_scale_le_above_mean
    hmean hscale hthreshold

/--
Proposition 1 admitted-merit support: above a common mean, the strictly
larger-scale Gaussian score law has strictly larger upper-tail mean under the
strict scaled-hazard monotonicity certificate.
-/
theorem paper_proposition1_upper_tail_mean_lt_of_same_mean_scale_lt_above_mean
    (C : GaussianHazardCertificate)
    {Lsmall Llarge : GaussianScaleLaw}
    (hmean : Lsmall.mean = Llarge.mean)
    (hscale : Lsmall.scale < Llarge.scale)
    {threshold : ℝ} (hthreshold : Lsmall.mean < threshold) :
    C.normalUpperTailMean Lsmall threshold <
      C.normalUpperTailMean Llarge threshold :=
  C.normalUpperTailMean_lt_of_same_mean_scale_lt_above_mean
    hmean hscale hthreshold

/--
Proposition 1 admitted-merit support over the source metric surface: if the
group-specific admitted academic merits are identified with the corresponding
Gaussian upper-tail means, then group B's admitted merit is weakly below group
A's when group A has the larger score scale.
-/
theorem paper_proposition1_groupB_academic_merit_le_groupA_of_tail_mean
    (C : GaussianHazardCertificate)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (groupA groupB : Group)
    {L_A L_B : GaussianScaleLaw}
    (hmean : L_B.mean = L_A.mean)
    (hscale : L_B.scale ≤ L_A.scale)
    {threshold : ℝ} (hthreshold : L_B.mean < threshold)
    (hmeritA :
      S.academicMerit groupA P = C.normalUpperTailMean L_A threshold)
    (hmeritB :
      S.academicMerit groupB P = C.normalUpperTailMean L_B threshold) :
    S.academicMerit groupB P ≤ S.academicMerit groupA P := by
  rw [hmeritA, hmeritB]
  exact C.normalUpperTailMean_le_of_same_mean_scale_le_above_mean
    hmean hscale hthreshold

/--
Proposition 1 strict admitted-merit support over the source metric surface:
if admitted academic merits are identified with Gaussian upper-tail means, then
group B's admitted merit is strictly below group A's when group A has the
larger score scale.
-/
theorem paper_proposition1_groupB_academic_merit_lt_groupA_of_tail_mean
    (C : GaussianHazardCertificate)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (groupA groupB : Group)
    {L_A L_B : GaussianScaleLaw}
    (hmean : L_B.mean = L_A.mean)
    (hscale : L_B.scale < L_A.scale)
    {threshold : ℝ} (hthreshold : L_B.mean < threshold)
    (hmeritA :
      S.academicMerit groupA P = C.normalUpperTailMean L_A threshold)
    (hmeritB :
      S.academicMerit groupB P = C.normalUpperTailMean L_B threshold) :
    S.academicMerit groupB P < S.academicMerit groupA P := by
  rw [hmeritA, hmeritB]
  exact C.normalUpperTailMean_lt_of_same_mean_scale_lt_above_mean
    hmean hscale hthreshold

/--
Proposition 1 threshold-location support: if the admission capacity is below
one half and equals the two-group Gaussian upper-tail mixture, then the common
threshold is strictly above the common mean.
-/
theorem paper_proposition1_threshold_gt_common_mean_of_capacity_lt_half
    (api : StandardGaussianCDFAPI)
    {pi capacity threshold : ℝ} {L_A L_B : GaussianScaleLaw}
    (hpi_nonneg : 0 ≤ pi) (hpi_le_one : pi ≤ 1)
    (hmean : L_A.mean = L_B.mean)
    (hcapacity :
      capacity =
        (1 - pi) * api.thresholdPassProb L_A threshold +
          pi * api.thresholdPassProb L_B threshold)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ)) :
    L_B.mean < threshold := by
  by_contra hnot
  have hthreshold_le_B : threshold ≤ L_B.mean := le_of_not_gt hnot
  have hthreshold_le_A : threshold ≤ L_A.mean := by
    rw [hmean]
    exact hthreshold_le_B
  have htail_A :
      (1 / 2 : ℝ) ≤ api.thresholdPassProb L_A threshold := by
    rw [← api.thresholdPassProb_at_mean L_A]
    exact api.thresholdPassProb_antitone_threshold L_A hthreshold_le_A
  have htail_B :
      (1 / 2 : ℝ) ≤ api.thresholdPassProb L_B threshold := by
    rw [← api.thresholdPassProb_at_mean L_B]
    exact api.thresholdPassProb_antitone_threshold L_B hthreshold_le_B
  have hleft_weight_nonneg : 0 ≤ 1 - pi := by
    linarith
  have hmix_ge_half :
      (1 / 2 : ℝ) ≤
        (1 - pi) * api.thresholdPassProb L_A threshold +
          pi * api.thresholdPassProb L_B threshold := by
    calc
      (1 / 2 : ℝ) =
          (1 - pi) * (1 / 2 : ℝ) + pi * (1 / 2 : ℝ) := by
        ring
      _ ≤ (1 - pi) * api.thresholdPassProb L_A threshold +
            pi * api.thresholdPassProb L_B threshold :=
        add_le_add
          (mul_le_mul_of_nonneg_left htail_A hleft_weight_nonneg)
          (mul_le_mul_of_nonneg_left htail_B hpi_nonneg)
  have hcapacity_ge_half : (1 / 2 : ℝ) ≤ capacity := by
    rw [hcapacity]
    exact hmix_ge_half
  linarith

/-- Proposition 1 logical support: one diversity mismatch proves group fairness fails. -/
theorem paper_proposition1_not_group_fair_of_diversity_ne
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (hne : S.diversity P ≠ S.populationShareB) :
    ¬ glm20GroupFair S P := glm20_not_groupFair_of_diversity_ne hne

/-- Proposition 1 logical support: under-representation proves group fairness fails. -/
theorem paper_proposition1_not_group_fair_of_diversity_lt
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (hlt : S.diversity P < S.populationShareB) :
    ¬ glm20GroupFair S P := glm20_not_groupFair_of_diversity_lt hlt

/-- Proposition 1 logical support: one nonzero skill-level gap proves individual fairness fails. -/
theorem paper_proposition1_not_individual_fair_of_gap_ne
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (q : ℝ) (hne : S.individualFairnessGap P q ≠ 0) :
    ¬ glm20IndividualFair S P := glm20_not_individualFair_of_gap_ne q hne

/--
Proposition 1 diversity algebra: if group B's admitted tail mass is below the
overall capacity, then the admitted group-B share is below the population share
`π`.
-/
theorem paper_proposition1_diversity_share_lt_population_share_of_tail_lt_capacity
    {pi tailB capacity : ℝ} (hpi : 0 < pi) (hcap : 0 < capacity)
    (htail : tailB < capacity) :
    pi * tailB / capacity < pi :=  weighted_share_lt_weight_of_value_lt_total hpi hcap htail

/--
Proposition 1 capacity algebra: if group A has a strictly larger admission
tail than group B and the total capacity is the population-weighted mixture
`(1 - π) * tailA + π * tailB`, then group B's tail is below total capacity.
-/
theorem paper_proposition1_tailB_lt_capacity_of_mixture_tail_gap
    {pi tailA tailB capacity : ℝ} (hpi_lt_one : pi < 1)
    (hcapacity : capacity = (1 - pi) * tailA + pi * tailB)
    (htail_gap : tailB < tailA) :
    tailB < capacity := by
  rw [hcapacity]
  exact right_lt_weightedAverage_of_right_lt_left hpi_lt_one htail_gap

/--
Proposition 1 diversity algebra from the source mixture equation: if group A's
tail is strictly larger than group B's tail at the common threshold, then the
admitted group-B share is strictly below the population share `π`.
-/
theorem paper_proposition1_diversity_share_lt_population_share_of_mixture_tail_gap
    {pi tailA tailB capacity : ℝ}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_pos : 0 < capacity)
    (hcapacity : capacity = (1 - pi) * tailA + pi * tailB)
    (htail_gap : tailB < tailA) :
    pi * tailB / capacity < pi :=
  paper_proposition1_diversity_share_lt_population_share_of_tail_lt_capacity
    hpi_pos hcapacity_pos
    (paper_proposition1_tailB_lt_capacity_of_mixture_tail_gap
      hpi_lt_one hcapacity htail_gap)

/--
Proposition 1 diversity under-representation core: if group A has strictly
larger Gaussian score scale than group B, both laws have the same mean, and
the common threshold realizes a selective capacity below one half, then group B
is under-represented among admitted students.
-/
theorem paper_proposition1_diversity_share_lt_population_share_of_scale_gap_capacity_lt_half
    (api : StandardGaussianCDFAPI)
    {pi capacity threshold : ℝ} {L_A L_B : GaussianScaleLaw}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_pos : 0 < capacity)
    (hmean : L_A.mean = L_B.mean)
    (hscale_gap : L_B.scale < L_A.scale)
    (hcapacity :
      capacity =
        (1 - pi) * api.thresholdPassProb L_A threshold +
          pi * api.thresholdPassProb L_B threshold)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ)) :
    pi * api.thresholdPassProb L_B threshold / capacity < pi := by
  have hthreshold_gt_mean :
      L_B.mean < threshold :=
    paper_proposition1_threshold_gt_common_mean_of_capacity_lt_half
      api hpi_pos.le hpi_lt_one.le hmean hcapacity hcapacity_lt_half
  have htail_gap :
      api.thresholdPassProb L_B threshold <
        api.thresholdPassProb L_A threshold :=
    api.thresholdPassProb_lt_of_same_mean_scale_lt_of_mean_lt
      hmean.symm hscale_gap hthreshold_gt_mean
  exact paper_proposition1_diversity_share_lt_population_share_of_mixture_tail_gap
    hpi_pos hpi_lt_one hcapacity_pos hcapacity htail_gap

/--
Proposition 1 diversity under-representation from total precision: if group A
has strictly larger total signal precision than group B, both groups share the
same prior mean and variance, and the resulting threshold realizes a selective
capacity below one half, then group B is under-represented.
-/
theorem paper_proposition1_diversity_share_lt_population_share_of_precision_gap_capacity_lt_half
    (api : StandardGaussianCDFAPI)
    {Feature : Type*} [Fintype Feature] [Nonempty Feature]
    {M_B M_A : GaussianOffsetSignalFamily Feature}
    {pi capacity threshold : ℝ}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_pos : 0 < capacity)
    (hpriorMean : M_A.priorMean = M_B.priorMean)
    (hpriorVar : M_B.priorVar = M_A.priorVar)
    (hsum :
      (∑ k : Feature, M_B.centeredFamily.signalPrecision k) <
        ∑ k : Feature, M_A.centeredFamily.signalPrecision k)
    (hcapacity :
      capacity =
        (1 - pi) *
            api.thresholdPassProb M_A.posteriorMeanScaleLaw threshold +
          pi * api.thresholdPassProb M_B.posteriorMeanScaleLaw threshold)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ)) :
    pi * api.thresholdPassProb M_B.posteriorMeanScaleLaw threshold / capacity < pi := by
  have hmean :
      M_A.posteriorMeanScaleLaw.mean = M_B.posteriorMeanScaleLaw.mean := by
    simpa [GaussianOffsetSignalFamily.posteriorMeanScaleLaw] using hpriorMean
  have hscale :
      M_B.posteriorMeanScaleLaw.scale < M_A.posteriorMeanScaleLaw.scale :=
    paper_proposition1_estimated_skill_scale_lt_of_total_precision_lt
      hpriorVar hsum
  exact
    paper_proposition1_diversity_share_lt_population_share_of_scale_gap_capacity_lt_half
      api hpi_pos hpi_lt_one hcapacity_pos hmean hscale
      hcapacity hcapacity_lt_half

/--
Proposition 1 diversity monotonicity support: for fixed group-B score law,
population share, and capacity, raising the common admissions threshold
strictly decreases group B's admitted share.
-/
theorem paper_proposition1_diversity_share_decreases_of_threshold_increases
    (api : StandardGaussianCDFAPI)
    {pi capacity thresholdLow thresholdHigh : ℝ}
    {L_B : GaussianScaleLaw}
    (hpi_pos : 0 < pi) (hcapacity_pos : 0 < capacity)
    (hthreshold : thresholdLow < thresholdHigh) :
    pi * api.thresholdPassProb L_B thresholdHigh / capacity <
      pi * api.thresholdPassProb L_B thresholdLow / capacity := by
  have htail :
      api.thresholdPassProb L_B thresholdHigh <
        api.thresholdPassProb L_B thresholdLow :=
    api.thresholdPassProb_strictAnti_threshold L_B hthreshold
  exact div_lt_div_of_pos_right
    (mul_lt_mul_of_pos_left htail hpi_pos) hcapacity_pos

/--
Proposition 1 comparative-statics support: the variance term in the closed-form
threshold equation increases when group A's total precision increases.
-/
theorem paper_proposition1_threshold_variance_term_lt_of_precision_gap_lt
    {priorPrecision sigmaSq pi fixedPrecision delta delta' : ℝ}
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsigmaSq_pos : 0 < sigmaSq)
    (hleftWeight_pos : 0 < 1 - pi)
    (hbase_nonneg : 0 ≤ fixedPrecision + delta)
    (hdelta : delta < delta') :
    (1 - pi) * sigmaSq *
          ((fixedPrecision + delta) /
            (priorPrecision + (fixedPrecision + delta))) +
        pi * sigmaSq *
          (fixedPrecision / (priorPrecision + fixedPrecision)) <
      (1 - pi) * sigmaSq *
          ((fixedPrecision + delta') /
            (priorPrecision + (fixedPrecision + delta'))) +
        pi * sigmaSq *
          (fixedPrecision / (priorPrecision + fixedPrecision)) := by
  have hratio :
      (fixedPrecision + delta) /
          (priorPrecision + (fixedPrecision + delta)) <
        (fixedPrecision + delta') /
          (priorPrecision + (fixedPrecision + delta')) :=
    div_const_add_lt_div_const_add
      hpriorPrecision_pos hbase_nonneg (by linarith)
  have hweight_pos : 0 < (1 - pi) * sigmaSq :=
    mul_pos hleftWeight_pos hsigmaSq_pos
  have hweighted :
      (1 - pi) * sigmaSq *
          ((fixedPrecision + delta) /
            (priorPrecision + (fixedPrecision + delta))) <
        (1 - pi) * sigmaSq *
          ((fixedPrecision + delta') /
            (priorPrecision + (fixedPrecision + delta'))) :=
    mul_lt_mul_of_pos_left hratio hweight_pos
  simpa [add_comm, add_left_comm, add_assoc, mul_assoc] using
    add_lt_add_right hweighted
      (pi * sigmaSq * (fixedPrecision / (priorPrecision + fixedPrecision)))

/--
Proposition 1 comparative-statics support: multiplying a square-root threshold
term by a positive quantile preserves a strict increase in the variance term.
-/
theorem paper_proposition1_threshold_formula_lt_of_variance_term_lt
    {mean quantile term term' : ℝ}
    (hquantile_pos : 0 < quantile)
    (hterm_nonneg : 0 ≤ term)
    (hterm : term < term') :
    mean + quantile * Real.sqrt term <
      mean + quantile * Real.sqrt term' := by
  have hsqrt : Real.sqrt term < Real.sqrt term' :=
    Real.sqrt_lt_sqrt hterm_nonneg hterm
  simpa [add_comm, add_left_comm, add_assoc] using
    add_lt_add_left (mul_lt_mul_of_pos_left hsqrt hquantile_pos) mean

/--
Proposition 1 comparative-statics support: the paper's closed-form threshold
increases when group A's informativeness gap increases, provided the displayed
variance term is nonnegative and the normal quantile multiplier is positive.
-/
theorem paper_proposition1_threshold_formula_lt_of_precision_gap_lt
    {mean quantile priorPrecision sigmaSq pi fixedPrecision delta delta' : ℝ}
    (hquantile_pos : 0 < quantile)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsigmaSq_pos : 0 < sigmaSq)
    (hleftWeight_pos : 0 < 1 - pi)
    (hbase_nonneg : 0 ≤ fixedPrecision + delta)
    (hterm_nonneg :
      0 ≤
        (1 - pi) * sigmaSq *
            ((fixedPrecision + delta) /
              (priorPrecision + (fixedPrecision + delta))) +
          pi * sigmaSq *
            (fixedPrecision / (priorPrecision + fixedPrecision)))
    (hdelta : delta < delta') :
    mean + quantile * Real.sqrt
        ((1 - pi) * sigmaSq *
            ((fixedPrecision + delta) /
              (priorPrecision + (fixedPrecision + delta))) +
          pi * sigmaSq *
            (fixedPrecision / (priorPrecision + fixedPrecision))) <
      mean + quantile * Real.sqrt
        ((1 - pi) * sigmaSq *
            ((fixedPrecision + delta') /
              (priorPrecision + (fixedPrecision + delta'))) +
          pi * sigmaSq *
            (fixedPrecision / (priorPrecision + fixedPrecision))) :=
  paper_proposition1_threshold_formula_lt_of_variance_term_lt
    hquantile_pos hterm_nonneg
    (paper_proposition1_threshold_variance_term_lt_of_precision_gap_lt
      hpriorPrecision_pos hsigmaSq_pos hleftWeight_pos hbase_nonneg hdelta)

/--
Proposition 1 diversity comparative statics: using the paper's closed-form
threshold formula, increasing group A's informativeness gap strictly decreases
group B's admitted share when group B's score law and capacity are fixed.
-/
theorem paper_proposition1_diversity_share_decreases_of_precision_gap_lt
    (api : StandardGaussianCDFAPI)
    {L_B : GaussianScaleLaw}
    {populationShareB capacity mean quantile priorPrecision sigmaSq pi
      fixedPrecision delta delta' : ℝ}
    (hpopulation_pos : 0 < populationShareB)
    (hcapacity_pos : 0 < capacity)
    (hquantile_pos : 0 < quantile)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsigmaSq_pos : 0 < sigmaSq)
    (hleftWeight_pos : 0 < 1 - pi)
    (hbase_nonneg : 0 ≤ fixedPrecision + delta)
    (hterm_nonneg :
      0 ≤
        (1 - pi) * sigmaSq *
            ((fixedPrecision + delta) /
              (priorPrecision + (fixedPrecision + delta))) +
          pi * sigmaSq *
            (fixedPrecision / (priorPrecision + fixedPrecision)))
    (hdelta : delta < delta') :
    populationShareB *
        api.thresholdPassProb L_B
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) /
        capacity <
      populationShareB *
        api.thresholdPassProb L_B
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) /
        capacity :=
  paper_proposition1_diversity_share_decreases_of_threshold_increases
    api hpopulation_pos hcapacity_pos
    (paper_proposition1_threshold_formula_lt_of_precision_gap_lt
      hquantile_pos hpriorPrecision_pos hsigmaSq_pos hleftWeight_pos
      hbase_nonneg hterm_nonneg hdelta)

/--
Proposition 1 group-B comparative statics from the paper's closed-form
threshold formula: increasing group A's informativeness gap strictly decreases
a fixed group-B student's admission probability.
-/
theorem paper_proposition1_groupB_admission_probability_decreases_of_precision_gap_lt
    (api : StandardGaussianCDFAPI)
    {L_B : GaussianScaleLaw}
    {mean quantile priorPrecision sigmaSq pi fixedPrecision delta delta' : ℝ}
    (hquantile_pos : 0 < quantile)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsigmaSq_pos : 0 < sigmaSq)
    (hleftWeight_pos : 0 < 1 - pi)
    (hbase_nonneg : 0 ≤ fixedPrecision + delta)
    (hterm_nonneg :
      0 ≤
        (1 - pi) * sigmaSq *
            ((fixedPrecision + delta) /
              (priorPrecision + (fixedPrecision + delta))) +
          pi * sigmaSq *
            (fixedPrecision / (priorPrecision + fixedPrecision)))
    (hdelta : delta < delta') :
    api.thresholdPassProb L_B
        (mean + quantile * Real.sqrt
          ((1 - pi) * sigmaSq *
              ((fixedPrecision + delta') /
                (priorPrecision + (fixedPrecision + delta'))) +
            pi * sigmaSq *
              (fixedPrecision / (priorPrecision + fixedPrecision)))) <
      api.thresholdPassProb L_B
        (mean + quantile * Real.sqrt
          ((1 - pi) * sigmaSq *
              ((fixedPrecision + delta) /
                (priorPrecision + (fixedPrecision + delta))) +
            pi * sigmaSq *
              (fixedPrecision / (priorPrecision + fixedPrecision)))) :=
  paper_proposition1_groupB_admission_probability_decreases_of_threshold_increases
    api
    (paper_proposition1_threshold_formula_lt_of_precision_gap_lt
      hquantile_pos hpriorPrecision_pos hsigmaSq_pos hleftWeight_pos
      hbase_nonneg hterm_nonneg hdelta)

/--
Proposition 1 individual-fairness comparative statics with the paper's
closed-form threshold formula: after the scalar group-A standardized-cutoff
inequality is established, increasing group A's informativeness gap strictly
increases the individual-fairness gap for the compared skill.
-/
theorem paper_proposition1_individual_fairness_gap_increases_of_precision_gap_lt
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P_low P_high : Policy}
    {L_A_low L_A_high L_B : GaussianScaleLaw}
    {mean quantile priorPrecision sigmaSq pi fixedPrecision delta delta' q : ℝ}
    (hgap_low :
      S.individualFairnessGap P_low q =
        api.thresholdPassProb L_A_low
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) -
          api.thresholdPassProb L_B
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))))
    (hgap_high :
      S.individualFairnessGap P_high q =
        api.thresholdPassProb L_A_high
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) -
          api.thresholdPassProb L_B
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))))
    (hquantile_pos : 0 < quantile)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsigmaSq_pos : 0 < sigmaSq)
    (hleftWeight_pos : 0 < 1 - pi)
    (hbase_nonneg : 0 ≤ fixedPrecision + delta)
    (hterm_nonneg :
      0 ≤
        (1 - pi) * sigmaSq *
            ((fixedPrecision + delta) /
              (priorPrecision + (fixedPrecision + delta))) +
          pi * sigmaSq *
            (fixedPrecision / (priorPrecision + fixedPrecision)))
    (hdelta : delta < delta')
    (hstd :
      L_A_high.standardize
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) <
        L_A_low.standardize
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision))))) :
    S.individualFairnessGap P_low q <
      S.individualFairnessGap P_high q :=
  paper_proposition1_individual_fairness_gap_increases_of_threshold_and_standardized_monotonicity
    api hgap_low hgap_high
    (paper_proposition1_threshold_formula_lt_of_precision_gap_lt
      hquantile_pos hpriorPrecision_pos hsigmaSq_pos hleftWeight_pos
      hbase_nonneg hterm_nonneg hdelta)
    hstd

/--
Proposition 1 individual-fairness comparative statics for high-skilled
students with the paper's closed-form threshold formula and the scalar
group-A standardized-cutoff formula.  This is the formal version of Step 3 in
the proof of Proposition 1: the group-B admission probability falls because
the common threshold rises, while the group-A admission probability rises for
skills above the perfect-information cutoff.
-/
theorem paper_proposition1_individual_fairness_gap_increases_of_precision_gap_high_skill_formula
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P_low P_high : Policy}
    {L_A_low L_A_high L_B : GaussianScaleLaw}
    {mean quantile priorPrecision sigmaSq pi fixedPrecision delta delta' q
      a c d quantileScale sqrtPrecLow sqrtPrecHigh : ℝ}
    (hgap_low :
      S.individualFairnessGap P_low q =
        api.thresholdPassProb L_A_low
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) -
          api.thresholdPassProb L_B
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))))
    (hgap_high :
      S.individualFairnessGap P_high q =
        api.thresholdPassProb L_A_high
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) -
          api.thresholdPassProb L_B
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))))
    (hstd_low :
      L_A_low.standardize
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) =
        quantileScale *
            Real.sqrt (a * sqrtPrecLow ^ 2 + c + d / sqrtPrecLow ^ 2) -
          sqrtPrecLow * (q - mean))
    (hstd_high :
      L_A_high.standardize
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) =
        quantileScale *
            Real.sqrt (a * sqrtPrecHigh ^ 2 + c + d / sqrtPrecHigh ^ 2) -
          sqrtPrecHigh * (q - mean))
    (hquantile_pos : 0 < quantile)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsigmaSq_pos : 0 < sigmaSq)
    (hleftWeight_pos : 0 < 1 - pi)
    (hbase_nonneg : 0 ≤ fixedPrecision + delta)
    (hterm_nonneg :
      0 ≤
        (1 - pi) * sigmaSq *
            ((fixedPrecision + delta) /
              (priorPrecision + (fixedPrecision + delta))) +
          pi * sigmaSq *
            (fixedPrecision / (priorPrecision + fixedPrecision)))
    (hdelta : delta < delta')
    (ha_pos : 0 < a) (ha_le_one : a ≤ 1)
    (hc_nonneg : 0 ≤ c) (hd_nonneg : 0 ≤ d)
    (hquantileScale_pos : 0 < quantileScale)
    (hhighSkill : quantileScale < q - mean)
    (hsqrtLow_pos : 0 < sqrtPrecLow)
    (hprecision : sqrtPrecLow < sqrtPrecHigh) :
    S.individualFairnessGap P_low q <
      S.individualFairnessGap P_high q :=
  paper_proposition1_individual_fairness_gap_increases_of_high_skill_standardized_formula
    api hgap_low hgap_high hstd_low hstd_high
    (paper_proposition1_threshold_formula_lt_of_precision_gap_lt
      hquantile_pos hpriorPrecision_pos hsigmaSq_pos hleftWeight_pos
      hbase_nonneg hterm_nonneg hdelta)
    ha_pos ha_le_one hc_nonneg hd_nonneg hquantileScale_pos hhighSkill
    hsqrtLow_pos hprecision

/--
Proposition 1 group-fairness failure core: under the two-group Gaussian
capacity equation, a strictly larger group-A score scale and selective capacity
imply that the paper's group-fairness predicate fails.
-/
theorem paper_proposition1_not_group_fair_of_scale_gap_capacity_lt_half
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {pi capacity threshold : ℝ} {L_A L_B : GaussianScaleLaw}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_pos : 0 < capacity)
    (hmean : L_A.mean = L_B.mean)
    (hscale_gap : L_B.scale < L_A.scale)
    (hcapacity :
      capacity =
        (1 - pi) * api.thresholdPassProb L_A threshold +
          pi * api.thresholdPassProb L_B threshold)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ))
    (hdiversity :
      S.diversity P = pi * api.thresholdPassProb L_B threshold / capacity)
    (hpopulation : S.populationShareB = pi) :
    ¬ glm20GroupFair S P := by
  apply paper_proposition1_not_group_fair_of_diversity_lt
  rw [hdiversity, hpopulation]
  exact
    paper_proposition1_diversity_share_lt_population_share_of_scale_gap_capacity_lt_half
      api hpi_pos hpi_lt_one hcapacity_pos hmean hscale_gap
      hcapacity hcapacity_lt_half

/--
Proposition 1 group-fairness failure from total precision: a strict group-A
precision advantage, common prior, and selective capacity imply the paper's
group-fairness predicate fails.
-/
theorem paper_proposition1_not_group_fair_of_precision_gap_capacity_lt_half
    (api : StandardGaussianCDFAPI)
    {Feature : Type*} [Fintype Feature] [Nonempty Feature]
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {M_B M_A : GaussianOffsetSignalFamily Feature}
    {pi capacity threshold : ℝ}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_pos : 0 < capacity)
    (hpriorMean : M_A.priorMean = M_B.priorMean)
    (hpriorVar : M_B.priorVar = M_A.priorVar)
    (hsum :
      (∑ k : Feature, M_B.centeredFamily.signalPrecision k) <
        ∑ k : Feature, M_A.centeredFamily.signalPrecision k)
    (hcapacity :
      capacity =
        (1 - pi) *
            api.thresholdPassProb M_A.posteriorMeanScaleLaw threshold +
          pi * api.thresholdPassProb M_B.posteriorMeanScaleLaw threshold)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ))
    (hdiversity :
      S.diversity P =
        pi * api.thresholdPassProb M_B.posteriorMeanScaleLaw threshold / capacity)
    (hpopulation : S.populationShareB = pi) :
    ¬ glm20GroupFair S P := by
  apply paper_proposition1_not_group_fair_of_diversity_lt
  rw [hdiversity, hpopulation]
  exact
    paper_proposition1_diversity_share_lt_population_share_of_precision_gap_capacity_lt_half
      api hpi_pos hpi_lt_one hcapacity_pos hpriorMean hpriorVar hsum
      hcapacity hcapacity_lt_half

/--
Proposition 1 fixed-policy static core: under the paper's Gaussian metric
equations, unequal informativeness yields all three static conclusions:
group fairness fails, individual fairness fails, and admitted group-B academic
merit is strictly below group A's.
-/
theorem paper_proposition1_fixed_policy_static_core
    (C : GaussianHazardCertificate)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (groupA groupB : Group)
    {L_A L_B : GaussianScaleLaw}
    {pi capacity threshold priorPrecision sqrtPrecB sqrtPrecA mean : ℝ}
    {lawA lawB : ℝ → GaussianScaleLaw}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_pos : 0 < capacity)
    (hmean : L_A.mean = L_B.mean)
    (hscale : L_B.scale < L_A.scale)
    (hcapacity :
      capacity =
        (1 - pi) * C.api.thresholdPassProb L_A threshold +
          pi * C.api.thresholdPassProb L_B threshold)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ))
    (hdiversity :
      S.diversity P = pi * C.api.thresholdPassProb L_B threshold / capacity)
    (hpopulation : S.populationShareB = pi)
    (hgap_eq : ∀ q,
      S.individualFairnessGap P q =
        C.api.thresholdPassProb (lawA q) threshold -
          C.api.thresholdPassProb (lawB q) threshold)
    (hstdA : ∀ q,
      (lawA q).standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecA +
          sqrtPrecA * (threshold - q))
    (hstdB : ∀ q,
      (lawB q).standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecB +
          sqrtPrecB * (threshold - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hprecision_gap : sqrtPrecB < sqrtPrecA)
    (hmeritA :
      S.academicMerit groupA P = C.normalUpperTailMean L_A threshold)
    (hmeritB :
      S.academicMerit groupB P = C.normalUpperTailMean L_B threshold) :
    ¬ glm20GroupFair S P ∧
      ¬ glm20IndividualFair S P ∧
        S.academicMerit groupB P < S.academicMerit groupA P := by
  have hthreshold : L_B.mean < threshold :=
    paper_proposition1_threshold_gt_common_mean_of_capacity_lt_half
      C.api hpi_pos.le hpi_lt_one.le hmean hcapacity hcapacity_lt_half
  exact ⟨
    paper_proposition1_not_group_fair_of_scale_gap_capacity_lt_half
      C.api hpi_pos hpi_lt_one hcapacity_pos hmean hscale
      hcapacity hcapacity_lt_half hdiversity hpopulation,
    paper_proposition1_not_individual_fair_of_precision_tail_formulas
      C.api hgap_eq hstdA hstdB hsqrtB_pos hsqrtA_pos hprecision_gap,
    paper_proposition1_groupB_academic_merit_lt_groupA_of_tail_mean
      C groupA groupB hmean.symm hscale hthreshold hmeritA hmeritB⟩

/--
Proposition 1 canonical fixed-policy source surface.

For the fixed policy `P`, diversity is the admitted group-B share, the
individual-fairness gap is the group-A minus group-B Gaussian admission
probability at skill `q`, and group academic merit is the corresponding
Gaussian upper-tail mean.  All other policies and unused fields are neutral.
-/
def proposition1FixedPolicySourceSurface
    (C : GaussianHazardCertificate)
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) (P : Policy)
    (pi capacity threshold : ℝ)
    (L_A L_B : GaussianScaleLaw)
    (lawA lawB : ℝ → GaussianScaleLaw) :
    GLM20SourcePolicySurface Group Policy where
  populationShareB := pi
  capacity := capacity
  precision := fun _ _ => 0
  accessLevel := fun _ => 1
  estimatedSkillMean := fun _ _ => 0
  estimatedSkillVariance := fun _ _ => 0
  admissionThreshold := fun P' => if P' = P then threshold else 0
  diversity := fun P' =>
    if P' = P then
      pi * C.api.thresholdPassProb L_B threshold / capacity
    else
      0
  individualFairnessGap := fun P' q =>
    if P' = P then
      C.api.thresholdPassProb (lawA q) threshold -
        C.api.thresholdPassProb (lawB q) threshold
    else
      0
  academicMerit := fun g P' =>
    if P' = P then
      if g = groupB then
        C.normalUpperTailMean L_B threshold
      else if g = groupA then
        C.normalUpperTailMean L_A threshold
      else
        0
    else
      0

/--
Paper Proposition 1, canonical fixed-policy static endpoint.

Paper statement: with a fixed admissions policy and unequal informativeness,
the group-fairness predicate fails, individual fairness fails, and admitted
group-B academic merit is strictly below admitted group-A academic merit.

This theorem removes the abstract source-surface metric premises from
`paper_proposition1_fixed_policy_static_core`: the canonical surface makes the
paper's diversity, individual-fairness gap, population share, and admitted merit
formulas definitional.
-/
theorem paper_proposition1_fixed_policy_static_core_source_surface
    (C : GaussianHazardCertificate)
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) (P : Policy)
    {L_A L_B : GaussianScaleLaw}
    {pi capacity threshold priorPrecision sqrtPrecB sqrtPrecA mean : ℝ}
    {lawA lawB : ℝ → GaussianScaleLaw}
    (hgroups : groupA ≠ groupB)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_pos : 0 < capacity)
    (hmean : L_A.mean = L_B.mean)
    (hscale : L_B.scale < L_A.scale)
    (hcapacity :
      capacity =
        (1 - pi) * C.api.thresholdPassProb L_A threshold +
          pi * C.api.thresholdPassProb L_B threshold)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ))
    (hstdA : ∀ q,
      (lawA q).standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecA +
          sqrtPrecA * (threshold - q))
    (hstdB : ∀ q,
      (lawB q).standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecB +
          sqrtPrecB * (threshold - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hprecision_gap : sqrtPrecB < sqrtPrecA) :
    let S : GLM20SourcePolicySurface Group Policy :=
      proposition1FixedPolicySourceSurface C groupA groupB P
        pi capacity threshold L_A L_B lawA lawB
    ¬ glm20GroupFair S P ∧
      ¬ glm20IndividualFair S P ∧
        S.academicMerit groupB P < S.academicMerit groupA P := by
  dsimp only
  refine
    paper_proposition1_fixed_policy_static_core
      (S :=
        proposition1FixedPolicySourceSurface C groupA groupB P
          pi capacity threshold L_A L_B lawA lawB)
      C groupA groupB hpi_pos hpi_lt_one hcapacity_pos hmean hscale
      hcapacity hcapacity_lt_half ?_ ?_ ?_ hstdA hstdB
      hsqrtB_pos hsqrtA_pos hprecision_gap ?_ ?_
  · simp [proposition1FixedPolicySourceSurface]
  · simp [proposition1FixedPolicySourceSurface]
  · intro q
    simp [proposition1FixedPolicySourceSurface]
  · simp [proposition1FixedPolicySourceSurface, hgroups]
  · simp [proposition1FixedPolicySourceSurface]

/--
Paper Proposition 1, canonical fixed-policy static endpoint for the concrete
mathlib-backed standard normal.

This specializes `paper_proposition1_fixed_policy_static_core_source_surface`
with `standardGaussianHazardInverseCertificate`, so the CDF, density, hazard,
and upper-tail-mean primitives are the real standard-normal objects supplied by
the shared Gaussian library.
-/
theorem paper_proposition1_fixed_policy_static_core_source_surface_standardGaussian
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) (P : Policy)
    {L_A L_B : GaussianScaleLaw}
    {pi capacity threshold priorPrecision sqrtPrecB sqrtPrecA mean : ℝ}
    {lawA lawB : ℝ → GaussianScaleLaw}
    (hgroups : groupA ≠ groupB)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_pos : 0 < capacity)
    (hmean : L_A.mean = L_B.mean)
    (hscale : L_B.scale < L_A.scale)
    (hcapacity :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb L_A threshold +
          pi * standardGaussianCDFAPI.thresholdPassProb L_B threshold)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ))
    (hstdA : ∀ q,
      (lawA q).standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecA +
          sqrtPrecA * (threshold - q))
    (hstdB : ∀ q,
      (lawB q).standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecB +
          sqrtPrecB * (threshold - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hprecision_gap : sqrtPrecB < sqrtPrecA) :
    let S : GLM20SourcePolicySurface Group Policy :=
      proposition1FixedPolicySourceSurface
        standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
        groupA groupB P
        pi capacity threshold L_A L_B lawA lawB
    ¬ glm20GroupFair S P ∧
      ¬ glm20IndividualFair S P ∧
        S.academicMerit groupB P < S.academicMerit groupA P :=
    paper_proposition1_fixed_policy_static_core_source_surface
      standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
      groupA groupB P hgroups hpi_pos hpi_lt_one hcapacity_pos hmean hscale hcapacity
      hcapacity_lt_half hstdA hstdB hsqrtB_pos hsqrtA_pos hprecision_gap

/--
Definition 1 from Appendix F in finite-kernel form: one experiment is sufficient
for another when the less-informative posterior experiment is obtained by a
garbling of the more-informative one.
-/
abbrev glm20BlackwellSufficient {Q RichSignal CoarseSignal : Type*}
    (rich : Q → PMF RichSignal) (coarse : Q → PMF CoarseSignal) : Prop := BlackwellSufficient rich coarse

/-- Appendix F Blackwell sufficiency from an explicit garbling kernel. -/
theorem glm20BlackwellSufficient_bind
    {Q RichSignal CoarseSignal : Type*}
    (rich : Q → PMF RichSignal)
    (garbling : RichSignal → PMF CoarseSignal) :
    glm20BlackwellSufficient rich (fun q => (rich q).bind garbling) :=  BlackwellSufficient.bind rich garbling

/-- Deterministic post-processing is a Blackwell garbling. -/
theorem glm20BlackwellSufficient_map
    {Q RichSignal CoarseSignal : Type*}
    (rich : Q → PMF RichSignal) (f : RichSignal → CoarseSignal) :
    glm20BlackwellSufficient rich (fun q => (rich q).map f) :=  BlackwellSufficient.map rich f

/-- Appendix F Blackwell sufficiency is reflexive. -/
theorem glm20BlackwellSufficient_refl
    {Q Signal : Type*} (experiment : Q → PMF Signal) :
    glm20BlackwellSufficient experiment experiment :=  BlackwellSufficient.refl experiment

/-- Appendix F Blackwell sufficiency is transitive under composition of garblings. -/
theorem glm20BlackwellSufficient_trans
    {Q RichSignal MidSignal CoarseSignal : Type*}
    {rich : Q → PMF RichSignal}
    {middle : Q → PMF MidSignal}
    {coarse : Q → PMF CoarseSignal}
    (hrich_mid : glm20BlackwellSufficient rich middle)
    (hmid_coarse : glm20BlackwellSufficient middle coarse) :
    glm20BlackwellSufficient rich coarse :=  BlackwellSufficient.trans hrich_mid hmid_coarse

/--
Appendix F / Proposition 7 crossing-point diversity support.

Paper statement, Proposition 7(i): if the group-A and group-B posterior-score
CDFs cross once at `q_plus`, the school admits by an aggregate threshold
`qStar`, and the aggregate CDF is
`\hat F = (1-\pi)\hat F_A + \pi \hat F_B`, then group B is
under-represented exactly when `C < 1 - \hat F(q_plus)`.

The SSD-to-single-crossing step is intentionally kept as the hypothesis
`hcross_high`; this theorem proves the algebraic and threshold part of the
paper proof after Lemma F.4 supplies that crossing.
-/
theorem paper_proposition7_diversity_underrepresented_iff_capacity_lt_crossing_tail
    {Fhat FA FB : ℝ → ℝ}
    {pi capacity qStar qPlus tauB : ℝ}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_pos : 0 < capacity)
    (hFhat :
      ∀ q : ℝ, Fhat q = (1 - pi) * FA q + pi * FB q)
    (hcapacity :
      capacity =
        (1 - pi) * (1 - FA qStar) + pi * (1 - FB qStar))
    (hthreshold : Fhat qStar = 1 - capacity)
    (hFhat_strictMono : StrictMono Fhat)
    (hcross_high : FA qStar < FB qStar ↔ qPlus < qStar)
    (htauB : tauB = pi * (1 - FB qStar) / capacity) :
    tauB < pi ↔ capacity < 1 - Fhat qPlus := by
  have hnotA_pos : 0 < 1 - pi := by
    linarith
  have htau_iff : tauB < pi ↔ FA qStar < FB qStar := by
    constructor
    · intro htau
      rw [htauB] at htau
      have htailB_lt_capacity : 1 - FB qStar < capacity := by
        have hmul : pi * (1 - FB qStar) < pi * capacity :=
          (div_lt_iff₀ hcapacity_pos).mp htau
        exact lt_of_mul_lt_mul_left hmul hpi_pos.le
      rw [hcapacity] at htailB_lt_capacity
      have htailB_lt_tailA : 1 - FB qStar < 1 - FA qStar := by
        nlinarith [hnotA_pos, htailB_lt_capacity]
      linarith
    · intro hcdf
      have htailB_lt_tailA : 1 - FB qStar < 1 - FA qStar := by
        linarith
      rw [htauB]
      have htailB_lt_capacity : 1 - FB qStar < capacity := by
        rw [hcapacity]
        nlinarith [hnotA_pos, htailB_lt_tailA]
      have hmul : pi * (1 - FB qStar) < pi * capacity :=
        mul_lt_mul_of_pos_left htailB_lt_capacity hpi_pos
      exact (div_lt_iff₀ hcapacity_pos).mpr hmul
  rw [htau_iff, hcross_high]
  constructor
  · intro hq
    have hF_lt : Fhat qPlus < Fhat qStar :=
      hFhat_strictMono hq
    rw [hthreshold] at hF_lt
    linarith
  · intro hcap
    have hF_lt : Fhat qPlus < Fhat qStar := by
      rw [hthreshold]
      linarith
    exact hFhat_strictMono.lt_iff_lt.mp hF_lt

/--
Appendix F / Lemma F.3 utility-order interface.

The paper invokes the standard equivalence between mean-preserving spreads,
second-order stochastic dominance, and expected utility for every weakly
increasing concave utility.  This predicate is the exact source-level utility
side of that equivalence: the `low` posterior-score law has weakly lower
utility than the `high` law for every weakly increasing concave utility.
-/
def glm20IncreasingConcaveUtilityWeakOrder
    (expectedLow expectedHigh : (ℝ → ℝ) → ℝ) : Prop :=
  ∀ u : ℝ → ℝ, Monotone u → ConcaveOn ℝ Set.univ u →
    expectedLow u ≤ expectedHigh u

/--
Appendix F / Proposition 7(ii), weak academic-merit form.

Paper statement: under the same second-order stochastic-dominance /
mean-preserving-spread condition as Proposition 7, for every capacity the
policy has worse academic merit for admitted group-B students.  The cited
Lemma F.3 supplies the increasing-concave utility order; instantiating it with
the linear utility `u(x)=x` gives the admitted-merit comparison.
-/
theorem paper_proposition7_academic_merit_groupB_le_groupA_of_increasingConcaveOrder
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {groupA groupB : Group}
    {expectedB expectedA : (ℝ → ℝ) → ℝ}
    (horder : glm20IncreasingConcaveUtilityWeakOrder expectedB expectedA)
    (hmeritA : S.academicMerit groupA P = expectedA (fun x : ℝ => x))
    (hmeritB : S.academicMerit groupB P = expectedB (fun x : ℝ => x)) :
    S.academicMerit groupB P ≤ S.academicMerit groupA P := by
  have hid_mono : Monotone (fun x : ℝ => x) :=
    monotone_id
  have hid_concave : ConcaveOn ℝ Set.univ (fun x : ℝ => x) := by
    simpa [id] using
      (concaveOn_id (𝕜 := ℝ) (s := (Set.univ : Set ℝ)) convex_univ)
  have hlinear := horder (fun x : ℝ => x) hid_mono hid_concave
  rw [hmeritB, hmeritA]
  exact hlinear

/--
Appendix F / Proposition 7(ii), strict academic-merit form.

This is the strict form used when the source dominance is strict enough that
the linear-utility comparison of admitted posterior scores is strict.
-/
theorem paper_proposition7_academic_merit_groupB_lt_groupA_of_linearUtility
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {groupA groupB : Group}
    {expectedB expectedA : (ℝ → ℝ) → ℝ}
    (hlinear :
      expectedB (fun x : ℝ => x) < expectedA (fun x : ℝ => x))
    (hmeritA : S.academicMerit groupA P = expectedA (fun x : ℝ => x))
    (hmeritB : S.academicMerit groupB P = expectedB (fun x : ℝ => x)) :
    S.academicMerit groupB P < S.academicMerit groupA P := by
  rw [hmeritB, hmeritA]
  exact hlinear

/--
Appendix F / Proposition 7(iii), individual-fairness threshold form.

Paper statement: sufficiency gives a threshold `qhat` such that the individual
fairness gap is positive iff `q > qhat`.  The Blackwell/SSD crossing lemma
supplies the admission-probability crossing; this theorem proves the
source-surface gap rewriting.
-/
theorem paper_proposition7_individual_fairness_gap_positive_iff_above_threshold
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {admitA admitB : ℝ → ℝ} {qhat : ℝ}
    (hgap :
      ∀ q : ℝ, S.individualFairnessGap P q = admitA q - admitB q)
    (hcross : ∀ q : ℝ, admitA q > admitB q ↔ qhat < q) :
    ∀ q : ℝ, 0 < S.individualFairnessGap P q ↔ qhat < q := by
  intro q
  rw [hgap q]
  constructor
  · intro hpos
    exact (hcross q).mp (by linarith)
  · intro hq
    have hprob : admitA q > admitB q :=
      (hcross q).mpr hq
    linarith

/--
Appendix F / Proposition 7(iii), existential threshold statement matching the
paper's wording.
-/
theorem paper_proposition7_exists_individual_fairness_threshold
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {admitA admitB : ℝ → ℝ} {qhat : ℝ}
    (hgap :
      ∀ q : ℝ, S.individualFairnessGap P q = admitA q - admitB q)
    (hcross : ∀ q : ℝ, admitA q > admitB q ↔ qhat < q) :
    ∃ qhat : ℝ, ∀ q : ℝ, 0 < S.individualFairnessGap P q ↔ qhat < q :=
  ⟨qhat,
    paper_proposition7_individual_fairness_gap_positive_iff_above_threshold
      hgap hcross⟩

/--
Affirmative-action fixed-policy support: if affirmative action raises the
group-A threshold and lowers the group-B threshold relative to the unconstrained
fixed policy, then the individual-fairness gap strictly improves at every
skill level.
-/
theorem paper_proposition8_individual_fairness_gap_improves_of_admission_probabilities
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {Pbase Paa : Policy}
    {admitABase admitBBase admitAAA admitBAA : ℝ → ℝ}
    (hgapBase :
      ∀ q : ℝ, S.individualFairnessGap Pbase q =
        admitABase q - admitBBase q)
    (hgapAA :
      ∀ q : ℝ, S.individualFairnessGap Paa q =
        admitAAA q - admitBAA q)
    (hA : ∀ q : ℝ, admitAAA q < admitABase q)
    (hB : ∀ q : ℝ, admitBBase q < admitBAA q) :
    ∀ q : ℝ,
      S.individualFairnessGap Paa q <
        S.individualFairnessGap Pbase q := by
  intro q
  rw [hgapAA q, hgapBase q]
  linarith [hA q, hB q]

/--
Affirmative-action fixed-policy algebra: with group-specific admission
thresholds, the standardized-threshold comparison is equivalent to the
displayed paper cutoff in Proposition 8(i).

Here `priorPrecision = σ^{-2}`, `sqrtPrecA = sqrt(∑ σ_{Ak}^{-2})`, and
`sqrtPrecB = sqrt(∑ σ_{Bk}^{-2})`.
-/
theorem paper_proposition8_standardized_threshold_lt_iff_skill_above_cutoff
    {priorPrecision sqrtPrecB sqrtPrecA thresholdA thresholdB mean q : ℝ}
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hgap : sqrtPrecB < sqrtPrecA) :
    priorPrecision * (thresholdA - mean) / sqrtPrecA +
        sqrtPrecA * (thresholdA - q) <
      priorPrecision * (thresholdB - mean) / sqrtPrecB +
        sqrtPrecB * (thresholdB - q) ↔
      ((priorPrecision + sqrtPrecA ^ 2) / sqrtPrecA * thresholdA -
            (priorPrecision + sqrtPrecB ^ 2) / sqrtPrecB * thresholdB) /
          (sqrtPrecA - sqrtPrecB) +
        mean * priorPrecision / (sqrtPrecA * sqrtPrecB) <
        q :=
  precisionStandardizedThreshold_lt_iff_cutoff_lt_skill
    hsqrtB_pos hsqrtA_pos hgap

/--
Affirmative-action fixed-policy support: a two-threshold Gaussian
admission-probability gap is positive exactly when the first standardized
threshold is lower.
-/
theorem paper_proposition8_tail_gap_pos_iff_standardized_threshold_lt
    (api : StandardGaussianCDFAPI)
    {L_A L_B : GaussianScaleLaw} {thresholdA thresholdB : ℝ} :
    0 < api.thresholdPassProb L_A thresholdA -
        api.thresholdPassProb L_B thresholdB ↔
      L_A.standardize thresholdA < L_B.standardize thresholdB := by
  rw [sub_pos]
  exact api.thresholdPassProb_gt_iff_standardize_lt_of_thresholds

/--
Affirmative-action fixed-policy support for Proposition 8(i): after rewriting
the two groups' standardized thresholds into the paper's precision form, the
affirmative-action individual-fairness gap is positive exactly above the
displayed skill cutoff.
-/
theorem paper_proposition8_individual_fairness_gap_pos_iff_skill_above_cutoff
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {Paa : Policy}
    {L_A L_B : GaussianScaleLaw}
    {priorPrecision sqrtPrecB sqrtPrecA thresholdA thresholdB mean q : ℝ}
    (hgap_eq :
      S.individualFairnessGap Paa q =
        api.thresholdPassProb L_A thresholdA -
          api.thresholdPassProb L_B thresholdB)
    (hstdA :
      L_A.standardize thresholdA =
        priorPrecision * (thresholdA - mean) / sqrtPrecA +
          sqrtPrecA * (thresholdA - q))
    (hstdB :
      L_B.standardize thresholdB =
        priorPrecision * (thresholdB - mean) / sqrtPrecB +
          sqrtPrecB * (thresholdB - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hprecision_gap : sqrtPrecB < sqrtPrecA) :
    0 < S.individualFairnessGap Paa q ↔
      ((priorPrecision + sqrtPrecA ^ 2) / sqrtPrecA * thresholdA -
            (priorPrecision + sqrtPrecB ^ 2) / sqrtPrecB * thresholdB) /
          (sqrtPrecA - sqrtPrecB) +
        mean * priorPrecision / (sqrtPrecA * sqrtPrecB) <
        q := by
  rw [hgap_eq]
  rw [paper_proposition8_tail_gap_pos_iff_standardized_threshold_lt api,
    hstdA, hstdB]
  exact paper_proposition8_standardized_threshold_lt_iff_skill_above_cutoff
    hsqrtB_pos hsqrtA_pos hprecision_gap

/--
Proposition 8(ii) academic-merit decomposition: if admitted group-B merit at
the lower affirmative-action threshold is a convex combination of the
below-`thresholdA` interval mean and the above-`thresholdA` group-B tail mean,
and both pieces are below group A's admitted merit at `thresholdA`, then group
B has lower admitted academic merit.
-/
theorem paper_proposition8_groupB_academic_merit_lt_groupA_of_tail_decomposition
    {meritA meritB intervalMeanB tailMeanBHigh weight : ℝ}
    (hweight_nonneg : 0 ≤ weight) (hweight_lt_one : weight < 1)
    (hinterval_lt_tailB : intervalMeanB < tailMeanBHigh)
    (htailB_lt_A : tailMeanBHigh < meritA)
    (hmeritB :
      meritB =
        weight * intervalMeanB + (1 - weight) * tailMeanBHigh) :
    meritB < meritA := by
  have hweight_tail_pos : 0 < 1 - weight := by
    linarith
  have hinterval_lt_A : intervalMeanB < meritA :=
    lt_trans hinterval_lt_tailB htailB_lt_A
  rw [hmeritB]
  have hleft :
      weight * intervalMeanB ≤ weight * meritA :=
    mul_le_mul_of_nonneg_left (le_of_lt hinterval_lt_A) hweight_nonneg
  have hright :
      (1 - weight) * tailMeanBHigh <
        (1 - weight) * meritA :=
    mul_lt_mul_of_pos_left htailB_lt_A hweight_tail_pos
  have hsum :
      weight * intervalMeanB + (1 - weight) * tailMeanBHigh <
        weight * meritA + (1 - weight) * meritA :=
    add_lt_add_of_le_of_lt hleft hright
  nlinarith

/--
Proposition 8(ii) support: for the concrete standard Gaussian, admitted
upper-tail mean is continuous in the admission threshold.
-/
theorem paper_standardGaussian_normalUpperTailMean_continuous_threshold
    (L : GaussianScaleLaw) :
    Continuous
      (GaussianHazardCertificate.normalUpperTailMean
        standardGaussianHazardInverseCertificate.toGaussianHazardCertificate L) := standardGaussian_normalUpperTailMean_continuous L

/--
Proposition 8(ii) support: for the concrete standard Gaussian, admitted
upper-tail mean is strictly increasing in the admission threshold.
-/
theorem paper_proposition8_standardGaussian_normalUpperTailMean_strictMono_threshold
    (L : GaussianScaleLaw) :
    StrictMono
      (GaussianHazardCertificate.normalUpperTailMean
        standardGaussianHazardInverseCertificate.toGaussianHazardCertificate L) :=
  standardGaussian_normalUpperTailMean_strictMono_threshold L

/--
Proposition 8(ii): when affirmative action raises group A's admission
threshold and lowers group B's threshold relative to the fixed testing policy,
standard-Gaussian upper-tail academic merit increases for group A and decreases
for group B.
-/
theorem paper_proposition8_academic_merit_changes_standardGaussian_of_threshold_order
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy}
    {groupA groupB : Group} {Pbase Paa : Policy}
    {L_A L_B : GaussianScaleLaw}
    {thresholdBase thresholdA thresholdB : ℝ}
    (hthresholdA : thresholdBase < thresholdA)
    (hthresholdB : thresholdB < thresholdBase)
    (hmeritABase :
      S.academicMerit groupA Pbase =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_A thresholdBase)
    (hmeritAAA :
      S.academicMerit groupA Paa =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_A thresholdA)
    (hmeritBBase :
      S.academicMerit groupB Pbase =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_B thresholdBase)
    (hmeritBAA :
      S.academicMerit groupB Paa =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_B thresholdB) :
    S.academicMerit groupA Pbase < S.academicMerit groupA Paa ∧
      S.academicMerit groupB Paa < S.academicMerit groupB Pbase := by
  constructor
  · rw [hmeritABase, hmeritAAA]
    exact
      paper_proposition8_standardGaussian_normalUpperTailMean_strictMono_threshold
        L_A hthresholdA
  · rw [hmeritBAA, hmeritBBase]
    exact
      paper_proposition8_standardGaussian_normalUpperTailMean_strictMono_threshold
        L_B hthresholdB

/--
Proposition 8, affirmative action under a fixed testing policy.

This bundles the paper-facing consequences after the model-side Gaussian
threshold identities have been reduced to the component lemmas above: the
individual-fairness gap improves pointwise, the affirmative-action gap is
positive exactly above the displayed cutoff, admitted group-B academic merit is
below group A's, group-A admitted merit increases, and group-B admitted merit
decreases.
-/
theorem paper_proposition8_affirmative_action_fixed_policy_standardGaussian
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy}
    {groupA groupB : Group} {Pbase Paa : Policy}
    {admitABase admitBBase admitAAA admitBAA : ℝ → ℝ}
    {L_AA L_BA : ℝ → GaussianScaleLaw}
    {L_A_merit L_B_merit : GaussianScaleLaw}
    {priorPrecision sqrtPrecB sqrtPrecA thresholdA thresholdB mean : ℝ}
    {thresholdBase : ℝ}
    {intervalMeanB tailMeanBHigh weight : ℝ}
    (hgapBase :
      ∀ q : ℝ, S.individualFairnessGap Pbase q =
        admitABase q - admitBBase q)
    (hgapAA :
      ∀ q : ℝ, S.individualFairnessGap Paa q =
        admitAAA q - admitBAA q)
    (hA_prob : ∀ q : ℝ, admitAAA q < admitABase q)
    (hB_prob : ∀ q : ℝ, admitBBase q < admitBAA q)
    (hgap_eq :
      ∀ q : ℝ, S.individualFairnessGap Paa q =
        api.thresholdPassProb (L_AA q) thresholdA -
          api.thresholdPassProb (L_BA q) thresholdB)
    (hstdA :
      ∀ q : ℝ, (L_AA q).standardize thresholdA =
        priorPrecision * (thresholdA - mean) / sqrtPrecA +
          sqrtPrecA * (thresholdA - q))
    (hstdB :
      ∀ q : ℝ, (L_BA q).standardize thresholdB =
        priorPrecision * (thresholdB - mean) / sqrtPrecB +
          sqrtPrecB * (thresholdB - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hprecision_gap : sqrtPrecB < sqrtPrecA)
    (hweight_nonneg : 0 ≤ weight) (hweight_lt_one : weight < 1)
    (hinterval_lt_tailB : intervalMeanB < tailMeanBHigh)
    (htailB_lt_A :
      tailMeanBHigh < S.academicMerit groupA Paa)
    (hmeritB_decomp :
      S.academicMerit groupB Paa =
        weight * intervalMeanB + (1 - weight) * tailMeanBHigh)
    (hthresholdA : thresholdBase < thresholdA)
    (hthresholdB : thresholdB < thresholdBase)
    (hmeritABase :
      S.academicMerit groupA Pbase =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_A_merit thresholdBase)
    (hmeritAAA :
      S.academicMerit groupA Paa =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_A_merit thresholdA)
    (hmeritBBase :
      S.academicMerit groupB Pbase =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_B_merit thresholdBase)
    (hmeritBAA :
      S.academicMerit groupB Paa =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_B_merit thresholdB) :
    (∀ q : ℝ,
        S.individualFairnessGap Paa q <
          S.individualFairnessGap Pbase q) ∧
      (∀ q : ℝ,
        0 < S.individualFairnessGap Paa q ↔
          ((priorPrecision + sqrtPrecA ^ 2) / sqrtPrecA * thresholdA -
                (priorPrecision + sqrtPrecB ^ 2) / sqrtPrecB *
                  thresholdB) /
              (sqrtPrecA - sqrtPrecB) +
            mean * priorPrecision / (sqrtPrecA * sqrtPrecB) <
            q) ∧
      S.academicMerit groupB Paa < S.academicMerit groupA Paa ∧
      S.academicMerit groupA Pbase < S.academicMerit groupA Paa ∧
      S.academicMerit groupB Paa < S.academicMerit groupB Pbase := by
  refine ⟨?_, ?_, ?_, ?_⟩
  · exact
      paper_proposition8_individual_fairness_gap_improves_of_admission_probabilities
        hgapBase hgapAA hA_prob hB_prob
  · intro q
    exact
      paper_proposition8_individual_fairness_gap_pos_iff_skill_above_cutoff
        api (hgap_eq q) (hstdA q) (hstdB q) hsqrtB_pos hsqrtA_pos
        hprecision_gap
  · exact
      paper_proposition8_groupB_academic_merit_lt_groupA_of_tail_decomposition
        hweight_nonneg hweight_lt_one hinterval_lt_tailB htailB_lt_A
        hmeritB_decomp
  · exact
      paper_proposition8_academic_merit_changes_standardGaussian_of_threshold_order
        hthresholdA hthresholdB hmeritABase hmeritAAA hmeritBBase
        hmeritBAA

/--
Proposition 9 notation: the affirmative-action access-barrier threshold
obtained by solving the displayed hazard equation for `γ_g`.

Here `groupCapacity = τ_g C`, `populationShare = π_g`, `scaleSub` and
`scaleFull` are the posterior-score scales under `P_sub` and `P_full`, and
the formula keeps the population-share factor from the capacity equation
`π_g γ_g (1-F_g(w_g^*)) = τ_g C`.
-/
def paperProposition9HatGamma
    (groupCapacity populationShare scaleSub scaleFull : ℝ) : ℝ :=
  let zSub := standardGaussianQuantile (1 - groupCapacity / populationShare)
  let zFull :=
    standardGaussianHazardInv
      ((scaleSub / scaleFull) * standardGaussianHazard zSub)
  groupCapacity /
    (populationShare * (1 - standardGaussianCDF zFull))

/--
Proposition 9 notation in the paper's displayed precision coordinates:
`\hat γ_g` with
`sqrt(sum_sub/(sigma^{-2}+sum_sub)) /
 sqrt(sum_full/(sigma^{-2}+sum_full))`.
-/
def paperProposition9HatGammaSource
    (groupCapacity populationShare priorPrecision
      subPrecisionSum fullPrecisionSum : ℝ) : ℝ :=
  paperProposition9HatGamma groupCapacity populationShare
    (Real.sqrt (subPrecisionSum / (priorPrecision + subPrecisionSum)))
    (Real.sqrt (fullPrecisionSum / (priorPrecision + fullPrecisionSum)))

/--
Proposition 9 inverse-CDF algebra: the standardized full-policy cutoff lies
below a scalar `z` exactly when the access level `γ_g` is below the solved
threshold from the capacity equation.
-/
theorem paper_proposition9_quantile_le_iff_gamma_le_threshold
    {groupCapacity populationShare gamma z : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hcapacity_pos : 0 < groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hgamma_pos : 0 < gamma)
    (htail_pos : 0 < 1 - standardGaussianCDF z)
    (harg :
      1 - groupCapacity / (populationShare * gamma) ∈
        Set.Ioo (0 : ℝ) 1) :
    standardGaussianQuantile
        (1 - groupCapacity / (populationShare * gamma)) ≤ z ↔
      gamma ≤
        groupCapacity /
          (populationShare * (1 - standardGaussianCDF z)) := by
  let p := 1 - groupCapacity / (populationShare * gamma)
  have hquantile_cdf :
      standardGaussianCDF (standardGaussianQuantile p) = p :=
    standardGaussianCDF_standardGaussianQuantile harg
  have hquantile_le :
      standardGaussianQuantile p ≤ z ↔ p ≤ standardGaussianCDF z := by
    constructor
    · intro hle
      have hcdf :
          standardGaussianCDF (standardGaussianQuantile p) ≤
            standardGaussianCDF z :=
        standardGaussianCDF_mono hle
      simpa [hquantile_cdf] using hcdf
    · intro hp
      have hcdf :
          standardGaussianCDF (standardGaussianQuantile p) ≤
            standardGaussianCDF z := by
        simpa [hquantile_cdf] using hp
      exact standardGaussianCDF_strictMono.le_iff_le.mp hcdf
  have hpop_gamma_pos : 0 < populationShare * gamma :=
    mul_pos hpopulation_pos hgamma_pos
  have hden_pos :
      0 < populationShare * (1 - standardGaussianCDF z) :=
    mul_pos hpopulation_pos htail_pos
  rw [hquantile_le]
  constructor
  · intro hp
    have htail_le :
        1 - standardGaussianCDF z ≤
          groupCapacity / (populationShare * gamma) := by
      dsimp [p] at hp
      linarith
    have hmul :
        (1 - standardGaussianCDF z) * (populationShare * gamma) ≤
          groupCapacity := by
      rw [le_div_iff₀ hpop_gamma_pos] at htail_le
      exact htail_le
    rw [le_div_iff₀ hden_pos]
    nlinarith
  · intro hgamma
    have hmul :
        populationShare * (1 - standardGaussianCDF z) * gamma ≤
          groupCapacity := by
      rw [le_div_iff₀ hden_pos] at hgamma
      nlinarith
    have htail_le :
        1 - standardGaussianCDF z ≤
          groupCapacity / (populationShare * gamma) := by
      rw [le_div_iff₀ hpop_gamma_pos]
      nlinarith
    dsimp [p]
    linarith

/--
Proposition 9 hazard-inverse threshold calculation: the displayed comparison
of standard-Gaussian hazard rates is equivalent to `γ_g ≤ \hat γ_g`.
-/
theorem paper_proposition9_hazard_condition_iff_gamma_le_hatGamma
    {groupCapacity populationShare scaleSub scaleFull gamma : ℝ}
    (hcapacity_pos : 0 < groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hgamma_pos : 0 < gamma)
    (hscaleSub_pos : 0 < scaleSub)
    (hscaleFull_pos : 0 < scaleFull)
    (hargFull :
      1 - groupCapacity / (populationShare * gamma) ∈
        Set.Ioo (0 : ℝ) 1)
    (hargSub :
      1 - groupCapacity / populationShare ∈ Set.Ioo (0 : ℝ) 1) :
    standardGaussianHazard
        (standardGaussianQuantile
          (1 - groupCapacity / (populationShare * gamma))) ≤
        (scaleSub / scaleFull) *
          standardGaussianHazard
            (standardGaussianQuantile
              (1 - groupCapacity / populationShare)) ↔
      gamma ≤
        paperProposition9HatGamma
          groupCapacity populationShare scaleSub scaleFull := by
  let zSub := standardGaussianQuantile (1 - groupCapacity / populationShare)
  let y := (scaleSub / scaleFull) * standardGaussianHazard zSub
  have hy_pos : 0 < y := by
    dsimp [y]
    exact mul_pos (div_pos hscaleSub_pos hscaleFull_pos)
      (standardGaussianHazard_pos zSub)
  have hhaz_iff :
      standardGaussianHazard
          (standardGaussianQuantile
            (1 - groupCapacity / (populationShare * gamma))) ≤ y ↔
        standardGaussianQuantile
            (1 - groupCapacity / (populationShare * gamma)) ≤
          standardGaussianHazardInv y :=
    standardGaussianHazard_le_iff_le_inv hy_pos
  rw [hhaz_iff]
  have htail_pos :
      0 < 1 - standardGaussianCDF (standardGaussianHazardInv y) :=
    standardGaussianHazardInverseCertificate.toGaussianHazardCertificate.tail_pos
      (standardGaussianHazardInv y)
  have hgamma_iff :=
    paper_proposition9_quantile_le_iff_gamma_le_threshold
      (groupCapacity := groupCapacity)
      (populationShare := populationShare)
      (gamma := gamma)
      (z := standardGaussianHazardInv y)
      (le_of_lt hcapacity_pos) hcapacity_pos hpopulation_pos hgamma_pos
      htail_pos hargFull
  dsimp [paperProposition9HatGamma, zSub, y] at hgamma_iff ⊢
  exact hgamma_iff

/--
Proposition 9 paper-facing wrapper: once the Gaussian upper-tail merit
comparison has been reduced to the displayed hazard inequality, dropping the
test under affirmative action improves group `g`'s admitted academic merit
exactly when `γ_g ≤ \hat γ_g`.
-/
theorem paper_proposition9_dropping_tests_affirmative_action_iff_gamma_le_hatGamma
    {academicMeritImproves : Prop}
    {groupCapacity populationShare scaleSub scaleFull gamma : ℝ}
    (hcapacity_pos : 0 < groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hgamma_pos : 0 < gamma)
    (hscaleSub_pos : 0 < scaleSub)
    (hscaleFull_pos : 0 < scaleFull)
    (hargFull :
      1 - groupCapacity / (populationShare * gamma) ∈
        Set.Ioo (0 : ℝ) 1)
    (hargSub :
      1 - groupCapacity / populationShare ∈ Set.Ioo (0 : ℝ) 1)
    (hhazard :
      academicMeritImproves ↔
        standardGaussianHazard
            (standardGaussianQuantile
              (1 - groupCapacity / (populationShare * gamma))) ≤
          (scaleSub / scaleFull) *
            standardGaussianHazard
              (standardGaussianQuantile
                (1 - groupCapacity / populationShare))) :
    academicMeritImproves ↔
      gamma ≤
        paperProposition9HatGamma
          groupCapacity populationShare scaleSub scaleFull := by
  rw [hhazard]
  exact paper_proposition9_hazard_condition_iff_gamma_le_hatGamma
    hcapacity_pos hpopulation_pos hgamma_pos hscaleSub_pos hscaleFull_pos
    hargFull hargSub

/--
Proposition 9 source-precision wrapper.

This is the same `γ_g ≤ \hat γ_g` characterization as the preceding theorem,
but with `scaleSub` and `scaleFull` replaced by the paper's displayed
posterior-score scale terms
`sqrt(sum_sub/(sigma^{-2}+sum_sub))` and
`sqrt(sum_full/(sigma^{-2}+sum_full))`.
-/
theorem paper_proposition9_dropping_tests_affirmative_action_iff_gamma_le_hatGammaSource
    {academicMeritImproves : Prop}
    {groupCapacity populationShare priorPrecision
      subPrecisionSum fullPrecisionSum gamma : ℝ}
    (hcapacity_pos : 0 < groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hgamma_pos : 0 < gamma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsubPrecision_pos : 0 < subPrecisionSum)
    (hfullPrecision_pos : 0 < fullPrecisionSum)
    (hargFull :
      1 - groupCapacity / (populationShare * gamma) ∈
        Set.Ioo (0 : ℝ) 1)
    (hargSub :
      1 - groupCapacity / populationShare ∈ Set.Ioo (0 : ℝ) 1)
    (hhazard :
      academicMeritImproves ↔
        standardGaussianHazard
            (standardGaussianQuantile
              (1 - groupCapacity / (populationShare * gamma))) ≤
          (Real.sqrt
              (subPrecisionSum / (priorPrecision + subPrecisionSum)) /
            Real.sqrt
              (fullPrecisionSum / (priorPrecision + fullPrecisionSum))) *
            standardGaussianHazard
              (standardGaussianQuantile
                (1 - groupCapacity / populationShare))) :
    academicMeritImproves ↔
      gamma ≤
        paperProposition9HatGammaSource groupCapacity populationShare
          priorPrecision subPrecisionSum fullPrecisionSum := by
  have hscaleSub_pos :
      0 <
        Real.sqrt
          (subPrecisionSum / (priorPrecision + subPrecisionSum)) := by
    have hden : 0 < priorPrecision + subPrecisionSum := by
      linarith
    exact Real.sqrt_pos.mpr (div_pos hsubPrecision_pos hden)
  have hscaleFull_pos :
      0 <
        Real.sqrt
          (fullPrecisionSum / (priorPrecision + fullPrecisionSum)) := by
    have hden : 0 < priorPrecision + fullPrecisionSum := by
      linarith
    exact Real.sqrt_pos.mpr (div_pos hfullPrecision_pos hden)
  simpa [paperProposition9HatGammaSource] using
    (paper_proposition9_dropping_tests_affirmative_action_iff_gamma_le_hatGamma
      (academicMeritImproves := academicMeritImproves)
      (groupCapacity := groupCapacity)
      (populationShare := populationShare)
      (scaleSub :=
        Real.sqrt
          (subPrecisionSum / (priorPrecision + subPrecisionSum)))
      (scaleFull :=
        Real.sqrt
          (fullPrecisionSum / (priorPrecision + fullPrecisionSum)))
      (gamma := gamma) hcapacity_pos hpopulation_pos hgamma_pos
      hscaleSub_pos hscaleFull_pos hargFull hargSub hhazard)

/--
Proposition 9 monotonicity support: increasing the solved inverse-hazard
cutoff weakly increases the `\hat γ_g` threshold because it lowers the
standard-normal upper tail in the denominator.
-/
theorem paper_proposition9_hatGamma_mono_of_inverse_cutoff_le
    {groupCapacity populationShare zOld zNew : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hz : zOld ≤ zNew) :
    groupCapacity /
        (populationShare * (1 - standardGaussianCDF zOld)) ≤
      groupCapacity /
        (populationShare * (1 - standardGaussianCDF zNew)) := by
  have hcdf : standardGaussianCDF zOld ≤ standardGaussianCDF zNew :=
    standardGaussianCDF_mono hz
  have htail :
      1 - standardGaussianCDF zNew ≤ 1 - standardGaussianCDF zOld := by
    linarith
  have hden :
      populationShare * (1 - standardGaussianCDF zNew) ≤
        populationShare * (1 - standardGaussianCDF zOld) :=
    mul_le_mul_of_nonneg_left htail hpopulation_pos.le
  have hden_new_pos :
      0 < populationShare * (1 - standardGaussianCDF zNew) :=
    mul_pos hpopulation_pos
      (GaussianHazardCertificate.tail_pos
        standardGaussianHazardInverseCertificate.toGaussianHazardCertificate zNew)
  exact div_le_div_of_nonneg_left hcapacity_nonneg hden_new_pos hden

/--
Proposition 9 monotonicity in test variance: holding the test-free scale fixed,
if the test-using posterior-score scale weakly decreases, then the solved
barrier threshold `\hat γ_g` weakly increases.
-/
theorem paper_proposition9_hatGamma_mono_of_scaleFull_decreases
    {groupCapacity populationShare scaleSub scaleFullOld scaleFullNew : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hscaleSub_pos : 0 < scaleSub)
    (hscaleFullNew_pos : 0 < scaleFullNew)
    (hscaleFullNew_le_old : scaleFullNew ≤ scaleFullOld) :
    paperProposition9HatGamma
        groupCapacity populationShare scaleSub scaleFullOld ≤
      paperProposition9HatGamma
        groupCapacity populationShare scaleSub scaleFullNew := by
  let zSub := standardGaussianQuantile (1 - groupCapacity / populationShare)
  let yOld := (scaleSub / scaleFullOld) * standardGaussianHazard zSub
  let yNew := (scaleSub / scaleFullNew) * standardGaussianHazard zSub
  have hscaleFullOld_pos : 0 < scaleFullOld :=
    lt_of_lt_of_le hscaleFullNew_pos hscaleFullNew_le_old
  have hratio :
      scaleSub / scaleFullOld ≤ scaleSub / scaleFullNew :=
    div_le_div_of_nonneg_left (le_of_lt hscaleSub_pos)
      hscaleFullNew_pos hscaleFullNew_le_old
  have hy_le : yOld ≤ yNew := by
    dsimp [yOld, yNew]
    exact mul_le_mul_of_nonneg_right hratio
      (le_of_lt (standardGaussianHazard_pos zSub))
  have hyOld_pos : 0 < yOld := by
    dsimp [yOld]
    exact mul_pos (div_pos hscaleSub_pos hscaleFullOld_pos)
      (standardGaussianHazard_pos zSub)
  have hyNew_pos : 0 < yNew := by
    dsimp [yNew]
    exact mul_pos (div_pos hscaleSub_pos hscaleFullNew_pos)
      (standardGaussianHazard_pos zSub)
  have hhazOld :
      standardGaussianHazard (standardGaussianHazardInv yOld) ≤ yOld :=
    (standardGaussianHazard_le_iff_le_inv hyOld_pos).mpr le_rfl
  have hhazNew :
      standardGaussianHazard (standardGaussianHazardInv yOld) ≤ yNew :=
    le_trans hhazOld hy_le
  have hz :
      standardGaussianHazardInv yOld ≤ standardGaussianHazardInv yNew :=
    (standardGaussianHazard_le_iff_le_inv hyNew_pos).mp hhazNew
  have hmono :=
    paper_proposition9_hatGamma_mono_of_inverse_cutoff_le
      (groupCapacity := groupCapacity)
      (populationShare := populationShare)
      (zOld := standardGaussianHazardInv yOld)
      (zNew := standardGaussianHazardInv yNew)
      hcapacity_nonneg hpopulation_pos hz
  dsimp [paperProposition9HatGamma, zSub, yOld, yNew] at hmono ⊢
  exact hmono

/--
Proposition 9 source-scale monotonicity: lowering the test precision lowers the
full-policy posterior-score scale
`\sigma sqrt(sum_full / (sigma^{-2}+sum_full))`.

This is the algebraic step used by the source proof line
"as `sigma_{gK}` increases,
`sqrt(sum_full/(sigma^{-2}+sum_full))` decreases", written in precision
coordinates where increasing test variance means decreasing test precision.
-/
theorem paper_proposition9_full_scale_mono_of_test_precision_le
    {priorSigma priorPrecision subPrecisionSum
      testPrecisionOld testPrecisionNew : ℝ}
    (hpriorSigma_pos : 0 < priorSigma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hfullNew_pos : 0 < subPrecisionSum + testPrecisionNew)
    (htestPrecisionNew_le_old : testPrecisionNew ≤ testPrecisionOld) :
    priorSigma *
        Real.sqrt
          ((subPrecisionSum + testPrecisionNew) /
            (priorPrecision + (subPrecisionSum + testPrecisionNew))) ≤
      priorSigma *
        Real.sqrt
          ((subPrecisionSum + testPrecisionOld) /
            (priorPrecision + (subPrecisionSum + testPrecisionOld))) := by
  have hfullNew_nonneg : 0 ≤ subPrecisionSum + testPrecisionNew :=
    le_of_lt hfullNew_pos
  have hfull_le :
      subPrecisionSum + testPrecisionNew ≤
        subPrecisionSum + testPrecisionOld := by
    linarith
  have hsqrt :
      Real.sqrt
          ((subPrecisionSum + testPrecisionNew) /
            (priorPrecision + (subPrecisionSum + testPrecisionNew))) ≤
        Real.sqrt
          ((subPrecisionSum + testPrecisionOld) /
            (priorPrecision + (subPrecisionSum + testPrecisionOld))) :=
    EconCSLib.sqrt_self_div_add_const_le_of_le
      hpriorPrecision_pos hfullNew_nonneg hfull_le
  exact mul_le_mul_of_nonneg_left hsqrt hpriorSigma_pos.le

/--
Proposition 9 final monotonicity, in source precision coordinates: holding all
other parameters fixed, if the test precision falls, then the solved
affirmative-action access threshold `\hat γ_g` weakly increases.
-/
theorem paper_proposition9_hatGamma_mono_of_test_precision_decreases
    {groupCapacity populationShare scaleSub priorSigma priorPrecision
      subPrecisionSum testPrecisionOld testPrecisionNew : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hscaleSub_pos : 0 < scaleSub)
    (hpriorSigma_pos : 0 < priorSigma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hfullNew_pos : 0 < subPrecisionSum + testPrecisionNew)
    (htestPrecisionNew_le_old : testPrecisionNew ≤ testPrecisionOld) :
    paperProposition9HatGamma groupCapacity populationShare scaleSub
        (priorSigma *
          Real.sqrt
            ((subPrecisionSum + testPrecisionOld) /
              (priorPrecision + (subPrecisionSum + testPrecisionOld)))) ≤
      paperProposition9HatGamma groupCapacity populationShare scaleSub
        (priorSigma *
          Real.sqrt
            ((subPrecisionSum + testPrecisionNew) /
              (priorPrecision + (subPrecisionSum + testPrecisionNew)))) := by
  have hscaleFullNew_pos :
      0 <
        priorSigma *
          Real.sqrt
            ((subPrecisionSum + testPrecisionNew) /
              (priorPrecision + (subPrecisionSum + testPrecisionNew))) := by
    have hdenNew :
        0 < priorPrecision + (subPrecisionSum + testPrecisionNew) := by
      linarith
    have hratioNew_pos :
        0 <
          (subPrecisionSum + testPrecisionNew) /
            (priorPrecision + (subPrecisionSum + testPrecisionNew)) :=
      div_pos hfullNew_pos hdenNew
    exact mul_pos hpriorSigma_pos (Real.sqrt_pos.mpr hratioNew_pos)
  have hscaleFullNew_le_old :
      priorSigma *
          Real.sqrt
            ((subPrecisionSum + testPrecisionNew) /
              (priorPrecision + (subPrecisionSum + testPrecisionNew))) ≤
        priorSigma *
          Real.sqrt
            ((subPrecisionSum + testPrecisionOld) /
              (priorPrecision + (subPrecisionSum + testPrecisionOld))) :=
    paper_proposition9_full_scale_mono_of_test_precision_le
      hpriorSigma_pos hpriorPrecision_pos hfullNew_pos
      htestPrecisionNew_le_old
  exact
    paper_proposition9_hatGamma_mono_of_scaleFull_decreases
      hcapacity_nonneg hpopulation_pos hscaleSub_pos hscaleFullNew_pos
      hscaleFullNew_le_old

/--
Proposition 9 final monotonicity in the paper's variance language: holding all
other parameters fixed, increasing the test variance `sigma_{gK}^2` weakly
increases the access threshold `\hat γ_g`.
-/
theorem paper_proposition9_hatGamma_mono_of_test_variance_increases
    {groupCapacity populationShare scaleSub priorSigma priorPrecision
      subPrecisionSum testVarianceOld testVarianceNew : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hscaleSub_pos : 0 < scaleSub)
    (hpriorSigma_pos : 0 < priorSigma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsubPrecision_nonneg : 0 ≤ subPrecisionSum)
    (hvarianceOld_pos : 0 < testVarianceOld)
    (hvarianceOld_le_new : testVarianceOld ≤ testVarianceNew) :
    paperProposition9HatGamma groupCapacity populationShare scaleSub
        (priorSigma *
          Real.sqrt
            ((subPrecisionSum + 1 / testVarianceOld) /
              (priorPrecision + (subPrecisionSum + 1 / testVarianceOld)))) ≤
      paperProposition9HatGamma groupCapacity populationShare scaleSub
        (priorSigma *
          Real.sqrt
            ((subPrecisionSum + 1 / testVarianceNew) /
              (priorPrecision + (subPrecisionSum + 1 / testVarianceNew)))) := by
  have hvarianceNew_pos : 0 < testVarianceNew :=
    lt_of_lt_of_le hvarianceOld_pos hvarianceOld_le_new
  have htestPrecisionNew_le_old :
      1 / testVarianceNew ≤ 1 / testVarianceOld :=
    one_div_le_one_div_of_le hvarianceOld_pos hvarianceOld_le_new
  have hfullNew_pos : 0 < subPrecisionSum + 1 / testVarianceNew := by
    have hprecisionNew_pos : 0 < 1 / testVarianceNew :=
      one_div_pos.mpr hvarianceNew_pos
    linarith
  exact
    paper_proposition9_hatGamma_mono_of_test_precision_decreases
      hcapacity_nonneg hpopulation_pos hscaleSub_pos hpriorSigma_pos
      hpriorPrecision_pos hfullNew_pos htestPrecisionNew_le_old

/--
Proposition 9 final monotonicity in the paper's displayed precision formula:
if the test precision falls while the non-test precision is fixed, then the
source threshold `\hat γ_g` weakly increases.
-/
theorem paper_proposition9_hatGammaSource_mono_of_test_precision_decreases
    {groupCapacity populationShare priorPrecision
      subPrecisionSum testPrecisionOld testPrecisionNew : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsubPrecision_pos : 0 < subPrecisionSum)
    (htestPrecisionNew_nonneg : 0 ≤ testPrecisionNew)
    (htestPrecisionNew_le_old : testPrecisionNew ≤ testPrecisionOld) :
    paperProposition9HatGammaSource groupCapacity populationShare
        priorPrecision subPrecisionSum
        (subPrecisionSum + testPrecisionOld) ≤
      paperProposition9HatGammaSource groupCapacity populationShare
        priorPrecision subPrecisionSum
        (subPrecisionSum + testPrecisionNew) := by
  have hscaleSub_pos :
      0 <
        Real.sqrt
          (subPrecisionSum / (priorPrecision + subPrecisionSum)) := by
    have hdenSub : 0 < priorPrecision + subPrecisionSum := by
      linarith
    exact Real.sqrt_pos.mpr (div_pos hsubPrecision_pos hdenSub)
  have hfullNew_pos : 0 < subPrecisionSum + testPrecisionNew := by
    linarith
  simpa [paperProposition9HatGammaSource] using
    (paper_proposition9_hatGamma_mono_of_test_precision_decreases
      (groupCapacity := groupCapacity)
      (populationShare := populationShare)
      (scaleSub :=
        Real.sqrt
          (subPrecisionSum / (priorPrecision + subPrecisionSum)))
      (priorSigma := 1)
      (priorPrecision := priorPrecision)
      (subPrecisionSum := subPrecisionSum)
      (testPrecisionOld := testPrecisionOld)
      (testPrecisionNew := testPrecisionNew)
      hcapacity_nonneg hpopulation_pos hscaleSub_pos zero_lt_one
      hpriorPrecision_pos hfullNew_pos htestPrecisionNew_le_old)

/--
Proposition 9 final monotonicity in the paper's variance language and displayed
formula: fixing all other parameters, increasing the test variance
`sigma_{gK}^2` weakly increases the source threshold `\hat γ_g`.
-/
theorem paper_proposition9_hatGammaSource_mono_of_test_variance_increases
    {groupCapacity populationShare priorPrecision
      subPrecisionSum testVarianceOld testVarianceNew : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsubPrecision_pos : 0 < subPrecisionSum)
    (hvarianceOld_pos : 0 < testVarianceOld)
    (hvarianceOld_le_new : testVarianceOld ≤ testVarianceNew) :
    paperProposition9HatGammaSource groupCapacity populationShare
        priorPrecision subPrecisionSum
        (subPrecisionSum + 1 / testVarianceOld) ≤
      paperProposition9HatGammaSource groupCapacity populationShare
        priorPrecision subPrecisionSum
        (subPrecisionSum + 1 / testVarianceNew) := by
  have hvarianceNew_pos : 0 < testVarianceNew :=
    lt_of_lt_of_le hvarianceOld_pos hvarianceOld_le_new
  have htestPrecisionNew_nonneg : 0 ≤ 1 / testVarianceNew :=
    le_of_lt (one_div_pos.mpr hvarianceNew_pos)
  have htestPrecisionNew_le_old :
      1 / testVarianceNew ≤ 1 / testVarianceOld :=
    one_div_le_one_div_of_le hvarianceOld_pos hvarianceOld_le_new
  exact
    paper_proposition9_hatGammaSource_mono_of_test_precision_decreases
      hcapacity_nonneg hpopulation_pos hpriorPrecision_pos hsubPrecision_pos
      htestPrecisionNew_nonneg htestPrecisionNew_le_old

/--
Section 5 equilibrium data, abstracted from the paper's strategic
test-taking/application and school-policy games.
-/
structure GLM20StrategicEquilibriumData (Student Action SchoolPolicy : Type*) where
  studentActionFeasible : Student → Action → Prop
  chosenStudentAction : Student → Action
  studentPayoff : Student → Action → ℝ
  schoolPolicyFeasible : SchoolPolicy → Prop
  chosenSchoolPolicy : SchoolPolicy
  schoolObjective : SchoolPolicy → ℝ
  assignmentConsistent : Prop

/--
Strategic equilibrium predicate: student actions are feasible best responses,
the school policy is a feasible maximizer of academic merit, and assignment is
consistent with the induced threshold decisions.
-/
def glm20StrategicEquilibrium {Student Action SchoolPolicy : Type*}
    (E : GLM20StrategicEquilibriumData Student Action SchoolPolicy) : Prop :=
  (∀ s, E.studentActionFeasible s (E.chosenStudentAction s)) ∧
    (∀ s a, E.studentActionFeasible s a →
      E.studentPayoff s a ≤ E.studentPayoff s (E.chosenStudentAction s)) ∧
      E.schoolPolicyFeasible E.chosenSchoolPolicy ∧
        (∀ P, E.schoolPolicyFeasible P →
          E.schoolObjective P ≤ E.schoolObjective E.chosenSchoolPolicy) ∧
            E.assignmentConsistent

/--
Section 5 strategic equilibrium with student best-response obligations required
only almost everywhere under a realized student information law.

The school-policy and assignment-consistency clauses remain pointwise because
they are not indexed by the continuous student type.  This mirrors the LG21
`SourceEquilibriumAE` pattern and is useful when cutoff-tie behavior occurs on
null sets.
-/
def glm20StrategicEquilibriumAE
    {Student Action SchoolPolicy : Type*} [MeasurableSpace Student]
    (μ : Measure Student)
    (E : GLM20StrategicEquilibriumData Student Action SchoolPolicy) : Prop :=
  (∀ᵐ s ∂μ, E.studentActionFeasible s (E.chosenStudentAction s)) ∧
    (∀ᵐ s ∂μ, ∀ a, E.studentActionFeasible s a →
      E.studentPayoff s a ≤ E.studentPayoff s (E.chosenStudentAction s)) ∧
      E.schoolPolicyFeasible E.chosenSchoolPolicy ∧
        (∀ P, E.schoolPolicyFeasible P →
          E.schoolObjective P ≤ E.schoolObjective E.chosenSchoolPolicy) ∧
            E.assignmentConsistent

theorem glm20StrategicEquilibriumAE_student_feasible_ae
    {Student Action SchoolPolicy : Type*} [MeasurableSpace Student]
    {μ : Measure Student}
    {E : GLM20StrategicEquilibriumData Student Action SchoolPolicy}
    (hEq : glm20StrategicEquilibriumAE μ E) :
    ∀ᵐ s ∂μ, E.studentActionFeasible s (E.chosenStudentAction s) := hEq.1

theorem glm20StrategicEquilibriumAE_student_best_response_ae
    {Student Action SchoolPolicy : Type*} [MeasurableSpace Student]
    {μ : Measure Student}
    {E : GLM20StrategicEquilibriumData Student Action SchoolPolicy}
    (hEq : glm20StrategicEquilibriumAE μ E) :
    ∀ᵐ s ∂μ, ∀ a, E.studentActionFeasible s a →
      E.studentPayoff s a ≤ E.studentPayoff s (E.chosenStudentAction s) := hEq.2.1

theorem glm20StrategicEquilibriumAE_school_policy_feasible
    {Student Action SchoolPolicy : Type*} [MeasurableSpace Student]
    {μ : Measure Student}
    {E : GLM20StrategicEquilibriumData Student Action SchoolPolicy}
    (hEq : glm20StrategicEquilibriumAE μ E) :
    E.schoolPolicyFeasible E.chosenSchoolPolicy := hEq.2.2.1

theorem glm20StrategicEquilibriumAE_school_policy_best_response
    {Student Action SchoolPolicy : Type*} [MeasurableSpace Student]
    {μ : Measure Student}
    {E : GLM20StrategicEquilibriumData Student Action SchoolPolicy}
    (hEq : glm20StrategicEquilibriumAE μ E) :
    ∀ P, E.schoolPolicyFeasible P →
      E.schoolObjective P ≤ E.schoolObjective E.chosenSchoolPolicy := hEq.2.2.2.1

theorem glm20StrategicEquilibriumAE_assignmentConsistent
    {Student Action SchoolPolicy : Type*} [MeasurableSpace Student]
    {μ : Measure Student}
    {E : GLM20StrategicEquilibriumData Student Action SchoolPolicy}
    (hEq : glm20StrategicEquilibriumAE μ E) :
    E.assignmentConsistent := hEq.2.2.2.2

theorem glm20StrategicEquilibriumAE_of_strategicEquilibrium
    {Student Action SchoolPolicy : Type*} [MeasurableSpace Student]
    {μ : Measure Student}
    {E : GLM20StrategicEquilibriumData Student Action SchoolPolicy}
    (hEq : glm20StrategicEquilibrium E) :
    glm20StrategicEquilibriumAE μ E := by
  refine ⟨?_, ?_, ?_, ?_, ?_⟩
  · exact Filter.Eventually.of_forall fun s => hEq.1 s
  · exact Filter.Eventually.of_forall fun s a hfeasible =>
      hEq.2.1 s a hfeasible
  · exact hEq.2.2.1
  · exact hEq.2.2.2.1
  · exact hEq.2.2.2.2

/--
Source-facing two-school strategic surface.  The source instantiates
`massTestTaking` as `M_g(P)` and `admittedAcademicMerit` as `L_i^g(P)`.
-/
structure GLM20StrategicPolicySurface (Group Policy School Equilibrium : Type*) where
  massTestTaking : Group → Policy → ℝ
  admittedAcademicMerit : School → Group → Policy → ℝ
  diversity : School → Policy → ℝ
  policyPairIsEquilibrium : Policy → Policy → Prop
  equilibriumPredicate : Equilibrium → Prop

/--
Section 5 two-school policy states.

The paper compares the two single-school policies `P_sub` and `P_full`, but
observables such as `M_g(P)` and `L_i^g(P)` are evaluated on the induced
two-school policy pair.  This datatype separates the two single-school actions
from the four induced pair states, so the source wrappers can instantiate
`policyPair` by computation instead of passing opaque policy objects.
-/
inductive GLM20StrategicPolicyState where
  | singleSub
  | singleFull
  | subSub
  | subFull
  | fullSub
  | fullFull
  deriving DecidableEq, Repr

/--
The induced two-school policy-pair state for the source policies
`P_sub` and `P_full`.

Only the four combinations of `singleSub` and `singleFull` are used by the
paper-facing wrappers.  Other inputs are routed to their first argument so the
function remains total without adding impossible-state assumptions.
-/
def glm20StrategicPolicyStatePair :
    GLM20StrategicPolicyState → GLM20StrategicPolicyState →
      GLM20StrategicPolicyState
  | .singleSub, .singleSub => .subSub
  | .singleSub, .singleFull => .subFull
  | .singleFull, .singleSub => .fullSub
  | .singleFull, .singleFull => .fullFull
  | P, _ => P

@[simp] theorem glm20StrategicPolicyStatePair_sub_sub :
    glm20StrategicPolicyStatePair
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleSub =
      GLM20StrategicPolicyState.subSub := rfl

@[simp] theorem glm20StrategicPolicyStatePair_sub_full :
    glm20StrategicPolicyStatePair
        GLM20StrategicPolicyState.singleSub
        GLM20StrategicPolicyState.singleFull =
      GLM20StrategicPolicyState.subFull := rfl

@[simp] theorem glm20StrategicPolicyStatePair_full_sub :
    glm20StrategicPolicyStatePair
        GLM20StrategicPolicyState.singleFull
        GLM20StrategicPolicyState.singleSub =
      GLM20StrategicPolicyState.fullSub := rfl

@[simp] theorem glm20StrategicPolicyStatePair_full_full :
    glm20StrategicPolicyStatePair
        GLM20StrategicPolicyState.singleFull
        GLM20StrategicPolicyState.singleFull =
      GLM20StrategicPolicyState.fullFull := rfl

/--
Mass table for the four source two-school policy states.

The two single-school constructors are assigned their natural benchmark pair
states only to keep the observable total; the paper-facing theorems use the
