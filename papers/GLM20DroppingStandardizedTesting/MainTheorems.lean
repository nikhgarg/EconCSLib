/--
Proposition 5 threshold support for the cost-comparison argument.

Source proof line: in the one-expanding-group case, the test-based admitted
merit term is continuous and strictly decreasing in the group cost; at zero
cost the school prefers the test-based pool, while at the high-cost endpoint
dropping the test has higher merit.  Hence there is a positive threshold
`c_hat` such that dropping weakly improves merit exactly for costs at or above
that threshold.

This theorem is normalized to the unit cost interval.  Paper-specific wrappers
can feed it a normalized cost ratio such as `c_g / v_2`.
-/
theorem paper_proposition5_cost_threshold_of_continuous_strictAntiOn_unit_interval
    {testBasedMerit : ℝ → ℝ} {testFreeMerit : ℝ}
    (hcont : ContinuousOn testBasedMerit (Set.Icc 0 1))
    (hanti : StrictAntiOn testBasedMerit (Set.Icc 0 1))
    (hlowCost : testFreeMerit < testBasedMerit 0)
    (hhighCost : testBasedMerit 1 < testFreeMerit) :
    ∃ costThreshold : ℝ,
      costThreshold ∈ Set.Ioo (0 : ℝ) 1 ∧
        testBasedMerit costThreshold = testFreeMerit ∧
          (∀ c ∈ Set.Icc (0 : ℝ) 1,
            testFreeMerit < testBasedMerit c ↔ c < costThreshold) ∧
            (∀ c ∈ Set.Icc (0 : ℝ) 1,
              testBasedMerit c < testFreeMerit ↔ costThreshold < c) ∧
              (∀ c ∈ Set.Icc (0 : ℝ) 1,
                testBasedMerit c ≤ testFreeMerit ↔ costThreshold ≤ c) := by
  rcases
    exists_threshold_of_continuous_strictAntiOn_Icc_crossing
      hcont hanti hlowCost hhighCost with
    ⟨costThreshold, hmem, heq, hgt, hlt, _hge, hle⟩
  exact ⟨costThreshold, hmem, heq, hgt, hlt, hle⟩

/--
Proposition 5 threshold support on the paper's actual cost interval.

This is the non-normalized version used for cost domains such as
`0 <= c_g <= v_2`: a continuous strictly decreasing test-based merit term on
`[0,maxCost]`, with opposite endpoint comparisons against the test-free merit,
induces a positive threshold `c_hat` such that dropping weakly improves merit
exactly for costs above that threshold.
-/
theorem paper_proposition5_cost_threshold_of_continuous_strictAntiOn_cost_interval
    {testBasedMerit : ℝ → ℝ} {testFreeMerit maxCost : ℝ}
    (hmaxCost : 0 < maxCost)
    (hcont : ContinuousOn testBasedMerit (Set.Icc 0 maxCost))
    (hanti : StrictAntiOn testBasedMerit (Set.Icc 0 maxCost))
    (hlowCost : testFreeMerit < testBasedMerit 0)
    (hhighCost : testBasedMerit maxCost < testFreeMerit) :
    ∃ costThreshold : ℝ,
      costThreshold ∈ Set.Ioo (0 : ℝ) maxCost ∧
        testBasedMerit costThreshold = testFreeMerit ∧
          (∀ c ∈ Set.Icc (0 : ℝ) maxCost,
            testFreeMerit < testBasedMerit c ↔ c < costThreshold) ∧
            (∀ c ∈ Set.Icc (0 : ℝ) maxCost,
              testBasedMerit c < testFreeMerit ↔ costThreshold < c) ∧
              (∀ c ∈ Set.Icc (0 : ℝ) maxCost,
                testBasedMerit c ≤ testFreeMerit ↔ costThreshold ≤ c) := by
  rcases
    exists_threshold_of_continuous_strictAntiOn_Icc_crossing_interval
      (f := testBasedMerit) (level := testFreeMerit) hmaxCost hcont hanti
      hlowCost hhighCost with
    ⟨costThreshold, hmem, heq, hgt, hlt, _hge, hle⟩
  exact ⟨costThreshold, hmem, heq, hgt, hlt, hle⟩

/--
Two-group exact-one helper for paper statements that say a condition holds
for exactly one group in `{A,B}`.
-/
def glm20ExactlyOneOfTwo {α : Type*} (a b : α) (condition : α → Prop) : Prop := (condition a ∧ ¬ condition b) ∨ (condition b ∧ ¬ condition a)

/-- Congruence for the two-group exact-one helper. -/
theorem glm20ExactlyOneOfTwo_congr
    {α : Type*} {a b : α} {condition condition' : α → Prop}
    (ha : condition a ↔ condition' a)
    (hb : condition b ↔ condition' b) :
    glm20ExactlyOneOfTwo a b condition ↔
      glm20ExactlyOneOfTwo a b condition' := by
  constructor
  · intro hone
    rcases hone with ⟨hA, hnotB⟩ | ⟨hB, hnotA⟩
    · exact Or.inl ⟨ha.mp hA, fun hB' => hnotB (hb.mpr hB')⟩
    · exact Or.inr ⟨hb.mp hB, fun hA' => hnotA (ha.mpr hA')⟩
  · intro hone
    rcases hone with ⟨hA, hnotB⟩ | ⟨hB, hnotA⟩
    · exact Or.inl ⟨ha.mpr hA, fun hB' => hnotB (hb.mp hB')⟩
    · exact Or.inr ⟨hb.mpr hB, fun hA' => hnotA (ha.mp hA')⟩

/--
Two-group case-analysis helper for Proposition 5 style proofs.

If no group satisfies the cutoff case then the deviation is not profitable; if
both groups satisfy it, the case is impossible; and if exactly one group
satisfies it, profitability is equivalent to that group's qualifier, then
profitability is equivalent to exactly one qualified cutoff case.
-/
theorem glm20ExactlyOneOfTwo_qualified_cutoff_iff_of_case_analysis
    {α : Type*} {a b : α} {deviationProfitable : Prop}
    {cutoffCase qualifier : α → Prop}
    (hnone :
      ¬ cutoffCase a → ¬ cutoffCase b → ¬ deviationProfitable)
    (hboth_impossible :
      cutoffCase a → cutoffCase b → False)
    (honlyA :
      cutoffCase a → ¬ cutoffCase b →
        (deviationProfitable ↔ qualifier a))
    (honlyB :
      cutoffCase b → ¬ cutoffCase a →
        (deviationProfitable ↔ qualifier b)) :
    deviationProfitable ↔
      glm20ExactlyOneOfTwo a b (fun g => qualifier g ∧ cutoffCase g) := by
  by_cases hAcut : cutoffCase a
  · by_cases hBcut : cutoffCase b
    · exact False.elim (hboth_impossible hAcut hBcut)
    · have hdev_iff : deviationProfitable ↔ qualifier a :=
        honlyA hAcut hBcut
      constructor
      · intro hdev
        exact Or.inl ⟨⟨hdev_iff.mp hdev, hAcut⟩,
          fun hBqualified => hBcut hBqualified.2⟩
      · intro hexact
        rcases hexact with ⟨hAqualified, _hnotB⟩ | ⟨hBqualified, _hnotA⟩
        · exact hdev_iff.mpr hAqualified.1
        · exact False.elim (hBcut hBqualified.2)
  · by_cases hBcut : cutoffCase b
    · have hdev_iff : deviationProfitable ↔ qualifier b :=
        honlyB hBcut hAcut
      constructor
      · intro hdev
        exact Or.inr ⟨⟨hdev_iff.mp hdev, hBcut⟩,
          fun hAqualified => hAcut hAqualified.2⟩
      · intro hexact
        rcases hexact with ⟨hAqualified, _hnotB⟩ | ⟨hBqualified, _hnotA⟩
        · exact False.elim (hAcut hAqualified.2)
        · exact hdev_iff.mpr hBqualified.1
    · constructor
      · intro hdev
        exact False.elim (hnone hAcut hBcut hdev)
      · intro hexact
        rcases hexact with ⟨hAqualified, _hnotB⟩ | ⟨hBqualified, _hnotA⟩
        · exact False.elim (hAcut hAqualified.2)
        · exact False.elim (hBcut hBqualified.2)

/--
The two-group exact-one helper is equivalent to the paper wording "there
exists a unique group in `{A,B}` satisfying the condition."
-/
theorem glm20ExactlyOneOfTwo_iff_existsUnique_mem_pair
    {α : Type*} {a b : α} (hne : a ≠ b) (condition : α → Prop) :
    glm20ExactlyOneOfTwo a b condition ↔
      ∃ g : α,
        (g = a ∨ g = b) ∧ condition g ∧
          ∀ h : α, (h = a ∨ h = b) → condition h → h = g := by
  constructor
  · intro hone
    rcases hone with ⟨ha, hnb⟩ | ⟨hb, hna⟩
    · refine ⟨a, Or.inl rfl, ha, ?_⟩
      intro h hmem hh
      rcases hmem with rfl | rfl
      · rfl
      · exact False.elim (hnb hh)
    · refine ⟨b, Or.inr rfl, hb, ?_⟩
      intro h hmem hh
      rcases hmem with rfl | rfl
      · exact False.elim (hna hh)
      · rfl
  · rintro ⟨g, hmem, hg, hunique⟩
    rcases hmem with hga | hgb
    · refine Or.inl ⟨?_, ?_⟩
      · simpa [hga] using hg
      intro hb
      have hb_eq_g : b = g := hunique b (Or.inr rfl) hb
      have hb_eq_a : b = a := hb_eq_g.trans hga
      exact hne hb_eq_a.symm
    · refine Or.inr ⟨?_, ?_⟩
      · simpa [hgb] using hg
      intro ha
      have ha_eq_g : a = g := hunique a (Or.inl rfl) ha
      have ha_eq_b : a = b := ha_eq_g.trans hgb
      exact hne ha_eq_b

/--
Theorem 3(i), condition (10), for a candidate expanding group.

Paper statement: `c_g ≥ c_hat_g` and
`M_g(P_full, P_full) < K_g(q^*_{1,sub})`, with `c_hat_g > 0`.
-/
def glm20Theorem3SubFullGroupExpandsByDropping
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy)
    (testCost costThreshold : Group → ℝ)
    (q1Sub : ℝ) (K : Group → ℝ → ℝ) (g : Group) : Prop :=
  testCost g ≥ costThreshold g ∧
    0 < costThreshold g ∧
      S.massTestTaking g (policyPair Pfull Pfull) < K g q1Sub

/--
Theorem 3(i) branch predicate on the source-family policy-state table
surface.  This abbreviates the paper's condition that one group's pool expands
when school `J1` switches from `P_full` to `P_sub`.
-/
abbrev glm20Theorem3SourceFamilyPolicyStateTableSubFullExpands
    {Group School FeatureDrop FeatureKeep : Type*}
    [DecidableEq School]
    [Fintype FeatureDrop] [Nonempty FeatureDrop]
    [Fintype FeatureKeep] [Nonempty FeatureKeep]
    (api : StandardGaussianCDFAPI)
    (subEstimateLaw : Group → GaussianScaleLaw)
    (subSubMass subFullMass : Group → ℝ)
    (subSubMerit subFullMeritFallback fullSubMeritFallback
      fullFullMeritFallback : School → Group → ℝ)
    (diversity : School → GLM20StrategicPolicyState → ℝ)
    (J1 J2 : School) (groupA groupB : Group)
    (populationShare testCost : Group → ℝ)
    (fullFullCutoff fullSubCutoff : Group → ℝ)
    (C : GaussianHazardCertificate)
    (J1DropFamily J2DropFamily :
      Group → GaussianOffsetSignalFamily FeatureDrop)
    (J1KeepFamily J2KeepFamily :
      Group → GaussianOffsetSignalFamily FeatureKeep)
    (J1DropThreshold J1KeepThreshold J2DropThreshold
      J2KeepThreshold : Group → ℝ)
    (q1Sub : ℝ) (costThreshold : Group → ℝ) (g : Group) : Prop :=
  glm20Theorem3SubFullGroupExpandsByDropping
    (glm20Theorem3SourceFamilyPolicyStateTableSurface api subEstimateLaw
      subSubMass subFullMass subSubMerit subFullMeritFallback
      fullSubMeritFallback fullFullMeritFallback diversity J1 J2 groupA
      groupB populationShare fullFullCutoff fullSubCutoff C J1DropFamily
      J2DropFamily J1KeepFamily J2KeepFamily J1DropThreshold
      J1KeepThreshold J2DropThreshold J2KeepThreshold)
    glm20StrategicPolicyStatePair GLM20StrategicPolicyState.singleSub
    GLM20StrategicPolicyState.singleFull testCost costThreshold q1Sub
    (fun g q => glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
    g

/--
Proposition 5(i) / Theorem 3(i), condition (10), rewritten in the cutoff
case-analysis form used in the proof.

Paper proof line: `q^*_{1,sub} < q^g_{full,full}` is equivalent to the
second part of (10), `M_g(P_full,P_full) < K_g(q^*_{1,sub})`.
-/
theorem paper_proposition5_condition10_iff_cost_and_fullFull_cutoff_case
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy)
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {testCost costThreshold : Group → ℝ} {q1Sub : ℝ}
    {fullFullCutoff : Group → ℝ} {g : Group}
    (hmass :
      S.massTestTaking g (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw g)
          (fullFullCutoff g)) :
    glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
        testCost costThreshold q1Sub
        (fun h q => glm20StrategicSubEstimateMassAbove api (subEstimateLaw h) q)
        g ↔
      testCost g ≥ costThreshold g ∧
        0 < costThreshold g ∧ q1Sub < fullFullCutoff g := by
  constructor
  · rintro ⟨hcost, hthreshold_pos, hmass_lt⟩
    exact ⟨hcost, hthreshold_pos,
      (paper_proposition5_mass_below_K_iff_reference_below_cutoff
        api (subEstimateLaw g) hmass).mp hmass_lt⟩
  · rintro ⟨hcost, hthreshold_pos, hcutoff⟩
    exact ⟨hcost, hthreshold_pos,
      (paper_proposition5_mass_below_K_iff_reference_below_cutoff
        api (subEstimateLaw g) hmass).mpr hcutoff⟩

/--
Proposition 5(i) / Theorem 3(i), condition (10), with the paper's raw
test-free precision formula for `K_g` substituted.
-/
theorem paper_proposition5_condition10_iff_cost_and_source_fullFull_cutoff_case
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy)
    (api : StandardGaussianCDFAPI)
    (priorSigma priorPrecision subPrecisionSum mu : Group → ℝ)
    (hpriorSigma_pos : ∀ g, 0 < priorSigma g)
    (hpriorPrecision_pos : ∀ g, 0 < priorPrecision g)
    (hsubPrecisionSum_pos : ∀ g, 0 < subPrecisionSum g)
    {testCost costThreshold : Group → ℝ} {q1Sub : ℝ}
    {fullFullCutoff : Group → ℝ} {g : Group}
    (hmass :
      S.massTestTaking g (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api
          (glm20StrategicSubEstimateLawSource (priorSigma g)
            (priorPrecision g) (subPrecisionSum g) (mu g)
            (hpriorSigma_pos g) (hpriorPrecision_pos g)
            (hsubPrecisionSum_pos g))
          (fullFullCutoff g)) :
    glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
        testCost costThreshold q1Sub
        (fun h q =>
          glm20StrategicSubEstimateMassAbove api
            (glm20StrategicSubEstimateLawSource (priorSigma h)
              (priorPrecision h) (subPrecisionSum h) (mu h)
              (hpriorSigma_pos h) (hpriorPrecision_pos h)
              (hsubPrecisionSum_pos h))
            q)
        g ↔
      testCost g ≥ costThreshold g ∧
        0 < costThreshold g ∧ q1Sub < fullFullCutoff g :=
  paper_proposition5_condition10_iff_cost_and_fullFull_cutoff_case
    S policyPair Psub Pfull api
    (fun h =>
      glm20StrategicSubEstimateLawSource (priorSigma h) (priorPrecision h)
        (subPrecisionSum h) (mu h) (hpriorSigma_pos h)
        (hpriorPrecision_pos h) (hsubPrecisionSum_pos h))
    hmass

/--
Theorem 3(i), conditions (11)--(12), for the non-expanding group when
`(P_sub,P_full)` is tested.

Paper statement:
`M_{g'}(P_sub, P_full) ≥ C_2` and
`π_{g'} L_2^{g'}(P_sub, P_full) >
 π_A L_2^A(P_sub, P_sub) + π_B L_2^B(P_sub, P_sub)`.
-/
def glm20Theorem3SubFullOtherGroupKeepsTest
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J2 : School) (groupA groupB : Group)
    (populationShare : Group → ℝ) (capacity2 : ℝ) (g : Group) : Prop :=
  S.massTestTaking g (policyPair Psub Pfull) ≥ capacity2 ∧
    populationShare g *
        S.admittedAcademicMerit J2 g (policyPair Psub Pfull) >
      populationShare groupA *
          S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
        populationShare groupB *
          S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)

/--
Theorem 3(i)'s conditions for `(P_sub, P_full)`.

Paper statement: `(P_sub, P_full)` is an equilibrium iff, for exactly one
group `g`, condition (10) holds; for the other group `g'`, conditions
(11)--(12) hold.
-/
def glm20Theorem3SubFullCondition
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J2 : School) (groupA groupB : Group)
    (populationShare testCost costThreshold : Group → ℝ)
    (capacity2 q1Sub : ℝ) (K : Group → ℝ → ℝ) : Prop :=
  let groupExpandsByDropping :=
    glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
      testCost costThreshold q1Sub K
  let otherGroupKeepsTest :=
    glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull J2
      groupA groupB populationShare capacity2
  glm20ExactlyOneOfTwo groupA groupB groupExpandsByDropping ∧
    (groupExpandsByDropping groupA → otherGroupKeepsTest groupB) ∧
      (groupExpandsByDropping groupB → otherGroupKeepsTest groupA)

/--
Theorem 3(i), expanded two-group form.

Paper wording: `(P_sub,P_full)` is an equilibrium iff exactly one group
satisfies condition (10), and the other group satisfies conditions (11)--(12).
This theorem unfolds the source condition into the two possible group cases.
-/
theorem glm20Theorem3SubFullCondition_iff_groupA_or_groupB
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost costThreshold : Group → ℝ}
    {capacity2 q1Sub : ℝ} {K : Group → ℝ → ℝ} :
    glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
        groupA groupB populationShare testCost costThreshold capacity2
        q1Sub K ↔
      (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupA ∧
        ¬ glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub
          Pfull testCost costThreshold q1Sub K groupB ∧
        glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull
          J2 groupA groupB populationShare capacity2 groupB) ∨
      (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupB ∧
        ¬ glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub
          Pfull testCost costThreshold q1Sub K groupA ∧
        glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull
          J2 groupA groupB populationShare capacity2 groupA) := by
  let expands :=
    glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
      testCost costThreshold q1Sub K
  let otherKeeps :=
    glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull J2
      groupA groupB populationShare capacity2
  constructor
  · intro h
    rcases h with ⟨hexact, hA_other, hB_other⟩
    rcases hexact with ⟨hA, hnotB⟩ | ⟨hB, hnotA⟩
    · exact Or.inl ⟨hA, hnotB, hA_other hA⟩
    · exact Or.inr ⟨hB, hnotA, hB_other hB⟩
  · intro h
    rcases h with ⟨hA, hnotB, hotherB⟩ | ⟨hB, hnotA, hotherA⟩
    · refine ⟨Or.inl ⟨hA, hnotB⟩, ?_, ?_⟩
      · intro _hA
        exact hotherB
      · intro hB
        exact False.elim (hnotB hB)
    · refine ⟨Or.inr ⟨hB, hnotA⟩, ?_, ?_⟩
      · intro hA
        exact False.elim (hnotA hA)
      · intro _hB
        exact hotherA

/--
Theorem 3 / Proposition 5 support: condition (11)--(12)'s `J2` keep-test
predicate is exactly the school-`J2` objective comparison once the objective
values have been reduced to the source's weighted admitted-merit expressions,
the surviving group's test-taking mass meets capacity, and the merit
comparison is not tied.
-/
theorem paper_theorem3_school2_objective_iff_single_group_merit_gt_of_no_tie
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J2 : School) (groupA groupB otherGroup : Group)
    (populationShare : Group → ℝ)
    (objective2 : Policy → Policy → ℝ)
    (hobjectiveSubFull :
      objective2 Psub Pfull =
        populationShare otherGroup *
          S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull))
    (hobjectiveSubSub :
      objective2 Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hnotTie :
      populationShare otherGroup *
          S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull) ≠
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :
    (objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
      populationShare otherGroup *
          S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull) >
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub) := by
  let single :=
    populationShare otherGroup *
      S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull)
  let combined :=
    populationShare groupA *
        S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
      populationShare groupB *
        S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)
  have hobjective_iff :
      objective2 Psub Psub ≤ objective2 Psub Pfull ↔ combined ≤ single := by
    rw [hobjectiveSubSub, hobjectiveSubFull]
  have hle_iff_gt : combined ≤ single ↔ single > combined := by
    constructor
    · intro hle
      exact lt_of_le_of_ne hle (by simpa [single, combined] using hnotTie.symm)
    · intro hgt
      exact le_of_lt hgt
  exact hobjective_iff.trans hle_iff_gt

/--
Theorem 3 / Proposition 5 support: condition (11)--(12)'s `J2` keep-test
predicate is exactly the school-`J2` objective comparison once the objective
values have been reduced to the source's weighted admitted-merit expressions,
the surviving group's test-taking mass meets capacity, and the merit
comparison is not tied.
-/
theorem paper_theorem3_school2_objective_iff_other_group_keeps_test_of_single_group_no_tie
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J2 : School) (groupA groupB otherGroup : Group)
    (populationShare : Group → ℝ) {capacity2 : ℝ}
    (objective2 : Policy → Policy → ℝ)
    (hobjectiveSubFull :
      objective2 Psub Pfull =
        populationShare otherGroup *
          S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull))
    (hobjectiveSubSub :
      objective2 Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hmass :
      S.massTestTaking otherGroup (policyPair Psub Pfull) ≥ capacity2)
    (hnotTie :
      populationShare otherGroup *
          S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull) ≠
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :
    (objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
      glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull
        J2 groupA groupB populationShare capacity2 otherGroup := by
  let single :=
    populationShare otherGroup *
      S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull)
  let combined :=
    populationShare groupA *
        S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
      populationShare groupB *
        S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)
  have hobjective_iff :
      objective2 Psub Psub ≤ objective2 Psub Pfull ↔ combined ≤ single := by
    rw [hobjectiveSubSub, hobjectiveSubFull]
  have hle_iff_gt : combined ≤ single ↔ single > combined := by
    constructor
    · intro hle
      exact lt_of_le_of_ne hle (by simpa [single, combined] using hnotTie.symm)
    · intro hgt
      exact le_of_lt hgt
  constructor
  · intro hobjective
    exact ⟨hmass, hle_iff_gt.mp (hobjective_iff.mp hobjective)⟩
  · rintro ⟨_hmass, hmerit⟩
    exact hobjective_iff.mpr (hle_iff_gt.mpr hmerit)

/--
Theorem 3 / Proposition 5 support with the paper's strict merit comparison.

This is the same bridge as
`paper_theorem3_school2_objective_iff_other_group_keeps_test_of_single_group_no_tie`,
but the technical no-tie premise is discharged from the strict condition
appearing in condition (12).
-/
theorem paper_theorem3_school2_objective_iff_other_group_keeps_test_of_single_group_merit_gt
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J2 : School) (groupA groupB otherGroup : Group)
    (populationShare : Group → ℝ) {capacity2 : ℝ}
    (objective2 : Policy → Policy → ℝ)
    (hobjectiveSubFull :
      objective2 Psub Pfull =
        populationShare otherGroup *
          S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull))
    (hobjectiveSubSub :
      objective2 Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hmass :
      S.massTestTaking otherGroup (policyPair Psub Pfull) ≥ capacity2)
    (hmerit_gt :
      populationShare otherGroup *
          S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull) >
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :
    (objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
      glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull
