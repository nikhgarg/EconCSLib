          (priorPrecision g) (subPrecision g) (testPrecision g) *
          Q.quantile (1 - cost g / value)
  have hqApply : Continuous qApply := by
    dsimp [qApply]
    exact continuous_id.sub continuous_const
  simpa [glm20Lemma3StrategicApplicantComponent, qApply] using
    (glm20BivariateApplyAdmitMass_continuous_along
      Q.cdfAPI bivariateCDF
      (populationShare := populationShare g)
      (sigmaTilde := sigmaTilde g)
      (b := b g) (mu := mu g)
      (aOfApply := aOfApply g)
      (qApply := qApply) (qAdmit := fun qAdmit : ℝ => qAdmit)
      ha hqApply continuous_id hbivar)

