theorem paper_proposition5_equation50_subFull_apply_cutoff_formula_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {q2Full scale cost v2 : ℝ}
    (hscale : 0 < scale) (hv2 : 0 < v2)
    (hcostRatio : cost / v2 ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ subFullCutoff : ℝ,
      subFullCutoff =
        q2Full - scale * Q.quantile (1 - cost / v2) ∧
