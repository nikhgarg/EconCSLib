/--
Proposition 5(ii) school-`J2` bridge from cutoff-case proof language to the
paper's condition (13).

If the concrete Gaussian proof shows that `J2` weakly prefers dropping the
test exactly when there is exactly one group satisfying the two cost-threshold
comparisons and cutoff case `q^*_{2,sub} < q^g_{full,full}`, then the same
objective comparison is equivalent to Theorem 3(ii)'s displayed condition (13)
for exactly one group.
-/
theorem paper_proposition5_part_ii_school2_objective_iff_condition13_of_cutoff_cases
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy)
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {groupA groupB : Group}
    {testCost lowCostThreshold highCostThreshold : Group → ℝ}
    {q1Sub q2Sub : ℝ} {fullFullCutoff : Group → ℝ}
    (objective2 : Policy → Policy → ℝ)
    (hmassA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hobjectiveCutoff :
      (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (fun g =>
            testCost g ≥ lowCostThreshold g ∧
              0 < lowCostThreshold g ∧
                lowCostThreshold g < highCostThreshold g ∧
                  q2Sub < fullFullCutoff g)) :
    (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
      glm20ExactlyOneOfTwo groupA groupB
        (glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
          testCost lowCostThreshold highCostThreshold q1Sub q2Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)) := by
  let cutoffCondition := fun g : Group =>
    testCost g ≥ lowCostThreshold g ∧
      0 < lowCostThreshold g ∧
        lowCostThreshold g < highCostThreshold g ∧
          q2Sub < fullFullCutoff g
  let condition13 :=
    glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
      testCost lowCostThreshold highCostThreshold q1Sub q2Sub
      (fun g q => glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
  have hA : cutoffCondition groupA ↔ condition13 groupA :=
    (paper_proposition5_condition13_iff_cost_and_fullFull_cutoff_case
      S policyPair Psub Pfull api subEstimateLaw hmassA).symm
  have hB : cutoffCondition groupB ↔ condition13 groupB :=
    (paper_proposition5_condition13_iff_cost_and_fullFull_cutoff_case
      S policyPair Psub Pfull api subEstimateLaw hmassB).symm
  exact hobjectiveCutoff.trans (glm20ExactlyOneOfTwo_congr hA hB)

/--
Proposition 5(ii) school-`J2` case-analysis bridge.

This is the part-(ii) analogue of the part-(i) school-`J1` bridge: if no group
satisfies the full/full cutoff case then `J2` does not drop; if both groups
satisfy it the case is impossible; and if exactly one group satisfies it,
dropping is equivalent to the low positive cost-threshold comparison, with the
high threshold above the low threshold.
-/
theorem paper_proposition5_part_ii_school2_cutoff_objective_iff_exactly_one_cost_case
    {Group Policy : Type*}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost lowCostThreshold highCostThreshold : Group → ℝ} {q2Sub : ℝ}
    {fullFullCutoff : Group → ℝ}
    (objective2 : Policy → Policy → ℝ)
    (hnone :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ¬ objective2 Pfull Pfull ≤ objective2 Pfull Psub)
    (hboth_impossible :
      q2Sub < fullFullCutoff groupA →
        q2Sub < fullFullCutoff groupB → False)
    (honlyA :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            testCost groupA ≥ lowCostThreshold groupA ∧
              0 < lowCostThreshold groupA ∧
                lowCostThreshold groupA < highCostThreshold groupA))
    (honlyB :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            testCost groupB ≥ lowCostThreshold groupB ∧
              0 < lowCostThreshold groupB ∧
                lowCostThreshold groupB < highCostThreshold groupB)) :
    (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
      glm20ExactlyOneOfTwo groupA groupB
        (fun g =>
          (testCost g ≥ lowCostThreshold g ∧
              0 < lowCostThreshold g ∧
                lowCostThreshold g < highCostThreshold g) ∧
            q2Sub < fullFullCutoff g) :=
  glm20ExactlyOneOfTwo_qualified_cutoff_iff_of_case_analysis
    (a := groupA) (b := groupB)
    (deviationProfitable :=
      objective2 Pfull Pfull ≤ objective2 Pfull Psub)
    (cutoffCase := fun g => q2Sub < fullFullCutoff g)
    (qualifier := fun g =>
      testCost g ≥ lowCostThreshold g ∧
        0 < lowCostThreshold g ∧
          lowCostThreshold g < highCostThreshold g)
    hnone hboth_impossible honlyA honlyB

/--
Proposition 5(ii) low/high threshold-ordering support from direct merit
ordering.

The source proof's root-side premise says that when the low-threshold
test-based merit is exactly at its test-free benchmark, the high-threshold
test-based merit is still above its own test-free benchmark.  A reusable way to
prove that premise is to show that the high test-free benchmark is below the
low benchmark and that the high test-based merit weakly dominates the low
test-based merit at the candidate cost.
-/
theorem paper_proposition5_high_merit_at_low_root_of_test_free_lt_and_test_based_le
    {Group : Type*}
    {leftCost rightCost : Group → ℝ}
    (lowTestBasedMerit : Group → ℝ → ℝ)
    (lowTestFreeMerit : Group → ℝ)
    (highTestBasedMerit : Group → ℝ → ℝ)
    (highTestFreeMerit : Group → ℝ)
    (hfree :
      ∀ g, highTestFreeMerit g < lowTestFreeMerit g)
    (hbased :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        lowTestBasedMerit g c ≤ highTestBasedMerit g c) :
    ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
      lowTestBasedMerit g c = lowTestFreeMerit g →
        highTestFreeMerit g < highTestBasedMerit g c := by
  intro g c hc hroot
  exact lt_of_lt_of_le (by simpa [hroot] using hfree g) (hbased g c hc)

/--
Proposition 5(ii) Gaussian source support for direct full-sub merit ordering.

This is the upstream source-family bridge for
`paper_proposition5_high_merit_at_low_root_of_test_free_lt_and_test_based_le`:
if the low/high test-free and test-based merits are identified with Gaussian
upper-tail means, then ordinary scale and threshold comparisons imply the two
ordered-merit premises used by the selected-threshold construction.
-/
theorem
    paper_proposition5_fullSub_ordered_merits_of_gaussian_tail_mean_formulas
    (C : GaussianHazardCertificate)
    {Group : Type*}
    {leftCost rightCost : Group → ℝ}
    (lowTestBasedMerit : Group → ℝ → ℝ)
    (lowTestFreeMerit : Group → ℝ)
    (highTestBasedMerit : Group → ℝ → ℝ)
    (highTestFreeMerit : Group → ℝ)
    (lowFreeLaw highFreeLaw : Group → GaussianScaleLaw)
    (lowFreeThreshold highFreeThreshold : Group → ℝ)
    (lowBasedLaw highBasedLaw : Group → ℝ → GaussianScaleLaw)
    (lowBasedThreshold highBasedThreshold : Group → ℝ → ℝ)
    (hlowFreeFormula :
      ∀ g,
        lowTestFreeMerit g =
          C.normalUpperTailMean (lowFreeLaw g) (lowFreeThreshold g))
    (hhighFreeFormula :
      ∀ g,
        highTestFreeMerit g =
          C.normalUpperTailMean (highFreeLaw g) (highFreeThreshold g))
    (hfreeMean :
      ∀ g, (highFreeLaw g).mean = (lowFreeLaw g).mean)
    (hfreeScale :
      ∀ g, (highFreeLaw g).scale < (lowFreeLaw g).scale)
    (hfreeThresholdMean :
      ∀ g, (highFreeLaw g).mean < highFreeThreshold g)
    (hfreeThreshold :
      ∀ g, highFreeThreshold g ≤ lowFreeThreshold g)
    (hlowBasedFormula :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        lowTestBasedMerit g c =
          C.normalUpperTailMean (lowBasedLaw g c)
            (lowBasedThreshold g c))
    (hhighBasedFormula :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        highTestBasedMerit g c =
          C.normalUpperTailMean (highBasedLaw g c)
            (highBasedThreshold g c))
    (hbasedMean :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        (lowBasedLaw g c).mean = (highBasedLaw g c).mean)
    (hbasedScale :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        (lowBasedLaw g c).scale ≤ (highBasedLaw g c).scale)
    (hbasedThresholdMean :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        (lowBasedLaw g c).mean < lowBasedThreshold g c)
    (hbasedThreshold :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        lowBasedThreshold g c ≤ highBasedThreshold g c) :
    (∀ g, highTestFreeMerit g < lowTestFreeMerit g) ∧
      (∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        lowTestBasedMerit g c ≤ highTestBasedMerit g c) := by
  refine ⟨?_, ?_⟩
  · intro g
    rw [hhighFreeFormula g, hlowFreeFormula g]
    have hscaleStep :
        C.normalUpperTailMean (highFreeLaw g) (highFreeThreshold g) <
          C.normalUpperTailMean (lowFreeLaw g) (highFreeThreshold g) :=
      C.normalUpperTailMean_lt_of_same_mean_scale_lt_above_mean
        (hfreeMean g) (hfreeScale g) (hfreeThresholdMean g)
    have hthresholdStep :
        C.normalUpperTailMean (lowFreeLaw g) (highFreeThreshold g) ≤
          C.normalUpperTailMean (lowFreeLaw g) (lowFreeThreshold g) :=
      C.normalUpperTailMean_mono_threshold (lowFreeLaw g)
        (hfreeThreshold g)
    exact lt_of_lt_of_le hscaleStep hthresholdStep
  · intro g c hc
    rw [hlowBasedFormula g c hc, hhighBasedFormula g c hc]
    have hscaleStep :
        C.normalUpperTailMean (lowBasedLaw g c)
            (lowBasedThreshold g c) ≤
          C.normalUpperTailMean (highBasedLaw g c)
            (lowBasedThreshold g c) :=
      C.normalUpperTailMean_le_of_same_mean_scale_le_above_mean
        (hbasedMean g c hc) (hbasedScale g c hc)
        (hbasedThresholdMean g c hc)
    have hthresholdStep :
        C.normalUpperTailMean (highBasedLaw g c)
            (lowBasedThreshold g c) ≤
          C.normalUpperTailMean (highBasedLaw g c)
            (highBasedThreshold g c) :=
      C.normalUpperTailMean_mono_threshold (highBasedLaw g c)
        (hbasedThreshold g c hc)
    exact le_trans hscaleStep hthresholdStep

/--
Proposition 5(ii) high-at-low-root support from Gaussian source formulas.

This composes the Gaussian tail-mean identification/order bridge with the
generic high-at-low-root lemma, producing the exact root-side premise required
by the full-sub threshold construction.
-/
theorem
    paper_proposition5_high_merit_at_low_root_of_gaussian_tail_mean_formulas
    (C : GaussianHazardCertificate)
    {Group : Type*}
    {leftCost rightCost : Group → ℝ}
    (lowTestBasedMerit : Group → ℝ → ℝ)
    (lowTestFreeMerit : Group → ℝ)
    (highTestBasedMerit : Group → ℝ → ℝ)
    (highTestFreeMerit : Group → ℝ)
    (lowFreeLaw highFreeLaw : Group → GaussianScaleLaw)
    (lowFreeThreshold highFreeThreshold : Group → ℝ)
    (lowBasedLaw highBasedLaw : Group → ℝ → GaussianScaleLaw)
    (lowBasedThreshold highBasedThreshold : Group → ℝ → ℝ)
    (hlowFreeFormula :
