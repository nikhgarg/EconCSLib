    (highQ1Full := highQ1Full) (highQ2Full := highQ2Full)
    (highScale := highScale) (highV1 := highV1) (highV2 := highV2)
    lowCutoffOfCost highCutoffOfCost lowMeritOfCutoff lowTestFreeMerit
