theorem paper_proposition5_cost_merit_continuous_strictAntiOn_of_cutoff_strictMono
    {cutoffOfCost meritOfCutoff : ℝ → ℝ} {costDomain cutoffDomain : Set ℝ}
    (hcutoff_cont : ContinuousOn cutoffOfCost costDomain)
    (hcutoff_mono : StrictMonoOn cutoffOfCost costDomain)
    (hcutoff_maps : Set.MapsTo cutoffOfCost costDomain cutoffDomain)
    (hmerit_cont : ContinuousOn meritOfCutoff cutoffDomain)
    (hmerit_anti : StrictAntiOn meritOfCutoff cutoffDomain) :
