    simpa [cutoffOfCost, hcost] using hspec.1
  refine ⟨cutoffOfCost, hcutoff, ?_⟩
  exact
    paper_proposition5_twoFull_apply_payoff_cutoff_strictMonoOn_cost
      standardGaussianCDFAPI hscale hv2_pos hv2_lt_v1
      (fun cost hcost => (hcutoff cost hcost).1)

