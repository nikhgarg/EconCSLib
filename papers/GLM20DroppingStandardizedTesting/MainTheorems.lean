/--
Theorem 1 academic-merit Step 2, group A square-root factor: for `ρ_A < 1`,
the second factor in `β_A` is strictly increasing in `γ_A`.
-/
theorem paper_theorem1_beta_groupA_factor_strictMonoOn
    {ownShare otherEligibleMass rho : ℝ}
    (hown_pos : 0 < ownShare)
    (hother_pos : 0 < otherEligibleMass)
    (hrho_nonneg : 0 ≤ rho) (hrho_lt_one : rho < 1) :
    StrictMonoOn
      (theorem1BetaGroupAFactor ownShare otherEligibleMass rho)
      (Set.Icc (0 : ℝ) 1) := by
  intro x hx y _hy hxy
  exact sqrt_fractionalLinear_const_mul_lt_of_rho_lt_one
    hown_pos hother_pos hrho_nonneg hrho_lt_one hx.1 hxy

/--
Theorem 1 academic-merit Step 2, group B square-root factor: for `1 < ρ_B`,
the second factor in `β_B` is strictly increasing in `γ_B`.
-/
theorem paper_theorem1_beta_groupB_factor_strictMonoOn
    {ownShare otherEligibleMass rho : ℝ}
    (hown_pos : 0 < ownShare)
    (hother_pos : 0 < otherEligibleMass)
    (hone_lt_rho : 1 < rho) :
    StrictMonoOn
      (theorem1BetaGroupBFactor ownShare otherEligibleMass rho)
      (Set.Icc (0 : ℝ) 1) := by
  intro x hx y _hy hxy
  exact sqrt_fractionalLinear_mul_const_lt_of_one_lt_rho
    hown_pos hother_pos hone_lt_rho hx.1 hxy

/--
Theorem 1 academic-merit Step 2, group A: under the source's selective
eligible-pool condition, the full paper `β_A` expression is strictly
increasing in `γ_A`.

The analytic normal-distribution facts needed here are exactly that
`Φ⁻¹` is monotone and that an upper-tail quantile above one half is positive;
both are provided by `StandardGaussianQuantileAPI`.
-/
theorem paper_theorem1_beta_groupA_strictMonoOn
    (Q : StandardGaussianQuantileAPI)
    {capacity ownShare otherEligibleMass rho : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hown_pos : 0 < ownShare)
    (hother_pos : 0 < otherEligibleMass)
    (hrho_nonneg : 0 ≤ rho) (hrho_lt_one : rho < 1)
    (hselective :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShare * γ + otherEligibleMass) :
    StrictMonoOn
      (theorem1BetaGroupA Q capacity ownShare otherEligibleMass rho)
      (Set.Icc (0 : ℝ) 1) := by
  intro x hx y hy hxy
  have hmassx_pos : 0 < ownShare * x + otherEligibleMass := by
    nlinarith [hcapacity_pos, hselective x hx]
  have hmassy_pos : 0 < ownShare * y + otherEligibleMass := by
    nlinarith [hcapacity_pos, hselective y hy]
  have hmass_le : ownShare * x + otherEligibleMass ≤
      ownShare * y + otherEligibleMass := by
    nlinarith [mul_pos hown_pos (sub_pos.mpr hxy)]
  have hcapacity_div :
      capacity / (ownShare * y + otherEligibleMass) ≤
        capacity / (ownShare * x + otherEligibleMass) := by
    rw [div_le_div_iff₀ hmassy_pos hmassx_pos]
    exact mul_le_mul_of_nonneg_left hmass_le hcapacity_pos.le
  have harg_mono :
      1 - capacity / (ownShare * x + otherEligibleMass) ≤
        1 - capacity / (ownShare * y + otherEligibleMass) := by
    linarith
  have hquantile_mono :
      Q.quantile (1 - capacity / (ownShare * x + otherEligibleMass)) ≤
        Q.quantile (1 - capacity / (ownShare * y + otherEligibleMass)) :=
    Q.quantile_mono
      (theorem1_quantile_arg_mem_Ioo hcapacity_pos (hselective x hx))
      (theorem1_quantile_arg_mem_Ioo hcapacity_pos (hselective y hy))
      harg_mono
  have hquantile_pos :
      0 < Q.quantile (1 - capacity / (ownShare * x + otherEligibleMass)) :=
    Q.quantile_pos_of_two_mul_capacity_lt_mass
      hcapacity_pos hmassx_pos (hselective x hx)
  have hfactor_lt :
      theorem1BetaGroupAFactor ownShare otherEligibleMass rho x <
        theorem1BetaGroupAFactor ownShare otherEligibleMass rho y :=
    paper_theorem1_beta_groupA_factor_strictMonoOn
      hown_pos hother_pos hrho_nonneg hrho_lt_one hx hy hxy
  have hleft_lt :
      Q.quantile (1 - capacity / (ownShare * x + otherEligibleMass)) *
          theorem1BetaGroupAFactor ownShare otherEligibleMass rho x <
        Q.quantile (1 - capacity / (ownShare * x + otherEligibleMass)) *
          theorem1BetaGroupAFactor ownShare otherEligibleMass rho y :=
    mul_lt_mul_of_pos_left hfactor_lt hquantile_pos
  have hright_le :
      Q.quantile (1 - capacity / (ownShare * x + otherEligibleMass)) *
          theorem1BetaGroupAFactor ownShare otherEligibleMass rho y ≤
        Q.quantile (1 - capacity / (ownShare * y + otherEligibleMass)) *
          theorem1BetaGroupAFactor ownShare otherEligibleMass rho y :=
    mul_le_mul_of_nonneg_right hquantile_mono
      (Real.sqrt_nonneg
        ((ownShare * y + otherEligibleMass * rho) /
          (ownShare * y + otherEligibleMass)))
  exact lt_of_lt_of_le hleft_lt hright_le

/--
Theorem 1 academic-merit Step 2, group B: under the source's selective
eligible-pool condition, the full paper `β_B` expression is strictly
increasing in `γ_B`.
-/
theorem paper_theorem1_beta_groupB_strictMonoOn
    (Q : StandardGaussianQuantileAPI)
    {capacity ownShare otherEligibleMass rho : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hown_pos : 0 < ownShare)
    (hother_pos : 0 < otherEligibleMass)
    (hone_lt_rho : 1 < rho)
    (hselective :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShare * γ + otherEligibleMass) :
    StrictMonoOn
      (theorem1BetaGroupB Q capacity ownShare otherEligibleMass rho)
      (Set.Icc (0 : ℝ) 1) := by
  intro x hx y hy hxy
  have hmassx_pos : 0 < ownShare * x + otherEligibleMass := by
    nlinarith [hcapacity_pos, hselective x hx]
  have hmassy_pos : 0 < ownShare * y + otherEligibleMass := by
    nlinarith [hcapacity_pos, hselective y hy]
  have hmass_le : ownShare * x + otherEligibleMass ≤
      ownShare * y + otherEligibleMass := by
    nlinarith [mul_pos hown_pos (sub_pos.mpr hxy)]
  have hcapacity_div :
      capacity / (ownShare * y + otherEligibleMass) ≤
        capacity / (ownShare * x + otherEligibleMass) := by
    rw [div_le_div_iff₀ hmassy_pos hmassx_pos]
    exact mul_le_mul_of_nonneg_left hmass_le hcapacity_pos.le
  have harg_mono :
      1 - capacity / (ownShare * x + otherEligibleMass) ≤
        1 - capacity / (ownShare * y + otherEligibleMass) := by
    linarith
  have hquantile_mono :
      Q.quantile (1 - capacity / (ownShare * x + otherEligibleMass)) ≤
        Q.quantile (1 - capacity / (ownShare * y + otherEligibleMass)) :=
    Q.quantile_mono
      (theorem1_quantile_arg_mem_Ioo hcapacity_pos (hselective x hx))
      (theorem1_quantile_arg_mem_Ioo hcapacity_pos (hselective y hy))
      harg_mono
  have hquantile_pos :
      0 < Q.quantile (1 - capacity / (ownShare * x + otherEligibleMass)) :=
    Q.quantile_pos_of_two_mul_capacity_lt_mass
      hcapacity_pos hmassx_pos (hselective x hx)
  have hfactor_lt :
      theorem1BetaGroupBFactor ownShare otherEligibleMass rho x <
        theorem1BetaGroupBFactor ownShare otherEligibleMass rho y :=
    paper_theorem1_beta_groupB_factor_strictMonoOn
      hown_pos hother_pos hone_lt_rho hx hy hxy
  have hleft_lt :
      Q.quantile (1 - capacity / (ownShare * x + otherEligibleMass)) *
          theorem1BetaGroupBFactor ownShare otherEligibleMass rho x <
        Q.quantile (1 - capacity / (ownShare * x + otherEligibleMass)) *
