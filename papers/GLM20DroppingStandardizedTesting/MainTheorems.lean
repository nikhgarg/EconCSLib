    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃! equilibrium : ℝ × ℝ × (ℝ → Bool),
      glm20Proposition2TwoSchoolThresholdEquilibrium standardGaussianQuantileAPI
        (standardGaussianCDFAPI.mixtureTailMass weight1 law1)
        (standardGaussianCDFAPI.mixtureTailMass weight2 law2)
        capacity1 capacity2 scale cost v1 v2 hscale equilibrium :=
    paper_proposition2_two_school_threshold_equilibrium_existsUnique_standardGaussian_of_high_cost_ratio
      standardGaussianQuantileAPI
      (applicantMass1 := standardGaussianCDFAPI.mixtureTailMass weight1 law1)
      (applicantMass2 := standardGaussianCDFAPI.mixtureTailMass weight2 law2)
      (capacity1 := capacity1) (capacity2 := capacity2)
      (totalApplicantMass1 := ∑ g : Group1, weight1 g)
      (totalApplicantMass2 := ∑ g : Group2, weight2 g)
      (scale := scale) (cost := cost) (v1 := v1) (v2 := v2)
      (standardGaussianCDFAPI.mixtureTailMass_continuous weight1 law1)
      (standardGaussianCDFAPI.mixtureTailMass_strictAnti_threshold
        (law := law1) hweight1 hpos1)
      (standardGaussianCDFAPI.mixtureTailMass_tendsto_atBot_sum_weights
        standardGaussianCDF_tendsto_atBot weight1 law1)
      (standardGaussianCDFAPI.mixtureTailMass_tendsto_atTop_zero
        standardGaussianCDF_tendsto_atTop weight1 law1)
      hcapacity1
      (standardGaussianCDFAPI.mixtureTailMass_continuous weight2 law2)
      (standardGaussianCDFAPI.mixtureTailMass_strictAnti_threshold
        (law := law2) hweight2 hpos2)
      (standardGaussianCDFAPI.mixtureTailMass_tendsto_atBot_sum_weights
        standardGaussianCDF_tendsto_atBot weight2 law2)
      (standardGaussianCDFAPI.mixtureTailMass_tendsto_atTop_zero
        standardGaussianCDF_tendsto_atTop weight2 law2)
      hcapacity2 hscale hcost hv1 hdiff_pos hdiff_lt_v1 hcostRatioHigh

/--
Proposition 2 finite standard-Gaussian mixture threshold-equilibrium endpoint
