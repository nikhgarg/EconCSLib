            0 ≤ (v1 - v2) *
              Q.cdfAPI.thresholdPassProb
                { mean := q, scale := scale, scale_pos := hscale }
                admissionThreshold - cost)) ↔
        ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
          max highCutoff school2SubThreshold ≤ q) :=
  paper_proposition2_two_school_application_region_standardGaussian_of_high_cost_ratio
    Q hscale hcost hv1 hdiff_pos hdiff_lt_v1
    (paper_proposition2_cost_ratio_high_of_cost_bounds hcost hcost_lt_diff)

