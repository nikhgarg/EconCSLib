            γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SB groupB Pfull Psub γB ↔
            γB ≤ γbarB) :=
    paper_theorem1_dropping_tests_with_barriers_canonical_of_capacity_range
      standardGaussianHazardInverseCertificate standardGaussianQuantileAPI
