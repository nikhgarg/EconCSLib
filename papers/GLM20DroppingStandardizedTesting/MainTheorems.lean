/--
Proposition 5(ii) / Theorem 3(ii) objective bridge from merit crossings on a
positive interior cost interval.

This version is tailored for the source Gaussian cutoff formulas, which are
usually proved on `left_g ≤ c_g ≤ right_g` with `0 < left_g` rather than on
`0 ≤ c_g ≤ maxCost_g`.
-/
theorem
    paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_merit_crossings_interval
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost leftCost rightCost : Group → ℝ} {q1Sub q2Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff fullSubCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (lowTestBasedMerit : Group → ℝ → ℝ) (lowTestFreeMerit : Group → ℝ)
    (highTestBasedMerit : Group → ℝ → ℝ) (highTestFreeMerit : Group → ℝ)
    (hleft_right : ∀ g, leftCost g < rightCost g)
    (hleft_pos : ∀ g, 0 < leftCost g)
    (hcostMem :
      ∀ g, testCost g ∈ Set.Icc (leftCost g) (rightCost g))
    (hlowCont :
      ∀ g, ContinuousOn (lowTestBasedMerit g)
        (Set.Icc (leftCost g) (rightCost g)))
    (hlowAnti :
      ∀ g, StrictAntiOn (lowTestBasedMerit g)
        (Set.Icc (leftCost g) (rightCost g)))
    (hlowAtLeft :
      ∀ g, lowTestFreeMerit g < lowTestBasedMerit g (leftCost g))
    (hlowAtRight :
      ∀ g, lowTestBasedMerit g (rightCost g) < lowTestFreeMerit g)
    (hhighCont :
      ∀ g, ContinuousOn (highTestBasedMerit g)
        (Set.Icc (leftCost g) (rightCost g)))
    (hhighAnti :
      ∀ g, StrictAntiOn (highTestBasedMerit g)
        (Set.Icc (leftCost g) (rightCost g)))
    (hhighAtLeft :
      ∀ g, highTestFreeMerit g < highTestBasedMerit g (leftCost g))
    (hhighAtRight :
      ∀ g, highTestBasedMerit g (rightCost g) < highTestFreeMerit g)
    (hhighAtLowRoot :
      ∀ g c, c ∈ Set.Ioo (leftCost g) (rightCost g) →
        lowTestBasedMerit g c = lowTestFreeMerit g →
          highTestFreeMerit g < highTestBasedMerit g c)
