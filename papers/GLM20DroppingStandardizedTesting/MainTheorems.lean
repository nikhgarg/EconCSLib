    intro g
    exact Classical.choose_spec (hlowThreshold g)
  have hhighSpec :
      ∀ g,
        highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g) ∧
          highTestBasedMerit g (highCostThreshold g) = highTestFreeMerit g ∧
            (∀ c ∈ Set.Icc (0 : ℝ) (maxCost g),
