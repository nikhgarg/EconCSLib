      hatTop hcapacity hprior_pos hsub_pos htest_pos hvalue hcostRatio

/--
Proposition 3 diversity formula for one group under the full test-based
policy.

This is the paper's Step 2 expression
`π_g σtilde_g / C * (Φ(A_g) - Φ_2(A_g,B_g;ρ_g))`, where
`A_g = (a_g + b_g μ) / sqrt(1 + σtilde_g^2 b_g^2)`,
`B_g = (q_full^* - μ) / σtilde_g`, and
`ρ_g = -σtilde_g b_g / sqrt(1 + σtilde_g^2 b_g^2)`.
-/
def glm20Proposition3TauFormula
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (populationShare capacity sigmaTilde a b mu qFull : ℝ) : ℝ :=
  populationShare * sigmaTilde / capacity *
    glm20Proposition3SelectionCore api bivariateCDF sigmaTilde a b mu qFull

/--
Proposition 3 admitted-group share from the bivariate selection mass.

This is the model-side definition of the admitted fraction of a group under
the full policy: admitted group mass divided by school capacity.
-/
def glm20Proposition3AdmittedShareFromSelectionMass
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (populationShare capacity sigmaTilde a b mu qFull : ℝ) : ℝ :=
  populationShare * sigmaTilde *
    glm20Proposition3SelectionCore api bivariateCDF sigmaTilde a b mu qFull /
      capacity

/--
Proposition 3 mass-to-share bookkeeping.

The model-side admitted share from the bivariate selection mass is exactly the
displayed `tau_g` formula.
-/
theorem glm20Proposition3AdmittedShareFromSelectionMass_eq_tauFormula
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (populationShare capacity sigmaTilde a b mu qFull : ℝ) :
    glm20Proposition3AdmittedShareFromSelectionMass api bivariateCDF
        populationShare capacity sigmaTilde a b mu qFull =
      glm20Proposition3TauFormula api bivariateCDF
        populationShare capacity sigmaTilde a b mu qFull := by
  simp [glm20Proposition3AdmittedShareFromSelectionMass,
    glm20Proposition3TauFormula]
  ring

/--
Proposition 3 `tau_g` formula for the concrete correlated standard-Gaussian
CDF.

The paper's displayed diversity share
`pi_g sigma_tilde_g / C * (Phi(A_g)-Phi_2(A_g,B_g;rho_g))` is a scaled
vertical strip mass under `correlatedStandardGaussianLaw rho_g`.
-/
theorem paper_proposition3_tau_formula_eq_correlatedStandardGaussian_verticalUpperStripMass
    {populationShare capacity sigmaTilde a b mu qFull : ℝ} :
    glm20Proposition3TauFormula standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare capacity sigmaTilde
        a b mu qFull =
      populationShare * sigmaTilde / capacity *
        verticalUpperStripMass
          (correlatedStandardGaussianLaw
            (-(sigmaTilde * b) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
          ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((qFull - mu) / sigmaTilde) := by
  rw [glm20Proposition3TauFormula,
    paper_proposition3_selection_core_eq_correlatedStandardGaussian_verticalUpperStripMass]

/--
Proposition 3 `tau_g` formula from the source affine Owen mass.

This packages the paper's Step 2 source route: the diversity share computed
from the integrated affine application probability is the displayed
`π_g σtilde_g / C * (Phi(A_g)-Phi_2(A_g,B_g;rho_g))` formula.
-/
theorem paper_proposition3_tau_formula_eq_owenAffineSelectionMass
    {populationShare capacity sigmaTilde a b mu qFull : ℝ} :
    glm20Proposition3TauFormula standardGaussianCDFAPI
        standardBivariateGaussianCDF populationShare capacity sigmaTilde
        a b mu qFull =
      populationShare * sigmaTilde / capacity *
        glm20Proposition3OwenAffineSelectionMass
          sigmaTilde a b mu qFull := by
  rw [glm20Proposition3TauFormula,
    paper_proposition3_selection_core_eq_owenAffineSelectionMass]

/--
Proposition 3(i), algebraic diversity comparison from the displayed `τ_g`
formula.

If capacity equals the total admitted mass
`(1-π) σ_A X_A + π σ_B X_B`, where `X_g` is the common selection-core
expression, then group B is under-represented exactly when
`σ_B X_B < σ_A X_A`.
-/
theorem paper_proposition3_underrepresented_iff_selection_core_mass
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {pi capacity tauB sigmaTildeA sigmaTildeB aA aB bA bB mu qFull : ℝ}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hsigmaA_pos : 0 < sigmaTildeA)
    (hsigmaB_pos : 0 < sigmaTildeB)
    (hcoreA_pos :
      0 <
        glm20Proposition3SelectionCore api bivariateCDF
          sigmaTildeA aA bA mu qFull)
    (hcoreB_pos :
      0 <
        glm20Proposition3SelectionCore api bivariateCDF
          sigmaTildeB aB bB mu qFull)
    (hcapacity :
      capacity =
        (1 - pi) * sigmaTildeA *
            glm20Proposition3SelectionCore api bivariateCDF
              sigmaTildeA aA bA mu qFull +
          pi * sigmaTildeB *
            glm20Proposition3SelectionCore api bivariateCDF
              sigmaTildeB aB bB mu qFull)
    (htauB :
      tauB =
        glm20Proposition3TauFormula api bivariateCDF
          pi capacity sigmaTildeB aB bB mu qFull) :
    tauB < pi ↔
      sigmaTildeB *
          glm20Proposition3SelectionCore api bivariateCDF
            sigmaTildeB aB bB mu qFull <
        sigmaTildeA *
          glm20Proposition3SelectionCore api bivariateCDF
            sigmaTildeA aA bA mu qFull := by
  let coreA :=
    glm20Proposition3SelectionCore api bivariateCDF
      sigmaTildeA aA bA mu qFull
  let coreB :=
    glm20Proposition3SelectionCore api bivariateCDF
      sigmaTildeB aB bB mu qFull
  have hcoreA_pos' : 0 < coreA := by simpa [coreA] using hcoreA_pos
  have hcoreB_pos' : 0 < coreB := by simpa [coreB] using hcoreB_pos
  have honeMinus_pos : 0 < 1 - pi := by linarith
  have hcapacity' :
      capacity = (1 - pi) * sigmaTildeA * coreA +
        pi * sigmaTildeB * coreB := by
    simpa [coreA, coreB] using hcapacity
  have hcapacity_pos : 0 < capacity := by
    rw [hcapacity']
    nlinarith [mul_pos honeMinus_pos (mul_pos hsigmaA_pos hcoreA_pos'),
      mul_pos hpi_pos (mul_pos hsigmaB_pos hcoreB_pos')]
  have htauB' :
      tauB = pi * sigmaTildeB / capacity * coreB := by
    simpa [glm20Proposition3TauFormula, coreB] using htauB
  have htauB_mul :
      pi * sigmaTildeB / capacity * coreB =
        pi * (sigmaTildeB * coreB / capacity) := by
    field_simp [ne_of_gt hcapacity_pos]
  constructor
  · intro hunder
    rw [htauB', htauB_mul] at hunder
    have hratio : sigmaTildeB * coreB / capacity < 1 :=
      by nlinarith [hunder, hpi_pos]
    have hmass_lt_capacity : sigmaTildeB * coreB < capacity := by
      rwa [div_lt_one hcapacity_pos] at hratio
    rw [hcapacity'] at hmass_lt_capacity
    nlinarith [hpi_pos, hpi_lt_one, hmass_lt_capacity]
  · intro hmass
    have hmass_lt_capacity : sigmaTildeB * coreB < capacity := by
      rw [hcapacity']
      nlinarith [hpi_pos, hpi_lt_one, hmass]
    have hratio : sigmaTildeB * coreB / capacity < 1 := by
      rwa [div_lt_one hcapacity_pos]
    rw [htauB', htauB_mul]
    nlinarith [hpi_pos, hratio]

/--
Proposition 3(i), paper-ratio form of the diversity comparison.

This is the algebraic core of Equation (37): with positive selection cores,
`τ_B < π` is equivalent to
`σ_B / σ_A < X_A / X_B`, where `X_g` is the displayed
`Φ(A_g)-Φ₂(A_g,B_g;ρ_g)` bracket.
-/
theorem paper_proposition3_underrepresented_iff_selection_core_ratio
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {pi capacity tauB sigmaTildeA sigmaTildeB aA aB bA bB mu qFull : ℝ}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hsigmaA_pos : 0 < sigmaTildeA)
    (hsigmaB_pos : 0 < sigmaTildeB)
    (hcoreA_pos :
      0 <
        glm20Proposition3SelectionCore api bivariateCDF
          sigmaTildeA aA bA mu qFull)
    (hcoreB_pos :
      0 <
        glm20Proposition3SelectionCore api bivariateCDF
          sigmaTildeB aB bB mu qFull)
    (hcapacity :
      capacity =
        (1 - pi) * sigmaTildeA *
            glm20Proposition3SelectionCore api bivariateCDF
              sigmaTildeA aA bA mu qFull +
          pi * sigmaTildeB *
            glm20Proposition3SelectionCore api bivariateCDF
              sigmaTildeB aB bB mu qFull)
    (htauB :
      tauB =
        glm20Proposition3TauFormula api bivariateCDF
          pi capacity sigmaTildeB aB bB mu qFull) :
    tauB < pi ↔
      sigmaTildeB / sigmaTildeA <
        glm20Proposition3SelectionCore api bivariateCDF
            sigmaTildeA aA bA mu qFull /
          glm20Proposition3SelectionCore api bivariateCDF
            sigmaTildeB aB bB mu qFull := by
  let coreA :=
    glm20Proposition3SelectionCore api bivariateCDF
      sigmaTildeA aA bA mu qFull
  let coreB :=
    glm20Proposition3SelectionCore api bivariateCDF
      sigmaTildeB aB bB mu qFull
  have hmass :
      tauB < pi ↔ sigmaTildeB * coreB < sigmaTildeA * coreA :=
    paper_proposition3_underrepresented_iff_selection_core_mass
      api bivariateCDF hpi_pos hpi_lt_one hsigmaA_pos hsigmaB_pos
      (by simpa [coreA] using hcoreA_pos)
      (by simpa [coreB] using hcoreB_pos)
      (by simpa [coreA, coreB] using hcapacity)
      (by simpa [coreB] using htauB)
  have hratio :
      sigmaTildeB * coreB < sigmaTildeA * coreA ↔
        sigmaTildeB / sigmaTildeA < coreA / coreB := by
    rw [div_lt_div_iff₀ hsigmaA_pos (by simpa [coreB] using hcoreB_pos)]
    ring_nf
  exact hmass.trans hratio

/--
Proposition 3(i), concrete bivariate-Gaussian ratio form.

This removes the generic positive-selection-core premises from
`paper_proposition3_underrepresented_iff_selection_core_ratio` by proving
positivity of the displayed standard-bivariate brackets.
-/
theorem paper_proposition3_underrepresented_iff_selection_core_ratio_standardBivariate
    {pi capacity tauB sigmaTildeA sigmaTildeB aA aB bA bB mu qFull : ℝ}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hsigmaA_pos : 0 < sigmaTildeA)
    (hsigmaB_pos : 0 < sigmaTildeB)
    (hcapacity :
      capacity =
        (1 - pi) * sigmaTildeA *
            glm20Proposition3SelectionCore standardGaussianCDFAPI
              standardBivariateGaussianCDF sigmaTildeA aA bA mu qFull +
          pi * sigmaTildeB *
            glm20Proposition3SelectionCore standardGaussianCDFAPI
              standardBivariateGaussianCDF sigmaTildeB aB bB mu qFull)
    (htauB :
      tauB =
        glm20Proposition3TauFormula standardGaussianCDFAPI
          standardBivariateGaussianCDF pi capacity sigmaTildeB aB bB mu
          qFull) :
    tauB < pi ↔
      sigmaTildeB / sigmaTildeA <
        glm20Proposition3SelectionCore standardGaussianCDFAPI
            standardBivariateGaussianCDF sigmaTildeA aA bA mu qFull /
          glm20Proposition3SelectionCore standardGaussianCDFAPI
            standardBivariateGaussianCDF sigmaTildeB aB bB mu qFull :=
  paper_proposition3_underrepresented_iff_selection_core_ratio
    standardGaussianCDFAPI standardBivariateGaussianCDF
    hpi_pos hpi_lt_one hsigmaA_pos hsigmaB_pos
    (glm20Proposition3SelectionCore_standardBivariate_pos
      sigmaTildeA aA bA mu qFull)
    (glm20Proposition3SelectionCore_standardBivariate_pos
      sigmaTildeB aB bB mu qFull)
    hcapacity htauB

/--
Proposition 3 academic-merit formula `λ(a_g,b_g,σtilde_g,τ_g)`.

This follows the paper's displayed expression in Part (ii).  The bivariate
integral/Owen-formula work should prove that each group's admitted academic
merit equals this expression; the comparison theorem below then turns those
identities into the paper's iff.
-/
def glm20Proposition3LambdaFormula
    (api : StandardGaussianCDFAPI)
    (a b sigmaTilde tau mu qFull : ℝ) : ℝ :=
  let denom := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let A := (a + b * mu) / denom
  let shifted :=
    qFull * denom + b * sigmaTilde * (a + b * mu) / denom
  mu -
    sigmaTilde ^ 2 * b / (tau * denom) * api.density A *
      api.cdf shifted +
    api.cdf (a + b * mu + b * sigmaTilde * qFull) *
      sigmaTilde ^ 2 * api.density qFull / tau

/--
Proposition 3 first-moment formula suggested by the upper-tail Owen
calculation.

The source's displayed `lambda` formula has the `- Phi(shifted)` part of the
first boundary term.  The upper-tail integration-by-parts form instead has
`1 - Phi(shifted)`.  The theorem below records the exact missing boundary
term, so later integral work can target the mathematically precise endpoint
rather than hiding the discrepancy inside a certificate.
-/
def glm20Proposition3LambdaOwenFirstMomentFormula
    (api : StandardGaussianCDFAPI)
    (a b sigmaTilde tau mu qFull : ℝ) : ℝ :=
  let denom := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let A := (a + b * mu) / denom
  let shifted :=
    qFull * denom + b * sigmaTilde * (a + b * mu) / denom
  mu +
    sigmaTilde ^ 2 * b / (tau * denom) * api.density A *
      (1 - api.cdf shifted) +
    api.cdf (a + b * mu + b * sigmaTilde * qFull) *
      sigmaTilde ^ 2 * api.density qFull / tau

/--
Exact algebraic difference between the source-displayed `lambda` formula and
the upper-tail first-moment/Owen expression.

Thus the two coincide only when the displayed boundary term
`sigmaTilde^2 * b * phi(A) / (tau * sqrt(1+sigmaTilde^2 b^2))` vanishes.
-/
theorem glm20Proposition3LambdaOwenFirstMomentFormula_eq_lambdaFormula_add_boundaryTerm
    (api : StandardGaussianCDFAPI)
    (a b sigmaTilde tau mu qFull : ℝ) :
    glm20Proposition3LambdaOwenFirstMomentFormula api
        a b sigmaTilde tau mu qFull =
      glm20Proposition3LambdaFormula api a b sigmaTilde tau mu qFull +
        (let denom := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
         let A := (a + b * mu) / denom
         sigmaTilde ^ 2 * b / (tau * denom) * api.density A) := by
  simp [glm20Proposition3LambdaOwenFirstMomentFormula,
    glm20Proposition3LambdaFormula]
  ring

/--
The source-displayed and upper-tail first-moment `lambda` formulas agree when
the affine application boundary has zero slope in the admitted score.
-/
theorem glm20Proposition3LambdaFormula_eq_owenFirstMomentFormula_of_slope_zero
    (api : StandardGaussianCDFAPI)
    (a sigmaTilde tau mu qFull : ℝ) :
    glm20Proposition3LambdaFormula api a 0 sigmaTilde tau mu qFull =
      glm20Proposition3LambdaOwenFirstMomentFormula api
        a 0 sigmaTilde tau mu qFull := by
  rw [glm20Proposition3LambdaOwenFirstMomentFormula_eq_lambdaFormula_add_boundaryTerm]
  simp

/--
Audit theorem for Proposition 3: with the mathlib-backed standard Gaussian
density, the source-displayed `lambda` formula and the upper-tail
first-moment formula are genuinely different whenever the boundary coefficient
is nonzero.  In particular, nonzero `sigmaTilde`, nonzero slope `b`, and
nonzero `tau` force a nonzero missing boundary term.
-/
theorem glm20Proposition3LambdaFormula_ne_owenFirstMomentFormula_of_nonzero_slope
    {a b sigmaTilde tau mu qFull : ℝ}
    (hsigma : sigmaTilde ≠ 0) (hb : b ≠ 0) (htau : tau ≠ 0) :
    glm20Proposition3LambdaFormula standardGaussianCDFAPI
        a b sigmaTilde tau mu qFull ≠
      glm20Proposition3LambdaOwenFirstMomentFormula standardGaussianCDFAPI
        a b sigmaTilde tau mu qFull := by
  let denom := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let A := (a + b * mu) / denom
  have hdenom_pos : 0 < denom := by
    have hnonneg : 0 ≤ sigmaTilde ^ 2 * b ^ 2 := mul_nonneg (sq_nonneg _) (sq_nonneg _)
    exact Real.sqrt_pos.2 (by linarith)
  have hdenom_ne : denom ≠ 0 := ne_of_gt hdenom_pos
  have hdensity_ne : standardGaussianCDFAPI.density A ≠ 0 :=
    ne_of_gt (standardGaussianDensity_pos A)
  have hboundary_ne :
      sigmaTilde ^ 2 * b / (tau * denom) *
          standardGaussianCDFAPI.density A ≠ 0 :=
    mul_ne_zero
      (div_ne_zero (mul_ne_zero (pow_ne_zero 2 hsigma) hb)
        (mul_ne_zero htau hdenom_ne))
      hdensity_ne
  intro hEq
  have hdiff :=
    glm20Proposition3LambdaOwenFirstMomentFormula_eq_lambdaFormula_add_boundaryTerm
      standardGaussianCDFAPI a b sigmaTilde tau mu qFull
  change
      glm20Proposition3LambdaOwenFirstMomentFormula standardGaussianCDFAPI
          a b sigmaTilde tau mu qFull =
        glm20Proposition3LambdaFormula standardGaussianCDFAPI
            a b sigmaTilde tau mu qFull +
          (sigmaTilde ^ 2 * b / (tau * denom) *
            standardGaussianCDFAPI.density A) at hdiff
  rw [← hEq] at hdiff
  have hzero :
      sigmaTilde ^ 2 * b / (tau * denom) *
          standardGaussianCDFAPI.density A = 0 := by
    linarith
  exact hboundary_ne hzero

/--
Proposition 3 upper-tail product integral in the first-moment calculation.

With `c_g = sigma_tilde_g b_g`, `D_g = sqrt(1+c_g^2)`, and
`A_g = (a_g + b_g mu_g)/D_g`, this is the Gaussian density product that appears
after differentiating the affine application CDF in the integration-by-parts
proof of the admitted academic-merit formula.
-/
def glm20Proposition3OwenFirstMomentProductTailIntegral
    (a b sigmaTilde mu qFull : ℝ) : ℝ :=
  let c := sigmaTilde * b
  let denom := Real.sqrt (1 + c ^ 2)
  let A := (a + b * mu) / denom
  ∫ z in Set.Ioi qFull,
    standardGaussianDensity z *
      standardGaussianDensity (A * denom + c * z)

/--
Verified Gaussian product-tail identity for the Proposition 3 first-moment
calculation.

This is the reusable analytic sub-identity behind the upper-tail
integration-by-parts expression.  It supplies the `phi(A_g) *
(1-Phi(shifted_g))/D_g` term that creates the boundary-term discrepancy with
the source-displayed `lambda` formula.
-/
theorem glm20Proposition3OwenFirstMomentProductTailIntegral_eq
    (a b sigmaTilde mu qFull : ℝ) :
    glm20Proposition3OwenFirstMomentProductTailIntegral
        a b sigmaTilde mu qFull =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity A * denom⁻¹ *
         (1 - standardGaussianCDF (denom * qFull + A * c))) := by
  simpa [glm20Proposition3OwenFirstMomentProductTailIntegral] using
    standardGaussianDensity_mul_affine_integral_Ioi
      (sigmaTilde * b)
      ((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2))
      qFull

/--
Proposition 3 upper-tail first moment before simplification.

This is the normalized standard-Gaussian integral
`∫_{q_full}^{∞} z phi(z) Phi(A_g D_g + c_g z) dz` that the paper evaluates
by integration by parts in the admitted academic-merit formula.
-/
def glm20Proposition3OwenFirstMomentIntegral
    (a b sigmaTilde mu qFull : ℝ) : ℝ :=
  let c := sigmaTilde * b
  let denom := Real.sqrt (1 + c ^ 2)
  let A := (a + b * mu) / denom
  ∫ z in Set.Ioi qFull,
    z * standardGaussianDensity z *
      standardGaussianCDF (A * denom + c * z)

/--
Verified integration-by-parts formula for the Proposition 3 first-moment
integral, conditional only on the standard integrability premises for the two
integration-by-parts terms.
-/
theorem glm20Proposition3OwenFirstMomentIntegral_eq_of_integrable
    (a b sigmaTilde mu qFull : ℝ)
    (hleft :
      let c := sigmaTilde * b
      let denom := Real.sqrt (1 + c ^ 2)
      let A := (a + b * mu) / denom
      IntegrableOn
        ((fun z : ℝ => standardGaussianCDF (A * denom + c * z)) *
          (fun z : ℝ => -z * standardGaussianDensity z))
        (Set.Ioi qFull))
    (hprod :
      let c := sigmaTilde * b
      let denom := Real.sqrt (1 + c ^ 2)
      let A := (a + b * mu) / denom
      IntegrableOn
        ((fun z : ℝ => c * standardGaussianDensity (A * denom + c * z)) *
          standardGaussianDensity)
        (Set.Ioi qFull)) :
    glm20Proposition3OwenFirstMomentIntegral
        a b sigmaTilde mu qFull =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity qFull *
           standardGaussianCDF (A * denom + c * qFull) +
         c * (standardGaussianDensity A * denom⁻¹ *
          (1 - standardGaussianCDF (denom * qFull + A * c)))) := by
  simp only [glm20Proposition3OwenFirstMomentIntegral]
  rw [standardGaussian_firstMoment_affineCDF_integral_Ioi_of_integrable
    (((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2)) *
      Real.sqrt (1 + (sigmaTilde * b) ^ 2))
    (sigmaTilde * b) qFull hleft hprod]
  rw [standardGaussianDensity_mul_affine_integral_Ioi]

/--
Verified integration-by-parts formula for the Proposition 3 first-moment
integral.  The Gaussian product-density integrability premise is discharged in
`EconCSLib`; only the first-moment integrability term remains explicit.
-/
theorem glm20Proposition3OwenFirstMomentIntegral_eq_of_left_integrable
    (a b sigmaTilde mu qFull : ℝ)
    (hleft :
      let c := sigmaTilde * b
      let denom := Real.sqrt (1 + c ^ 2)
      let A := (a + b * mu) / denom
      IntegrableOn
        ((fun z : ℝ => standardGaussianCDF (A * denom + c * z)) *
          (fun z : ℝ => -z * standardGaussianDensity z))
        (Set.Ioi qFull)) :
    glm20Proposition3OwenFirstMomentIntegral
        a b sigmaTilde mu qFull =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity qFull *
           standardGaussianCDF (A * denom + c * qFull) +
         c * (standardGaussianDensity A * denom⁻¹ *
           (1 - standardGaussianCDF (denom * qFull + A * c)))) := by
  simp only [glm20Proposition3OwenFirstMomentIntegral]
  rw [standardGaussian_firstMoment_affineCDF_integral_Ioi_of_left_integrable
    (((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2)) *
      Real.sqrt (1 + (sigmaTilde * b) ^ 2))
    (sigmaTilde * b) qFull hleft]
  rw [standardGaussianDensity_mul_affine_integral_Ioi]

/--
Verified integration-by-parts formula for the Proposition 3 first-moment
integral with all Gaussian integrability obligations discharged.
-/
theorem glm20Proposition3OwenFirstMomentIntegral_eq
    (a b sigmaTilde mu qFull : ℝ) :
    glm20Proposition3OwenFirstMomentIntegral
        a b sigmaTilde mu qFull =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity qFull *
           standardGaussianCDF (A * denom + c * qFull) +
         c * (standardGaussianDensity A * denom⁻¹ *
           (1 - standardGaussianCDF (denom * qFull + A * c)))) := by
  simp only [glm20Proposition3OwenFirstMomentIntegral]
  rw [standardGaussian_firstMoment_affineCDF_integral_Ioi
    (((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2)) *
      Real.sqrt (1 + (sigmaTilde * b) ^ 2))
    (sigmaTilde * b) qFull]
  rw [standardGaussianDensity_mul_affine_integral_Ioi]

/--
Proposition 3 normalized admitted academic merit from the standardized
upper-tail first moment.

This is the direct conditional-expectation shape after standardizing the
full-policy admitted score: the raw mean contributes `mu`, and the centered
first moment is scaled by `sigmaTilde / tau`.
-/
def glm20Proposition3OwenStandardizedAdmittedAcademicMerit
    (a b sigmaTilde tau mu qFull : ℝ) : ℝ :=
  mu + sigmaTilde / tau *
    glm20Proposition3OwenFirstMomentIntegral a b sigmaTilde mu qFull

/--
Proposition 3 scale bookkeeping for the first-moment route.

The standardized upper-tail first-moment expression agrees with the verified
`lambda`/Owen formula up to the displayed density-boundary rescaling term.
This isolates the remaining source-identification issue: a model-side proof
can close the `lambda` premise directly when this residual term vanishes, or
can use the theorem as the exact correction otherwise.
-/
theorem
    glm20Proposition3LambdaOwenFirstMomentFormula_eq_standardizedAdmittedAcademicMerit_add_densityScaleCorrection
    (a b sigmaTilde tau mu qFull : ℝ) :
    glm20Proposition3LambdaOwenFirstMomentFormula standardGaussianCDFAPI
        a b sigmaTilde tau mu qFull =
      glm20Proposition3OwenStandardizedAdmittedAcademicMerit
          a b sigmaTilde tau mu qFull +
        ((sigmaTilde ^ 2 - sigmaTilde) / tau) *
          standardGaussianDensity qFull *
          standardGaussianCDF (a + b * mu + b * sigmaTilde * qFull) := by
  let c : ℝ := sigmaTilde * b
  let denom : ℝ := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let A : ℝ := (a + b * mu) / denom
  have hdenom_pos : 0 < denom :=
    Real.sqrt_pos.2
      (by nlinarith [mul_nonneg (sq_nonneg sigmaTilde) (sq_nonneg b)])
  have hdenom_ne : denom ≠ 0 := ne_of_gt hdenom_pos
  have hAdenom : A * denom = a + b * mu := by
    change ((a + b * mu) / denom) * denom = a + b * mu
    field_simp [hdenom_ne]
  have hboundary :
      standardGaussianCDF (A * denom + c * qFull) =
        standardGaussianCDF (a + b * mu + b * sigmaTilde * qFull) := by
    congr 1
    rw [hAdenom]
    change a + b * mu + (sigmaTilde * b) * qFull =
      a + b * mu + b * sigmaTilde * qFull
    ring_nf
  have hshift :
      standardGaussianCDF (denom * qFull + A * c) =
        standardGaussianCDF
          (qFull * denom + b * sigmaTilde * (a + b * mu) / denom) := by
    congr 1
    rw [mul_comm denom qFull]
    have hc : A * c = b * sigmaTilde * (a + b * mu) / denom := by
      change ((a + b * mu) / denom) * (sigmaTilde * b) =
        b * sigmaTilde * (a + b * mu) / denom
      field_simp [hdenom_ne]
    rw [hc]
  rw [glm20Proposition3OwenStandardizedAdmittedAcademicMerit,
    glm20Proposition3OwenFirstMomentIntegral_eq,
    glm20Proposition3LambdaOwenFirstMomentFormula]
  simp only [standardGaussianCDFAPI]
  simp only [mul_pow]
  rw [← hboundary, ← hshift]
  have hboundary_std :
      standardGaussianCDF
          ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2) *
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2) +
            sigmaTilde * b * qFull) =
        standardGaussianCDF (A * denom + c * qFull) := by
    rfl
  have hshift_std :
      standardGaussianCDF
          (Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2) * qFull +
            (a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2) *
              (sigmaTilde * b)) =
        standardGaussianCDF (denom * qFull + A * c) := by
    rfl
  rw [hboundary_std]
  rw [hshift_std]
  ring_nf

/--
Unit-scale corollary of the Proposition 3 first-moment bridge.

When the standardized admitted-score scale is one, the normalized upper-tail
first moment exactly matches the verified `lambda`/Owen formula.
-/
theorem
    glm20Proposition3LambdaOwenFirstMomentFormula_eq_standardizedAdmittedAcademicMerit_of_unit_scale
    (a b tau mu qFull : ℝ) :
    glm20Proposition3LambdaOwenFirstMomentFormula standardGaussianCDFAPI
        a b 1 tau mu qFull =
      glm20Proposition3OwenStandardizedAdmittedAcademicMerit
        a b 1 tau mu qFull := by
  rw [
    glm20Proposition3LambdaOwenFirstMomentFormula_eq_standardizedAdmittedAcademicMerit_add_densityScaleCorrection]
  simp

/--
Proposition 2/Appendix D.6 finite-interval first moment.

This is the interval analogue of the Proposition 3 upper-tail first moment and
is the reusable analytic piece for the displayed `kappa` merit formula: later
model-specific work can identify the relevant enrollment region with a finite
interval in the standardized source-affine variable, then use this theorem by
subtraction of two upper tails.
-/
def glm20Proposition2OwenFirstMomentInterval
    (a b sigmaTilde mu lower upper : ℝ) : ℝ :=
  let c := sigmaTilde * b
  let denom := Real.sqrt (1 + c ^ 2)
  let A := (a + b * mu) / denom
  ∫ z in lower..upper,
    z * standardGaussianDensity z *
      standardGaussianCDF (A * denom + c * z)

/--
Proposition 2/Appendix D.6 finite-interval product-density term for the same
source-affine normal integrand.
-/
def glm20Proposition2OwenProductInterval
    (a b sigmaTilde mu lower upper : ℝ) : ℝ :=
  let c := sigmaTilde * b
  let denom := Real.sqrt (1 + c ^ 2)
  let A := (a + b * mu) / denom
  ∫ z in lower..upper,
    standardGaussianDensity z *
      standardGaussianDensity (A * denom + c * z)

/--
Verified finite-interval product-density identity for the source-affine normal
integrand.
-/
theorem glm20Proposition2OwenProductInterval_eq
    (a b sigmaTilde mu lower upper : ℝ) (hlower_upper : lower ≤ upper) :
    glm20Proposition2OwenProductInterval
        a b sigmaTilde mu lower upper =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity A * denom⁻¹ *
        (standardGaussianCDF (denom * upper + A * c) -
          standardGaussianCDF (denom * lower + A * c))) := by
  simpa [glm20Proposition2OwenProductInterval] using
    standardGaussianDensity_mul_affine_integral_interval
      (sigmaTilde * b)
      ((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2))
      lower upper hlower_upper

/--
Verified finite-interval first-moment identity for the source-affine normal
integrand, obtained by subtracting the two proved upper-tail identities.
-/
theorem glm20Proposition2OwenFirstMomentInterval_eq
    (a b sigmaTilde mu lower upper : ℝ) (hlower_upper : lower ≤ upper) :
    glm20Proposition2OwenFirstMomentInterval
        a b sigmaTilde mu lower upper =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity lower *
           standardGaussianCDF (A * denom + c * lower) +
         c * (standardGaussianDensity A * denom⁻¹ *
           (1 - standardGaussianCDF (denom * lower + A * c)))) -
        (let c := sigmaTilde * b
         let denom := Real.sqrt (1 + c ^ 2)
         let A := (a + b * mu) / denom
         standardGaussianDensity upper *
             standardGaussianCDF (A * denom + c * upper) +
           c * (standardGaussianDensity A * denom⁻¹ *
             (1 - standardGaussianCDF (denom * upper + A * c)))) := by
  simpa [glm20Proposition2OwenFirstMomentInterval] using
    standardGaussian_firstMoment_affineCDF_integral_interval
      ((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2))
      (sigmaTilde * b) lower upper hlower_upper

/--
Proposition 2/Appendix D.6 lower-tail product-density term for the source
affine normal integrand.

This is the direct lower-tail form of the Owen identity used in the displayed
`kappa` formula.
-/
def glm20Proposition2OwenProductLowerTail
    (a b sigmaTilde mu upper : ℝ) : ℝ :=
  let c := sigmaTilde * b
  let denom := Real.sqrt (1 + c ^ 2)
  let A := (a + b * mu) / denom
  ∫ z in Set.Iic upper,
    standardGaussianDensity z *
      standardGaussianDensity (A * denom + c * z)

/--
Proposition 2/Appendix D.6 lower-tail selection mass before simplification.

This is the standardized mass
`∫_{-∞}^{upper} phi(z) Phi(A_g D_g + c_g z) dz` of students above the
test-free cutoff and below the `J1` full-test cutoff.  It is distinct from
`glm20Proposition2OwenProductLowerTail`, which is the product-density term
created by the integration-by-parts calculation.
-/
def glm20Proposition2OwenSelectionLowerTail
    (a b sigmaTilde mu upper : ℝ) : ℝ :=
  let c := sigmaTilde * b
  let denom := Real.sqrt (1 + c ^ 2)
  let A := (a + b * mu) / denom
  ∫ z in Set.Iic upper,
    standardGaussianDensity z *
      standardGaussianCDF (A * denom + c * z)

/--
The outer standard-Gaussian measure in the Proposition 2(iv) lower selection
integral can be rewritten against the standard density.
-/
theorem glm20Proposition2OwenSelectionLowerTail_eq_standardGaussianIntegral
    (a b sigmaTilde mu upper : ℝ) :
    glm20Proposition2OwenSelectionLowerTail a b sigmaTilde mu upper =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       ∫ z in Set.Iic upper,
         standardGaussianCDF (A * denom + c * z)
           ∂standardGaussianMeasure) := by
  let c : ℝ := sigmaTilde * b
  let denom : ℝ := Real.sqrt (1 + c ^ 2)
  let A : ℝ := (a + b * mu) / denom
  rw [glm20Proposition2OwenSelectionLowerTail]
  change
      (∫ z in Set.Iic upper,
        standardGaussianDensity z *
          standardGaussianCDF (A * denom + c * z)) =
        ∫ z in Set.Iic upper,
          standardGaussianCDF (A * denom + c * z)
            ∂standardGaussianMeasure
  have hgauss :
      (∫ z,
          (Set.Iic upper).indicator
            (fun z : ℝ => standardGaussianCDF (A * denom + c * z)) z
          ∂(ProbabilityTheory.gaussianReal (0 : ℝ) (1 : ℝ≥0))) =
        ∫ z,
          ProbabilityTheory.gaussianPDFReal (0 : ℝ) (1 : ℝ≥0) z •
            (Set.Iic upper).indicator
              (fun z : ℝ => standardGaussianCDF (A * denom + c * z)) z :=
          ProbabilityTheory.integral_gaussianReal_eq_integral_smul
        (E := ℝ) (μ := (0 : ℝ)) (v := (1 : ℝ≥0))
        (f := Set.indicator (Set.Iic upper)
          (fun z : ℝ => standardGaussianCDF (A * denom + c * z)))
        (by norm_num : (1 : ℝ≥0) ≠ 0)
  conv_rhs =>
    rw [← MeasureTheory.integral_indicator measurableSet_Iic]
    rw [standardGaussianMeasure]
    rw [hgauss]
  rw [← MeasureTheory.integral_indicator measurableSet_Iic]
  simp only [standardGaussianDensity]
  exact MeasureTheory.integral_congr_ae
    (Filter.Eventually.of_forall fun z => by
      by_cases hz : z ∈ Set.Iic upper
      · simp [Set.indicator_of_mem hz, mul_comm]
      · simp [Set.indicator_of_notMem hz])

/--
Proposition 2(iv) integral/event bridge for the lower-tail selection mass.

If `upper` is the standardized full-test cutoff `(qFull - mu) / sigmaTilde`,
then the normalized lower-tail selection integral is exactly the affine source
event mass used for the `J2` academic-merit calculation.
-/
theorem glm20Proposition2OwenSelectionLowerTail_eq_owenAffineLowerSelectionMass
    {a b sigmaTilde mu upper qFull : ℝ}
    (hupper : upper = (qFull - mu) / sigmaTilde) :
    glm20Proposition2OwenSelectionLowerTail a b sigmaTilde mu upper =
      glm20Proposition2OwenAffineLowerSelectionMass
        sigmaTilde a b mu qFull := by
  rw [glm20Proposition2OwenSelectionLowerTail_eq_standardGaussianIntegral]
  rw [glm20Proposition2OwenAffineLowerSelectionMass_eq_standardGaussianIntegral]
  simp [hupper, mul_comm]

/--
Proposition 2(iv) lower-tail selection integral equals the concrete bivariate
lower-left rectangle after the full-test cutoff is standardized.
-/
theorem glm20Proposition2OwenSelectionLowerTail_eq_correlatedStandardGaussian_lowerLeftRectangleMass
    {a b sigmaTilde mu upper qFull : ℝ}
    (hupper : upper = (qFull - mu) / sigmaTilde) :
    glm20Proposition2OwenSelectionLowerTail a b sigmaTilde mu upper =
      lowerLeftRectangleMass
        (correlatedStandardGaussianLaw
          (-(sigmaTilde * b) /
            Real.sqrt (1 + (sigmaTilde * b) ^ 2)))
        ((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2))
        ((qFull - mu) / sigmaTilde) := by
  rw [glm20Proposition2OwenSelectionLowerTail_eq_owenAffineLowerSelectionMass
    hupper]
  exact
    glm20Proposition2OwenAffineLowerSelectionMass_eq_correlatedStandardGaussian_lowerLeftRectangleMass
      sigmaTilde a b mu qFull

/--
Proposition 2(iv) source tau normalization for the lower-tail selection mass.

After substituting the paper's displayed `a'_g(q)` and `b'_g` definitions, the
standardized Owen lower-tail selection mass is exactly the complement of the
source `tau_g` normalization.
-/
theorem glm20Proposition2OwenSelectionLowerTail_eq_one_sub_kappaSourceTau
    {priorPrecision subPrecisionSum sigmaTilde mu upper qFull q2Sub : ℝ}
    (hsub : 0 < subPrecisionSum)
    (hupper : upper = (qFull - mu) / sigmaTilde) :
    glm20Proposition2OwenSelectionLowerTail
        (glm20Proposition2KappaAPrime
          priorPrecision subPrecisionSum mu q2Sub)
        (glm20Proposition2KappaBPrime subPrecisionSum)
        sigmaTilde mu upper =
      1 -
        glm20Proposition2KappaSourceTau
          priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull := by
  rw [glm20Proposition2OwenSelectionLowerTail_eq_correlatedStandardGaussian_lowerLeftRectangleMass
    hupper]
  rw [glm20Proposition2KappaSourceTau]
  rw [glm20Proposition2KappaSourceLowerLeftMass_eq_sourcePrimes hsub]
  ring

/--
Proposition 2(iv) source-parameter tau normalization.

This is the same lower-tail selection-mass identity as
`glm20Proposition2OwenSelectionLowerTail_eq_one_sub_kappaSourceTau`, with the
paper's displayed `\tilde\sigma_g` source definition and raw full-test cutoff
substituted directly.
-/
theorem glm20Proposition2OwenSelectionLowerTail_eq_one_sub_kappaSourceTau_sourceParameters
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum
      mu qFull q2Sub : ℝ}
    (hsub : 0 < subPrecisionSum) :
    glm20Proposition2OwenSelectionLowerTail
        (glm20Proposition2KappaAPrime
          priorPrecision subPrecisionSum mu q2Sub)
        (glm20Proposition2KappaBPrime subPrecisionSum)
        (glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum)
        mu
        ((qFull - mu) /
          glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum) =
      1 -
        glm20Proposition2KappaSourceTau
          priorPrecision subPrecisionSum
          (glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum)
          mu q2Sub qFull :=
  glm20Proposition2OwenSelectionLowerTail_eq_one_sub_kappaSourceTau
    hsub rfl

/--
Verified lower-tail product-density identity for the source-affine normal
integrand in the Proposition 2 `kappa` route.
-/
theorem glm20Proposition2OwenProductLowerTail_eq
    (a b sigmaTilde mu upper : ℝ) :
    glm20Proposition2OwenProductLowerTail
        a b sigmaTilde mu upper =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity A * denom⁻¹ *
        standardGaussianCDF (denom * upper + A * c)) := by
  simpa [glm20Proposition2OwenProductLowerTail] using
    standardGaussianDensity_mul_affine_integral_Iic
      (sigmaTilde * b)
      ((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2))
      upper

/--
Proposition 2/Appendix D.6 lower-tail first moment before simplification.

This is the normalized standard-Gaussian integral
`∫_{-∞}^{upper} z phi(z) Phi(A_g D_g + c_g z) dz` in the `kappa`
calculation.
-/
def glm20Proposition2OwenFirstMomentLowerTail
    (a b sigmaTilde mu upper : ℝ) : ℝ :=
  let c := sigmaTilde * b
  let denom := Real.sqrt (1 + c ^ 2)
  let A := (a + b * mu) / denom
  ∫ z in Set.Iic upper,
    z * standardGaussianDensity z *
      standardGaussianCDF (A * denom + c * z)

/--
Verified lower-tail first-moment identity for the source-affine normal
integrand in the Proposition 2 `kappa` route.
-/
theorem glm20Proposition2OwenFirstMomentLowerTail_eq
    (a b sigmaTilde mu upper : ℝ) :
    glm20Proposition2OwenFirstMomentLowerTail
        a b sigmaTilde mu upper =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       c * (standardGaussianDensity A * denom⁻¹ *
          standardGaussianCDF (denom * upper + A * c)) -
        standardGaussianDensity upper *
          standardGaussianCDF (A * denom + c * upper)) := by
  simp only [glm20Proposition2OwenFirstMomentLowerTail]
  rw [standardGaussian_firstMoment_affineCDF_integral_Iic
    (((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2)) *
      Real.sqrt (1 + (sigmaTilde * b) ^ 2))
    (sigmaTilde * b) upper]
  rw [standardGaussianDensity_mul_affine_integral_Iic]

/--
Proposition 2(iv) standardized J2 merit expression before substituting
Owen's closed form.

After changing variables in the paper's raw Gaussian integral, the numerator is
`mu` times the lower-tail selection mass plus `sigmaTilde` times the lower-tail
first moment.
-/
def glm20Proposition2J2MeritStandardizedLowerTailFormula
    (a b sigmaTilde tau mu upper : ℝ) : ℝ :=
    sigmaTilde / tau *
      glm20Proposition2OwenFirstMomentLowerTail
        a b sigmaTilde mu upper +
    mu / tau *
      glm20Proposition2OwenSelectionLowerTail
        a b sigmaTilde mu upper

/--
If the lower-tail source mass is `1 - tau`, the standardized J2 merit formula
has the paper's `mu * (1 - tau) / tau` term plus the scaled first moment.
-/
theorem glm20Proposition2J2MeritStandardizedLowerTailFormula_eq_scaledFirstMoment_of_mass
    {a b sigmaTilde tau mu upper : ℝ}
    (hmass :
      glm20Proposition2OwenSelectionLowerTail a b sigmaTilde mu upper =
        1 - tau) :
    glm20Proposition2J2MeritStandardizedLowerTailFormula
        a b sigmaTilde tau mu upper =
      sigmaTilde / tau *
        glm20Proposition2OwenFirstMomentLowerTail
          a b sigmaTilde mu upper +
        mu * (1 - tau) / tau := by
  rw [glm20Proposition2J2MeritStandardizedLowerTailFormula, hmass]
  ring

/--
Source-scaling bridge for Proposition 2's displayed `kappa` expression.

After standardizing the source variable, the J2 merit integral has the shape
`mu * (1 - tau) / tau + sigmaTilde / tau` times the lower-tail Owen first
moment.  The paper's displayed boundary term uses the source density at the
unstandardized cutoff; the premise below is exactly the density-scaling
identification needed to rewrite that boundary term against the standardized
Gaussian density at `upper`.
-/
theorem glm20Proposition2KappaFormula_eq_scaled_owenFirstMomentLowerTail_of_boundary_density
    {a b sigmaTilde tau mu upper q : ℝ}
    (hboundary_density :
      standardGaussianDensity upper =
        sigmaTilde * standardGaussianDensity q) :
    glm20Proposition2KappaFormula standardGaussianCDFAPI
        a b sigmaTilde tau mu upper q =
      sigmaTilde / tau *
        glm20Proposition2OwenFirstMomentLowerTail
          a b sigmaTilde mu upper +
        mu * (1 - tau) / tau := by
  let c : ℝ := sigmaTilde * b
  let denom : ℝ := Real.sqrt (1 + c ^ 2)
  let A : ℝ := (a + b * mu) / denom
  have hdenom_pos : 0 < denom := by
    dsimp [denom]
    positivity
  have hdenom_ne : denom ≠ 0 := ne_of_gt hdenom_pos
  have hsq : sigmaTilde ^ 2 * b ^ 2 = (sigmaTilde * b) ^ 2 := by
    ring
  have hshift :
      upper * denom + b * sigmaTilde * (a + b * mu) / denom =
        denom * upper + A * c := by
    dsimp [A, c]
    ring
  have hboundary_arg :
      a + b * mu + b * sigmaTilde * upper =
        A * denom + c * upper := by
    dsimp [A, c]
    field_simp [hdenom_ne]
  rw [glm20Proposition2OwenFirstMomentLowerTail_eq]
  simp only [glm20Proposition2KappaFormula, standardGaussianCDFAPI]
  simp only [c, denom, A] at hshift hboundary_arg
  rw [hsq]
  rw [hshift, hboundary_arg, hboundary_density]
  ring

/--
Source-density version of the `kappa`/lower-tail bridge.

This is the preferred statement when the source proof supplies a raw
location-scale Gaussian density at the boundary rather than an already
standardized density argument.
-/
theorem glm20Proposition2KappaBoundaryDensityFormula_eq_scaled_owenFirstMomentLowerTail
    {a b sigmaTilde tau mu upper boundaryDensity : ℝ}
    (hboundary_density :
      standardGaussianDensity upper = sigmaTilde * boundaryDensity) :
    glm20Proposition2KappaBoundaryDensityFormula standardGaussianCDFAPI
        a b sigmaTilde tau mu upper boundaryDensity =
      sigmaTilde / tau *
        glm20Proposition2OwenFirstMomentLowerTail
          a b sigmaTilde mu upper +
        mu * (1 - tau) / tau := by
  let c : ℝ := sigmaTilde * b
  let denom : ℝ := Real.sqrt (1 + c ^ 2)
  let A : ℝ := (a + b * mu) / denom
  have hdenom_pos : 0 < denom := by
    dsimp [denom]
    positivity
  have hdenom_ne : denom ≠ 0 := ne_of_gt hdenom_pos
  have hsq : sigmaTilde ^ 2 * b ^ 2 = (sigmaTilde * b) ^ 2 := by
    ring
  have hshift :
      upper * denom + b * sigmaTilde * (a + b * mu) / denom =
        denom * upper + A * c := by
    dsimp [A, c]
    ring
  have hboundary_arg :
      a + b * mu + b * sigmaTilde * upper =
        A * denom + c * upper := by
    dsimp [A, c]
    field_simp [hdenom_ne]
  rw [glm20Proposition2OwenFirstMomentLowerTail_eq]
  simp only [glm20Proposition2KappaBoundaryDensityFormula,
    standardGaussianCDFAPI]
  simp only [c, denom, A] at hshift hboundary_arg
  rw [hsq]
  rw [hshift, hboundary_arg, hboundary_density]
  ring

/-- Raw location-scale Gaussian density supplies the source boundary-density
scaling used by the `kappa` bridge. -/
theorem glm20Proposition2_boundaryDensityScaling_of_normalDensity
    {mu sigmaTilde raw upper : ℝ} (hsigma : 0 < sigmaTilde)
    (hupper : upper = (raw - mu) / sigmaTilde) :
    standardGaussianDensity upper =
      sigmaTilde *
        standardGaussianCDFAPI.normalDensity
          { mean := mu, scale := sigmaTilde, scale_pos := hsigma } raw := by
  let L : GaussianScaleLaw :=
    { mean := mu, scale := sigmaTilde, scale_pos := hsigma }
  have hscale :=
    standardGaussianCDFAPI.scale_mul_normalDensity L raw
  have hstd : L.standardize raw = upper := by
    simp [L, GaussianScaleLaw.standardize, hupper]
  change standardGaussianCDFAPI.density upper =
    sigmaTilde * standardGaussianCDFAPI.normalDensity L raw
  rw [← hstd, ← hscale]

/--
Proposition 2(iv) J2 merit-to-`kappa` bridge.

This is the paper's Appendix D.6 simplification in source-shaped form: once the
lower-tail mass is the complement of `tau` and the boundary density is
identified with the source density, the standardized J2 merit expression is
exactly the source-density `kappa` formula.
-/
theorem glm20Proposition2J2MeritStandardizedLowerTailFormula_eq_kappaBoundaryDensityFormula
    {a b sigmaTilde tau mu upper boundaryDensity : ℝ}
    (hmass :
      glm20Proposition2OwenSelectionLowerTail a b sigmaTilde mu upper =
        1 - tau)
    (hboundary_density :
      standardGaussianDensity upper = sigmaTilde * boundaryDensity) :
    glm20Proposition2J2MeritStandardizedLowerTailFormula
        a b sigmaTilde tau mu upper =
      glm20Proposition2KappaBoundaryDensityFormula standardGaussianCDFAPI
        a b sigmaTilde tau mu upper boundaryDensity :=
  (glm20Proposition2J2MeritStandardizedLowerTailFormula_eq_scaledFirstMoment_of_mass
      hmass).trans
    (glm20Proposition2KappaBoundaryDensityFormula_eq_scaled_owenFirstMomentLowerTail
      hboundary_density).symm

/--
Source-normalized version of the Proposition 2(iv) J2 merit-to-`kappa`
bridge.

Instead of assuming the lower-tail mass identity directly, this version uses
the paper-shaped normalization `tau = 1 - Phi_2(...)` after the full-test
cutoff is standardized.
-/
theorem glm20Proposition2J2MeritStandardizedLowerTailFormula_eq_kappaBoundaryDensityFormula_of_tau_lowerLeftRectangle
    {a b sigmaTilde tau mu upper qFull boundaryDensity : ℝ}
    (hupper : upper = (qFull - mu) / sigmaTilde)
    (htau :
      tau =
        1 -
