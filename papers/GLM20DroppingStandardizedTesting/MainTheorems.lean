/--
Proposition 2(iv) source definition of `a'_g(q)`.

Paper statement:
`a'_g(q) =
  (mu * sigma^{-2} - q * (sigma^{-2} + sum_{k in sub} sigma_gk^{-2})) /
    sqrt(sum_{k in sub} sigma_gk^{-2})`.
-/
def glm20Proposition2KappaAPrime
    (priorPrecision subPrecisionSum mu q : ℝ) : ℝ :=
  (mu * priorPrecision - q * (priorPrecision + subPrecisionSum)) /
    Real.sqrt subPrecisionSum

/--
Proposition 2(iv) source definition of `b'_g`.

Paper statement:
`b'_g = sqrt(sum_{k in sub} sigma_gk^{-2})`.
-/
def glm20Proposition2KappaBPrime
    (subPrecisionSum : ℝ) : ℝ := Real.sqrt subPrecisionSum

/--
Source-prime algebra for Proposition 2(iv): the paper's `b'_g` squared is
the sub-test precision sum.
-/
theorem glm20Proposition2KappaBPrime_sq
    {subPrecisionSum : ℝ} (hsub : 0 ≤ subPrecisionSum) :
    glm20Proposition2KappaBPrime subPrecisionSum ^ 2 =
      subPrecisionSum := by
  simp [glm20Proposition2KappaBPrime, Real.sq_sqrt hsub]

/--
Source-prime denominator algebra for Proposition 2(iv).

This rewrites `sqrt(1 + (sigma_tilde_g b'_g)^2)` into the expression with the
raw sub-test precision sum.
-/
theorem glm20Proposition2KappaSourceDenom_eq
    {sigmaTilde subPrecisionSum : ℝ} (hsub : 0 ≤ subPrecisionSum) :
    Real.sqrt
        (1 +
          (sigmaTilde *
            glm20Proposition2KappaBPrime subPrecisionSum) ^ 2) =
      Real.sqrt (1 + sigmaTilde ^ 2 * subPrecisionSum) := by
  have hsq :
      (sigmaTilde *
          glm20Proposition2KappaBPrime subPrecisionSum) ^ 2 =
        sigmaTilde ^ 2 * subPrecisionSum := by
    rw [mul_pow, glm20Proposition2KappaBPrime_sq hsub]
  rw [hsq]

/--
Source-prime numerator algebra for Proposition 2(iv).

After substituting the displayed definitions of `a'_g(q)` and `b'_g`, the
Gaussian lower-left first-coordinate cutoff has numerator
`(sigma^{-2}+sum_sub sigma_gk^{-2}) * (mu-q)`.
-/
theorem glm20Proposition2KappaAPrime_add_BPrime_mul_mu
    {priorPrecision subPrecisionSum mu q : ℝ}
    (hsub : 0 < subPrecisionSum) :
    glm20Proposition2KappaAPrime priorPrecision subPrecisionSum mu q +
        glm20Proposition2KappaBPrime subPrecisionSum * mu =
      (priorPrecision + subPrecisionSum) * (mu - q) /
        Real.sqrt subPrecisionSum := by
  have hsqrt_ne : Real.sqrt subPrecisionSum ≠ 0 :=
    ne_of_gt (Real.sqrt_pos.2 hsub)
  simp only [glm20Proposition2KappaAPrime, glm20Proposition2KappaBPrime]
  field_simp [hsqrt_ne]
  rw [Real.sq_sqrt hsub.le]
  ring

/--
Proposition 2(iv) source-prime lower-left mass after substituting the paper's
displayed `a'_g(q)` and `b'_g` definitions.

This is the mass appearing in the normalization `tau_g = 1 - Phi_2(...)`,
written directly in the raw precision-sum notation from the source display.
-/
def glm20Proposition2KappaSourceLowerLeftMass
    (priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull : ℝ) : ℝ :=
  lowerLeftRectangleMass
    (correlatedStandardGaussianLaw
      (-(sigmaTilde * Real.sqrt subPrecisionSum) /
        Real.sqrt (1 + sigmaTilde ^ 2 * subPrecisionSum)))
    (((priorPrecision + subPrecisionSum) * (mu - q2Sub) /
        Real.sqrt subPrecisionSum) /
      Real.sqrt (1 + sigmaTilde ^ 2 * subPrecisionSum))
    ((qFull - mu) / sigmaTilde)

/--
Proposition 2(iv) source normalization for the `J2` admitted class.

The paper's `kappa` term uses the complement of the lower-left excluded mass:
`tau_g = 1 - Phi_2(...)`, after substituting the displayed `a'_g(q)` and
`b'_g` definitions into raw precision notation.
-/
def glm20Proposition2KappaSourceTau
    (priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull : ℝ) : ℝ :=
  1 -
    glm20Proposition2KappaSourceLowerLeftMass
      priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull

/--
Source-prime substitution bridge for the Proposition 2(iv) lower-left mass.

The raw precision-sum expression above is exactly the correlated Gaussian
lower-left mass obtained by first using the paper's `a'_g(q)` and `b'_g`
definitions and then standardizing.
-/
theorem glm20Proposition2KappaSourceLowerLeftMass_eq_sourcePrimes
    {priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull : ℝ}
    (hsub : 0 < subPrecisionSum) :
    glm20Proposition2KappaSourceLowerLeftMass
        priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull =
      lowerLeftRectangleMass
        (correlatedStandardGaussianLaw
          (-(sigmaTilde *
                glm20Proposition2KappaBPrime subPrecisionSum) /
            Real.sqrt
              (1 +
                (sigmaTilde *
                  glm20Proposition2KappaBPrime subPrecisionSum) ^ 2)))
        (((glm20Proposition2KappaAPrime
                priorPrecision subPrecisionSum mu q2Sub) +
              glm20Proposition2KappaBPrime subPrecisionSum * mu) /
          Real.sqrt
            (1 +
              (sigmaTilde *
                glm20Proposition2KappaBPrime subPrecisionSum) ^ 2))
        ((qFull - mu) / sigmaTilde) := by
  have hdenom :
      Real.sqrt
          (1 +
            (sigmaTilde *
              glm20Proposition2KappaBPrime subPrecisionSum) ^ 2) =
        Real.sqrt (1 + sigmaTilde ^ 2 * subPrecisionSum) :=
    glm20Proposition2KappaSourceDenom_eq hsub.le
  have hnum :
      glm20Proposition2KappaAPrime
            priorPrecision subPrecisionSum mu q2Sub +
          glm20Proposition2KappaBPrime subPrecisionSum * mu =
        (priorPrecision + subPrecisionSum) * (mu - q2Sub) /
          Real.sqrt subPrecisionSum :=
    glm20Proposition2KappaAPrime_add_BPrime_mul_mu hsub
  have hdenom_sqrt :
      Real.sqrt (1 + (sigmaTilde * Real.sqrt subPrecisionSum) ^ 2) =
        Real.sqrt (1 + sigmaTilde ^ 2 * subPrecisionSum) := by
    simpa [glm20Proposition2KappaBPrime] using hdenom
  have hnum_sqrt :
      glm20Proposition2KappaAPrime
            priorPrecision subPrecisionSum mu q2Sub +
          Real.sqrt subPrecisionSum * mu =
        (priorPrecision + subPrecisionSum) * (mu - q2Sub) /
          Real.sqrt subPrecisionSum := by
    simpa [glm20Proposition2KappaBPrime] using hnum
  simpa [glm20Proposition2KappaSourceLowerLeftMass,
    glm20Proposition2KappaBPrime, hdenom_sqrt, hnum_sqrt]

/--
Proposition 2(iv) source tau normalization with the displayed
`a'_g(q)` and `b'_g` definitions.
-/
theorem glm20Proposition2KappaSourceTau_eq_sourcePrimes
    {priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull : ℝ}
    (hsub : 0 < subPrecisionSum) :
    glm20Proposition2KappaSourceTau
        priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull =
      1 -
        lowerLeftRectangleMass
          (correlatedStandardGaussianLaw
            (-(sigmaTilde *
                  glm20Proposition2KappaBPrime subPrecisionSum) /
              Real.sqrt
                (1 +
                  (sigmaTilde *
                    glm20Proposition2KappaBPrime subPrecisionSum) ^ 2)))
          (((glm20Proposition2KappaAPrime
                  priorPrecision subPrecisionSum mu q2Sub) +
                glm20Proposition2KappaBPrime subPrecisionSum * mu) /
            Real.sqrt
              (1 +
                (sigmaTilde *
                  glm20Proposition2KappaBPrime subPrecisionSum) ^ 2))
          ((qFull - mu) / sigmaTilde) := by
  rw [glm20Proposition2KappaSourceTau,
    glm20Proposition2KappaSourceLowerLeftMass_eq_sourcePrimes hsub]

/--
Proposition 2(iv) academic-merit formula `kappa`.

Paper statement:
`kappa(a'_g(q), b'_g, sigma_tilde_g, tau_g)` equals the displayed
Owen-integral simplification for the academic merit of students enrolling in
`J2` after they clear the test-free cutoff but are not admitted by `J1`.
-/
def glm20Proposition2KappaFormula
    (api : StandardGaussianCDFAPI)
    (aPrime bPrime sigmaTilde tau mu q1Full q : ℝ) : ℝ :=
  let denom := Real.sqrt (1 + sigmaTilde ^ 2 * bPrime ^ 2)
  let A := (aPrime + bPrime * mu) / denom
  let shifted :=
    q1Full * denom + bPrime * sigmaTilde * (aPrime + bPrime * mu) / denom
  sigmaTilde ^ 2 * bPrime / (tau * denom) * api.density A *
      api.cdf shifted -
    api.cdf (aPrime + bPrime * mu + bPrime * sigmaTilde * q1Full) *
      sigmaTilde ^ 2 * api.density q / tau +
    mu * (1 - tau) / tau

/--
Source-density version of Proposition 2(iv)'s `kappa` formula.

The source display uses a boundary density at the cutoff.  This variant keeps
that boundary density as an explicit scalar so that source-to-standardized
density scaling can be proved separately from the Owen first-moment algebra.
-/
def glm20Proposition2KappaBoundaryDensityFormula
    (api : StandardGaussianCDFAPI)
    (aPrime bPrime sigmaTilde tau mu q1Full boundaryDensity : ℝ) : ℝ :=
  let denom := Real.sqrt (1 + sigmaTilde ^ 2 * bPrime ^ 2)
  let A := (aPrime + bPrime * mu) / denom
  let shifted :=
    q1Full * denom + bPrime * sigmaTilde * (aPrime + bPrime * mu) / denom
  sigmaTilde ^ 2 * bPrime / (tau * denom) * api.density A *
      api.cdf shifted -
    api.cdf (aPrime + bPrime * mu + bPrime * sigmaTilde * q1Full) *
      sigmaTilde ^ 2 * boundaryDensity / tau +
    mu * (1 - tau) / tau

/-- The older `kappa` encoding is the boundary-density formula with
`boundaryDensity = phi(q)`. -/
theorem glm20Proposition2KappaBoundaryDensityFormula_eq_kappaFormula
    (api : StandardGaussianCDFAPI)
    (aPrime bPrime sigmaTilde tau mu q1Full q : ℝ) :
    glm20Proposition2KappaBoundaryDensityFormula api
        aPrime bPrime sigmaTilde tau mu q1Full (api.density q) =
      glm20Proposition2KappaFormula api
        aPrime bPrime sigmaTilde tau mu q1Full q := by
  rfl

/--
Measure-backed source model for the Lemma 3 application/admission event.

The event is exactly `{q_sub >= qApply, q_full >= qAdmit}` under a joint law
for the group's test-free and full-score estimates, scaled by the group's
population share.
-/
def glm20MeasureApplyAdmitMass
    (populationShare : ℝ) (jointLaw : Measure (ℝ × ℝ))
    (qApply qAdmit : ℝ) : ℝ := populationShare * upperOrthantMass jointLaw qApply qAdmit

/--
If the joint source law is finite and positive on nonempty open sets, then the
application/admission mass strictly falls along the Lemma 3 diagonal
`(q - offset, q)`.
-/
theorem glm20MeasureApplyAdmitMass_strictAnti_diagonal
    (jointLaw : Measure (ℝ × ℝ))
    [IsFiniteMeasure jointLaw] [Measure.IsOpenPosMeasure jointLaw]
    {populationShare offset : ℝ} (hpopulation : 0 < populationShare) :
    StrictAnti fun q : ℝ =>
      glm20MeasureApplyAdmitMass populationShare jointLaw (q - offset) q := by
  have hApply : StrictMono fun q : ℝ => q - offset := by
    intro x y hxy
    linarith
  have hAdmit : Monotone fun q : ℝ => q := by
    intro x y hxy
    exact hxy
  have hmass :
      StrictAnti fun q : ℝ => upperOrthantMass jointLaw (q - offset) q :=
    upperOrthantMass_strictAnti_of_strictMono_left_monotone_right
      jointLaw hApply hAdmit
  intro x y hxy
  simpa [glm20MeasureApplyAdmitMass] using
    mul_lt_mul_of_pos_left (hmass hxy) hpopulation

/-- Endpoint at `-∞` for the measure-backed Lemma 3 applicant mass. -/
theorem glm20MeasureApplyAdmitMass_tendsto_atBot_diagonal
    (jointLaw : Measure (ℝ × ℝ)) [IsFiniteMeasure jointLaw]
    (populationShare offset : ℝ) :
    Filter.Tendsto
      (fun q : ℝ =>
        glm20MeasureApplyAdmitMass populationShare jointLaw (q - offset) q)
      Filter.atBot (nhds (populationShare * jointLaw.real Set.univ)) := by
  simpa [glm20MeasureApplyAdmitMass] using
    tendsto_const_nhds.mul
      (upperOrthantMass_diagonal_tendsto_atBot_univ jointLaw offset)

/-- Endpoint at `+∞` for the measure-backed Lemma 3 applicant mass. -/
theorem glm20MeasureApplyAdmitMass_tendsto_atTop_diagonal
    (jointLaw : Measure (ℝ × ℝ)) [IsFiniteMeasure jointLaw]
    (populationShare offset : ℝ) :
    Filter.Tendsto
      (fun q : ℝ =>
        glm20MeasureApplyAdmitMass populationShare jointLaw (q - offset) q)
      Filter.atTop (nhds 0) := by
  simpa [glm20MeasureApplyAdmitMass] using
    tendsto_const_nhds.mul
      (upperOrthantMass_diagonal_tendsto_atTop_zero jointLaw offset)

/--
Continuity of the measure-backed Lemma 3 applicant mass along the diagonal
when both source-score marginals are nonatomic.
-/
theorem glm20MeasureApplyAdmitMass_continuous_diagonal_of_noAtoms_marginals
    (jointLaw : Measure (ℝ × ℝ)) [IsFiniteMeasure jointLaw]
    [NoAtoms (jointLaw.map Prod.fst)] [NoAtoms (jointLaw.map Prod.snd)]
    (populationShare offset : ℝ) :
    Continuous fun q : ℝ =>
      glm20MeasureApplyAdmitMass populationShare jointLaw (q - offset) q := by
  simpa [glm20MeasureApplyAdmitMass] using
    continuous_const.mul
      (upperOrthantMass_diagonal_continuous_of_noAtoms_marginals
        jointLaw offset)

theorem glm20MeasureApplyAdmitMass_continuous_diagonal_of_boundary_null
    (jointLaw : Measure (ℝ × ℝ)) [IsFiniteMeasure jointLaw]
    (populationShare offset : ℝ)
    (hboundary :
      ∀ q : ℝ,
        jointLaw
          ({p : ℝ × ℝ | p.1 = q - offset} ∪
            {p : ℝ × ℝ | p.2 = q}) = 0) :
    Continuous fun q : ℝ =>
      glm20MeasureApplyAdmitMass populationShare jointLaw (q - offset) q := by
  simpa [glm20MeasureApplyAdmitMass] using
    continuous_const.mul
      (upperOrthantMass_diagonal_continuous_of_boundary_null
        jointLaw offset hboundary)

theorem glm20MeasureApplyAdmitMass_continuous_diagonal_of_volume_density
    (density : ℝ × ℝ → ℝ≥0∞)
    [IsFiniteMeasure ((volume : Measure (ℝ × ℝ)).withDensity density)]
    (populationShare offset : ℝ) :
    Continuous fun q : ℝ =>
      glm20MeasureApplyAdmitMass populationShare
        ((volume : Measure (ℝ × ℝ)).withDensity density) (q - offset) q := by
  simpa [glm20MeasureApplyAdmitMass] using
    continuous_const.mul
      (upperOrthantMass_diagonal_continuous_of_volume_withDensity
        density offset)

/--
Regularity of the measure-backed application/admission mass for the concrete
nondegenerate correlated standard-Gaussian law.
-/
theorem glm20MeasureApplyAdmitMass_correlatedStandardGaussian_regular_diagonal
    {rho populationShare offset : ℝ} (hrho : rho ^ 2 < 1)
    (hpopulation : 0 < populationShare) :
    Continuous
        (fun q : ℝ =>
          glm20MeasureApplyAdmitMass populationShare
            (correlatedStandardGaussianLaw rho) (q - offset) q) ∧
      StrictAnti
        (fun q : ℝ =>
          glm20MeasureApplyAdmitMass populationShare
            (correlatedStandardGaussianLaw rho) (q - offset) q) ∧
      Filter.Tendsto
        (fun q : ℝ =>
          glm20MeasureApplyAdmitMass populationShare
            (correlatedStandardGaussianLaw rho) (q - offset) q)
        Filter.atBot (nhds populationShare) ∧
      Filter.Tendsto
        (fun q : ℝ =>
          glm20MeasureApplyAdmitMass populationShare
            (correlatedStandardGaussianLaw rho) (q - offset) q)
        Filter.atTop (nhds 0) := by
  let jointLaw : Measure (ℝ × ℝ) := correlatedStandardGaussianLaw rho
  have hcont :
      Continuous
        (fun q : ℝ =>
          glm20MeasureApplyAdmitMass populationShare jointLaw
            (q - offset) q) := by
    simpa [jointLaw, glm20MeasureApplyAdmitMass] using
      continuous_const.mul
        (correlatedStandardGaussianLaw_upperOrthantMass_diagonal_continuous
          (le_of_lt hrho) offset)
  have hanti :
      StrictAnti
        (fun q : ℝ =>
          glm20MeasureApplyAdmitMass populationShare jointLaw
            (q - offset) q) := by
    letI : Measure.IsOpenPosMeasure jointLaw :=
      by
        dsimp [jointLaw]
        exact correlatedStandardGaussianLaw_isOpenPosMeasure hrho
    exact
      glm20MeasureApplyAdmitMass_strictAnti_diagonal
        jointLaw hpopulation
  have hbot :
      Filter.Tendsto
