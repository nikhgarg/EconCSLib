  paper_theorem3_school2_objective_iff_other_group_keeps_test_of_single_group_no_tie
    S policyPair Psub Pfull J2 groupA groupB otherGroup populationShare
    objective2 hobjectiveSubFull hobjectiveSubSub hmass
    (ne_of_gt hmerit_gt)

/--
Proposition 5(i) school-`J2` objective bridges from source weighted-merit
bookkeeping.

If the expanding-group case identifies `(P_sub,P_full)` with the other group's
single weighted admitted-merit contribution, and the other group has enough
test-taking mass with a non-tied merit comparison, then the `J2` objective
comparison is equivalent to conditions (11)--(12) for that other group.
-/
theorem paper_proposition5_part_i_school2_objective_bridges_of_single_group_no_tie
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost costThreshold : Group → ℝ}
    {capacity2 q1Sub : ℝ} {K : Group → ℝ → ℝ}
    (objective2 : Policy → Policy → ℝ)
    (hobjectiveSubSub :
      objective2 Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hobjectiveSubFullB :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupA →
        objective2 Psub Pfull =
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull))
    (hmassB :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupA →
        S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2)
    (hnotTieB :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hobjectiveSubFullA :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupB →
        objective2 Psub Pfull =
          populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull))
    (hmassA :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2)
    (hnotTieA :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :
    (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
        testCost costThreshold q1Sub K groupA →
      ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
        glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull
          J2 groupA groupB populationShare capacity2 groupB)) ∧
      (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub K groupB →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull
            J2 groupA groupB populationShare capacity2 groupA)) := by
  constructor
  · intro hdropA
    exact
      paper_theorem3_school2_objective_iff_other_group_keeps_test_of_single_group_no_tie
        S policyPair Psub Pfull J2 groupA groupB groupB populationShare
        objective2 (hobjectiveSubFullB hdropA) hobjectiveSubSub
        (hmassB hdropA) (hnotTieB hdropA)
  · intro hdropB
    exact
