  have hmean_B :
      (M_B_sub.posteriorMeanScaleLaw).mean =
        (M_B_full.posteriorMeanScaleLaw).mean := by
    simp [GaussianOffsetSignalFamily.posteriorMeanScaleLaw,
      hmeanB_sub, hmeanB_full]
  have hsum_A :
      M_A_sub.centeredFamily.signalPrecisionSum <
        M_A_full.centeredFamily.signalPrecisionSum := by
    rw [hsubA_sum, hfullA_sum]
    linarith
  have hsum_B :
      M_B_sub.centeredFamily.signalPrecisionSum <
        M_B_full.centeredFamily.signalPrecisionSum := by
    rw [hsubB_sum, hfullB_sum]
    linarith
  have hscale_A :
      (M_A_sub.posteriorMeanScaleLaw).scale <
        (M_A_full.posteriorMeanScaleLaw).scale :=
    GaussianOffsetSignalFamily.posteriorMeanScaleLaw_scale_lt_of_priorVar_eq_signalPrecisionSum_lt
      hpriorVar_A hsum_A
  have hscale_B :
      (M_B_sub.posteriorMeanScaleLaw).scale <
        (M_B_full.posteriorMeanScaleLaw).scale :=
    GaussianOffsetSignalFamily.posteriorMeanScaleLaw_scale_lt_of_priorVar_eq_signalPrecisionSum_lt
      hpriorVar_B hsum_B
  exact
    paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_surface_of_precision_order_population_weights_main_text_direction
      (groupA := groupA) (groupB := groupB) (Psub := Psub) (Pfull := Pfull)
      (pi := pi) (capacity := capacity) (quantile := quantile)
      (priorPrecision := priorPrecision) (mean := mean)
      (subA := subA) (subB := subB) (testA := testA) (testB := testB)
      (L_A_sub := M_A_sub.posteriorMeanScaleLaw)
      (L_A_full := M_A_full.posteriorMeanScaleLaw)
      (L_B_sub := M_B_sub.posteriorMeanScaleLaw)
      (L_B_full := M_B_full.posteriorMeanScaleLaw)
      (thresholdSub := thresholdSub) (thresholdFull := thresholdFull)
      hgroups hP_ne hquantile_pos hprior_pos hsubA_pos hsubB_pos
      htestA_pos htestB_pos hfull_precision_order hsub_precision_order
      hpi_pos hpi_lt_one hmean_sub hmean_A hmean_B hscale_A hscale_B
      hcapacity_sub hcapacity_full hcapacity_lt_half

/--
Theorem 2, source-family wrapper with constructed capacity thresholds in the
main-text high-skill direction.
-/
theorem paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_families_of_precision_order_population_weights_capacity_thresholds_main_text_direction
    {SubFeature FullFeature Group Policy : Type*}
    [Fintype SubFeature] [Nonempty SubFeature]
    [Fintype FullFeature] [Nonempty FullFeature]
    [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) {Psub Pfull : Policy}
    {M_A_sub M_B_sub : GaussianOffsetSignalFamily SubFeature}
    {M_A_full M_B_full : GaussianOffsetSignalFamily FullFeature}
    {pi capacity quantile priorPrecision mean subA subB testA testB : ℝ}
    (hgroups : groupA ≠ groupB) (hP_ne : Psub ≠ Pfull)
    (hquantile_pos : 0 < quantile)
    (hcapacity_pos : 0 < capacity)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ))
    (hpriorPrecision : M_A_sub.centeredFamily.priorPrecision = priorPrecision)
    (hmeanA_sub : M_A_sub.priorMean = mean)
    (hmeanB_sub : M_B_sub.priorMean = mean)
    (hmeanA_full : M_A_full.priorMean = mean)
    (hmeanB_full : M_B_full.priorMean = mean)
    (hpriorVar_A : M_A_sub.priorVar = M_A_full.priorVar)
    (hpriorVar_B : M_B_sub.priorVar = M_B_full.priorVar)
    (hsubA_sum : M_A_sub.centeredFamily.signalPrecisionSum = subA)
    (hsubB_sum : M_B_sub.centeredFamily.signalPrecisionSum = subB)
    (hfullA_sum : M_A_full.centeredFamily.signalPrecisionSum = subA + testA)
    (hfullB_sum : M_B_full.centeredFamily.signalPrecisionSum = subB + testB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB)
    (hfull_precision_order : subB + testB < subA + testA)
    (hsub_precision_order : subB < subA)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1) :
    ∃ thresholdSub thresholdFull : ℝ,
      let interceptAFull :=
        (priorPrecision * (thresholdFull - mean) +
            (subA + testA) * thresholdFull) /
          Real.sqrt (subA + testA)
      let slopeAFull := Real.sqrt (subA + testA)
      let interceptASub :=
        (priorPrecision * (thresholdSub - mean) + subA * thresholdSub) /
          Real.sqrt subA
      let slopeASub := Real.sqrt subA
      let interceptBFull :=
        (priorPrecision * (thresholdFull - mean) +
            (subB + testB) * thresholdFull) /
          Real.sqrt (subB + testB)
      let slopeBFull := Real.sqrt (subB + testB)
      let interceptBSub :=
        (priorPrecision * (thresholdSub - mean) + subB * thresholdSub) /
          Real.sqrt subB
      let slopeBSub := Real.sqrt subB
      let S : GLM20SourcePolicySurface Group Policy :=
        theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
          pi capacity quantile (1 - pi) priorPrecision subA subB testA testB
          interceptAFull slopeAFull interceptASub slopeASub
          interceptBFull slopeBFull interceptBSub slopeBSub
          M_A_sub.posteriorMeanScaleLaw M_A_full.posteriorMeanScaleLaw
          M_B_sub.posteriorMeanScaleLaw M_B_full.posteriorMeanScaleLaw
          thresholdSub thresholdFull
      (S.diversity Psub > S.diversity Pfull ↔
        (subA * (priorPrecision + subA + testA)) /
            (subB * (priorPrecision + subB + testB)) <
          testA / testB) ∧
        (∃ qA qB : ℝ,
          (∀ q : ℝ,
            standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q >
                standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q ↔
              qA < q) ∧
          (∀ q : ℝ,
            standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q >
                standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q ↔
              qB < q) ∧
          ∃ qhat : ℝ, max qA qB ≤ qhat ∧
            ∀ q : ℝ, qhat < q →
              S.individualFairnessGap Psub q >
                S.individualFairnessGap Pfull q) ∧
        S.academicMerit groupA Psub < S.academicMerit groupA Pfull ∧
          S.academicMerit groupB Psub < S.academicMerit groupB Pfull := by
  let weight : Bool → ℝ := fun b => if b then pi else 1 - pi
  let lawSub : Bool → GaussianScaleLaw :=
    fun b => if b then M_B_sub.posteriorMeanScaleLaw
      else M_A_sub.posteriorMeanScaleLaw
  let lawFull : Bool → GaussianScaleLaw :=
    fun b => if b then M_B_full.posteriorMeanScaleLaw
      else M_A_full.posteriorMeanScaleLaw
  have hcapacity_mem : capacity ∈ Set.Ioo (0 : ℝ) (∑ b : Bool, weight b) := by
    have hlt_one : capacity < 1 := by linarith
    constructor
    · exact hcapacity_pos
    · simpa [weight, add_comm, add_left_comm, add_assoc] using hlt_one
  rcases standardGaussianCDFAPI.exists_mixtureTailMass_eq_of_capacity_mem_Ioo
      standardGaussianCDF_tendsto_atBot standardGaussianCDF_tendsto_atTop
      (weight := weight) (law := lawSub) hcapacity_mem with
    ⟨thresholdSub, hthresholdSub⟩
  rcases standardGaussianCDFAPI.exists_mixtureTailMass_eq_of_capacity_mem_Ioo
      standardGaussianCDF_tendsto_atBot standardGaussianCDF_tendsto_atTop
      (weight := weight) (law := lawFull) hcapacity_mem with
    ⟨thresholdFull, hthresholdFull⟩
  have hcapacity_sub :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_sub.posteriorMeanScaleLaw thresholdSub +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_sub.posteriorMeanScaleLaw thresholdSub := by
    rw [← hthresholdSub]
    simp [StandardGaussianCDFAPI.mixtureTailMass, weight, lawSub, add_comm]
  have hcapacity_full :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_full.posteriorMeanScaleLaw thresholdFull +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_full.posteriorMeanScaleLaw thresholdFull := by
    rw [← hthresholdFull]
    simp [StandardGaussianCDFAPI.mixtureTailMass, weight, lawFull, add_comm]
  refine ⟨thresholdSub, thresholdFull, ?_⟩
  exact
    paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_families_of_precision_order_population_weights_main_text_direction
      (groupA := groupA) (groupB := groupB) (Psub := Psub) (Pfull := Pfull)
      (M_A_sub := M_A_sub) (M_B_sub := M_B_sub)
      (M_A_full := M_A_full) (M_B_full := M_B_full)
      (pi := pi) (capacity := capacity) (quantile := quantile)
      (priorPrecision := priorPrecision) (mean := mean)
      (subA := subA) (subB := subB) (testA := testA) (testB := testB)
      (thresholdSub := thresholdSub) (thresholdFull := thresholdFull)
      hgroups hP_ne hquantile_pos hpriorPrecision hmeanA_sub hmeanB_sub
      hmeanA_full hmeanB_full hpriorVar_A hpriorVar_B hsubA_sum hsubB_sum
      hfullA_sum hfullB_sum htestA_pos htestB_pos hfull_precision_order
      hsub_precision_order hpi_pos hpi_lt_one hcapacity_sub hcapacity_full
      hcapacity_lt_half

/--
Theorem 2(ii), per-group admission-probability thresholds with constructed
capacity cutoffs.

This theorem isolates the source statement that, for each group, there is a
skill threshold above which dropping the test decreases that group's admission
probability.  Unlike the bundled high-skill individual-fairness-gap wrapper,
this result needs only that the dropped test adds positive precision for each
group; it does not assume any cross-group test-free precision ordering.
-/
theorem paper_theorem2_group_admission_thresholds_standardGaussian_source_families_capacity_thresholds
    {SubFeature FullFeature : Type*}
    [Fintype SubFeature] [Nonempty SubFeature]
    [Fintype FullFeature] [Nonempty FullFeature]
    {M_A_sub M_B_sub : GaussianOffsetSignalFamily SubFeature}
    {M_A_full M_B_full : GaussianOffsetSignalFamily FullFeature}
    {pi capacity priorPrecision mean subA subB testA testB : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hcapacity_lt_one : capacity < 1)
    (hpriorPrecision : M_A_sub.centeredFamily.priorPrecision = priorPrecision)
    (hsubA_sum : M_A_sub.centeredFamily.signalPrecisionSum = subA)
    (hsubB_sum : M_B_sub.centeredFamily.signalPrecisionSum = subB)
    (hfullA_sum : M_A_full.centeredFamily.signalPrecisionSum = subA + testA)
    (hfullB_sum : M_B_full.centeredFamily.signalPrecisionSum = subB + testB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1) :
    ∃ thresholdSub thresholdFull qA qB : ℝ,
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_sub.posteriorMeanScaleLaw thresholdSub +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_sub.posteriorMeanScaleLaw thresholdSub ∧
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_full.posteriorMeanScaleLaw thresholdFull +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_full.posteriorMeanScaleLaw thresholdFull ∧
      (∀ q : ℝ,
        standardGaussianDerivativeAPI.affineUpperTail
            ((priorPrecision * (thresholdFull - mean) +
                (subA + testA) * thresholdFull) /
              Real.sqrt (subA + testA))
            (Real.sqrt (subA + testA)) q >
          standardGaussianDerivativeAPI.affineUpperTail
            ((priorPrecision * (thresholdSub - mean) +
                subA * thresholdSub) /
              Real.sqrt subA)
            (Real.sqrt subA) q ↔
          qA < q) ∧
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail
              ((priorPrecision * (thresholdFull - mean) +
                  (subB + testB) * thresholdFull) /
                Real.sqrt (subB + testB))
              (Real.sqrt (subB + testB)) q >
            standardGaussianDerivativeAPI.affineUpperTail
              ((priorPrecision * (thresholdSub - mean) +
                  subB * thresholdSub) /
                Real.sqrt subB)
              (Real.sqrt subB) q ↔
            qB < q) := by
  let weight : Bool → ℝ := fun b => if b then pi else 1 - pi
  let lawSub : Bool → GaussianScaleLaw :=
    fun b => if b then M_B_sub.posteriorMeanScaleLaw
      else M_A_sub.posteriorMeanScaleLaw
  let lawFull : Bool → GaussianScaleLaw :=
    fun b => if b then M_B_full.posteriorMeanScaleLaw
      else M_A_full.posteriorMeanScaleLaw
  have hcapacity_mem : capacity ∈ Set.Ioo (0 : ℝ) (∑ b : Bool, weight b) := by
    constructor
    · exact hcapacity_pos
    · simpa [weight, add_comm, add_left_comm, add_assoc] using hcapacity_lt_one
  rcases standardGaussianCDFAPI.exists_mixtureTailMass_eq_of_capacity_mem_Ioo
      standardGaussianCDF_tendsto_atBot standardGaussianCDF_tendsto_atTop
      (weight := weight) (law := lawSub) hcapacity_mem with
    ⟨thresholdSub, hthresholdSub⟩
  rcases standardGaussianCDFAPI.exists_mixtureTailMass_eq_of_capacity_mem_Ioo
      standardGaussianCDF_tendsto_atBot standardGaussianCDF_tendsto_atTop
      (weight := weight) (law := lawFull) hcapacity_mem with
    ⟨thresholdFull, hthresholdFull⟩
  have hcapacity_sub :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_sub.posteriorMeanScaleLaw thresholdSub +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_sub.posteriorMeanScaleLaw thresholdSub := by
    rw [← hthresholdSub]
    simp [StandardGaussianCDFAPI.mixtureTailMass, weight, lawSub, add_comm]
  have hcapacity_full :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_full.posteriorMeanScaleLaw thresholdFull +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_full.posteriorMeanScaleLaw thresholdFull := by
    rw [← hthresholdFull]
    simp [StandardGaussianCDFAPI.mixtureTailMass, weight, lawFull, add_comm]
  have hsubA_pos : 0 < subA := by
    simpa [hsubA_sum] using M_A_sub.centeredFamily.signalPrecisionSum_pos
  have hsubB_pos : 0 < subB := by
    simpa [hsubB_sum] using M_B_sub.centeredFamily.signalPrecisionSum_pos
  have hprior_pos : 0 < priorPrecision := by
    simpa [hpriorPrecision] using M_A_sub.centeredFamily.priorPrecision_pos
  have hfullA_pos : 0 < subA + testA := by linarith
  have hfullB_pos : 0 < subB + testB := by linarith
  have hslopeA : Real.sqrt subA < Real.sqrt (subA + testA) := by
    apply Real.sqrt_lt_sqrt hsubA_pos.le
    linarith
  have hslopeB : Real.sqrt subB < Real.sqrt (subB + testB) := by
    apply Real.sqrt_lt_sqrt hsubB_pos.le
    linarith
  let qA :=
    (((priorPrecision * (thresholdFull - mean) +
          (subA + testA) * thresholdFull) /
        Real.sqrt (subA + testA)) -
      ((priorPrecision * (thresholdSub - mean) + subA * thresholdSub) /
        Real.sqrt subA)) /
      (Real.sqrt (subA + testA) - Real.sqrt subA)
  let qB :=
    (((priorPrecision * (thresholdFull - mean) +
          (subB + testB) * thresholdFull) /
        Real.sqrt (subB + testB)) -
      ((priorPrecision * (thresholdSub - mean) + subB * thresholdSub) /
        Real.sqrt subB)) /
      (Real.sqrt (subB + testB) - Real.sqrt subB)
  refine ⟨thresholdSub, thresholdFull, qA, qB,
    hcapacity_sub, hcapacity_full, ?_, ?_⟩
  · intro q
    exact
      paper_theorem2_affine_admission_probability_full_gt_sub_iff_cutoff_lt
        standardGaussianDerivativeAPI hslopeA
  · intro q
    exact
      paper_theorem2_affine_admission_probability_full_gt_sub_iff_cutoff_lt
        standardGaussianDerivativeAPI hslopeB

/--
Theorem 2 no-barrier canonical Gaussian source model.

The primitive fields are exactly the raw Gaussian-family assumptions used by
the current formal proof: common prior mean, matched prior variances between
the test-free and test-using families, the paper precision-sum notation, a
selective capacity, positive dropped-test precisions, and the main-text
precision order that the test-free features still favor group A.
-/
structure GLM20Theorem2NoBarrierCanonicalSourceModel
    (SubFeature FullFeature Group Policy : Type*)
    [Fintype SubFeature] [Nonempty SubFeature]
    [Fintype FullFeature] [Nonempty FullFeature] where
  groupA : Group
  groupB : Group
  groups_ne : groupA ≠ groupB
  Psub : Policy
  Pfull : Policy
  P_ne : Psub ≠ Pfull
  M_A_sub : GaussianOffsetSignalFamily SubFeature
  M_B_sub : GaussianOffsetSignalFamily SubFeature
  M_A_full : GaussianOffsetSignalFamily FullFeature
  M_B_full : GaussianOffsetSignalFamily FullFeature
  pi : ℝ
  capacity : ℝ
  quantile : ℝ
  priorPrecision : ℝ
  mean : ℝ
  subA : ℝ
  subB : ℝ
  testA : ℝ
  testB : ℝ
  quantile_pos : 0 < quantile
  capacity_pos : 0 < capacity
  capacity_lt_half : capacity < (1 / 2 : ℝ)
  priorPrecision_eq : M_A_sub.centeredFamily.priorPrecision = priorPrecision
  meanA_sub_eq : M_A_sub.priorMean = mean
  meanB_sub_eq : M_B_sub.priorMean = mean
  meanA_full_eq : M_A_full.priorMean = mean
  meanB_full_eq : M_B_full.priorMean = mean
  priorVar_A_eq : M_A_sub.priorVar = M_A_full.priorVar
  priorVar_B_eq : M_B_sub.priorVar = M_B_full.priorVar
  subA_sum_eq : M_A_sub.centeredFamily.signalPrecisionSum = subA
  subB_sum_eq : M_B_sub.centeredFamily.signalPrecisionSum = subB
  fullA_sum_eq : M_A_full.centeredFamily.signalPrecisionSum = subA + testA
  fullB_sum_eq : M_B_full.centeredFamily.signalPrecisionSum = subB + testB
  testA_pos : 0 < testA
  testB_pos : 0 < testB
  full_precision_order : subB + testB < subA + testA
  sub_precision_order : subB < subA
  pi_pos : 0 < pi
  pi_lt_one : pi < 1

/-- Paper-facing conclusion package for the corrected Theorem 2 source model. -/
def GLM20Theorem2NoBarrierCanonicalSourceModelConclusion
    {SubFeature FullFeature Group Policy : Type*}
    [Fintype SubFeature] [Nonempty SubFeature]
    [Fintype FullFeature] [Nonempty FullFeature]
    [DecidableEq Group] [DecidableEq Policy]
    (M : GLM20Theorem2NoBarrierCanonicalSourceModel
      SubFeature FullFeature Group Policy) : Prop :=
  ∃ thresholdSub thresholdFull : ℝ,
    let interceptAFull :=
      (M.priorPrecision * (thresholdFull - M.mean) +
          (M.subA + M.testA) * thresholdFull) /
        Real.sqrt (M.subA + M.testA)
    let slopeAFull := Real.sqrt (M.subA + M.testA)
    let interceptASub :=
      (M.priorPrecision * (thresholdSub - M.mean) +
          M.subA * thresholdSub) /
        Real.sqrt M.subA
    let slopeASub := Real.sqrt M.subA
    let interceptBFull :=
      (M.priorPrecision * (thresholdFull - M.mean) +
          (M.subB + M.testB) * thresholdFull) /
        Real.sqrt (M.subB + M.testB)
    let slopeBFull := Real.sqrt (M.subB + M.testB)
    let interceptBSub :=
      (M.priorPrecision * (thresholdSub - M.mean) +
          M.subB * thresholdSub) /
        Real.sqrt M.subB
    let slopeBSub := Real.sqrt M.subB
    let S : GLM20SourcePolicySurface Group Policy :=
      theorem2NoBarrierSourceSurface M.groupA M.groupB M.Psub M.Pfull
        M.pi M.capacity M.quantile (1 - M.pi) M.priorPrecision
        M.subA M.subB M.testA M.testB
        interceptAFull slopeAFull interceptASub slopeASub
        interceptBFull slopeBFull interceptBSub slopeBSub
        M.M_A_sub.posteriorMeanScaleLaw M.M_A_full.posteriorMeanScaleLaw
        M.M_B_sub.posteriorMeanScaleLaw M.M_B_full.posteriorMeanScaleLaw
        thresholdSub thresholdFull
    (S.diversity M.Psub > S.diversity M.Pfull ↔
      (M.subA * (M.priorPrecision + M.subA + M.testA)) /
          (M.subB * (M.priorPrecision + M.subB + M.testB)) <
        M.testA / M.testB) ∧
      (∃ qA qB : ℝ,
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail
              interceptAFull slopeAFull q >
            standardGaussianDerivativeAPI.affineUpperTail
              interceptASub slopeASub q ↔
            qA < q) ∧
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail
              interceptBFull slopeBFull q >
            standardGaussianDerivativeAPI.affineUpperTail
              interceptBSub slopeBSub q ↔
            qB < q) ∧
        ∃ qhat : ℝ, max qA qB ≤ qhat ∧
          ∀ q : ℝ, qhat < q →
            S.individualFairnessGap M.Psub q >
              S.individualFairnessGap M.Pfull q) ∧
      S.academicMerit M.groupA M.Psub <
          S.academicMerit M.groupA M.Pfull ∧
        S.academicMerit M.groupB M.Psub <
          S.academicMerit M.groupB M.Pfull

/-- Compatibility alias for older ledgers that used the appendix-direction name. -/
abbrev GLM20Theorem2NoBarrierCanonicalSourceModelAppendixDirection
    {SubFeature FullFeature Group Policy : Type*}
    [Fintype SubFeature] [Nonempty SubFeature]
    [Fintype FullFeature] [Nonempty FullFeature]
    [DecidableEq Group] [DecidableEq Policy]
    (M : GLM20Theorem2NoBarrierCanonicalSourceModel
      SubFeature FullFeature Group Policy) : Prop := GLM20Theorem2NoBarrierCanonicalSourceModelConclusion M

/--
Theorem 2, raw Gaussian source model with constructed capacity thresholds.

This closes the source-model construction for the theorem clauses that follow
from the corrected main-text assumptions: the diversity equivalence, both
per-group admission-probability cutoffs, the high-skill direction
`I(q; P_sub) > I(q; P_full)`, and strict academic-merit loss from dropping the
test.  The historical theorem name is kept temporarily for downstream
compatibility; its statement is the main-text direction.
-/
theorem paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_model_appendix_direction
    {SubFeature FullFeature Group Policy : Type*}
    [Fintype SubFeature] [Nonempty SubFeature]
    [Fintype FullFeature] [Nonempty FullFeature]
    [DecidableEq Group] [DecidableEq Policy]
    (M : GLM20Theorem2NoBarrierCanonicalSourceModel
      SubFeature FullFeature Group Policy) :
    GLM20Theorem2NoBarrierCanonicalSourceModelConclusion M :=
    paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_families_of_precision_order_population_weights_capacity_thresholds_main_text_direction
      (groupA := M.groupA) (groupB := M.groupB)
      (Psub := M.Psub) (Pfull := M.Pfull)
      (M_A_sub := M.M_A_sub) (M_B_sub := M.M_B_sub)
      (M_A_full := M.M_A_full) (M_B_full := M.M_B_full)
      (pi := M.pi) (capacity := M.capacity) (quantile := M.quantile)
      (priorPrecision := M.priorPrecision) (mean := M.mean)
      (subA := M.subA) (subB := M.subB)
      (testA := M.testA) (testB := M.testB)
      M.groups_ne M.P_ne M.quantile_pos M.capacity_pos
      M.capacity_lt_half M.priorPrecision_eq M.meanA_sub_eq
      M.meanB_sub_eq M.meanA_full_eq M.meanB_full_eq M.priorVar_A_eq
      M.priorVar_B_eq M.subA_sum_eq M.subB_sum_eq M.fullA_sum_eq
      M.fullB_sum_eq M.testA_pos M.testB_pos M.full_precision_order
      M.sub_precision_order M.pi_pos M.pi_lt_one

/--
Theorem 1 notation: the group-A square-root factor in the paper's
`β_A(γ_A, γ_B, ρ_A)` expression, after holding group-B eligible mass fixed.

This is the factor whose derivative is positive in the source proof when
`ρ_A < 1`.
-/
def theorem1BetaGroupAFactor
    (ownShare otherEligibleMass rho gamma : ℝ) : ℝ :=
  Real.sqrt
    ((ownShare * gamma + otherEligibleMass * rho) /
      (ownShare * gamma + otherEligibleMass))

/--
Theorem 1 notation: the group-B square-root factor in the paper's
`β_B(γ_B, γ_A, ρ_B)` expression, after holding group-A eligible mass fixed.

This is the factor whose derivative is positive in the source proof when
`1 < ρ_B`.
-/
def theorem1BetaGroupBFactor
    (ownShare otherEligibleMass rho gamma : ℝ) : ℝ :=
  Real.sqrt
    ((ownShare * gamma * rho + otherEligibleMass) /
      (ownShare * gamma + otherEligibleMass))

/--
Theorem 1 notation: the paper's `β_A` access score, with
`Φ⁻¹` represented by `Q.quantile` and with all parameters except `γ_A` held
fixed.
-/
def theorem1BetaGroupA
    (Q : StandardGaussianQuantileAPI)
    (capacity ownShare otherEligibleMass rho gamma : ℝ) : ℝ :=
  Q.quantile (1 - capacity / (ownShare * gamma + otherEligibleMass)) *
    theorem1BetaGroupAFactor ownShare otherEligibleMass rho gamma

/--
Theorem 1 notation: the paper's `β_B` access score, with
`Φ⁻¹` represented by `Q.quantile` and with all parameters except `γ_B` held
fixed.
-/
def theorem1BetaGroupB
    (Q : StandardGaussianQuantileAPI)
    (capacity ownShare otherEligibleMass rho gamma : ℝ) : ℝ :=
  Q.quantile (1 - capacity / (ownShare * gamma + otherEligibleMass)) *
    theorem1BetaGroupBFactor ownShare otherEligibleMass rho gamma

/--
Theorem 1 notation: the appendix constant
`Δ_g(ξ_g, ρ_g^sub) = HR⁻¹(ξ_g * HR(benchmark_g))`.

The source's benchmark is the standardized no-test admitted-merit cutoff.
Lean keeps it as the scalar `benchmark` so the paper-facing theorem can expose
the exact remaining Gaussian substitution separately.
-/
def theorem1AcademicMeritDelta
    (H : GaussianHazardInverseCertificate) (xi benchmark : ℝ) : ℝ := H.hazardInv (xi * H.hazard benchmark)

/--
Theorem 1 academic-merit Step 1 hazard-inverse bridge: once the truncated
normal comparison is reduced to a hazard inequality, the paper's displayed
`β_g ≤ Δ_g` condition follows by the order inverse property of `HR⁻¹`.
-/
theorem paper_theorem1_academic_merit_hazard_condition_iff_beta_le_delta
    (H : GaussianHazardInverseCertificate)
    {beta xi benchmark : ℝ} {academicMeritImproves : Prop}
    (hxi_pos : 0 < xi)
    (hhazard :
      academicMeritImproves ↔ H.hazard beta ≤ xi * H.hazard benchmark) :
    academicMeritImproves ↔
      beta ≤ theorem1AcademicMeritDelta H xi benchmark := by
  rw [hhazard, theorem1AcademicMeritDelta]
  have hy_pos : 0 < xi * H.hazard benchmark :=
    mul_pos hxi_pos (H.hazard_pos benchmark)
  exact (H.hazard_le_iff_le_inv
    (z := beta) (y := xi * H.hazard benchmark)) hy_pos

/--
Pointwise version of
`paper_theorem1_academic_merit_hazard_condition_iff_beta_le_delta`.
-/
theorem paper_theorem1_academic_merit_hazard_condition_iff_beta_le_delta_on_Icc
    (H : GaussianHazardInverseCertificate)
    {beta : ℝ → ℝ} {xi benchmark : ℝ}
    {academicMeritImproves : ℝ → Prop}
    (hxi_pos : 0 < xi)
    (hhazard :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γ ↔
          H.hazard (beta γ) ≤ xi * H.hazard benchmark) :
    ∀ γ ∈ Set.Icc (0 : ℝ) 1,
      academicMeritImproves γ ↔
        beta γ ≤ theorem1AcademicMeritDelta H xi benchmark := by
  intro γ hγ
  exact paper_theorem1_academic_merit_hazard_condition_iff_beta_le_delta
    H hxi_pos (hhazard γ hγ)

/--
Theorem 1 academic-merit Step 1 tail-mean bridge: if admitted academic merit
under the full policy and the test-free policy are both expressed as
Gaussian upper-tail means with a common base and positive scale, then
academic-merit improvement is equivalent to the hazard inequality that the
appendix converts to `β_g ≤ Δ_g`.
-/
theorem paper_theorem1_academic_merit_improves_iff_hazard_of_tail_mean
    (H : GaussianHazardInverseCertificate)
    {academicMeritImproves : Prop}
    {fullMerit subMerit base scale beta xi benchmark : ℝ}
    (hscale_pos : 0 < scale)
    (hfull :
      fullMerit = base + scale * H.hazard beta)
    (hsub :
      subMerit = base + scale * (xi * H.hazard benchmark))
    (himproves : academicMeritImproves ↔ fullMerit ≤ subMerit) :
    academicMeritImproves ↔
      H.hazard beta ≤ xi * H.hazard benchmark := by
  rw [himproves, hfull, hsub]
  constructor
  · intro h
    have hmul :
        scale * H.hazard beta ≤
          scale * (xi * H.hazard benchmark) := by
      linarith
    exact le_of_mul_le_mul_of_pos_left hmul hscale_pos
  · intro h
    have hmul :
        scale * H.hazard beta ≤
          scale * (xi * H.hazard benchmark) :=
      mul_le_mul_of_nonneg_left h hscale_pos.le
    linarith

/--
Pointwise version of
`paper_theorem1_academic_merit_improves_iff_hazard_of_tail_mean`.
-/
theorem paper_theorem1_academic_merit_improves_iff_hazard_of_tail_mean_on_Icc
    (H : GaussianHazardInverseCertificate)
    {academicMeritImproves : ℝ → Prop}
    {fullMerit : ℝ → ℝ}
    {subMerit base scale xi benchmark : ℝ} {beta : ℝ → ℝ}
    (hscale_pos : 0 < scale)
    (hfull :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMerit γ = base + scale * H.hazard (beta γ))
    (hsub :
      subMerit = base + scale * (xi * H.hazard benchmark))
    (himproves :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γ ↔ fullMerit γ ≤ subMerit) :
    ∀ γ ∈ Set.Icc (0 : ℝ) 1,
      academicMeritImproves γ ↔
        H.hazard (beta γ) ≤ xi * H.hazard benchmark := by
  intro γ hγ
  exact paper_theorem1_academic_merit_improves_iff_hazard_of_tail_mean
    H hscale_pos (hfull γ hγ) hsub (himproves γ hγ)

/-- Theorem 1 quantile argument lies in the true normal-quantile domain. -/
private theorem theorem1_quantile_arg_mem_Ioo
    {capacity mass : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hselective : 2 * capacity < mass) :
    1 - capacity / mass ∈ Set.Ioo (0 : ℝ) 1 := by
  have hmass_pos : 0 < mass := by nlinarith
  have hdiv_pos : 0 < capacity / mass := div_pos hcapacity_pos hmass_pos
  have hcapacity_lt_mass : capacity < mass := by nlinarith
  have hdiv_lt_one : capacity / mass < (1 : ℝ) := by
    rw [div_lt_iff₀ hmass_pos]
    simpa using hcapacity_lt_mass
  exact ⟨by linarith, by linarith⟩

/--
Theorem 1 analytic support: the displayed `β_A` access expression is
continuous on `[0,1]` under the source's selective eligible-pool condition,
which keeps the true normal-quantile argument inside `(0,1)`.
-/
theorem paper_theorem1_beta_groupA_continuousOn
    (Q : StandardGaussianQuantileAPI)
    {capacity ownShare otherEligibleMass rho : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hselective :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShare * γ + otherEligibleMass) :
    ContinuousOn
      (theorem1BetaGroupA Q capacity ownShare otherEligibleMass rho)
      (Set.Icc (0 : ℝ) 1) := by
  unfold theorem1BetaGroupA theorem1BetaGroupAFactor
  let s : Set ℝ := Set.Icc 0 1
  have hden :
      ∀ γ ∈ s, ownShare * γ + otherEligibleMass ≠ 0 := by
    intro γ hγ
    exact ne_of_gt (by nlinarith [hcapacity_pos, hselective γ hγ])
  have hlinear :
      ContinuousOn (fun γ : ℝ => ownShare * γ + otherEligibleMass) s := by
    fun_prop
  have htail_arg :
      ContinuousOn
        (fun γ : ℝ => 1 - capacity / (ownShare * γ + otherEligibleMass)) s :=
    continuousOn_const.sub (continuousOn_const.div hlinear hden)
  have hquantile :
      ContinuousOn
        (fun γ : ℝ =>
          Q.quantile (1 - capacity / (ownShare * γ + otherEligibleMass))) s :=
    Q.quantile_continuous.comp htail_arg (by
      intro γ hγ
      exact theorem1_quantile_arg_mem_Ioo hcapacity_pos (hselective γ hγ))
  have hfrac :
      ContinuousOn
        (fun γ : ℝ =>
          (ownShare * γ + otherEligibleMass * rho) /
            (ownShare * γ + otherEligibleMass)) s := by
    have hnum :
        ContinuousOn
          (fun γ : ℝ => ownShare * γ + otherEligibleMass * rho) s := by
      fun_prop
    exact hnum.div hlinear hden
  exact hquantile.mul hfrac.sqrt

/--
Theorem 1 analytic support: the displayed `β_B` access expression is
continuous on `[0,1]` under the source's selective eligible-pool condition,
which keeps the true normal-quantile argument inside `(0,1)`.
-/
theorem paper_theorem1_beta_groupB_continuousOn
    (Q : StandardGaussianQuantileAPI)
    {capacity ownShare otherEligibleMass rho : ℝ}
