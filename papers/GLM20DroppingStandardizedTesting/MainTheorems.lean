    intro hcutA hnotB
    have hobjective_merit := honlyA_merit hcutA hnotB
    have hmerit_cost := hle groupA (testCost groupA) (hcostMem groupA)
    have hpos : 0 < lowCostThreshold groupA := (hmem groupA).1
    have hsep : lowCostThreshold groupA < highCostThreshold groupA :=
      hrootBelowHigh groupA (lowCostThreshold groupA) (hmem groupA)
