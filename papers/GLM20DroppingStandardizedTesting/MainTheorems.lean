    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {diversityLevel groupBPopulationShare capacity mu qFull : ℝ}
    {sigmaTildeA sigmaTildeB aA aB bA bB tauA tauB : ℝ}
