/--
Weighted-objective bookkeeping: if group `A` contributes zero under a policy
pair, the two-group weighted objective is the group-`B` contribution.
-/
theorem glm20TwoGroupWeightedAcademicMeritObjective_eq_groupB_of_groupA_zero
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB : Group) (populationShare : Group → ℝ)
    (P1 P2 : Policy)
    (hzeroA :
      populationShare groupA *
          S.admittedAcademicMerit J groupA (policyPair P1 P2) = 0) :
    glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1 P2 =
      populationShare groupB *
        S.admittedAcademicMerit J groupB (policyPair P1 P2) := by
  simp [glm20TwoGroupWeightedAcademicMeritObjective,
    glm20TwoGroupWeightedAcademicMerit, hzeroA]

/--
Weighted-objective bookkeeping from a zero admitted-merit term: if group `A`
has zero admitted merit under a policy pair, the two-group objective is the
group-`B` contribution.
-/
theorem glm20TwoGroupWeightedAcademicMeritObjective_eq_groupB_of_groupA_merit_zero
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB : Group) (populationShare : Group → ℝ)
    (P1 P2 : Policy)
    (hzeroA :
      S.admittedAcademicMerit J groupA (policyPair P1 P2) = 0) :
    glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1 P2 =
      populationShare groupB *
        S.admittedAcademicMerit J groupB (policyPair P1 P2) :=
    glm20TwoGroupWeightedAcademicMeritObjective_eq_groupB_of_groupA_zero
      S policyPair J groupA groupB populationShare P1 P2 (by simp [hzeroA])

/--
Weighted-objective bookkeeping: if group `B` contributes zero under a policy
pair, the two-group weighted objective is the group-`A` contribution.
-/
theorem glm20TwoGroupWeightedAcademicMeritObjective_eq_groupA_of_groupB_zero
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB : Group) (populationShare : Group → ℝ)
    (P1 P2 : Policy)
    (hzeroB :
      populationShare groupB *
          S.admittedAcademicMerit J groupB (policyPair P1 P2) = 0) :
    glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1 P2 =
      populationShare groupA *
        S.admittedAcademicMerit J groupA (policyPair P1 P2) := by
  simp [glm20TwoGroupWeightedAcademicMeritObjective,
    glm20TwoGroupWeightedAcademicMerit, hzeroB]

/--
Weighted-objective bookkeeping from a zero admitted-merit term: if group `B`
has zero admitted merit under a policy pair, the two-group objective is the
group-`A` contribution.
-/
theorem glm20TwoGroupWeightedAcademicMeritObjective_eq_groupA_of_groupB_merit_zero
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB : Group) (populationShare : Group → ℝ)
    (P1 P2 : Policy)
    (hzeroB :
      S.admittedAcademicMerit J groupB (policyPair P1 P2) = 0) :
    glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1 P2 =
      populationShare groupA *
        S.admittedAcademicMerit J groupA (policyPair P1 P2) :=
    glm20TwoGroupWeightedAcademicMeritObjective_eq_groupA_of_groupB_zero
      S policyPair J groupA groupB populationShare P1 P2 (by simp [hzeroB])

/--
Weighted-objective cancellation for the group-`A` term.

If group `B`'s admitted academic merit is the same under two policy pairs,
then the two-group weighted objective comparison is exactly the group-`A`
admitted-merit comparison, provided group `A` has positive population weight.
This is the algebraic source of the exactly-one-group reductions in
Proposition 5.
-/
theorem glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupA_of_groupB_eq
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB : Group) (populationShare : Group → ℝ)
    (P1 P2 P1' P2' : Policy)
    (hshareA : 0 < populationShare groupA)
    (hgroupB :
      S.admittedAcademicMerit J groupB (policyPair P1 P2) =
        S.admittedAcademicMerit J groupB (policyPair P1' P2')) :
    (glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1 P2 ≤
      glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1' P2') ↔
      S.admittedAcademicMerit J groupA (policyPair P1 P2) ≤
        S.admittedAcademicMerit J groupA (policyPair P1' P2') := by
  unfold glm20TwoGroupWeightedAcademicMeritObjective
    glm20TwoGroupWeightedAcademicMerit
  rw [hgroupB]
  constructor
  · intro h
    nlinarith [hshareA, h]
  · intro h
    have hmul :
        populationShare groupA *
            S.admittedAcademicMerit J groupA (policyPair P1 P2) ≤
          populationShare groupA *
            S.admittedAcademicMerit J groupA (policyPair P1' P2') :=
      mul_le_mul_of_nonneg_left h hshareA.le
    nlinarith [hmul]

/--
Weighted-objective cancellation for the group-`B` term.

If group `A`'s admitted academic merit is the same under two policy pairs,
then the two-group weighted objective comparison is exactly the group-`B`
admitted-merit comparison, provided group `B` has positive population weight.
-/
theorem glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupB_of_groupA_eq
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB : Group) (populationShare : Group → ℝ)
    (P1 P2 P1' P2' : Policy)
    (hshareB : 0 < populationShare groupB)
    (hgroupA :
      S.admittedAcademicMerit J groupA (policyPair P1 P2) =
        S.admittedAcademicMerit J groupA (policyPair P1' P2')) :
    (glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1 P2 ≤
      glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1' P2') ↔
      S.admittedAcademicMerit J groupB (policyPair P1 P2) ≤
        S.admittedAcademicMerit J groupB (policyPair P1' P2') := by
  unfold glm20TwoGroupWeightedAcademicMeritObjective
    glm20TwoGroupWeightedAcademicMerit
  rw [hgroupA]
  constructor
  · intro h
    nlinarith [hshareB, h]
  · intro h
    have hmul :
        populationShare groupB *
            S.admittedAcademicMerit J groupB (policyPair P1 P2) ≤
          populationShare groupB *
        S.admittedAcademicMerit J groupB (policyPair P1' P2') :=
      mul_le_mul_of_nonneg_left h hshareB.le
    nlinarith [hmul]

/--
Weighted-objective cancellation and formula rewrite for group `A`.

This is the exact algebra needed when the paper's case split says that group
`B`'s contribution is unchanged and the two group-`A` merit terms are the
displayed test-based and test-free formulas.
-/
theorem
    glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupA_formula_of_groupB_eq
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB : Group) (populationShare : Group → ℝ)
    (P1 P2 P1' P2' : Policy) {lhs rhs : ℝ}
    (hshareA : 0 < populationShare groupA)
    (hgroupB :
      S.admittedAcademicMerit J groupB (policyPair P1 P2) =
        S.admittedAcademicMerit J groupB (policyPair P1' P2'))
    (hlhs :
      S.admittedAcademicMerit J groupA (policyPair P1 P2) = lhs)
    (hrhs :
      S.admittedAcademicMerit J groupA (policyPair P1' P2') = rhs) :
    (glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1 P2 ≤
      glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1' P2') ↔
      lhs ≤ rhs := by
  rw [glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupA_of_groupB_eq
    S policyPair J groupA groupB populationShare P1 P2 P1' P2'
    hshareA hgroupB, hlhs, hrhs]

/--
Weighted-objective cancellation and formula rewrite for group `B`.

This is the symmetric source-algebra bridge for exactly-one-group cases where
group `A`'s contribution is unchanged.
-/
theorem
    glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupB_formula_of_groupA_eq
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB : Group) (populationShare : Group → ℝ)
    (P1 P2 P1' P2' : Policy) {lhs rhs : ℝ}
    (hshareB : 0 < populationShare groupB)
    (hgroupA :
      S.admittedAcademicMerit J groupA (policyPair P1 P2) =
        S.admittedAcademicMerit J groupA (policyPair P1' P2'))
    (hlhs :
      S.admittedAcademicMerit J groupB (policyPair P1 P2) = lhs)
    (hrhs :
      S.admittedAcademicMerit J groupB (policyPair P1' P2') = rhs) :
    (glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1 P2 ≤
      glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1' P2') ↔
      lhs ≤ rhs := by
  rw [glm20TwoGroupWeightedAcademicMeritObjective_le_iff_groupB_of_groupA_eq
    S policyPair J groupA groupB populationShare P1 P2 P1' P2'
    hshareB hgroupA, hlhs, hrhs]

/--
Weighted-objective monotonicity: if both group-specific admitted academic
merits strictly increase and the two population shares are positive, then the
paper's two-group weighted objective strictly increases.
-/
theorem glm20TwoGroupWeightedAcademicMeritObjective_lt_of_groupwise_lt
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB : Group) (populationShare : Group → ℝ)
    (P1 P2 P1' P2' : Policy)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hA :
      S.admittedAcademicMerit J groupA (policyPair P1 P2) <
        S.admittedAcademicMerit J groupA (policyPair P1' P2'))
    (hB :
      S.admittedAcademicMerit J groupB (policyPair P1 P2) <
        S.admittedAcademicMerit J groupB (policyPair P1' P2')) :
    glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1 P2 <
      glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
        groupA groupB populationShare P1' P2' := by
  unfold glm20TwoGroupWeightedAcademicMeritObjective
    glm20TwoGroupWeightedAcademicMerit
  exact
    add_lt_add
      (mul_lt_mul_of_pos_left hA hshareA)
      (mul_lt_mul_of_pos_left hB hshareB)

/--
Proposition 5 fixed-pool branch support.  If no group satisfies the relevant
cutoff-expansion case and, under that fixed pool, each group's admitted merit
is strictly higher under the keep-test policy pair than under the drop-test
policy pair, then the school has no incentive to drop.

This is the Lean version of the source proof's Case (2) appeal to Theorem 2:
with the applicant pool fixed, the full signal strictly improves academic
merit.
-/
theorem
    paper_proposition5_no_group_expands_no_drop_of_weighted_groupwise_merit_lt
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB : Group) (populationShare : Group → ℝ)
    (Pdrop1 Pdrop2 Pkeep1 Pkeep2 : Policy)
    {q : ℝ} {cutoff : Group → ℝ}
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmeritA :
      ¬ q < cutoff groupA →
        ¬ q < cutoff groupB →
          S.admittedAcademicMerit J groupA (policyPair Pdrop1 Pdrop2) <
            S.admittedAcademicMerit J groupA (policyPair Pkeep1 Pkeep2))
    (hmeritB :
      ¬ q < cutoff groupA →
        ¬ q < cutoff groupB →
          S.admittedAcademicMerit J groupB (policyPair Pdrop1 Pdrop2) <
            S.admittedAcademicMerit J groupB (policyPair Pkeep1 Pkeep2)) :
    ¬ q < cutoff groupA →
      ¬ q < cutoff groupB →
        ¬ glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
              groupA groupB populationShare Pkeep1 Pkeep2 ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
              groupA groupB populationShare Pdrop1 Pdrop2 := by
  intro hnotA hnotB hle
  have hlt :
      glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
          groupA groupB populationShare Pdrop1 Pdrop2 <
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J
          groupA groupB populationShare Pkeep1 Pkeep2 :=
    glm20TwoGroupWeightedAcademicMeritObjective_lt_of_groupwise_lt
      S policyPair J groupA groupB populationShare Pdrop1 Pdrop2
      Pkeep1 Pkeep2 hshareA hshareB (hmeritA hnotA hnotB)
      (hmeritB hnotA hnotB)
  exact (not_lt_of_ge hle) hlt

/--
Generic objective-rewrite helper for Proposition 5 style proof steps.

Once the two policy-pair objective values are identified with the source's
displayed merit formulas, the objective comparison is just the corresponding
real inequality.
-/
theorem glm20_policy_pair_objective_le_iff_of_value_eq
    {Policy : Type*} (objective : Policy → Policy → ℝ)
    {P1 P2 P1' P2' : Policy} {lhs rhs : ℝ}
    (hlhs : objective P1 P2 = lhs) (hrhs : objective P1' P2' = rhs) :
    objective P1 P2 ≤ objective P1' P2' ↔ lhs ≤ rhs := by
  rw [hlhs, hrhs]

/--
Theorem 3 / Proposition 5 support: if school 2's test-keeping objective under
`(P_sub,P_full)` is a single surviving group contribution, and that
contribution is strictly larger than the weighted merit under `(P_sub,P_sub)`,
then school 2 weakly prefers keeping the test to dropping it.
-/
theorem paper_theorem3_school2_keep_test_objective_le_of_single_group_merit_gt
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J2 : School) (groupA groupB otherGroup : Group)
    (populationShare : Group → ℝ)
    (hsingle :
      glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
          groupA groupB populationShare Psub Pfull =
        populationShare otherGroup *
          S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull))
    (hsubsub :
      glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
          groupA groupB populationShare Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hmerit :
      populationShare otherGroup *
          S.admittedAcademicMerit J2 otherGroup (policyPair Psub Pfull) >
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :
    glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
        groupA groupB populationShare Psub Psub ≤
    glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
        groupA groupB populationShare Psub Pfull := by
  rw [hsingle, hsubsub]
  exact le_of_lt hmerit

/--
Section 5 strategic cutoff formula for a one-school full-policy application
decision.  If projected full-policy admission is
`1 - Φ((threshold - q) / scale)` and applying has cost/value ratio `α`, then
the indifferent projected-skill cutoff is
`threshold - scale * Φ⁻¹(1 - α)`.
-/
def glm20StrategicApplyCutoff
    (Q : StandardGaussianQuantileAPI)
    (admissionThreshold scale costRatio : ℝ) : ℝ := admissionThreshold - scale * Q.quantile (1 - costRatio)

/-- Student payoff for the binary apply/not-apply decision. -/
def glm20StrategicApplyPayoff
    (value cost admissionProbability : ℝ) (apply : Bool) : ℝ := if apply then value * admissionProbability - cost else 0

/--
Incremental payoff for the two-school application decision in Proposition 2.

Below the second school's test-free threshold, applying to the preferred
test-requiring school has value `v1`; above that threshold, the fallback value
`v2` is already available, so the incremental value is `v1 - v2`.
-/
def glm20StrategicTwoSchoolApplyPayoff
    (school2SubThreshold v1 v2 cost admissionProbability q : ℝ)
    (apply : Bool) : ℝ :=
  if apply then
    if q < school2SubThreshold then
      v1 * admissionProbability - cost
    else
      (v1 - v2) * admissionProbability - cost
  else
    0

/--
Proposition 2 low/high application region for the two-school case.

Students apply to `J1` either below `J2`'s test-free cutoff but above the low
cutoff, or above both `J2`'s cutoff and the high cutoff.
-/
def glm20StrategicTwoSchoolApplicationRegion
    (school2SubThreshold lowCutoff highCutoff q : ℝ) : Prop :=
  (q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
    (school2SubThreshold ≤ q ∧ highCutoff ≤ q)

/--
Capacity-realizing upper-threshold condition for an applicant-mass function.

This is the source shape of the school selection rule: the cutoff realizes
capacity and the capacity sublevel set is exactly the upper-threshold region.
-/
def glm20CapacityThreshold
    (applicantMass : ℝ → ℝ) (capacity threshold : ℝ) : Prop :=
  applicantMass threshold = capacity ∧
    ∀ z : ℝ, applicantMass z ≤ capacity ↔ threshold ≤ z

/--
Proposition 2 threshold-equilibrium object for fixed two-school applicant
mass functions.

The triple is `(J1 cutoff, J2 cutoff, student strategy)`.  The predicate
requires both school cutoffs to realize capacity and the student strategy to be
a pointwise best response using the paper's tie-breaking at the low and high
application cutoffs.
-/
def glm20Proposition2TwoSchoolThresholdEquilibrium
    (Q : StandardGaussianQuantileAPI)
    (applicantMass1 applicantMass2 : ℝ → ℝ)
    (capacity1 capacity2 scale cost v1 v2 : ℝ)
    (hscale : 0 < scale)
    (equilibrium : ℝ × ℝ × (ℝ → Bool)) : Prop :=
  let admissionThreshold := equilibrium.1
  let school2SubThreshold := equilibrium.2.1
  let strategy := equilibrium.2.2
  let lowCutoff :=
    glm20StrategicApplyCutoff Q admissionThreshold scale (cost / v1)
  let highCutoff :=
    glm20StrategicApplyCutoff Q admissionThreshold scale (cost / (v1 - v2))
  glm20CapacityThreshold applicantMass1 capacity1 admissionThreshold ∧
    glm20CapacityThreshold applicantMass2 capacity2 school2SubThreshold ∧
      (∀ q : ℝ, ∀ apply : Bool,
        glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold)
            q apply ≤
        glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold)
            q (strategy q)) ∧
        strategy lowCutoff =
          decide
            ((lowCutoff < school2SubThreshold ∧ lowCutoff ≤ lowCutoff) ∨
              (school2SubThreshold ≤ lowCutoff ∧ highCutoff ≤ lowCutoff)) ∧
          strategy highCutoff =
            decide
              ((highCutoff < school2SubThreshold ∧ lowCutoff ≤ highCutoff) ∨
                (school2SubThreshold ≤ highCutoff ∧ highCutoff ≤ highCutoff))

/--
Proposition 5 / equation (46) payoff expression when both schools require the
test.

For projected skill `q`, full-test projected scale `scale`, and school
thresholds `q1Full` and `q2Full`, this is
`v1 - c + (v2 - v1) Phi((q1Full-q)/scale)
  - v2 Phi((q2Full-q)/scale)`.
-/
def glm20StrategicTwoFullPolicyApplyPayoffValue
    (api : StandardGaussianCDFAPI)
    (q1Full q2Full scale v1 v2 cost q : ℝ) : ℝ :=
  v1 - cost +
    (v2 - v1) * api.cdf ((q1Full - q) / scale) -
      v2 * api.cdf ((q2Full - q) / scale)

/--
Proposition 5 payoff before expanding the Gaussian tail probability.

The first term is the value of admission to `J1`; the second is the fallback
value of admission to `J2` after failing `J1`, written as the CDF mass between
the two full-test school thresholds.
-/
def glm20StrategicTwoFullPolicyApplyExpectedPayoff
    (api : StandardGaussianCDFAPI)
    (q1Full q2Full scale v1 v2 cost q : ℝ) : ℝ :=
  v1 * (1 - api.cdf ((q1Full - q) / scale)) +
    v2 * (api.cdf ((q1Full - q) / scale) -
      api.cdf ((q2Full - q) / scale)) - cost

/--
Proposition 5 / equation (47) inverse-CDF argument.

Solving equation (46) for the CDF of the first-school cutoff gives
`Phi((q1Full-q)/scale) =
  (v1-cost)/(v1-v2) - (v2/(v1-v2)) Phi((q2Full-q)/scale)`.
Equation (47) applies `Phi^{-1}` to this probability.
-/
def glm20StrategicTwoFullPolicyEquation47QuantileArg
    (api : StandardGaussianCDFAPI)
    (q2Full scale v1 v2 cost q : ℝ) : ℝ :=
  (v1 - cost) / (v1 - v2) -
    (v2 / (v1 - v2)) * api.cdf ((q2Full - q) / scale)

/--
Proposition 5 support: expanding the two-school expected payoff gives the
source's displayed equation (46).
-/
theorem paper_proposition5_twoFull_apply_expected_payoff_eq_equation46
    (api : StandardGaussianCDFAPI)
    {q1Full q2Full scale v1 v2 cost q : ℝ} (hscale : 0 < scale) :
    (v1 * api.thresholdPassProb
        { mean := q, scale := scale, scale_pos := hscale } q1Full +
      v2 * (api.cdf ((q1Full - q) / scale) -
        api.cdf ((q2Full - q) / scale)) - cost) =
      glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
        scale v1 v2 cost q := by
  simp [glm20StrategicTwoFullPolicyApplyPayoffValue,
    StandardGaussianCDFAPI.thresholdPassProb,
    StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
    GaussianScaleLaw.standardize]
  ring

/--
Proposition 5 support: equation (47), derived from equation (46).

If the equation (47) inverse-CDF argument is in `(0,1)` and `q` is an
indifference point for the two-full-policy payoff, then `q` equals the paper's
displayed inverse-CDF formula.
-/
theorem paper_proposition5_equation47_cutoff_formula_of_twoFull_payoff_zero
    (Q : StandardGaussianQuantileAPI)
    {q1Full q2Full scale v1 v2 cost q : ℝ}
    (hscale : 0 < scale) (hv2_lt_v1 : v2 < v1)
    (hprob :
      glm20StrategicTwoFullPolicyEquation47QuantileArg Q.cdfAPI
        q2Full scale v1 v2 cost q ∈ Set.Ioo (0 : ℝ) 1)
    (hzero :
      glm20StrategicTwoFullPolicyApplyPayoffValue Q.cdfAPI
        q1Full q2Full scale v1 v2 cost q = 0) :
    q = q1Full - scale *
      Q.quantile
        (glm20StrategicTwoFullPolicyEquation47QuantileArg Q.cdfAPI
          q2Full scale v1 v2 cost q) := by
  let p :=
    glm20StrategicTwoFullPolicyEquation47QuantileArg Q.cdfAPI
      q2Full scale v1 v2 cost q
  have hden_pos : 0 < v1 - v2 := sub_pos.mpr hv2_lt_v1
  have hcdf_eq :
      Q.cdfAPI.cdf ((q1Full - q) / scale) = p := by
    dsimp [p, glm20StrategicTwoFullPolicyEquation47QuantileArg,
      glm20StrategicTwoFullPolicyApplyPayoffValue] at hzero ⊢
    field_simp [ne_of_gt hden_pos]
    linarith
  have hquantile : Q.cdfAPI.cdf (Q.quantile p) = p :=
    Q.cdf_quantile hprob
  have hz_eq : (q1Full - q) / scale = Q.quantile p :=
    Q.cdfAPI.cdf_strictMono.injective (by rw [hcdf_eq, hquantile])
  have hmul : q1Full - q = scale * Q.quantile p := by
    have hz := hz_eq
    field_simp [ne_of_gt hscale] at hz
    linarith
  change q = q1Full - scale * Q.quantile p
  linarith

/--
Proposition 5 support: the two-full-policy test-taking payoff in equation
(46) is strictly increasing in projected skill.

The proof uses only that `Phi` is strictly increasing, the standardized
cutoffs `(q_i-q)/scale` strictly decrease in `q`, and `0 < v2 < v1`.
-/
theorem paper_proposition5_twoFull_apply_payoff_strictMono_projectedSkill
    (api : StandardGaussianCDFAPI)
    {q1Full q2Full scale v1 v2 cost : ℝ}
    (hscale : 0 < scale) (hv2_pos : 0 < v2) (hv2_lt_v1 : v2 < v1) :
    StrictMono
      (glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
        scale v1 v2 cost) := by
  intro q q' hqq'
  have hz1 :
      (q1Full - q') / scale < (q1Full - q) / scale := by
    rw [div_lt_div_iff₀ hscale hscale]
    nlinarith
  have hz2 :
      (q2Full - q') / scale < (q2Full - q) / scale := by
    rw [div_lt_div_iff₀ hscale hscale]
    nlinarith
  have hcdf1 :
      api.cdf ((q1Full - q') / scale) <
        api.cdf ((q1Full - q) / scale) :=
    api.cdf_strictMono hz1
  have hcdf2 :
      api.cdf ((q2Full - q') / scale) <
        api.cdf ((q2Full - q) / scale) :=
    api.cdf_strictMono hz2
  have hcoef1 : v2 - v1 < 0 := by linarith
  have hcoef2 : -v2 < 0 := by linarith
  have hterm1 :
      (v2 - v1) * api.cdf ((q1Full - q) / scale) <
        (v2 - v1) * api.cdf ((q1Full - q') / scale) :=
    mul_lt_mul_of_neg_left hcdf1 hcoef1
  have hterm2 :
      -v2 * api.cdf ((q2Full - q) / scale) <
        -v2 * api.cdf ((q2Full - q') / scale) :=
    mul_lt_mul_of_neg_left hcdf2 hcoef2
  dsimp [glm20StrategicTwoFullPolicyApplyPayoffValue]
  linarith

/--
Proposition 5 support: the full/full student test-taking cutoff is strictly
increasing in the test cost.

This proves the monotonicity statement used after equation (47).  Since cost
enters equation (46) as `-c`, increasing cost shifts the payoff down
pointwise.  With strict monotonicity in projected skill, the zero of the payoff
must move to the right.
-/
theorem paper_proposition5_twoFull_apply_payoff_cutoff_strictMono_cost
    (api : StandardGaussianCDFAPI)
    {q1Full q2Full scale v1 v2 costLow costHigh cutoffLow cutoffHigh : ℝ}
    (hscale : 0 < scale) (hv2_pos : 0 < v2) (hv2_lt_v1 : v2 < v1)
    (hcost : costLow < costHigh)
    (hcutoffLow :
      glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
        scale v1 v2 costLow cutoffLow = 0)
    (hcutoffHigh :
      glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
        scale v1 v2 costHigh cutoffHigh = 0) :
    cutoffLow < cutoffHigh := by
  have hmonoHigh :
      StrictMono
        (glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 costHigh) :=
    paper_proposition5_twoFull_apply_payoff_strictMono_projectedSkill
      api hscale hv2_pos hv2_lt_v1
  have hlow_at_high_cost :
      glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
        scale v1 v2 costHigh cutoffLow < 0 := by
    dsimp [glm20StrategicTwoFullPolicyApplyPayoffValue] at hcutoffLow ⊢
    linarith
  by_contra hnot
  have hle : cutoffHigh ≤ cutoffLow := le_of_not_gt hnot
  have hpayoff_le :
      glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
        scale v1 v2 costHigh cutoffHigh ≤
      glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
        scale v1 v2 costHigh cutoffLow :=
    hmonoHigh.monotone hle
  rw [hcutoffHigh] at hpayoff_le
  linarith

/--
Proposition 5 support: any selected full/full zero-payoff cutoff is strictly
increasing as a function of test cost.

This is the function-level version of
`paper_proposition5_twoFull_apply_payoff_cutoff_strictMono_cost`, matching the
source proof's statement that `q^g_{full,full}` is strictly increasing in
`c_g`.
-/
theorem paper_proposition5_twoFull_apply_payoff_cutoff_strictMonoOn_cost
    (api : StandardGaussianCDFAPI)
    {q1Full q2Full scale v1 v2 : ℝ} {costDomain : Set ℝ}
    {cutoffOfCost : ℝ → ℝ}
    (hscale : 0 < scale) (hv2_pos : 0 < v2) (hv2_lt_v1 : v2 < v1)
    (hzero :
      ∀ cost ∈ costDomain,
        glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost (cutoffOfCost cost) = 0) :
    StrictMonoOn cutoffOfCost costDomain := by
  intro costLow hcostLow costHigh hcostHigh hcost
  exact
    paper_proposition5_twoFull_apply_payoff_cutoff_strictMono_cost
      api hscale hv2_pos hv2_lt_v1 hcost
      (hzero costLow hcostLow) (hzero costHigh hcostHigh)

/--
Proposition 5 support: any selected full/full zero-payoff cutoff is continuous
in cost on its cost domain.

Equation (46) has the form `basePayoff(q) - c`; therefore a zero of the
cost-`c` payoff is a right inverse of the strictly increasing base payoff.
The reusable right-inverse continuity lemma then gives continuity of the
selected cutoff, removing the previous need to assume this regularity
separately.
-/
theorem paper_proposition5_twoFull_apply_payoff_cutoff_continuousOn_cost
    (api : StandardGaussianCDFAPI)
    {q1Full q2Full scale v1 v2 : ℝ} {costDomain : Set ℝ}
    {cutoffOfCost : ℝ → ℝ}
    (hscale : 0 < scale) (hv2_pos : 0 < v2) (hv2_lt_v1 : v2 < v1)
    (hzero :
      ∀ cost ∈ costDomain,
        glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost (cutoffOfCost cost) = 0) :
    ContinuousOn cutoffOfCost costDomain := by
  let basePayoff : ℝ → ℝ :=
    glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
      scale v1 v2 0
  have hbase_mono : StrictMono basePayoff :=
    paper_proposition5_twoFull_apply_payoff_strictMono_projectedSkill
      api hscale hv2_pos hv2_lt_v1
  have hroot :
      ∀ cost ∈ costDomain, basePayoff (cutoffOfCost cost) = cost := by
    intro cost hcost
    have hzero_cost := hzero cost hcost
    dsimp [basePayoff, glm20StrategicTwoFullPolicyApplyPayoffValue] at hzero_cost ⊢
    linarith
  exact EconCSLib.continuousOn_rightInverse_of_strictMono hbase_mono hroot

/--
Proposition 5 support: if the equation (46) payoff is negative somewhere and
positive somewhere, then the full/full test-taking strategy has a unique
projected-skill cutoff, and applying is weakly optimal exactly above it.
-/
theorem paper_proposition5_twoFull_apply_payoff_cutoff_existsUnique_of_crossing
    (api : StandardGaussianCDFAPI)
    {q1Full q2Full scale v1 v2 cost : ℝ}
    (hscale : 0 < scale) (hv2_pos : 0 < v2) (hv2_lt_v1 : v2 < v1)
    (hneg :
      ∃ q : ℝ,
        glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost q < 0)
    (hpos :
      ∃ q : ℝ,
        0 < glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost q) :
    ∃! cutoff : ℝ,
      glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost cutoff = 0 ∧
        ∀ q : ℝ,
          0 ≤ glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
              scale v1 v2 cost q ↔
            cutoff ≤ q := by
  have hcont :
      Continuous
        (glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost) := by
    have harg1 : Continuous fun q : ℝ => (q1Full - q) / scale :=
      (continuous_const.sub continuous_id).div_const scale
    have harg2 : Continuous fun q : ℝ => (q2Full - q) / scale :=
      (continuous_const.sub continuous_id).div_const scale
    have hcdf1 :
        Continuous fun q : ℝ => api.cdf ((q1Full - q) / scale) :=
      api.cdf_continuous.comp harg1
    have hcdf2 :
        Continuous fun q : ℝ => api.cdf ((q2Full - q) / scale) :=
      api.cdf_continuous.comp harg2
    have hbase : Continuous fun _q : ℝ => v1 - cost := continuous_const
    have hterm1 :
        Continuous fun q : ℝ =>
          (v2 - v1) * api.cdf ((q1Full - q) / scale) :=
      continuous_const.mul hcdf1
    have hterm2 :
        Continuous fun q : ℝ =>
          v2 * api.cdf ((q2Full - q) / scale) :=
      continuous_const.mul hcdf2
    simpa [glm20StrategicTwoFullPolicyApplyPayoffValue] using
      (hbase.add hterm1).sub hterm2
  have hmono :
      StrictMono
        (glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost) :=
    paper_proposition5_twoFull_apply_payoff_strictMono_projectedSkill
      api hscale hv2_pos hv2_lt_v1
  exact
    existsUnique_zero_and_nonneg_iff_of_continuous_strictMono_crossing
      hcont hmono hneg hpos

/--
Proposition 5 support: under standard Gaussian tail limits and `0 < cost < v1`,
the equation (46) payoff is negative somewhere and positive somewhere.
-/
theorem paper_proposition5_twoFull_apply_payoff_crosses_zero_of_tail_limits
    (api : StandardGaussianCDFAPI)
    (hcdf_atBot : Filter.Tendsto api.cdf Filter.atBot (nhds 0))
    (hcdf_atTop : Filter.Tendsto api.cdf Filter.atTop (nhds 1))
    {q1Full q2Full scale v1 v2 cost : ℝ}
    (hscale : 0 < scale) (hcost_pos : 0 < cost) (hcost_lt_v1 : cost < v1) :
    (∃ q : ℝ,
      glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
        scale v1 v2 cost q < 0) ∧
      (∃ q : ℝ,
        0 < glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost q) := by
  have hcoef_neg : -scale⁻¹ < 0 := by
    have hscale_inv_pos : 0 < scale⁻¹ := inv_pos.mpr hscale
    linarith
  have harg_atTop :
      ∀ threshold : ℝ,
        Filter.Tendsto (fun q : ℝ => (threshold - q) / scale)
          Filter.atTop Filter.atBot := by
    intro threshold
    have hlin :
        Filter.Tendsto (fun q : ℝ => (-scale⁻¹) * q + threshold / scale)
          Filter.atTop Filter.atBot :=
      (Filter.Tendsto.const_mul_atTop_of_neg hcoef_neg
        Filter.tendsto_id).atBot_add tendsto_const_nhds
    convert hlin using 1
    ext q
    field_simp [ne_of_gt hscale]
    ring
  have harg_atBot :
      ∀ threshold : ℝ,
        Filter.Tendsto (fun q : ℝ => (threshold - q) / scale)
          Filter.atBot Filter.atTop := by
    intro threshold
    have hlin :
        Filter.Tendsto (fun q : ℝ => (-scale⁻¹) * q + threshold / scale)
          Filter.atBot Filter.atTop :=
      (Filter.Tendsto.const_mul_atBot_of_neg hcoef_neg
        Filter.tendsto_id).atTop_add tendsto_const_nhds
    convert hlin using 1
    ext q
    field_simp [ne_of_gt hscale]
    ring
  have hcdf1_atTop :
      Filter.Tendsto (fun q : ℝ => api.cdf ((q1Full - q) / scale))
        Filter.atTop (nhds 0) :=
    hcdf_atBot.comp (harg_atTop q1Full)
  have hcdf2_atTop :
      Filter.Tendsto (fun q : ℝ => api.cdf ((q2Full - q) / scale))
        Filter.atTop (nhds 0) :=
    hcdf_atBot.comp (harg_atTop q2Full)
  have hpayoff_atTop :
      Filter.Tendsto
        (glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost)
        Filter.atTop (nhds (v1 - cost)) := by
    have hbase :
        Filter.Tendsto (fun _q : ℝ => v1 - cost)
          Filter.atTop (nhds (v1 - cost)) :=
      tendsto_const_nhds
    have hterm1 :
        Filter.Tendsto
          (fun q : ℝ => (v2 - v1) * api.cdf ((q1Full - q) / scale))
          Filter.atTop (nhds ((v2 - v1) * 0)) :=
      tendsto_const_nhds.mul hcdf1_atTop
    have hterm2 :
        Filter.Tendsto
          (fun q : ℝ => v2 * api.cdf ((q2Full - q) / scale))
          Filter.atTop (nhds (v2 * 0)) :=
      tendsto_const_nhds.mul hcdf2_atTop
    simpa [glm20StrategicTwoFullPolicyApplyPayoffValue] using
      (hbase.add hterm1).sub hterm2
  have hcdf1_atBot :
      Filter.Tendsto (fun q : ℝ => api.cdf ((q1Full - q) / scale))
        Filter.atBot (nhds 1) :=
    hcdf_atTop.comp (harg_atBot q1Full)
  have hcdf2_atBot :
      Filter.Tendsto (fun q : ℝ => api.cdf ((q2Full - q) / scale))
        Filter.atBot (nhds 1) :=
    hcdf_atTop.comp (harg_atBot q2Full)
  have hpayoff_atBot :
      Filter.Tendsto
        (glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost)
        Filter.atBot (nhds (-cost)) := by
    have hbase :
        Filter.Tendsto (fun _q : ℝ => v1 - cost)
          Filter.atBot (nhds (v1 - cost)) :=
      tendsto_const_nhds
    have hterm1 :
        Filter.Tendsto
          (fun q : ℝ => (v2 - v1) * api.cdf ((q1Full - q) / scale))
          Filter.atBot (nhds ((v2 - v1) * 1)) :=
      tendsto_const_nhds.mul hcdf1_atBot
    have hterm2 :
        Filter.Tendsto
          (fun q : ℝ => v2 * api.cdf ((q2Full - q) / scale))
          Filter.atBot (nhds (v2 * 1)) :=
      tendsto_const_nhds.mul hcdf2_atBot
    have hlim : v1 - cost + (v2 - v1) * 1 - v2 * 1 = -cost := by
      ring
    simpa [glm20StrategicTwoFullPolicyApplyPayoffValue, hlim] using
      (hbase.add hterm1).sub hterm2
  constructor
  · have hneg_eventually :
        ∀ᶠ q in Filter.atBot,
          glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
            scale v1 v2 cost q < 0 :=
      hpayoff_atBot.eventually (eventually_lt_nhds (by linarith))
    exact hneg_eventually.exists
  · have hpos_eventually :
        ∀ᶠ q in Filter.atTop,
          0 < glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
            scale v1 v2 cost q :=
      hpayoff_atTop.eventually (eventually_gt_nhds (by linarith))
    exact hpos_eventually.exists

/--
Proposition 5 support: under standard Gaussian tail limits, `0 < cost < v1`,
and `0 < v2 < v1`, equation (46) has a unique projected-skill cutoff and
test-taking is weakly optimal exactly above it.
-/
theorem paper_proposition5_twoFull_apply_payoff_cutoff_existsUnique_of_tail_limits
    (api : StandardGaussianCDFAPI)
    (hcdf_atBot : Filter.Tendsto api.cdf Filter.atBot (nhds 0))
    (hcdf_atTop : Filter.Tendsto api.cdf Filter.atTop (nhds 1))
    {q1Full q2Full scale v1 v2 cost : ℝ}
    (hscale : 0 < scale) (hcost_pos : 0 < cost) (hcost_lt_v1 : cost < v1)
    (hv2_pos : 0 < v2) (hv2_lt_v1 : v2 < v1) :
    ∃! cutoff : ℝ,
      glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
          scale v1 v2 cost cutoff = 0 ∧
        ∀ q : ℝ,
          0 ≤ glm20StrategicTwoFullPolicyApplyPayoffValue api q1Full q2Full
              scale v1 v2 cost q ↔
            cutoff ≤ q := by
  rcases
    paper_proposition5_twoFull_apply_payoff_crosses_zero_of_tail_limits
      api hcdf_atBot hcdf_atTop hscale hcost_pos hcost_lt_v1 with
    ⟨hneg, hpos⟩
  exact
    paper_proposition5_twoFull_apply_payoff_cutoff_existsUnique_of_crossing
      api hscale hv2_pos hv2_lt_v1 hneg hpos

/--
Proposition 5 support for the mathlib-backed standard Gaussian CDF: equation
(46) has a unique projected-skill cutoff and test-taking is weakly optimal
exactly above it.
-/
theorem paper_proposition5_standardGaussian_twoFull_apply_payoff_cutoff_existsUnique
    {q1Full q2Full scale v1 v2 cost : ℝ}
    (hscale : 0 < scale) (hcost_pos : 0 < cost) (hcost_lt_v1 : cost < v1)
    (hv2_pos : 0 < v2) (hv2_lt_v1 : v2 < v1) :
    ∃! cutoff : ℝ,
      glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          q1Full q2Full scale v1 v2 cost cutoff = 0 ∧
