    {admissionThreshold school2SubThreshold
      priorPrecision subPrecision testPrecision cost v1 v2 : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioLow : cost / v1 ∈ Set.Ioo (0 : ℝ) 1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ lowCutoff highCutoff : ℝ,
      lowCutoff =
        admissionThreshold -
          glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision *
              Q.quantile (1 - cost / v1) ∧
      highCutoff =
        admissionThreshold -
          glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision *
              Q.quantile (1 - cost / (v1 - v2)) ∧
      lowCutoff < highCutoff ∧
      ∀ strategy : ℝ → Bool,
        (∀ q : ℝ, ∀ apply : Bool,
          glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
              (Q.cdfAPI.thresholdPassProb
                { mean := q
                  scale :=
                    glm20StrategicProjectedScale
                      priorPrecision subPrecision testPrecision
                  scale_pos :=
                    glm20StrategicProjectedScale_pos
                      hprior_pos hsub_pos htest_pos }
                admissionThreshold)
              q apply ≤
            glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
              (Q.cdfAPI.thresholdPassProb
                { mean := q
                  scale :=
                    glm20StrategicProjectedScale
                      priorPrecision subPrecision testPrecision
                  scale_pos :=
                    glm20StrategicProjectedScale_pos
                      hprior_pos hsub_pos htest_pos }
                admissionThreshold)
              q (strategy q)) →
        strategy lowCutoff =
          decide
            ((lowCutoff < school2SubThreshold ∧ lowCutoff ≤ lowCutoff) ∨
              (school2SubThreshold ≤ lowCutoff ∧ highCutoff ≤ lowCutoff)) →
        strategy highCutoff =
          decide
            ((highCutoff < school2SubThreshold ∧ lowCutoff ≤ highCutoff) ∨
              (school2SubThreshold ≤ highCutoff ∧ highCutoff ≤ highCutoff)) →
        strategy =
          fun q : ℝ =>
            decide
              ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
                (school2SubThreshold ≤ q ∧ highCutoff ≤ q)) := by
  let scale :=
    glm20StrategicProjectedScale priorPrecision subPrecision testPrecision
  have hscale : 0 < scale :=
    glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos
  rcases
    paper_proposition2_two_school_application_region_unique_strategy_standardGaussian
      Q (admissionThreshold := admissionThreshold)
      (school2SubThreshold := school2SubThreshold) (scale := scale)
      (cost := cost) (v1 := v1) (v2 := v2)
      hscale hcost hv1 hdiff_pos hdiff_lt_v1
      hcostRatioLow hcostRatioHigh with
    ⟨lowCutoff, highCutoff, hlow, hhigh, hlt, hunique⟩
  refine ⟨lowCutoff, highCutoff, ?_, ?_, hlt, ?_⟩
  · simpa [scale, glm20StrategicApplyCutoff] using hlow
  · simpa [scale, glm20StrategicApplyCutoff] using hhigh
  · exact hunique

/--
