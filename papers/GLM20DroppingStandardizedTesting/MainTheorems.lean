/--
Theorem 1(ii), group-B academic-merit threshold from explicit Gaussian
upper-tail laws.  This is the group-B analogue of
`paper_theorem1_academic_merit_access_threshold_of_groupA_normal_laws_main`.
-/
theorem paper_theorem1_academic_merit_access_threshold_of_groupB_normal_laws_main
    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    {capacity ownShare otherEligibleMass rho xi benchmark base scale : ℝ}
    {Lfull : ℝ → GaussianScaleLaw} {thresholdFull : ℝ → ℝ}
    {Lsub : GaussianScaleLaw} {thresholdSub subMerit : ℝ}
    {fullMerit : ℝ → ℝ} {academicMeritImproves : ℝ → Prop}
    (hfullMerit :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMerit γ = H.normalUpperTailMean (Lfull γ) (thresholdFull γ))
    (hfull_mean :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, (Lfull γ).mean = base)
    (hfull_scale :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, (Lfull γ).scale = scale)
    (hfull_standardize :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        (Lfull γ).standardize (thresholdFull γ) =
          theorem1BetaGroupB Q capacity ownShare otherEligibleMass rho γ)
    (hsubMerit :
      subMerit = H.normalUpperTailMean Lsub thresholdSub)
    (hsub_mean : Lsub.mean = base)
    (hsub_scale : Lsub.scale = scale * xi)
    (hsub_standardize : Lsub.standardize thresholdSub = benchmark)
    (himproves :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γ ↔ fullMerit γ ≤ subMerit)
    (hscale_pos : 0 < scale)
    (hxi_pos : 0 < xi)
    (hcapacity_pos : 0 < capacity)
    (hown_pos : 0 < ownShare)
    (hother_pos : 0 < otherEligibleMass)
    (hone_lt_rho : 1 < rho)
    (hselective :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShare * γ + otherEligibleMass) :
    ∃ γbar : ℝ,
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γ ↔ γ ≤ γbar := by
  have hfull :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMerit γ =
          base + scale *
            H.hazard
              (theorem1BetaGroupB Q capacity ownShare otherEligibleMass rho γ) := by
    intro γ hγ
    rw [hfullMerit γ hγ, GaussianHazardCertificate.normalUpperTailMean,
      hfull_mean γ hγ, hfull_scale γ hγ, hfull_standardize γ hγ]
  have hsub :
      subMerit = base + scale * (xi * H.hazard benchmark) := by
    rw [hsubMerit, GaussianHazardCertificate.normalUpperTailMean,
      hsub_mean, hsub_scale, hsub_standardize]
    ring
  exact
    paper_theorem1_academic_merit_access_threshold_of_groupB_tail_mean_main
      H Q hxi_pos hscale_pos hfull hsub himproves hcapacity_pos hown_pos hother_pos
      hone_lt_rho hselective

/--
Theorem 1 main-body bundle, non-strategic access-barrier case.

Paper statement: with access barriers, holding other parameters fixed, there
is a group-B access threshold for diversity and, for each group, an access
threshold for group academic merit.  This bundled theorem uses the source proof
route already formalized above:

* diversity comes from the barrier capacity equations and the diversity
  formula;
* group academic merit comes from the Gaussian upper-tail-mean hazard formulas
  and the displayed `β_g` monotonicity.

The thresholds are real-valued.  Interior threshold statements are available
from the corresponding `_crossing` wrappers when the endpoint-crossing
inequalities are supplied.
-/
theorem paper_theorem1_dropping_tests_with_barriers_main_thresholds
    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    {fullDiversity threshold : ℝ → ℝ}
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw}
    {diversityImproves meritImprovesA meritImprovesB : ℝ → Prop}
    {ownShareA otherEligibleMassA rhoA xiA benchmarkA baseA scaleA : ℝ}
    {fullMeritA : ℝ → ℝ} {subMeritA : ℝ}
    {ownShareB otherEligibleMassB rhoB xiB benchmarkB baseB scaleB : ℝ}
    {fullMeritB : ℝ → ℝ} {subMeritB : ℝ}
    (hfull_cont : ContinuousOn fullDiversity (Set.Icc (0 : ℝ) 1))
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hcapacity_eq :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          groupAEligibleMass *
              H.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              H.api.thresholdPassProb L_B (threshold γB))
    (hdiversity_share :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          groupBShare * γB *
            H.api.thresholdPassProb L_B (threshold γB) / capacity)
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ fullDiversity γB < diversitySub)
    (hscaleA_pos : 0 < scaleA)
    (hxiA_pos : 0 < xiA)
    (hfullA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMeritA γ =
          baseA + scaleA *
            H.hazard
              (theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA γ))
    (hsubA :
      subMeritA = baseA + scaleA * (xiA * H.hazard benchmarkA))
    (himprovesA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        meritImprovesA γ ↔ fullMeritA γ ≤ subMeritA)
    (hownA_pos : 0 < ownShareA)
    (hotherA_pos : 0 < otherEligibleMassA)
    (hrhoA_nonneg : 0 ≤ rhoA) (hrhoA_lt_one : rhoA < 1)
    (hselectiveA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareA * γ + otherEligibleMassA)
    (hscaleB_pos : 0 < scaleB)
    (hxiB_pos : 0 < xiB)
    (hfullB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMeritB γ =
          baseB + scaleB *
            H.hazard
              (theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB γ))
    (hsubB :
      subMeritB = baseB + scaleB * (xiB * H.hazard benchmarkB))
    (himprovesB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        meritImprovesB γ ↔ fullMeritB γ ≤ subMeritB)
    (hownB_pos : 0 < ownShareB)
    (hotherB_pos : 0 < otherEligibleMassB)
    (hone_lt_rhoB : 1 < rhoB)
    (hselectiveB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareB * γ + otherEligibleMassB) :
    (∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ γB < γbar) ∧
      (∃ γbarA : ℝ,
        ∀ γA ∈ Set.Icc (0 : ℝ) 1,
          meritImprovesA γA ↔ γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          meritImprovesB γB ↔ γB ≤ γbarB) := by
  refine ⟨?_, ?_, ?_⟩
  · exact
      paper_theorem1_diversity_access_threshold_of_capacity_share_main
        H.toGaussianHazardCertificate hfull_cont hcapacity_pos hgroupA_pos
        hgroupB_pos hcapacity_eq hdiversity_share hdiversity
  · exact
      paper_theorem1_academic_merit_access_threshold_of_groupA_tail_mean_main
        H Q hxiA_pos hscaleA_pos hfullA hsubA himprovesA hcapacity_pos hownA_pos
        hotherA_pos hrhoA_nonneg hrhoA_lt_one hselectiveA
  · exact
      paper_theorem1_academic_merit_access_threshold_of_groupB_tail_mean_main
        H Q hxiB_pos hscaleB_pos hfullB hsubB himprovesB hcapacity_pos hownB_pos
        hotherB_pos hone_lt_rhoB hselectiveB

/--
Theorem 1 main-body bundle from explicit Gaussian normal-law formulas.

Compared with `paper_theorem1_dropping_tests_with_barriers_main_thresholds`,
this wrapper lets the academic-merit hypotheses be stated as Gaussian
upper-tail means plus standardized-threshold identities, matching the source
proof's admitted-normal-tail presentation before it rewrites into hazard form.
-/
theorem paper_theorem1_dropping_tests_with_barriers_normal_laws_main_thresholds
    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    {fullDiversity threshold : ℝ → ℝ}
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw}
    {diversityImproves meritImprovesA meritImprovesB : ℝ → Prop}
    {ownShareA otherEligibleMassA rhoA xiA benchmarkA baseA scaleA : ℝ}
    {LfullA : ℝ → GaussianScaleLaw} {thresholdFullA : ℝ → ℝ}
    {LsubA : GaussianScaleLaw} {thresholdSubA subMeritA : ℝ}
    {fullMeritA : ℝ → ℝ}
    {ownShareB otherEligibleMassB rhoB xiB benchmarkB baseB scaleB : ℝ}
    {LfullB : ℝ → GaussianScaleLaw} {thresholdFullB : ℝ → ℝ}
    {LsubB : GaussianScaleLaw} {thresholdSubB subMeritB : ℝ}
    {fullMeritB : ℝ → ℝ}
    (hfull_cont : ContinuousOn fullDiversity (Set.Icc (0 : ℝ) 1))
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hcapacity_eq :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          groupAEligibleMass *
              H.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              H.api.thresholdPassProb L_B (threshold γB))
    (hdiversity_share :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          groupBShare * γB *
            H.api.thresholdPassProb L_B (threshold γB) / capacity)
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ fullDiversity γB < diversitySub)
    (hfullMeritA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMeritA γ = H.normalUpperTailMean (LfullA γ) (thresholdFullA γ))
    (hfullA_mean :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, (LfullA γ).mean = baseA)
    (hfullA_scale :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, (LfullA γ).scale = scaleA)
    (hfullA_standardize :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        (LfullA γ).standardize (thresholdFullA γ) =
          theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA γ)
    (hsubMeritA :
      subMeritA = H.normalUpperTailMean LsubA thresholdSubA)
    (hsubA_mean : LsubA.mean = baseA)
    (hsubA_scale : LsubA.scale = scaleA * xiA)
    (hsubA_standardize : LsubA.standardize thresholdSubA = benchmarkA)
    (himprovesA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        meritImprovesA γ ↔ fullMeritA γ ≤ subMeritA)
    (hscaleA_pos : 0 < scaleA)
    (hxiA_pos : 0 < xiA)
    (hownA_pos : 0 < ownShareA)
    (hotherA_pos : 0 < otherEligibleMassA)
    (hrhoA_nonneg : 0 ≤ rhoA) (hrhoA_lt_one : rhoA < 1)
    (hselectiveA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareA * γ + otherEligibleMassA)
    (hfullMeritB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMeritB γ = H.normalUpperTailMean (LfullB γ) (thresholdFullB γ))
    (hfullB_mean :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, (LfullB γ).mean = baseB)
    (hfullB_scale :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, (LfullB γ).scale = scaleB)
    (hfullB_standardize :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        (LfullB γ).standardize (thresholdFullB γ) =
          theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB γ)
    (hsubMeritB :
      subMeritB = H.normalUpperTailMean LsubB thresholdSubB)
    (hsubB_mean : LsubB.mean = baseB)
    (hsubB_scale : LsubB.scale = scaleB * xiB)
    (hsubB_standardize : LsubB.standardize thresholdSubB = benchmarkB)
    (himprovesB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        meritImprovesB γ ↔ fullMeritB γ ≤ subMeritB)
    (hscaleB_pos : 0 < scaleB)
    (hxiB_pos : 0 < xiB)
    (hownB_pos : 0 < ownShareB)
    (hotherB_pos : 0 < otherEligibleMassB)
    (hone_lt_rhoB : 1 < rhoB)
    (hselectiveB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareB * γ + otherEligibleMassB) :
    (∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ γB < γbar) ∧
      (∃ γbarA : ℝ,
        ∀ γA ∈ Set.Icc (0 : ℝ) 1,
          meritImprovesA γA ↔ γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          meritImprovesB γB ↔ γB ≤ γbarB) := by
  refine ⟨?_, ?_, ?_⟩
  · exact
      paper_theorem1_diversity_access_threshold_of_capacity_share_main
        H.toGaussianHazardCertificate hfull_cont hcapacity_pos hgroupA_pos
        hgroupB_pos hcapacity_eq hdiversity_share hdiversity
  · exact
      paper_theorem1_academic_merit_access_threshold_of_groupA_normal_laws_main
        H Q hfullMeritA hfullA_mean hfullA_scale hfullA_standardize
        hsubMeritA hsubA_mean hsubA_scale hsubA_standardize himprovesA
        hscaleA_pos hxiA_pos hcapacity_pos hownA_pos hotherA_pos hrhoA_nonneg
        hrhoA_lt_one hselectiveA
  · exact
      paper_theorem1_academic_merit_access_threshold_of_groupB_normal_laws_main
        H Q hfullMeritB hfullB_mean hfullB_scale hfullB_standardize
        hsubMeritB hsubB_mean hsubB_scale hsubB_standardize himprovesB
        hscaleB_pos hxiB_pos hcapacity_pos hownB_pos hotherB_pos hone_lt_rhoB
        hselectiveB

/-- Theorem 1 source metric: full-policy diversity as admitted group-B share. -/
def theorem1FullDiversityShare
    (api : StandardGaussianCDFAPI)
    (capacity groupBShare : ℝ) (L_B : GaussianScaleLaw)
    (threshold : ℝ → ℝ) (γB : ℝ) : ℝ := groupBShare * γB * api.thresholdPassProb L_B (threshold γB) / capacity

theorem theorem1FullDiversityShare_continuousOn
    (api : StandardGaussianCDFAPI)
    {capacity groupBShare : ℝ} (L_B : GaussianScaleLaw)
    {threshold : ℝ → ℝ}
    (hthreshold_cont : ContinuousOn threshold (Set.Icc (0 : ℝ) 1)) :
    ContinuousOn
      (theorem1FullDiversityShare api capacity groupBShare L_B threshold)
      (Set.Icc (0 : ℝ) 1) := by
  unfold theorem1FullDiversityShare
  let s : Set ℝ := Set.Icc 0 1
  have htail :
      ContinuousOn
        (fun γB : ℝ => api.thresholdPassProb L_B (threshold γB)) s :=
    (api.thresholdPassProb_continuous L_B).comp_continuousOn hthreshold_cont
  have hlinear :
      ContinuousOn (fun γB : ℝ => groupBShare * γB) s := by
    fun_prop
  exact ((hlinear.mul htail).div_const capacity)

/-- Theorem 1 source comparison: diversity improves after dropping the test. -/
def theorem1DiversityImproves
    (fullDiversity : ℝ → ℝ) (diversitySub γB : ℝ) : Prop := fullDiversity γB < diversitySub

/-- Location-scale Gaussian law used in Theorem 1 normal-tail formulas. -/
def theorem1GaussianLaw (base scale : ℝ) (hscale : 0 < scale) :
    GaussianScaleLaw where
  mean := base
  scale := scale
  scale_pos := hscale

/-- Threshold with a prescribed standardized score. -/
def theorem1ThresholdFromStandardizedScore
    (base scale score : ℝ) : ℝ := base + scale * score

@[simp] theorem theorem1GaussianLaw_mean
    (base scale : ℝ) (hscale : 0 < scale) :
    (theorem1GaussianLaw base scale hscale).mean = base := rfl

@[simp] theorem theorem1GaussianLaw_scale
    (base scale : ℝ) (hscale : 0 < scale) :
    (theorem1GaussianLaw base scale hscale).scale = scale := rfl

theorem theorem1GaussianLaw_standardize_thresholdFromScore
    {base scale score : ℝ} (hscale : 0 < scale) :
    (theorem1GaussianLaw base scale hscale).standardize
        (theorem1ThresholdFromStandardizedScore base scale score) =
      score := by
  rw [theorem1GaussianLaw, theorem1ThresholdFromStandardizedScore,
    GaussianScaleLaw.standardize]
  field_simp [ne_of_gt hscale]
  ring

/-- Theorem 1 source metric: admitted group merit from a normal upper tail. -/
def theorem1FullMeritFromStandardizedScore
    (H : GaussianHazardInverseCertificate)
    (base scale : ℝ) (hscale : 0 < scale) (score : ℝ → ℝ) (γ : ℝ) : ℝ :=
  H.normalUpperTailMean (theorem1GaussianLaw base scale hscale)
    (theorem1ThresholdFromStandardizedScore base scale (score γ))

/-- Theorem 1 source metric: test-free admitted group merit benchmark. -/
def theorem1SubMeritFromBenchmark
    (H : GaussianHazardInverseCertificate)
    (base scale xi : ℝ) (hscale : 0 < scale) (hxi : 0 < xi)
    (benchmark : ℝ) : ℝ :=
  H.normalUpperTailMean
    (theorem1GaussianLaw base (scale * xi) (mul_pos hscale hxi))
    (theorem1ThresholdFromStandardizedScore base (scale * xi) benchmark)

/-- Theorem 1 source comparison: group academic merit improves after dropping the test. -/
def theorem1AcademicMeritImproves
    (fullMerit : ℝ → ℝ) (subMerit γ : ℝ) : Prop := fullMerit γ ≤ subMerit

/--
Theorem 1, paper-facing metric-definition endpoint.

This theorem removes the ad hoc metric-equation hypotheses from
`paper_theorem1_dropping_tests_with_barriers_normal_laws_main_thresholds` by
using Lean definitions for the source metrics: diversity is the admitted
group-B share, and academic merit is the Gaussian upper-tail mean with the
paper's standardized `β_A`/`β_B` cutoffs and no-test benchmarks.
-/
theorem paper_theorem1_dropping_tests_with_barriers_explicit_metrics
    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw} {threshold : ℝ → ℝ}
    {ownShareA otherEligibleMassA rhoA xiA benchmarkA baseA scaleA : ℝ}
    {ownShareB otherEligibleMassB rhoB xiB benchmarkB baseB scaleB : ℝ}
    (hthreshold_cont : ContinuousOn threshold (Set.Icc (0 : ℝ) 1))
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hcapacity_eq :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          groupAEligibleMass *
              H.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              H.api.thresholdPassProb L_B (threshold γB))
    (hscaleA_pos : 0 < scaleA)
    (hxiA_pos : 0 < xiA)
    (hownA_pos : 0 < ownShareA)
    (hotherA_pos : 0 < otherEligibleMassA)
    (hrhoA_nonneg : 0 ≤ rhoA) (hrhoA_lt_one : rhoA < 1)
    (hselectiveA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareA * γ + otherEligibleMassA)
    (hscaleB_pos : 0 < scaleB)
    (hxiB_pos : 0 < xiB)
    (hownB_pos : 0 < ownShareB)
    (hotherB_pos : 0 < otherEligibleMassB)
    (hone_lt_rhoB : 1 < rhoB)
    (hselectiveB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareB * γ + otherEligibleMassB) :
    (∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        theorem1DiversityImproves
          (theorem1FullDiversityShare H.api capacity groupBShare L_B threshold)
          diversitySub γB ↔ γB < γbar) ∧
      (∃ γbarA : ℝ,
        ∀ γA ∈ Set.Icc (0 : ℝ) 1,
          theorem1AcademicMeritImproves
            (theorem1FullMeritFromStandardizedScore H baseA scaleA hscaleA_pos
              (theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA))
            (theorem1SubMeritFromBenchmark H baseA scaleA xiA hscaleA_pos
              hxiA_pos benchmarkA) γA ↔
            γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          theorem1AcademicMeritImproves
            (theorem1FullMeritFromStandardizedScore H baseB scaleB hscaleB_pos
              (theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB))
            (theorem1SubMeritFromBenchmark H baseB scaleB xiB hscaleB_pos
              hxiB_pos benchmarkB) γB ↔
            γB ≤ γbarB) := by
  let fullDiversity :=
    theorem1FullDiversityShare H.api capacity groupBShare L_B threshold
  let fullMeritA :=
    theorem1FullMeritFromStandardizedScore H baseA scaleA hscaleA_pos
      (theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA)
  let subMeritA :=
    theorem1SubMeritFromBenchmark H baseA scaleA xiA hscaleA_pos
      hxiA_pos benchmarkA
  let fullMeritB :=
    theorem1FullMeritFromStandardizedScore H baseB scaleB hscaleB_pos
      (theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB)
  let subMeritB :=
    theorem1SubMeritFromBenchmark H baseB scaleB xiB hscaleB_pos
      hxiB_pos benchmarkB
  have hdiversity_share :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          groupBShare * γB *
            H.api.thresholdPassProb L_B (threshold γB) / capacity := by
    intro γB _hγB
    rfl
  have hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        theorem1DiversityImproves fullDiversity diversitySub γB ↔
          fullDiversity γB < diversitySub := by
    intro γB _hγB
    rfl
  have hfullMeritA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMeritA γ =
          H.normalUpperTailMean
            (theorem1GaussianLaw baseA scaleA hscaleA_pos)
            (theorem1ThresholdFromStandardizedScore baseA scaleA
              (theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA γ)) := by
    intro γ _hγ
    rfl
  have hfullA_mean :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        (theorem1GaussianLaw baseA scaleA hscaleA_pos).mean = baseA := by
    intro γ hγ
    simp
  have hfullA_scale :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        (theorem1GaussianLaw baseA scaleA hscaleA_pos).scale = scaleA := by
    intro γ hγ
    simp
  have hfullA_standardize :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        (theorem1GaussianLaw baseA scaleA hscaleA_pos).standardize
            (theorem1ThresholdFromStandardizedScore baseA scaleA
              (theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA γ)) =
          theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA γ := by
    intro γ _hγ
    exact theorem1GaussianLaw_standardize_thresholdFromScore hscaleA_pos
  have hsubMeritA :
      subMeritA =
        H.normalUpperTailMean
          (theorem1GaussianLaw baseA (scaleA * xiA)
            (mul_pos hscaleA_pos hxiA_pos))
          (theorem1ThresholdFromStandardizedScore baseA (scaleA * xiA)
            benchmarkA) := by
    rfl
  have hsubA_mean :
      (theorem1GaussianLaw baseA (scaleA * xiA)
        (mul_pos hscaleA_pos hxiA_pos)).mean = baseA := by
    simp
  have hsubA_scale :
      (theorem1GaussianLaw baseA (scaleA * xiA)
        (mul_pos hscaleA_pos hxiA_pos)).scale = scaleA * xiA := by
    simp
  have hsubA_standardize :
      (theorem1GaussianLaw baseA (scaleA * xiA)
          (mul_pos hscaleA_pos hxiA_pos)).standardize
        (theorem1ThresholdFromStandardizedScore baseA (scaleA * xiA)
          benchmarkA) = benchmarkA :=
    theorem1GaussianLaw_standardize_thresholdFromScore
      (mul_pos hscaleA_pos hxiA_pos)
  have himprovesA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        theorem1AcademicMeritImproves fullMeritA subMeritA γ ↔
          fullMeritA γ ≤ subMeritA := by
    intro γ _hγ
    rfl
  have hfullMeritB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMeritB γ =
          H.normalUpperTailMean
            (theorem1GaussianLaw baseB scaleB hscaleB_pos)
            (theorem1ThresholdFromStandardizedScore baseB scaleB
              (theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB γ)) := by
    intro γ _hγ
    rfl
  have hfullB_mean :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        (theorem1GaussianLaw baseB scaleB hscaleB_pos).mean = baseB := by
    intro γ hγ
    simp
  have hfullB_scale :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        (theorem1GaussianLaw baseB scaleB hscaleB_pos).scale = scaleB := by
    intro γ hγ
    simp
  have hfullB_standardize :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        (theorem1GaussianLaw baseB scaleB hscaleB_pos).standardize
            (theorem1ThresholdFromStandardizedScore baseB scaleB
              (theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB γ)) =
          theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB γ := by
    intro γ _hγ
    exact theorem1GaussianLaw_standardize_thresholdFromScore hscaleB_pos
  have hsubMeritB :
      subMeritB =
        H.normalUpperTailMean
          (theorem1GaussianLaw baseB (scaleB * xiB)
            (mul_pos hscaleB_pos hxiB_pos))
          (theorem1ThresholdFromStandardizedScore baseB (scaleB * xiB)
            benchmarkB) := by
    rfl
  have hsubB_mean :
      (theorem1GaussianLaw baseB (scaleB * xiB)
        (mul_pos hscaleB_pos hxiB_pos)).mean = baseB := by
    simp
  have hsubB_scale :
      (theorem1GaussianLaw baseB (scaleB * xiB)
        (mul_pos hscaleB_pos hxiB_pos)).scale = scaleB * xiB := by
    simp
  have hsubB_standardize :
      (theorem1GaussianLaw baseB (scaleB * xiB)
          (mul_pos hscaleB_pos hxiB_pos)).standardize
        (theorem1ThresholdFromStandardizedScore baseB (scaleB * xiB)
          benchmarkB) = benchmarkB :=
    theorem1GaussianLaw_standardize_thresholdFromScore
      (mul_pos hscaleB_pos hxiB_pos)
  have himprovesB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        theorem1AcademicMeritImproves fullMeritB subMeritB γ ↔
          fullMeritB γ ≤ subMeritB := by
    intro γ _hγ
    rfl
  simpa [fullDiversity, fullMeritA, subMeritA, fullMeritB, subMeritB]
    using
      paper_theorem1_dropping_tests_with_barriers_normal_laws_main_thresholds
        H Q (theorem1FullDiversityShare_continuousOn H.api L_B hthreshold_cont)
        hcapacity_pos hgroupA_pos hgroupB_pos hcapacity_eq
        hdiversity_share hdiversity hfullMeritA hfullA_mean hfullA_scale
        hfullA_standardize hsubMeritA hsubA_mean hsubA_scale
        hsubA_standardize himprovesA hscaleA_pos hxiA_pos hownA_pos hotherA_pos
        hrhoA_nonneg hrhoA_lt_one hselectiveA hfullMeritB hfullB_mean
        hfullB_scale hfullB_standardize hsubMeritB hsubB_mean hsubB_scale
        hsubB_standardize himprovesB hscaleB_pos hxiB_pos hownB_pos hotherB_pos
        hone_lt_rhoB hselectiveB

/-- Theorem 1 source-surface comparison: diversity improves after dropping the test. -/
def theorem1SourceDiversityImproves {Group Policy : Type*}
    (S : ℝ → GLM20SourcePolicySurface Group Policy)
    (Pfull Psub : Policy) (γB : ℝ) : Prop := (S γB).diversity Pfull < (S γB).diversity Psub

/-- Theorem 1 source-surface comparison: group academic merit improves. -/
def theorem1SourceAcademicMeritImproves {Group Policy : Type*}
    (S : ℝ → GLM20SourcePolicySurface Group Policy)
    (group : Group) (Pfull Psub : Policy) (γ : ℝ) : Prop := (S γ).academicMerit group Pfull ≤ (S γ).academicMerit group Psub

/--
Theorem 1 canonical source surface for the diversity comparison.

All fields not used by the theorem are filled with neutral values.  The used
fields are by-definition the paper's access level, common capacity, admitted
group-B share under `P_full`, and test-free diversity benchmark under `P_sub`.
-/
def theorem1DiversitySourceSurface
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (Pfull Psub : Policy) (groupB : Group)
    (capacity groupBShare diversitySub : ℝ)
    (L_B : GaussianScaleLaw) (threshold : ℝ → ℝ)
    (γB : ℝ) : GLM20SourcePolicySurface Group Policy where
  populationShareB := groupBShare
  capacity := capacity
  precision := fun _ _ => 0
  accessLevel := fun g => if g = groupB then γB else 0
  estimatedSkillMean := fun _ _ => 0
  estimatedSkillVariance := fun _ _ => 0
  admissionThreshold := fun P => if P = Pfull then threshold γB else 0
  diversity := fun P =>
    if P = Pfull then
      theorem1FullDiversityShare api capacity groupBShare L_B threshold γB
    else if P = Psub then
      diversitySub
    else
      0
  individualFairnessGap := fun _ _ => 0
  academicMerit := fun _ _ => 0

/--
Theorem 1 canonical source surface for one group's academic-merit comparison.

The full-policy academic merit is the Gaussian upper-tail mean at the paper's
standardized access score, while the test-free benchmark is the corresponding
no-test upper-tail mean.
-/
def theorem1AcademicMeritSourceSurface
    (H : GaussianHazardInverseCertificate)
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (Pfull Psub : Policy) (group : Group)
    (capacity base scale xi : ℝ) (hscale : 0 < scale) (hxi : 0 < xi)
    (benchmark : ℝ) (score : ℝ → ℝ)
    (γ : ℝ) : GLM20SourcePolicySurface Group Policy where
  populationShareB := 0
  capacity := capacity
  precision := fun _ _ => 0
  accessLevel := fun g => if g = group then γ else 0
  estimatedSkillMean := fun _ _ => 0
  estimatedSkillVariance := fun _ _ => 0
  admissionThreshold := fun _ => 0
  diversity := fun _ => 0
  individualFairnessGap := fun _ _ => 0
  academicMerit := fun g P =>
    if g = group then
      if P = Pfull then
        theorem1FullMeritFromStandardizedScore H base scale hscale score γ
      else if P = Psub then
        theorem1SubMeritFromBenchmark H base scale xi hscale hxi benchmark
      else
        0
    else
      0

/--
Theorem 1 admissions-cutoff certificate.

This records the source model's defining capacity equation for the full-policy
cutoff when barriers restrict the eligible group masses.  It is intentionally
narrow: it says only that the threshold family admits exactly the fixed school
capacity from the two Gaussian upper-tail masses.
-/
structure Theorem1BarrierCapacityCertificate
    (api : StandardGaussianCDFAPI)
    (capacity groupAEligibleMass groupBShare : ℝ)
    (L_A L_B : GaussianScaleLaw) (threshold : ℝ → ℝ) : Prop where
  holds :
    ∀ γB ∈ Set.Icc (0 : ℝ) 1,
      capacity =
        groupAEligibleMass * api.thresholdPassProb L_A (threshold γB) +
          groupBShare * γB * api.thresholdPassProb L_B (threshold γB)

/--
Two-point weights for Theorem 1's barrier admissions mixture.

The Boolean index is only a lightweight finite-mixture helper: `false` is group
A's eligible mass and `true` is group B's eligible mass at access level `γB`.
-/
def theorem1BarrierCapacityWeight
    (groupAEligibleMass groupBShare γB : ℝ) : Bool → ℝ
  | false => groupAEligibleMass
  | true => groupBShare * γB

/--
Two-point score laws for Theorem 1's barrier admissions mixture.

The Boolean index matches `theorem1BarrierCapacityWeight`: `false` is group A,
and `true` is group B.
-/
def theorem1BarrierCapacityLaw
    (L_A L_B : GaussianScaleLaw) : Bool → GaussianScaleLaw
  | false => L_A
  | true => L_B

/--
Theorem 1 barrier capacity as a finite two-group Gaussian mixture.

This is the algebraic bridge from the reusable
`StandardGaussianCDFAPI.mixtureTailMass` interface to the paper's displayed
capacity equation.
-/
theorem theorem1BarrierMixtureTailMass_eq
    (api : StandardGaussianCDFAPI)
    (groupAEligibleMass groupBShare γB : ℝ)
    (L_A L_B : GaussianScaleLaw) (threshold : ℝ → ℝ) :
  api.mixtureTailMass
        (theorem1BarrierCapacityWeight groupAEligibleMass groupBShare γB)
        (theorem1BarrierCapacityLaw L_A L_B)
        (threshold γB) =
      groupAEligibleMass * api.thresholdPassProb L_A (threshold γB) +
        groupBShare * γB * api.thresholdPassProb L_B (threshold γB) := by
  simp [StandardGaussianCDFAPI.mixtureTailMass, theorem1BarrierCapacityWeight,
    theorem1BarrierCapacityLaw, mul_assoc, add_comm]

/--
Construct Theorem 1's named cutoff-capacity certificate from the shared
finite-mixture tail-mass capacity equation.
-/
theorem theorem1BarrierCapacityCertificate_of_mixtureTailMass
    {api : StandardGaussianCDFAPI}
    {capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw} {threshold : ℝ → ℝ}
    (hmixtureCapacity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        api.mixtureTailMass
            (theorem1BarrierCapacityWeight groupAEligibleMass groupBShare γB)
            (theorem1BarrierCapacityLaw L_A L_B)
            (threshold γB) = capacity) :
    Theorem1BarrierCapacityCertificate api capacity groupAEligibleMass
      groupBShare L_A L_B threshold := by
  refine ⟨?_⟩
  intro γB hγB
  rw [← hmixtureCapacity γB hγB]
  exact theorem1BarrierMixtureTailMass_eq
    api groupAEligibleMass groupBShare γB L_A L_B threshold

/-- Sum of Theorem 1's two finite-mixture weights. -/
theorem theorem1BarrierCapacityWeight_sum
    (groupAEligibleMass groupBShare γB : ℝ) :
    (∑ g : Bool, theorem1BarrierCapacityWeight groupAEligibleMass groupBShare γB g) =
      groupAEligibleMass + groupBShare * γB := by
  simp [theorem1BarrierCapacityWeight, add_comm]

/--
Theorem 1 capacity-feasibility helper.

If the capacity is already below the group-A eligible mass, then it is below
the total eligible mass for every group-B access level on `[0,1]`.
-/
theorem theorem1_capacity_mem_on_unit_of_capacity_lt_groupAEligibleMass
    {capacity groupAEligibleMass groupBShare : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hcapacity_lt_groupA : capacity < groupAEligibleMass)
    (hgroupB_nonneg : 0 ≤ groupBShare) :
    ∀ γB ∈ Set.Icc (0 : ℝ) 1,
      capacity ∈ Set.Ioo (0 : ℝ) (groupAEligibleMass + groupBShare * γB) := by
  intro γB hγB
  have hterm_nonneg : 0 ≤ groupBShare * γB :=
    mul_nonneg hgroupB_nonneg hγB.1
  exact ⟨hcapacity_pos, by nlinarith⟩

/--
Theorem 1 source-domain simplification.

For the paper's population/access notation, the group-B worst-case selectivity
condition is stronger than the separate capacity-feasibility condition used by
the Gaussian mixture cutoff theorem.
-/
theorem theorem1_capacity_lt_groupA_eligible_of_selectiveB_worst
    {capacity pi gammaA : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hselectiveB_worst : 2 * capacity < (1 - pi) * gammaA) :
    capacity < (1 - pi) * gammaA := by
  have hcapacity_lt_twice : capacity < 2 * capacity := by
    linarith
  exact lt_trans hcapacity_lt_twice hselectiveB_worst

/--
Theorem 1 low-capacity domain is nonempty.

Given positive group masses and access levels, there is always a positive
capacity satisfying the two nonredundant full-sweep selectivity inequalities.
This does not show the paper assumes that regime; it shows the Lean theorem's
strengthened domain is feasible rather than vacuous.
-/
theorem theorem1_low_capacity_domain_nonempty
    {pi gammaA gammaB : ℝ}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hgammaA_pos : 0 < gammaA) (hgammaB_pos : 0 < gammaB) :
    ∃ capacity : ℝ,
      0 < capacity ∧
        2 * capacity < pi * gammaB ∧
        2 * capacity < (1 - pi) * gammaA := by
  have hgroupAEligible_pos : 0 < (1 - pi) * gammaA := by
    have hgroupA_pos : 0 < 1 - pi := by
      linarith
    exact mul_pos hgroupA_pos hgammaA_pos
  have hgroupBEligible_pos : 0 < pi * gammaB :=
    mul_pos hpi_pos hgammaB_pos
  let m := min (pi * gammaB) ((1 - pi) * gammaA)
  have hm_pos : 0 < m :=
    lt_min hgroupBEligible_pos hgroupAEligible_pos
  refine ⟨m / 4, ?_, ?_, ?_⟩
  · nlinarith
  · have hm_le : m ≤ pi * gammaB :=
      min_le_left _ _
    nlinarith
  · have hm_le : m ≤ (1 - pi) * gammaA :=
      min_le_right _ _
    nlinarith

/--
Theorem 1 selectivity helper for the quantile terms.

If `2 * capacity` is below the other group's eligible mass, then it is below
`ownShare * γ + otherEligibleMass` for every access level on `[0,1]`.
-/
theorem theorem1_selective_on_unit_of_two_capacity_lt_otherEligibleMass
    {capacity ownShare otherEligibleMass : ℝ}
    (hown_nonneg : 0 ≤ ownShare)
    (htwo_capacity_lt_other : 2 * capacity < otherEligibleMass) :
    ∀ γ ∈ Set.Icc (0 : ℝ) 1,
      2 * capacity < ownShare * γ + otherEligibleMass := by
  intro γ hγ
  have hterm_nonneg : 0 ≤ ownShare * γ :=
    mul_nonneg hown_nonneg hγ.1
  nlinarith

/--
Theorem 1 Gaussian mixture capacity threshold exists uniquely.

This is the formal capacity-realization fact behind the paper's phrase that
the school chooses the admissions cutoff to fill capacity.  If capacity lies
strictly between zero and the total eligible mass in the two-group Gaussian
mixture, the mixture upper-tail mass is continuous, tends to total mass at
`-∞`, tends to zero at `+∞`, and is strictly decreasing in the common cutoff.
-/
theorem theorem1BarrierMixtureCapacityThreshold_existsUnique
    (api : StandardGaussianCDFAPI)
    (hcdf_atBot : Filter.Tendsto api.cdf Filter.atBot (nhds 0))
    (hcdf_atTop : Filter.Tendsto api.cdf Filter.atTop (nhds 1))
    {capacity groupAEligibleMass groupBShare γB : ℝ}
    {L_A L_B : GaussianScaleLaw}
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_nonneg : 0 ≤ groupBShare)
    (hγB_nonneg : 0 ≤ γB)
    (hcapacity_mem :
      capacity ∈ Set.Ioo (0 : ℝ) (groupAEligibleMass + groupBShare * γB)) :
    ∃! threshold : ℝ,
      api.mixtureTailMass
          (theorem1BarrierCapacityWeight groupAEligibleMass groupBShare γB)
          (theorem1BarrierCapacityLaw L_A L_B)
          threshold = capacity := by
  apply api.existsUnique_mixtureTailMass_eq_of_capacity_mem_Ioo
    (weight := theorem1BarrierCapacityWeight groupAEligibleMass groupBShare γB)
    (law := theorem1BarrierCapacityLaw L_A L_B)
    hcdf_atBot hcdf_atTop
  · intro g
    cases g <;> simp [theorem1BarrierCapacityWeight, hgroupA_pos.le,
      mul_nonneg hgroupB_nonneg hγB_nonneg]
  · exact ⟨false, by simpa [theorem1BarrierCapacityWeight] using hgroupA_pos⟩
  · simpa [theorem1BarrierCapacityWeight, add_comm] using hcapacity_mem

/--
Canonical capacity-realizing cutoff family for Theorem 1 on access levels
`γ_B ∈ [0,1]`.

Outside `[0,1]` the value is arbitrary; all paper-facing theorems use the
accompanying equation only on the unit interval.
-/
noncomputable def theorem1BarrierCapacityThresholdOnUnit
    (api : StandardGaussianCDFAPI)
    (hcdf_atBot : Filter.Tendsto api.cdf Filter.atBot (nhds 0))
    (hcdf_atTop : Filter.Tendsto api.cdf Filter.atTop (nhds 1))
    (capacity groupAEligibleMass groupBShare : ℝ)
    (L_A L_B : GaussianScaleLaw)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_nonneg : 0 ≤ groupBShare)
    (hcapacity_mem :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity ∈ Set.Ioo (0 : ℝ) (groupAEligibleMass + groupBShare * γB))
    (γB : ℝ) : ℝ :=
  if hγB : γB ∈ Set.Icc (0 : ℝ) 1 then
    Classical.choose
      (theorem1BarrierMixtureCapacityThreshold_existsUnique
        api hcdf_atBot hcdf_atTop hgroupA_pos hgroupB_nonneg hγB.1
        (hcapacity_mem γB hγB)
        (L_A := L_A) (L_B := L_B))
  else
    0

/--
The canonical Theorem 1 cutoff family realizes the Gaussian mixture capacity
equation on the paper's access interval.
-/
theorem theorem1BarrierCapacityThresholdOnUnit_mixtureTailMass_eq
    (api : StandardGaussianCDFAPI)
    (hcdf_atBot : Filter.Tendsto api.cdf Filter.atBot (nhds 0))
    (hcdf_atTop : Filter.Tendsto api.cdf Filter.atTop (nhds 1))
    {capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw}
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_nonneg : 0 ≤ groupBShare)
    (hcapacity_mem :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity ∈ Set.Ioo (0 : ℝ) (groupAEligibleMass + groupBShare * γB)) :
    ∀ γB ∈ Set.Icc (0 : ℝ) 1,
      api.mixtureTailMass
          (theorem1BarrierCapacityWeight groupAEligibleMass groupBShare γB)
          (theorem1BarrierCapacityLaw L_A L_B)
          (theorem1BarrierCapacityThresholdOnUnit
            api hcdf_atBot hcdf_atTop capacity groupAEligibleMass groupBShare
            L_A L_B hgroupA_pos hgroupB_nonneg hcapacity_mem γB) =
        capacity := by
  intro γB hγB
  rw [theorem1BarrierCapacityThresholdOnUnit, dif_pos hγB]
  exact
    (Classical.choose_spec
      (theorem1BarrierMixtureCapacityThreshold_existsUnique
        api hcdf_atBot hcdf_atTop hgroupA_pos hgroupB_nonneg hγB.1
        (hcapacity_mem γB hγB)
        (L_A := L_A) (L_B := L_B))).1

/--
Theorem 1, source-surface endpoint.

Paper statement: "With barriers, holding other parameters fixed, there exists
a threshold `γbar` such that diversity improves under `P_sub` iff group-B test
access `γ_B < γbar`; for each group `g`, holding other parameters fixed, there
exists a threshold `γbar_g` such that academic merit of group `g` increases
under `P_sub` iff `γ_g < γbar_g`."

This theorem is the paper-facing source-surface version of
`paper_theorem1_dropping_tests_with_barriers_explicit_metrics`.  It no longer
talks about anonymous metric predicates: the comparisons are the actual
`diversity` and `academicMerit` fields of the source policy surfaces.  The
remaining hypotheses are the paper's displayed source equations for the
varying access-barrier family: access levels, capacity equation, admitted
group-B share, and Gaussian upper-tail mean formulas for academic merit.
-/
theorem paper_theorem1_dropping_tests_with_barriers_source_surface
    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    {Group Policy : Type*}
    {Sdiv SA SB : ℝ → GLM20SourcePolicySurface Group Policy}
    {Pfull Psub : Policy} {groupA groupB : Group}
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw} {threshold : ℝ → ℝ}
    {ownShareA otherEligibleMassA rhoA xiA benchmarkA baseA scaleA : ℝ}
    {ownShareB otherEligibleMassB rhoB xiB benchmarkB baseB scaleB : ℝ}
    (hthreshold_cont : ContinuousOn threshold (Set.Icc (0 : ℝ) 1))
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hdiv_capacity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1, (Sdiv γB).capacity = capacity)
    (hdiv_accessB :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1, (Sdiv γB).accessLevel groupB = γB)
    (hcapacity_eq :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        (Sdiv γB).capacity =
          groupAEligibleMass *
              H.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              H.api.thresholdPassProb L_B (threshold γB))
    (hdiversity_full :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        (Sdiv γB).diversity Pfull =
          theorem1FullDiversityShare H.api capacity groupBShare L_B threshold γB)
    (hdiversity_sub :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        (Sdiv γB).diversity Psub = diversitySub)
    (hmeritA_access :
      ∀ γA ∈ Set.Icc (0 : ℝ) 1, (SA γA).accessLevel groupA = γA)
    (hscaleA_pos : 0 < scaleA)
    (hxiA_pos : 0 < xiA)
    (hmeritA_full :
      ∀ γA ∈ Set.Icc (0 : ℝ) 1,
        (SA γA).academicMerit groupA Pfull =
          theorem1FullMeritFromStandardizedScore H baseA scaleA hscaleA_pos
            (theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA) γA)
    (hmeritA_sub :
      ∀ γA ∈ Set.Icc (0 : ℝ) 1,
        (SA γA).academicMerit groupA Psub =
          theorem1SubMeritFromBenchmark H baseA scaleA xiA hscaleA_pos
            hxiA_pos benchmarkA)
    (hmeritB_access :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1, (SB γB).accessLevel groupB = γB)
    (hscaleB_pos : 0 < scaleB)
    (hxiB_pos : 0 < xiB)
    (hmeritB_full :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        (SB γB).academicMerit groupB Pfull =
          theorem1FullMeritFromStandardizedScore H baseB scaleB hscaleB_pos
            (theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB) γB)
    (hmeritB_sub :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        (SB γB).academicMerit groupB Psub =
          theorem1SubMeritFromBenchmark H baseB scaleB xiB hscaleB_pos
            hxiB_pos benchmarkB)
    (hownA_pos : 0 < ownShareA)
    (hotherA_pos : 0 < otherEligibleMassA)
    (hrhoA_nonneg : 0 ≤ rhoA) (hrhoA_lt_one : rhoA < 1)
    (hselectiveA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareA * γ + otherEligibleMassA)
    (hownB_pos : 0 < ownShareB)
    (hotherB_pos : 0 < otherEligibleMassB)
    (hone_lt_rhoB : 1 < rhoB)
    (hselectiveB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareB * γ + otherEligibleMassB) :
    (∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        theorem1SourceDiversityImproves Sdiv Pfull Psub γB ↔ γB < γbar) ∧
      (∃ γbarA : ℝ,
        ∀ γA ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SA groupA Pfull Psub γA ↔
            γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SB groupB Pfull Psub γB ↔
            γB ≤ γbarB) := by
  have hcapacity_eq_metrics :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          groupAEligibleMass *
              H.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              H.api.thresholdPassProb L_B (threshold γB) := by
    intro γB hγB
    rw [← hdiv_capacity γB hγB]
    exact hcapacity_eq γB hγB
  obtain ⟨hdiv, hmeritA, hmeritB⟩ :=
    paper_theorem1_dropping_tests_with_barriers_explicit_metrics
      H Q hthreshold_cont hcapacity_pos hgroupA_pos hgroupB_pos
      hcapacity_eq_metrics hscaleA_pos hxiA_pos hownA_pos hotherA_pos
      hrhoA_nonneg hrhoA_lt_one hselectiveA hscaleB_pos hxiB_pos hownB_pos
      hotherB_pos hone_lt_rhoB hselectiveB
  refine ⟨?_, ?_, ?_⟩
  · rcases hdiv with ⟨γbar, hγbar⟩
    refine ⟨γbar, ?_⟩
    intro γB hγB
    rw [theorem1SourceDiversityImproves, hdiversity_full γB hγB,
      hdiversity_sub γB hγB]
    simpa [theorem1DiversityImproves] using hγbar γB hγB
  · rcases hmeritA with ⟨γbarA, hγbarA⟩
    refine ⟨γbarA, ?_⟩
    intro γA hγA
    rw [theorem1SourceAcademicMeritImproves, hmeritA_full γA hγA,
      hmeritA_sub γA hγA]
    simpa [theorem1AcademicMeritImproves] using hγbarA γA hγA
  · rcases hmeritB with ⟨γbarB, hγbarB⟩
    refine ⟨γbarB, ?_⟩
    intro γB hγB
    rw [theorem1SourceAcademicMeritImproves, hmeritB_full γB hγB,
      hmeritB_sub γB hγB]
    simpa [theorem1AcademicMeritImproves] using hγbarB γB hγB

/--
Theorem 1, canonical source-surface endpoint.

This is the least opaque current Theorem 1 statement: the varying source
surfaces are the canonical Lean surfaces above, so the access, diversity, and
academic-merit field equations are discharged by computation.  The remaining
mathematical source premise is exactly the admissions capacity equation for
the full-policy cutoff family.
-/
theorem paper_theorem1_dropping_tests_with_barriers_canonical_source_surfaces
    (H : GaussianHazardInverseCertificate) (Q : StandardGaussianQuantileAPI)
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    {Pfull Psub : Policy} (hP_ne : Pfull ≠ Psub)
    {groupA groupB : Group}
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw} {threshold : ℝ → ℝ}
    {ownShareA otherEligibleMassA rhoA xiA benchmarkA baseA scaleA : ℝ}
    {ownShareB otherEligibleMassB rhoB xiB benchmarkB baseB scaleB : ℝ}
    (hthreshold_cont : ContinuousOn threshold (Set.Icc (0 : ℝ) 1))
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hcapacity_eq :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          groupAEligibleMass *
              H.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              H.api.thresholdPassProb L_B (threshold γB))
    (hscaleA_pos : 0 < scaleA)
    (hxiA_pos : 0 < xiA)
    (hownA_pos : 0 < ownShareA)
    (hotherA_pos : 0 < otherEligibleMassA)
    (hrhoA_nonneg : 0 ≤ rhoA) (hrhoA_lt_one : rhoA < 1)
    (hselectiveA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareA * γ + otherEligibleMassA)
    (hscaleB_pos : 0 < scaleB)
    (hxiB_pos : 0 < xiB)
    (hownB_pos : 0 < ownShareB)
    (hotherB_pos : 0 < otherEligibleMassB)
    (hone_lt_rhoB : 1 < rhoB)
    (hselectiveB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareB * γ + otherEligibleMassB) :
    let Sdiv :=
      theorem1DiversitySourceSurface H.api Pfull Psub groupB
        capacity groupBShare diversitySub L_B threshold
    let SA :=
      theorem1AcademicMeritSourceSurface H Pfull Psub groupA
        capacity baseA scaleA xiA hscaleA_pos hxiA_pos benchmarkA
        (theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA)
    let SB :=
      theorem1AcademicMeritSourceSurface H Pfull Psub groupB
        capacity baseB scaleB xiB hscaleB_pos hxiB_pos benchmarkB
        (theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB)
    (∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        theorem1SourceDiversityImproves Sdiv Pfull Psub γB ↔ γB < γbar) ∧
      (∃ γbarA : ℝ,
        ∀ γA ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SA groupA Pfull Psub γA ↔
            γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SB groupB Pfull Psub γB ↔
            γB ≤ γbarB) := by
  dsimp only
  let Sdiv :=
    theorem1DiversitySourceSurface H.api Pfull Psub groupB
      capacity groupBShare diversitySub L_B threshold
  let SA :=
    theorem1AcademicMeritSourceSurface H Pfull Psub groupA
      capacity baseA scaleA xiA hscaleA_pos hxiA_pos benchmarkA
      (theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA)
  let SB :=
    theorem1AcademicMeritSourceSurface H Pfull Psub groupB
      capacity baseB scaleB xiB hscaleB_pos hxiB_pos benchmarkB
      (theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB)
  refine
    paper_theorem1_dropping_tests_with_barriers_source_surface
      (H := H) (Q := Q) (Sdiv := Sdiv) (SA := SA) (SB := SB)
      (Pfull := Pfull) (Psub := Psub) (groupA := groupA) (groupB := groupB)
      (diversitySub := diversitySub) (capacity := capacity)
      (groupAEligibleMass := groupAEligibleMass) (groupBShare := groupBShare)
      (L_A := L_A) (L_B := L_B) (threshold := threshold)
      (ownShareA := ownShareA) (otherEligibleMassA := otherEligibleMassA)
      (rhoA := rhoA) (xiA := xiA) (benchmarkA := benchmarkA)
      (baseA := baseA) (scaleA := scaleA) (ownShareB := ownShareB)
      (otherEligibleMassB := otherEligibleMassB) (rhoB := rhoB)
      (xiB := xiB) (benchmarkB := benchmarkB) (baseB := baseB)
      (scaleB := scaleB)
      hthreshold_cont hcapacity_pos hgroupA_pos hgroupB_pos ?_ ?_ ?_ ?_ ?_ ?_
      hscaleA_pos hxiA_pos ?_ ?_ ?_ hscaleB_pos hxiB_pos ?_ ?_
      hownA_pos hotherA_pos hrhoA_nonneg hrhoA_lt_one hselectiveA
      hownB_pos hotherB_pos hone_lt_rhoB hselectiveB
  · intro γB _hγB
    simp [Sdiv, theorem1DiversitySourceSurface]
  · intro γB _hγB
    simp [Sdiv, theorem1DiversitySourceSurface]
  · intro γB hγB
    simp [Sdiv, theorem1DiversitySourceSurface, hcapacity_eq γB hγB]
  · intro γB _hγB
    simp [Sdiv, theorem1DiversitySourceSurface]
  · intro γB _hγB
    simp [Sdiv, theorem1DiversitySourceSurface, hP_ne.symm]
  · intro γA _hγA
    simp [SA, theorem1AcademicMeritSourceSurface]
  · intro γA _hγA
    simp [SA, theorem1AcademicMeritSourceSurface]
  · intro γA _hγA
    simp [SA, theorem1AcademicMeritSourceSurface, hP_ne.symm]
  · intro γB _hγB
    simp [SB, theorem1AcademicMeritSourceSurface]
  · intro γB _hγB
    simp [SB, theorem1AcademicMeritSourceSurface]
  · intro γB _hγB
    simp [SB, theorem1AcademicMeritSourceSurface, hP_ne.symm]

/--
