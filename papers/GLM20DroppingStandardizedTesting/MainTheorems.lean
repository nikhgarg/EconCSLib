      0 ≤
        (1 - pi) *
            ((subA / (priorPrecision + subA)) /
              (subB / (priorPrecision + subB))) +
          pi :=
    theorem2_diversity_sqrt_term_nonneg hpi_pos hleftWeight_pos.le
      hprior_pos hsubA_pos hsubB_pos
  have htermFull_nonneg :
      0 ≤
        (1 - pi) *
            (((subA + testA) / (priorPrecision + subA + testA)) /
              ((subB + testB) / (priorPrecision + subB + testB))) +
          pi := by
    simpa [add_assoc] using
      (theorem2_diversity_sqrt_term_nonneg
        (pi := pi) (leftWeight := 1 - pi)
        (priorPrecision := priorPrecision)
        (precisionA := subA + testA)
        (precisionB := subB + testB)
        hpi_pos hleftWeight_pos.le hprior_pos hfullA_pos hfullB_pos)
  exact
    paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_surface_of_precision_order
      (groupA := groupA) (groupB := groupB) (Psub := Psub) (Pfull := Pfull)
      (pi := pi) (capacity := capacity) (quantile := quantile)
      (leftWeight := 1 - pi) (priorPrecision := priorPrecision) (mean := mean)
      (subA := subA) (subB := subB) (testA := testA) (testB := testB)
      (L_A_sub := L_A_sub) (L_A_full := L_A_full)
      (L_B_sub := L_B_sub) (L_B_full := L_B_full)
      (thresholdSub := thresholdSub) (thresholdFull := thresholdFull)
      hgroups hP_ne hquantile_pos hleftWeight_pos
      htermSub_nonneg htermFull_nonneg
      hprior_pos hsubA_pos hsubB_pos htestA_pos htestB_pos
      hfull_precision_order hsub_precision_order hpi_pos hpi_lt_one
      hmean_sub hmean_A hmean_B hscale_A hscale_B hcapacity_sub
      hcapacity_full hcapacity_lt_half

/--
Theorem 2, no-barrier source-family wrapper.

This variant plugs the marginal estimated-skill laws generated by
`GaussianOffsetSignalFamily` into the paper-parameter Theorem 2 wrapper.  It
derives the same-mean and larger-scale hypotheses from common prior means,
common prior variances, and signal-precision sums; the remaining assumptions
are the paper's precision-order and capacity equations.
-/
theorem paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_families_of_precision_order_population_weights
    {SubFeature FullFeature Group Policy : Type*}
    [Fintype SubFeature] [Nonempty SubFeature]
    [Fintype FullFeature] [Nonempty FullFeature]
    [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) {Psub Pfull : Policy}
    {M_A_sub M_B_sub : GaussianOffsetSignalFamily SubFeature}
    {M_A_full M_B_full : GaussianOffsetSignalFamily FullFeature}
    {pi capacity quantile priorPrecision mean subA subB testA testB : ℝ}
    {thresholdSub thresholdFull : ℝ}
    (hgroups : groupA ≠ groupB) (hP_ne : Psub ≠ Pfull)
    (hquantile_pos : 0 < quantile)
    (hpriorPrecision : M_A_sub.centeredFamily.priorPrecision = priorPrecision)
    (hmeanA_sub : M_A_sub.priorMean = mean)
    (hmeanB_sub : M_B_sub.priorMean = mean)
    (hmeanA_full : M_A_full.priorMean = mean)
    (hmeanB_full : M_B_full.priorMean = mean)
    (hpriorVar_A : M_A_sub.priorVar = M_A_full.priorVar)
    (hpriorVar_B : M_B_sub.priorVar = M_B_full.priorVar)
    (hsubA_sum : M_A_sub.centeredFamily.signalPrecisionSum = subA)
    (hsubB_sum : M_B_sub.centeredFamily.signalPrecisionSum = subB)
    (hfullA_sum : M_A_full.centeredFamily.signalPrecisionSum = subA + testA)
    (hfullB_sum : M_B_full.centeredFamily.signalPrecisionSum = subB + testB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB)
    (hfull_precision_order : subB + testB < subA + testA)
    (hsub_precision_order : subA < subB)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hcapacity_sub :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_sub.posteriorMeanScaleLaw thresholdSub +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_sub.posteriorMeanScaleLaw thresholdSub)
    (hcapacity_full :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_full.posteriorMeanScaleLaw thresholdFull +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_full.posteriorMeanScaleLaw thresholdFull)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ)) :
    let interceptAFull :=
      (priorPrecision * (thresholdFull - mean) +
          (subA + testA) * thresholdFull) /
        Real.sqrt (subA + testA)
    let slopeAFull := Real.sqrt (subA + testA)
    let interceptASub :=
      (priorPrecision * (thresholdSub - mean) + subA * thresholdSub) /
        Real.sqrt subA
    let slopeASub := Real.sqrt subA
    let interceptBFull :=
      (priorPrecision * (thresholdFull - mean) +
          (subB + testB) * thresholdFull) /
        Real.sqrt (subB + testB)
    let slopeBFull := Real.sqrt (subB + testB)
    let interceptBSub :=
      (priorPrecision * (thresholdSub - mean) + subB * thresholdSub) /
        Real.sqrt subB
    let slopeBSub := Real.sqrt subB
    let S : GLM20SourcePolicySurface Group Policy :=
      theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
        pi capacity quantile (1 - pi) priorPrecision subA subB testA testB
        interceptAFull slopeAFull interceptASub slopeASub
        interceptBFull slopeBFull interceptBSub slopeBSub
        M_A_sub.posteriorMeanScaleLaw M_A_full.posteriorMeanScaleLaw
        M_B_sub.posteriorMeanScaleLaw M_B_full.posteriorMeanScaleLaw
        thresholdSub thresholdFull
    (S.diversity Psub > S.diversity Pfull ↔
      (subA * (priorPrecision + subA + testA)) /
          (subB * (priorPrecision + subB + testB)) <
        testA / testB) ∧
      (∃ qA qB : ℝ,
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q >
              standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q ↔
            qA < q) ∧
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q >
              standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q ↔
            qB < q) ∧
        ∃ qhat : ℝ, max qA qB ≤ qhat ∧
          ∀ q : ℝ, qhat < q →
            S.individualFairnessGap Pfull q >
              S.individualFairnessGap Psub q) ∧
      S.academicMerit groupA Psub < S.academicMerit groupA Pfull ∧
        S.academicMerit groupB Psub < S.academicMerit groupB Pfull := by
  have hprior_pos : 0 < priorPrecision := by
    simpa [hpriorPrecision] using M_A_sub.centeredFamily.priorPrecision_pos
  have hsubA_pos : 0 < subA := by
    simpa [hsubA_sum] using M_A_sub.centeredFamily.signalPrecisionSum_pos
  have hsubB_pos : 0 < subB := by
    simpa [hsubB_sum] using M_B_sub.centeredFamily.signalPrecisionSum_pos
  have hmean_sub :
      (M_A_sub.posteriorMeanScaleLaw).mean =
        (M_B_sub.posteriorMeanScaleLaw).mean := by
    simp [GaussianOffsetSignalFamily.posteriorMeanScaleLaw,
      hmeanA_sub, hmeanB_sub]
  have hmean_A :
      (M_A_sub.posteriorMeanScaleLaw).mean =
        (M_A_full.posteriorMeanScaleLaw).mean := by
    simp [GaussianOffsetSignalFamily.posteriorMeanScaleLaw,
      hmeanA_sub, hmeanA_full]
  have hmean_B :
      (M_B_sub.posteriorMeanScaleLaw).mean =
        (M_B_full.posteriorMeanScaleLaw).mean := by
    simp [GaussianOffsetSignalFamily.posteriorMeanScaleLaw,
      hmeanB_sub, hmeanB_full]
  have hsum_A :
      M_A_sub.centeredFamily.signalPrecisionSum <
        M_A_full.centeredFamily.signalPrecisionSum := by
    rw [hsubA_sum, hfullA_sum]
    linarith
  have hsum_B :
      M_B_sub.centeredFamily.signalPrecisionSum <
        M_B_full.centeredFamily.signalPrecisionSum := by
    rw [hsubB_sum, hfullB_sum]
    linarith
  have hscale_A :
      (M_A_sub.posteriorMeanScaleLaw).scale <
        (M_A_full.posteriorMeanScaleLaw).scale :=
    GaussianOffsetSignalFamily.posteriorMeanScaleLaw_scale_lt_of_priorVar_eq_signalPrecisionSum_lt
      hpriorVar_A hsum_A
  have hscale_B :
      (M_B_sub.posteriorMeanScaleLaw).scale <
        (M_B_full.posteriorMeanScaleLaw).scale :=
    GaussianOffsetSignalFamily.posteriorMeanScaleLaw_scale_lt_of_priorVar_eq_signalPrecisionSum_lt
      hpriorVar_B hsum_B
  exact
    paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_surface_of_precision_order_population_weights
      (groupA := groupA) (groupB := groupB) (Psub := Psub) (Pfull := Pfull)
      (pi := pi) (capacity := capacity) (quantile := quantile)
      (priorPrecision := priorPrecision) (mean := mean)
      (subA := subA) (subB := subB) (testA := testA) (testB := testB)
      (L_A_sub := M_A_sub.posteriorMeanScaleLaw)
      (L_A_full := M_A_full.posteriorMeanScaleLaw)
      (L_B_sub := M_B_sub.posteriorMeanScaleLaw)
      (L_B_full := M_B_full.posteriorMeanScaleLaw)
      (thresholdSub := thresholdSub) (thresholdFull := thresholdFull)
      hgroups hP_ne hquantile_pos hprior_pos hsubA_pos hsubB_pos
      htestA_pos htestB_pos hfull_precision_order hsub_precision_order
      hpi_pos hpi_lt_one hmean_sub hmean_A hmean_B hscale_A hscale_B
      hcapacity_sub hcapacity_full hcapacity_lt_half

/--
Theorem 2, no-barrier source-family wrapper with constructed capacity
thresholds.

The two common admissions thresholds for `P_sub` and `P_full` are obtained
from the concrete standard-normal finite-mixture capacity equation.  The
remaining source assumptions are the paper's common-prior/precision-sum
identifications and the precision-order hypotheses.
-/
theorem paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_families_of_precision_order_population_weights_capacity_thresholds
    {SubFeature FullFeature Group Policy : Type*}
    [Fintype SubFeature] [Nonempty SubFeature]
    [Fintype FullFeature] [Nonempty FullFeature]
    [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) {Psub Pfull : Policy}
    {M_A_sub M_B_sub : GaussianOffsetSignalFamily SubFeature}
    {M_A_full M_B_full : GaussianOffsetSignalFamily FullFeature}
    {pi capacity quantile priorPrecision mean subA subB testA testB : ℝ}
    (hgroups : groupA ≠ groupB) (hP_ne : Psub ≠ Pfull)
    (hquantile_pos : 0 < quantile)
    (hcapacity_pos : 0 < capacity)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ))
    (hpriorPrecision : M_A_sub.centeredFamily.priorPrecision = priorPrecision)
    (hmeanA_sub : M_A_sub.priorMean = mean)
    (hmeanB_sub : M_B_sub.priorMean = mean)
    (hmeanA_full : M_A_full.priorMean = mean)
    (hmeanB_full : M_B_full.priorMean = mean)
    (hpriorVar_A : M_A_sub.priorVar = M_A_full.priorVar)
    (hpriorVar_B : M_B_sub.priorVar = M_B_full.priorVar)
    (hsubA_sum : M_A_sub.centeredFamily.signalPrecisionSum = subA)
    (hsubB_sum : M_B_sub.centeredFamily.signalPrecisionSum = subB)
    (hfullA_sum : M_A_full.centeredFamily.signalPrecisionSum = subA + testA)
    (hfullB_sum : M_B_full.centeredFamily.signalPrecisionSum = subB + testB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB)
    (hfull_precision_order : subB + testB < subA + testA)
    (hsub_precision_order : subA < subB)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1) :
    ∃ thresholdSub thresholdFull : ℝ,
      let interceptAFull :=
        (priorPrecision * (thresholdFull - mean) +
            (subA + testA) * thresholdFull) /
          Real.sqrt (subA + testA)
      let slopeAFull := Real.sqrt (subA + testA)
      let interceptASub :=
        (priorPrecision * (thresholdSub - mean) + subA * thresholdSub) /
          Real.sqrt subA
      let slopeASub := Real.sqrt subA
      let interceptBFull :=
        (priorPrecision * (thresholdFull - mean) +
            (subB + testB) * thresholdFull) /
          Real.sqrt (subB + testB)
      let slopeBFull := Real.sqrt (subB + testB)
      let interceptBSub :=
        (priorPrecision * (thresholdSub - mean) + subB * thresholdSub) /
          Real.sqrt subB
      let slopeBSub := Real.sqrt subB
      let S : GLM20SourcePolicySurface Group Policy :=
        theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
          pi capacity quantile (1 - pi) priorPrecision subA subB testA testB
          interceptAFull slopeAFull interceptASub slopeASub
          interceptBFull slopeBFull interceptBSub slopeBSub
          M_A_sub.posteriorMeanScaleLaw M_A_full.posteriorMeanScaleLaw
          M_B_sub.posteriorMeanScaleLaw M_B_full.posteriorMeanScaleLaw
          thresholdSub thresholdFull
      (S.diversity Psub > S.diversity Pfull ↔
        (subA * (priorPrecision + subA + testA)) /
            (subB * (priorPrecision + subB + testB)) <
          testA / testB) ∧
        (∃ qA qB : ℝ,
          (∀ q : ℝ,
            standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q >
                standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q ↔
              qA < q) ∧
          (∀ q : ℝ,
            standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q >
                standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q ↔
              qB < q) ∧
          ∃ qhat : ℝ, max qA qB ≤ qhat ∧
            ∀ q : ℝ, qhat < q →
              S.individualFairnessGap Pfull q >
                S.individualFairnessGap Psub q) ∧
        S.academicMerit groupA Psub < S.academicMerit groupA Pfull ∧
          S.academicMerit groupB Psub < S.academicMerit groupB Pfull := by
  let weight : Bool → ℝ := fun b => if b then pi else 1 - pi
  let lawSub : Bool → GaussianScaleLaw :=
    fun b => if b then M_B_sub.posteriorMeanScaleLaw
      else M_A_sub.posteriorMeanScaleLaw
  let lawFull : Bool → GaussianScaleLaw :=
    fun b => if b then M_B_full.posteriorMeanScaleLaw
      else M_A_full.posteriorMeanScaleLaw
  have hcapacity_mem : capacity ∈ Set.Ioo (0 : ℝ) (∑ b : Bool, weight b) := by
    have hlt_one : capacity < 1 := by linarith
    constructor
    · exact hcapacity_pos
    · simpa [weight, add_comm, add_left_comm, add_assoc] using hlt_one
  rcases standardGaussianCDFAPI.exists_mixtureTailMass_eq_of_capacity_mem_Ioo
      standardGaussianCDF_tendsto_atBot standardGaussianCDF_tendsto_atTop
      (weight := weight) (law := lawSub) hcapacity_mem with
    ⟨thresholdSub, hthresholdSub⟩
  rcases standardGaussianCDFAPI.exists_mixtureTailMass_eq_of_capacity_mem_Ioo
      standardGaussianCDF_tendsto_atBot standardGaussianCDF_tendsto_atTop
      (weight := weight) (law := lawFull) hcapacity_mem with
    ⟨thresholdFull, hthresholdFull⟩
  have hcapacity_sub :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_sub.posteriorMeanScaleLaw thresholdSub +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_sub.posteriorMeanScaleLaw thresholdSub := by
    rw [← hthresholdSub]
    simp [StandardGaussianCDFAPI.mixtureTailMass, weight, lawSub, add_comm]
  have hcapacity_full :
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_full.posteriorMeanScaleLaw thresholdFull +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_full.posteriorMeanScaleLaw thresholdFull := by
    rw [← hthresholdFull]
    simp [StandardGaussianCDFAPI.mixtureTailMass, weight, lawFull, add_comm]
  refine ⟨thresholdSub, thresholdFull, ?_⟩
  exact
    paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_families_of_precision_order_population_weights
      (groupA := groupA) (groupB := groupB) (Psub := Psub) (Pfull := Pfull)
      (M_A_sub := M_A_sub) (M_B_sub := M_B_sub)
      (M_A_full := M_A_full) (M_B_full := M_B_full)
      (pi := pi) (capacity := capacity) (quantile := quantile)
      (priorPrecision := priorPrecision) (mean := mean)
      (subA := subA) (subB := subB) (testA := testA) (testB := testB)
      (thresholdSub := thresholdSub) (thresholdFull := thresholdFull)
      hgroups hP_ne hquantile_pos hpriorPrecision hmeanA_sub hmeanB_sub
      hmeanA_full hmeanB_full hpriorVar_A hpriorVar_B hsubA_sum hsubB_sum
      hfullA_sum hfullB_sum htestA_pos htestB_pos hfull_precision_order
      hsub_precision_order hpi_pos hpi_lt_one hcapacity_sub hcapacity_full
      hcapacity_lt_half

/--
Theorem 2, direct standard-Gaussian no-barrier source surface in the
main-text high-skill direction.

This has the same diversity, group-threshold, and academic-merit clauses as
`paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_surface`,
but it uses the prose/main-text high-skill conclusion
`I(q; P_sub) > I(q; P_full)`.
-/
theorem paper_theorem2_dropping_tests_without_barriers_standardGaussian_source_surface_main_text_direction
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) {Psub Pfull : Policy}
    {pi capacity quantile leftWeight priorPrecision subA subB testA testB : ℝ}
    {interceptAFull slopeAFull interceptASub slopeASub
      interceptBFull slopeBFull interceptBSub slopeBSub : ℝ}
    {L_A_sub L_A_full L_B_sub L_B_full : GaussianScaleLaw}
    {thresholdSub thresholdFull qDelta : ℝ}
    (hgroups : groupA ≠ groupB) (hP_ne : Psub ≠ Pfull)
    (hquantile_pos : 0 < quantile)
    (hleftWeight_pos : 0 < leftWeight)
    (htermSub_nonneg :
      0 ≤
        leftWeight *
            ((subA / (priorPrecision + subA)) /
              (subB / (priorPrecision + subB))) +
          pi)
    (htermFull_nonneg :
      0 ≤
        leftWeight *
            (((subA + testA) /
                (priorPrecision + subA + testA)) /
              ((subB + testB) /
                (priorPrecision + subB + testB))) +
          pi)
    (hprior_pos : 0 < priorPrecision)
    (hsubA_pos : 0 < subA) (hsubB_pos : 0 < subB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB)
    (hslopeA : slopeASub < slopeAFull)
    (hslopeB : slopeBSub < slopeBFull)
    (hdelta :
      ∀ q : ℝ, qDelta < q →
        standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q -
            standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q <
          standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q -
            standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hmean_sub : L_A_sub.mean = L_B_sub.mean)
    (hmean_A : L_A_sub.mean = L_A_full.mean)
    (hmean_B : L_B_sub.mean = L_B_full.mean)
    (hscale_A : L_A_sub.scale < L_A_full.scale)
    (hscale_B : L_B_sub.scale < L_B_full.scale)
    (hcapacity_sub :
      capacity =
        (1 - pi) * standardGaussianCDFAPI.thresholdPassProb L_A_sub thresholdSub +
          pi * standardGaussianCDFAPI.thresholdPassProb L_B_sub thresholdSub)
    (hcapacity_full :
      capacity =
        (1 - pi) * standardGaussianCDFAPI.thresholdPassProb L_A_full thresholdFull +
          pi * standardGaussianCDFAPI.thresholdPassProb L_B_full thresholdFull)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ)) :
    let S : GLM20SourcePolicySurface Group Policy :=
      theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
        pi capacity quantile leftWeight priorPrecision subA subB testA testB
        interceptAFull slopeAFull interceptASub slopeASub
        interceptBFull slopeBFull interceptBSub slopeBSub
        L_A_sub L_A_full L_B_sub L_B_full thresholdSub thresholdFull
    (S.diversity Psub > S.diversity Pfull ↔
      (subA * (priorPrecision + subA + testA)) /
          (subB * (priorPrecision + subB + testB)) <
        testA / testB) ∧
      (∃ qA qB : ℝ,
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q >
              standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q ↔
            qA < q) ∧
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q >
              standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q ↔
            qB < q) ∧
        ∃ qhat : ℝ, max qA qB ≤ qhat ∧
          ∀ q : ℝ, qhat < q →
            S.individualFairnessGap Psub q >
              S.individualFairnessGap Pfull q) ∧
      S.academicMerit groupA Psub < S.academicMerit groupA Pfull ∧
        S.academicMerit groupB Psub < S.academicMerit groupB Pfull := by
  dsimp only
  let S : GLM20SourcePolicySurface Group Policy :=
    theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
      pi capacity quantile leftWeight priorPrecision subA subB testA testB
      interceptAFull slopeAFull interceptASub slopeASub
      interceptBFull slopeBFull interceptBSub slopeBSub
      L_A_sub L_A_full L_B_sub L_B_full thresholdSub thresholdFull
  have hthreshold_lt :
      thresholdSub < thresholdFull :=
    paper_theorem2_admission_threshold_full_gt_sub_of_scale_increases
      standardGaussianCDFAPI hpi_pos hpi_lt_one hmean_sub hmean_A hmean_B
      hscale_A hscale_B hcapacity_sub hcapacity_full hcapacity_lt_half
  have hthreshold_le : thresholdSub ≤ thresholdFull := le_of_lt hthreshold_lt
  have hthreshold_B_sub : L_B_sub.mean < thresholdSub :=
    paper_proposition1_threshold_gt_common_mean_of_capacity_lt_half
      standardGaussianCDFAPI hpi_pos.le hpi_lt_one.le hmean_sub hcapacity_sub
      hcapacity_lt_half
  have hthreshold_A_sub : L_A_sub.mean < thresholdSub := by
    rw [hmean_sub]
    exact hthreshold_B_sub
  have hgroups_symm : groupB ≠ groupA := hgroups.symm
  refine ⟨?_, ?_, ?_⟩
  · exact
      paper_theorem2_diversity_tail_formula_improves_iff_test_precision_ratio
        standardGaussianCDFAPI
        (S := S) (Psub := Psub) (Pfull := Pfull)
        (by simp [S, theorem2NoBarrierSourceSurface])
        (by simp [S, theorem2NoBarrierSourceSurface, hP_ne.symm])
        hquantile_pos hleftWeight_pos htermSub_nonneg htermFull_nonneg
        hprior_pos hsubA_pos hsubB_pos htestA_pos htestB_pos
  · exact
      paper_theorem2_high_skill_individual_fairness_gap_sub_gt_full_source_surface
        (groupA := groupA) (groupB := groupB) (Psub := Psub) (Pfull := Pfull)
        (pi := pi) (capacity := capacity) (quantile := quantile)
        (leftWeight := leftWeight) (priorPrecision := priorPrecision)
        (subA := subA) (subB := subB) (testA := testA) (testB := testB)
        (interceptAFull := interceptAFull) (slopeAFull := slopeAFull)
        (interceptASub := interceptASub) (slopeASub := slopeASub)
        (interceptBFull := interceptBFull) (slopeBFull := slopeBFull)
        (interceptBSub := interceptBSub) (slopeBSub := slopeBSub)
        (L_A_sub := L_A_sub) (L_A_full := L_A_full)
        (L_B_sub := L_B_sub) (L_B_full := L_B_full)
        (thresholdSub := thresholdSub) (thresholdFull := thresholdFull)
        (qDelta := qDelta) hP_ne hslopeA hslopeB hdelta
  · constructor
    · exact
        paper_theorem2_group_academic_merit_full_gt_sub_of_tail_mean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          (S := S) groupA hmean_A hscale_A hthreshold_A_sub hthreshold_le
