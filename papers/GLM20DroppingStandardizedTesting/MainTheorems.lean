                            fullSubLowCostThreshold fullSubHighCostThreshold
                            q1Sub q2Sub
                            (fun g q =>
                              glm20StrategicSubEstimateMassAbove api
                                (subEstimateLaw g) q)) ∧
                          glm20Theorem3FullFullCondition S Pfull groupA
                            groupB testCost) := by
  let objective1 : Policy → Policy → ℝ :=
