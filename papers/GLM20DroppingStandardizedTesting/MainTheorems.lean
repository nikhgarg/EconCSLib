        glm20BivariateApplyAdmitMass standardGaussianCDFAPI
          standardBivariateGaussianCDF
          (populationShare g) (sigmaTilde g) (aOfApply g)
          (b g) (mu g) qApply qAdmit
    let hscale :
      ∀ g : Group,
