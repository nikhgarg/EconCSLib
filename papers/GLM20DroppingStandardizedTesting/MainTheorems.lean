/--
Theorem 3 support: the paper's `K_g(q)` term is the mass of group-`g`
students whose test-free estimated skill exceeds the threshold `q`.

This definition takes the relevant group-specific test-free estimated-skill
law as a `GaussianScaleLaw`; in the paper this law has mean `μ` and scale
`σ * sqrt(sum_{k in sub} σ_gk^{-2} / (σ^{-2} + sum_{k in sub} σ_gk^{-2}))`.
-/
def glm20StrategicSubEstimateMassAbove
    (api : StandardGaussianCDFAPI) (subEstimateLaw : GaussianScaleLaw)
    (q : ℝ) : ℝ := api.thresholdPassProb subEstimateLaw q

/-- Theorem 3 support: `K_g(q)` is a continuous function of the threshold. -/
theorem glm20StrategicSubEstimateMassAbove_continuous
    (api : StandardGaussianCDFAPI) (subEstimateLaw : GaussianScaleLaw) :
    Continuous (glm20StrategicSubEstimateMassAbove api subEstimateLaw) := api.thresholdPassProb_continuous subEstimateLaw

/-- Theorem 3 support: `K_g(q)` is strictly decreasing in the threshold. -/
theorem glm20StrategicSubEstimateMassAbove_strictAnti
    (api : StandardGaussianCDFAPI) (subEstimateLaw : GaussianScaleLaw) :
    StrictAnti (glm20StrategicSubEstimateMassAbove api subEstimateLaw) := api.thresholdPassProb_strictAnti_threshold subEstimateLaw

/--
Theorem 3 support: expanded normal-tail formula for `K_g(q)`.

Paper statement:
`K_g(q) = 1 - Phi((q - μ) /
  (σ * sqrt(sum_{k in sub} σ_gk^{-2} /
    (σ^{-2} + sum_{k in sub} σ_gk^{-2}))))`.
-/
theorem paper_theorem3_Kg_eq_normal_tail_formula
    (api : StandardGaussianCDFAPI) (subEstimateLaw : GaussianScaleLaw)
    (q : ℝ) :
    glm20StrategicSubEstimateMassAbove api subEstimateLaw q =
      1 - api.cdf ((q - subEstimateLaw.mean) / subEstimateLaw.scale) := by
  simp [glm20StrategicSubEstimateMassAbove,
    StandardGaussianCDFAPI.thresholdPassProb,
    StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
    GaussianScaleLaw.standardize]

/--
Theorem 3 support: `K_g(q)` specialized to the canonical Gaussian posterior
mean law from Lemma 1.

This is the bridge from the Section 5 notation `K_g(q)` back to the already
formalized estimated-skill law for a group-specific `P_sub` feature family.
-/
theorem paper_theorem3_Kg_eq_offset_posterior_mean_tail
    {Feature : Type*} [Fintype Feature] [Nonempty Feature]
    (api : StandardGaussianCDFAPI) (M : GaussianOffsetSignalFamily Feature)
    (q : ℝ) :
    glm20StrategicSubEstimateMassAbove api M.posteriorMeanScaleLaw q =
      1 - api.cdf
        ((q - M.priorMean) / Real.sqrt M.posteriorMeanVariance) := by
  simp [glm20StrategicSubEstimateMassAbove,
    StandardGaussianCDFAPI.thresholdPassProb,
    StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
    GaussianScaleLaw.standardize,
    GaussianOffsetSignalFamily.posteriorMeanScaleLaw]

/--
Theorem 3 source notation: the Gaussian law of the test-free estimated skill
used in the paper's `K_g(q)` definition.

Paper formula:
`tilde q_sub ~ N(mu,
  sigma^2 * sum_{k in sub} sigma_gk^{-2} /
    (sigma^{-2} + sum_{k in sub} sigma_gk^{-2}))`.
We store the positive scale
`sigma * sqrt(subPrecisionSum / (priorPrecision + subPrecisionSum))`.
-/
def glm20StrategicSubEstimateLawSource
    (priorSigma priorPrecision subPrecisionSum mu : ℝ)
    (hpriorSigma_pos : 0 < priorSigma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsubPrecisionSum_pos : 0 < subPrecisionSum) :
    GaussianScaleLaw where
  mean := mu
  scale :=
    priorSigma *
      Real.sqrt (subPrecisionSum / (priorPrecision + subPrecisionSum))
  scale_pos := by
    refine mul_pos hpriorSigma_pos ?_
    exact Real.sqrt_pos.2
      (div_pos hsubPrecisionSum_pos (by linarith))

/--
Theorem 3 support: `K_g(q)` with the raw precision formula from the source.

This is the paper's displayed formula
`K_g(q) = 1 - Phi((q - mu) /
  (sigma * sqrt(sum_{k in sub} sigma_gk^{-2} /
    (sigma^{-2} + sum_{k in sub} sigma_gk^{-2}))))`.
-/
theorem paper_theorem3_Kg_eq_source_precision_tail
    (api : StandardGaussianCDFAPI)
    {priorSigma priorPrecision subPrecisionSum mu q : ℝ}
    (hpriorSigma_pos : 0 < priorSigma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsubPrecisionSum_pos : 0 < subPrecisionSum) :
    glm20StrategicSubEstimateMassAbove api
        (glm20StrategicSubEstimateLawSource priorSigma priorPrecision
          subPrecisionSum mu hpriorSigma_pos hpriorPrecision_pos
          hsubPrecisionSum_pos) q =
      1 -
        api.cdf
          ((q - mu) /
            (priorSigma *
              Real.sqrt
                (subPrecisionSum /
                  (priorPrecision + subPrecisionSum)))) := by
  simp [glm20StrategicSubEstimateMassAbove,
    glm20StrategicSubEstimateLawSource,
    StandardGaussianCDFAPI.thresholdPassProb,
    StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
    GaussianScaleLaw.standardize]

