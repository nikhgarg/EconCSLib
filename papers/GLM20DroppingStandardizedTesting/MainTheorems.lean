    intro g
    simpa [jointApplyAdmitMass] using
      glm20Lemma3StrategicApplicantComponent_measure_strictAnti
        Q jointLaw g (hfinite g) (hopen g) (hpopulation g)
  have hatBot :
      ∀ g : Group,
        Filter.Tendsto
          (glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
            priorPrecision subPrecision testPrecision cost value g)
          Filter.atBot (nhds (populationShare g * (jointLaw g).real Set.univ)) := by
    intro g
    simpa [jointApplyAdmitMass] using
      glm20Lemma3StrategicApplicantComponent_measure_tendsto_atBot
        Q jointLaw g (hfinite g)
  have hatTop :
      ∀ g : Group,
        Filter.Tendsto
          (glm20Lemma3StrategicApplicantComponent Q jointApplyAdmitMass
            priorPrecision subPrecision testPrecision cost value g)
          Filter.atTop (nhds 0) := by
    intro g
    simpa [jointApplyAdmitMass] using
      glm20Lemma3StrategicApplicantComponent_measure_tendsto_atTop
        Q jointLaw g (hfinite g)
  exact
    paper_lemma3_full_policy_threshold_equilibrium_existsUnique_of_strategic_applicant_components
      Q jointApplyAdmitMass hcont hanti hatBot hatTop hcapacity hprior_pos
      hsub_pos htest_pos hvalue hcostRatio

