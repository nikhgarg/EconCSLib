/--
Proposition 5 / equation (50), group-indexed threshold support.

This packages the source proof's repeated groupwise construction of the
`(P_sub,P_full)` cost threshold: global regularity of the admitted-merit
function in the Gaussian cutoff plus opposite endpoint comparisons produce a
positive interior threshold for every group.
-/
theorem
    paper_proposition5_equation50_subFull_cost_thresholds_of_cutoff_merit_crossing_interval_of_global_regular_cost_bounds
    (Q : StandardGaussianQuantileAPI)
    {Group : Type*}
    {q2Full scale v2 left right testFreeMerit : Group → ℝ}
    {meritOfCutoff : Group → ℝ → ℝ}
    (hleft_right : ∀ g, left g < right g)
    (hscale : ∀ g, 0 < scale g)
    (hleft_pos : ∀ g, 0 < left g)
    (hright_lt_v2 : ∀ g, right g < v2 g)
    (hmerit_cont : ∀ g, Continuous (meritOfCutoff g))
    (hmerit_anti : ∀ g, StrictAnti (meritOfCutoff g))
    (hleft :
      ∀ g,
        testFreeMerit g <
          meritOfCutoff g
            (q2Full g - scale g * Q.quantile (1 - left g / v2 g)))
    (hright :
      ∀ g,
        meritOfCutoff g
            (q2Full g - scale g * Q.quantile (1 - right g / v2 g)) <
          testFreeMerit g) :
    ∃ costThreshold : Group → ℝ,
      (∀ g, costThreshold g ∈ Set.Ioo (left g) (right g)) ∧
        (∀ g,
          meritOfCutoff g
              (q2Full g -
                scale g * Q.quantile (1 - costThreshold g / v2 g)) =
            testFreeMerit g) ∧
          (∀ g cost, cost ∈ Set.Icc (left g) (right g) →
            (testFreeMerit g <
                meritOfCutoff g
                  (q2Full g - scale g * Q.quantile (1 - cost / v2 g)) ↔
              cost < costThreshold g)) ∧
            (∀ g cost, cost ∈ Set.Icc (left g) (right g) →
              (meritOfCutoff g
                    (q2Full g - scale g * Q.quantile (1 - cost / v2 g)) <
                  testFreeMerit g ↔
                costThreshold g < cost)) ∧
              (∀ g cost, cost ∈ Set.Icc (left g) (right g) →
                (testFreeMerit g ≤
                    meritOfCutoff g
                      (q2Full g -
                        scale g * Q.quantile (1 - cost / v2 g)) ↔
                  cost ≤ costThreshold g)) ∧
                (∀ g cost, cost ∈ Set.Icc (left g) (right g) →
                  (meritOfCutoff g
                        (q2Full g -
                          scale g * Q.quantile (1 - cost / v2 g)) ≤
                      testFreeMerit g ↔
                    costThreshold g ≤ cost)) := by
  classical
  have hthreshold :
      ∀ g : Group, ∃ costThreshold : ℝ,
        costThreshold ∈ Set.Ioo (left g) (right g) ∧
          meritOfCutoff g
              (q2Full g -
                scale g * Q.quantile (1 - costThreshold / v2 g)) =
            testFreeMerit g ∧
            (∀ cost ∈ Set.Icc (left g) (right g),
              testFreeMerit g <
                  meritOfCutoff g
                    (q2Full g -
                      scale g * Q.quantile (1 - cost / v2 g)) ↔
                cost < costThreshold) ∧
              (∀ cost ∈ Set.Icc (left g) (right g),
                meritOfCutoff g
                    (q2Full g -
                      scale g * Q.quantile (1 - cost / v2 g)) <
                    testFreeMerit g ↔
                  costThreshold < cost) ∧
                (∀ cost ∈ Set.Icc (left g) (right g),
                  testFreeMerit g ≤
                      meritOfCutoff g
                        (q2Full g -
                          scale g * Q.quantile (1 - cost / v2 g)) ↔
                    cost ≤ costThreshold) ∧
                  (∀ cost ∈ Set.Icc (left g) (right g),
                    meritOfCutoff g
                        (q2Full g -
                          scale g * Q.quantile (1 - cost / v2 g)) ≤
                      testFreeMerit g ↔
                    costThreshold ≤ cost) := by
    intro g
    exact
      paper_proposition5_equation50_subFull_cost_threshold_of_cutoff_merit_crossing_interval_of_global_regular_cost_bounds
        Q (hleft_right g) (hscale g) (hleft_pos g) (hright_lt_v2 g)
        (hmerit_cont g) (hmerit_anti g) (hleft g) (hright g)
  let costThreshold : Group → ℝ := fun g => Classical.choose (hthreshold g)
  have hspec :
      ∀ g,
        costThreshold g ∈ Set.Ioo (left g) (right g) ∧
          meritOfCutoff g
              (q2Full g -
                scale g * Q.quantile (1 - costThreshold g / v2 g)) =
            testFreeMerit g ∧
            (∀ cost ∈ Set.Icc (left g) (right g),
              testFreeMerit g <
                  meritOfCutoff g
                    (q2Full g -
                      scale g * Q.quantile (1 - cost / v2 g)) ↔
                cost < costThreshold g) ∧
              (∀ cost ∈ Set.Icc (left g) (right g),
                meritOfCutoff g
                    (q2Full g -
                      scale g * Q.quantile (1 - cost / v2 g)) <
                    testFreeMerit g ↔
                  costThreshold g < cost) ∧
                (∀ cost ∈ Set.Icc (left g) (right g),
                  testFreeMerit g ≤
                      meritOfCutoff g
                        (q2Full g -
                          scale g * Q.quantile (1 - cost / v2 g)) ↔
                    cost ≤ costThreshold g) ∧
                  (∀ cost ∈ Set.Icc (left g) (right g),
                    meritOfCutoff g
                        (q2Full g -
                          scale g * Q.quantile (1 - cost / v2 g)) ≤
                      testFreeMerit g ↔
                    costThreshold g ≤ cost) := by
    intro g
    exact Classical.choose_spec (hthreshold g)
  exact
    ⟨costThreshold,
      (fun g => (hspec g).1),
      (fun g => (hspec g).2.1),
      (fun g cost hcost => (hspec g).2.2.1 cost hcost),
      (fun g cost hcost => (hspec g).2.2.2.1 cost hcost),
      (fun g cost hcost => (hspec g).2.2.2.2.1 cost hcost),
      (fun g cost hcost => (hspec g).2.2.2.2.2 cost hcost)⟩

/--
Lemma 3 strict payoff support above the cutoff: applying is strictly better
than not applying exactly above the displayed Gaussian cutoff.
-/
theorem paper_lemma3_apply_payoff_positive_iff_above_gaussian_cutoff
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold scale value cost q : ℝ}
    (hscale : 0 < scale) (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    0 < value *
        Q.cdfAPI.thresholdPassProb
          { mean := q, scale := scale, scale_pos := hscale }
          admissionThreshold - cost ↔
      glm20StrategicApplyCutoff Q admissionThreshold scale (cost / value) < q := by
  have htail :=
    Q.lt_standardTail_iff_lt_quantile_one_sub
      (alpha := cost / value)
      (z := (admissionThreshold - q) / scale)
      hcostRatio
  constructor
  · intro hpayoff
    have hprob :
        cost / value <
          Q.cdfAPI.thresholdPassProb
            { mean := q, scale := scale, scale_pos := hscale }
            admissionThreshold :=
      (paper_lemma3_apply_payoff_positive_iff_cost_ratio_lt_probability
          (value := value) (cost := cost)
          (admissionProbability :=
            Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold)
          hvalue).mp hpayoff
    have hstd :
        (admissionThreshold - q) / scale <
          Q.quantile (1 - cost / value) :=
      htail.mp (by
        simpa [StandardGaussianCDFAPI.thresholdPassProb,
          StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
          GaussianScaleLaw.standardize] using hprob)
    have hmul :
        admissionThreshold - q <
          scale * Q.quantile (1 - cost / value) := by
      have := (div_lt_iff₀ hscale).mp hstd
      simpa [mul_comm] using this
    unfold glm20StrategicApplyCutoff
    linarith
  · intro hcutoff
    have hstd :
        (admissionThreshold - q) / scale <
          Q.quantile (1 - cost / value) := by
      rw [div_lt_iff₀ hscale]
      unfold glm20StrategicApplyCutoff at hcutoff
      linarith
    have hprob := htail.mpr hstd
    have hprob' :
        cost / value <
          Q.cdfAPI.thresholdPassProb
            { mean := q, scale := scale, scale_pos := hscale }
            admissionThreshold := by
      simpa [StandardGaussianCDFAPI.thresholdPassProb,
        StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
        GaussianScaleLaw.standardize] using hprob
    exact
      (paper_lemma3_apply_payoff_positive_iff_cost_ratio_lt_probability
          (value := value) (cost := cost)
          (admissionProbability :=
            Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold)
          hvalue).mpr hprob'

/--
Lemma 3 strict payoff support below the cutoff: applying is strictly worse
than not applying exactly below the displayed Gaussian cutoff.
-/
theorem paper_lemma3_apply_payoff_negative_iff_below_gaussian_cutoff
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold scale value cost q : ℝ}
    (hscale : 0 < scale) (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    value *
        Q.cdfAPI.thresholdPassProb
          { mean := q, scale := scale, scale_pos := hscale }
          admissionThreshold - cost < 0 ↔
      q < glm20StrategicApplyCutoff Q admissionThreshold scale (cost / value) := by
  have htail :=
    Q.standardTail_lt_iff_quantile_one_sub_lt
      (alpha := cost / value)
      (z := (admissionThreshold - q) / scale)
      hcostRatio
  constructor
  · intro hpayoff
    have hprob :
        Q.cdfAPI.thresholdPassProb
            { mean := q, scale := scale, scale_pos := hscale }
            admissionThreshold <
          cost / value :=
      (paper_lemma3_apply_payoff_negative_iff_probability_lt_cost_ratio
          (value := value) (cost := cost)
          (admissionProbability :=
            Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold)
          hvalue).mp hpayoff
    have hstd :
        Q.quantile (1 - cost / value) <
          (admissionThreshold - q) / scale :=
      htail.mp (by
        simpa [StandardGaussianCDFAPI.thresholdPassProb,
          StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
          GaussianScaleLaw.standardize] using hprob)
    have hmul :
        scale * Q.quantile (1 - cost / value) <
          admissionThreshold - q := by
      have := (lt_div_iff₀ hscale).mp hstd
      simpa [mul_comm] using this
    unfold glm20StrategicApplyCutoff
    linarith
  · intro hcutoff
    have hstd :
        Q.quantile (1 - cost / value) <
          (admissionThreshold - q) / scale := by
      rw [lt_div_iff₀ hscale]
      unfold glm20StrategicApplyCutoff at hcutoff
      linarith
    have hprob := htail.mpr hstd
    have hprob' :
        Q.cdfAPI.thresholdPassProb
            { mean := q, scale := scale, scale_pos := hscale }
            admissionThreshold <
          cost / value := by
      simpa [StandardGaussianCDFAPI.thresholdPassProb,
        StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
        GaussianScaleLaw.standardize] using hprob
    exact
      (paper_lemma3_apply_payoff_negative_iff_probability_lt_cost_ratio
          (value := value) (cost := cost)
          (admissionProbability :=
            Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold)
          hvalue).mpr hprob'

/--
Paper Lemma 3 threshold-form component.

Paper statement: under `P_full`, each group has a cutoff `q^g` such that
students apply exactly above that cutoff, and
`q^g = q^*_{full} - scale_g * Φ⁻¹(1 - c_g / v)`.

This theorem closes the one-school Gaussian threshold calculation.  The
remaining Lemma 3 certificate records the global fixed-point uniqueness of the
school cutoff and the equilibrium consistency conditions.
-/
theorem paper_lemma3_full_policy_threshold_form_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold scale value cost : ℝ}
    (hscale : 0 < scale) (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ groupCutoff : ℝ,
      groupCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / value) ∧
      ∀ q : ℝ,
        0 ≤ value *
            Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold - cost ↔
          groupCutoff ≤ q := by
  refine ⟨glm20StrategicApplyCutoff Q admissionThreshold scale (cost / value),
    rfl, ?_⟩
  intro q
  exact
    paper_lemma3_apply_payoff_nonnegative_iff_above_gaussian_cutoff
      Q hscale hvalue hcostRatio

/--
Paper Lemma 3 threshold-form component in the displayed precision notation.

This is the same cutoff calculation as
`paper_lemma3_full_policy_threshold_form_standardGaussian`, with the projected
Gaussian scale expanded to the source expression in prior, non-test, and test
precisions.
-/
theorem paper_lemma3_full_policy_threshold_form_precision_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold priorPrecision subPrecision testPrecision value cost : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ groupCutoff : ℝ,
      groupCutoff =
        admissionThreshold -
          glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision *
              Q.quantile (1 - cost / value) ∧
      ∀ q : ℝ,
        0 ≤ value *
            Q.cdfAPI.thresholdPassProb
              { mean := q
                scale :=
                  glm20StrategicProjectedScale
                    priorPrecision subPrecision testPrecision
                scale_pos :=
                  glm20StrategicProjectedScale_pos
                    hprior_pos hsub_pos htest_pos }
              admissionThreshold - cost ↔
          groupCutoff ≤ q := by
  let scale :=
    glm20StrategicProjectedScale priorPrecision subPrecision testPrecision
  have hscale : 0 < scale :=
    glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos
  rcases
    paper_lemma3_full_policy_threshold_form_standardGaussian
      Q (admissionThreshold := admissionThreshold) (scale := scale)
      (value := value) (cost := cost) hscale hvalue hcostRatio with
    ⟨groupCutoff, hcutoff, hiff⟩
  refine ⟨groupCutoff, ?_, ?_⟩
  · simpa [scale, glm20StrategicApplyCutoff] using hcutoff
  · exact hiff

/--
Lemma 3 student best-response component in precision notation.

Choosing to apply exactly above the displayed Gaussian cutoff is a best
response for the binary apply/not-apply payoff used in the source equilibrium
definition.
-/
theorem paper_lemma3_precision_cutoff_apply_bestResponse_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold priorPrecision subPrecision testPrecision value cost : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    let scale :=
      glm20StrategicProjectedScale priorPrecision subPrecision testPrecision
    let cutoff :=
      admissionThreshold - scale * Q.quantile (1 - cost / value)
    ∀ q : ℝ, ∀ apply : Bool,
      glm20StrategicApplyPayoff value cost
          (Q.cdfAPI.thresholdPassProb
            { mean := q
              scale := scale
              scale_pos :=
                glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
            admissionThreshold)
          apply ≤
        glm20StrategicApplyPayoff value cost
          (Q.cdfAPI.thresholdPassProb
            { mean := q
              scale := scale
              scale_pos :=
                glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
            admissionThreshold)
          (decide (cutoff ≤ q)) := by
  intro scale cutoff q apply
  let admissionProbability :=
    Q.cdfAPI.thresholdPassProb
      { mean := q
        scale := scale
        scale_pos :=
          glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
      admissionThreshold
  have hscale : 0 < scale := by
    dsimp [scale]
    exact glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos
  have hcutoff_eq :
      cutoff = glm20StrategicApplyCutoff Q admissionThreshold scale (cost / value) := by
    dsimp [cutoff, glm20StrategicApplyCutoff]
  have hiff :
      0 ≤ value * admissionProbability - cost ↔ cutoff ≤ q := by
    rw [hcutoff_eq]
    exact
      paper_lemma3_apply_payoff_nonnegative_iff_above_gaussian_cutoff
        Q hscale hvalue hcostRatio
  by_cases hcut : cutoff ≤ q
  · have hchosen : decide (cutoff ≤ q) = true := by simp [hcut]
    have hpayoff_nonneg : 0 ≤ value * admissionProbability - cost :=
      hiff.mpr hcut
    cases apply <;>
      simp [glm20StrategicApplyPayoff, admissionProbability, hchosen,
        hpayoff_nonneg]
  · have hchosen : decide (cutoff ≤ q) = false := by simp [hcut]
    have hpayoff_le_zero : value * admissionProbability - cost ≤ 0 := by
      have hnot : ¬ 0 ≤ value * admissionProbability - cost := by
        intro hnonneg
        exact hcut (hiff.mp hnonneg)
      exact le_of_lt (not_le.mp hnot)
    cases apply <;>
      simp [glm20StrategicApplyPayoff, admissionProbability, hchosen,
        hpayoff_le_zero]

/--
Lemma 3 strict best-response order in precision notation.

Away from the displayed cutoff, the threshold action is the unique payoff
maximizer: below the cutoff, not applying strictly dominates applying; above
the cutoff, applying strictly dominates not applying.  This is the strict
payoff-order ingredient used by the source proof to rule out non-threshold
student strategies.
-/
theorem paper_lemma3_precision_cutoff_apply_strict_payoff_order_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold priorPrecision subPrecision testPrecision value cost : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    let scale :=
      glm20StrategicProjectedScale priorPrecision subPrecision testPrecision
    let cutoff :=
      admissionThreshold - scale * Q.quantile (1 - cost / value)
    (∀ q : ℝ, cutoff < q →
      glm20StrategicApplyPayoff value cost
          (Q.cdfAPI.thresholdPassProb
            { mean := q
              scale := scale
              scale_pos :=
                glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
            admissionThreshold)
          false <
        glm20StrategicApplyPayoff value cost
          (Q.cdfAPI.thresholdPassProb
            { mean := q
              scale := scale
              scale_pos :=
                glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
            admissionThreshold)
          true) ∧
      (∀ q : ℝ, q < cutoff →
        glm20StrategicApplyPayoff value cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale := scale
                scale_pos :=
                  glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
              admissionThreshold)
            true <
          glm20StrategicApplyPayoff value cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale := scale
                scale_pos :=
                  glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
              admissionThreshold)
            false) := by
  intro scale cutoff
  constructor
  · intro q hq
    let admissionProbability :=
      Q.cdfAPI.thresholdPassProb
        { mean := q
          scale := scale
          scale_pos :=
            glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
        admissionThreshold
    have hscale : 0 < scale := by
      dsimp [scale]
      exact glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos
    have hcutoff_eq :
        cutoff =
          glm20StrategicApplyCutoff Q admissionThreshold scale (cost / value) := by
      dsimp [cutoff, glm20StrategicApplyCutoff]
    have hpayoff_pos :
        0 < value * admissionProbability - cost := by
      rw [paper_lemma3_apply_payoff_positive_iff_above_gaussian_cutoff
        Q hscale hvalue hcostRatio]
      simpa [hcutoff_eq] using hq
    simp [glm20StrategicApplyPayoff, admissionProbability, hpayoff_pos]
  · intro q hq
    let admissionProbability :=
      Q.cdfAPI.thresholdPassProb
        { mean := q
          scale := scale
          scale_pos :=
            glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
        admissionThreshold
    have hscale : 0 < scale := by
      dsimp [scale]
      exact glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos
    have hcutoff_eq :
        cutoff =
          glm20StrategicApplyCutoff Q admissionThreshold scale (cost / value) := by
      dsimp [cutoff, glm20StrategicApplyCutoff]
    have hpayoff_neg :
        value * admissionProbability - cost < 0 := by
      rw [paper_lemma3_apply_payoff_negative_iff_below_gaussian_cutoff
        Q hscale hvalue hcostRatio]
      simpa [hcutoff_eq] using hq
    simp [glm20StrategicApplyPayoff, admissionProbability, hpayoff_neg]

/--
Lemma 3 threshold-form support in precision notation.

Any pointwise best-response student strategy for the displayed one-school
Gaussian payoff must agree with the threshold rule away from the indifference
point: it applies strictly above the cutoff and does not apply strictly below
the cutoff.  The source proof uses this as the formal content of the
"equilibrium student strategy must be non-decreasing and threshold-form" step,
before the remaining school-cutoff fixed point is solved.
-/
theorem paper_lemma3_precision_pointwise_bestResponse_threshold_form_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold priorPrecision subPrecision testPrecision value cost : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    let scale :=
      glm20StrategicProjectedScale priorPrecision subPrecision testPrecision
    let cutoff :=
      admissionThreshold - scale * Q.quantile (1 - cost / value)
    ∀ strategy : ℝ → Bool,
      (∀ q : ℝ, ∀ apply : Bool,
        glm20StrategicApplyPayoff value cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale := scale
                scale_pos :=
                  glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
              admissionThreshold)
            apply ≤
          glm20StrategicApplyPayoff value cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale := scale
                scale_pos :=
                  glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
              admissionThreshold)
            (strategy q)) →
      (∀ q : ℝ, cutoff < q → strategy q = true) ∧
        (∀ q : ℝ, q < cutoff → strategy q = false) := by
  intro scale cutoff strategy hbest
  have hstrict :=
    paper_lemma3_precision_cutoff_apply_strict_payoff_order_standardGaussian
      Q (admissionThreshold := admissionThreshold)
      (priorPrecision := priorPrecision) (subPrecision := subPrecision)
      (testPrecision := testPrecision) (value := value) (cost := cost)
      hprior_pos hsub_pos htest_pos hvalue hcostRatio
  constructor
  · intro q hq
    by_contra hnot
    have hstrategy : strategy q = false := by
      cases hs : strategy q
      · rfl
      · simp [hs] at hnot
    have hle := hbest q true
    rw [hstrategy] at hle
    exact (not_lt_of_ge hle) (hstrict.1 q hq)
  · intro q hq
    by_contra hnot
    have hstrategy : strategy q = true := by
      cases hs : strategy q
      · simp [hs] at hnot
      · rfl
    have hle := hbest q false
    rw [hstrategy] at hle
    exact (not_lt_of_ge hle) (hstrict.2 q hq)

/--
Lemma 3 unique threshold strategy in precision notation.

With the paper's tie-breaking convention that the indifferent projected-skill
type applies, any pointwise best-response student strategy is exactly the
threshold indicator `1{cutoff ≤ q}`.  This formalizes the local uniqueness of
the student strategy for a fixed school cutoff; the only remaining Lemma 3
global issue is solving the school cutoff's capacity fixed point.
-/
theorem paper_lemma3_precision_unique_threshold_strategy_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold priorPrecision subPrecision testPrecision value cost : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    let scale :=
      glm20StrategicProjectedScale priorPrecision subPrecision testPrecision
    let cutoff :=
      admissionThreshold - scale * Q.quantile (1 - cost / value)
    ∀ strategy : ℝ → Bool,
      (∀ q : ℝ, ∀ apply : Bool,
        glm20StrategicApplyPayoff value cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale := scale
                scale_pos :=
                  glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
              admissionThreshold)
            apply ≤
          glm20StrategicApplyPayoff value cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale := scale
                scale_pos :=
                  glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
              admissionThreshold)
            (strategy q)) →
      strategy cutoff = true →
      strategy = fun q : ℝ => decide (cutoff ≤ q) := by
  intro scale cutoff strategy hbest htie
  have hthreshold :=
    paper_lemma3_precision_pointwise_bestResponse_threshold_form_standardGaussian
      Q (admissionThreshold := admissionThreshold)
      (priorPrecision := priorPrecision) (subPrecision := subPrecision)
      (testPrecision := testPrecision) (value := value) (cost := cost)
      hprior_pos hsub_pos htest_pos hvalue hcostRatio
      strategy hbest
  funext q
  by_cases habove : cutoff < q
  · rw [hthreshold.1 q habove]
    simp [habove.le]
  · by_cases hbelow : q < cutoff
    · rw [hthreshold.2 q hbelow]
      simp [not_le.mpr hbelow]
    · have hq : q = cutoff :=
        le_antisymm (le_of_not_gt habove) (le_of_not_gt hbelow)
      subst q
      rw [htie]
      simp

