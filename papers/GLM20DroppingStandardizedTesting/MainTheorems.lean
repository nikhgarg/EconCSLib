    glm20TwoSchoolBinaryPolicyEquilibrium objective1 objective2
        Psub Pfull Pfull Psub ↔
      objective1 Psub Psub ≤ objective1 Pfull Psub ∧
        objective2 Pfull Pfull ≤ objective2 Pfull Psub := by
  constructor
  · intro h
    exact ⟨h.1 Psub (Or.inl rfl), h.2 Pfull (Or.inr rfl)⟩
  · rintro ⟨h1, h2⟩
    constructor
    · intro P1' hmem
      rcases hmem with rfl | rfl
      · exact h1
      · exact le_rfl
    · intro P2' hmem
      rcases hmem with rfl | rfl
      · exact le_rfl
      · exact h2

/-- Binary-policy equilibrium characterization for `(P_full, P_full)`. -/
theorem glm20TwoSchoolBinaryPolicyEquilibrium_fullFull_iff
    {Policy : Type*} (objective1 objective2 : Policy → Policy → ℝ)
    (Psub Pfull : Policy) :
    glm20TwoSchoolBinaryPolicyEquilibrium objective1 objective2
        Psub Pfull Pfull Pfull ↔
      objective1 Psub Pfull ≤ objective1 Pfull Pfull ∧
        objective2 Pfull Psub ≤ objective2 Pfull Pfull := by
  constructor
  · intro h
    exact ⟨h.1 Psub (Or.inl rfl), h.2 Psub (Or.inl rfl)⟩
