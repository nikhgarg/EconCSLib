/--
Theorem 3(ii), condition (13), for a candidate group under `(P_full,P_sub)`.

Paper statement: `c_g ≥ c_hat'_g`,
`M_g(P_full,P_full) < K_g(q^*_{2,sub})`, with
`c_hat''_g > c_hat'_g > 0`.
-/
def glm20Theorem3FullSubSchool2DropsCondition
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy)
    (testCost lowCostThreshold highCostThreshold : Group → ℝ)
    (q1Sub q2Sub : ℝ) (K : Group → ℝ → ℝ) (g : Group) : Prop :=
  testCost g ≥ lowCostThreshold g ∧
    0 < lowCostThreshold g ∧
      lowCostThreshold g < highCostThreshold g ∧
        S.massTestTaking g (policyPair Pfull Pfull) < K g q2Sub

/--
Proposition 5(ii) / Theorem 3(ii), condition (13), rewritten in the cutoff
case-analysis form.

Paper proof line: the condition
`M_g(P_full,P_full) < K_g(q^*_{2,sub})` is equivalent to
`q^*_{2,sub} < q^g_{full,full}`.
-/
theorem paper_proposition5_condition13_iff_cost_and_fullFull_cutoff_case
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy)
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {testCost lowCostThreshold highCostThreshold : Group → ℝ}
    {q1Sub q2Sub : ℝ} {fullFullCutoff : Group → ℝ} {g : Group}
    (hmass :
      S.massTestTaking g (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw g)
          (fullFullCutoff g)) :
    glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
        testCost lowCostThreshold highCostThreshold q1Sub q2Sub
        (fun h q => glm20StrategicSubEstimateMassAbove api (subEstimateLaw h) q)
        g ↔
      testCost g ≥ lowCostThreshold g ∧
        0 < lowCostThreshold g ∧
          lowCostThreshold g < highCostThreshold g ∧
            q2Sub < fullFullCutoff g := by
  constructor
  · rintro ⟨hcost, hlow_pos, hlow_high, hmass_lt⟩
    exact ⟨hcost, hlow_pos, hlow_high,
      (paper_proposition5_mass_below_K_iff_reference_below_cutoff
        api (subEstimateLaw g) hmass).mp hmass_lt⟩
  · rintro ⟨hcost, hlow_pos, hlow_high, hcutoff⟩
    exact ⟨hcost, hlow_pos, hlow_high,
      (paper_proposition5_mass_below_K_iff_reference_below_cutoff
        api (subEstimateLaw g) hmass).mpr hcutoff⟩

/--
Proposition 5(ii) / Theorem 3(ii), condition (13), with the paper's raw
test-free precision formula for `K_g` substituted.
-/
theorem paper_proposition5_condition13_iff_cost_and_source_fullFull_cutoff_case
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy)
    (api : StandardGaussianCDFAPI)
    (priorSigma priorPrecision subPrecisionSum mu : Group → ℝ)
    (hpriorSigma_pos : ∀ g, 0 < priorSigma g)
    (hpriorPrecision_pos : ∀ g, 0 < priorPrecision g)
    (hsubPrecisionSum_pos : ∀ g, 0 < subPrecisionSum g)
    {testCost lowCostThreshold highCostThreshold : Group → ℝ}
    {q1Sub q2Sub : ℝ} {fullFullCutoff : Group → ℝ} {g : Group}
    (hmass :
      S.massTestTaking g (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api
          (glm20StrategicSubEstimateLawSource (priorSigma g)
            (priorPrecision g) (subPrecisionSum g) (mu g)
            (hpriorSigma_pos g) (hpriorPrecision_pos g)
            (hsubPrecisionSum_pos g))
          (fullFullCutoff g)) :
    glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
        testCost lowCostThreshold highCostThreshold q1Sub q2Sub
        (fun h q =>
          glm20StrategicSubEstimateMassAbove api
            (glm20StrategicSubEstimateLawSource (priorSigma h)
              (priorPrecision h) (subPrecisionSum h) (mu h)
              (hpriorSigma_pos h) (hpriorPrecision_pos h)
              (hsubPrecisionSum_pos h))
            q)
        g ↔
      testCost g ≥ lowCostThreshold g ∧
        0 < lowCostThreshold g ∧
          lowCostThreshold g < highCostThreshold g ∧
            q2Sub < fullFullCutoff g :=
  paper_proposition5_condition13_iff_cost_and_fullFull_cutoff_case
    S policyPair Psub Pfull api
    (fun h =>
      glm20StrategicSubEstimateLawSource (priorSigma h) (priorPrecision h)
        (subPrecisionSum h) (mu h) (hpriorSigma_pos h)
        (hpriorPrecision_pos h) (hsubPrecisionSum_pos h))
    hmass

/--
Theorem 3(ii), condition (14), for school `J1` keeping the test after `J2`
drops.

Paper statement:
`M_g(P_full,P_sub) > K_g(q^*_{1,sub})` or `c_g ≤ c_hat''_g`.
-/
def glm20Theorem3FullSubSchool1KeepsTestCondition
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy)
    (testCost highCostThreshold : Group → ℝ)
    (q1Sub : ℝ) (K : Group → ℝ → ℝ) (g : Group) : Prop :=
  S.massTestTaking g (policyPair Pfull Psub) > K g q1Sub ∨
    testCost g ≤ highCostThreshold g

