        Q.quantile (1 - capacity / (ownShare * y + otherEligibleMass)) *
          theorem1BetaGroupBFactor ownShare otherEligibleMass rho y :=
    mul_le_mul_of_nonneg_right hquantile_mono
      (Real.sqrt_nonneg
        ((ownShare * y * rho + otherEligibleMass) /
          (ownShare * y + otherEligibleMass)))
  exact lt_of_lt_of_le hleft_lt hright_le

/--
Theorem 1 threshold-characterization support.

Paper statement pattern: holding all other parameters fixed, there exists a
threshold access level `γbar` such that the target comparison improves after
dropping the test iff `γ < γbar`.

This theorem discharges the source proof's generic Step 3: once the paper's
scalar score (`βg` for academic merit or `η` for diversity) is continuous and
strictly increasing in the access parameter, and the benchmark lies strictly
between the endpoint values, the threshold exists and has exactly the desired
iff characterization on `[0,1]`.
-/
theorem paper_theorem1_exists_access_threshold_of_scalar_crossing
    {score : ℝ → ℝ} {benchmark : ℝ} {improves : ℝ → Prop}
    (hscore_cont : ContinuousOn score (Set.Icc 0 1))
    (hscore_mono : StrictMonoOn score (Set.Icc 0 1))
    (hzero : score 0 < benchmark) (hone : benchmark < score 1)
    (himproves :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, improves γ ↔ score γ < benchmark) :
    ∃ γbar : ℝ, γbar ∈ Set.Ioo (0 : ℝ) 1 ∧
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, improves γ ↔ γ < γbar := by
  rcases exists_threshold_of_continuous_strictMonoOn_Icc_crossing
      hscore_cont hscore_mono hzero hone with
    ⟨γbar, hγbar, _hroot, hlt, _hgt, _hle, _hge⟩
  refine ⟨γbar, hγbar, ?_⟩
  intro γ hγ
  rw [himproves γ hγ, hlt γ hγ]

/--
Theorem 1 threshold-characterization support, non-strict version.

This matches the appendix's displayed academic-merit condition
`β_g ≤ Δ_g`: a continuous strictly increasing scalar score has a unique
crossing, and weak comparison to the benchmark is equivalent to being weakly
below the access threshold.
-/
theorem paper_theorem1_exists_access_threshold_of_scalar_le_crossing
    {score : ℝ → ℝ} {benchmark : ℝ} {improves : ℝ → Prop}
    (hscore_cont : ContinuousOn score (Set.Icc 0 1))
    (hscore_mono : StrictMonoOn score (Set.Icc 0 1))
    (hzero : score 0 < benchmark) (hone : benchmark < score 1)
    (himproves :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, improves γ ↔ score γ ≤ benchmark) :
    ∃ γbar : ℝ, γbar ∈ Set.Ioo (0 : ℝ) 1 ∧
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, improves γ ↔ γ ≤ γbar := by
  rcases exists_threshold_of_continuous_strictMonoOn_Icc_crossing
      hscore_cont hscore_mono hzero hone with
    ⟨γbar, hγbar, _hroot, _hlt, _hgt, hle, _hge⟩
  refine ⟨γbar, hγbar, ?_⟩
  intro γ hγ
  rw [himproves γ hγ, hle γ hγ]

/--
Theorem 1 threshold-characterization support without endpoint-crossing
assumptions.

This is the main-body threshold form: if the scalar score is continuous and
strictly increasing on feasible access levels, then there is a real cutoff
`γbar` such that improvement holds exactly below `γbar`.  When the benchmark
lies outside the endpoint range, `γbar` may lie outside `[0,1]`, representing
the always-improve or never-improve cases.
-/
theorem paper_theorem1_exists_access_threshold_of_scalar
    {score : ℝ → ℝ} {benchmark : ℝ} {improves : ℝ → Prop}
    (hscore_cont : ContinuousOn score (Set.Icc 0 1))
    (hscore_mono : StrictMonoOn score (Set.Icc 0 1))
    (himproves :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, improves γ ↔ score γ < benchmark) :
    ∃ γbar : ℝ,
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, improves γ ↔ γ < γbar := by
  rcases exists_threshold_of_continuous_strictMonoOn_Icc
      hscore_cont hscore_mono with
    ⟨γbar, hthreshold⟩
  refine ⟨γbar, ?_⟩
  intro γ hγ
  rw [himproves γ hγ, hthreshold γ hγ]

/--
Theorem 1 weak threshold-characterization support without endpoint-crossing
assumptions.  This is the non-strict version used by the appendix's
`β_g ≤ Δ_g` academic-merit comparison.
-/
theorem paper_theorem1_exists_access_threshold_of_scalar_le
    {score : ℝ → ℝ} {benchmark : ℝ} {improves : ℝ → Prop}
    (hscore_cont : ContinuousOn score (Set.Icc 0 1))
    (hscore_mono : StrictMonoOn score (Set.Icc 0 1))
    (himproves :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, improves γ ↔ score γ ≤ benchmark) :
    ∃ γbar : ℝ,
      ∀ γ ∈ Set.Icc (0 : ℝ) 1, improves γ ↔ γ ≤ γbar := by
  rcases exists_threshold_le_of_continuous_strictMonoOn_Icc
      hscore_cont hscore_mono with
    ⟨γbar, hthreshold⟩
  refine ⟨γbar, ?_⟩
  intro γ hγ
  rw [himproves γ hγ, hthreshold γ hγ]

/--
Theorem 1(i) diversity threshold support.

Paper statement: "Diversity strictly improves after dropping test scores iff
`η(1,1,ρ_sub^B) > η(γ_A,γ_B,ρ_full^B)`. Given any `γ_A ∈ (0,1]`, there exists
a threshold `γbar ∈ (0,1]` such that diversity strictly improves after
dropping test scores iff `γ_B < γbar`."

The Lean theorem takes the already-derived diversity comparison
`diversityImproves γB ↔ η γB < ηSub` and proves the threshold conclusion from
continuity, strict monotonicity, and endpoint crossing of the barrier-side
`η` function.
-/
theorem paper_theorem1_diversity_access_threshold_of_eta_crossing
    {etaFull : ℝ → ℝ} {etaSub : ℝ} {diversityImproves : ℝ → Prop}
    (heta_cont : ContinuousOn etaFull (Set.Icc 0 1))
    (heta_mono : StrictMonoOn etaFull (Set.Icc 0 1))
    (heta_zero : etaFull 0 < etaSub)
    (heta_one : etaSub < etaFull 1)
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ etaFull γB < etaSub) :
    ∃ γbar : ℝ, γbar ∈ Set.Ioo (0 : ℝ) 1 ∧
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ γB < γbar :=
  paper_theorem1_exists_access_threshold_of_scalar_crossing
    heta_cont heta_mono heta_zero heta_one hdiversity

/--
Theorem 1(i) diversity threshold support without endpoint-crossing
assumptions.  This is the main-body threshold form of the source statement.
-/
theorem paper_theorem1_diversity_access_threshold_of_eta_main
    {etaFull : ℝ → ℝ} {etaSub : ℝ} {diversityImproves : ℝ → Prop}
    (heta_cont : ContinuousOn etaFull (Set.Icc 0 1))
    (heta_mono : StrictMonoOn etaFull (Set.Icc 0 1))
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ etaFull γB < etaSub) :
    ∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ γB < γbar :=
  paper_theorem1_exists_access_threshold_of_scalar
    heta_cont heta_mono hdiversity

/--
Theorem 1(i) cutoff monotonicity from the barrier capacity equations.

Holding group-A access fixed, if `threshold γB` always clears exactly the same
capacity

`C = groupAEligibleMass * tail_A(threshold γB)
     + groupBShare * γB * tail_B(threshold γB)`,

then the threshold is strictly increasing in group-B access.  Otherwise, a
weakly lower threshold and a strictly larger eligible group-B mass would make
the capacity equation strictly larger.
-/
theorem paper_theorem1_barrier_threshold_strictMonoOn_of_capacity_equations
    (C : GaussianHazardCertificate)
    {threshold : ℝ → ℝ}
    {capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw}
    (hgroupA_nonneg : 0 ≤ groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hcapacity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          groupAEligibleMass *
              C.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              C.api.thresholdPassProb L_B (threshold γB)) :
    StrictMonoOn threshold (Set.Icc (0 : ℝ) 1) := by
  intro γ γ_mem γ' γ'_mem hγ
  by_contra hnot
  have hthreshold_le : threshold γ' ≤ threshold γ := le_of_not_gt hnot
  have htailA_le :
      C.api.thresholdPassProb L_A (threshold γ) ≤
        C.api.thresholdPassProb L_A (threshold γ') :=
    C.api.thresholdPassProb_antitone_threshold L_A hthreshold_le
  have htailB_le :
      C.api.thresholdPassProb L_B (threshold γ) ≤
        C.api.thresholdPassProb L_B (threshold γ') :=
    C.api.thresholdPassProb_antitone_threshold L_B hthreshold_le
  have hAterm_le :
      groupAEligibleMass *
          C.api.thresholdPassProb L_A (threshold γ) ≤
        groupAEligibleMass *
          C.api.thresholdPassProb L_A (threshold γ') :=
    mul_le_mul_of_nonneg_left htailA_le hgroupA_nonneg
  have hγ_nonneg : 0 ≤ γ := γ_mem.1
  have hBγ_nonneg : 0 ≤ groupBShare * γ :=
    mul_nonneg hgroupB_pos.le hγ_nonneg
  have hBterm_le_tail :
      groupBShare * γ *
          C.api.thresholdPassProb L_B (threshold γ) ≤
        groupBShare * γ *
          C.api.thresholdPassProb L_B (threshold γ') :=
    mul_le_mul_of_nonneg_left htailB_le hBγ_nonneg
  have htailB_pos :
      0 < C.api.thresholdPassProb L_B (threshold γ') :=
    C.normalTail_pos L_B (threshold γ')
  have hBterm_lt_access :
      groupBShare * γ *
          C.api.thresholdPassProb L_B (threshold γ') <
        groupBShare * γ' *
          C.api.thresholdPassProb L_B (threshold γ') :=
    mul_lt_mul_of_pos_right
      (mul_lt_mul_of_pos_left hγ hgroupB_pos) htailB_pos
  have hBterm_lt :
      groupBShare * γ *
          C.api.thresholdPassProb L_B (threshold γ) <
        groupBShare * γ' *
          C.api.thresholdPassProb L_B (threshold γ') :=
    lt_of_le_of_lt hBterm_le_tail hBterm_lt_access
  have hrhs_lt :
      groupAEligibleMass *
            C.api.thresholdPassProb L_A (threshold γ) +
          groupBShare * γ *
            C.api.thresholdPassProb L_B (threshold γ) <
        groupAEligibleMass *
            C.api.thresholdPassProb L_A (threshold γ') +
          groupBShare * γ' *
            C.api.thresholdPassProb L_B (threshold γ') :=
    add_lt_add_of_le_of_lt hAterm_le hBterm_lt
  have hcapγ := hcapacity γ γ_mem
  have hcapγ' := hcapacity γ' γ'_mem
  rw [← hcapγ, ← hcapγ'] at hrhs_lt
  exact (lt_irrefl capacity) hrhs_lt

def theorem1BarrierCapacityMass
    (api : StandardGaussianCDFAPI)
    (groupAEligibleMass groupBShare : ℝ)
    (L_A L_B : GaussianScaleLaw) (γB threshold : ℝ) : ℝ :=
  groupAEligibleMass * api.thresholdPassProb L_A threshold +
    groupBShare * γB * api.thresholdPassProb L_B threshold

/--
Theorem 1 cutoff-continuity support from the barrier capacity equations.

The paper treats the full-policy admission cutoff as the threshold that clears
the school's fixed capacity.  Because the finite Gaussian mixture mass is
continuous in access and strictly decreasing in the cutoff, any capacity-
realizing cutoff family is continuous on the feasible access interval.
-/
theorem paper_theorem1_barrier_threshold_continuousOn_of_capacity_equations
    (api : StandardGaussianCDFAPI)
    {threshold : ℝ → ℝ}
    {capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw}
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_nonneg : 0 ≤ groupBShare)
    (hcapacity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          theorem1BarrierCapacityMass api groupAEligibleMass groupBShare
            L_A L_B γB (threshold γB)) :
    ContinuousOn threshold (Set.Icc (0 : ℝ) 1) := by
  let F : ℝ → ℝ → ℝ := fun γB t =>
    theorem1BarrierCapacityMass api groupAEligibleMass groupBShare
      L_A L_B γB t
  have hF_antitone :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1, Antitone (F γB) := by
    intro γB hγB x y hxy
    have htailA :
        api.thresholdPassProb L_A y ≤ api.thresholdPassProb L_A x :=
      api.thresholdPassProb_antitone_threshold L_A hxy
    have htailB :
        api.thresholdPassProb L_B y ≤ api.thresholdPassProb L_B x :=
      api.thresholdPassProb_antitone_threshold L_B hxy
    have hA :
        groupAEligibleMass * api.thresholdPassProb L_A y ≤
          groupAEligibleMass * api.thresholdPassProb L_A x :=
      mul_le_mul_of_nonneg_left htailA hgroupA_pos.le
    have hBcoeff : 0 ≤ groupBShare * γB :=
      mul_nonneg hgroupB_nonneg hγB.1
    have hB :
        groupBShare * γB * api.thresholdPassProb L_B y ≤
          groupBShare * γB * api.thresholdPassProb L_B x :=
      mul_le_mul_of_nonneg_left htailB hBcoeff
    exact add_le_add hA hB
  have hF_strictAnti :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1, StrictAnti (F γB) := by
    intro γB hγB x y hxy
    have htailA :
        api.thresholdPassProb L_A y < api.thresholdPassProb L_A x :=
      api.thresholdPassProb_strictAnti_threshold L_A hxy
    have htailB :
        api.thresholdPassProb L_B y ≤ api.thresholdPassProb L_B x :=
      api.thresholdPassProb_antitone_threshold L_B hxy.le
    have hA :
        groupAEligibleMass * api.thresholdPassProb L_A y <
          groupAEligibleMass * api.thresholdPassProb L_A x :=
      mul_lt_mul_of_pos_left htailA hgroupA_pos
    have hBcoeff : 0 ≤ groupBShare * γB :=
      mul_nonneg hgroupB_nonneg hγB.1
    have hB :
        groupBShare * γB * api.thresholdPassProb L_B y ≤
          groupBShare * γB * api.thresholdPassProb L_B x :=
      mul_le_mul_of_nonneg_left htailB hBcoeff
    exact add_lt_add_of_lt_of_le hA hB
  rw [ContinuousOn]
  intro γ0 hγ0
  rw [ContinuousWithinAt]
  refine tendsto_order.2 ⟨?_, ?_⟩
  · intro a ha
    have hstrict :
        F γ0 (threshold γ0) < F γ0 a :=
      hF_strictAnti γ0 hγ0 ha
    have hcap0 : capacity = F γ0 (threshold γ0) :=
      hcapacity γ0 hγ0
    have hcap_lt : capacity < F γ0 a := by
      simpa [hcap0] using hstrict
    have hcont :
        ContinuousWithinAt (fun γB : ℝ => F γB a)
          (Set.Icc (0 : ℝ) 1) γ0 := by
      dsimp [F, theorem1BarrierCapacityMass]
      fun_prop
    have hevent :
        ∀ᶠ γB in nhdsWithin γ0 (Set.Icc (0 : ℝ) 1), capacity < F γB a :=
      hcont.eventually (eventually_gt_nhds hcap_lt)
    filter_upwards [hevent, self_mem_nhdsWithin] with γB hgt hγB
    by_contra hnot
    have hle : threshold γB ≤ a := le_of_not_gt hnot
    have hF_le : F γB a ≤ F γB (threshold γB) :=
      hF_antitone γB hγB hle
    have hcapγ : capacity = F γB (threshold γB) :=
      hcapacity γB hγB
    linarith
  · intro b hb
    have hstrict :
        F γ0 b < F γ0 (threshold γ0) :=
      hF_strictAnti γ0 hγ0 hb
    have hcap0 : capacity = F γ0 (threshold γ0) :=
      hcapacity γ0 hγ0
    have hlt_cap : F γ0 b < capacity := by
      simpa [hcap0] using hstrict
    have hcont :
        ContinuousWithinAt (fun γB : ℝ => F γB b)
          (Set.Icc (0 : ℝ) 1) γ0 := by
      dsimp [F, theorem1BarrierCapacityMass]
      fun_prop
    have hevent :
        ∀ᶠ γB in nhdsWithin γ0 (Set.Icc (0 : ℝ) 1), F γB b < capacity :=
      hcont.eventually (eventually_lt_nhds hlt_cap)
    filter_upwards [hevent, self_mem_nhdsWithin] with γB hlt hγB
    by_contra hnot
    have hle : b ≤ threshold γB := le_of_not_gt hnot
    have hF_le : F γB (threshold γB) ≤ F γB b :=
      hF_antitone γB hγB hle
    have hcapγ : capacity = F γB (threshold γB) :=
      hcapacity γB hγB
    linarith

/--
Theorem 1(i) diversity monotonicity support from the capacity-equation proof:
if the full-policy cutoff is strictly increasing in group-B access, then the
group-B admitted share is strictly increasing because the fixed group-A
eligible tail is strictly decreasing in that cutoff.
-/
theorem paper_theorem1_diversity_strictMonoOn_of_groupA_tail_threshold
    (api : StandardGaussianCDFAPI)
    {fullDiversity threshold : ℝ → ℝ}
    {capacity groupAEligibleMass : ℝ} {L_A : GaussianScaleLaw}
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hthreshold_mono : StrictMonoOn threshold (Set.Icc (0 : ℝ) 1))
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          1 - groupAEligibleMass *
              api.thresholdPassProb L_A (threshold γB) / capacity) :
    StrictMonoOn fullDiversity (Set.Icc (0 : ℝ) 1) := by
  intro γ γ_mem γ' γ'_mem hγ
  have hthreshold : threshold γ < threshold γ' :=
    hthreshold_mono γ_mem γ'_mem hγ
  have htail :
      api.thresholdPassProb L_A (threshold γ') <
        api.thresholdPassProb L_A (threshold γ) :=
    api.thresholdPassProb_strictAnti_threshold L_A hthreshold
  have hshare :
      groupAEligibleMass * api.thresholdPassProb L_A (threshold γ') /
          capacity <
        groupAEligibleMass * api.thresholdPassProb L_A (threshold γ) /
          capacity :=
    div_lt_div_of_pos_right
      (mul_lt_mul_of_pos_left htail hgroupA_pos) hcapacity_pos
  rw [hdiversity γ γ_mem, hdiversity γ' γ'_mem]
  linarith

/--
Theorem 1(i) diversity threshold support using the source proof's
capacity-equation monotonicity route.

The remaining source obligations are the cutoff monotonicity in group-B access,
continuity of the full-policy diversity curve, endpoint crossing with the
test-free benchmark, and the already-derived equivalence between improvement
and `fullDiversity γB < diversitySub`.
-/
theorem paper_theorem1_diversity_access_threshold_of_capacity_tail
    (api : StandardGaussianCDFAPI)
    {fullDiversity threshold : ℝ → ℝ}
    {diversitySub capacity groupAEligibleMass : ℝ}
    {L_A : GaussianScaleLaw} {diversityImproves : ℝ → Prop}
    (hfull_cont : ContinuousOn fullDiversity (Set.Icc (0 : ℝ) 1))
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hthreshold_mono : StrictMonoOn threshold (Set.Icc (0 : ℝ) 1))
    (hdiversity_formula :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          1 - groupAEligibleMass *
              api.thresholdPassProb L_A (threshold γB) / capacity)
    (hzero : fullDiversity 0 < diversitySub)
    (hone : diversitySub < fullDiversity 1)
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ fullDiversity γB < diversitySub) :
    ∃ γbar : ℝ, γbar ∈ Set.Ioo (0 : ℝ) 1 ∧
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ γB < γbar :=
  paper_theorem1_diversity_access_threshold_of_eta_crossing
    hfull_cont
    (paper_theorem1_diversity_strictMonoOn_of_groupA_tail_threshold
      api hcapacity_pos hgroupA_pos hthreshold_mono hdiversity_formula)
    hzero hone hdiversity

/--
Theorem 1(i) capacity-equation threshold route without endpoint-crossing
assumptions.  The returned threshold is real-valued; if it is outside the
feasible access interval, the characterization is still exact on `[0,1]`.
-/
theorem paper_theorem1_diversity_access_threshold_of_capacity_tail_main
    (api : StandardGaussianCDFAPI)
    {fullDiversity threshold : ℝ → ℝ}
    {diversitySub capacity groupAEligibleMass : ℝ}
    {L_A : GaussianScaleLaw} {diversityImproves : ℝ → Prop}
    (hfull_cont : ContinuousOn fullDiversity (Set.Icc (0 : ℝ) 1))
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hthreshold_mono : StrictMonoOn threshold (Set.Icc (0 : ℝ) 1))
    (hdiversity_formula :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          1 - groupAEligibleMass *
              api.thresholdPassProb L_A (threshold γB) / capacity)
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ fullDiversity γB < diversitySub) :
    ∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ γB < γbar :=
  paper_theorem1_diversity_access_threshold_of_eta_main
    hfull_cont
    (paper_theorem1_diversity_strictMonoOn_of_groupA_tail_threshold
      api hcapacity_pos hgroupA_pos hthreshold_mono hdiversity_formula)
    hdiversity

/--
Theorem 1(i) diversity threshold support directly from the barrier capacity
equations.

This discharges the source proof's cutoff-monotonicity step: positive
group-B tail mass plus the capacity equation imply the full-policy cutoff
strictly increases with group-B access, which then implies full-policy
diversity strictly increases with group-B access.
-/
theorem paper_theorem1_diversity_access_threshold_of_capacity_equations
    (C : GaussianHazardCertificate)
    {fullDiversity threshold : ℝ → ℝ}
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw} {diversityImproves : ℝ → Prop}
    (hfull_cont : ContinuousOn fullDiversity (Set.Icc (0 : ℝ) 1))
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hcapacity_eq :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          groupAEligibleMass *
              C.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              C.api.thresholdPassProb L_B (threshold γB))
    (hdiversity_formula :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          1 - groupAEligibleMass *
              C.api.thresholdPassProb L_A (threshold γB) / capacity)
    (hzero : fullDiversity 0 < diversitySub)
    (hone : diversitySub < fullDiversity 1)
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ fullDiversity γB < diversitySub) :
    ∃ γbar : ℝ, γbar ∈ Set.Ioo (0 : ℝ) 1 ∧
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ γB < γbar :=
  paper_theorem1_diversity_access_threshold_of_capacity_tail
    C.api hfull_cont hcapacity_pos hgroupA_pos
    (paper_theorem1_barrier_threshold_strictMonoOn_of_capacity_equations
      C hgroupA_pos.le hgroupB_pos hcapacity_eq)
    hdiversity_formula hzero hone hdiversity

/--
Theorem 1(i) diversity threshold support directly from the barrier capacity
equations, without endpoint-crossing assumptions.
-/
theorem paper_theorem1_diversity_access_threshold_of_capacity_equations_main
    (C : GaussianHazardCertificate)
    {fullDiversity threshold : ℝ → ℝ}
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw} {diversityImproves : ℝ → Prop}
    (hfull_cont : ContinuousOn fullDiversity (Set.Icc (0 : ℝ) 1))
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hcapacity_eq :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          groupAEligibleMass *
              C.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              C.api.thresholdPassProb L_B (threshold γB))
    (hdiversity_formula :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          1 - groupAEligibleMass *
              C.api.thresholdPassProb L_A (threshold γB) / capacity)
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ fullDiversity γB < diversitySub) :
    ∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ γB < γbar :=
  paper_theorem1_diversity_access_threshold_of_capacity_tail_main
    C.api hfull_cont hcapacity_pos hgroupA_pos
    (paper_theorem1_barrier_threshold_strictMonoOn_of_capacity_equations
      C hgroupA_pos.le hgroupB_pos hcapacity_eq)
    hdiversity_formula hdiversity

/--
Theorem 1(i) diversity threshold support from the direct admitted-share
definition of diversity.

The source defines diversity as the admitted group-B share.  Given the barrier
capacity equation, that share is algebraically the same as
`1 - groupA admitted mass / capacity`, which is the form used by the monotonicity
proof above.
-/
theorem paper_theorem1_diversity_access_threshold_of_capacity_share_main
    (C : GaussianHazardCertificate)
    {fullDiversity threshold : ℝ → ℝ}
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw} {diversityImproves : ℝ → Prop}
    (hfull_cont : ContinuousOn fullDiversity (Set.Icc (0 : ℝ) 1))
    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hcapacity_eq :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          groupAEligibleMass *
              C.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              C.api.thresholdPassProb L_B (threshold γB))
    (hdiversity_share :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          groupBShare * γB *
            C.api.thresholdPassProb L_B (threshold γB) / capacity)
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ fullDiversity γB < diversitySub) :
    ∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ γB < γbar := by
  have hformula :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          1 - groupAEligibleMass *
              C.api.thresholdPassProb L_A (threshold γB) / capacity := by
    intro γB hγB
    let a :=
      groupAEligibleMass *
        C.api.thresholdPassProb L_A (threshold γB)
    let b :=
      groupBShare * γB *
        C.api.thresholdPassProb L_B (threshold γB)
    have hcap : capacity = a + b := by
      simpa [a, b] using hcapacity_eq γB hγB
    calc
      fullDiversity γB = b / capacity := by
        simpa [b] using hdiversity_share γB hγB
      _ = 1 - a / capacity := by
        have hsum_ne : a + b ≠ 0 :=
          ne_of_gt (by rw [← hcap]; exact hcapacity_pos)
        rw [hcap]
        field_simp [hsum_ne]
        ring
      _ = 1 - groupAEligibleMass *
              C.api.thresholdPassProb L_A (threshold γB) / capacity := by
        rfl
  exact
    paper_theorem1_diversity_access_threshold_of_capacity_equations_main
      C hfull_cont hcapacity_pos hgroupA_pos hgroupB_pos hcapacity_eq
      hformula hdiversity

/--
Theorem 1(ii) academic-merit threshold support.

Paper statement: "For each group `g`, holding other parameters fixed, there
exists a threshold `γbar_g` such that academic merit of group `g` increases
under `P_sub` iff `γ_g < γbar_g`."

The source Step 1 proves the comparison is equivalent to a scalar condition in
`βg`; Step 2 proves `βg` is increasing in `γg`; Step 3 uses endpoint crossing.
This theorem formalizes Step 3 and leaves only the concrete `βg` formula,
monotonicity, and endpoint inequalities to instantiate.
-/
theorem paper_theorem1_academic_merit_access_threshold_of_beta_crossing
    {beta : ℝ → ℝ} {delta : ℝ} {academicMeritImproves : ℝ → Prop}
    (hbeta_cont : ContinuousOn beta (Set.Icc 0 1))
    (hbeta_mono : StrictMonoOn beta (Set.Icc 0 1))
    (hbeta_zero : beta 0 < delta)
    (hbeta_one : delta < beta 1)
    (hmerit :
      ∀ γg ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γg ↔ beta γg < delta) :
    ∃ γbar : ℝ, γbar ∈ Set.Ioo (0 : ℝ) 1 ∧
      ∀ γg ∈ Set.Icc (0 : ℝ) 1,
        academicMeritImproves γg ↔ γg < γbar :=
  paper_theorem1_exists_access_threshold_of_scalar_crossing
    hbeta_cont hbeta_mono hbeta_zero hbeta_one hmerit

