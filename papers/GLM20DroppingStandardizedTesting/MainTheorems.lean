            StrictMonoOn cutoffOfCost (Set.Icc (left g) (right g)) := by
    intro g
    exact
      paper_proposition5_standardGaussian_twoFull_apply_payoff_cutoff_function_regular_cost_interval
        (q1Full := q1Full g) (q2Full := q2Full g)
        (scale := scale g) (v1 := v1 g) (v2 := v2 g)
        (left := left g) (right := right g)
        (hscale g) (hv2_pos g) (hv2_lt_v1 g)
        (hleft_pos g) (hright_lt_v1 g)
  let cutoffOfCost : Group → ℝ → ℝ :=
    fun g => Classical.choose (hcutoff g)
  have hspec :
