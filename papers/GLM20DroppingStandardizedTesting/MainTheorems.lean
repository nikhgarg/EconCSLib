          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2)
    (hJ2NotTieA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (honlyA_J2_merit :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub) ↔
            fullSubLowTestBasedMerit groupA (testCost groupA) ≤
              fullSubLowTestFreeMerit groupA))
    (honlyB_J2_merit :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub) ↔
            fullSubLowTestBasedMerit groupB (testCost groupB) ≤
              fullSubLowTestFreeMerit groupB))
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandA_testFree :
      ¬ fullSubCutoff groupA < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub =
          fullSubHighTestFreeMerit groupA)
    (hexpandA_testBased :
      ¬ fullSubCutoff groupA < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub =
          fullSubHighTestBasedMerit groupA (testCost groupA))
    (hnoExpandB :
      fullSubCutoff groupB < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandB_testFree :
      ¬ fullSubCutoff groupB < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub =
          fullSubHighTestFreeMerit groupB)
    (hexpandB_testBased :
      ¬ fullSubCutoff groupB < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub =
          fullSubHighTestBasedMerit groupB (testCost groupB))
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    ∃ subFullCostThreshold fullSubLowCostThreshold
        fullSubHighCostThreshold : Group → ℝ,
      (∀ g, subFullCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
          subFullTestFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
              subFullCostThreshold g ≤ c)) ∧
            (∀ g, fullSubLowCostThreshold g ∈
              Set.Ioo (0 : ℝ) (maxCost g)) ∧
              (∀ g, fullSubHighCostThreshold g ∈
                Set.Ioo (0 : ℝ) (maxCost g)) ∧
                (∀ g, fullSubLowTestBasedMerit g
                    (fullSubLowCostThreshold g) =
                  fullSubLowTestFreeMerit g) ∧
                  (∀ g, fullSubHighTestBasedMerit g
                      (fullSubHighCostThreshold g) =
                    fullSubHighTestFreeMerit g) ∧
                    (∀ g,
                      fullSubLowCostThreshold g <
                        fullSubHighCostThreshold g) ∧
                      ((S.policyPairIsEquilibrium Psub Pfull ↔
                          glm20Theorem3SubFullCondition S policyPair
                            Psub Pfull J2 groupA groupB populationShare
                            testCost subFullCostThreshold capacity2 q1Sub
                            (fun g q =>
                              glm20StrategicSubEstimateMassAbove api
                                (subEstimateLaw g) q)) ∧
                        (S.policyPairIsEquilibrium Pfull Psub ↔
                          glm20Theorem3FullSubCondition S policyPair
                            Psub Pfull groupA groupB testCost
                            fullSubLowCostThreshold fullSubHighCostThreshold
                            q1Sub q2Sub
                            (fun g q =>
                              glm20StrategicSubEstimateMassAbove api
                                (subEstimateLaw g) q)) ∧
                          glm20Theorem3FullFullCondition S Pfull groupA
                            groupB testCost) := by
  have hnoneJ1 :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Psub Pfull :=
    paper_proposition5_no_group_expands_no_drop_of_weighted_groupwise_merit_lt
      (S := S) (policyPair := policyPair) (J := J1) (groupA := groupA)
      (groupB := groupB) (populationShare := populationShare)
      (Pdrop1 := Psub) (Pdrop2 := Pfull) (Pkeep1 := Pfull)
      (Pkeep2 := Pfull) (q := q1Sub) (cutoff := fullFullCutoff)
      hshareA hshareB hfixedPoolJ1A hfixedPoolJ1B
  have hbothJ1_impossible :
      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False :=
    paper_proposition5_part_i_both_fullFull_cutoff_cases_impossible_of_capacity
      (S := S) (policyPair := policyPair) (Pfull := Pfull)
      (populationShare := populationShare) (capacity1 := capacity1)
      (q1Sub := q1Sub) api subEstimateLaw hshareA hshareB hmassFullFullA
      hmassFullFullB hcapacity1 hfillFullFull1
  have hnoneJ2 :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ¬ glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub :=
    paper_proposition5_no_group_expands_no_drop_of_weighted_groupwise_merit_lt
      (S := S) (policyPair := policyPair) (J := J2) (groupA := groupA)
      (groupB := groupB) (populationShare := populationShare)
      (Pdrop1 := Pfull) (Pdrop2 := Psub) (Pkeep1 := Pfull)
      (Pkeep2 := Pfull) (q := q2Sub) (cutoff := fullFullCutoff)
      hshareA hshareB hfixedPoolJ2A hfixedPoolJ2B
  have hbothJ2_impossible :
      q2Sub < fullFullCutoff groupA →
        q2Sub < fullFullCutoff groupB → False :=
    paper_proposition5_part_ii_both_fullFull_cutoff_cases_impossible_of_capacity
      (S := S) (policyPair := policyPair) (Pfull := Pfull)
      (populationShare := populationShare) (capacity2 := capacity2)
      (q2Sub := q2Sub) api subEstimateLaw hshareA hshareB hmassFullFullA
      hmassFullFullB hcapacity2 hfillFullFull2
  exact
    paper_theorem3_source_conditions_of_proposition5_merit_crossings_weighted_objectives
      (S := S) (policyPair := policyPair) (Psub := Psub) (Pfull := Pfull)
      (J1 := J1) (J2 := J2) (groupA := groupA) (groupB := groupB)
      (populationShare := populationShare) (testCost := testCost)
      (maxCost := maxCost) (capacity2 := capacity2) (q1Sub := q1Sub)
      (q2Sub := q2Sub) (fullFullCutoff := fullFullCutoff)
      (fullSubCutoff := fullSubCutoff) api subEstimateLaw
      subFullTestBasedMerit subFullTestFreeMerit fullSubLowTestBasedMerit
      fullSubLowTestFreeMerit fullSubHighTestBasedMerit
      fullSubHighTestFreeMerit hmaxCost hcostMem hpolicySubFull
      hpolicyFullSub hsubFullCont hsubFullAnti hsubFullAtZero
      hsubFullAtMax hlowCont hlowAnti hlowAtZero hlowAtMax hhighCont
      hhighAnti hhighAtZero hhighAtMax hhighAtLowRoot hmassFullFullA
      hmassFullFullB hmassFullSubA hmassFullSubB hnoneJ1
      hbothJ1_impossible honlyA_J1_merit honlyB_J1_merit hJ2ZeroA
      hJ2MassB hJ2NotTieB hJ2ZeroB hJ2MassA hJ2NotTieA hnoneJ2
      hbothJ2_impossible honlyA_J2_merit honlyB_J2_merit hnoExpandA
      hexpandA_testFree hexpandA_testBased hnoExpandB hexpandB_testFree
      hexpandB_testBased hcostA hcostB

/--
Paper Theorem 3 source-shaped endpoint over the weighted academic-merit
binary-policy surface.

This is the same Proposition 5 merit-crossing endpoint as
`paper_theorem3_source_conditions_of_proposition5_merit_crossings_weighted_objectives`,
but specialized to
`glm20WeightedAcademicMeritBinaryPolicySurface`.  The assumptions saying that
`policyPairIsEquilibrium` is equivalent to the two-policy binary game are
therefore discharged by the surface definition.
-/
theorem paper_theorem3_source_conditions_of_proposition5_merit_crossings_weighted_binary_surface
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff fullSubCutoff : Group → ℝ}
    (subFullTestBasedMerit : Group → ℝ → ℝ)
    (subFullTestFreeMerit : Group → ℝ)
    (fullSubLowTestBasedMerit : Group → ℝ → ℝ)
    (fullSubLowTestFreeMerit : Group → ℝ)
    (fullSubHighTestBasedMerit : Group → ℝ → ℝ)
    (fullSubHighTestFreeMerit : Group → ℝ)
    (hS :
      S =
        glm20WeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2
          groupA groupB populationShare)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hsubFullCont :
      ∀ g, ContinuousOn (subFullTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hsubFullAnti :
      ∀ g, StrictAntiOn (subFullTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hsubFullAtZero :
      ∀ g, subFullTestFreeMerit g < subFullTestBasedMerit g 0)
    (hsubFullAtMax :
      ∀ g, subFullTestBasedMerit g (maxCost g) < subFullTestFreeMerit g)
    (hlowCont :
      ∀ g, ContinuousOn (fullSubLowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAnti :
      ∀ g, StrictAntiOn (fullSubLowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAtZero :
      ∀ g, fullSubLowTestFreeMerit g < fullSubLowTestBasedMerit g 0)
    (hlowAtMax :
      ∀ g, fullSubLowTestBasedMerit g (maxCost g) <
        fullSubLowTestFreeMerit g)
    (hhighCont :
      ∀ g, ContinuousOn (fullSubHighTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAnti :
      ∀ g, StrictAntiOn (fullSubHighTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAtZero :
      ∀ g, fullSubHighTestFreeMerit g < fullSubHighTestBasedMerit g 0)
    (hhighAtMax :
      ∀ g, fullSubHighTestBasedMerit g (maxCost g) <
        fullSubHighTestFreeMerit g)
    (hhighAtLowRoot :
      ∀ g c, c ∈ Set.Ioo (0 : ℝ) (maxCost g) →
        fullSubLowTestBasedMerit g c = fullSubLowTestFreeMerit g →
          fullSubHighTestFreeMerit g < fullSubHighTestBasedMerit g c)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hmassFullSubA :
      S.massTestTaking groupA (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullSubCutoff groupA))
    (hmassFullSubB :
      S.massTestTaking groupB (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullSubCutoff groupB))
    (hnoneJ1 :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Psub Pfull)
    (hbothJ1_impossible :
      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False)
    (honlyA_J1_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Psub Pfull) ↔
            subFullTestBasedMerit groupA (testCost groupA) ≤
              subFullTestFreeMerit groupA))
    (honlyB_J1_merit :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Psub Pfull) ↔
            subFullTestBasedMerit groupB (testCost groupB) ≤
              subFullTestFreeMerit groupB))
    (hJ2ZeroA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) = 0)
    (hJ2MassB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2)
    (hJ2NotTieB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ZeroB :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) = 0)
    (hJ2MassA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2)
    (hJ2NotTieA :
      ∀ costThreshold : Group → ℝ,
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hnoneJ2 :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ¬ glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub)
    (hbothJ2_impossible :
      q2Sub < fullFullCutoff groupA →
        q2Sub < fullFullCutoff groupB → False)
    (honlyA_J2_merit :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub) ↔
            fullSubLowTestBasedMerit groupA (testCost groupA) ≤
              fullSubLowTestFreeMerit groupA))
    (honlyB_J2_merit :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          ((glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            glm20TwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub) ↔
            fullSubLowTestBasedMerit groupB (testCost groupB) ≤
              fullSubLowTestFreeMerit groupB))
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandA_testFree :
      ¬ fullSubCutoff groupA < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub =
          fullSubHighTestFreeMerit groupA)
    (hexpandA_testBased :
      ¬ fullSubCutoff groupA < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub =
          fullSubHighTestBasedMerit groupA (testCost groupA))
    (hnoExpandB :
      fullSubCutoff groupB < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandB_testFree :
      ¬ fullSubCutoff groupB < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub =
          fullSubHighTestFreeMerit groupB)
    (hexpandB_testBased :
      ¬ fullSubCutoff groupB < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub =
          fullSubHighTestBasedMerit groupB (testCost groupB))
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    ∃ subFullCostThreshold fullSubLowCostThreshold
        fullSubHighCostThreshold : Group → ℝ,
      (∀ g, subFullCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
          subFullTestFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
              subFullCostThreshold g ≤ c)) ∧
            (∀ g, fullSubLowCostThreshold g ∈
              Set.Ioo (0 : ℝ) (maxCost g)) ∧
              (∀ g, fullSubHighCostThreshold g ∈
                Set.Ioo (0 : ℝ) (maxCost g)) ∧
                (∀ g, fullSubLowTestBasedMerit g
                    (fullSubLowCostThreshold g) =
                  fullSubLowTestFreeMerit g) ∧
                  (∀ g, fullSubHighTestBasedMerit g
                      (fullSubHighCostThreshold g) =
                    fullSubHighTestFreeMerit g) ∧
                    (∀ g,
                      fullSubLowCostThreshold g <
                        fullSubHighCostThreshold g) ∧
                      ((S.policyPairIsEquilibrium Psub Pfull ↔
                          glm20Theorem3SubFullCondition S policyPair
                            Psub Pfull J2 groupA groupB populationShare
                            testCost subFullCostThreshold capacity2 q1Sub
                            (fun g q =>
                              glm20StrategicSubEstimateMassAbove api
                                (subEstimateLaw g) q)) ∧
                        (S.policyPairIsEquilibrium Pfull Psub ↔
                          glm20Theorem3FullSubCondition S policyPair
                            Psub Pfull groupA groupB testCost
                            fullSubLowCostThreshold fullSubHighCostThreshold
                            q1Sub q2Sub
                            (fun g q =>
                              glm20StrategicSubEstimateMassAbove api
                                (subEstimateLaw g) q)) ∧
                          glm20Theorem3FullFullCondition S Pfull groupA
                            groupB testCost) := by
  subst S
  exact
    paper_theorem3_source_conditions_of_proposition5_merit_crossings_weighted_objectives
      (S :=
        glm20WeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2
          groupA groupB populationShare)
      (policyPair := policyPair) (Psub := Psub) (Pfull := Pfull)
      (J1 := J1) (J2 := J2) (groupA := groupA) (groupB := groupB)
      (populationShare := populationShare) (testCost := testCost)
      (maxCost := maxCost) (capacity2 := capacity2) (q1Sub := q1Sub)
      (q2Sub := q2Sub) (fullFullCutoff := fullFullCutoff)
      (fullSubCutoff := fullSubCutoff) api subEstimateLaw
      subFullTestBasedMerit subFullTestFreeMerit fullSubLowTestBasedMerit
      fullSubLowTestFreeMerit fullSubHighTestBasedMerit
      fullSubHighTestFreeMerit hmaxCost hcostMem
      (by
        exact
          glm20WeightedAcademicMeritBinaryPolicySurface_policyPairIsEquilibrium_iff)
      (by
        exact
          glm20WeightedAcademicMeritBinaryPolicySurface_policyPairIsEquilibrium_iff)
      hsubFullCont hsubFullAnti hsubFullAtZero hsubFullAtMax hlowCont
        hlowAnti hlowAtZero hlowAtMax hhighCont hhighAnti hhighAtZero
        hhighAtMax hhighAtLowRoot hmassFullFullA hmassFullFullB
        hmassFullSubA hmassFullSubB hnoneJ1 hbothJ1_impossible
        honlyA_J1_merit honlyB_J1_merit
        (by
          intro costThreshold hdropA
          simp [hJ2ZeroA costThreshold hdropA])
        hJ2MassB hJ2NotTieB
        (by
          intro costThreshold hdropB
          simp [hJ2ZeroB costThreshold hdropB])
        hJ2MassA hJ2NotTieA hnoneJ2 hbothJ2_impossible
      honlyA_J2_merit honlyB_J2_merit hnoExpandA hexpandA_testFree
      hexpandA_testBased hnoExpandB hexpandB_testFree hexpandB_testBased
      hcostA hcostB

/-- Certificate for Lemma 1's Gaussian estimated-skill formula and law. -/
structure GLM20EstimatedSkillCertificate
    {Group Policy : Type*} (_S : GLM20SourcePolicySurface Group Policy) where
  posteriorMeanFormula : Prop
  estimatedSkillDistribution : Prop
  posteriorMeanFormula_holds : posteriorMeanFormula
  estimatedSkillDistribution_holds : estimatedSkillDistribution

/-- Lemma 1 endpoint, conditional on the Gaussian posterior algebra certificate. -/
theorem paper_lemma1_estimated_skill_of_certificate
    {Group Policy : Type*} {S : GLM20SourcePolicySurface Group Policy}
    (C : GLM20EstimatedSkillCertificate S) :
    C.posteriorMeanFormula ∧ C.estimatedSkillDistribution :=  ⟨C.posteriorMeanFormula_holds, C.estimatedSkillDistribution_holds⟩

/-- Certificate for Proposition 1's fixed-policy metrics. -/
structure GLM20FixedPolicyMetricsCertificate
    {Group Policy : Type*} (_S : GLM20SourcePolicySurface Group Policy) where
  groupFairnessFailureExceptEqualPrecision : Prop
  diversityDecreasesWithInformativenessGap : Prop
  individualFairnessGapCharacterization : Prop
  individualFairnessGapIncreasesHighSkill : Prop
  admittedGroupBLowerAcademicMerit : Prop
  groupFairnessFailureExceptEqualPrecision_holds :
    groupFairnessFailureExceptEqualPrecision
  diversityDecreasesWithInformativenessGap_holds :
    diversityDecreasesWithInformativenessGap
  individualFairnessGapCharacterization_holds :
    individualFairnessGapCharacterization
  individualFairnessGapIncreasesHighSkill_holds :
    individualFairnessGapIncreasesHighSkill
  admittedGroupBLowerAcademicMerit_holds :
    admittedGroupBLowerAcademicMerit

/-- Proposition 1 endpoint, conditional on the fixed-policy Gaussian metric certificate. -/
theorem paper_proposition1_metrics_fixed_policy_of_certificate
    {Group Policy : Type*} {S : GLM20SourcePolicySurface Group Policy}
    (C : GLM20FixedPolicyMetricsCertificate S) :
    C.groupFairnessFailureExceptEqualPrecision ∧
      C.diversityDecreasesWithInformativenessGap ∧
        C.individualFairnessGapCharacterization ∧
          C.individualFairnessGapIncreasesHighSkill ∧
            C.admittedGroupBLowerAcademicMerit :=
   ⟨C.groupFairnessFailureExceptEqualPrecision_holds,
    C.diversityDecreasesWithInformativenessGap_holds,
    C.individualFairnessGapCharacterization_holds,
    C.individualFairnessGapIncreasesHighSkill_holds,
    C.admittedGroupBLowerAcademicMerit_holds⟩

/--
Lemma 2 calculus support: if the derivative of the source individual-fairness
gap is strictly negative on the tail above `q_e`, then the gap is strictly
decreasing on that tail.
-/
theorem paper_lemma2_individual_fairness_gap_strictAntiOn_of_deriv_neg
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy} {q_e : ℝ}
    (hcont :
      ContinuousOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e))
    (hderiv_neg :
      ∀ q ∈ interior (Set.Ioi q_e),
        deriv (fun x : ℝ => S.individualFairnessGap P x) q < 0) :
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) := strictAntiOn_of_deriv_neg (convex_Ioi q_e) hcont hderiv_neg

/--
Lemma 2 tail comparison: a strictly antitone individual-fairness gap on
`(q_e, ∞)` gives the paper's pairwise decreasing conclusion for any
`q_e < q_low < q_high`.
-/
theorem paper_lemma2_individual_fairness_gap_decreases_on_tail
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy} {q_e q_low q_high : ℝ}
    (hanti :
      StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e))
    (hlow : q_e < q_low) (hhigh : q_low < q_high) :
    S.individualFairnessGap P q_high <
      S.individualFairnessGap P q_low :=
  hanti (show q_low ∈ Set.Ioi q_e by simpa)
    (show q_high ∈ Set.Ioi q_e by simp [lt_trans hlow hhigh])
    hhigh

/--
Lemma 2 limit support: if the individual-fairness gap is the difference of
two admission-tail probabilities and both tails vanish as skill goes to
infinity, then the gap itself tends to zero.
-/
theorem paper_lemma2_individual_fairness_gap_tendsto_zero_of_tail_tendsto
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {tailA tailB : ℝ → ℝ}
    (hgap_eq :
      ∀ q : ℝ, S.individualFairnessGap P q = tailA q - tailB q)
    (hA : Filter.Tendsto tailA Filter.atTop (nhds 0))
    (hB : Filter.Tendsto tailB Filter.atTop (nhds 0)) :
    Filter.Tendsto (fun q : ℝ => S.individualFairnessGap P q) Filter.atTop (nhds 0) := by
  have hfun :
      (fun q : ℝ => S.individualFairnessGap P q) =
        fun q : ℝ => tailA q - tailB q := by
    funext q
    exact hgap_eq q
  rw [hfun]
  simpa using hA.sub hB

/--
Lemma 2 log-density algebra: for unequal positive precisions `B < A`, the
paper's displayed threshold `q_e` is sufficient for the log-density comparison
that makes the derivative of the individual-fairness gap negative.

Here `priorTerm` is the paper's `σ^{-2}(\tilde q_S^* - μ)`, `threshold` is
`\tilde q_S^*`, and `A`/`B` are the two group total precisions.
-/
theorem paper_lemma2_log_density_inequality_of_q_gt_threshold
    {precisionA precisionB priorTerm threshold q : ℝ}
    (hprecisionB_pos : 0 < precisionB)
    (hprecision_gap : precisionB < precisionA)
    (hq :
      threshold +
          Real.sqrt
            ((Real.log precisionA - Real.log precisionB) /
                (precisionA - precisionB) +
              priorTerm ^ 2 / (precisionA * precisionB)) <
        q) :
    - (priorTerm - precisionA * (q - threshold)) ^ 2 / precisionA +
        Real.log precisionA <
      - (priorTerm - precisionB * (q - threshold)) ^ 2 / precisionB +
        Real.log precisionB := by
  have hprecisionA_pos : 0 < precisionA :=
    lt_trans hprecisionB_pos hprecision_gap
  have hdiff_pos : 0 < precisionA - precisionB :=
    sub_pos.mpr hprecision_gap
  let R : ℝ :=
    (Real.log precisionA - Real.log precisionB) /
        (precisionA - precisionB) +
      priorTerm ^ 2 / (precisionA * precisionB)
  have hx_pos : 0 < q - threshold := by
    have hsqrt_nonneg : 0 ≤ Real.sqrt R := Real.sqrt_nonneg R
    dsimp [R] at hsqrt_nonneg
    linarith
  have hsqrt_lt : Real.sqrt R < q - threshold := by
    dsimp [R]
    linarith
  have hR_lt : R < (q - threshold) ^ 2 :=
    (Real.sqrt_lt' hx_pos).mp hsqrt_lt
  have hmain :
      (Real.log precisionA - Real.log precisionB) /
          (precisionA - precisionB) +
        priorTerm ^ 2 / (precisionA * precisionB) <
          (q - threshold) ^ 2 := by
    simpa [R] using hR_lt
  have hprecisionA_ne : precisionA ≠ 0 := ne_of_gt hprecisionA_pos
  have hprecisionB_ne : precisionB ≠ 0 := ne_of_gt hprecisionB_pos
  have hdiff_ne : precisionA - precisionB ≠ 0 := ne_of_gt hdiff_pos
  field_simp [hprecisionA_ne, hprecisionB_ne, hdiff_ne] at hmain ⊢
  nlinarith

/--
Lemma 2 log-to-derivative bridge: if the derivative is the difference of two
positive weighted density terms, and the log of the first term is smaller than
the log of the second, then the derivative is strictly negative.
-/
theorem paper_lemma2_deriv_neg_of_log_weighted_density_lt
    {derivGap weightedA weightedB : ℝ}
    (hderiv : derivGap = weightedA - weightedB)
    (hweightedA_pos : 0 < weightedA)
    (hweightedB_pos : 0 < weightedB)
    (hlog : Real.log weightedA < Real.log weightedB) :
    derivGap < 0 := by
  have hlt : weightedA < weightedB :=
    (Real.log_lt_log_iff hweightedA_pos hweightedB_pos).mp hlog
  linarith

/--
Lemma 2 derivative negativity from the displayed `q_e` threshold and
log-density identities.  This connects the source's algebraic `q > q_e`
condition to the negative derivative premise used by
`paper_lemma2_individual_fairness_gap_strictAntiOn_of_deriv_neg`.
-/
theorem paper_lemma2_deriv_neg_of_q_gt_threshold_and_log_identities
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {precisionA precisionB priorTerm threshold q weightedA weightedB : ℝ}
    (hderiv :
      deriv (fun x : ℝ => S.individualFairnessGap P x) q =
        weightedA - weightedB)
    (hweightedA_pos : 0 < weightedA)
    (hweightedB_pos : 0 < weightedB)
    (hlogA :
      Real.log weightedA =
        - (priorTerm - precisionA * (q - threshold)) ^ 2 / precisionA +
          Real.log precisionA)
    (hlogB :
      Real.log weightedB =
        - (priorTerm - precisionB * (q - threshold)) ^ 2 / precisionB +
          Real.log precisionB)
    (hprecisionB_pos : 0 < precisionB)
    (hprecision_gap : precisionB < precisionA)
    (hq :
      threshold +
          Real.sqrt
            ((Real.log precisionA - Real.log precisionB) /
                (precisionA - precisionB) +
              priorTerm ^ 2 / (precisionA * precisionB)) <
        q) :
    deriv (fun x : ℝ => S.individualFairnessGap P x) q < 0 := by
  apply paper_lemma2_deriv_neg_of_log_weighted_density_lt
    hderiv hweightedA_pos hweightedB_pos
  rw [hlogA, hlogB]
  exact
    paper_lemma2_log_density_inequality_of_q_gt_threshold
      hprecisionB_pos hprecision_gap hq

/--
Lemma 2 log-to-derivative bridge in the paper's normalized form: the standard
normal density contributes a common constant, so it is enough to compare the
doubled logarithms of the two positive density-weighted terms.
-/
theorem paper_lemma2_deriv_neg_of_q_gt_threshold_and_doubled_log_identities
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {precisionA precisionB priorTerm threshold q weightedA weightedB
      commonLogDensityConstant : ℝ}
    (hderiv :
      deriv (fun x : ℝ => S.individualFairnessGap P x) q =
        weightedA - weightedB)
    (hweightedA_pos : 0 < weightedA)
    (hweightedB_pos : 0 < weightedB)
    (h2logA :
      2 * Real.log weightedA =
        - (priorTerm - precisionA * (q - threshold)) ^ 2 / precisionA +
          Real.log precisionA + commonLogDensityConstant)
    (h2logB :
      2 * Real.log weightedB =
        - (priorTerm - precisionB * (q - threshold)) ^ 2 / precisionB +
          Real.log precisionB + commonLogDensityConstant)
    (hprecisionB_pos : 0 < precisionB)
    (hprecision_gap : precisionB < precisionA)
    (hq :
      threshold +
          Real.sqrt
            ((Real.log precisionA - Real.log precisionB) /
                (precisionA - precisionB) +
              priorTerm ^ 2 / (precisionA * precisionB)) <
        q) :
    deriv (fun x : ℝ => S.individualFairnessGap P x) q < 0 := by
  apply paper_lemma2_deriv_neg_of_log_weighted_density_lt
    hderiv hweightedA_pos hweightedB_pos
  have hmain :
      - (priorTerm - precisionA * (q - threshold)) ^ 2 / precisionA +
          Real.log precisionA <
        - (priorTerm - precisionB * (q - threshold)) ^ 2 / precisionB +
          Real.log precisionB :=
    paper_lemma2_log_density_inequality_of_q_gt_threshold
      hprecisionB_pos hprecision_gap hq
  have htwice :
      2 * Real.log weightedA < 2 * Real.log weightedB := by
    rw [h2logA, h2logB]
    linarith
  linarith

/--
Lemma 2 packaged tail-decrease theorem: if `q_e` is the paper's displayed
threshold and the Gaussian derivative/log-density identities hold above
`q_e`, then the individual-fairness gap is strictly decreasing on `(q_e, ∞)`.
-/
theorem paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_log_density_data
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {precisionA precisionB priorTerm threshold q_e : ℝ}
    {weightedA weightedB : ℝ → ℝ}
    (hcont :
      ContinuousOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e))
    (hqe :
      q_e =
        threshold +
          Real.sqrt
            ((Real.log precisionA - Real.log precisionB) /
                (precisionA - precisionB) +
              priorTerm ^ 2 / (precisionA * precisionB)))
    (hderiv :
      ∀ q ∈ interior (Set.Ioi q_e),
        deriv (fun x : ℝ => S.individualFairnessGap P x) q =
          weightedA q - weightedB q)
    (hweightedA_pos :
      ∀ q ∈ interior (Set.Ioi q_e), 0 < weightedA q)
    (hweightedB_pos :
      ∀ q ∈ interior (Set.Ioi q_e), 0 < weightedB q)
    (hlogA :
      ∀ q ∈ interior (Set.Ioi q_e),
        Real.log (weightedA q) =
          - (priorTerm - precisionA * (q - threshold)) ^ 2 / precisionA +
            Real.log precisionA)
    (hlogB :
      ∀ q ∈ interior (Set.Ioi q_e),
        Real.log (weightedB q) =
          - (priorTerm - precisionB * (q - threshold)) ^ 2 / precisionB +
            Real.log precisionB)
    (hprecisionB_pos : 0 < precisionB)
    (hprecision_gap : precisionB < precisionA) :
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) := by
  apply paper_lemma2_individual_fairness_gap_strictAntiOn_of_deriv_neg hcont
  intro q hq
  apply paper_lemma2_deriv_neg_of_q_gt_threshold_and_log_identities
    (hderiv q hq) (hweightedA_pos q hq) (hweightedB_pos q hq)
    (hlogA q hq) (hlogB q hq) hprecisionB_pos hprecision_gap
  rw [← hqe]
  simpa using (interior_subset hq)

/--
Lemma 2 normalized-log packaged theorem: if `q_e` is the paper's displayed
threshold and the doubled-log density identities hold above `q_e`, then the
individual-fairness gap is strictly decreasing on `(q_e, ∞)`.
-/
theorem paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_doubled_log_density_data
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    {precisionA precisionB priorTerm threshold q_e commonLogDensityConstant : ℝ}
    {weightedA weightedB : ℝ → ℝ}
    (hcont :
      ContinuousOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e))
    (hqe :
      q_e =
        threshold +
          Real.sqrt
            ((Real.log precisionA - Real.log precisionB) /
                (precisionA - precisionB) +
              priorTerm ^ 2 / (precisionA * precisionB)))
    (hderiv :
      ∀ q ∈ interior (Set.Ioi q_e),
        deriv (fun x : ℝ => S.individualFairnessGap P x) q =
          weightedA q - weightedB q)
    (hweightedA_pos :
      ∀ q ∈ interior (Set.Ioi q_e), 0 < weightedA q)
    (hweightedB_pos :
      ∀ q ∈ interior (Set.Ioi q_e), 0 < weightedB q)
    (h2logA :
      ∀ q ∈ interior (Set.Ioi q_e),
        2 * Real.log (weightedA q) =
          - (priorTerm - precisionA * (q - threshold)) ^ 2 / precisionA +
            Real.log precisionA + commonLogDensityConstant)
    (h2logB :
      ∀ q ∈ interior (Set.Ioi q_e),
        2 * Real.log (weightedB q) =
          - (priorTerm - precisionB * (q - threshold)) ^ 2 / precisionB +
            Real.log precisionB + commonLogDensityConstant)
    (hprecisionB_pos : 0 < precisionB)
    (hprecision_gap : precisionB < precisionA) :
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) := by
  apply paper_lemma2_individual_fairness_gap_strictAntiOn_of_deriv_neg hcont
  intro q hq
  apply paper_lemma2_deriv_neg_of_q_gt_threshold_and_doubled_log_identities
    (hderiv q hq) (hweightedA_pos q hq) (hweightedB_pos q hq)
    (h2logA q hq) (h2logB q hq) hprecisionB_pos hprecision_gap
  rw [← hqe]
  simpa using (interior_subset hq)

/--
Lemma 2 Gaussian-tail continuity bridge: if the source individual-fairness gap
is the difference of two affine standardized normal upper tails, then it is
continuous on the tail interval.
-/
theorem paper_lemma2_individual_fairness_gap_continuousOn_of_affine_tail_formulas
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianDerivativeAPI)
    {interceptA slopeA interceptB slopeB q_e : ℝ}
    (hgap_eq :
      ∀ q : ℝ, S.individualFairnessGap P q =
        A.affineUpperTail interceptA slopeA q -
          A.affineUpperTail interceptB slopeB q) :
    ContinuousOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) := by
  have hfun :
      (fun q : ℝ => S.individualFairnessGap P q) =
        fun q : ℝ =>
          A.affineUpperTail interceptA slopeA q -
            A.affineUpperTail interceptB slopeB q := by
    funext q
    exact hgap_eq q
  rw [hfun]
  exact (A.affineUpperTailDifference_continuous (interceptA := interceptA)
    (slopeA := slopeA) (interceptB := interceptB)
    (slopeB := slopeB)).continuousOn

/--
Lemma 2 Gaussian-tail derivative bridge: the derivative of a difference of two
affine standardized upper tails is the difference of the corresponding
density-weighted affine slopes.
-/
theorem paper_lemma2_individual_fairness_gap_hasDerivAt_of_affine_tail_formulas
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianDerivativeAPI)
    {interceptA slopeA interceptB slopeB q : ℝ}
    (hgap_eq :
      ∀ x : ℝ, S.individualFairnessGap P x =
        A.affineUpperTail interceptA slopeA x -
          A.affineUpperTail interceptB slopeB x) :
    HasDerivAt (fun x : ℝ => S.individualFairnessGap P x)
      (A.api.density (interceptA - slopeA * q) * slopeA -
        A.api.density (interceptB - slopeB * q) * slopeB) q := by
  have hfun :
      (fun x : ℝ => S.individualFairnessGap P x) =
        fun x : ℝ =>
          A.affineUpperTail interceptA slopeA x -
            A.affineUpperTail interceptB slopeB x := by
    funext x
    exact hgap_eq x
  rw [hfun]
  exact A.affineUpperTailDifference_hasDerivAt
    (interceptA := interceptA) (slopeA := slopeA)
    (interceptB := interceptB) (slopeB := slopeB) (q := q)

/--
Lemma 2 derivative equation from affine Gaussian tail formulas.  This removes
the raw derivative-equality premise from the source-facing Lemma 2 bridge.
-/
theorem paper_lemma2_individual_fairness_gap_deriv_eq_of_affine_tail_formulas
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianDerivativeAPI)
    {interceptA slopeA interceptB slopeB q : ℝ}
    (hgap_eq :
      ∀ x : ℝ, S.individualFairnessGap P x =
        A.affineUpperTail interceptA slopeA x -
          A.affineUpperTail interceptB slopeB x) :
    deriv (fun x : ℝ => S.individualFairnessGap P x) q =
      A.api.density (interceptA - slopeA * q) * slopeA -
        A.api.density (interceptB - slopeB * q) * slopeB :=
  (paper_lemma2_individual_fairness_gap_hasDerivAt_of_affine_tail_formulas
    A hgap_eq).deriv

/--
Lemma 2 Gaussian-tail limit bridge: a difference of two affine standardized
upper-tail admission probabilities tends to zero as true skill goes to
infinity.
-/
theorem paper_lemma2_individual_fairness_gap_tendsto_zero_of_affine_tail_formulas
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianTailLimitAPI)
    {interceptA slopeA interceptB slopeB : ℝ}
    (hgap_eq :
      ∀ q : ℝ, S.individualFairnessGap P q =
        A.derivativeAPI.affineUpperTail interceptA slopeA q -
          A.derivativeAPI.affineUpperTail interceptB slopeB q)
    (hslopeA_pos : 0 < slopeA)
    (hslopeB_pos : 0 < slopeB) :
    Filter.Tendsto (fun q : ℝ => S.individualFairnessGap P q)
      Filter.atTop (nhds 0) := by
  have hfun :
      (fun q : ℝ => S.individualFairnessGap P q) =
        fun q : ℝ =>
          A.derivativeAPI.affineUpperTail interceptA slopeA q -
            A.derivativeAPI.affineUpperTail interceptB slopeB q := by
    funext q
    exact hgap_eq q
  rw [hfun]
  exact A.affineUpperTailDifference_tendsto_zero_atTop_of_slope_pos
    hslopeA_pos hslopeB_pos

/--
Lemma 2 normal-density log identity from the standard Gaussian doubled-log API.
The remaining inputs are algebraic: the squared standardized cutoff and the
positive-slope log identity for the paper's precision parameterization.
-/
theorem paper_lemma2_doubled_log_weighted_density_eq_of_square_data
    (A : StandardGaussianDoubledLogDensityAPI)
    {precision priorTerm threshold intercept slope q : ℝ}
    (hslope_pos : 0 < slope)
    (hz_sq :
      (intercept - slope * q) ^ 2 =
        (priorTerm - precision * (q - threshold)) ^ 2 / precision)
    (hslope_log : 2 * Real.log slope = Real.log precision) :
    2 * Real.log
        (A.derivativeAPI.api.density (intercept - slope * q) * slope) =
      - (priorTerm - precision * (q - threshold)) ^ 2 / precision +
        Real.log precision + A.logDensityConstant := by
  rw [A.doubled_log_density_mul_slope_eq (z := intercept - slope * q)
    (slope := slope) hslope_pos]
  rw [hz_sq, hslope_log]
  ring

/--
Lemma 2 standardization algebra: the paper's affine standardized cutoff
formula implies the squared cutoff identity used in the doubled-log density
comparison.
-/
theorem paper_lemma2_standardized_square_eq_of_sqrt_precision
    {precision priorTerm threshold intercept slope q : ℝ}
    (hprecision_pos : 0 < precision)
    (hstandardized :
      intercept - slope * q =
        (priorTerm - precision * (q - threshold)) / Real.sqrt precision) :
    (intercept - slope * q) ^ 2 =
      (priorTerm - precision * (q - threshold)) ^ 2 / precision := by
  rw [hstandardized]
  rw [div_pow]
  rw [Real.sq_sqrt hprecision_pos.le]

/--
Lemma 2 slope-log algebra: if the affine tail slope is the square root of the
paper's precision term, then its doubled log is the log precision term.
-/
theorem paper_lemma2_slope_log_eq_of_sqrt_precision
    {precision slope : ℝ}
    (hprecision_pos : 0 < precision)
    (hslope_eq : slope = Real.sqrt precision) :
    2 * Real.log slope = Real.log precision := by
  rw [hslope_eq, Real.log_sqrt hprecision_pos.le]
  ring

/--
Lemma 2 precision algebra: the source standardization numerator has the affine
form `intercept - sqrt(precision) * q`.
-/
theorem paper_lemma2_precision_standardized_eq_affine
    {precision priorTerm threshold q : ℝ}
    (hprecision_pos : 0 < precision) :
    (priorTerm - precision * (q - threshold)) / Real.sqrt precision =
      (priorTerm + precision * threshold) / Real.sqrt precision -
        Real.sqrt precision * q := by
  have hsqrt_ne : Real.sqrt precision ≠ 0 :=
    ne_of_gt (Real.sqrt_pos.mpr hprecision_pos)
  field_simp [hsqrt_ne]
  rw [Real.sq_sqrt hprecision_pos.le]
  ring

/--
Lemma 2 source-facing affine-tail bridge: for Gaussian upper-tail formulas,
positive affine slopes, and the paper's log-density identities, the
individual-fairness gap is strictly decreasing above the displayed threshold.
-/
theorem paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_affine_tail_log_density_data
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianDerivativeAPI)
    {precisionA precisionB priorTerm threshold q_e : ℝ}
    {interceptA slopeA interceptB slopeB : ℝ}
    (hgap_eq :
      ∀ q : ℝ, S.individualFairnessGap P q =
        A.affineUpperTail interceptA slopeA q -
          A.affineUpperTail interceptB slopeB q)
    (hqe :
      q_e =
        threshold +
          Real.sqrt
            ((Real.log precisionA - Real.log precisionB) /
                (precisionA - precisionB) +
              priorTerm ^ 2 / (precisionA * precisionB)))
    (hslopeA_pos : 0 < slopeA)
    (hslopeB_pos : 0 < slopeB)
    (hlogA :
      ∀ q ∈ interior (Set.Ioi q_e),
        Real.log (A.api.density (interceptA - slopeA * q) * slopeA) =
          - (priorTerm - precisionA * (q - threshold)) ^ 2 / precisionA +
            Real.log precisionA)
    (hlogB :
      ∀ q ∈ interior (Set.Ioi q_e),
        Real.log (A.api.density (interceptB - slopeB * q) * slopeB) =
          - (priorTerm - precisionB * (q - threshold)) ^ 2 / precisionB +
            Real.log precisionB)
    (hprecisionB_pos : 0 < precisionB)
    (hprecision_gap : precisionB < precisionA) :
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) := by
  apply paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_log_density_data
    (paper_lemma2_individual_fairness_gap_continuousOn_of_affine_tail_formulas
      A hgap_eq)
    hqe
  · intro q hq
    exact
      paper_lemma2_individual_fairness_gap_deriv_eq_of_affine_tail_formulas
        A hgap_eq
  · intro q hq
    exact A.density_mul_slope_pos hslopeA_pos
  · intro q hq
    exact A.density_mul_slope_pos hslopeB_pos
  · exact hlogA
  · exact hlogB
  · exact hprecisionB_pos
  · exact hprecision_gap

/--
Lemma 2 source-facing standard-normal bridge: if `I(q; P_S)` is the difference
of two affine standardized Gaussian upper tails, the paper's squared
standardization identities hold, and the affine slopes match the displayed
precision logs, then `I(q; P_S)` is strictly decreasing above `q_e`.
-/
theorem paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_standard_normal_log_density_data
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianDoubledLogDensityAPI)
    {precisionA precisionB priorTerm threshold q_e : ℝ}
    {interceptA slopeA interceptB slopeB : ℝ}
    (hgap_eq :
      ∀ q : ℝ, S.individualFairnessGap P q =
        A.derivativeAPI.affineUpperTail interceptA slopeA q -
          A.derivativeAPI.affineUpperTail interceptB slopeB q)
    (hqe :
      q_e =
        threshold +
          Real.sqrt
            ((Real.log precisionA - Real.log precisionB) /
                (precisionA - precisionB) +
              priorTerm ^ 2 / (precisionA * precisionB)))
    (hslopeA_pos : 0 < slopeA)
    (hslopeB_pos : 0 < slopeB)
    (hzA_sq :
      ∀ q ∈ interior (Set.Ioi q_e),
        (interceptA - slopeA * q) ^ 2 =
          (priorTerm - precisionA * (q - threshold)) ^ 2 / precisionA)
    (hzB_sq :
      ∀ q ∈ interior (Set.Ioi q_e),
        (interceptB - slopeB * q) ^ 2 =
          (priorTerm - precisionB * (q - threshold)) ^ 2 / precisionB)
    (hslopeA_log : 2 * Real.log slopeA = Real.log precisionA)
    (hslopeB_log : 2 * Real.log slopeB = Real.log precisionB)
    (hprecisionB_pos : 0 < precisionB)
    (hprecision_gap : precisionB < precisionA) :
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) := by
  apply paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_doubled_log_density_data
    (paper_lemma2_individual_fairness_gap_continuousOn_of_affine_tail_formulas
      A.derivativeAPI hgap_eq)
    hqe
  · intro q hq
    exact
      paper_lemma2_individual_fairness_gap_deriv_eq_of_affine_tail_formulas
        A.derivativeAPI hgap_eq
  · intro q hq
    exact A.derivativeAPI.density_mul_slope_pos hslopeA_pos
  · intro q hq
    exact A.derivativeAPI.density_mul_slope_pos hslopeB_pos
  · intro q hq
    exact
      paper_lemma2_doubled_log_weighted_density_eq_of_square_data
        A hslopeA_pos (hzA_sq q hq) hslopeA_log
  · intro q hq
    exact
      paper_lemma2_doubled_log_weighted_density_eq_of_square_data
        A hslopeB_pos (hzB_sq q hq) hslopeB_log
  · exact hprecisionB_pos
  · exact hprecision_gap

/--
Lemma 2 source-surface bridge: if the individual-fairness gap is the
difference of the two Gaussian threshold pass probabilities, and both
standardized thresholds are affine in true skill, then the gap is the
difference of two affine Gaussian upper tails.
-/
theorem paper_lemma2_affine_tail_gap_eq_of_threshold_pass_prob_standardizations
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianDerivativeAPI)
    {threshold interceptA slopeA interceptB slopeB : ℝ}
    {lawA lawB : ℝ → GaussianScaleLaw}
    (hgap_eq_threshold :
      ∀ q : ℝ, S.individualFairnessGap P q =
        A.api.thresholdPassProb (lawA q) threshold -
          A.api.thresholdPassProb (lawB q) threshold)
    (hstdA :
      ∀ q : ℝ, (lawA q).standardize threshold = interceptA - slopeA * q)
    (hstdB :
      ∀ q : ℝ, (lawB q).standardize threshold = interceptB - slopeB * q) :
    ∀ q : ℝ, S.individualFairnessGap P q =
      A.affineUpperTail interceptA slopeA q -
        A.affineUpperTail interceptB slopeB q := by
  intro q
  rw [hgap_eq_threshold q]
  simp [StandardGaussianCDFAPI.thresholdPassProb,
    StandardGaussianCDFAPI.normalTail, StandardGaussianCDFAPI.normalCDF,
    StandardGaussianDerivativeAPI.affineUpperTail, hstdA q, hstdB q]

/--
Lemma 2 source-facing standard-normal tail-formula theorem: this is the
closest Lean statement to the paper's proof line.  Once the individual-fairness
gap is written as a difference of two affine Gaussian upper tails, and each
affine standardization has the paper's `numerator / sqrt(precision)` form,
the displayed `q_e` implies strict decrease of `I(q; P_S)` on the tail.
-/
theorem paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_standard_normal_tail_formulas
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianDoubledLogDensityAPI)
    {precisionA precisionB priorTerm threshold q_e : ℝ}
    {interceptA slopeA interceptB slopeB : ℝ}
    (hgap_eq :
      ∀ q : ℝ, S.individualFairnessGap P q =
        A.derivativeAPI.affineUpperTail interceptA slopeA q -
          A.derivativeAPI.affineUpperTail interceptB slopeB q)
    (hqe :
      q_e =
        threshold +
          Real.sqrt
            ((Real.log precisionA - Real.log precisionB) /
                (precisionA - precisionB) +
              priorTerm ^ 2 / (precisionA * precisionB)))
    (hslopeA_eq : slopeA = Real.sqrt precisionA)
    (hslopeB_eq : slopeB = Real.sqrt precisionB)
    (hstandardizedA :
      ∀ q ∈ interior (Set.Ioi q_e),
        interceptA - slopeA * q =
          (priorTerm - precisionA * (q - threshold)) / Real.sqrt precisionA)
    (hstandardizedB :
      ∀ q ∈ interior (Set.Ioi q_e),
        interceptB - slopeB * q =
          (priorTerm - precisionB * (q - threshold)) / Real.sqrt precisionB)
    (hprecisionB_pos : 0 < precisionB)
    (hprecision_gap : precisionB < precisionA) :
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) := by
  have hprecisionA_pos : 0 < precisionA :=
    lt_trans hprecisionB_pos hprecision_gap
  have hslopeA_pos : 0 < slopeA := by
    rw [hslopeA_eq]
    exact Real.sqrt_pos.mpr hprecisionA_pos
  have hslopeB_pos : 0 < slopeB := by
    rw [hslopeB_eq]
    exact Real.sqrt_pos.mpr hprecisionB_pos
  apply
    paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_standard_normal_log_density_data
      A hgap_eq hqe hslopeA_pos hslopeB_pos
  · intro q hq
    exact
      paper_lemma2_standardized_square_eq_of_sqrt_precision
        hprecisionA_pos (hstandardizedA q hq)
  · intro q hq
    exact
      paper_lemma2_standardized_square_eq_of_sqrt_precision
        hprecisionB_pos (hstandardizedB q hq)
  · exact
      paper_lemma2_slope_log_eq_of_sqrt_precision
        hprecisionA_pos hslopeA_eq
  · exact
      paper_lemma2_slope_log_eq_of_sqrt_precision
        hprecisionB_pos hslopeB_eq
  · exact hprecisionB_pos
  · exact hprecision_gap

/--
Lemma 2 threshold-probability theorem: this states the source proof in terms of
Gaussian score laws and a common admissions threshold.  The threshold pass
probabilities are rewritten to affine upper tails and then discharged by the
standard-normal tail-formula theorem above.
-/
theorem paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_threshold_tail_formulas
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianDoubledLogDensityAPI)
    {precisionA precisionB priorTerm threshold q_e : ℝ}
    {interceptA slopeA interceptB slopeB : ℝ}
    {lawA lawB : ℝ → GaussianScaleLaw}
    (hgap_eq_threshold :
      ∀ q : ℝ, S.individualFairnessGap P q =
        A.derivativeAPI.api.thresholdPassProb (lawA q) threshold -
          A.derivativeAPI.api.thresholdPassProb (lawB q) threshold)
    (hstdA :
      ∀ q : ℝ, (lawA q).standardize threshold = interceptA - slopeA * q)
    (hstdB :
      ∀ q : ℝ, (lawB q).standardize threshold = interceptB - slopeB * q)
    (hqe :
      q_e =
        threshold +
          Real.sqrt
            ((Real.log precisionA - Real.log precisionB) /
                (precisionA - precisionB) +
              priorTerm ^ 2 / (precisionA * precisionB)))
    (hslopeA_eq : slopeA = Real.sqrt precisionA)
    (hslopeB_eq : slopeB = Real.sqrt precisionB)
    (hstandardizedA :
      ∀ q ∈ interior (Set.Ioi q_e),
        interceptA - slopeA * q =
          (priorTerm - precisionA * (q - threshold)) / Real.sqrt precisionA)
    (hstandardizedB :
      ∀ q ∈ interior (Set.Ioi q_e),
        interceptB - slopeB * q =
          (priorTerm - precisionB * (q - threshold)) / Real.sqrt precisionB)
    (hprecisionB_pos : 0 < precisionB)
    (hprecision_gap : precisionB < precisionA) :
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) :=
  paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_standard_normal_tail_formulas
    A
    (paper_lemma2_affine_tail_gap_eq_of_threshold_pass_prob_standardizations
      A.derivativeAPI hgap_eq_threshold hstdA hstdB)
    hqe hslopeA_eq hslopeB_eq hstandardizedA hstandardizedB
    hprecisionB_pos hprecision_gap

/--
Lemma 2 conditional-posterior-law theorem: instantiates the threshold-tail
bridge with the conditional Gaussian law of the posterior estimate generated by
`GaussianOffsetSignalFamily`.  The only source-surface premise left here is
that `individualFairnessGap` is the difference of the two conditional Gaussian
threshold pass probabilities.
-/
theorem paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_conditional_posterior_laws
    {Feature Group Policy : Type*} [Fintype Feature] [Nonempty Feature]
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianDoubledLogDensityAPI)
    {M_A M_B : GaussianOffsetSignalFamily Feature}
    {priorTerm threshold q_e : ℝ}
    (hgap_eq_threshold :
      ∀ q : ℝ, S.individualFairnessGap P q =
        A.derivativeAPI.api.thresholdPassProb
            (M_A.conditionalPosteriorMeanScaleLaw q) threshold -
          A.derivativeAPI.api.thresholdPassProb
            (M_B.conditionalPosteriorMeanScaleLaw q) threshold)
    (hpriorTermA :
      M_A.centeredFamily.priorPrecision * (threshold - M_A.priorMean) =
        priorTerm)
    (hpriorTermB :
      M_B.centeredFamily.priorPrecision * (threshold - M_B.priorMean) =
        priorTerm)
    (hqe :
      q_e =
        threshold +
          Real.sqrt
            ((Real.log M_A.centeredFamily.signalPrecisionSum -
                Real.log M_B.centeredFamily.signalPrecisionSum) /
                (M_A.centeredFamily.signalPrecisionSum -
                  M_B.centeredFamily.signalPrecisionSum) +
              priorTerm ^ 2 /
                (M_A.centeredFamily.signalPrecisionSum *
                  M_B.centeredFamily.signalPrecisionSum)))
    (hprecision_gap :
      M_B.centeredFamily.signalPrecisionSum <
        M_A.centeredFamily.signalPrecisionSum) :
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) := by
  let precisionA := M_A.centeredFamily.signalPrecisionSum
  let precisionB := M_B.centeredFamily.signalPrecisionSum
  have hprecisionA_pos : 0 < precisionA := by
    dsimp [precisionA]
    exact M_A.centeredFamily.signalPrecisionSum_pos
  have hprecisionB_pos : 0 < precisionB := by
    dsimp [precisionB]
    exact M_B.centeredFamily.signalPrecisionSum_pos
  apply
    paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_threshold_tail_formulas
      (A := A)
      (precisionA := precisionA) (precisionB := precisionB)
      (priorTerm := priorTerm) (threshold := threshold) (q_e := q_e)
      (interceptA := (priorTerm + precisionA * threshold) / Real.sqrt precisionA)
      (slopeA := Real.sqrt precisionA)
      (interceptB := (priorTerm + precisionB * threshold) / Real.sqrt precisionB)
      (slopeB := Real.sqrt precisionB)
      (lawA := fun q : ℝ => M_A.conditionalPosteriorMeanScaleLaw q)
      (lawB := fun q : ℝ => M_B.conditionalPosteriorMeanScaleLaw q)
  · exact hgap_eq_threshold
  · intro q
    rw [GaussianOffsetSignalFamily.conditionalPosteriorMeanScaleLaw_standardize_threshold,
      hpriorTermA]
    exact paper_lemma2_precision_standardized_eq_affine hprecisionA_pos
  · intro q
    rw [GaussianOffsetSignalFamily.conditionalPosteriorMeanScaleLaw_standardize_threshold,
      hpriorTermB]
    exact paper_lemma2_precision_standardized_eq_affine hprecisionB_pos
  · simpa [precisionA, precisionB] using hqe
  · rfl
  · rfl
  · intro q hq
    exact (paper_lemma2_precision_standardized_eq_affine hprecisionA_pos).symm
  · intro q hq
    exact (paper_lemma2_precision_standardized_eq_affine hprecisionB_pos).symm
  · exact hprecisionB_pos
  · simpa [precisionA, precisionB] using hprecision_gap

/--
Lemma 2 conditional-posterior-law limit theorem: for the conditional Gaussian
posterior-score laws generated by `GaussianOffsetSignalFamily`, both group
admission probabilities tend to one as true skill goes to infinity, so their
difference tends to zero.
-/
theorem paper_lemma2_individual_fairness_gap_tendsto_zero_of_conditional_posterior_laws
    {Feature Group Policy : Type*} [Fintype Feature] [Nonempty Feature]
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianTailLimitAPI)
    {M_A M_B : GaussianOffsetSignalFamily Feature}
    {threshold : ℝ}
    (hgap_eq_threshold :
      ∀ q : ℝ, S.individualFairnessGap P q =
        A.derivativeAPI.api.thresholdPassProb
            (M_A.conditionalPosteriorMeanScaleLaw q) threshold -
          A.derivativeAPI.api.thresholdPassProb
            (M_B.conditionalPosteriorMeanScaleLaw q) threshold) :
    Filter.Tendsto (fun q : ℝ => S.individualFairnessGap P q)
      Filter.atTop (nhds 0) := by
  let precisionA := M_A.centeredFamily.signalPrecisionSum
  let precisionB := M_B.centeredFamily.signalPrecisionSum
  let priorTermA := M_A.centeredFamily.priorPrecision * (threshold - M_A.priorMean)
  let priorTermB := M_B.centeredFamily.priorPrecision * (threshold - M_B.priorMean)
  have hprecisionA_pos : 0 < precisionA := by
    dsimp [precisionA]
    exact M_A.centeredFamily.signalPrecisionSum_pos
  have hprecisionB_pos : 0 < precisionB := by
    dsimp [precisionB]
    exact M_B.centeredFamily.signalPrecisionSum_pos
  have hslopeA_pos : 0 < Real.sqrt precisionA :=
    Real.sqrt_pos.mpr hprecisionA_pos
  have hslopeB_pos : 0 < Real.sqrt precisionB :=
    Real.sqrt_pos.mpr hprecisionB_pos
  apply paper_lemma2_individual_fairness_gap_tendsto_zero_of_affine_tail_formulas
    (A := A)
    (interceptA := (priorTermA + precisionA * threshold) / Real.sqrt precisionA)
    (slopeA := Real.sqrt precisionA)
    (interceptB := (priorTermB + precisionB * threshold) / Real.sqrt precisionB)
    (slopeB := Real.sqrt precisionB)
  · apply paper_lemma2_affine_tail_gap_eq_of_threshold_pass_prob_standardizations
      A.derivativeAPI hgap_eq_threshold
    · intro q
      rw [GaussianOffsetSignalFamily.conditionalPosteriorMeanScaleLaw_standardize_threshold]
      exact paper_lemma2_precision_standardized_eq_affine hprecisionA_pos
    · intro q
      rw [GaussianOffsetSignalFamily.conditionalPosteriorMeanScaleLaw_standardize_threshold]
      exact paper_lemma2_precision_standardized_eq_affine hprecisionB_pos
  · exact hslopeA_pos
  · exact hslopeB_pos

/--
Paper Lemma 2 over conditional Gaussian posterior-score laws: under unequal
precision and the displayed `q_e`, the individual-fairness gap is strictly
decreasing for `q > q_e` and tends to zero as `q -> ∞`.
-/
theorem paper_lemma2_conditional_posterior_laws
    {Feature Group Policy : Type*} [Fintype Feature] [Nonempty Feature]
    {S : GLM20SourcePolicySurface Group Policy} {P : Policy}
    (A : StandardGaussianAnalyticAPI)
    {M_A M_B : GaussianOffsetSignalFamily Feature}
    {priorTerm threshold q_e : ℝ}
    (hgap_eq_threshold :
      ∀ q : ℝ, S.individualFairnessGap P q =
        A.logAPI.derivativeAPI.api.thresholdPassProb
            (M_A.conditionalPosteriorMeanScaleLaw q) threshold -
          A.logAPI.derivativeAPI.api.thresholdPassProb
            (M_B.conditionalPosteriorMeanScaleLaw q) threshold)
    (hpriorTermA :
      M_A.centeredFamily.priorPrecision * (threshold - M_A.priorMean) =
        priorTerm)
    (hpriorTermB :
      M_B.centeredFamily.priorPrecision * (threshold - M_B.priorMean) =
        priorTerm)
    (hqe :
      q_e =
        threshold +
          Real.sqrt
            ((Real.log M_A.centeredFamily.signalPrecisionSum -
                Real.log M_B.centeredFamily.signalPrecisionSum) /
                (M_A.centeredFamily.signalPrecisionSum -
                  M_B.centeredFamily.signalPrecisionSum) +
              priorTerm ^ 2 /
                (M_A.centeredFamily.signalPrecisionSum *
                  M_B.centeredFamily.signalPrecisionSum)))
    (hprecision_gap :
      M_B.centeredFamily.signalPrecisionSum <
        M_A.centeredFamily.signalPrecisionSum) :
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) ∧
      Filter.Tendsto (fun q : ℝ => S.individualFairnessGap P q)
        Filter.atTop (nhds 0) := by
  constructor
  · exact
      paper_lemma2_individual_fairness_gap_strictAntiOn_of_qe_conditional_posterior_laws
        A.logAPI hgap_eq_threshold hpriorTermA hpriorTermB hqe hprecision_gap
  · exact
      paper_lemma2_individual_fairness_gap_tendsto_zero_of_conditional_posterior_laws
        A.tailLimitAPI hgap_eq_threshold

/--
Lemma 2 canonical source surface.

The source paper's individual-fairness gap for the single-school subpolicy
`P_S` is the difference between the group-A and group-B admission probabilities
at true skill `q`.  In the Gaussian conditional-posterior model, those
probabilities are upper tails of the posterior-score laws
`M_A.conditionalPosteriorMeanScaleLaw q` and
`M_B.conditionalPosteriorMeanScaleLaw q` at the common threshold.

All fields not used by Lemma 2 are neutral; the used `individualFairnessGap`
field unfolds directly to the displayed paper quantity.
-/
def lemma2ConditionalPosteriorSourceSurface
    (api : StandardGaussianCDFAPI)
    {Group Policy Feature : Type*} [Fintype Feature] [Nonempty Feature]
    [DecidableEq Policy]
    (Psource : Policy) (M_A M_B : GaussianOffsetSignalFamily Feature)
    (threshold populationShareB capacity : ℝ) :
    GLM20SourcePolicySurface Group Policy where
  populationShareB := populationShareB
  capacity := capacity
  precision := fun _ _ => 0
  accessLevel := fun _ => 1
  estimatedSkillMean := fun _ _ => 0
  estimatedSkillVariance := fun _ _ => 0
  admissionThreshold := fun P => if P = Psource then threshold else 0
  diversity := fun _ => 0
  individualFairnessGap := fun P q =>
    if P = Psource then
      api.thresholdPassProb (M_A.conditionalPosteriorMeanScaleLaw q) threshold -
        api.thresholdPassProb (M_B.conditionalPosteriorMeanScaleLaw q) threshold
    else
      0
  academicMerit := fun _ _ => 0

/--
Paper Lemma 2, canonical source-surface endpoint.

Paper statement: for subpolicy `P_S`, the individual-fairness gap
`I(q; P_S)` is eventually decreasing in true skill.  More precisely, for

`q > q_e = t + sqrt((log s_A - log s_B)/(s_A - s_B)
  + priorTerm^2/(s_A*s_B))`

with `s_B < s_A`, the gap strictly decreases, and `I(q; P_S) -> 0` as
`q -> ∞`.

The Lean endpoint instantiates the source metric surface with conditional
Gaussian posterior-score laws, so the displayed individual-fairness-gap formula
is no longer an external premise.
-/
theorem paper_lemma2_conditional_posterior_laws_source_surface
    {Feature Group Policy : Type*} [Fintype Feature] [Nonempty Feature]
    [DecidableEq Policy]
    (A : StandardGaussianAnalyticAPI)
    {P : Policy} {M_A M_B : GaussianOffsetSignalFamily Feature}
    {priorTerm threshold q_e populationShareB capacity : ℝ}
    (hpriorTermA :
      M_A.centeredFamily.priorPrecision * (threshold - M_A.priorMean) =
        priorTerm)
    (hpriorTermB :
      M_B.centeredFamily.priorPrecision * (threshold - M_B.priorMean) =
        priorTerm)
    (hqe :
      q_e =
        threshold +
          Real.sqrt
            ((Real.log M_A.centeredFamily.signalPrecisionSum -
                Real.log M_B.centeredFamily.signalPrecisionSum) /
                (M_A.centeredFamily.signalPrecisionSum -
                  M_B.centeredFamily.signalPrecisionSum) +
              priorTerm ^ 2 /
                (M_A.centeredFamily.signalPrecisionSum *
                  M_B.centeredFamily.signalPrecisionSum)))
    (hprecision_gap :
      M_B.centeredFamily.signalPrecisionSum <
        M_A.centeredFamily.signalPrecisionSum) :
    let S : GLM20SourcePolicySurface Group Policy :=
      lemma2ConditionalPosteriorSourceSurface
        (Group := Group) (Policy := Policy) (Feature := Feature)
        A.logAPI.derivativeAPI.api P M_A M_B threshold populationShareB capacity
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) ∧
      Filter.Tendsto (fun q : ℝ => S.individualFairnessGap P q)
        Filter.atTop (nhds 0) := by
  dsimp only
  exact
    paper_lemma2_conditional_posterior_laws
      (Feature := Feature) (Group := Group) (Policy := Policy)
      (S :=
        lemma2ConditionalPosteriorSourceSurface
          (Group := Group) (Policy := Policy) (Feature := Feature)
          A.logAPI.derivativeAPI.api P M_A M_B threshold populationShareB capacity)
      (P := P) A
      (by
        intro q
        simp [lemma2ConditionalPosteriorSourceSurface])
      hpriorTermA hpriorTermB hqe hprecision_gap

/--
Paper Lemma 2, canonical source-surface endpoint for the concrete
mathlib-backed standard normal.

This specializes `paper_lemma2_conditional_posterior_laws_source_surface` with
`standardGaussianAnalyticAPI`, so the derivative of the CDF, positive density,
doubled-log density identity, and left-tail CDF limit are all supplied by the
shared Gaussian library rather than by paper-local assumptions.
-/
theorem paper_lemma2_conditional_posterior_laws_source_surface_standardGaussian
    {Feature Group Policy : Type*} [Fintype Feature] [Nonempty Feature]
    [DecidableEq Policy]
    {P : Policy} {M_A M_B : GaussianOffsetSignalFamily Feature}
    {priorTerm threshold q_e populationShareB capacity : ℝ}
    (hpriorTermA :
      M_A.centeredFamily.priorPrecision * (threshold - M_A.priorMean) =
        priorTerm)
    (hpriorTermB :
      M_B.centeredFamily.priorPrecision * (threshold - M_B.priorMean) =
        priorTerm)
    (hqe :
      q_e =
        threshold +
          Real.sqrt
            ((Real.log M_A.centeredFamily.signalPrecisionSum -
                Real.log M_B.centeredFamily.signalPrecisionSum) /
                (M_A.centeredFamily.signalPrecisionSum -
                  M_B.centeredFamily.signalPrecisionSum) +
              priorTerm ^ 2 /
                (M_A.centeredFamily.signalPrecisionSum *
                  M_B.centeredFamily.signalPrecisionSum)))
    (hprecision_gap :
      M_B.centeredFamily.signalPrecisionSum <
        M_A.centeredFamily.signalPrecisionSum) :
    let S : GLM20SourcePolicySurface Group Policy :=
      lemma2ConditionalPosteriorSourceSurface
        (Group := Group) (Policy := Policy) (Feature := Feature)
        standardGaussianCDFAPI P M_A M_B threshold populationShareB capacity
    StrictAntiOn (fun q : ℝ => S.individualFairnessGap P q) (Set.Ioi q_e) ∧
      Filter.Tendsto (fun q : ℝ => S.individualFairnessGap P q)
        Filter.atTop (nhds 0) :=
    paper_lemma2_conditional_posterior_laws_source_surface
      (Feature := Feature) (Group := Group) (Policy := Policy)
      standardGaussianAnalyticAPI
      hpriorTermA hpriorTermB hqe hprecision_gap

/--
Theorem 2(i) displayed algebra: Equation (4), the comparison of the
relative informativeness ratios before and after dropping the test, is
equivalent to Equation (3), the displayed test-precision ratio.

Here `priorPrecision = σ^{-2}`, `subA` and `subB` are
`∑_{k∈SUB} σ_{Ak}^{-2}` and `∑_{k∈SUB} σ_{Bk}^{-2}`, while `testA` and
`testB` are the dropped feature precisions `σ_{AK}^{-2}` and
`σ_{BK}^{-2}`.
-/
theorem paper_theorem2_diversity_ratio_condition_iff_test_precision_ratio
    {priorPrecision subA subB testA testB : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsubA_pos : 0 < subA) (hsubB_pos : 0 < subB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB) :
    (subA / (priorPrecision + subA)) /
          (subB / (priorPrecision + subB)) <
        ((subA + testA) / (priorPrecision + subA + testA)) /
          ((subB + testB) / (priorPrecision + subB + testB)) ↔
      (subA * (priorPrecision + subA + testA)) /
          (subB * (priorPrecision + subB + testB)) <
        testA / testB := by
  have hpa_pos : 0 < priorPrecision + subA := by linarith
  have hpb_pos : 0 < priorPrecision + subB := by linarith
  have hpaf_pos : 0 < priorPrecision + subA + testA := by linarith
  have hpbf_pos : 0 < priorPrecision + subB + testB := by linarith
  have hleft_den_pos : 0 < subB / (priorPrecision + subB) :=
    div_pos hsubB_pos hpb_pos
  have hright_den_pos :
      0 < (subB + testB) / (priorPrecision + subB + testB) :=
    div_pos (by linarith) hpbf_pos
  constructor
  · intro h
    have hcleared :
        subA * (subB + testB) *
            (priorPrecision + subA + testA) *
            (priorPrecision + subB) <
          (subA + testA) * subB *
            (priorPrecision + subA) *
            (priorPrecision + subB + testB) := by
      field_simp [hpa_pos.ne', hpb_pos.ne', hpaf_pos.ne', hpbf_pos.ne',
        hsubB_pos.ne', (ne_of_gt (by linarith : 0 < subB + testB)),
        hleft_den_pos.ne', hright_den_pos.ne'] at h
      nlinarith
    have hmain :
        subA * testB * (priorPrecision + subA + testA) <
          testA * subB * (priorPrecision + subB + testB) := by
      nlinarith [hcleared, hprior_pos]
    rw [div_lt_div_iff₀ (mul_pos hsubB_pos hpbf_pos) htestB_pos]
    simpa [mul_comm, mul_left_comm, mul_assoc] using hmain
  · intro h
    have hmain :
        subA * testB * (priorPrecision + subA + testA) <
          testA * subB * (priorPrecision + subB + testB) := by
      rw [div_lt_div_iff₀ (mul_pos hsubB_pos hpbf_pos) htestB_pos] at h
      simpa [mul_comm, mul_left_comm, mul_assoc] using h
    have hcleared :
        subA * (subB + testB) *
            (priorPrecision + subA + testA) *
            (priorPrecision + subB) <
          (subA + testA) * subB *
            (priorPrecision + subA) *
            (priorPrecision + subB + testB) := by
      nlinarith [hmain, hprior_pos]
    field_simp [hpa_pos.ne', hpb_pos.ne', hpaf_pos.ne', hpbf_pos.ne',
      hsubB_pos.ne', (ne_of_gt (by linarith : 0 < subB + testB)),
      hleft_den_pos.ne', hright_den_pos.ne']
    nlinarith

/--
Theorem 2(i) CDF/threshold support: in the closed-form no-barrier threshold
formula, diversity improvement is equivalent to the source's relative
informativeness comparison.  The argument is exactly the monotonicity chain in
the paper: upper tails reverse the CDF comparison, `Φ` is strictly increasing,
the quantile multiplier is positive, and square root is strictly increasing.
-/
theorem paper_theorem2_diversity_tail_formula_gt_iff_ratio_lt
    (api : StandardGaussianCDFAPI)
    {diversitySub diversityFull quantile leftWeight pi
      ratioSub ratioFull : ℝ}
    (hdiversitySub :
      diversitySub =
        1 - api.cdf (quantile * Real.sqrt (leftWeight * ratioSub + pi)))
    (hdiversityFull :
      diversityFull =
        1 - api.cdf (quantile * Real.sqrt (leftWeight * ratioFull + pi)))
    (hquantile_pos : 0 < quantile)
    (hleftWeight_pos : 0 < leftWeight)
    (htermSub_nonneg : 0 ≤ leftWeight * ratioSub + pi)
    (htermFull_nonneg : 0 ≤ leftWeight * ratioFull + pi) :
    diversitySub > diversityFull ↔ ratioSub < ratioFull := by
  constructor
  · intro hdiv
    rw [hdiversitySub, hdiversityFull] at hdiv
    have hcdf :
        api.cdf (quantile * Real.sqrt (leftWeight * ratioSub + pi)) <
          api.cdf (quantile * Real.sqrt (leftWeight * ratioFull + pi)) := by
      linarith
    have harg :
        quantile * Real.sqrt (leftWeight * ratioSub + pi) <
          quantile * Real.sqrt (leftWeight * ratioFull + pi) :=
      api.cdf_strictMono.lt_iff_lt.mp hcdf
    have hsqrt :
        Real.sqrt (leftWeight * ratioSub + pi) <
          Real.sqrt (leftWeight * ratioFull + pi) :=
      by nlinarith
    have hterm :
        leftWeight * ratioSub + pi < leftWeight * ratioFull + pi :=
      (Real.sqrt_lt_sqrt_iff htermSub_nonneg).mp hsqrt
    nlinarith
  · intro hratio
    rw [hdiversitySub, hdiversityFull]
    have hterm :
        leftWeight * ratioSub + pi < leftWeight * ratioFull + pi := by
      nlinarith
    have hsqrt :
        Real.sqrt (leftWeight * ratioSub + pi) <
          Real.sqrt (leftWeight * ratioFull + pi) :=
      (Real.sqrt_lt_sqrt_iff htermSub_nonneg).mpr hterm
    have harg :
        quantile * Real.sqrt (leftWeight * ratioSub + pi) <
          quantile * Real.sqrt (leftWeight * ratioFull + pi) :=
      mul_lt_mul_of_pos_left hsqrt hquantile_pos
    have hcdf :
        api.cdf (quantile * Real.sqrt (leftWeight * ratioSub + pi)) <
          api.cdf (quantile * Real.sqrt (leftWeight * ratioFull + pi)) :=
      api.cdf_strictMono harg
    linarith

/--
Theorem 2(i) source-surface wrapper: once the CDF/threshold derivation has
identified diversity improvement with Equation (4)'s relative-informativeness
comparison, the paper's displayed Equation (3) is exactly equivalent to
diversity improvement.
-/
theorem paper_theorem2_diversity_improves_iff_test_precision_ratio
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {Psub Pfull : Policy}
    {priorPrecision subA subB testA testB : ℝ}
    (hdiversity_ratio :
      S.diversity Psub > S.diversity Pfull ↔
        (subA / (priorPrecision + subA)) /
            (subB / (priorPrecision + subB)) <
          ((subA + testA) / (priorPrecision + subA + testA)) /
            ((subB + testB) / (priorPrecision + subB + testB)))
    (hprior_pos : 0 < priorPrecision)
    (hsubA_pos : 0 < subA) (hsubB_pos : 0 < subB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB) :
    S.diversity Psub > S.diversity Pfull ↔
      (subA * (priorPrecision + subA + testA)) /
          (subB * (priorPrecision + subB + testB)) <
        testA / testB := by
  rw [hdiversity_ratio]
  exact paper_theorem2_diversity_ratio_condition_iff_test_precision_ratio
    hprior_pos hsubA_pos hsubB_pos htestA_pos htestB_pos

/--
Theorem 2(i) source-formula wrapper: if the paper's closed-form Gaussian tail
formula is supplied for `P_sub` and `P_full`, then diversity improvement is
equivalent to the displayed test-precision ratio condition.

This combines the CDF monotonicity argument with the algebraic equivalence
between the relative-informativeness comparison and Equation (3).
-/
theorem paper_theorem2_diversity_tail_formula_improves_iff_test_precision_ratio
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {Psub Pfull : Policy}
    {quantile leftWeight pi priorPrecision subA subB testA testB : ℝ}
    (hdiversitySub :
      S.diversity Psub =
        1 - api.cdf
          (quantile * Real.sqrt
            (leftWeight *
                ((subA / (priorPrecision + subA)) /
                  (subB / (priorPrecision + subB))) +
              pi)))
    (hdiversityFull :
      S.diversity Pfull =
        1 - api.cdf
          (quantile * Real.sqrt
            (leftWeight *
                (((subA + testA) /
                    (priorPrecision + subA + testA)) /
                  ((subB + testB) /
                    (priorPrecision + subB + testB))) +
              pi)))
    (hquantile_pos : 0 < quantile)
    (hleftWeight_pos : 0 < leftWeight)
    (htermSub_nonneg :
      0 ≤
        leftWeight *
            ((subA / (priorPrecision + subA)) /
              (subB / (priorPrecision + subB))) +
          pi)
    (htermFull_nonneg :
      0 ≤
        leftWeight *
            (((subA + testA) /
                (priorPrecision + subA + testA)) /
              ((subB + testB) /
                (priorPrecision + subB + testB))) +
          pi)
    (hprior_pos : 0 < priorPrecision)
    (hsubA_pos : 0 < subA) (hsubB_pos : 0 < subB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB) :
    S.diversity Psub > S.diversity Pfull ↔
      (subA * (priorPrecision + subA + testA)) /
          (subB * (priorPrecision + subB + testB)) <
        testA / testB := by
  rw [paper_theorem2_diversity_tail_formula_gt_iff_ratio_lt
    api hdiversitySub hdiversityFull hquantile_pos hleftWeight_pos
    htermSub_nonneg htermFull_nonneg]
  exact paper_theorem2_diversity_ratio_condition_iff_test_precision_ratio
    hprior_pos hsubA_pos hsubB_pos htestA_pos htestB_pos

/--
Theorem 2 / Lemma D.10 threshold support: in the no-barrier comparison, if
both groups' posterior-score laws have the same means under `P_sub` and
`P_full`, the `P_full` score laws have strictly larger scales, and the common
capacity is selective, then the admission threshold is strictly higher under
`P_full` than under `P_sub`.
-/
theorem paper_theorem2_admission_threshold_full_gt_sub_of_scale_increases
    (api : StandardGaussianCDFAPI)
    {pi capacity thresholdSub thresholdFull : ℝ}
    {L_A_sub L_A_full L_B_sub L_B_full : GaussianScaleLaw}
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1)
    (hmean_sub : L_A_sub.mean = L_B_sub.mean)
    (hmean_A : L_A_sub.mean = L_A_full.mean)
    (hmean_B : L_B_sub.mean = L_B_full.mean)
    (hscale_A : L_A_sub.scale < L_A_full.scale)
    (hscale_B : L_B_sub.scale < L_B_full.scale)
    (hcapacity_sub :
      capacity =
        (1 - pi) * api.thresholdPassProb L_A_sub thresholdSub +
          pi * api.thresholdPassProb L_B_sub thresholdSub)
    (hcapacity_full :
      capacity =
        (1 - pi) * api.thresholdPassProb L_A_full thresholdFull +
          pi * api.thresholdPassProb L_B_full thresholdFull)
    (hcapacity_lt_half : capacity < (1 / 2 : ℝ)) :
    thresholdSub < thresholdFull := by
  have hleft_weight_pos : 0 < 1 - pi := by
    linarith
  have hthreshold_B_sub : L_B_sub.mean < thresholdSub :=
    paper_proposition1_threshold_gt_common_mean_of_capacity_lt_half
      api hpi_pos.le hpi_lt_one.le hmean_sub hcapacity_sub
      hcapacity_lt_half
  have hthreshold_A_sub : L_A_sub.mean < thresholdSub := by
    rw [hmean_sub]
    exact hthreshold_B_sub
  have htail_A :
      api.thresholdPassProb L_A_sub thresholdSub <
        api.thresholdPassProb L_A_full thresholdSub :=
    api.thresholdPassProb_lt_of_same_mean_scale_lt_of_mean_lt
      hmean_A hscale_A hthreshold_A_sub
  have htail_B :
      api.thresholdPassProb L_B_sub thresholdSub <
        api.thresholdPassProb L_B_full thresholdSub :=
    api.thresholdPassProb_lt_of_same_mean_scale_lt_of_mean_lt
      hmean_B hscale_B hthreshold_B_sub
  have hfull_at_sub_gt_capacity :
      capacity <
        (1 - pi) * api.thresholdPassProb L_A_full thresholdSub +
          pi * api.thresholdPassProb L_B_full thresholdSub := by
    rw [hcapacity_sub]
    exact add_lt_add
      (mul_lt_mul_of_pos_left htail_A hleft_weight_pos)
      (mul_lt_mul_of_pos_left htail_B hpi_pos)
  by_contra hnot
  have hthresholdFull_le_sub : thresholdFull ≤ thresholdSub :=
    le_of_not_gt hnot
  have htail_A_mono :
      api.thresholdPassProb L_A_full thresholdSub ≤
        api.thresholdPassProb L_A_full thresholdFull :=
    api.thresholdPassProb_antitone_threshold L_A_full hthresholdFull_le_sub
  have htail_B_mono :
      api.thresholdPassProb L_B_full thresholdSub ≤
        api.thresholdPassProb L_B_full thresholdFull :=
    api.thresholdPassProb_antitone_threshold L_B_full hthresholdFull_le_sub
  have hfull_at_sub_le_capacity :
      (1 - pi) * api.thresholdPassProb L_A_full thresholdSub +
          pi * api.thresholdPassProb L_B_full thresholdSub ≤
        capacity := by
    rw [hcapacity_full]
    exact add_le_add
      (mul_le_mul_of_nonneg_left htail_A_mono hleft_weight_pos.le)
      (mul_le_mul_of_nonneg_left htail_B_mono hpi_pos.le)
  linarith

/--
Theorem 2(iii) Gaussian tail-mean support: if dropping the test lowers the
Gaussian score scale and the test-free threshold is weakly below the full
threshold, then the admitted upper-tail mean is strictly higher under the full
policy.
-/
theorem paper_theorem2_upper_tail_mean_full_gt_sub_of_scale_and_threshold
    (C : GaussianHazardCertificate)
    {Lsub Lfull : GaussianScaleLaw}
    {thresholdSub thresholdFull : ℝ}
    (hmean : Lsub.mean = Lfull.mean)
    (hscale : Lsub.scale < Lfull.scale)
    (hthreshold_mean : Lsub.mean < thresholdSub)
    (hthreshold : thresholdSub ≤ thresholdFull) :
    C.normalUpperTailMean Lsub thresholdSub <
      C.normalUpperTailMean Lfull thresholdFull := by
  have hscale_step :
      C.normalUpperTailMean Lsub thresholdSub <
        C.normalUpperTailMean Lfull thresholdSub :=
    C.normalUpperTailMean_lt_of_same_mean_scale_lt_above_mean
      hmean hscale hthreshold_mean
  have hthreshold_step :
      C.normalUpperTailMean Lfull thresholdSub ≤
        C.normalUpperTailMean Lfull thresholdFull :=
    C.normalUpperTailMean_mono_threshold Lfull hthreshold
  exact lt_of_lt_of_le hscale_step hthreshold_step

/--
Theorem 2(iii) source-surface support: once a group's academic merit under
`P_sub` and `P_full` is identified with the corresponding Gaussian upper-tail
means, the no-barrier scale and threshold comparisons imply that academic
merit is strictly higher under `P_full`.
-/
theorem paper_theorem2_group_academic_merit_full_gt_sub_of_tail_mean
    (C : GaussianHazardCertificate)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} (group : Group)
    {Psub Pfull : Policy}
    {Lsub Lfull : GaussianScaleLaw}
    {thresholdSub thresholdFull : ℝ}
    (hmean : Lsub.mean = Lfull.mean)
    (hscale : Lsub.scale < Lfull.scale)
    (hthreshold_mean : Lsub.mean < thresholdSub)
    (hthreshold : thresholdSub ≤ thresholdFull)
    (hmeritSub :
      S.academicMerit group Psub = C.normalUpperTailMean Lsub thresholdSub)
    (hmeritFull :
      S.academicMerit group Pfull = C.normalUpperTailMean Lfull thresholdFull) :
    S.academicMerit group Psub < S.academicMerit group Pfull := by
  rw [hmeritSub, hmeritFull]
  exact
    paper_theorem2_upper_tail_mean_full_gt_sub_of_scale_and_threshold
      C hmean hscale hthreshold_mean hthreshold

/--
Proposition 5 fixed-pool merit support from Theorem 2.

This is the strategic-surface version of Theorem 2(iii): once the admitted
academic merits under a drop-test policy pair and a keep-test policy pair are
identified with the corresponding Gaussian upper-tail means, the no-barrier
scale and threshold comparisons imply that the keep-test pair has strictly
higher group admitted merit.
-/
theorem paper_proposition5_fixed_pool_group_merit_lt_of_theorem2_tail_mean
    (C : GaussianHazardCertificate)
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (group : Group)
    {Pdrop1 Pdrop2 Pkeep1 Pkeep2 : Policy}
    {Ldrop Lkeep : GaussianScaleLaw}
    {thresholdDrop thresholdKeep : ℝ}
    (hmean : Ldrop.mean = Lkeep.mean)
    (hscale : Ldrop.scale < Lkeep.scale)
    (hthreshold_mean : Ldrop.mean < thresholdDrop)
    (hthreshold : thresholdDrop ≤ thresholdKeep)
    (hmeritDrop :
      S.admittedAcademicMerit J group (policyPair Pdrop1 Pdrop2) =
        C.normalUpperTailMean Ldrop thresholdDrop)
    (hmeritKeep :
      S.admittedAcademicMerit J group (policyPair Pkeep1 Pkeep2) =
        C.normalUpperTailMean Lkeep thresholdKeep) :
    S.admittedAcademicMerit J group (policyPair Pdrop1 Pdrop2) <
      S.admittedAcademicMerit J group (policyPair Pkeep1 Pkeep2) := by
  rw [hmeritDrop, hmeritKeep]
  exact
    paper_theorem2_upper_tail_mean_full_gt_sub_of_scale_and_threshold
      C hmean hscale hthreshold_mean hthreshold

/--
Proposition 5 fixed-pool branch support from Theorem 2, with the branch
premises threaded through the displayed merit identities.
-/
theorem
    paper_proposition5_fixed_pool_group_merit_lt_of_theorem2_tail_mean_branch
    (C : GaussianHazardCertificate)
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (J : School) (groupA groupB group : Group)
    {Pdrop1 Pdrop2 Pkeep1 Pkeep2 : Policy}
    {q : ℝ} {cutoff : Group → ℝ}
    {Ldrop Lkeep : GaussianScaleLaw}
    {thresholdDrop thresholdKeep : ℝ}
    (hmean : Ldrop.mean = Lkeep.mean)
    (hscale : Ldrop.scale < Lkeep.scale)
    (hthreshold_mean : Ldrop.mean < thresholdDrop)
    (hthreshold : thresholdDrop ≤ thresholdKeep)
    (hmeritDrop :
      ¬ q < cutoff groupA →
        ¬ q < cutoff groupB →
          S.admittedAcademicMerit J group (policyPair Pdrop1 Pdrop2) =
            C.normalUpperTailMean Ldrop thresholdDrop)
    (hmeritKeep :
      ¬ q < cutoff groupA →
        ¬ q < cutoff groupB →
          S.admittedAcademicMerit J group (policyPair Pkeep1 Pkeep2) =
            C.normalUpperTailMean Lkeep thresholdKeep) :
    ¬ q < cutoff groupA →
      ¬ q < cutoff groupB →
        S.admittedAcademicMerit J group (policyPair Pdrop1 Pdrop2) <
          S.admittedAcademicMerit J group (policyPair Pkeep1 Pkeep2) := by
  intro hnotA hnotB
  exact
    paper_proposition5_fixed_pool_group_merit_lt_of_theorem2_tail_mean
      C S policyPair J group hmean hscale hthreshold_mean hthreshold
      (hmeritDrop hnotA hnotB) (hmeritKeep hnotA hnotB)

/--
Theorem 3 fixed-pool branch comparisons from the Theorem 2 tail-mean data.

This bundles the four fixed-pool comparisons used by Proposition 5: school
`J1` for the `(P_sub,P_full)` branch and school `J2` for the
`(P_full,P_sub)` branch, for both groups.
-/
theorem paper_theorem3_fixed_pool_merit_comparisons_of_theorem2_tail_mean_branches
    (C : GaussianHazardCertificate)
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {q1Sub q2Sub : ℝ} {fullFullCutoff : Group → ℝ}
    (J1DropLaw J1KeepLaw J2DropLaw J2KeepLaw : Group → GaussianScaleLaw)
    (J1DropThreshold J1KeepThreshold J2DropThreshold
      J2KeepThreshold : Group → ℝ)
    (hJ1Mean : ∀ g, (J1DropLaw g).mean = (J1KeepLaw g).mean)
    (hJ1Scale : ∀ g, (J1DropLaw g).scale < (J1KeepLaw g).scale)
    (hJ1ThresholdMean :
      ∀ g, (J1DropLaw g).mean < J1DropThreshold g)
    (hJ1Threshold :
      ∀ g, J1DropThreshold g ≤ J1KeepThreshold g)
    (hJ2Mean : ∀ g, (J2DropLaw g).mean = (J2KeepLaw g).mean)
    (hJ2Scale : ∀ g, (J2DropLaw g).scale < (J2KeepLaw g).scale)
    (hJ2ThresholdMean :
      ∀ g, (J2DropLaw g).mean < J2DropThreshold g)
    (hJ2Threshold :
      ∀ g, J2DropThreshold g ≤ J2KeepThreshold g)
    (hJ1DropMerit :
      ∀ g,
        ¬ q1Sub < fullFullCutoff groupA →
          ¬ q1Sub < fullFullCutoff groupB →
            S.admittedAcademicMerit J1 g (policyPair Psub Pfull) =
              C.normalUpperTailMean (J1DropLaw g) (J1DropThreshold g))
    (hJ1KeepMerit :
      ∀ g,
        ¬ q1Sub < fullFullCutoff groupA →
          ¬ q1Sub < fullFullCutoff groupB →
            S.admittedAcademicMerit J1 g (policyPair Pfull Pfull) =
              C.normalUpperTailMean (J1KeepLaw g) (J1KeepThreshold g))
    (hJ2DropMerit :
      ∀ g,
        ¬ q2Sub < fullFullCutoff groupA →
          ¬ q2Sub < fullFullCutoff groupB →
            S.admittedAcademicMerit J2 g (policyPair Pfull Psub) =
              C.normalUpperTailMean (J2DropLaw g) (J2DropThreshold g))
    (hJ2KeepMerit :
      ∀ g,
        ¬ q2Sub < fullFullCutoff groupA →
          ¬ q2Sub < fullFullCutoff groupB →
            S.admittedAcademicMerit J2 g (policyPair Pfull Pfull) =
              C.normalUpperTailMean (J2KeepLaw g) (J2KeepThreshold g)) :
    (¬ q1Sub < fullFullCutoff groupA →
      ¬ q1Sub < fullFullCutoff groupB →
        S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull) <
          S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull)) ∧
      (¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull) <
            S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull)) ∧
        (¬ q2Sub < fullFullCutoff groupA →
          ¬ q2Sub < fullFullCutoff groupB →
            S.admittedAcademicMerit J2 groupA (policyPair Pfull Psub) <
              S.admittedAcademicMerit J2 groupA (policyPair Pfull Pfull)) ∧
          (¬ q2Sub < fullFullCutoff groupA →
            ¬ q2Sub < fullFullCutoff groupB →
              S.admittedAcademicMerit J2 groupB (policyPair Pfull Psub) <
                S.admittedAcademicMerit J2 groupB
                  (policyPair Pfull Pfull)) := by
  refine ⟨?_, ?_, ?_, ?_⟩
  · exact
      paper_proposition5_fixed_pool_group_merit_lt_of_theorem2_tail_mean_branch
        C S policyPair J1 groupA groupB groupA
        (Pdrop1 := Psub) (Pdrop2 := Pfull) (Pkeep1 := Pfull)
        (Pkeep2 := Pfull) (q := q1Sub) (cutoff := fullFullCutoff)
        (Ldrop := J1DropLaw groupA) (Lkeep := J1KeepLaw groupA)
        (thresholdDrop := J1DropThreshold groupA)
        (thresholdKeep := J1KeepThreshold groupA)
        (hJ1Mean groupA) (hJ1Scale groupA) (hJ1ThresholdMean groupA)
        (hJ1Threshold groupA) (hJ1DropMerit groupA) (hJ1KeepMerit groupA)
  · exact
      paper_proposition5_fixed_pool_group_merit_lt_of_theorem2_tail_mean_branch
        C S policyPair J1 groupA groupB groupB
        (Pdrop1 := Psub) (Pdrop2 := Pfull) (Pkeep1 := Pfull)
        (Pkeep2 := Pfull) (q := q1Sub) (cutoff := fullFullCutoff)
        (Ldrop := J1DropLaw groupB) (Lkeep := J1KeepLaw groupB)
        (thresholdDrop := J1DropThreshold groupB)
        (thresholdKeep := J1KeepThreshold groupB)
        (hJ1Mean groupB) (hJ1Scale groupB) (hJ1ThresholdMean groupB)
        (hJ1Threshold groupB) (hJ1DropMerit groupB) (hJ1KeepMerit groupB)
  · exact
      paper_proposition5_fixed_pool_group_merit_lt_of_theorem2_tail_mean_branch
        C S policyPair J2 groupA groupB groupA
        (Pdrop1 := Pfull) (Pdrop2 := Psub) (Pkeep1 := Pfull)
        (Pkeep2 := Pfull) (q := q2Sub) (cutoff := fullFullCutoff)
        (Ldrop := J2DropLaw groupA) (Lkeep := J2KeepLaw groupA)
        (thresholdDrop := J2DropThreshold groupA)
        (thresholdKeep := J2KeepThreshold groupA)
        (hJ2Mean groupA) (hJ2Scale groupA) (hJ2ThresholdMean groupA)
        (hJ2Threshold groupA) (hJ2DropMerit groupA) (hJ2KeepMerit groupA)
  · exact
      paper_proposition5_fixed_pool_group_merit_lt_of_theorem2_tail_mean_branch
        C S policyPair J2 groupA groupB groupB
        (Pdrop1 := Pfull) (Pdrop2 := Psub) (Pkeep1 := Pfull)
        (Pkeep2 := Pfull) (q := q2Sub) (cutoff := fullFullCutoff)
        (Ldrop := J2DropLaw groupB) (Lkeep := J2KeepLaw groupB)
        (thresholdDrop := J2DropThreshold groupB)
        (thresholdKeep := J2KeepThreshold groupB)
        (hJ2Mean groupB) (hJ2Scale groupB) (hJ2ThresholdMean groupB)
        (hJ2Threshold groupB) (hJ2DropMerit groupB) (hJ2KeepMerit groupB)

/--
Theorem 3 fixed-pool branch comparisons from concrete Gaussian source
families.

This is the source-model version of
`paper_theorem3_fixed_pool_merit_comparisons_of_theorem2_tail_mean_branches`:
the equal-mean and larger-scale premises are discharged from common prior means,
common prior variances, and the paper's strict total-precision increase from
the test-free feature set to the full feature set.
-/
theorem
    paper_theorem3_fixed_pool_merit_comparisons_of_source_families_theorem2_tail_mean_branches
    (C : GaussianHazardCertificate)
    {Group Policy School Equilibrium FeatureDrop FeatureKeep : Type*}
    [Fintype FeatureDrop] [Nonempty FeatureDrop]
    [Fintype FeatureKeep] [Nonempty FeatureKeep]
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {q1Sub q2Sub : ℝ} {fullFullCutoff : Group → ℝ}
    (J1DropFamily J2DropFamily :
      Group → GaussianOffsetSignalFamily FeatureDrop)
    (J1KeepFamily J2KeepFamily :
      Group → GaussianOffsetSignalFamily FeatureKeep)
    (J1DropThreshold J1KeepThreshold J2DropThreshold
      J2KeepThreshold : Group → ℝ)
    (hJ1PriorMean :
      ∀ g, (J1DropFamily g).priorMean = (J1KeepFamily g).priorMean)
    (hJ1PriorVar :
      ∀ g, (J1DropFamily g).priorVar = (J1KeepFamily g).priorVar)
    (hJ1Precision :
      ∀ g,
        (J1DropFamily g).centeredFamily.signalPrecisionSum <
          (J1KeepFamily g).centeredFamily.signalPrecisionSum)
    (hJ1ThresholdMean :
      ∀ g, (J1DropFamily g).priorMean < J1DropThreshold g)
    (hJ1Threshold :
      ∀ g, J1DropThreshold g ≤ J1KeepThreshold g)
    (hJ2PriorMean :
      ∀ g, (J2DropFamily g).priorMean = (J2KeepFamily g).priorMean)
    (hJ2PriorVar :
      ∀ g, (J2DropFamily g).priorVar = (J2KeepFamily g).priorVar)
    (hJ2Precision :
      ∀ g,
        (J2DropFamily g).centeredFamily.signalPrecisionSum <
          (J2KeepFamily g).centeredFamily.signalPrecisionSum)
    (hJ2ThresholdMean :
      ∀ g, (J2DropFamily g).priorMean < J2DropThreshold g)
    (hJ2Threshold :
      ∀ g, J2DropThreshold g ≤ J2KeepThreshold g)
    (hJ1DropMerit :
      ∀ g,
        ¬ q1Sub < fullFullCutoff groupA →
          ¬ q1Sub < fullFullCutoff groupB →
            S.admittedAcademicMerit J1 g (policyPair Psub Pfull) =
              C.normalUpperTailMean
                (J1DropFamily g).posteriorMeanScaleLaw
                (J1DropThreshold g))
    (hJ1KeepMerit :
      ∀ g,
        ¬ q1Sub < fullFullCutoff groupA →
          ¬ q1Sub < fullFullCutoff groupB →
            S.admittedAcademicMerit J1 g (policyPair Pfull Pfull) =
              C.normalUpperTailMean
                (J1KeepFamily g).posteriorMeanScaleLaw
                (J1KeepThreshold g))
    (hJ2DropMerit :
      ∀ g,
        ¬ q2Sub < fullFullCutoff groupA →
          ¬ q2Sub < fullFullCutoff groupB →
            S.admittedAcademicMerit J2 g (policyPair Pfull Psub) =
              C.normalUpperTailMean
                (J2DropFamily g).posteriorMeanScaleLaw
                (J2DropThreshold g))
    (hJ2KeepMerit :
      ∀ g,
        ¬ q2Sub < fullFullCutoff groupA →
          ¬ q2Sub < fullFullCutoff groupB →
            S.admittedAcademicMerit J2 g (policyPair Pfull Pfull) =
              C.normalUpperTailMean
                (J2KeepFamily g).posteriorMeanScaleLaw
                (J2KeepThreshold g)) :
    (¬ q1Sub < fullFullCutoff groupA →
      ¬ q1Sub < fullFullCutoff groupB →
        S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull) <
          S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull)) ∧
      (¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull) <
            S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull)) ∧
        (¬ q2Sub < fullFullCutoff groupA →
          ¬ q2Sub < fullFullCutoff groupB →
            S.admittedAcademicMerit J2 groupA (policyPair Pfull Psub) <
              S.admittedAcademicMerit J2 groupA (policyPair Pfull Pfull)) ∧
          (¬ q2Sub < fullFullCutoff groupA →
            ¬ q2Sub < fullFullCutoff groupB →
              S.admittedAcademicMerit J2 groupB (policyPair Pfull Psub) <
                S.admittedAcademicMerit J2 groupB
                  (policyPair Pfull Pfull)) := by
  refine
    paper_theorem3_fixed_pool_merit_comparisons_of_theorem2_tail_mean_branches
      C S policyPair
      (J1DropLaw := fun g => (J1DropFamily g).posteriorMeanScaleLaw)
      (J1KeepLaw := fun g => (J1KeepFamily g).posteriorMeanScaleLaw)
      (J2DropLaw := fun g => (J2DropFamily g).posteriorMeanScaleLaw)
      (J2KeepLaw := fun g => (J2KeepFamily g).posteriorMeanScaleLaw)
      J1DropThreshold J1KeepThreshold J2DropThreshold J2KeepThreshold
      ?_ ?_ ?_ hJ1Threshold ?_ ?_ ?_ hJ2Threshold
      hJ1DropMerit hJ1KeepMerit hJ2DropMerit hJ2KeepMerit
  · intro g
    simpa [GaussianOffsetSignalFamily.posteriorMeanScaleLaw]
      using hJ1PriorMean g
  · intro g
    exact
      GaussianOffsetSignalFamily.posteriorMeanScaleLaw_scale_lt_of_priorVar_eq_signalPrecisionSum_lt
        (Mlow := J1DropFamily g) (Mhigh := J1KeepFamily g)
        (hJ1PriorVar g) (hJ1Precision g)
  · intro g
    simpa [GaussianOffsetSignalFamily.posteriorMeanScaleLaw]
      using hJ1ThresholdMean g
  · intro g
    simpa [GaussianOffsetSignalFamily.posteriorMeanScaleLaw]
      using hJ2PriorMean g
  · intro g
    exact
      GaussianOffsetSignalFamily.posteriorMeanScaleLaw_scale_lt_of_priorVar_eq_signalPrecisionSum_lt
        (Mlow := J2DropFamily g) (Mhigh := J2KeepFamily g)
        (hJ2PriorVar g) (hJ2Precision g)
  · intro g
    simpa [GaussianOffsetSignalFamily.posteriorMeanScaleLaw]
      using hJ2ThresholdMean g

