      hscale hcost hv1 hdiff_pos hdiff_lt_v1
      hcostRatioLow hcostRatioHigh

/--
Paper Proposition 2 student-region support in the displayed precision
notation.

This expands the projected admission scale in the two-school payoff region to
the same precision expression used in Lemma 3.
-/
theorem paper_proposition2_two_school_application_region_precision_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold school2SubThreshold
      priorPrecision subPrecision testPrecision cost v1 v2 : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioLow : cost / v1 ∈ Set.Ioo (0 : ℝ) 1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ lowCutoff highCutoff : ℝ,
      lowCutoff =
        admissionThreshold -
          glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision *
              Q.quantile (1 - cost / v1) ∧
      highCutoff =
        admissionThreshold -
          glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision *
              Q.quantile (1 - cost / (v1 - v2)) ∧
      lowCutoff < highCutoff ∧
      ∀ q : ℝ,
        ((q < school2SubThreshold ∧
            0 ≤ v1 *
              Q.cdfAPI.thresholdPassProb
                { mean := q
                  scale :=
                    glm20StrategicProjectedScale
                      priorPrecision subPrecision testPrecision
                  scale_pos :=
                    glm20StrategicProjectedScale_pos
                      hprior_pos hsub_pos htest_pos }
                admissionThreshold - cost) ∨
          (school2SubThreshold ≤ q ∧
            0 ≤ (v1 - v2) *
              Q.cdfAPI.thresholdPassProb
                { mean := q
                  scale :=
                    glm20StrategicProjectedScale
                      priorPrecision subPrecision testPrecision
                  scale_pos :=
                    glm20StrategicProjectedScale_pos
                      hprior_pos hsub_pos htest_pos }
                admissionThreshold - cost)) ↔
        ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
          max highCutoff school2SubThreshold ≤ q) := by
  let scale :=
    glm20StrategicProjectedScale priorPrecision subPrecision testPrecision
  have hscale : 0 < scale :=
    glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos
  rcases
    paper_proposition2_two_school_application_region_standardGaussian
      Q (admissionThreshold := admissionThreshold)
      (school2SubThreshold := school2SubThreshold) (scale := scale)
      (cost := cost) (v1 := v1) (v2 := v2)
      hscale hcost hv1 hdiff_pos hdiff_lt_v1
      hcostRatioLow hcostRatioHigh with
    ⟨lowCutoff, highCutoff, hlow, hhigh, hlt, hregion⟩
  refine ⟨lowCutoff, highCutoff, ?_, ?_, hlt, ?_⟩
  · simpa [scale, glm20StrategicApplyCutoff] using hlow
  · simpa [scale, glm20StrategicApplyCutoff] using hhigh
  · exact hregion

/--
Paper Proposition 2 student-region support in displayed precision notation,
with the low cost-ratio domain derived from the high cost-ratio domain.
-/
theorem paper_proposition2_two_school_application_region_precision_standardGaussian_of_high_cost_ratio
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold school2SubThreshold
      priorPrecision subPrecision testPrecision cost v1 v2 : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ lowCutoff highCutoff : ℝ,
      lowCutoff =
        admissionThreshold -
          glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision *
              Q.quantile (1 - cost / v1) ∧
      highCutoff =
        admissionThreshold -
          glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision *
              Q.quantile (1 - cost / (v1 - v2)) ∧
      lowCutoff < highCutoff ∧
      ∀ q : ℝ,
