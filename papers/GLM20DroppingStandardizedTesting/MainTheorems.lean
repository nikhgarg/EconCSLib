/--
Proposition 5(i), school-`J1`, threshold construction from explicit
objective-value formulas.

This is the source-facing version of the previous theorem: in each
exactly-one-expanding-group case, it is enough to identify the old objective
with the displayed test-based merit formula and the deviation objective with
the displayed test-free merit formula.  Lean then derives the merit comparison
and constructs the cost threshold.
-/
theorem
    paper_proposition5_part_i_school1_cutoff_objective_iff_exactly_one_cost_case_of_merit_formulas
    {Group Policy : Type*}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost maxCost : Group → ℝ} {q1Sub : ℝ}
    {fullFullCutoff : Group → ℝ}
    (objective1 : Policy → Policy → ℝ)
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g) (Set.Icc (0 : ℝ) (maxCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g) (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowCost : ∀ g, testFreeMerit g < testBasedMerit g 0)
    (hhighCost : ∀ g, testBasedMerit g (maxCost g) < testFreeMerit g)
    (hnone :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ objective1 Pfull Pfull ≤ objective1 Psub Pfull)
    (hboth_impossible :
      q1Sub < fullFullCutoff groupA →
        q1Sub < fullFullCutoff groupB → False)
    (honlyA_testBased :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          objective1 Pfull Pfull =
            testBasedMerit groupA (testCost groupA))
    (honlyA_testFree :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          objective1 Psub Pfull = testFreeMerit groupA)
    (honlyB_testBased :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          objective1 Pfull Pfull =
            testBasedMerit groupB (testCost groupB))
    (honlyB_testFree :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          objective1 Psub Pfull = testFreeMerit groupB) :
    ∃ costThreshold : Group → ℝ,
      (∀ g, costThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, testBasedMerit g (costThreshold g) = testFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (testBasedMerit g c ≤ testFreeMerit g ↔
              costThreshold g ≤ c)) ∧
