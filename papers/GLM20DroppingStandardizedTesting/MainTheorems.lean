        admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
        groupB populationShare feasible1 feasible2).policyPairIsEquilibrium
        P1 P2 ↔
      glm20TwoSchoolBinaryPolicyFeasibleEquilibrium
        (glm20TwoGroupWeightedAcademicMeritObjective
          (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
            massTestTaking admittedAcademicMerit diversity policyPair Psub
            Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
          policyPair J1 groupA groupB populationShare)
        (glm20TwoGroupWeightedAcademicMeritObjective
          (glm20FeasibleWeightedAcademicMeritBinaryPolicySurface
            massTestTaking admittedAcademicMerit diversity policyPair Psub
            Pfull J1 J2 groupA groupB populationShare feasible1 feasible2)
          policyPair J2 groupA groupB populationShare)
        feasible1 feasible2 Psub Pfull P1 P2 := by
  rfl

/-- Pair-valued predicate agrees with `policyPairIsEquilibrium` on the feasible surface. -/
theorem glm20FeasibleWeightedAcademicMeritBinaryPolicySurface_equilibriumPredicate_iff
    {Group Policy School : Type*}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull P1 P2 : Policy} {J1 J2 : School}
    {groupA groupB : Group} {populationShare : Group → ℝ}
