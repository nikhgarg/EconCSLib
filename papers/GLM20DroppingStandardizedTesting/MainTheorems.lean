        fullSubHighTestFreeMerit g <
          fullSubHighTestBasedMerit g (fullSubLeftCost g))
    (hhighAtRight :
      ∀ g,
        fullSubHighTestBasedMerit g (fullSubRightCost g) <
          fullSubHighTestFreeMerit g)
    (hhighAtLowRoot :
