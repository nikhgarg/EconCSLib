/--
Theorem 3 / Proposition 5 source-merit regularity package.

The paper's source proof uses three cost-indexed admitted-merit functions:
the equation-(50) sub-full merit formula and the low/high selected
equation-(46) full-sub merit formulas.  This lemma proves the continuity and
strict decrease in cost needed by the theorem-level interval endpoints from
the displayed Gaussian cutoff formulas, so higher wrappers do not have to carry
those regularity assumptions separately.
-/
theorem
    paper_theorem3_source_cost_merit_regularities_of_equation50_and_selected_twoFull
    (Q : StandardGaussianQuantileAPI)
    {Group : Type*}
    {subFullLeftCost subFullRightCost subFullQ2Full subFullScale subFullV2 :
      Group → ℝ}
    {fullSubLeftCost fullSubRightCost : Group → ℝ}
    {lowQ1Full lowQ2Full lowScale lowV1 lowV2 : Group → ℝ}
    {highQ1Full highQ2Full highScale highV1 highV2 : Group → ℝ}
    (subFullMeritOfCutoff : Group → ℝ → ℝ)
    (lowCutoffOfCost highCutoffOfCost : Group → ℝ → ℝ)
    (lowMeritOfCutoff highMeritOfCutoff : Group → ℝ → ℝ)
    (hsubFullLeftRight :
      ∀ g, subFullLeftCost g < subFullRightCost g)
    (hsubFullScale : ∀ g, 0 < subFullScale g)
    (hsubFullLeftPos : ∀ g, 0 < subFullLeftCost g)
    (hsubFullRightLtV2 :
      ∀ g, subFullRightCost g < subFullV2 g)
    (hsubFullMeritCont :
      ∀ g, Continuous (subFullMeritOfCutoff g))
    (hsubFullMeritAnti :
      ∀ g, StrictAnti (subFullMeritOfCutoff g))
    (hlowScale : ∀ g, 0 < lowScale g)
    (hlowV2Pos : ∀ g, 0 < lowV2 g)
    (hlowV2LtV1 : ∀ g, lowV2 g < lowV1 g)
    (hlowZero :
      ∀ g cost, cost ∈
          Set.Icc (fullSubLeftCost g) (fullSubRightCost g) →
        glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          (lowQ1Full g) (lowQ2Full g) (lowScale g) (lowV1 g)
          (lowV2 g) cost (lowCutoffOfCost g cost) = 0)
    (hlowMeritCont : ∀ g, Continuous (lowMeritOfCutoff g))
    (hlowMeritAnti : ∀ g, StrictAnti (lowMeritOfCutoff g))
    (hhighScale : ∀ g, 0 < highScale g)
    (hhighV2Pos : ∀ g, 0 < highV2 g)
    (hhighV2LtV1 : ∀ g, highV2 g < highV1 g)
    (hhighZero :
      ∀ g cost, cost ∈
          Set.Icc (fullSubLeftCost g) (fullSubRightCost g) →
        glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          (highQ1Full g) (highQ2Full g) (highScale g) (highV1 g)
          (highV2 g) cost (highCutoffOfCost g cost) = 0)
    (hhighMeritCont : ∀ g, Continuous (highMeritOfCutoff g))
    (hhighMeritAnti : ∀ g, StrictAnti (highMeritOfCutoff g)) :
    (∀ g,
      ContinuousOn
          (fun cost =>
            subFullMeritOfCutoff g
              (subFullQ2Full g -
                subFullScale g *
                  Q.quantile (1 - cost / subFullV2 g)))
          (Set.Icc (subFullLeftCost g) (subFullRightCost g)) ∧
        StrictAntiOn
          (fun cost =>
            subFullMeritOfCutoff g
              (subFullQ2Full g -
                subFullScale g *
                  Q.quantile (1 - cost / subFullV2 g)))
          (Set.Icc (subFullLeftCost g) (subFullRightCost g))) ∧
      (∀ g,
        ContinuousOn
            (fun cost => lowMeritOfCutoff g (lowCutoffOfCost g cost))
            (Set.Icc (fullSubLeftCost g) (fullSubRightCost g)) ∧
          StrictAntiOn
            (fun cost => lowMeritOfCutoff g (lowCutoffOfCost g cost))
            (Set.Icc (fullSubLeftCost g) (fullSubRightCost g))) ∧
        (∀ g,
          ContinuousOn
              (fun cost =>
                highMeritOfCutoff g (highCutoffOfCost g cost))
              (Set.Icc (fullSubLeftCost g) (fullSubRightCost g)) ∧
            StrictAntiOn
              (fun cost =>
                highMeritOfCutoff g (highCutoffOfCost g cost))
              (Set.Icc (fullSubLeftCost g) (fullSubRightCost g))) := by
  refine ⟨?_, ?_, ?_⟩
  · intro g
    have hsubRegular :=
      paper_proposition5_equation50_subFull_cost_merit_regular_of_global_regular_cost_bounds
        Q (q2Full := subFullQ2Full) (scale := subFullScale)
        (v2 := subFullV2) (left := subFullLeftCost)
        (right := subFullRightCost) (meritOfCutoff := subFullMeritOfCutoff)
        hsubFullLeftRight hsubFullScale hsubFullLeftPos hsubFullRightLtV2
        hsubFullMeritCont hsubFullMeritAnti
    exact ⟨hsubRegular.1 g, hsubRegular.2 g⟩
  · intro g
    exact
      paper_proposition5_twoFull_cost_merit_continuous_strictAntiOn_of_zero_payoff_cutoff
        standardGaussianCDFAPI
        (q1Full := lowQ1Full g) (q2Full := lowQ2Full g)
        (scale := lowScale g) (v1 := lowV1 g) (v2 := lowV2 g)
        (costDomain := Set.Icc (fullSubLeftCost g) (fullSubRightCost g))
        (cutoffDomain := Set.univ)
        (cutoffOfCost := lowCutoffOfCost g)
        (meritOfCutoff := lowMeritOfCutoff g)
        (hlowScale g) (hlowV2Pos g) (hlowV2LtV1 g)
        (by
          intro cost hcost
          exact hlowZero g cost hcost)
        (by intro cost hcost; simp)
        (hlowMeritCont g).continuousOn
        (by
          intro x _hx y _hy hxy
          exact hlowMeritAnti g hxy)
  · intro g
    exact
      paper_proposition5_twoFull_cost_merit_continuous_strictAntiOn_of_zero_payoff_cutoff
        standardGaussianCDFAPI
        (q1Full := highQ1Full g) (q2Full := highQ2Full g)
        (scale := highScale g) (v1 := highV1 g) (v2 := highV2 g)
        (costDomain := Set.Icc (fullSubLeftCost g) (fullSubRightCost g))
        (cutoffDomain := Set.univ)
        (cutoffOfCost := highCutoffOfCost g)
        (meritOfCutoff := highMeritOfCutoff g)
        (hhighScale g) (hhighV2Pos g) (hhighV2LtV1 g)
        (by
          intro cost hcost
          exact hhighZero g cost hcost)
        (by intro cost hcost; simp)
        (hhighMeritCont g).continuousOn
        (by
          intro x _hx y _hy hxy
          exact hhighMeritAnti g hxy)

/--
Theorem 3 / Proposition 5 source-merit regularity package with the
standard-Gaussian equation-(46) full/full cutoffs constructed internally.

This is the theorem-level support lemma to use before invoking the interval
Theorem 3 endpoints: equation (50) gives the sub-full merit regularity, while
equation (46) constructs the low/high full/full zero-payoff cutoffs and proves
the corresponding low/high cost-merit regularity.
-/
theorem
    paper_theorem3_source_cost_merit_regularities_of_equation50_and_standardGaussian_twoFull
    (Q : StandardGaussianQuantileAPI)
    {Group : Type*}
    {subFullLeftCost subFullRightCost subFullQ2Full subFullScale subFullV2 :
      Group → ℝ}
    {fullSubLeftCost fullSubRightCost : Group → ℝ}
    {lowQ1Full lowQ2Full lowScale lowV1 lowV2 : Group → ℝ}
    {highQ1Full highQ2Full highScale highV1 highV2 : Group → ℝ}
    (subFullMeritOfCutoff : Group → ℝ → ℝ)
    (lowMeritOfCutoff highMeritOfCutoff : Group → ℝ → ℝ)
    (hsubFullLeftRight :
      ∀ g, subFullLeftCost g < subFullRightCost g)
    (hsubFullScale : ∀ g, 0 < subFullScale g)
    (hsubFullLeftPos : ∀ g, 0 < subFullLeftCost g)
    (hsubFullRightLtV2 :
      ∀ g, subFullRightCost g < subFullV2 g)
    (hsubFullMeritCont :
      ∀ g, Continuous (subFullMeritOfCutoff g))
    (hsubFullMeritAnti :
      ∀ g, StrictAnti (subFullMeritOfCutoff g))
    (hfullSubLeftRight :
      ∀ g, fullSubLeftCost g < fullSubRightCost g)
    (hfullSubLeftPos : ∀ g, 0 < fullSubLeftCost g)
    (hlowScale : ∀ g, 0 < lowScale g)
    (hlowV2Pos : ∀ g, 0 < lowV2 g)
    (hlowV2LtV1 : ∀ g, lowV2 g < lowV1 g)
    (hlowRightLtV1 : ∀ g, fullSubRightCost g < lowV1 g)
    (hlowMeritCont : ∀ g, Continuous (lowMeritOfCutoff g))
    (hlowMeritAnti : ∀ g, StrictAnti (lowMeritOfCutoff g))
    (hhighScale : ∀ g, 0 < highScale g)
    (hhighV2Pos : ∀ g, 0 < highV2 g)
    (hhighV2LtV1 : ∀ g, highV2 g < highV1 g)
    (hhighRightLtV1 : ∀ g, fullSubRightCost g < highV1 g)
    (hhighMeritCont : ∀ g, Continuous (highMeritOfCutoff g))
    (hhighMeritAnti : ∀ g, StrictAnti (highMeritOfCutoff g)) :
    ∃ lowCutoffOfCost highCutoffOfCost : Group → ℝ → ℝ,
      (∀ g cost, cost ∈
          Set.Icc (fullSubLeftCost g) (fullSubRightCost g) →
        glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
          (lowQ1Full g) (lowQ2Full g) (lowScale g) (lowV1 g)
          (lowV2 g) cost (lowCutoffOfCost g cost) = 0 ∧
          ∀ q : ℝ,
            0 ≤
                glm20StrategicTwoFullPolicyApplyPayoffValue
                  standardGaussianCDFAPI (lowQ1Full g) (lowQ2Full g)
                  (lowScale g) (lowV1 g) (lowV2 g) cost q ↔
              lowCutoffOfCost g cost ≤ q) ∧
        (∀ g cost, cost ∈
            Set.Icc (fullSubLeftCost g) (fullSubRightCost g) →
          glm20StrategicTwoFullPolicyApplyPayoffValue standardGaussianCDFAPI
            (highQ1Full g) (highQ2Full g) (highScale g) (highV1 g)
            (highV2 g) cost (highCutoffOfCost g cost) = 0 ∧
            ∀ q : ℝ,
              0 ≤
                  glm20StrategicTwoFullPolicyApplyPayoffValue
                    standardGaussianCDFAPI (highQ1Full g) (highQ2Full g)
                    (highScale g) (highV1 g) (highV2 g) cost q ↔
                highCutoffOfCost g cost ≤ q) ∧
          (∀ g,
            ContinuousOn
                (fun cost =>
                  subFullMeritOfCutoff g
                    (subFullQ2Full g -
                      subFullScale g *
                        Q.quantile (1 - cost / subFullV2 g)))
                (Set.Icc (subFullLeftCost g) (subFullRightCost g)) ∧
              StrictAntiOn
                (fun cost =>
                  subFullMeritOfCutoff g
                    (subFullQ2Full g -
                      subFullScale g *
                        Q.quantile (1 - cost / subFullV2 g)))
                (Set.Icc (subFullLeftCost g) (subFullRightCost g))) ∧
            (∀ g,
              ContinuousOn
                  (fun cost => lowMeritOfCutoff g
                    (lowCutoffOfCost g cost))
                  (Set.Icc (fullSubLeftCost g) (fullSubRightCost g)) ∧
                StrictAntiOn
                  (fun cost => lowMeritOfCutoff g
                    (lowCutoffOfCost g cost))
                  (Set.Icc (fullSubLeftCost g) (fullSubRightCost g))) ∧
              (∀ g,
                ContinuousOn
                    (fun cost => highMeritOfCutoff g
                      (highCutoffOfCost g cost))
                    (Set.Icc (fullSubLeftCost g) (fullSubRightCost g)) ∧
                  StrictAntiOn
                    (fun cost => highMeritOfCutoff g
                      (highCutoffOfCost g cost))
                    (Set.Icc (fullSubLeftCost g) (fullSubRightCost g))) := by
  classical
  rcases
    paper_proposition5_standardGaussian_twoFull_cost_merit_regular_of_global_regular_cost_bounds
      (q1Full := lowQ1Full) (q2Full := lowQ2Full)
      (scale := lowScale) (v1 := lowV1) (v2 := lowV2)
      (left := fullSubLeftCost) (right := fullSubRightCost)
      (meritOfCutoff := lowMeritOfCutoff)
      hlowScale hlowV2Pos hlowV2LtV1 hfullSubLeftPos hlowRightLtV1
      hlowMeritCont hlowMeritAnti with
    ⟨lowCutoffOfCost, hlowZero, _hlowCutoffCont, _hlowCutoffMono,
      _hlowMeritCont, _hlowMeritAnti⟩
  rcases
    paper_proposition5_standardGaussian_twoFull_cost_merit_regular_of_global_regular_cost_bounds
      (q1Full := highQ1Full) (q2Full := highQ2Full)
      (scale := highScale) (v1 := highV1) (v2 := highV2)
      (left := fullSubLeftCost) (right := fullSubRightCost)
      (meritOfCutoff := highMeritOfCutoff)
      hhighScale hhighV2Pos hhighV2LtV1 hfullSubLeftPos
      hhighRightLtV1 hhighMeritCont hhighMeritAnti with
    ⟨highCutoffOfCost, hhighZero, _hhighCutoffCont,
      _hhighCutoffMono, _hhighMeritCont, _hhighMeritAnti⟩
  have hregular :=
    paper_theorem3_source_cost_merit_regularities_of_equation50_and_selected_twoFull
      Q
      (subFullLeftCost := subFullLeftCost)
      (subFullRightCost := subFullRightCost)
      (subFullQ2Full := subFullQ2Full)
      (subFullScale := subFullScale) (subFullV2 := subFullV2)
      (fullSubLeftCost := fullSubLeftCost)
      (fullSubRightCost := fullSubRightCost)
      (lowQ1Full := lowQ1Full) (lowQ2Full := lowQ2Full)
      (lowScale := lowScale) (lowV1 := lowV1) (lowV2 := lowV2)
      (highQ1Full := highQ1Full) (highQ2Full := highQ2Full)
      (highScale := highScale) (highV1 := highV1)
      (highV2 := highV2) subFullMeritOfCutoff lowCutoffOfCost
      highCutoffOfCost lowMeritOfCutoff highMeritOfCutoff
      hsubFullLeftRight hsubFullScale hsubFullLeftPos
      hsubFullRightLtV2 hsubFullMeritCont hsubFullMeritAnti hlowScale
      hlowV2Pos hlowV2LtV1
      (fun g cost hcost => (hlowZero g cost hcost).1)
      hlowMeritCont hlowMeritAnti hhighScale hhighV2Pos hhighV2LtV1
      (fun g cost hcost => (hhighZero g cost hcost).1)
      hhighMeritCont hhighMeritAnti
  exact ⟨lowCutoffOfCost, highCutoffOfCost, hlowZero, hhighZero,
    hregular.1, hregular.2.1, hregular.2.2⟩

/--
Theorem 3(ii), feasibility-aware cost-threshold endpoint.

This is the full-sub analogue of the feasibility-aware Theorem 3(i) endpoint:
the Proposition 5(ii) merit-crossing proof supplies the paper thresholds and
the objective-pair condition, while the feasible weighted binary surface
translates that condition into the actual `(P_full,P_sub)` equilibrium.
-/
theorem
    paper_theorem3_fullSub_condition_of_feasible_weighted_surface_merit_crossings_capacity_fixed_pool_and_weighted_group_merit_formulas
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff fullSubCutoff : Group → ℝ}
    {feasible1 feasible2 : Policy → Policy → Prop}
    (hS :
      S =
        glm20FeasibleWeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2 groupA
          groupB populationShare feasible1 feasible2)
    (hfeasible1FullSub : feasible1 Pfull Psub)
    (hfeasible2FullSub : feasible2 Pfull Psub)
    (hfeasible1SubSub : feasible1 Psub Psub)
    (hfeasible2FullFull : feasible2 Pfull Pfull)
    (lowTestBasedMerit : Group → ℝ → ℝ)
    (lowTestFreeMerit : Group → ℝ)
    (highTestBasedMerit : Group → ℝ → ℝ)
    (highTestFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hlowCont :
      ∀ g, ContinuousOn (lowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAnti :
      ∀ g, StrictAntiOn (lowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAtZero : ∀ g, lowTestFreeMerit g < lowTestBasedMerit g 0)
    (hlowAtMax :
      ∀ g, lowTestBasedMerit g (maxCost g) < lowTestFreeMerit g)
    (hhighCont :
      ∀ g, ContinuousOn (highTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAnti :
      ∀ g, StrictAntiOn (highTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAtZero : ∀ g, highTestFreeMerit g < highTestBasedMerit g 0)
    (hhighAtMax :
      ∀ g, highTestBasedMerit g (maxCost g) < highTestFreeMerit g)
    (hhighAtLowRoot :
      ∀ g c, c ∈ Set.Ioo (0 : ℝ) (maxCost g) →
        lowTestBasedMerit g c = lowTestFreeMerit g →
          highTestFreeMerit g < highTestBasedMerit g c)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hmassFullSubA :
      S.massTestTaking groupA (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullSubCutoff groupA))
    (hmassFullSubB :
      S.massTestTaking groupB (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullSubCutoff groupB))
    (hcapacity2 :
      capacity2 =
        populationShare groupA *
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
              q2Sub +
          populationShare groupB *
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
              q2Sub)
    (hfillFullFull2 :
      capacity2 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hfixedPoolMeritA :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupA (policyPair Pfull Psub) <
            S.admittedAcademicMerit J2 groupA (policyPair Pfull Pfull))
    (hfixedPoolMeritB :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupB (policyPair Pfull Psub) <
            S.admittedAcademicMerit J2 groupB (policyPair Pfull Pfull))
    (honlyA_J2_groupB_eq :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupB (policyPair Pfull Pfull) =
            S.admittedAcademicMerit J2 groupB (policyPair Pfull Psub))
    (honlyA_J2_groupA_testBased :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupA (policyPair Pfull Pfull) =
            lowTestBasedMerit groupA (testCost groupA))
    (honlyA_J2_groupA_testFree :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupA (policyPair Pfull Psub) =
            lowTestFreeMerit groupA)
    (honlyB_J2_groupA_eq :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J2 groupA (policyPair Pfull Pfull) =
            S.admittedAcademicMerit J2 groupA (policyPair Pfull Psub))
    (honlyB_J2_groupB_testBased :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J2 groupB (policyPair Pfull Pfull) =
            lowTestBasedMerit groupB (testCost groupB))
    (honlyB_J2_groupB_testFree :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          S.admittedAcademicMerit J2 groupB (policyPair Pfull Psub) =
            lowTestFreeMerit groupB)
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        glm20TwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
