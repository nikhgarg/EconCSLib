  let costThreshold : Group → ℝ := fun g => Classical.choose (hthreshold g)
  have hspec :
      ∀ g,
        costThreshold g ∈ Set.Ioo (leftCost g) (rightCost g) ∧
          testBasedMerit g (costThreshold g) = testFreeMerit g ∧
            (∀ c ∈ Set.Icc (leftCost g) (rightCost g),
              testFreeMerit g < testBasedMerit g c ↔
                c < costThreshold g) ∧
              (∀ c ∈ Set.Icc (leftCost g) (rightCost g),
                testBasedMerit g c < testFreeMerit g ↔
                  costThreshold g < c) ∧
                (∀ c ∈ Set.Icc (leftCost g) (rightCost g),
                  testFreeMerit g ≤ testBasedMerit g c ↔
                    c ≤ costThreshold g) ∧
                  (∀ c ∈ Set.Icc (leftCost g) (rightCost g),
                    testBasedMerit g c ≤ testFreeMerit g ↔
