      (populationShare := populationShare) (testCost := testCost)
      (maxCost := maxCost) (capacity1 := capacity1)
      (capacity2 := capacity2) (q1Sub := q1Sub) (q2Sub := q2Sub) api
      subEstimateLaw (fullFullCutoff := fullFullCutoff)
      (fullSubCutoff := fullSubCutoff) subFullTestBasedMerit
      subFullTestFreeMerit fullSubLowTestBasedMerit fullSubLowTestFreeMerit
      fullSubHighTestBasedMerit fullSubHighTestFreeMerit
      (feasible1 := feasible1) (feasible2 := feasible2) hS hmaxCost hcostMem
      hsubFullCont hsubFullAnti hsubFullAtZero hsubFullAtMax hlowCont
      hlowAnti hlowAtZero hlowAtMax hhighCont hhighAnti hhighAtZero
      hhighAtMax hhighAtLowRoot hshareA hshareB hmassFullFullA
      hmassFullFullB hmassFullSubA hmassFullSubB hcapacity1 hfillFullFull1
      hcapacity2 hfillFullFull2 hfixedPoolJ1A hfixedPoolJ1B
      hfixedPoolJ2A hfixedPoolJ2B honlyA_J1_groupB_eq
