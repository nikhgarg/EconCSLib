theorem glm20_with_test_exp_decompose
    {Θ ΩTest ΩNo : Type*} [Fintype Θ] [DecidableEq Θ]
    [Fintype ΩTest] [DecidableEq ΩTest] [Fintype ΩNo] [DecidableEq ΩNo]
    (m : GLM20Model Θ ΩTest ΩNo) (p : ΩTest → Prop) [DecidablePred p] :
    pmfExp m.prior m.quality =
      glm20TestSelectionProb m p * glm20TestConditionalMass m p +
        glm20TestSelectionProb m (fun ω => ¬ p ω) * glm20TestConditionalMass m (fun ω => ¬ p ω) := by
  simpa [glm20TwoSignalAdmissionsModel, twoSignalLeftSelectionProb,
    twoSignalLeftConditionalValue, twoSignalLeftModel, glm20TestSelectionProb,
    glm20TestConditionalMass, glm20WithTestModel] using
    (twoSignalLeftValueExp_decompose (m := glm20TwoSignalAdmissionsModel m) (p := p))

theorem glm20_no_test_conditional_of_compl
    {Θ ΩTest ΩNo : Type*} [Fintype Θ] [DecidableEq Θ]
    [Fintype ΩTest] [DecidableEq ΩTest] [Fintype ΩNo] [DecidableEq ΩNo]
    (m : GLM20Model Θ ΩTest ΩNo) (p : ΩNo → Prop) [DecidablePred p] :
    glm20NoTestConditionalMass m (fun ω => ¬ p ω) =
      (pmfExp m.prior m.quality - glm20NoTestSelectionProb m p * glm20NoTestConditionalMass m p) /
        glm20NoTestSelectionProb m (fun ω => ¬ p ω) := by
  simpa [glm20NoTestConditionalMass, glm20NoTestSelectionProb] using
    (admissionsSelectedWelfareConditionalExp_of_compl (m := glm20WithoutTestModel m) (p := p)
      (value := m.quality))

theorem glm20_no_test_exp_decompose
    {Θ ΩTest ΩNo : Type*} [Fintype Θ] [DecidableEq Θ]
    [Fintype ΩTest] [DecidableEq ΩTest] [Fintype ΩNo] [DecidableEq ΩNo]
    (m : GLM20Model Θ ΩTest ΩNo) (p : ΩNo → Prop) [DecidablePred p] :
    pmfExp m.prior m.quality =
      glm20NoTestSelectionProb m p * glm20NoTestConditionalMass m p +
        glm20NoTestSelectionProb m (fun ω => ¬ p ω) * glm20NoTestConditionalMass m (fun ω => ¬ p ω) := by
  simpa [glm20TwoSignalAdmissionsModel, twoSignalRightSelectionProb,
    twoSignalRightConditionalValue, twoSignalRightModel, glm20NoTestSelectionProb,
    glm20NoTestConditionalMass, glm20WithoutTestModel] using
    (twoSignalRightValueExp_decompose (m := glm20TwoSignalAdmissionsModel m) (p := p))

end

end GLM20DroppingStandardizedTesting
