            priorSigmaA priorPrecisionA subPrecisionSumA
            priorSigmaB priorPrecisionB subPrecisionSumB) ∧
      diversity J2 (policyPair Psub Psub) ≤
        diversity J2 (policyPair Psub Pfull) :=
  paper_proposition6_diversity_surface_subFull_equilibrium_iff_paper_formulas
    api Q bivariateCDF hfull hsub

/--
Paper Proposition 6, diversity-only equilibrium consequence.

If the displayed source-parameter Proposition 6 inequality holds for school
`J1` and school `J2` weakly prefers keeping the test against `P_sub`, then
`(P_sub,P_full)` is a binary-policy equilibrium on the diversity-only surface.
-/
theorem
    paper_proposition6_source_parameter_formula_inequality_implies_diversity_surface_subFull_equilibrium
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {Group Policy School : Type*}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School}
    {groupBPopulationShare capacity1 priorSigmaA priorPrecisionA
      subPrecisionSumA priorSigmaB priorPrecisionB subPrecisionSumB
      fullPrecisionSumB aB mu q1Full : ℝ}
    (hJ2 :
      diversity J2 (policyPair Psub Psub) ≤
        diversity J2 (policyPair Psub Pfull))
    (hfull :
      diversity J1 (policyPair Pfull Pfull) =
        glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1
          (glm20Proposition3SigmaTildeSource
            priorSigmaB priorPrecisionB fullPrecisionSumB)
          aB
          (glm20Proposition3BSource
            priorPrecisionB subPrecisionSumB fullPrecisionSumB)
          mu q1Full)
    (hsub :
      diversity J1 (policyPair Psub Pfull) =
        glm20Proposition6PaperSubDiversityFormula Q capacity1
          groupBPopulationShare
          (glm20Proposition6SubSigmaTildeSourceRatio
            priorSigmaA priorPrecisionA subPrecisionSumA
            priorSigmaB priorPrecisionB subPrecisionSumB))
    (hineq :
      glm20Proposition6FullDiversityFormula api bivariateCDF
          groupBPopulationShare capacity1
          (glm20Proposition3SigmaTildeSource
            priorSigmaB priorPrecisionB fullPrecisionSumB)
          aB
          (glm20Proposition3BSource
            priorPrecisionB subPrecisionSumB fullPrecisionSumB)
          mu q1Full <
        glm20Proposition6PaperSubDiversityFormula Q capacity1
          groupBPopulationShare
          (glm20Proposition6SubSigmaTildeSourceRatio
            priorSigmaA priorPrecisionA subPrecisionSumA
            priorSigmaB priorPrecisionB subPrecisionSumB)) :
    (glm20DiversityBinaryPolicySurface massTestTaking admittedAcademicMerit
        diversity policyPair Psub Pfull J1 J2).policyPairIsEquilibrium
        Psub Pfull := by
  refine
    glm20DiversityBinaryPolicySurface_subFull_of_j1_strict_and_j2_weak
      (massTestTaking := massTestTaking)
      (admittedAcademicMerit := admittedAcademicMerit)
      (diversity := diversity) (policyPair := policyPair)
      (Psub := Psub) (Pfull := Pfull) (J1 := J1) (J2 := J2) ?_ hJ2
  rw [hfull, hsub]
  exact hineq

/--
Paper Proposition 6 on the concrete policy-state diversity table.

This removes the last policy-pair lookup from the strict-best-response version:
with diversity supplied by the four source policy-state entries, school `J1`
strictly drops the test exactly when the paper's full/full diversity formula is
below the test-free sub/full formula.
