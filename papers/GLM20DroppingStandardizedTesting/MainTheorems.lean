This is the next layer above the mass/cutoff equivalences: the concrete
Gaussian game may prove school-deviation objectives in the cutoff language
used inside the Proposition 5 proof.  The theorem below converts those
cutoff-form premises into the paper's displayed mass conditions (10), (13),
and (14), then invokes the source-shaped Theorem 3 wrapper.
-/
theorem paper_theorem3_source_conditions_of_proposition5_cutoff_objective_bridges
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost subFullCostThreshold
      fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff fullSubCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (hpolicySubFull :
      S.policyPairIsEquilibrium Psub Pfull ↔
        glm20TwoSchoolBinaryPolicyEquilibrium objective1 objective2
          Psub Pfull Psub Pfull)
    (hpolicyFullSub :
      S.policyPairIsEquilibrium Pfull Psub ↔
        glm20TwoSchoolBinaryPolicyEquilibrium objective1 objective2
          Psub Pfull Pfull Psub)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullFullCutoff groupB))
    (hmassFullSubA :
      S.massTestTaking groupA (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupA)
          (fullSubCutoff groupA))
    (hmassFullSubB :
      S.massTestTaking groupB (policyPair Pfull Psub) =
        glm20StrategicSubEstimateMassAbove api (subEstimateLaw groupB)
          (fullSubCutoff groupB))
    (hsubFullJ1Cutoff :
      (objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (fun g =>
            testCost g ≥ subFullCostThreshold g ∧
              0 < subFullCostThreshold g ∧ q1Sub < fullFullCutoff g))
    (hsubFullJ2A :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost subFullCostThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull
            J2 groupA groupB populationShare capacity2 groupB))
    (hsubFullJ2B :
      glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost subFullCostThreshold q1Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        ((objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          glm20Theorem3SubFullOtherGroupKeepsTest S policyPair Psub Pfull
            J2 groupA groupB populationShare capacity2 groupA))
    (hfullSubJ2Cutoff :
      (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (fun g =>
            testCost g ≥ fullSubLowCostThreshold g ∧
              0 < fullSubLowCostThreshold g ∧
                fullSubLowCostThreshold g < fullSubHighCostThreshold g ∧
                  q2Sub < fullFullCutoff g))
    (hfullSubJ1A :
      glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
          testCost fullSubLowCostThreshold fullSubHighCostThreshold q1Sub q2Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupA →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          fullSubCutoff groupA < q1Sub ∨
            testCost groupA ≤ fullSubHighCostThreshold groupA))
    (hfullSubJ1B :
      glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
          testCost fullSubLowCostThreshold fullSubHighCostThreshold q1Sub q2Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)
          groupB →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          fullSubCutoff groupB < q1Sub ∨
            testCost groupB ≤ fullSubHighCostThreshold groupB))
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    (S.policyPairIsEquilibrium Psub Pfull ↔
      glm20Theorem3SubFullCondition S policyPair Psub Pfull J2
        groupA groupB populationShare testCost subFullCostThreshold
        capacity2 q1Sub
        (fun g q =>
          glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)) ∧
      (S.policyPairIsEquilibrium Pfull Psub ↔
        glm20Theorem3FullSubCondition S policyPair Psub Pfull groupA groupB
          testCost fullSubLowCostThreshold fullSubHighCostThreshold
          q1Sub q2Sub
          (fun g q =>
            glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q)) ∧
        glm20Theorem3FullFullCondition S Pfull groupA groupB testCost := by
  let K := fun g q =>
    glm20StrategicSubEstimateMassAbove api (subEstimateLaw g) q
  have hsubFullJ1 :
      (objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
            testCost subFullCostThreshold q1Sub K) :=
    paper_proposition5_part_i_school1_objective_iff_condition10_of_cutoff_cases
      S policyPair Psub Pfull api subEstimateLaw objective1
      hmassFullFullA hmassFullFullB hsubFullJ1Cutoff
  have hfullSubJ2 :
      (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
        glm20ExactlyOneOfTwo groupA groupB
          (glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
            testCost fullSubLowCostThreshold fullSubHighCostThreshold
            q1Sub q2Sub K) :=
    paper_proposition5_part_ii_school2_objective_iff_condition13_of_cutoff_cases
      S policyPair Psub Pfull api subEstimateLaw objective2
      hmassFullFullA hmassFullFullB hfullSubJ2Cutoff
  have hfullSubJ1A' :
      glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
