      Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
  let B : ℝ → ℝ := fun z => (qAdmit z - mu) / sigmaTilde
  have hstrip :
      Filter.Tendsto
        (fun z : ℝ =>
          verticalUpperStripMass (correlatedStandardGaussianLaw rho)
            (A z) (B z))
        Filter.atBot (nhds ((correlatedStandardGaussianLaw rho).real Set.univ)) :=
    verticalUpperStripMass_tendsto_atBot_univ_of_left_atTop_right_atBot
      (correlatedStandardGaussianLaw rho) (by simpa [A] using hA)
      (by simpa [B] using hB)
  have hscaled :
      Filter.Tendsto
        (fun z : ℝ =>
          populationShare * sigmaTilde *
            verticalUpperStripMass (correlatedStandardGaussianLaw rho)
              (A z) (B z))
        Filter.atBot (nhds (populationShare * sigmaTilde)) := by
    simpa [measureReal_def] using tendsto_const_nhds.mul hstrip
  simpa [A, B, rho,
    glm20BivariateApplyAdmitMass_eq_correlatedStandardGaussian_verticalUpperStripMass]
    using hscaled

/--
Strict decrease of the Lemma 3 standard-bivariate component after substituting
the Eq. (7) application cutoff.
-/
theorem glm20Lemma3StrategicApplicantComponent_standardBivariate_strictAnti
    (Q : StandardGaussianQuantileAPI)
    {Group : Type*}
    {populationShare sigmaTilde b mu : Group → ℝ}
    {aOfApply : Group → ℝ → ℝ}
    {priorPrecision subPrecision testPrecision cost : Group → ℝ}
    {value : ℝ} (g : Group)
    (hpopulation : 0 < populationShare g)
    (hsigma : 0 < sigmaTilde g)
    (hA :
      StrictAnti fun qAdmit : ℝ =>
        (aOfApply g
            (qAdmit -
              glm20StrategicProjectedScale
                (priorPrecision g) (subPrecision g) (testPrecision g) *
              Q.quantile (1 - cost g / value)) +
          b g * mu g) /
          Real.sqrt (1 + sigmaTilde g ^ 2 * b g ^ 2)) :
    StrictAnti
      (glm20Lemma3StrategicApplicantComponent Q
        (fun g qApply qAdmit =>
          glm20BivariateApplyAdmitMass standardGaussianCDFAPI
            standardBivariateGaussianCDF
            (populationShare g) (sigmaTilde g) (aOfApply g)
            (b g) (mu g) qApply qAdmit)
        priorPrecision subPrecision testPrecision cost value g) := by
  let qApply : ℝ → ℝ :=
    fun qAdmit =>
      qAdmit -
        glm20StrategicProjectedScale
          (priorPrecision g) (subPrecision g) (testPrecision g) *
          Q.quantile (1 - cost g / value)
  have hB :
      Monotone fun qAdmit : ℝ =>
        (qAdmit - mu g) / sigmaTilde g := by
    intro x y hxy
    exact div_le_div_of_nonneg_right (by linarith) hsigma.le
  simpa [glm20Lemma3StrategicApplicantComponent, qApply] using
    glm20BivariateApplyAdmitMass_standardBivariate_strictAnti_along
