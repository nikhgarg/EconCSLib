          K groupA →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          glm20Theorem3FullSubSchool1KeepsTestCondition S policyPair
            Psub Pfull testCost fullSubHighCostThreshold q1Sub K groupA) := by
    intro hdrop
    exact
      paper_proposition5_part_ii_school1_objective_iff_condition14_of_cutoff_case
        S policyPair Psub Pfull api subEstimateLaw objective1 hmassFullSubA
        (hfullSubJ1A hdrop)
  have hfullSubJ1B' :
      glm20Theorem3FullSubSchool2DropsCondition S policyPair Psub Pfull
          testCost fullSubLowCostThreshold fullSubHighCostThreshold q1Sub q2Sub
          K groupB →
        ((objective1 Psub Psub ≤ objective1 Pfull Psub) ↔
          glm20Theorem3FullSubSchool1KeepsTestCondition S policyPair
            Psub Pfull testCost fullSubHighCostThreshold q1Sub K groupB) := by
    intro hdrop
    exact
      paper_proposition5_part_ii_school1_objective_iff_condition14_of_cutoff_case
        S policyPair Psub Pfull api subEstimateLaw objective1 hmassFullSubB
        (hfullSubJ1B hdrop)
  exact
    paper_theorem3_source_conditions_of_proposition5_objective_bridges
      (S := S) (policyPair := policyPair) (Psub := Psub) (Pfull := Pfull)
      (J2 := J2) (groupA := groupA) (groupB := groupB)
      (populationShare := populationShare) (testCost := testCost)
      (subFullCostThreshold := subFullCostThreshold)
      (fullSubLowCostThreshold := fullSubLowCostThreshold)
      (fullSubHighCostThreshold := fullSubHighCostThreshold)
