      (S := S) (policyPair := policyPair) (Psub := Psub)
      (Pfull := Pfull) (J2 := J2) (groupA := groupA)
      (groupB := groupB) (populationShare := populationShare)
      (testCost := testCost) (leftCost := leftCost)
      (rightCost := rightCost) (capacity2 := capacity2)
