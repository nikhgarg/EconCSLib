/--
Theorem 2(ii) affine crossing support: when full-policy and test-free
admission probabilities are affine standardized Gaussian upper tails and the
full-policy standardized cutoff has the larger skill slope, full-policy
admission is higher exactly above the displayed skill cutoff.
-/
theorem paper_theorem2_affine_admission_probability_full_gt_sub_iff_cutoff_lt
    (A : StandardGaussianDerivativeAPI)
    {interceptFull slopeFull interceptSub slopeSub q : ℝ}
    (hslope : slopeSub < slopeFull) :
    A.affineUpperTail interceptFull slopeFull q >
        A.affineUpperTail interceptSub slopeSub q ↔
      (interceptFull - interceptSub) / (slopeFull - slopeSub) < q := A.affineUpperTail_gt_iff_cutoff_lt_of_slope_lt hslope

