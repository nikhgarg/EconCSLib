    (m : GLM20Model Θ ΩTest ΩNo) :
    glm20TestMass m (fun _ : ΩTest => True) = pmfExp m.prior m.quality := by
  simpa [glm20TestMass] using
    (admissionsSelectionMass_of_true (m := glm20WithTestModel m) (value := m.quality))

