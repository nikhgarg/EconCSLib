    (hnone :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ¬ objective2 Pfull Pfull ≤ objective2 Pfull Psub)
    (hboth_impossible :
