/--
Source precision algebra for the denominator
`sqrt(1+\tilde\sigma_g^2 b_g^2)`.
-/
theorem paper_interface_proposition3_source_denominator_sq_eq_precision_ratio
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum : ℝ}
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 ≤ subPrecisionSum)
    (hfull : 0 ≤ fullPrecisionSum) :
    1 +
        paperProposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum ^ 2 *
          paperProposition3BSource
            priorPrecision subPrecisionSum fullPrecisionSum ^ 2 =
      (priorPrecision + subPrecisionSum) *
          (priorPrecision + fullPrecisionSum) /
        (priorPrecision *
          (priorPrecision + subPrecisionSum + fullPrecisionSum)) :=
  glm20Proposition3_source_denominator_sq_eq_precision_ratio
    hsigma_sq hprior hsub hfull

