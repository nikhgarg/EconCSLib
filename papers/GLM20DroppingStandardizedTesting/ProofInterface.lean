/--
Proposition 5(i) / Theorem 3(i) objective bridge from merit crossings and the
paper's capacity-fill contradiction.  This is the same endpoint as
`paper_interface_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings`,
but the both-groups cutoff case is derived from the capacity equation at
`q^*_{1,sub}`.
-/
theorem
    paper_interface_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_and_capacity
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity1 capacity2 q1Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowCost : ∀ g, testFreeMerit g < testBasedMerit g 0)
    (hhighCost : ∀ g, testBasedMerit g (maxCost g) < testFreeMerit g)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        paperTheorem3K api (subEstimateLaw groupA) (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        paperTheorem3K api (subEstimateLaw groupB) (fullFullCutoff groupB))
    (hcapacity1 :
      capacity1 =
        populationShare groupA * paperTheorem3K api (subEstimateLaw groupA)
            q1Sub +
          populationShare groupB * paperTheorem3K api (subEstimateLaw groupB)
            q1Sub)
    (hfillFullFull1 :
      capacity1 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hnoneJ1 :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ objective1 Pfull Pfull ≤ objective1 Psub Pfull)
    (honlyA_J1_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupA (testCost groupA) ≤
              testFreeMerit groupA))
    (honlyB_J1_merit :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupB (testCost groupB) ≤
              testFreeMerit groupB))
    (hJ2ObjectiveSubSub :
      objective2 Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullB :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupA →
        objective2 Psub Pfull =
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull))
    (hJ2MassB :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupA →
        S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2)
    (hJ2NotTieB :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullA :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        objective2 Psub Pfull =
          populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull))
    (hJ2MassA :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2)
    (hJ2NotTieA :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :
    ∃ costThreshold : Group → ℝ,
      (∀ g, costThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, testBasedMerit g (costThreshold g) = testFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (testBasedMerit g c ≤ testFreeMerit g ↔
              costThreshold g ≤ c)) ∧
            ((objective1 Pfull Pfull ≤ objective1 Psub Pfull ∧
                objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
              paperTheorem3SubFullCondition S policyPair Psub Pfull J2
                groupA groupB populationShare testCost costThreshold
                capacity2 q1Sub
                (fun g q => paperTheorem3K api (subEstimateLaw g) q)) :=
  paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_and_capacity
    api subEstimateLaw objective1 objective2 testBasedMerit testFreeMerit
    hmaxCost hcostMem hcont hanti hlowCost hhighCost hshareA hshareB
    hmassFullFullA hmassFullFullB hcapacity1 hfillFullFull1 hnoneJ1
    honlyA_J1_merit honlyB_J1_merit hJ2ObjectiveSubSub
    hJ2ObjectiveSubFullB hJ2MassB hJ2NotTieB hJ2ObjectiveSubFullA
    hJ2MassA hJ2NotTieA

/--
Proposition 5(i) / Theorem 3(i) objective bridge with the both-groups cutoff
branch ruled out by the paper's capacity-fill contradiction and condition (12)
supplied as a strict academic-merit comparison.
-/
abbrev
    paper_interface_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_and_capacity_strict_merit
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity1 capacity2 q1Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowCost : ∀ g, testFreeMerit g < testBasedMerit g 0)
    (hhighCost : ∀ g, testBasedMerit g (maxCost g) < testFreeMerit g)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        paperTheorem3K api (subEstimateLaw groupA) (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        paperTheorem3K api (subEstimateLaw groupB) (fullFullCutoff groupB))
    (hcapacity1 :
      capacity1 =
        populationShare groupA * paperTheorem3K api (subEstimateLaw groupA)
            q1Sub +
          populationShare groupB * paperTheorem3K api (subEstimateLaw groupB)
            q1Sub)
    (hfillFullFull1 :
      capacity1 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hnoneJ1 :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ¬ objective1 Pfull Pfull ≤ objective1 Psub Pfull)
    (honlyA_J1_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupA (testCost groupA) ≤
              testFreeMerit groupA))
    (honlyB_J1_merit :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          ((objective1 Pfull Pfull ≤ objective1 Psub Pfull) ↔
            testBasedMerit groupB (testCost groupB) ≤
              testFreeMerit groupB))
    (hJ2ObjectiveSubSub :
      objective2 Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullB :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupA →
        objective2 Psub Pfull =
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull))
    (hJ2MassB :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupA →
        S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2)
    (hJ2MeritGtB :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) >
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullA :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        objective2 Psub Pfull =
          populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull))
    (hJ2MassA :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2)
    (hJ2MeritGtA :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) >
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :=
  paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_and_capacity_strict_merit
    api subEstimateLaw objective1 objective2 testBasedMerit testFreeMerit
    hmaxCost hcostMem hcont hanti hlowCost hhighCost hshareA hshareB
    hmassFullFullA hmassFullFullB hcapacity1 hfillFullFull1 hnoneJ1
    honlyA_J1_merit honlyB_J1_merit hJ2ObjectiveSubSub
    hJ2ObjectiveSubFullB hJ2MassB hJ2MeritGtB hJ2ObjectiveSubFullA
    hJ2MassA hJ2MeritGtA

/--
Proposition 5(i) / Theorem 3(i) objective bridge with the source case
obligations discharged by the capacity-fill contradiction and the fixed-pool
academic-merit comparison.

This is the paper-facing version of the Case (2) argument: if neither group
expands when `J1` drops the test, groupwise full/full merit strictly dominates
the `(P_sub,P_full)` merit, so the weighted academic-merit objective gives
`J1` no incentive to drop.
-/
theorem
    paper_interface_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_capacity_and_fixed_pool_merit
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity1 capacity2 q1Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff : Group → ℝ}
    (objective2 : Policy → Policy → ℝ)
    (testBasedMerit : Group → ℝ → ℝ) (testFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hcont :
      ∀ g, ContinuousOn (testBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hanti :
      ∀ g, StrictAntiOn (testBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowCost : ∀ g, testFreeMerit g < testBasedMerit g 0)
    (hhighCost : ∀ g, testBasedMerit g (maxCost g) < testFreeMerit g)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        paperTheorem3K api (subEstimateLaw groupA) (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        paperTheorem3K api (subEstimateLaw groupB) (fullFullCutoff groupB))
    (hcapacity1 :
      capacity1 =
        populationShare groupA *
            paperTheorem3K api (subEstimateLaw groupA) q1Sub +
          populationShare groupB *
            paperTheorem3K api (subEstimateLaw groupB) q1Sub)
    (hfillFullFull1 :
      capacity1 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hfixedPoolMeritA :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupA (policyPair Psub Pfull) <
            S.admittedAcademicMerit J1 groupA (policyPair Pfull Pfull))
    (hfixedPoolMeritB :
      ¬ q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J1 groupB (policyPair Psub Pfull) <
            S.admittedAcademicMerit J1 groupB (policyPair Pfull Pfull))
    (honlyA_J1_merit :
      q1Sub < fullFullCutoff groupA →
        ¬ q1Sub < fullFullCutoff groupB →
          ((paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Pfull Pfull ≤
            paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Psub Pfull) ↔
            testBasedMerit groupA (testCost groupA) ≤
              testFreeMerit groupA))
    (honlyB_J1_merit :
      q1Sub < fullFullCutoff groupB →
        ¬ q1Sub < fullFullCutoff groupA →
          ((paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Pfull Pfull ≤
            paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
              groupA groupB populationShare Psub Pfull) ↔
            testBasedMerit groupB (testCost groupB) ≤
              testFreeMerit groupB))
    (hJ2ObjectiveSubSub :
      objective2 Psub Psub =
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullB :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupA →
        objective2 Psub Pfull =
          populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull))
    (hJ2MassB :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupA →
        S.massTestTaking groupB (policyPair Psub Pfull) ≥ capacity2)
    (hJ2NotTieB :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupA →
        populationShare groupB *
            S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ObjectiveSubFullA :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        objective2 Psub Pfull =
          populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull))
    (hJ2MassA :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2)
    (hJ2NotTieA :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub)) :
    ∃ costThreshold : Group → ℝ,
      (∀ g, costThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, testBasedMerit g (costThreshold g) = testFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (testBasedMerit g c ≤ testFreeMerit g ↔
              costThreshold g ≤ c)) ∧
            ((paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
                groupA groupB populationShare Pfull Pfull ≤
              paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
                groupA groupB populationShare Psub Pfull ∧
                objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
              paperTheorem3SubFullCondition S policyPair Psub Pfull J2
                groupA groupB populationShare testCost costThreshold
                capacity2 q1Sub
                (fun g q => paperTheorem3K api (subEstimateLaw g) q)) :=
  paper_proposition5_part_i_objective_pair_iff_theorem3_subFull_condition_of_merit_crossings_capacity_and_fixed_pool_merit
    api subEstimateLaw objective2 testBasedMerit testFreeMerit hmaxCost
    hcostMem hcont hanti hlowCost hhighCost hshareA hshareB
    hmassFullFullA hmassFullFullB hcapacity1 hfillFullFull1
    hfixedPoolMeritA hfixedPoolMeritB honlyA_J1_merit honlyB_J1_merit
