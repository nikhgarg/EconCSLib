/--
Paper Theorem 3 definition: `K_g(q)`, the mass of group-`g` students whose
test-free estimated skill exceeds `q`.

Paper formula:
`K_g(q) = 1 - Phi((q - μ) /
  (σ * sqrt(sum_{k in sub} σ_gk^{-2} /
    (σ^{-2} + sum_{k in sub} σ_gk^{-2}))))`.
-/
abbrev paperTheorem3K
    (api : StandardGaussianCDFAPI) (subEstimateLaw : GaussianScaleLaw)
    (q : ℝ) : ℝ :=
  glm20StrategicSubEstimateMassAbove api subEstimateLaw q

/-- Paper Theorem 3 support: expanded normal-tail formula for `K_g(q)`. -/
theorem paper_interface_theorem3_Kg_eq_normal_tail_formula
    (api : StandardGaussianCDFAPI) (subEstimateLaw : GaussianScaleLaw)
    (q : ℝ) :
    paperTheorem3K api subEstimateLaw q =
      1 - api.cdf ((q - subEstimateLaw.mean) / subEstimateLaw.scale) :=
  paper_theorem3_Kg_eq_normal_tail_formula api subEstimateLaw q

/--
Paper Theorem 3 support: the `K_g(q)` formula specialized to the canonical
test-free estimated-skill law from Lemma 1.
-/
theorem paper_interface_theorem3_Kg_eq_offset_posterior_mean_tail
    {Feature : Type*} [Fintype Feature] [Nonempty Feature]
    (api : StandardGaussianCDFAPI) (M : GaussianOffsetSignalFamily Feature)
    (q : ℝ) :
    paperTheorem3K api M.posteriorMeanScaleLaw q =
      1 - api.cdf
        ((q - M.priorMean) / Real.sqrt M.posteriorMeanVariance) :=
  paper_theorem3_Kg_eq_offset_posterior_mean_tail api M q

/--
Paper Theorem 3 definition: the source-precision law used by `K_g(q)`.

This expands the test-free estimated-skill scale to
`sigma * sqrt(sum_{k in sub} sigma_gk^{-2} /
  (sigma^{-2} + sum_{k in sub} sigma_gk^{-2}))`.
-/
abbrev paperTheorem3SourceSubEstimateLaw
    (priorSigma priorPrecision subPrecisionSum mu : ℝ)
    (hpriorSigma_pos : 0 < priorSigma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsubPrecisionSum_pos : 0 < subPrecisionSum) :
    GaussianScaleLaw :=
  glm20StrategicSubEstimateLawSource priorSigma priorPrecision
    subPrecisionSum mu hpriorSigma_pos hpriorPrecision_pos
    hsubPrecisionSum_pos

/-- Paper Theorem 3 support: `K_g(q)` with raw source precisions expanded. -/
theorem paper_interface_theorem3_Kg_eq_source_precision_tail
    (api : StandardGaussianCDFAPI)
    {priorSigma priorPrecision subPrecisionSum mu q : ℝ}
    (hpriorSigma_pos : 0 < priorSigma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsubPrecisionSum_pos : 0 < subPrecisionSum) :
    paperTheorem3K api
        (paperTheorem3SourceSubEstimateLaw priorSigma priorPrecision
          subPrecisionSum mu hpriorSigma_pos hpriorPrecision_pos
          hsubPrecisionSum_pos) q =
      1 -
        api.cdf
          ((q - mu) /
            (priorSigma *
              Real.sqrt
                (subPrecisionSum /
                  (priorPrecision + subPrecisionSum)))) :=
  paper_theorem3_Kg_eq_source_precision_tail api hpriorSigma_pos
    hpriorPrecision_pos hsubPrecisionSum_pos

