/--
Corrected-source eligible mass equals the affine selection mass after the
conditional-source `A_g(q)` substitution.
-/
theorem
    paper_interface_proposition2_subEligibleUnnormalizedMassFormula_eq_conditional_affineArgument
    (api : StandardGaussianCDFAPI)
    {populationShare mu priorSigma priorPrecision subPrecisionSum
      fullPrecisionSum q2Sub : ℝ}
    (hsigma : 0 < priorSigma)
    (hsigma_sq : priorSigma ^ 2 = 1 / priorPrecision)
    (hprior : 0 < priorPrecision) (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum) :
    paperProposition2SubEligibleUnnormalizedMassFormula api
        populationShare mu priorSigma priorPrecision subPrecisionSum
        fullPrecisionSum q2Sub =
      populationShare *
        paperProposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum *
        api.cdf
          (paperProposition2AArgument
            (paperProposition3SigmaTildeSource
              priorSigma priorPrecision fullPrecisionSum)
            (paperProposition2AHatConditionalSource
              priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub)
            (paperProposition3BSource
              priorPrecision subPrecisionSum fullPrecisionSum)
            mu) :=
  glm20Proposition2SubEligibleUnnormalizedMassFormula_eq_conditional_affineArgument
    api hsigma hsigma_sq hprior hsub hfull

