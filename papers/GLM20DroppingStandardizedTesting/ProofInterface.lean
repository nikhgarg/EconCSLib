        (1 - pi) * sigmaTildeA *
            paperProposition3SelectionCore api bivariateCDF
              sigmaTildeA aA bA mu qFull +
          pi * sigmaTildeB *
            paperProposition3SelectionCore api bivariateCDF
              sigmaTildeB aB bB mu qFull)
