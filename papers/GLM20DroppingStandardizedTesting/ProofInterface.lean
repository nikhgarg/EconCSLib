    hP_ne hcapacity_pos hgroupA_pos hgroupB_pos hcapacity_mem hscaleA_pos
    hxiA_pos hownA_pos hotherA_pos hrhoA_nonneg hrhoA_lt_one hselectiveA
    hscaleB_pos hxiB_pos hownB_pos hotherB_pos hone_lt_rhoB hselectiveB

