/--
Paper Proposition 2: tie-broken uniqueness of the two-school application
region with the paper's projected precision scale, using only the
nonredundant high cost-ratio domain.

For fixed school cutoffs, any pointwise best-response application strategy that
uses the displayed region's cutoff tie-breaking is exactly the paper's
low/high cutoff region.
-/
theorem paper_interface_proposition2_two_school_application_region_unique_strategy_precision_standardGaussian_of_high_cost_ratio
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold school2SubThreshold
      priorPrecision subPrecision testPrecision cost v1 v2 : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ lowCutoff highCutoff : ℝ,
      lowCutoff =
        admissionThreshold -
          glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision *
              Q.quantile (1 - cost / v1) ∧
      highCutoff =
        admissionThreshold -
          glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision *
              Q.quantile (1 - cost / (v1 - v2)) ∧
      lowCutoff < highCutoff ∧
      ∀ strategy : ℝ → Bool,
        (∀ q : ℝ, ∀ apply : Bool,
          glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
              (Q.cdfAPI.thresholdPassProb
                { mean := q
                  scale :=
                    glm20StrategicProjectedScale
                      priorPrecision subPrecision testPrecision
                  scale_pos :=
                    glm20StrategicProjectedScale_pos
                      hprior_pos hsub_pos htest_pos }
                admissionThreshold)
              q apply ≤
            glm20StrategicTwoSchoolApplyPayoff school2SubThreshold v1 v2 cost
              (Q.cdfAPI.thresholdPassProb
                { mean := q
                  scale :=
                    glm20StrategicProjectedScale
                      priorPrecision subPrecision testPrecision
                  scale_pos :=
                    glm20StrategicProjectedScale_pos
                      hprior_pos hsub_pos htest_pos }
                admissionThreshold)
              q (strategy q)) →
        strategy lowCutoff =
          decide
            ((lowCutoff < school2SubThreshold ∧ lowCutoff ≤ lowCutoff) ∨
              (school2SubThreshold ≤ lowCutoff ∧ highCutoff ≤ lowCutoff)) →
        strategy highCutoff =
          decide
            ((highCutoff < school2SubThreshold ∧ lowCutoff ≤ highCutoff) ∨
              (school2SubThreshold ≤ highCutoff ∧ highCutoff ≤ highCutoff)) →
        strategy =
          fun q : ℝ =>
            decide
              ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
                (school2SubThreshold ≤ q ∧ highCutoff ≤ q)) :=
  paper_proposition2_two_school_application_region_unique_strategy_precision_standardGaussian_of_high_cost_ratio
    Q hprior_pos hsub_pos htest_pos hcost hv1 hdiff_pos hdiff_lt_v1
    hcostRatioHigh

