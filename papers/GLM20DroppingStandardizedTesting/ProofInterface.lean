          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hJ2ZeroB :
      ∀ costThreshold : Group → ℝ,
        paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
            testCost costThreshold q1Sub
            (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
          S.admittedAcademicMerit J2 groupB (policyPair Psub Pfull) = 0)
    (hJ2MassA :
      ∀ costThreshold : Group → ℝ,
      paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        S.massTestTaking groupA (policyPair Psub Pfull) ≥ capacity2)
    (hJ2NotTieA :
      ∀ costThreshold : Group → ℝ,
      paperTheorem3SubFullGroupExpandsByDropping S policyPair Psub Pfull
          testCost costThreshold q1Sub
          (fun g q => paperTheorem3K api (subEstimateLaw g) q) groupB →
        populationShare groupA *
            S.admittedAcademicMerit J2 groupA (policyPair Psub Pfull) ≠
          populationShare groupA *
              S.admittedAcademicMerit J2 groupA (policyPair Psub Psub) +
            populationShare groupB *
              S.admittedAcademicMerit J2 groupB (policyPair Psub Psub))
    (hnoneJ2 :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ¬ paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub)
    (hbothJ2_impossible :
      q2Sub < fullFullCutoff groupA →
        q2Sub < fullFullCutoff groupB → False)
    (honlyA_J2_merit :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ((paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub) ↔
            fullSubLowTestBasedMerit groupA (testCost groupA) ≤
              fullSubLowTestFreeMerit groupA))
    (honlyB_J2_merit :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          ((paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub) ↔
            fullSubLowTestBasedMerit groupB (testCost groupB) ≤
              fullSubLowTestFreeMerit groupB))
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandA_testFree :
      ¬ fullSubCutoff groupA < q1Sub →
        paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub =
          fullSubHighTestFreeMerit groupA)
    (hexpandA_testBased :
      ¬ fullSubCutoff groupA < q1Sub →
        paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub =
          fullSubHighTestBasedMerit groupA (testCost groupA))
    (hnoExpandB :
      fullSubCutoff groupB < q1Sub →
        paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub ≤
        paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub)
    (hexpandB_testFree :
      ¬ fullSubCutoff groupB < q1Sub →
        paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Psub Psub =
          fullSubHighTestFreeMerit groupB)
    (hexpandB_testBased :
      ¬ fullSubCutoff groupB < q1Sub →
        paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
          groupA groupB populationShare Pfull Psub =
          fullSubHighTestBasedMerit groupB (testCost groupB))
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    ∃ subFullCostThreshold fullSubLowCostThreshold
        fullSubHighCostThreshold : Group → ℝ,
      (∀ g, subFullCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, subFullTestBasedMerit g (subFullCostThreshold g) =
          subFullTestFreeMerit g) ∧
          (∀ g c, c ∈ Set.Icc (0 : ℝ) (maxCost g) →
            (subFullTestBasedMerit g c ≤ subFullTestFreeMerit g ↔
              subFullCostThreshold g ≤ c)) ∧
            (∀ g, fullSubLowCostThreshold g ∈
              Set.Ioo (0 : ℝ) (maxCost g)) ∧
              (∀ g, fullSubHighCostThreshold g ∈
                Set.Ioo (0 : ℝ) (maxCost g)) ∧
                (∀ g, fullSubLowTestBasedMerit g
                    (fullSubLowCostThreshold g) =
                  fullSubLowTestFreeMerit g) ∧
                  (∀ g, fullSubHighTestBasedMerit g
                      (fullSubHighCostThreshold g) =
                    fullSubHighTestFreeMerit g) ∧
                    (∀ g,
                      fullSubLowCostThreshold g <
                        fullSubHighCostThreshold g) ∧
                      ((S.policyPairIsEquilibrium Psub Pfull ↔
                          paperTheorem3SubFullCondition S policyPair
                            Psub Pfull J2 groupA groupB populationShare
                            testCost subFullCostThreshold capacity2 q1Sub
                            (fun g q => paperTheorem3K api
                              (subEstimateLaw g) q)) ∧
                        (S.policyPairIsEquilibrium Pfull Psub ↔
                          paperTheorem3FullSubCondition S policyPair
                            Psub Pfull groupA groupB testCost
                            fullSubLowCostThreshold fullSubHighCostThreshold
                            q1Sub q2Sub
                            (fun g q => paperTheorem3K api
                              (subEstimateLaw g) q)) ∧
                          glm20Theorem3FullFullCondition S Pfull groupA
                            groupB testCost) :=
  paper_theorem3_source_conditions_of_proposition5_merit_crossings_weighted_binary_surface
    api subEstimateLaw subFullTestBasedMerit subFullTestFreeMerit
    fullSubLowTestBasedMerit fullSubLowTestFreeMerit
    fullSubHighTestBasedMerit fullSubHighTestFreeMerit hS hmaxCost hcostMem
    hsubFullCont hsubFullAnti hsubFullAtZero hsubFullAtMax hlowCont
    hlowAnti hlowAtZero hlowAtMax hhighCont hhighAnti hhighAtZero
    hhighAtMax hhighAtLowRoot hmassFullFullA hmassFullFullB hmassFullSubA
    hmassFullSubB hnoneJ1 hbothJ1_impossible honlyA_J1_merit
    honlyB_J1_merit hJ2ZeroA hJ2MassB hJ2NotTieB hJ2ZeroB hJ2MassA
    hJ2NotTieA hnoneJ2 hbothJ2_impossible honlyA_J2_merit
    honlyB_J2_merit hnoExpandA hexpandA_testFree hexpandA_testBased
    hnoExpandB hexpandB_testFree hexpandB_testBased hcostA hcostB

/--
Paper Theorem 3 exact-one wording: the two-group helper is equivalent to
"there exists a unique group in `{A,B}` satisfying the condition."
-/
theorem paper_interface_theorem3_exactly_one_group_iff_exists_unique
    {Group : Type*} {groupA groupB : Group} (hne : groupA ≠ groupB)
    (condition : Group → Prop) :
    glm20ExactlyOneOfTwo groupA groupB condition ↔
      ∃ g : Group,
        (g = groupA ∨ g = groupB) ∧ condition g ∧
          ∀ h : Group, (h = groupA ∨ h = groupB) → condition h → h = g :=
  glm20ExactlyOneOfTwo_iff_existsUnique_mem_pair hne condition

/--
Paper Theorem 3(iii) condition for `(P_full, P_full)`: there are positive
cost-boundary functions `c_A` and `c_B` such that both schools keep the test
iff each group's cost is below the other-cost-dependent boundary.
-/
abbrev paperTheorem3FullFullCondition
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (Pfull : Policy) (groupA groupB : Group)
    (testCost : Group → ℝ) : Prop :=
  glm20Theorem3FullFullCondition S Pfull groupA groupB testCost

/--
Paper Theorem 3(iii), cost-family version: the boundary functions characterize
the full/full equilibrium region for every positive pair of group costs.
-/
abbrev paperTheorem3FullFullCostFamilyCondition
    {Group : Type*} (groupA groupB : Group)
    (equilibriumAtCost : (Group → ℝ) → Prop) : Prop :=
  glm20Theorem3FullFullCostFamilyCondition groupA groupB equilibriumAtCost

/--
Paper Theorem 3(iii) source-proof composition: if each school has a two-sided
keep-test boundary region, the full/full equilibrium region is given by the
pointwise minima of the two schools' boundaries.
-/
theorem paper_interface_theorem3_fullFull_cost_family_condition_of_two_school_keep_regions
    {Group : Type*} {groupA groupB : Group}
    {equilibriumAtCost school1Keeps school2Keeps : (Group → ℝ) → Prop}
    (boundary1A boundary1B boundary2A boundary2B : ℝ → ℝ)
    (hboundary1A_pos : ∀ x : ℝ, 0 < x → 0 < boundary1A x)
    (hboundary1B_pos : ∀ x : ℝ, 0 < x → 0 < boundary1B x)
    (hboundary2A_pos : ∀ x : ℝ, 0 < x → 0 < boundary2A x)
    (hboundary2B_pos : ∀ x : ℝ, 0 < x → 0 < boundary2B x)
    (hequilibrium :
      ∀ testCost : Group → ℝ,
        0 < testCost groupA →
          0 < testCost groupB →
            (equilibriumAtCost testCost ↔
              school1Keeps testCost ∧ school2Keeps testCost))
    (hschool1 :
      ∀ testCost : Group → ℝ,
        0 < testCost groupA →
          0 < testCost groupB →
            (school1Keeps testCost ↔
              testCost groupA ≤ boundary1A (testCost groupB) ∧
                testCost groupB ≤ boundary1B (testCost groupA)))
    (hschool2 :
      ∀ testCost : Group → ℝ,
        0 < testCost groupA →
          0 < testCost groupB →
            (school2Keeps testCost ↔
              testCost groupA ≤ boundary2A (testCost groupB) ∧
                testCost groupB ≤ boundary2B (testCost groupA))) :
    paperTheorem3FullFullCostFamilyCondition groupA groupB
      equilibriumAtCost :=
  paper_theorem3_fullFull_cost_family_condition_of_two_school_keep_regions
    boundary1A boundary1B boundary2A boundary2B hboundary1A_pos
    hboundary1B_pos hboundary2A_pos hboundary2B_pos hequilibrium hschool1
    hschool2

/--
Paper Theorem 3(iii) binary-objective specialization: for a cost-parametric
two-policy school game, full/full is an equilibrium exactly when neither school
weakly improves by switching to `P_sub`.  If those two keep-test inequalities
have boundary forms, the full/full equilibrium region has the paper's
boundary functions.
-/
theorem paper_interface_theorem3_fullFull_cost_family_condition_of_binary_objective_keep_regions
    {Group Policy : Type*} {groupA groupB : Group} {Psub Pfull : Policy}
    (objective1 objective2 : (Group → ℝ) → Policy → Policy → ℝ)
    (boundary1A boundary1B boundary2A boundary2B : ℝ → ℝ)
    (hboundary1A_pos : ∀ x : ℝ, 0 < x → 0 < boundary1A x)
    (hboundary1B_pos : ∀ x : ℝ, 0 < x → 0 < boundary1B x)
    (hboundary2A_pos : ∀ x : ℝ, 0 < x → 0 < boundary2A x)
    (hboundary2B_pos : ∀ x : ℝ, 0 < x → 0 < boundary2B x)
    (hschool1 :
      ∀ testCost : Group → ℝ,
        0 < testCost groupA →
          0 < testCost groupB →
            (objective1 testCost Psub Pfull ≤
                objective1 testCost Pfull Pfull ↔
              testCost groupA ≤ boundary1A (testCost groupB) ∧
                testCost groupB ≤ boundary1B (testCost groupA)))
    (hschool2 :
      ∀ testCost : Group → ℝ,
        0 < testCost groupA →
          0 < testCost groupB →
            (objective2 testCost Pfull Psub ≤
                objective2 testCost Pfull Pfull ↔
              testCost groupA ≤ boundary2A (testCost groupB) ∧
                testCost groupB ≤ boundary2B (testCost groupA))) :
    paperTheorem3FullFullCostFamilyCondition groupA groupB
      (fun testCost =>
        paperTwoSchoolBinaryPolicyEquilibrium (objective1 testCost)
          (objective2 testCost) Psub Pfull Pfull Pfull) :=
  paper_theorem3_fullFull_cost_family_condition_of_binary_objective_keep_regions
    objective1 objective2 boundary1A boundary1B boundary2A boundary2B
    hboundary1A_pos hboundary1B_pos hboundary2A_pos hboundary2B_pos
    hschool1 hschool2

/--
Convert a cost-family Theorem 3(iii) boundary characterization into the
fixed-cost full/full condition used by the paper's source-condition wrapper.
-/
theorem paper_interface_theorem3_fullFull_condition_of_cost_family_condition
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {Pfull : Policy} {groupA groupB : Group} {testCost : Group → ℝ}
    {equilibriumAtCost : (Group → ℝ) → Prop}
    (hfamily :
      paperTheorem3FullFullCostFamilyCondition groupA groupB
        equilibriumAtCost)
    (hfixed :
      S.policyPairIsEquilibrium Pfull Pfull ↔ equilibriumAtCost testCost)
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    paperTheorem3FullFullCondition S Pfull groupA groupB testCost :=
  paper_theorem3_fullFull_condition_of_cost_family_condition hfamily hfixed
    hcostA hcostB

/--
Paper Theorem 3(iii) fixed-cost bridge for the weighted academic-merit surface:
if the cost-parametric binary objective family has a boundary characterization,
and at the realized costs its objectives are the paper's weighted merit
objectives, then `(P_full,P_full)` satisfies the source full/full condition.
-/
theorem paper_interface_theorem3_fullFull_condition_of_binary_objective_cost_family_at_weighted_surface
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost : Group → ℝ}
    (objective1 objective2 : (Group → ℝ) → Policy → Policy → ℝ)
    (hS :
      S =
        paperWeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2
          groupA groupB populationShare)
    (hfamily :
      paperTheorem3FullFullCostFamilyCondition groupA groupB
        (fun cost =>
          paperTwoSchoolBinaryPolicyEquilibrium (objective1 cost)
            (objective2 cost) Psub Pfull Pfull Pfull))
    (hobjective1 :
      ∀ P1 P2 : Policy,
        objective1 testCost P1 P2 =
          paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare P1 P2)
    (hobjective2 :
      ∀ P1 P2 : Policy,
        objective2 testCost P1 P2 =
          paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare P1 P2)
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    paperTheorem3FullFullCondition S Pfull groupA groupB testCost :=
  paper_theorem3_fullFull_condition_of_binary_objective_cost_family_at_weighted_surface
    objective1 objective2 hS hfamily hobjective1 hobjective2 hcostA hcostB

/--
Paper Theorem 3(iii) direct weighted-surface endpoint from two school-specific
full/full keep-region boundary characterizations.
-/
theorem paper_interface_theorem3_fullFull_condition_of_binary_objective_keep_regions_at_weighted_surface
    {Group Policy School : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School (Policy × Policy)}
    {massTestTaking : Group → Policy → ℝ}
    {admittedAcademicMerit : School → Group → Policy → ℝ}
    {diversity : School → Policy → ℝ}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J1 J2 : School} {groupA groupB : Group}
    {populationShare testCost : Group → ℝ}
    (objective1 objective2 : (Group → ℝ) → Policy → Policy → ℝ)
    (boundary1A boundary1B boundary2A boundary2B : ℝ → ℝ)
    (hS :
      S =
        paperWeightedAcademicMeritBinaryPolicySurface massTestTaking
          admittedAcademicMerit diversity policyPair Psub Pfull J1 J2
          groupA groupB populationShare)
    (hboundary1A_pos : ∀ x : ℝ, 0 < x → 0 < boundary1A x)
    (hboundary1B_pos : ∀ x : ℝ, 0 < x → 0 < boundary1B x)
    (hboundary2A_pos : ∀ x : ℝ, 0 < x → 0 < boundary2A x)
    (hboundary2B_pos : ∀ x : ℝ, 0 < x → 0 < boundary2B x)
    (hschool1 :
      ∀ cost : Group → ℝ,
        0 < cost groupA →
          0 < cost groupB →
            (objective1 cost Psub Pfull ≤ objective1 cost Pfull Pfull ↔
              cost groupA ≤ boundary1A (cost groupB) ∧
                cost groupB ≤ boundary1B (cost groupA)))
    (hschool2 :
      ∀ cost : Group → ℝ,
        0 < cost groupA →
          0 < cost groupB →
            (objective2 cost Pfull Psub ≤ objective2 cost Pfull Pfull ↔
              cost groupA ≤ boundary2A (cost groupB) ∧
                cost groupB ≤ boundary2B (cost groupA)))
    (hobjective1 :
      ∀ P1 P2 : Policy,
        objective1 testCost P1 P2 =
          paperTwoGroupWeightedAcademicMeritObjective S policyPair J1
            groupA groupB populationShare P1 P2)
    (hobjective2 :
      ∀ P1 P2 : Policy,
        objective2 testCost P1 P2 =
          paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
            groupA groupB populationShare P1 P2)
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    paperTheorem3FullFullCondition S Pfull groupA groupB testCost :=
  paper_theorem3_fullFull_condition_of_binary_objective_keep_regions_at_weighted_surface
    objective1 objective2 boundary1A boundary1B boundary2A boundary2B hS
    hboundary1A_pos hboundary1B_pos hboundary2A_pos hboundary2B_pos
    hschool1 hschool2 hobjective1 hobjective2 hcostA hcostB

/--
Paper Theorem 3(iii): existence of positive cost-boundary functions for the
`(P_full,P_full)` equilibrium condition.

At the abstract source-condition layer this follows from positive group test
costs; the concrete strategic work is identifying the economically meaningful
boundary functions generated by the two-school game.
-/
theorem paper_interface_theorem3_fullFull_condition_exists_boundary_functions_of_positive_costs
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (Pfull : Policy) (groupA groupB : Group) (testCost : Group → ℝ)
    (hcostA : 0 < testCost groupA) (hcostB : 0 < testCost groupB) :
    paperTheorem3FullFullCondition S Pfull groupA groupB testCost :=
  paper_theorem3_fullFull_condition_exists_boundary_functions_of_positive_costs
    S Pfull groupA groupB testCost hcostA hcostB

/--
Paper Proposition 5 strategic academic-merit source surface.

This is the typed non-certificate target for the Proposition 5 proof seams:
the two unilateral weighted-academic-merit objective comparisons are equivalent
to the paper's displayed source conditions for `(P_sub,P_full)` and
`(P_full,P_sub)`, and the full/full pair satisfies the source boundary
condition.
-/
def paperProposition5StrategicAcademicMeritSourceConditions
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J2 : School) (groupA groupB : Group)
    (populationShare testCost subFullCostThreshold
      fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ)
    (capacity2 q1Sub q2Sub : ℝ) (K : Group → ℝ → ℝ)
    (objective1 objective2 : Policy → Policy → ℝ) : Prop :=
  ((objective1 Pfull Pfull ≤ objective1 Psub Pfull ∧
      objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
    paperTheorem3SubFullCondition S policyPair Psub Pfull J2 groupA groupB
      populationShare testCost subFullCostThreshold capacity2 q1Sub K) ∧
    ((objective1 Psub Psub ≤ objective1 Pfull Psub ∧
        objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
      paperTheorem3FullSubCondition S policyPair Psub Pfull groupA groupB
        testCost fullSubLowCostThreshold fullSubHighCostThreshold q1Sub q2Sub
        K) ∧
      paperTheorem3FullFullCondition S Pfull groupA groupB testCost

/--
Existential-threshold version of Proposition 5's strategic academic-merit
source surface.

Use this when the Proposition 5 proof has constructed the three cost-threshold
functions but their names do not matter to the downstream theorem statement.
-/
def paperProposition5StrategicAcademicMeritSourceConditionsExists
    {Group Policy School Equilibrium : Type*}
    (S : GLM20StrategicPolicySurface Group Policy School Equilibrium)
    (policyPair : Policy → Policy → Policy)
    (Psub Pfull : Policy) (J2 : School) (groupA groupB : Group)
    (populationShare testCost : Group → ℝ)
    (capacity2 q1Sub q2Sub : ℝ) (K : Group → ℝ → ℝ)
    (objective1 objective2 : Policy → Policy → ℝ) : Prop :=
  ∃ subFullCostThreshold fullSubLowCostThreshold
      fullSubHighCostThreshold : Group → ℝ,
    paperProposition5StrategicAcademicMeritSourceConditions S policyPair Psub
      Pfull J2 groupA groupB populationShare testCost subFullCostThreshold
      fullSubLowCostThreshold fullSubHighCostThreshold capacity2 q1Sub q2Sub K
      objective1 objective2

/--
Paper Proposition 5 strategic academic-merit endpoint from already-verified
objective bridges.

This replaces the opaque `GLM20StrategicAcademicMeritCertificate` shape for
source-condition work: callers now supply the two Proposition 5 objective
bridges and the full/full source boundary condition directly.
-/
theorem
    paper_interface_proposition5_strategic_academic_merit_source_conditions_of_objective_bridges
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost subFullCostThreshold
      fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    {objective1 objective2 : Policy → Policy → ℝ}
    (hsubFullObjective :
      (objective1 Pfull Pfull ≤ objective1 Psub Pfull ∧
        objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
        paperTheorem3SubFullCondition S policyPair Psub Pfull J2
          groupA groupB populationShare testCost subFullCostThreshold
          capacity2 q1Sub K)
    (hfullSubObjective :
      (objective1 Psub Psub ≤ objective1 Pfull Psub ∧
        objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
        paperTheorem3FullSubCondition S policyPair Psub Pfull groupA groupB
          testCost fullSubLowCostThreshold fullSubHighCostThreshold
          q1Sub q2Sub K)
    (hfullFull :
      paperTheorem3FullFullCondition S Pfull groupA groupB testCost) :
    paperProposition5StrategicAcademicMeritSourceConditions S policyPair Psub
      Pfull J2 groupA groupB populationShare testCost subFullCostThreshold
      fullSubLowCostThreshold fullSubHighCostThreshold capacity2 q1Sub q2Sub K
      objective1 objective2 := by
  exact ⟨hsubFullObjective, hfullSubObjective, hfullFull⟩

/--
Existential Proposition 5 source surface from already-verified objective
bridges and a full/full source condition.
-/
theorem
    paper_interface_proposition5_strategic_academic_merit_source_conditions_exists_of_objective_bridges
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ} {K : Group → ℝ → ℝ}
    {objective1 objective2 : Policy → Policy → ℝ}
    (hsubFullObjective :
      ∃ subFullCostThreshold : Group → ℝ,
        (objective1 Pfull Pfull ≤ objective1 Psub Pfull ∧
          objective2 Psub Psub ≤ objective2 Psub Pfull) ↔
          paperTheorem3SubFullCondition S policyPair Psub Pfull J2
            groupA groupB populationShare testCost subFullCostThreshold
            capacity2 q1Sub K)
    (hfullSubObjective :
      ∃ fullSubLowCostThreshold fullSubHighCostThreshold : Group → ℝ,
        (objective1 Psub Psub ≤ objective1 Pfull Psub ∧
          objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
          paperTheorem3FullSubCondition S policyPair Psub Pfull groupA groupB
            testCost fullSubLowCostThreshold fullSubHighCostThreshold
            q1Sub q2Sub K)
    (hfullFull :
      paperTheorem3FullFullCondition S Pfull groupA groupB testCost) :
    paperProposition5StrategicAcademicMeritSourceConditionsExists S
      policyPair Psub Pfull J2 groupA groupB populationShare testCost
      capacity2 q1Sub q2Sub K objective1 objective2 := by
  rcases hsubFullObjective with ⟨subFullCostThreshold, hsubFull⟩
  rcases hfullSubObjective with
    ⟨fullSubLowCostThreshold, fullSubHighCostThreshold, hfullSub⟩
  exact
    ⟨subFullCostThreshold, fullSubLowCostThreshold,
      fullSubHighCostThreshold, hsubFull, hfullSub, hfullFull⟩

/--
Existential Proposition 5 source surface from threshold-construction objective
bridges and positive group costs.
