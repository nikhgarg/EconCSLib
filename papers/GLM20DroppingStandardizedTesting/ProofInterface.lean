/--
Paper Lemma 1: estimated skill.

Paper statement: for feature set `S`, estimated skill is the
precision-weighted posterior mean, and group-conditional estimated skill is
normal with mean `μ` and variance
`σ^2 * sum_signal_precision / posterior_precision`.
-/
theorem paper_interface_lemma1_estimated_skill_gaussian
    {Feature : Type*} [Fintype Feature] [Nonempty Feature]
    (M : GaussianOffsetSignalFamily Feature) (theta : Feature → ℝ) :
    M.posteriorMean theta =
        (M.centeredFamily.priorPrecision * M.priorMean +
          ∑ k : Feature,
            M.centeredFamily.signalPrecision k * (theta k - M.noiseMean k)) /
          M.centeredFamily.posteriorPrecision ∧
      (M.posteriorMeanLaw).mean = M.priorMean ∧
        (M.posteriorMeanLaw).variance =
          M.priorVar *
              (∑ k : Feature, M.centeredFamily.signalPrecision k) /
            M.centeredFamily.posteriorPrecision :=
  paper_lemma1_estimated_skill_gaussian M theta

/--
Paper Lemma 1, source-surface endpoint.

Paper statement: the Bayesian estimated skill is the precision-weighted
posterior mean, and the group/policy estimated-skill distribution is normal
with the displayed mean and variance.  The source surface here is the canonical
surface generated by the group/policy Gaussian families, so its precision,
estimated-skill mean, and estimated-skill variance fields are the displayed
Lemma 1 quantities.
-/
theorem paper_interface_lemma1_estimated_skill_source_surface
    {Group Policy Feature : Type*} [Fintype Feature] [Nonempty Feature]
    (M : Group → Policy → GaussianOffsetSignalFamily Feature)
    (populationShareB capacity : ℝ) (g : Group) (P : Policy)
    (theta : Feature → ℝ) :
    let S := lemma1GaussianSourceSurface M populationShareB capacity
    (M g P).posteriorMean theta =
        ((M g P).centeredFamily.priorPrecision * (M g P).priorMean +
          ∑ k : Feature,
            (M g P).centeredFamily.signalPrecision k *
              (theta k - (M g P).noiseMean k)) /
          (M g P).centeredFamily.posteriorPrecision ∧
      S.precision g P = (M g P).centeredFamily.signalPrecisionSum ∧
        S.estimatedSkillMean g P = (M g P).priorMean ∧
          S.estimatedSkillVariance g P =
            (M g P).priorVar *
                (∑ k : Feature, (M g P).centeredFamily.signalPrecision k) /
              (M g P).centeredFamily.posteriorPrecision :=
  paper_lemma1_estimated_skill_source_surface M populationShareB capacity g P theta

/--
Paper Lemma 1 monotonicity support: fixing all other features, estimated skill
is strictly increasing in the selected feature value.
-/
theorem paper_interface_lemma1_estimated_skill_strictMono_feature
    {Feature : Type*} [Fintype Feature] [DecidableEq Feature]
    (M : GaussianOffsetSignalFamily Feature) (theta : Feature → ℝ) (k : Feature) :
    StrictMono (fun value : ℝ =>
      M.posteriorMean (Function.update theta k value)) :=
  paper_lemma1_estimated_skill_strictMono_feature M theta k

/--
Fixed-policy threshold support: a positive-slope affine estimated-skill score
clears the paper's threshold exactly above the induced cutoff.
-/
theorem paper_interface_fixed_policy_affine_score_threshold_iff_cutoff
    {intercept slope threshold score : ℝ} (hslope : 0 < slope) :
    threshold ≤ intercept + slope * score ↔
      EconCSLib.affineCutoff intercept slope threshold ≤ score :=
  paper_fixed_policy_affine_score_threshold_iff_cutoff hslope

/--
Gaussian fixed-feature threshold support: with all other features fixed,
admission by estimated skill is equivalent to one feature clearing the induced
cutoff.
-/
theorem paper_interface_fixed_feature_gaussian_threshold_iff_cutoff
    {Feature : Type*} [Fintype Feature] [DecidableEq Feature]
    (M : GaussianOffsetSignalFamily Feature) (theta : Feature → ℝ) (k : Feature)
    (base threshold value : ℝ) :
    threshold ≤ M.posteriorMean (Function.update theta k value) ↔
      EconCSLib.affineCutoff
        (M.posteriorMean (Function.update theta k base) -
          M.centeredFamily.signalWeight k * base)
        (M.centeredFamily.signalWeight k) threshold ≤ value :=
  paper_fixed_feature_gaussian_threshold_iff_cutoff M theta k base threshold value

