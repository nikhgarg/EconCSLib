student cutoffs lie above the test-free admission threshold is impossible
when the full/full applicant mass fills the capacity equation.

This is the paper proof's capacity contradiction: strict decrease of `K_g`
would make the weighted full/full mass strictly smaller than capacity.
-/
theorem paper_interface_proposition5_both_fullFull_cutoff_cases_impossible_of_weighted_capacity
    {Group : Type*} {groupA groupB : Group}
    {populationShare : Group → ℝ} {capacity qSub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff massFullFull : Group → ℝ}
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassA :
      massFullFull groupA =
        paperTheorem3K api (subEstimateLaw groupA) (fullFullCutoff groupA))
    (hmassB :
      massFullFull groupB =
        paperTheorem3K api (subEstimateLaw groupB) (fullFullCutoff groupB))
    (hcapacity :
      capacity =
        populationShare groupA * paperTheorem3K api (subEstimateLaw groupA) qSub +
          populationShare groupB * paperTheorem3K api (subEstimateLaw groupB) qSub)
    (hfill :
      capacity ≤
        populationShare groupA * massFullFull groupA +
          populationShare groupB * massFullFull groupB)
    (hcutoffA : qSub < fullFullCutoff groupA)
    (hcutoffB : qSub < fullFullCutoff groupB) : False := by
  exact
    paper_proposition5_both_fullFull_cutoff_cases_impossible_of_weighted_capacity
      (K := fun g q => paperTheorem3K api (subEstimateLaw g) q)
      hshareA hshareB
      (by
        simpa [paperTheorem3K] using
          glm20StrategicSubEstimateMassAbove_strictAnti api
            (subEstimateLaw groupA))
      (by
        simpa [paperTheorem3K] using
          glm20StrategicSubEstimateMassAbove_strictAnti api
            (subEstimateLaw groupB))
      hmassA hmassB hcapacity hfill hcutoffA hcutoffB

