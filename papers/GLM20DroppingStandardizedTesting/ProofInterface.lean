/--
Proposition 8(i), affirmative action under a fixed testing policy: if the
target-diversity constraint raises group A's threshold and lowers group B's
threshold, the individual-fairness gap improves at every skill level.
-/
theorem paper_interface_proposition8_individual_fairness_gap_improves_of_admission_probabilities
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {Pbase Paa : Policy}
    {admitABase admitBBase admitAAA admitBAA : ℝ → ℝ}
    (hgapBase :
      ∀ q : ℝ, S.individualFairnessGap Pbase q =
        admitABase q - admitBBase q)
    (hgapAA :
      ∀ q : ℝ, S.individualFairnessGap Paa q =
        admitAAA q - admitBAA q)
    (hA : ∀ q : ℝ, admitAAA q < admitABase q)
    (hB : ∀ q : ℝ, admitBBase q < admitBAA q) :
    ∀ q : ℝ,
      S.individualFairnessGap Paa q <
        S.individualFairnessGap Pbase q :=
  paper_proposition8_individual_fairness_gap_improves_of_admission_probabilities
    hgapBase hgapAA hA hB

/--
Proposition 8(i) displayed cutoff algebra: with group-specific affirmative
action thresholds, the Gaussian standardized-threshold comparison is equivalent
to the paper's skill cutoff.
-/
theorem paper_interface_proposition8_standardized_threshold_lt_iff_skill_above_cutoff
    {priorPrecision sqrtPrecB sqrtPrecA thresholdA thresholdB mean q : ℝ}
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hgap : sqrtPrecB < sqrtPrecA) :
    priorPrecision * (thresholdA - mean) / sqrtPrecA +
        sqrtPrecA * (thresholdA - q) <
      priorPrecision * (thresholdB - mean) / sqrtPrecB +
        sqrtPrecB * (thresholdB - q) ↔
      ((priorPrecision + sqrtPrecA ^ 2) / sqrtPrecA * thresholdA -
            (priorPrecision + sqrtPrecB ^ 2) / sqrtPrecB * thresholdB) /
          (sqrtPrecA - sqrtPrecB) +
        mean * priorPrecision / (sqrtPrecA * sqrtPrecB) <
        q :=
  paper_proposition8_standardized_threshold_lt_iff_skill_above_cutoff
    hsqrtB_pos hsqrtA_pos hgap

/--
Proposition 8(i), paper-facing positive-gap formula: the affirmative-action
individual-fairness gap is positive exactly above the displayed skill cutoff.
-/
theorem paper_interface_proposition8_individual_fairness_gap_pos_iff_skill_above_cutoff
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {Paa : Policy}
    {L_A L_B : GaussianScaleLaw}
    {priorPrecision sqrtPrecB sqrtPrecA thresholdA thresholdB mean q : ℝ}
    (hgap_eq :
      S.individualFairnessGap Paa q =
        api.thresholdPassProb L_A thresholdA -
          api.thresholdPassProb L_B thresholdB)
    (hstdA :
      L_A.standardize thresholdA =
        priorPrecision * (thresholdA - mean) / sqrtPrecA +
          sqrtPrecA * (thresholdA - q))
    (hstdB :
      L_B.standardize thresholdB =
        priorPrecision * (thresholdB - mean) / sqrtPrecB +
          sqrtPrecB * (thresholdB - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hprecision_gap : sqrtPrecB < sqrtPrecA) :
    0 < S.individualFairnessGap Paa q ↔
      ((priorPrecision + sqrtPrecA ^ 2) / sqrtPrecA * thresholdA -
            (priorPrecision + sqrtPrecB ^ 2) / sqrtPrecB * thresholdB) /
          (sqrtPrecA - sqrtPrecB) +
        mean * priorPrecision / (sqrtPrecA * sqrtPrecB) <
        q :=
  paper_proposition8_individual_fairness_gap_pos_iff_skill_above_cutoff
    api hgap_eq hstdA hstdB hsqrtB_pos hsqrtA_pos hprecision_gap

/--
Proposition 8(ii): convex-combination support for the statement that admitted
group-B academic merit is below admitted group-A academic merit under
affirmative action.
-/
theorem paper_interface_proposition8_groupB_academic_merit_lt_groupA_of_tail_decomposition
    {meritA meritB intervalMeanB tailMeanBHigh weight : ℝ}
    (hweight_nonneg : 0 ≤ weight) (hweight_lt_one : weight < 1)
    (hinterval_lt_tailB : intervalMeanB < tailMeanBHigh)
    (htailB_lt_A : tailMeanBHigh < meritA)
    (hmeritB :
      meritB =
        weight * intervalMeanB + (1 - weight) * tailMeanBHigh) :
    meritB < meritA :=
  paper_proposition8_groupB_academic_merit_lt_groupA_of_tail_decomposition
    hweight_nonneg hweight_lt_one hinterval_lt_tailB htailB_lt_A hmeritB

