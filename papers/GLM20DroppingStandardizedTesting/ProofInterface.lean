/--
Paper Theorem 2(ii), high-skill individual-fairness statement in the main-text
direction.

The theorem text says that after dropping tests the individual-fairness gap
increases above a high-skill threshold.  This wrapper states that direction
directly, conditional on the matching eventual delta inequality.  The appendix
proof in the cached source derives the opposite direction, which remains
exposed by the full no-barrier source-surface theorem below.
-/
theorem paper_interface_theorem2_high_skill_individual_fairness_gap_sub_gt_full_source_surface
    {Group Policy : Type*} [DecidableEq Group] [DecidableEq Policy]
    (groupA groupB : Group) {Psub Pfull : Policy}
    {pi capacity quantile leftWeight priorPrecision subA subB testA testB : ℝ}
    {interceptAFull slopeAFull interceptASub slopeASub
      interceptBFull slopeBFull interceptBSub slopeBSub : ℝ}
    {L_A_sub L_A_full L_B_sub L_B_full : GaussianScaleLaw}
    {thresholdSub thresholdFull qDelta : ℝ}
    (hP_ne : Psub ≠ Pfull)
    (hslopeA : slopeASub < slopeAFull)
    (hslopeB : slopeBSub < slopeBFull)
    (hdelta :
      ∀ q : ℝ, qDelta < q →
        standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q -
            standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q <
          standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q -
            standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q) :
    let S : GLM20SourcePolicySurface Group Policy :=
      theorem2NoBarrierSourceSurface groupA groupB Psub Pfull
        pi capacity quantile leftWeight priorPrecision subA subB testA testB
        interceptAFull slopeAFull interceptASub slopeASub
        interceptBFull slopeBFull interceptBSub slopeBSub
        L_A_sub L_A_full L_B_sub L_B_full thresholdSub thresholdFull
    ∃ qA qB : ℝ,
      (∀ q : ℝ,
        standardGaussianDerivativeAPI.affineUpperTail interceptAFull slopeAFull q >
            standardGaussianDerivativeAPI.affineUpperTail interceptASub slopeASub q ↔
          qA < q) ∧
      (∀ q : ℝ,
        standardGaussianDerivativeAPI.affineUpperTail interceptBFull slopeBFull q >
            standardGaussianDerivativeAPI.affineUpperTail interceptBSub slopeBSub q ↔
          qB < q) ∧
      ∃ qhat : ℝ, max qA qB ≤ qhat ∧
        ∀ q : ℝ, qhat < q →
          S.individualFairnessGap Psub q >
            S.individualFairnessGap Pfull q :=
  paper_theorem2_high_skill_individual_fairness_gap_sub_gt_full_source_surface
    groupA groupB hP_ne hslopeA hslopeB hdelta

/--
Paper Theorem 2(ii), main-text high-skill direction proved from the
prose-consistent same-side slope assumption.

Paper statement: after dropping the test, the individual-fairness gap
`I(q; P_sub)` exceeds `I(q; P_full)` for sufficiently high skill `q`.

Lean statement: this is proved when both policies' precision order favors
group A (`slopeBFull < slopeAFull` and `slopeBSub < slopeASub`) and the
test increases group B's slope (`slopeBSub < slopeBFull`).  The extra
test-free precision-order assumption is the one present in the prose/model
reading but not explicit in the theorem statement.
-/
