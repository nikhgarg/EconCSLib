    hP_ne hcapacity_pos hpi_pos hpi_lt_one hgammaA_pos hgammaB_pos
    hcapacity_lt_groupA hselectiveA_worst hselectiveB_worst hscaleA_pos
    hxiA_pos hrhoA_nonneg hrhoA_lt_one hscaleB_pos hxiB_pos hone_lt_rhoB

