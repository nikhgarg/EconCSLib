    (hcapacity_pos : 0 < capacity)
    (hgroupA_pos : 0 < groupAEligibleMass)
    (hgroupB_pos : 0 < groupBShare)
    (hcapacity_eq :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        capacity =
          groupAEligibleMass *
              H.api.thresholdPassProb L_A (threshold γB) +
            groupBShare * γB *
              H.api.thresholdPassProb L_B (threshold γB))
    (hdiversity_share :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        fullDiversity γB =
          groupBShare * γB *
            H.api.thresholdPassProb L_B (threshold γB) / capacity)
    (hdiversity :
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ fullDiversity γB < diversitySub)
    (hscaleA_pos : 0 < scaleA)
    (hxiA_pos : 0 < xiA)
    (hfullA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMeritA γ =
          baseA + scaleA *
            H.hazard
              (theorem1BetaGroupA Q capacity ownShareA otherEligibleMassA rhoA γ))
    (hsubA :
      subMeritA = baseA + scaleA * (xiA * H.hazard benchmarkA))
    (himprovesA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        meritImprovesA γ ↔ fullMeritA γ ≤ subMeritA)
    (hownA_pos : 0 < ownShareA)
    (hotherA_pos : 0 < otherEligibleMassA)
    (hrhoA_nonneg : 0 ≤ rhoA) (hrhoA_lt_one : rhoA < 1)
    (hselectiveA :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
