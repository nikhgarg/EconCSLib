theorem paper_interface_proposition3_owenFirstMomentIntegral_eq_of_integrable
    (a b sigmaTilde mu qFull : ℝ)
    (hleft :
      let c := sigmaTilde * b
      let denom := Real.sqrt (1 + c ^ 2)
      let A := (a + b * mu) / denom
      IntegrableOn
        ((fun z : ℝ => standardGaussianCDF (A * denom + c * z)) *
          (fun z : ℝ => -z * standardGaussianDensity z))
        (Set.Ioi qFull))
    (hprod :
      let c := sigmaTilde * b
      let denom := Real.sqrt (1 + c ^ 2)
      let A := (a + b * mu) / denom
      IntegrableOn
        ((fun z : ℝ => c * standardGaussianDensity (A * denom + c * z)) *
          standardGaussianDensity)
        (Set.Ioi qFull)) :
    paperProposition3OwenFirstMomentIntegral
        a b sigmaTilde mu qFull =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity qFull *
           standardGaussianCDF (A * denom + c * qFull) +
         c * (standardGaussianDensity A * denom⁻¹ *
           (1 - standardGaussianCDF (denom * qFull + A * c)))) :=
  glm20Proposition3OwenFirstMomentIntegral_eq_of_integrable
    a b sigmaTilde mu qFull hleft hprod

