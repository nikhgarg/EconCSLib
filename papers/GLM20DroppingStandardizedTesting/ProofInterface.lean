/--
Proposition 1 individual-fairness algebra: the standardized-threshold
comparison is equivalent to the paper's skill cutoff inequality.
-/
theorem paper_interface_proposition1_standardized_threshold_lt_iff_skill_above_cutoff
    {priorPrecision sqrtPrecB sqrtPrecA threshold mean q : ℝ}
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hgap : sqrtPrecB < sqrtPrecA) :
    priorPrecision * (threshold - mean) / sqrtPrecA +
        sqrtPrecA * (threshold - q) <
      priorPrecision * (threshold - mean) / sqrtPrecB +
        sqrtPrecB * (threshold - q) ↔
      threshold -
          priorPrecision * (threshold - mean) / (sqrtPrecB * sqrtPrecA) <
        q :=
  paper_proposition1_standardized_threshold_lt_iff_skill_above_cutoff
    hsqrtB_pos hsqrtA_pos hgap

/--
Proposition 1 individual-fairness-gap core: once the standardized thresholds
are in the paper's precision form, the admission-probability gap is positive
exactly above the skill cutoff.
-/
theorem paper_interface_proposition1_tail_gap_pos_iff_skill_above_cutoff
    (api : StandardGaussianCDFAPI)
    {L_A L_B : GaussianScaleLaw}
    {priorPrecision sqrtPrecB sqrtPrecA threshold mean q : ℝ}
    (hstdA :
      L_A.standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecA +
          sqrtPrecA * (threshold - q))
    (hstdB :
      L_B.standardize threshold =
        priorPrecision * (threshold - mean) / sqrtPrecB +
          sqrtPrecB * (threshold - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hgap : sqrtPrecB < sqrtPrecA) :
    0 < api.thresholdPassProb L_A threshold -
        api.thresholdPassProb L_B threshold ↔
      threshold -
          priorPrecision * (threshold - mean) / (sqrtPrecB * sqrtPrecA) <
        q :=
  paper_proposition1_tail_gap_pos_iff_skill_above_cutoff
    api hstdA hstdB hsqrtB_pos hsqrtA_pos hgap

