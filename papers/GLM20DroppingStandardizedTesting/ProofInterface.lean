theorem paper_interface_proposition2_j2MassAboveHighCutoff_eq_lowerLeftRectangle_of_subEligibleMass
    {populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub
      sigmaTilde aHatQ2 b q1Full : ℝ}
    (hsub :
      paperProposition2SubEligibleMassFormula standardGaussianCDFAPI
        populationShare mu priorSigma priorPrecision subPrecisionSum q2Sub =
          populationShare * sigmaTilde *
            standardGaussianCDF
              ((aHatQ2 + b * mu) /
