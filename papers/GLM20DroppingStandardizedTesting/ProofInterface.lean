    (hscaleB_pos : 0 < scaleB)
    (hxiB_pos : 0 < xiB)
    (hfullB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        fullMeritB γ =
          baseB + scaleB *
            H.hazard
              (theorem1BetaGroupB Q capacity ownShareB otherEligibleMassB rhoB γ))
    (hsubB :
      subMeritB = baseB + scaleB * (xiB * H.hazard benchmarkB))
    (himprovesB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        meritImprovesB γ ↔ fullMeritB γ ≤ subMeritB)
    (hownB_pos : 0 < ownShareB)
    (hotherB_pos : 0 < otherEligibleMassB)
    (hone_lt_rhoB : 1 < rhoB)
    (hselectiveB :
      ∀ γ ∈ Set.Icc (0 : ℝ) 1,
        2 * capacity < ownShareB * γ + otherEligibleMassB) :
    (∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        diversityImproves γB ↔ γB < γbar) ∧
      (∃ γbarA : ℝ,
        ∀ γA ∈ Set.Icc (0 : ℝ) 1,
          meritImprovesA γA ↔ γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          meritImprovesB γB ↔ γB ≤ γbarB) :=
  paper_theorem1_dropping_tests_with_barriers_main_thresholds
    H Q hfull_cont hcapacity_pos hgroupA_pos hgroupB_pos hcapacity_eq
    hdiversity_share hdiversity hscaleA_pos hxiA_pos hfullA hsubA himprovesA
    hownA_pos hotherA_pos hrhoA_nonneg hrhoA_lt_one hselectiveA
    hscaleB_pos hxiB_pos hfullB hsubB himprovesB hownB_pos hotherB_pos
    hone_lt_rhoB hselectiveB

