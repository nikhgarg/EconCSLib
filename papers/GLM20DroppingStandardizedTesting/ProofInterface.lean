theorem paper_interface_proposition6_j1_drops_test_iff_full_formula_lt_testFreeGroupBTail
    (api : StandardGaussianCDFAPI) (Q : StandardGaussianQuantileAPI)
    (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    {schoolJ1DropsTest : Prop}
