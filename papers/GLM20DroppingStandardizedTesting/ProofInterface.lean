    hdiversity_ratio hprior_pos hsubA_pos hsubB_pos htestA_pos htestB_pos

/--
Paper Theorem 2(i), closed-form Gaussian-tail version: the paper's displayed
tail formulas for diversity under `P_sub` and `P_full` imply the exact
Equation (3) test-precision ratio condition.
-/
theorem paper_interface_theorem2_diversity_tail_formula_improves_iff_test_precision_ratio
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {Psub Pfull : Policy}
    {quantile leftWeight pi priorPrecision subA subB testA testB : ℝ}
    (hdiversitySub :
      S.diversity Psub =
        1 - api.cdf
          (quantile * Real.sqrt
            (leftWeight *
                ((subA / (priorPrecision + subA)) /
                  (subB / (priorPrecision + subB))) +
              pi)))
    (hdiversityFull :
      S.diversity Pfull =
        1 - api.cdf
          (quantile * Real.sqrt
            (leftWeight *
                (((subA + testA) /
                    (priorPrecision + subA + testA)) /
                  ((subB + testB) /
                    (priorPrecision + subB + testB))) +
              pi)))
    (hquantile_pos : 0 < quantile)
    (hleftWeight_pos : 0 < leftWeight)
    (htermSub_nonneg :
      0 ≤
        leftWeight *
            ((subA / (priorPrecision + subA)) /
              (subB / (priorPrecision + subB))) +
          pi)
    (htermFull_nonneg :
      0 ≤
        leftWeight *
            (((subA + testA) /
                (priorPrecision + subA + testA)) /
              ((subB + testB) /
                (priorPrecision + subB + testB))) +
          pi)
    (hprior_pos : 0 < priorPrecision)
    (hsubA_pos : 0 < subA) (hsubB_pos : 0 < subB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB) :
    S.diversity Psub > S.diversity Pfull ↔
      (subA * (priorPrecision + subA + testA)) /
          (subB * (priorPrecision + subB + testB)) <
        testA / testB :=
  paper_theorem2_diversity_tail_formula_improves_iff_test_precision_ratio
    api hdiversitySub hdiversityFull hquantile_pos hleftWeight_pos
    htermSub_nonneg htermFull_nonneg hprior_pos hsubA_pos hsubB_pos
    htestA_pos htestB_pos

