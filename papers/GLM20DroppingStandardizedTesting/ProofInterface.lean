/--
Paper Proposition 2(iv) source definition of `a'_g(q)` in the displayed
`kappa` formula.
-/
abbrev paperProposition2KappaAPrime
    (priorPrecision subPrecisionSum mu q : ℝ) : ℝ :=
  glm20Proposition2KappaAPrime priorPrecision subPrecisionSum mu q

/--
Paper Proposition 2(iv) source definition of `b'_g` in the displayed `kappa`
formula.
-/
abbrev paperProposition2KappaBPrime
    (subPrecisionSum : ℝ) : ℝ :=
  glm20Proposition2KappaBPrime subPrecisionSum

/--
Paper Proposition 2(iv) source-prime algebra: the displayed `b'_g` squared is
the sub-test precision sum.
-/
theorem paper_interface_proposition2_kappaBPrime_sq
    {subPrecisionSum : ℝ} (hsub : 0 ≤ subPrecisionSum) :
    paperProposition2KappaBPrime subPrecisionSum ^ 2 =
      subPrecisionSum :=
  glm20Proposition2KappaBPrime_sq hsub

/--
Paper Proposition 2(iv) source-prime denominator algebra:
`sqrt(1 + (sigma_tilde_g b'_g)^2)` reduces to the raw precision-sum form.
-/
theorem paper_interface_proposition2_kappaSourceDenom_eq
    {sigmaTilde subPrecisionSum : ℝ} (hsub : 0 ≤ subPrecisionSum) :
    Real.sqrt
        (1 +
          (sigmaTilde *
            paperProposition2KappaBPrime subPrecisionSum) ^ 2) =
      Real.sqrt (1 + sigmaTilde ^ 2 * subPrecisionSum) :=
  glm20Proposition2KappaSourceDenom_eq hsub

/--
Paper Proposition 2(iv) source-prime numerator algebra:
substituting the displayed definitions of `a'_g(q)` and `b'_g` yields the
raw precision-sum numerator used in the lower-left Gaussian argument.
-/
theorem paper_interface_proposition2_kappaAPrime_add_BPrime_mul_mu
    {priorPrecision subPrecisionSum mu q : ℝ}
    (hsub : 0 < subPrecisionSum) :
    paperProposition2KappaAPrime priorPrecision subPrecisionSum mu q +
        paperProposition2KappaBPrime subPrecisionSum * mu =
      (priorPrecision + subPrecisionSum) * (mu - q) /
        Real.sqrt subPrecisionSum :=
  glm20Proposition2KappaAPrime_add_BPrime_mul_mu hsub

/--
Paper Proposition 2(iv) source-prime lower-left mass in raw precision-sum
notation, used in the displayed normalization `tau_g = 1 - Phi_2(...)`.
-/
abbrev paperProposition2KappaSourceLowerLeftMass
    (priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull : ℝ) : ℝ :=
  glm20Proposition2KappaSourceLowerLeftMass
    priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull

/--
Paper Proposition 2(iv) source-prime normalization
`tau_g = 1 - Phi_2(...)` in raw precision-sum notation.
-/
abbrev paperProposition2KappaSourceTau
    (priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull : ℝ) : ℝ :=
  glm20Proposition2KappaSourceTau
    priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull

/--
Paper Proposition 2(iv) source-prime lower-left mass equals the same mass
written with the displayed `a'_g(q)` and `b'_g` definitions.
-/
theorem paper_interface_proposition2_kappaSourceLowerLeftMass_eq_sourcePrimes
    {priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull : ℝ}
    (hsub : 0 < subPrecisionSum) :
    paperProposition2KappaSourceLowerLeftMass
        priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull =
      lowerLeftRectangleMass
        (paperCorrelatedStandardGaussianLaw
          (-(sigmaTilde *
                paperProposition2KappaBPrime subPrecisionSum) /
            Real.sqrt
              (1 +
                (sigmaTilde *
                  paperProposition2KappaBPrime subPrecisionSum) ^ 2)))
        (((paperProposition2KappaAPrime
                priorPrecision subPrecisionSum mu q2Sub) +
              paperProposition2KappaBPrime subPrecisionSum * mu) /
          Real.sqrt
            (1 +
              (sigmaTilde *
                paperProposition2KappaBPrime subPrecisionSum) ^ 2))
        ((qFull - mu) / sigmaTilde) :=
  glm20Proposition2KappaSourceLowerLeftMass_eq_sourcePrimes hsub

/--
Paper Proposition 2(iv) source-prime tau normalization equals the displayed
`1 - Phi_2(...)` expression after substituting `a'_g(q)` and `b'_g`.
-/
theorem paper_interface_proposition2_kappaSourceTau_eq_sourcePrimes
    {priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull : ℝ}
    (hsub : 0 < subPrecisionSum) :
    paperProposition2KappaSourceTau
        priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull =
      1 -
        lowerLeftRectangleMass
          (paperCorrelatedStandardGaussianLaw
            (-(sigmaTilde *
                  paperProposition2KappaBPrime subPrecisionSum) /
              Real.sqrt
                (1 +
                  (sigmaTilde *
                    paperProposition2KappaBPrime subPrecisionSum) ^ 2)))
          (((paperProposition2KappaAPrime
                  priorPrecision subPrecisionSum mu q2Sub) +
                paperProposition2KappaBPrime subPrecisionSum * mu) /
            Real.sqrt
              (1 +
                (sigmaTilde *
                  paperProposition2KappaBPrime subPrecisionSum) ^ 2))
          ((qFull - mu) / sigmaTilde) :=
  glm20Proposition2KappaSourceTau_eq_sourcePrimes hsub

/--
Paper Proposition 2(iv) reuses the full-policy admitted academic-merit formula
`lambda(a_g(q_{1,full}^*), b_g, sigma_tilde_g, tau_g)` from Proposition 3.
-/
abbrev paperProposition2FullPolicyLambdaFormula
    (api : StandardGaussianCDFAPI)
    (a b sigmaTilde tau mu qFull : ℝ) : ℝ :=
  glm20Proposition3LambdaFormula api a b sigmaTilde tau mu qFull

/--
Paper Proposition 2(iv) / Proposition 3 first-moment formula obtained from
the upper-tail Owen calculation.  This differs from the source-displayed
`lambda` by the explicit boundary term exposed below.
-/
abbrev paperProposition2FullPolicyLambdaOwenFirstMomentFormula
    (api : StandardGaussianCDFAPI)
    (a b sigmaTilde tau mu qFull : ℝ) : ℝ :=
  glm20Proposition3LambdaOwenFirstMomentFormula
    api a b sigmaTilde tau mu qFull

/--
Paper-facing audit theorem: the source-displayed `lambda` formula is missing
exactly one upper-tail first-moment boundary term.
-/
theorem paper_interface_proposition2_lambda_owenFirstMomentFormula_eq_lambdaFormula_add_boundaryTerm
    (api : StandardGaussianCDFAPI)
    (a b sigmaTilde tau mu qFull : ℝ) :
    paperProposition2FullPolicyLambdaOwenFirstMomentFormula api
        a b sigmaTilde tau mu qFull =
      paperProposition2FullPolicyLambdaFormula api
          a b sigmaTilde tau mu qFull +
        (let denom := Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)
         let A := (a + b * mu) / denom
         sigmaTilde ^ 2 * b / (tau * denom) * api.density A) :=
  glm20Proposition3LambdaOwenFirstMomentFormula_eq_lambdaFormula_add_boundaryTerm
    api a b sigmaTilde tau mu qFull

/--
Paper Proposition 2(iv) first-moment support: the finite-interval
source-affine integral used for the `kappa` academic-merit term.
-/
abbrev paperProposition2OwenFirstMomentInterval
    (a b sigmaTilde mu lower upper : ℝ) : ℝ :=
  glm20Proposition2OwenFirstMomentInterval
    a b sigmaTilde mu lower upper

/--
Paper Proposition 2(iv) product-density support on the same finite interval.
-/
abbrev paperProposition2OwenProductInterval
    (a b sigmaTilde mu lower upper : ℝ) : ℝ :=
  glm20Proposition2OwenProductInterval
    a b sigmaTilde mu lower upper

/--
Paper-facing finite-interval product-density identity for the `kappa` route.
-/
theorem paper_interface_proposition2_owenProductInterval_eq
    (a b sigmaTilde mu lower upper : ℝ) (hlower_upper : lower ≤ upper) :
    paperProposition2OwenProductInterval
        a b sigmaTilde mu lower upper =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity A * denom⁻¹ *
        (standardGaussianCDF (denom * upper + A * c) -
          standardGaussianCDF (denom * lower + A * c))) :=
  glm20Proposition2OwenProductInterval_eq
    a b sigmaTilde mu lower upper hlower_upper

/--
Paper-facing finite-interval first-moment identity for the `kappa` route,
proved by subtracting two upper-tail first-moment formulas.
-/
theorem paper_interface_proposition2_owenFirstMomentInterval_eq
    (a b sigmaTilde mu lower upper : ℝ) (hlower_upper : lower ≤ upper) :
    paperProposition2OwenFirstMomentInterval
        a b sigmaTilde mu lower upper =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity lower *
           standardGaussianCDF (A * denom + c * lower) +
         c * (standardGaussianDensity A * denom⁻¹ *
           (1 - standardGaussianCDF (denom * lower + A * c)))) -
        (let c := sigmaTilde * b
         let denom := Real.sqrt (1 + c ^ 2)
         let A := (a + b * mu) / denom
         standardGaussianDensity upper *
             standardGaussianCDF (A * denom + c * upper) +
           c * (standardGaussianDensity A * denom⁻¹ *
             (1 - standardGaussianCDF (denom * upper + A * c)))) :=
  glm20Proposition2OwenFirstMomentInterval_eq
    a b sigmaTilde mu lower upper hlower_upper

/--
Paper Proposition 2(iv) product-density support on the lower tail appearing
directly in the displayed `kappa` calculation.
-/
abbrev paperProposition2OwenProductLowerTail
    (a b sigmaTilde mu upper : ℝ) : ℝ :=
  glm20Proposition2OwenProductLowerTail
    a b sigmaTilde mu upper

/--
Paper-facing lower-tail product-density identity for the `kappa` route.
-/
theorem paper_interface_proposition2_owenProductLowerTail_eq
    (a b sigmaTilde mu upper : ℝ) :
    paperProposition2OwenProductLowerTail
        a b sigmaTilde mu upper =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       standardGaussianDensity A * denom⁻¹ *
        standardGaussianCDF (denom * upper + A * c)) :=
  glm20Proposition2OwenProductLowerTail_eq
    a b sigmaTilde mu upper

/--
Paper Proposition 2(iv) lower-tail selection mass:
`∫_{-∞}^{q} phi(z) Phi(A_g D_g + c_g z) dz`.

This is the mass term in the standardized J2 academic-merit numerator.  The
product-density lower-tail integral above is the derivative term from
integration by parts, not this mass.
-/
abbrev paperProposition2OwenSelectionLowerTail
    (a b sigmaTilde mu upper : ℝ) : ℝ :=
  glm20Proposition2OwenSelectionLowerTail
    a b sigmaTilde mu upper

/--
Paper-facing integral/event bridge for Proposition 2(iv)'s lower-tail
selection mass.
-/
theorem paper_interface_proposition2_owenSelectionLowerTail_eq_owenAffineLowerSelectionMass
    {a b sigmaTilde mu upper qFull : ℝ}
    (hupper : upper = (qFull - mu) / sigmaTilde) :
    paperProposition2OwenSelectionLowerTail a b sigmaTilde mu upper =
      paperProposition2OwenAffineLowerSelectionMass
        sigmaTilde a b mu qFull :=
  glm20Proposition2OwenSelectionLowerTail_eq_owenAffineLowerSelectionMass
    hupper

/--
Paper-facing lower-tail selection integral equals the correlated bivariate
lower-left rectangle after standardizing the full-test cutoff.
-/
theorem paper_interface_proposition2_owenSelectionLowerTail_eq_correlatedStandardGaussian_lowerLeftRectangleMass
    {a b sigmaTilde mu upper qFull : ℝ}
    (hupper : upper = (qFull - mu) / sigmaTilde) :
    paperProposition2OwenSelectionLowerTail a b sigmaTilde mu upper =
      lowerLeftRectangleMass
        (paperCorrelatedStandardGaussianLaw
          (-(sigmaTilde * b) /
            Real.sqrt (1 + (sigmaTilde * b) ^ 2)))
        ((a + b * mu) / Real.sqrt (1 + (sigmaTilde * b) ^ 2))
        ((qFull - mu) / sigmaTilde) :=
  glm20Proposition2OwenSelectionLowerTail_eq_correlatedStandardGaussian_lowerLeftRectangleMass
    hupper

/--
Paper Proposition 2(iv) source tau normalization for the lower-tail selection
mass: after substituting the displayed `a'_g(q)` and `b'_g`, the Owen
lower-tail mass is `1 - tau_g`.
-/
theorem paper_interface_proposition2_owenSelectionLowerTail_eq_one_sub_kappaSourceTau
    {priorPrecision subPrecisionSum sigmaTilde mu upper qFull q2Sub : ℝ}
    (hsub : 0 < subPrecisionSum)
    (hupper : upper = (qFull - mu) / sigmaTilde) :
    paperProposition2OwenSelectionLowerTail
        (paperProposition2KappaAPrime
          priorPrecision subPrecisionSum mu q2Sub)
        (paperProposition2KappaBPrime subPrecisionSum)
        sigmaTilde mu upper =
      1 -
        paperProposition2KappaSourceTau
          priorPrecision subPrecisionSum sigmaTilde mu q2Sub qFull :=
  glm20Proposition2OwenSelectionLowerTail_eq_one_sub_kappaSourceTau
    hsub hupper

/--
Paper Proposition 2(iv) source-parameter tau normalization: after substituting
the displayed `a'_g(q)`, `b'_g`, and `\tilde\sigma_g` source definitions, the
Owen lower-tail mass at the raw full-test cutoff is `1 - tau_g`.
-/
theorem
    paper_interface_proposition2_owenSelectionLowerTail_eq_one_sub_kappaSourceTau_sourceParameters
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum
      mu qFull q2Sub : ℝ}
    (hsub : 0 < subPrecisionSum) :
    paperProposition2OwenSelectionLowerTail
        (paperProposition2KappaAPrime
          priorPrecision subPrecisionSum mu q2Sub)
        (paperProposition2KappaBPrime subPrecisionSum)
        (glm20Proposition3SigmaTildeSource
          priorSigma priorPrecision fullPrecisionSum)
        mu
        ((qFull - mu) /
          glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum) =
      1 -
        paperProposition2KappaSourceTau
          priorPrecision subPrecisionSum
          (glm20Proposition3SigmaTildeSource
            priorSigma priorPrecision fullPrecisionSum)
          mu q2Sub qFull :=
  glm20Proposition2OwenSelectionLowerTail_eq_one_sub_kappaSourceTau_sourceParameters
    hsub

/--
Paper Proposition 2(iv) lower-tail first-moment support:
`∫_{-∞}^{q} z phi(z) Phi(A_g D_g + c_g z) dz`.
-/
abbrev paperProposition2OwenFirstMomentLowerTail
    (a b sigmaTilde mu upper : ℝ) : ℝ :=
  glm20Proposition2OwenFirstMomentLowerTail
    a b sigmaTilde mu upper

/--
Paper-facing lower-tail first-moment identity for the `kappa` route.
-/
theorem paper_interface_proposition2_owenFirstMomentLowerTail_eq
    (a b sigmaTilde mu upper : ℝ) :
    paperProposition2OwenFirstMomentLowerTail
        a b sigmaTilde mu upper =
      (let c := sigmaTilde * b
       let denom := Real.sqrt (1 + c ^ 2)
       let A := (a + b * mu) / denom
       c * (standardGaussianDensity A * denom⁻¹ *
          standardGaussianCDF (denom * upper + A * c)) -
        standardGaussianDensity upper *
          standardGaussianCDF (A * denom + c * upper)) :=
  glm20Proposition2OwenFirstMomentLowerTail_eq
    a b sigmaTilde mu upper

/--
Paper Proposition 2(iv) standardized J2 merit expression before substituting
the closed-form `kappa` formula.
-/
abbrev paperProposition2J2MeritStandardizedLowerTailFormula
    (a b sigmaTilde tau mu upper : ℝ) : ℝ :=
  glm20Proposition2J2MeritStandardizedLowerTailFormula
    a b sigmaTilde tau mu upper

/--
Paper-facing mass bridge for the standardized J2 merit expression: the source
mass identity supplies the paper's `mu * (1 - tau) / tau` term.
-/
theorem paper_interface_proposition2_j2MeritStandardizedLowerTailFormula_eq_scaledFirstMoment_of_mass
    {a b sigmaTilde tau mu upper : ℝ}
    (hmass :
      paperProposition2OwenSelectionLowerTail a b sigmaTilde mu upper =
        1 - tau) :
    paperProposition2J2MeritStandardizedLowerTailFormula
        a b sigmaTilde tau mu upper =
      sigmaTilde / tau *
        paperProposition2OwenFirstMomentLowerTail
          a b sigmaTilde mu upper +
        mu * (1 - tau) / tau :=
  glm20Proposition2J2MeritStandardizedLowerTailFormula_eq_scaledFirstMoment_of_mass
    hmass

/--
Paper Proposition 2(iv) formula `kappa(a'_g(q), b'_g, sigma_tilde_g, tau_g)`
for group `g`'s academic merit at school `J2`.
-/
abbrev paperProposition2KappaFormula
    (api : StandardGaussianCDFAPI)
    (aPrime bPrime sigmaTilde tau mu q1Full q : ℝ) : ℝ :=
  glm20Proposition2KappaFormula api
    aPrime bPrime sigmaTilde tau mu q1Full q

/--
Paper Proposition 2(iv) source-density version of `kappa`, with the boundary
density supplied explicitly.
-/
abbrev paperProposition2KappaBoundaryDensityFormula
    (api : StandardGaussianCDFAPI)
    (aPrime bPrime sigmaTilde tau mu q1Full boundaryDensity : ℝ) : ℝ :=
  glm20Proposition2KappaBoundaryDensityFormula api
    aPrime bPrime sigmaTilde tau mu q1Full boundaryDensity

/-- The source-density `kappa` wrapper specializes to the older formula when
the boundary density is written as `phi(q)`. -/
theorem paper_interface_proposition2_kappaBoundaryDensityFormula_eq_kappaFormula
    (api : StandardGaussianCDFAPI)
    (aPrime bPrime sigmaTilde tau mu q1Full q : ℝ) :
    paperProposition2KappaBoundaryDensityFormula api
        aPrime bPrime sigmaTilde tau mu q1Full (api.density q) =
      paperProposition2KappaFormula api
        aPrime bPrime sigmaTilde tau mu q1Full q :=
