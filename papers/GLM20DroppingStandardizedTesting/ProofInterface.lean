/--
Paper Proposition 2(iii) source affine argument monotonicity: the cutoff order
`q_{2,sub}^* <= q_h^g` implies the corresponding standardized source argument
at `q_h^g` is weakly below the one at `q_{2,sub}^*`.
-/
theorem paper_interface_proposition2_aArgument_source_le_of_q_le
    {priorSigma priorPrecision subPrecisionSum fullPrecisionSum mu
      qHigh q2Sub : ℝ}
    (hprior : 0 < priorPrecision)
    (hsub : 0 < subPrecisionSum)
    (hfull : 0 < fullPrecisionSum)
    (hq : q2Sub ≤ qHigh) :
    (paperProposition2AHatSource
          priorPrecision subPrecisionSum fullPrecisionSum mu qHigh +
        paperProposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum * mu) /
        Real.sqrt
          (1 +
            paperProposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum ^ 2 *
              paperProposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum ^ 2) ≤
      (paperProposition2AHatSource
          priorPrecision subPrecisionSum fullPrecisionSum mu q2Sub +
        paperProposition3BSource
          priorPrecision subPrecisionSum fullPrecisionSum * mu) /
        Real.sqrt
          (1 +
            paperProposition3SigmaTildeSource
                priorSigma priorPrecision fullPrecisionSum ^ 2 *
              paperProposition3BSource
                priorPrecision subPrecisionSum fullPrecisionSum ^ 2) :=
  glm20Proposition2AArgument_source_le_of_q_le hprior hsub hfull hq

