/--
Paper Proposition 3 / Appendix D CDF bookkeeping.

If `Phi(A)` is the first marginal CDF and `Phi_2(A,B;rho)` is the lower-left
bivariate CDF of the transformed joint law, then the displayed bracket
`Phi(A)-Phi_2(A,B;rho)` is the vertical strip mass
`P(Z_1 <= A, B <= Z_2)`, assuming the horizontal boundary has zero mass.
-/
theorem paper_interface_proposition3_selection_core_expr_eq_verticalUpperStripMass_of_cdf_identities
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (jointLaw : Measure (ℝ × ℝ)) [IsFiniteMeasure jointLaw]
    {A B rho : ℝ}
    (hfirst :
      firstCoordinateLowerMass jointLaw A = api.cdf A)
    (hbivar :
      lowerLeftRectangleMass jointLaw A B = bivariateCDF A B rho)
    (hboundary :
      jointLaw.real {p : ℝ × ℝ | p.1 ≤ A ∧ p.2 = B} = 0) :
    api.cdf A - bivariateCDF A B rho =
      verticalUpperStripMass jointLaw A B :=
  paper_proposition3_selection_core_expr_eq_verticalUpperStripMass_of_cdf_identities
    api bivariateCDF jointLaw hfirst hbivar hboundary

/--
Paper Proposition 3 selection-core measure identity for the displayed
`A_g`, `B_g`, and `rho_g`.

This closes the source-event bookkeeping part of the Owen/CDF formula.  The
remaining analytic task is to prove that the concrete transformed Gaussian
law has the stated first marginal CDF and bivariate CDF.
-/
theorem paper_interface_proposition3_selection_core_eq_verticalUpperStripMass_of_cdf_identities
    (api : StandardGaussianCDFAPI) (bivariateCDF : ℝ → ℝ → ℝ → ℝ)
    (jointLaw : Measure (ℝ × ℝ)) [IsFiniteMeasure jointLaw]
    {sigmaTilde a b mu qFull : ℝ}
    (hfirst :
      firstCoordinateLowerMass jointLaw
          ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)) =
        api.cdf
          ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
    (hbivar :
      lowerLeftRectangleMass jointLaw
          ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((qFull - mu) / sigmaTilde) =
        bivariateCDF
          ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((qFull - mu) / sigmaTilde)
          (-(sigmaTilde * b) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
    (hboundary :
      jointLaw.real
          {p : ℝ × ℝ |
            p.1 ≤ (a + b * mu) /
                Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2) ∧
              p.2 = (qFull - mu) / sigmaTilde} = 0) :
    paperProposition3SelectionCore api bivariateCDF sigmaTilde a b mu qFull =
      verticalUpperStripMass jointLaw
        ((a + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
        ((qFull - mu) / sigmaTilde) :=
  paper_proposition3_selection_core_eq_verticalUpperStripMass_of_cdf_identities
    api bivariateCDF jointLaw hfirst hbivar hboundary

