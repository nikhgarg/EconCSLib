/--
Paper Proposition 2(iii) admitted group mass formula for the concrete
bivariate Gaussian CDF.
-/
theorem paper_interface_proposition2_admitted_mass_formula_eq_correlatedStandardGaussian_verticalUpperStripMass
    {populationShare sigmaTilde aHat b mu q1Full : ℝ} :
    paperProposition2AdmittedMassFormula standardGaussianCDFAPI
        paperStandardBivariateGaussianCDF populationShare sigmaTilde aHat b mu
        q1Full =
      populationShare * sigmaTilde *
        verticalUpperStripMass
          (paperCorrelatedStandardGaussianLaw
            (-(sigmaTilde * b) /
              Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2)))
          ((aHat + b * mu) / Real.sqrt (1 + sigmaTilde ^ 2 * b ^ 2))
          ((q1Full - mu) / sigmaTilde) :=
  glm20Proposition2AdmittedMassFormula_eq_correlatedStandardGaussian_verticalUpperStripMass

