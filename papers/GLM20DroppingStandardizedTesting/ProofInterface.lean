/--
Paper Proposition 2: unique two-school equilibrium.

Paper student-region statement: students take the test and apply to `J1` iff
either they are below `J2`'s test-free cutoff and above the low cutoff `q_l^g`,
or they are above both `J2`'s cutoff and the high cutoff `q_h^g`, with
`q_l^g < q_h^g`.

Current Lean status: the displayed two-cutoff Gaussian payoff region is proved;
selection-threshold existence and global equilibrium uniqueness remain in the
certificate endpoint below.
-/
theorem paper_interface_proposition2_two_school_application_region_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold school2SubThreshold scale cost v1 v2 : ℝ}
    (hscale : 0 < scale) (hcost : 0 < cost)
    (hv1 : 0 < v1) (hdiff_pos : 0 < v1 - v2)
    (hdiff_lt_v1 : v1 - v2 < v1)
    (hcostRatioLow : cost / v1 ∈ Set.Ioo (0 : ℝ) 1)
    (hcostRatioHigh : cost / (v1 - v2) ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ lowCutoff highCutoff : ℝ,
      lowCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / v1) ∧
      highCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / (v1 - v2)) ∧
      lowCutoff < highCutoff ∧
      ∀ q : ℝ,
        ((q < school2SubThreshold ∧
            0 ≤ v1 *
              Q.cdfAPI.thresholdPassProb
                { mean := q, scale := scale, scale_pos := hscale }
                admissionThreshold - cost) ∨
          (school2SubThreshold ≤ q ∧
            0 ≤ (v1 - v2) *
              Q.cdfAPI.thresholdPassProb
                { mean := q, scale := scale, scale_pos := hscale }
                admissionThreshold - cost)) ↔
        ((q < school2SubThreshold ∧ lowCutoff ≤ q) ∨
          max highCutoff school2SubThreshold ≤ q) :=
  paper_proposition2_two_school_application_region_standardGaussian
    Q hscale hcost hv1 hdiff_pos hdiff_lt_v1 hcostRatioLow hcostRatioHigh

