/--
Proposition 5(ii) / Theorem 3(ii) objective bridge from merit crossings and
the paper's capacity-fill contradiction.  This is the same endpoint as
`paper_interface_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_merit_crossings`,
but the both-groups condition-(13) branch is derived from the capacity
equation at `q^*_{2,sub}`.
-/
theorem
    paper_interface_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_merit_crossings_and_capacity
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff fullSubCutoff : Group → ℝ}
    (objective1 objective2 : Policy → Policy → ℝ)
    (lowTestBasedMerit : Group → ℝ → ℝ) (lowTestFreeMerit : Group → ℝ)
    (highTestBasedMerit : Group → ℝ → ℝ) (highTestFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hlowCont :
      ∀ g, ContinuousOn (lowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAnti :
      ∀ g, StrictAntiOn (lowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAtZero : ∀ g, lowTestFreeMerit g < lowTestBasedMerit g 0)
    (hlowAtMax :
      ∀ g, lowTestBasedMerit g (maxCost g) < lowTestFreeMerit g)
    (hhighCont :
      ∀ g, ContinuousOn (highTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAnti :
      ∀ g, StrictAntiOn (highTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAtZero : ∀ g, highTestFreeMerit g < highTestBasedMerit g 0)
    (hhighAtMax :
      ∀ g, highTestBasedMerit g (maxCost g) < highTestFreeMerit g)
    (hhighAtLowRoot :
      ∀ g c, c ∈ Set.Ioo (0 : ℝ) (maxCost g) →
        lowTestBasedMerit g c = lowTestFreeMerit g →
          highTestFreeMerit g < highTestBasedMerit g c)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        paperTheorem3K api (subEstimateLaw groupA) (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        paperTheorem3K api (subEstimateLaw groupB) (fullFullCutoff groupB))
    (hmassFullSubA :
      S.massTestTaking groupA (policyPair Pfull Psub) =
        paperTheorem3K api (subEstimateLaw groupA) (fullSubCutoff groupA))
    (hmassFullSubB :
      S.massTestTaking groupB (policyPair Pfull Psub) =
        paperTheorem3K api (subEstimateLaw groupB) (fullSubCutoff groupB))
    (hcapacity2 :
      capacity2 =
        populationShare groupA * paperTheorem3K api (subEstimateLaw groupA)
            q2Sub +
          populationShare groupB * paperTheorem3K api (subEstimateLaw groupB)
            q2Sub)
    (hfillFullFull2 :
      capacity2 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hnoneJ2 :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ¬ objective2 Pfull Pfull ≤ objective2 Pfull Psub)
    (honlyA_J2_merit :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            lowTestBasedMerit groupA (testCost groupA) ≤
              lowTestFreeMerit groupA))
    (honlyB_J2_merit :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            lowTestBasedMerit groupB (testCost groupB) ≤
              lowTestFreeMerit groupB))
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpandA_testFree :
      ¬ fullSubCutoff groupA < q1Sub →
        objective1 Psub Psub = highTestFreeMerit groupA)
    (hexpandA_testBased :
      ¬ fullSubCutoff groupA < q1Sub →
        objective1 Pfull Psub =
          highTestBasedMerit groupA (testCost groupA))
    (hnoExpandB :
      fullSubCutoff groupB < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpandB_testFree :
      ¬ fullSubCutoff groupB < q1Sub →
        objective1 Psub Psub = highTestFreeMerit groupB)
    (hexpandB_testBased :
      ¬ fullSubCutoff groupB < q1Sub →
        objective1 Pfull Psub =
          highTestBasedMerit groupB (testCost groupB)) :
    ∃ lowCostThreshold highCostThreshold : Group → ℝ,
      (∀ g, lowCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
          (∀ g, lowTestBasedMerit g (lowCostThreshold g) =
            lowTestFreeMerit g) ∧
            (∀ g, highTestBasedMerit g (highCostThreshold g) =
              highTestFreeMerit g) ∧
              (∀ g, lowCostThreshold g < highCostThreshold g) ∧
                ((objective1 Psub Psub ≤ objective1 Pfull Psub ∧
                    objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
                  paperTheorem3FullSubCondition S policyPair Psub Pfull
                    groupA groupB testCost lowCostThreshold highCostThreshold
                    q1Sub q2Sub
                    (fun g q => paperTheorem3K api (subEstimateLaw g) q)) :=
  paper_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_merit_crossings_and_capacity
    api subEstimateLaw objective1 objective2 lowTestBasedMerit
    lowTestFreeMerit highTestBasedMerit highTestFreeMerit hmaxCost hcostMem
    hlowCont hlowAnti hlowAtZero hlowAtMax hhighCont hhighAnti hhighAtZero
    hhighAtMax hhighAtLowRoot hshareA hshareB hmassFullFullA
    hmassFullFullB hmassFullSubA hmassFullSubB hcapacity2 hfillFullFull2
    hnoneJ2 honlyA_J2_merit honlyB_J2_merit hnoExpandA hexpandA_testFree
    hexpandA_testBased hnoExpandB hexpandB_testFree hexpandB_testBased

/--
Proposition 5(ii) / Theorem 3(ii) objective bridge with the capacity-fill
contradiction and fixed-pool academic-merit comparison discharged.

This wrapper removes the opaque no-expansion branch for school `J2`: if no
group expands after `J2` drops, groupwise full/full admitted merit strictly
dominates `(P_full,P_sub)`, so the weighted academic-merit objective gives
`J2` no incentive to drop.
-/
theorem
    paper_interface_proposition5_part_ii_objective_pair_iff_theorem3_fullSub_condition_of_merit_crossings_capacity_and_fixed_pool_merit
    {Group Policy School Equilibrium : Type*}
    {S : GLM20StrategicPolicySurface Group Policy School Equilibrium}
    {policyPair : Policy → Policy → Policy}
    {Psub Pfull : Policy} {J2 : School} {groupA groupB : Group}
    {populationShare testCost maxCost : Group → ℝ}
    {capacity2 q1Sub q2Sub : ℝ}
    (api : StandardGaussianCDFAPI) (subEstimateLaw : Group → GaussianScaleLaw)
    {fullFullCutoff fullSubCutoff : Group → ℝ}
    (objective1 : Policy → Policy → ℝ)
    (lowTestBasedMerit : Group → ℝ → ℝ) (lowTestFreeMerit : Group → ℝ)
    (highTestBasedMerit : Group → ℝ → ℝ) (highTestFreeMerit : Group → ℝ)
    (hmaxCost : ∀ g, 0 < maxCost g)
    (hcostMem : ∀ g, testCost g ∈ Set.Icc (0 : ℝ) (maxCost g))
    (hlowCont :
      ∀ g, ContinuousOn (lowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAnti :
      ∀ g, StrictAntiOn (lowTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hlowAtZero : ∀ g, lowTestFreeMerit g < lowTestBasedMerit g 0)
    (hlowAtMax :
      ∀ g, lowTestBasedMerit g (maxCost g) < lowTestFreeMerit g)
    (hhighCont :
      ∀ g, ContinuousOn (highTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAnti :
      ∀ g, StrictAntiOn (highTestBasedMerit g)
        (Set.Icc (0 : ℝ) (maxCost g)))
    (hhighAtZero : ∀ g, highTestFreeMerit g < highTestBasedMerit g 0)
    (hhighAtMax :
      ∀ g, highTestBasedMerit g (maxCost g) < highTestFreeMerit g)
    (hhighAtLowRoot :
      ∀ g c, c ∈ Set.Ioo (0 : ℝ) (maxCost g) →
        lowTestBasedMerit g c = lowTestFreeMerit g →
          highTestFreeMerit g < highTestBasedMerit g c)
    (hshareA : 0 < populationShare groupA)
    (hshareB : 0 < populationShare groupB)
    (hmassFullFullA :
      S.massTestTaking groupA (policyPair Pfull Pfull) =
        paperTheorem3K api (subEstimateLaw groupA) (fullFullCutoff groupA))
    (hmassFullFullB :
      S.massTestTaking groupB (policyPair Pfull Pfull) =
        paperTheorem3K api (subEstimateLaw groupB) (fullFullCutoff groupB))
    (hmassFullSubA :
      S.massTestTaking groupA (policyPair Pfull Psub) =
        paperTheorem3K api (subEstimateLaw groupA) (fullSubCutoff groupA))
    (hmassFullSubB :
      S.massTestTaking groupB (policyPair Pfull Psub) =
        paperTheorem3K api (subEstimateLaw groupB) (fullSubCutoff groupB))
    (hcapacity2 :
      capacity2 =
        populationShare groupA * paperTheorem3K api (subEstimateLaw groupA)
            q2Sub +
          populationShare groupB * paperTheorem3K api (subEstimateLaw groupB)
            q2Sub)
    (hfillFullFull2 :
      capacity2 ≤
        populationShare groupA *
            S.massTestTaking groupA (policyPair Pfull Pfull) +
          populationShare groupB *
            S.massTestTaking groupB (policyPair Pfull Pfull))
    (hfixedPoolMeritA :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupA (policyPair Pfull Psub) <
            S.admittedAcademicMerit J2 groupA (policyPair Pfull Pfull))
    (hfixedPoolMeritB :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          S.admittedAcademicMerit J2 groupB (policyPair Pfull Psub) <
            S.admittedAcademicMerit J2 groupB (policyPair Pfull Pfull))
    (honlyA_J2_merit :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ((paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub) ↔
            lowTestBasedMerit groupA (testCost groupA) ≤
              lowTestFreeMerit groupA))
    (honlyB_J2_merit :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          ((paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Pfull ≤
            paperTwoGroupWeightedAcademicMeritObjective S policyPair J2
              groupA groupB populationShare Pfull Psub) ↔
            lowTestBasedMerit groupB (testCost groupB) ≤
              lowTestFreeMerit groupB))
    (hnoExpandA :
      fullSubCutoff groupA < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpandA_testFree :
      ¬ fullSubCutoff groupA < q1Sub →
        objective1 Psub Psub = highTestFreeMerit groupA)
    (hexpandA_testBased :
      ¬ fullSubCutoff groupA < q1Sub →
        objective1 Pfull Psub =
          highTestBasedMerit groupA (testCost groupA))
    (hnoExpandB :
      fullSubCutoff groupB < q1Sub →
        objective1 Psub Psub ≤ objective1 Pfull Psub)
    (hexpandB_testFree :
      ¬ fullSubCutoff groupB < q1Sub →
        objective1 Psub Psub = highTestFreeMerit groupB)
    (hexpandB_testBased :
      ¬ fullSubCutoff groupB < q1Sub →
        objective1 Pfull Psub =
          highTestBasedMerit groupB (testCost groupB)) :
    ∃ lowCostThreshold highCostThreshold : Group → ℝ,
      (∀ g, lowCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
        (∀ g, highCostThreshold g ∈ Set.Ioo (0 : ℝ) (maxCost g)) ∧
          (∀ g, lowTestBasedMerit g (lowCostThreshold g) =
            lowTestFreeMerit g) ∧
