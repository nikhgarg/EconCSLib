/--
Proposition 8(ii): when affirmative action raises group A's threshold and
lowers group B's threshold, group A's admitted academic merit increases while
group B's admitted academic merit decreases.
-/
theorem paper_interface_proposition8_academic_merit_changes_standardGaussian_of_threshold_order
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy}
    {groupA groupB : Group} {Pbase Paa : Policy}
    {L_A L_B : GaussianScaleLaw}
    {thresholdBase thresholdA thresholdB : ℝ}
    (hthresholdA : thresholdBase < thresholdA)
    (hthresholdB : thresholdB < thresholdBase)
    (hmeritABase :
      S.academicMerit groupA Pbase =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_A thresholdBase)
    (hmeritAAA :
      S.academicMerit groupA Paa =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_A thresholdA)
    (hmeritBBase :
      S.academicMerit groupB Pbase =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_B thresholdBase)
    (hmeritBAA :
      S.academicMerit groupB Paa =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_B thresholdB) :
    S.academicMerit groupA Pbase < S.academicMerit groupA Paa ∧
      S.academicMerit groupB Paa < S.academicMerit groupB Pbase :=
  paper_proposition8_academic_merit_changes_standardGaussian_of_threshold_order
    hthresholdA hthresholdB hmeritABase hmeritAAA hmeritBBase hmeritBAA

/--
Proposition 8 bundled paper-facing endpoint: affirmative action improves the
individual-fairness gap, gives the displayed positive-gap cutoff, keeps group
B below group A in admitted academic merit, raises group A's admitted merit,
and lowers group B's admitted merit.
-/
theorem paper_interface_proposition8_affirmative_action_fixed_policy_standardGaussian
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy}
    {groupA groupB : Group} {Pbase Paa : Policy}
    {admitABase admitBBase admitAAA admitBAA : ℝ → ℝ}
    {L_AA L_BA : ℝ → GaussianScaleLaw}
    {L_A_merit L_B_merit : GaussianScaleLaw}
    {priorPrecision sqrtPrecB sqrtPrecA thresholdA thresholdB mean : ℝ}
    {thresholdBase : ℝ}
    {intervalMeanB tailMeanBHigh weight : ℝ}
    (hgapBase :
      ∀ q : ℝ, S.individualFairnessGap Pbase q =
        admitABase q - admitBBase q)
    (hgapAA :
      ∀ q : ℝ, S.individualFairnessGap Paa q =
        admitAAA q - admitBAA q)
    (hA_prob : ∀ q : ℝ, admitAAA q < admitABase q)
    (hB_prob : ∀ q : ℝ, admitBBase q < admitBAA q)
    (hgap_eq :
      ∀ q : ℝ, S.individualFairnessGap Paa q =
        api.thresholdPassProb (L_AA q) thresholdA -
          api.thresholdPassProb (L_BA q) thresholdB)
    (hstdA :
      ∀ q : ℝ, (L_AA q).standardize thresholdA =
        priorPrecision * (thresholdA - mean) / sqrtPrecA +
          sqrtPrecA * (thresholdA - q))
    (hstdB :
      ∀ q : ℝ, (L_BA q).standardize thresholdB =
        priorPrecision * (thresholdB - mean) / sqrtPrecB +
          sqrtPrecB * (thresholdB - q))
    (hsqrtB_pos : 0 < sqrtPrecB) (hsqrtA_pos : 0 < sqrtPrecA)
    (hprecision_gap : sqrtPrecB < sqrtPrecA)
    (hweight_nonneg : 0 ≤ weight) (hweight_lt_one : weight < 1)
    (hinterval_lt_tailB : intervalMeanB < tailMeanBHigh)
    (htailB_lt_A :
      tailMeanBHigh < S.academicMerit groupA Paa)
    (hmeritB_decomp :
      S.academicMerit groupB Paa =
        weight * intervalMeanB + (1 - weight) * tailMeanBHigh)
    (hthresholdA : thresholdBase < thresholdA)
    (hthresholdB : thresholdB < thresholdBase)
    (hmeritABase :
      S.academicMerit groupA Pbase =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_A_merit thresholdBase)
    (hmeritAAA :
      S.academicMerit groupA Paa =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_A_merit thresholdA)
    (hmeritBBase :
      S.academicMerit groupB Pbase =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_B_merit thresholdBase)
    (hmeritBAA :
      S.academicMerit groupB Paa =
        GaussianHazardCertificate.normalUpperTailMean
          standardGaussianHazardInverseCertificate.toGaussianHazardCertificate
          L_B_merit thresholdB) :
    (∀ q : ℝ,
        S.individualFairnessGap Paa q <
          S.individualFairnessGap Pbase q) ∧
      (∀ q : ℝ,
        0 < S.individualFairnessGap Paa q ↔
          ((priorPrecision + sqrtPrecA ^ 2) / sqrtPrecA * thresholdA -
                (priorPrecision + sqrtPrecB ^ 2) / sqrtPrecB *
                  thresholdB) /
              (sqrtPrecA - sqrtPrecB) +
            mean * priorPrecision / (sqrtPrecA * sqrtPrecB) <
            q) ∧
      S.academicMerit groupB Paa < S.academicMerit groupA Paa ∧
      S.academicMerit groupA Pbase < S.academicMerit groupA Paa ∧
      S.academicMerit groupB Paa < S.academicMerit groupB Pbase :=
  paper_proposition8_affirmative_action_fixed_policy_standardGaussian
    api hgapBase hgapAA hA_prob hB_prob hgap_eq hstdA hstdB hsqrtB_pos
    hsqrtA_pos hprecision_gap hweight_nonneg hweight_lt_one
    hinterval_lt_tailB htailB_lt_A hmeritB_decomp hthresholdA hthresholdB
    hmeritABase hmeritAAA hmeritBBase hmeritBAA

/--
Proposition 9 inverse-CDF algebra: the full-policy standardized cutoff is
below a scalar `z` exactly when `γ_g` is below the capacity-solved threshold.
-/
theorem paper_interface_proposition9_quantile_le_iff_gamma_le_threshold
    {groupCapacity populationShare gamma z : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hcapacity_pos : 0 < groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hgamma_pos : 0 < gamma)
    (htail_pos : 0 < 1 - standardGaussianCDF z)
    (harg :
      1 - groupCapacity / (populationShare * gamma) ∈
        Set.Ioo (0 : ℝ) 1) :
    standardGaussianQuantile
        (1 - groupCapacity / (populationShare * gamma)) ≤ z ↔
      gamma ≤
        groupCapacity /
          (populationShare * (1 - standardGaussianCDF z)) :=
  paper_proposition9_quantile_le_iff_gamma_le_threshold
    hcapacity_nonneg hcapacity_pos hpopulation_pos hgamma_pos htail_pos harg

/--
Proposition 9: the displayed standard-Gaussian hazard comparison is equivalent
to `γ_g ≤ \hat γ_g`.
-/
theorem paper_interface_proposition9_hazard_condition_iff_gamma_le_hatGamma
    {groupCapacity populationShare scaleSub scaleFull gamma : ℝ}
    (hcapacity_pos : 0 < groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hgamma_pos : 0 < gamma)
    (hscaleSub_pos : 0 < scaleSub)
    (hscaleFull_pos : 0 < scaleFull)
    (hargFull :
      1 - groupCapacity / (populationShare * gamma) ∈
        Set.Ioo (0 : ℝ) 1)
    (hargSub :
      1 - groupCapacity / populationShare ∈ Set.Ioo (0 : ℝ) 1) :
    standardGaussianHazard
        (standardGaussianQuantile
          (1 - groupCapacity / (populationShare * gamma))) ≤
        (scaleSub / scaleFull) *
          standardGaussianHazard
            (standardGaussianQuantile
              (1 - groupCapacity / populationShare)) ↔
      gamma ≤
        paperProposition9HatGamma
          groupCapacity populationShare scaleSub scaleFull :=
  paper_proposition9_hazard_condition_iff_gamma_le_hatGamma
    hcapacity_pos hpopulation_pos hgamma_pos hscaleSub_pos hscaleFull_pos
    hargFull hargSub

/--
Proposition 9 paper-facing wrapper: after reducing the admitted academic-merit
comparison to the displayed hazard inequality, dropping the test improves
group `g`'s admitted merit iff `γ_g ≤ \hat γ_g`.
-/
theorem paper_interface_proposition9_dropping_tests_affirmative_action_iff_gamma_le_hatGamma
    {academicMeritImproves : Prop}
    {groupCapacity populationShare scaleSub scaleFull gamma : ℝ}
    (hcapacity_pos : 0 < groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hgamma_pos : 0 < gamma)
    (hscaleSub_pos : 0 < scaleSub)
    (hscaleFull_pos : 0 < scaleFull)
    (hargFull :
      1 - groupCapacity / (populationShare * gamma) ∈
        Set.Ioo (0 : ℝ) 1)
    (hargSub :
      1 - groupCapacity / populationShare ∈ Set.Ioo (0 : ℝ) 1)
    (hhazard :
      academicMeritImproves ↔
        standardGaussianHazard
            (standardGaussianQuantile
              (1 - groupCapacity / (populationShare * gamma))) ≤
          (scaleSub / scaleFull) *
            standardGaussianHazard
              (standardGaussianQuantile
                (1 - groupCapacity / populationShare))) :
    academicMeritImproves ↔
      gamma ≤
        paperProposition9HatGamma
          groupCapacity populationShare scaleSub scaleFull :=
  paper_proposition9_dropping_tests_affirmative_action_iff_gamma_le_hatGamma
    hcapacity_pos hpopulation_pos hgamma_pos hscaleSub_pos hscaleFull_pos
    hargFull hargSub hhazard

/--
Proposition 9 source-precision wrapper: after the merit comparison is reduced
to the displayed hazard inequality with the paper's square-root precision
ratio, dropping the test improves admitted merit iff
`γ_g ≤ \hat γ_g`.
-/
theorem paper_interface_proposition9_dropping_tests_affirmative_action_iff_gamma_le_hatGammaSource
    {academicMeritImproves : Prop}
    {groupCapacity populationShare priorPrecision
      subPrecisionSum fullPrecisionSum gamma : ℝ}
    (hcapacity_pos : 0 < groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hgamma_pos : 0 < gamma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsubPrecision_pos : 0 < subPrecisionSum)
    (hfullPrecision_pos : 0 < fullPrecisionSum)
    (hargFull :
      1 - groupCapacity / (populationShare * gamma) ∈
        Set.Ioo (0 : ℝ) 1)
    (hargSub :
      1 - groupCapacity / populationShare ∈ Set.Ioo (0 : ℝ) 1)
    (hhazard :
      academicMeritImproves ↔
        standardGaussianHazard
            (standardGaussianQuantile
              (1 - groupCapacity / (populationShare * gamma))) ≤
          (Real.sqrt
              (subPrecisionSum / (priorPrecision + subPrecisionSum)) /
            Real.sqrt
              (fullPrecisionSum / (priorPrecision + fullPrecisionSum))) *
            standardGaussianHazard
              (standardGaussianQuantile
                (1 - groupCapacity / populationShare))) :
    academicMeritImproves ↔
      gamma ≤
        paperProposition9HatGammaSource groupCapacity populationShare
          priorPrecision subPrecisionSum fullPrecisionSum :=
  paper_proposition9_dropping_tests_affirmative_action_iff_gamma_le_hatGammaSource
    hcapacity_pos hpopulation_pos hgamma_pos hpriorPrecision_pos
    hsubPrecision_pos hfullPrecision_pos hargFull hargSub hhazard

/--
Proposition 9 monotonicity support: increasing the inverse-hazard cutoff
weakly increases `\hat γ_g`.
-/
theorem paper_interface_proposition9_hatGamma_mono_of_inverse_cutoff_le
    {groupCapacity populationShare zOld zNew : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hz : zOld ≤ zNew) :
    groupCapacity /
        (populationShare * (1 - standardGaussianCDF zOld)) ≤
      groupCapacity /
        (populationShare * (1 - standardGaussianCDF zNew)) :=
  paper_proposition9_hatGamma_mono_of_inverse_cutoff_le
    hcapacity_nonneg hpopulation_pos hz

/--
Proposition 9 monotonicity in test variance: if the test-using posterior-score
scale weakly decreases, the solved access threshold weakly increases.
-/
theorem paper_interface_proposition9_hatGamma_mono_of_scaleFull_decreases
    {groupCapacity populationShare scaleSub scaleFullOld scaleFullNew : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hscaleSub_pos : 0 < scaleSub)
    (hscaleFullNew_pos : 0 < scaleFullNew)
    (hscaleFullNew_le_old : scaleFullNew ≤ scaleFullOld) :
    paperProposition9HatGamma
        groupCapacity populationShare scaleSub scaleFullOld ≤
      paperProposition9HatGamma
        groupCapacity populationShare scaleSub scaleFullNew :=
  paper_proposition9_hatGamma_mono_of_scaleFull_decreases
    hcapacity_nonneg hpopulation_pos hscaleSub_pos hscaleFullNew_pos
    hscaleFullNew_le_old

/--
Proposition 9 source-scale monotonicity: lowering the test precision lowers
the full-policy posterior-score scale
`\sigma sqrt(sum_full/(sigma^{-2}+sum_full))`.
-/
theorem paper_interface_proposition9_full_scale_mono_of_test_precision_le
    {priorSigma priorPrecision subPrecisionSum
      testPrecisionOld testPrecisionNew : ℝ}
    (hpriorSigma_pos : 0 < priorSigma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hfullNew_pos : 0 < subPrecisionSum + testPrecisionNew)
    (htestPrecisionNew_le_old : testPrecisionNew ≤ testPrecisionOld) :
    glm20Proposition3SigmaTildeSource priorSigma priorPrecision
        (subPrecisionSum + testPrecisionNew) ≤
      glm20Proposition3SigmaTildeSource priorSigma priorPrecision
        (subPrecisionSum + testPrecisionOld) :=
  paper_proposition9_full_scale_mono_of_test_precision_le
    hpriorSigma_pos hpriorPrecision_pos hfullNew_pos
    htestPrecisionNew_le_old

/--
Proposition 9 monotonicity, in precision coordinates: if the test precision
falls, then the solved access threshold `\hat γ_g` weakly increases.
-/
theorem paper_interface_proposition9_hatGamma_mono_of_test_precision_decreases
    {groupCapacity populationShare scaleSub priorSigma priorPrecision
      subPrecisionSum testPrecisionOld testPrecisionNew : ℝ}
    (hcapacity_nonneg : 0 ≤ groupCapacity)
    (hpopulation_pos : 0 < populationShare)
    (hscaleSub_pos : 0 < scaleSub)
    (hpriorSigma_pos : 0 < priorSigma)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hfullNew_pos : 0 < subPrecisionSum + testPrecisionNew)
    (htestPrecisionNew_le_old : testPrecisionNew ≤ testPrecisionOld) :
    paperProposition9HatGamma groupCapacity populationShare scaleSub
        (glm20Proposition3SigmaTildeSource priorSigma priorPrecision
          (subPrecisionSum + testPrecisionOld)) ≤
      paperProposition9HatGamma groupCapacity populationShare scaleSub
        (glm20Proposition3SigmaTildeSource priorSigma priorPrecision
          (subPrecisionSum + testPrecisionNew)) :=
  paper_proposition9_hatGamma_mono_of_test_precision_decreases
    hcapacity_nonneg hpopulation_pos hscaleSub_pos hpriorSigma_pos
    hpriorPrecision_pos hfullNew_pos htestPrecisionNew_le_old

/--
Proposition 9 paper statement: fixing all other parameters, increasing the
