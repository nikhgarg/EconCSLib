/--
Paper Proposition 5 / Theorem 3 threshold support: a continuous strictly
decreasing test-based merit term with opposite endpoint comparisons has a
positive normalized cost threshold.  Dropping weakly improves merit exactly at
or above that threshold.
-/
theorem paper_interface_proposition5_cost_threshold_of_continuous_strictAntiOn_unit_interval
    {testBasedMerit : ℝ → ℝ} {testFreeMerit : ℝ}
    (hcont : ContinuousOn testBasedMerit (Set.Icc 0 1))
    (hanti : StrictAntiOn testBasedMerit (Set.Icc 0 1))
    (hlowCost : testFreeMerit < testBasedMerit 0)
    (hhighCost : testBasedMerit 1 < testFreeMerit) :
    ∃ costThreshold : ℝ,
      costThreshold ∈ Set.Ioo (0 : ℝ) 1 ∧
        testBasedMerit costThreshold = testFreeMerit ∧
          (∀ c ∈ Set.Icc (0 : ℝ) 1,
            testFreeMerit < testBasedMerit c ↔ c < costThreshold) ∧
            (∀ c ∈ Set.Icc (0 : ℝ) 1,
              testBasedMerit c < testFreeMerit ↔ costThreshold < c) ∧
              (∀ c ∈ Set.Icc (0 : ℝ) 1,
                testBasedMerit c ≤ testFreeMerit ↔ costThreshold ≤ c) :=
