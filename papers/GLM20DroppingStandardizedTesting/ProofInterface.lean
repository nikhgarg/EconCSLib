    let groupAEligibleMass := (1 - pi) * gammaA
    let groupBShare := pi
    let ownShareA := 1 - pi
    let otherEligibleMassA := pi * gammaB
    let ownShareB := pi
    let otherEligibleMassB := (1 - pi) * gammaA
    let threshold :=
      theorem1BarrierCapacityThresholdOnUnit standardGaussianCDFAPI
        standardGaussianCDF_tendsto_atBot standardGaussianCDF_tendsto_atTop
        capacity groupAEligibleMass groupBShare L_A L_B
        (lt_trans hcapacity_pos hcapacity_lt_groupA) hpi_pos.le
        (theorem1_capacity_mem_on_unit_of_capacity_lt_groupAEligibleMass
          hcapacity_pos hcapacity_lt_groupA hpi_pos.le)
    let Sdiv :=
      theorem1DiversitySourceSurface standardGaussianCDFAPI Pfull Psub groupB
        capacity groupBShare diversitySub L_B threshold
    let SA :=
      theorem1AcademicMeritSourceSurface standardGaussianHazardInverseCertificate
        Pfull Psub groupA capacity baseA scaleA xiA hscaleA_pos hxiA_pos
        benchmarkA
        (theorem1BetaGroupA standardGaussianQuantileAPI
          capacity ownShareA otherEligibleMassA rhoA)
    let SB :=
      theorem1AcademicMeritSourceSurface standardGaussianHazardInverseCertificate
        Pfull Psub groupB capacity baseB scaleB xiB hscaleB_pos hxiB_pos
        benchmarkB
        (theorem1BetaGroupB standardGaussianQuantileAPI
          capacity ownShareB otherEligibleMassB rhoB)
    (∃ γbar : ℝ,
      ∀ γB ∈ Set.Icc (0 : ℝ) 1,
        theorem1SourceDiversityImproves Sdiv Pfull Psub γB ↔ γB < γbar) ∧
      (∃ γbarA : ℝ,
        ∀ γA ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SA groupA Pfull Psub γA ↔
            γA ≤ γbarA) ∧
      (∃ γbarB : ℝ,
        ∀ γB ∈ Set.Icc (0 : ℝ) 1,
          theorem1SourceAcademicMeritImproves SB groupB Pfull Psub γB ↔
            γB ≤ γbarB) :=
