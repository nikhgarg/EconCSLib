/--
Theorem 3 support: derive the low-based/full-sub fixed posterior-law equality
from raw Gaussian source-family rows.  This discharges the fixed-law premise
used by the compact posterior cost-row route from prior mean, prior variance,
and total centered signal precision equalities.
-/
theorem paper_interface_theorem3_fullSub_low_based_law_of_prior_precision_rows
    {Group LowBasedFeature HighFreeFeature : Type*}
    [Fintype LowBasedFeature] [Nonempty LowBasedFeature]
    [Fintype HighFreeFeature] [Nonempty HighFreeFeature]
    (fullSubHighFreeFamily : Group → GaussianOffsetSignalFamily HighFreeFeature)
    (fullSubFreeExtraNoiseMean fullSubFreeExtraNoiseVar : Group → ℝ)
    (hfullSubFreeExtraNoiseVar :
      ∀ g, 0 < fullSubFreeExtraNoiseVar g)
    (fullSubLowBasedFamily :
      Group → ℝ → GaussianOffsetSignalFamily LowBasedFeature)
    (hpriorMean :
      ∀ g c,
        (fullSubLowBasedFamily g c).priorMean =
          ((fullSubHighFreeFamily g).withExtraSignal
            (fullSubFreeExtraNoiseMean g) (fullSubFreeExtraNoiseVar g)
            (hfullSubFreeExtraNoiseVar g)).priorMean)
    (hpriorVar :
      ∀ g c,
        (fullSubLowBasedFamily g c).priorVar =
          ((fullSubHighFreeFamily g).withExtraSignal
            (fullSubFreeExtraNoiseMean g) (fullSubFreeExtraNoiseVar g)
            (hfullSubFreeExtraNoiseVar g)).priorVar)
    (hsignalPrecisionSum :
      ∀ g c,
        (fullSubLowBasedFamily g c).centeredFamily.signalPrecisionSum =
          ((fullSubHighFreeFamily g).withExtraSignal
            (fullSubFreeExtraNoiseMean g) (fullSubFreeExtraNoiseVar g)
            (hfullSubFreeExtraNoiseVar g)).centeredFamily.signalPrecisionSum) :
    ∀ g c,
      (fullSubLowBasedFamily g c).posteriorMeanScaleLaw =
        ((fullSubHighFreeFamily g).withExtraSignal
          (fullSubFreeExtraNoiseMean g) (fullSubFreeExtraNoiseVar g)
          (hfullSubFreeExtraNoiseVar g)).posteriorMeanScaleLaw := by
  intro g c
  exact
    GaussianOffsetSignalFamily.posteriorMeanScaleLaw_eq_of_priorMean_eq_priorVar_eq_signalPrecisionSum_eq
      (fullSubLowBasedFamily g c)
      ((fullSubHighFreeFamily g).withExtraSignal
        (fullSubFreeExtraNoiseMean g) (fullSubFreeExtraNoiseVar g)
        (hfullSubFreeExtraNoiseVar g))
      (hpriorMean g c) (hpriorVar g c) (hsignalPrecisionSum g c)

/--
Theorem 3 support: derive the high-based/full-sub fixed posterior-law equality
from raw Gaussian source-family rows.  This is the companion to
`paper_interface_theorem3_fullSub_low_based_law_of_prior_precision_rows` for
the source-family route where the high based family is produced by adding one
extra signal to the low based family.
-/
theorem paper_interface_theorem3_fullSub_high_based_law_of_prior_precision_rows
    {Group LowBasedFeature HighFreeFeature : Type*}
    [Fintype LowBasedFeature] [Nonempty LowBasedFeature]
    [Fintype HighFreeFeature] [Nonempty HighFreeFeature]
    (fullSubHighFreeFamily : Group → GaussianOffsetSignalFamily HighFreeFeature)
    (fullSubLowBasedFamily :
      Group → ℝ → GaussianOffsetSignalFamily LowBasedFeature)
    (fullSubBasedExtraNoiseMean fullSubBasedExtraNoiseVar :
      Group → ℝ → ℝ)
    (hfullSubBasedExtraNoiseVar :
      ∀ g c, 0 < fullSubBasedExtraNoiseVar g c)
    (hpriorMean :
      ∀ g c,
        ((fullSubLowBasedFamily g c).withExtraSignal
          (fullSubBasedExtraNoiseMean g c)
          (fullSubBasedExtraNoiseVar g c)
          (hfullSubBasedExtraNoiseVar g c)).priorMean =
          (fullSubHighFreeFamily g).priorMean)
    (hpriorVar :
      ∀ g c,
        ((fullSubLowBasedFamily g c).withExtraSignal
          (fullSubBasedExtraNoiseMean g c)
          (fullSubBasedExtraNoiseVar g c)
          (hfullSubBasedExtraNoiseVar g c)).priorVar =
          (fullSubHighFreeFamily g).priorVar)
    (hsignalPrecisionSum :
      ∀ g c,
        ((fullSubLowBasedFamily g c).withExtraSignal
          (fullSubBasedExtraNoiseMean g c)
          (fullSubBasedExtraNoiseVar g c)
          (hfullSubBasedExtraNoiseVar g c)).centeredFamily.signalPrecisionSum =
          (fullSubHighFreeFamily g).centeredFamily.signalPrecisionSum) :
    ∀ g c,
      ((fullSubLowBasedFamily g c).withExtraSignal
        (fullSubBasedExtraNoiseMean g c)
        (fullSubBasedExtraNoiseVar g c)
        (hfullSubBasedExtraNoiseVar g c)).posteriorMeanScaleLaw =
        (fullSubHighFreeFamily g).posteriorMeanScaleLaw := by
  intro g c
  exact
    GaussianOffsetSignalFamily.posteriorMeanScaleLaw_eq_of_priorMean_eq_priorVar_eq_signalPrecisionSum_eq
      ((fullSubLowBasedFamily g c).withExtraSignal
        (fullSubBasedExtraNoiseMean g c)
        (fullSubBasedExtraNoiseVar g c)
        (hfullSubBasedExtraNoiseVar g c))
      (fullSubHighFreeFamily g)
      (hpriorMean g c) (hpriorVar g c) (hsignalPrecisionSum g c)

/--
Theorem 3 support: derive both fixed posterior-law equalities for the full-sub
low/high based rows from raw prior-mean, prior-variance, and total
signal-precision rows.
-/
theorem paper_interface_theorem3_fullSub_based_laws_of_prior_precision_rows
    {Group LowBasedFeature HighFreeFeature : Type*}
    [Fintype LowBasedFeature] [Nonempty LowBasedFeature]
    [Fintype HighFreeFeature] [Nonempty HighFreeFeature]
    (fullSubHighFreeFamily : Group → GaussianOffsetSignalFamily HighFreeFeature)
    (fullSubFreeExtraNoiseMean fullSubFreeExtraNoiseVar : Group → ℝ)
    (hfullSubFreeExtraNoiseVar :
      ∀ g, 0 < fullSubFreeExtraNoiseVar g)
    (fullSubLowBasedFamily :
      Group → ℝ → GaussianOffsetSignalFamily LowBasedFeature)
    (fullSubBasedExtraNoiseMean fullSubBasedExtraNoiseVar :
      Group → ℝ → ℝ)
    (hfullSubBasedExtraNoiseVar :
      ∀ g c, 0 < fullSubBasedExtraNoiseVar g c)
    (hlowPriorMean :
      ∀ g c,
        (fullSubLowBasedFamily g c).priorMean =
          ((fullSubHighFreeFamily g).withExtraSignal
            (fullSubFreeExtraNoiseMean g) (fullSubFreeExtraNoiseVar g)
            (hfullSubFreeExtraNoiseVar g)).priorMean)
    (hlowPriorVar :
      ∀ g c,
        (fullSubLowBasedFamily g c).priorVar =
          ((fullSubHighFreeFamily g).withExtraSignal
            (fullSubFreeExtraNoiseMean g) (fullSubFreeExtraNoiseVar g)
            (hfullSubFreeExtraNoiseVar g)).priorVar)
    (hlowPrecision :
      ∀ g c,
        (fullSubLowBasedFamily g c).centeredFamily.signalPrecisionSum =
          ((fullSubHighFreeFamily g).withExtraSignal
            (fullSubFreeExtraNoiseMean g) (fullSubFreeExtraNoiseVar g)
            (hfullSubFreeExtraNoiseVar g)).centeredFamily.signalPrecisionSum)
    (hhighPriorMean :
      ∀ g c,
        ((fullSubLowBasedFamily g c).withExtraSignal
          (fullSubBasedExtraNoiseMean g c)
          (fullSubBasedExtraNoiseVar g c)
          (hfullSubBasedExtraNoiseVar g c)).priorMean =
          (fullSubHighFreeFamily g).priorMean)
    (hhighPriorVar :
      ∀ g c,
        ((fullSubLowBasedFamily g c).withExtraSignal
          (fullSubBasedExtraNoiseMean g c)
          (fullSubBasedExtraNoiseVar g c)
          (hfullSubBasedExtraNoiseVar g c)).priorVar =
          (fullSubHighFreeFamily g).priorVar)
    (hhighPrecision :
      ∀ g c,
        ((fullSubLowBasedFamily g c).withExtraSignal
          (fullSubBasedExtraNoiseMean g c)
          (fullSubBasedExtraNoiseVar g c)
          (hfullSubBasedExtraNoiseVar g c)).centeredFamily.signalPrecisionSum =
          (fullSubHighFreeFamily g).centeredFamily.signalPrecisionSum) :
    (∀ g c,
      (fullSubLowBasedFamily g c).posteriorMeanScaleLaw =
        ((fullSubHighFreeFamily g).withExtraSignal
          (fullSubFreeExtraNoiseMean g) (fullSubFreeExtraNoiseVar g)
          (hfullSubFreeExtraNoiseVar g)).posteriorMeanScaleLaw) ∧
      (∀ g c,
        ((fullSubLowBasedFamily g c).withExtraSignal
          (fullSubBasedExtraNoiseMean g c)
          (fullSubBasedExtraNoiseVar g c)
          (hfullSubBasedExtraNoiseVar g c)).posteriorMeanScaleLaw =
          (fullSubHighFreeFamily g).posteriorMeanScaleLaw) := by
  constructor
  · exact
      paper_interface_theorem3_fullSub_low_based_law_of_prior_precision_rows
        fullSubHighFreeFamily fullSubFreeExtraNoiseMean
        fullSubFreeExtraNoiseVar hfullSubFreeExtraNoiseVar
        fullSubLowBasedFamily hlowPriorMean hlowPriorVar hlowPrecision
  · exact
      paper_interface_theorem3_fullSub_high_based_law_of_prior_precision_rows
        fullSubHighFreeFamily fullSubLowBasedFamily
        fullSubBasedExtraNoiseMean fullSubBasedExtraNoiseVar
        hfullSubBasedExtraNoiseVar hhighPriorMean hhighPriorVar
        hhighPrecision

