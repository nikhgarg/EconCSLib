    {fullDiversity threshold : ℝ → ℝ}
    {diversitySub capacity groupAEligibleMass groupBShare : ℝ}
    {L_A L_B : GaussianScaleLaw}
    {diversityImproves meritImprovesA meritImprovesB : ℝ → Prop}
    {ownShareA otherEligibleMassA rhoA xiA benchmarkA baseA scaleA : ℝ}
    {fullMeritA : ℝ → ℝ} {subMeritA : ℝ}
