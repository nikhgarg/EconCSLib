/--
Proposition 1 comparative-statics support: the variance term in the closed-form
threshold equation increases with group A's total precision.
-/
theorem paper_interface_proposition1_threshold_variance_term_lt_of_precision_gap_lt
    {priorPrecision sigmaSq pi fixedPrecision delta delta' : ℝ}
