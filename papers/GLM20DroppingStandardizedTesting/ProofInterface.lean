/--
Proposition 1 individual-fairness comparative statics: if the common threshold
rises, group B's score law is fixed, and group A's standardized cutoff falls,
then the individual-fairness gap strictly increases.
-/
theorem paper_interface_proposition1_individual_fairness_gap_increases_of_threshold_and_standardized_monotonicity
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P_low P_high : Policy}
    {L_A_low L_A_high L_B : GaussianScaleLaw}
    {thresholdLow thresholdHigh q : ℝ}
    (hgap_low :
      S.individualFairnessGap P_low q =
        api.thresholdPassProb L_A_low thresholdLow -
          api.thresholdPassProb L_B thresholdLow)
    (hgap_high :
      S.individualFairnessGap P_high q =
        api.thresholdPassProb L_A_high thresholdHigh -
          api.thresholdPassProb L_B thresholdHigh)
    (hthreshold : thresholdLow < thresholdHigh)
    (hstd :
      L_A_high.standardize thresholdHigh <
        L_A_low.standardize thresholdLow) :
    S.individualFairnessGap P_low q <
      S.individualFairnessGap P_high q :=
  paper_proposition1_individual_fairness_gap_increases_of_threshold_and_standardized_monotonicity
    api hgap_low hgap_high hthreshold hstd

/--
Proposition 1 individual-fairness comparative statics with the paper's
closed-form threshold formula: after the scalar group-A standardized-cutoff
inequality is established, increasing group A's informativeness gap strictly
increases the individual-fairness gap for the compared skill.
-/
theorem paper_interface_proposition1_individual_fairness_gap_increases_of_precision_gap_lt
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P_low P_high : Policy}
    {L_A_low L_A_high L_B : GaussianScaleLaw}
    {mean quantile priorPrecision sigmaSq pi fixedPrecision delta delta' q : ℝ}
    (hgap_low :
      S.individualFairnessGap P_low q =
        api.thresholdPassProb L_A_low
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) -
          api.thresholdPassProb L_B
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))))
    (hgap_high :
      S.individualFairnessGap P_high q =
        api.thresholdPassProb L_A_high
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) -
          api.thresholdPassProb L_B
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))))
    (hquantile_pos : 0 < quantile)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsigmaSq_pos : 0 < sigmaSq)
    (hleftWeight_pos : 0 < 1 - pi)
    (hbase_nonneg : 0 ≤ fixedPrecision + delta)
    (hterm_nonneg :
      0 ≤
        (1 - pi) * sigmaSq *
            ((fixedPrecision + delta) /
              (priorPrecision + (fixedPrecision + delta))) +
          pi * sigmaSq *
            (fixedPrecision / (priorPrecision + fixedPrecision)))
    (hdelta : delta < delta')
    (hstd :
      L_A_high.standardize
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) <
        L_A_low.standardize
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision))))) :
    S.individualFairnessGap P_low q <
      S.individualFairnessGap P_high q :=
  paper_proposition1_individual_fairness_gap_increases_of_precision_gap_lt
    api hgap_low hgap_high hquantile_pos hpriorPrecision_pos hsigmaSq_pos
    hleftWeight_pos hbase_nonneg hterm_nonneg hdelta hstd

/--
Proposition 1 individual-fairness comparative statics for high-skilled
students: with the paper's closed-form threshold formula and scalar group-A
standardized-cutoff formula, increasing group A's informativeness gap strictly
increases the individual-fairness gap.
-/
theorem paper_interface_proposition1_individual_fairness_gap_increases_of_precision_gap_high_skill_formula
    (api : StandardGaussianCDFAPI)
    {Group Policy : Type*}
    {S : GLM20SourcePolicySurface Group Policy} {P_low P_high : Policy}
    {L_A_low L_A_high L_B : GaussianScaleLaw}
    {mean quantile priorPrecision sigmaSq pi fixedPrecision delta delta' q
      a c d quantileScale sqrtPrecLow sqrtPrecHigh : ℝ}
    (hgap_low :
      S.individualFairnessGap P_low q =
        api.thresholdPassProb L_A_low
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) -
          api.thresholdPassProb L_B
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))))
    (hgap_high :
      S.individualFairnessGap P_high q =
        api.thresholdPassProb L_A_high
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) -
          api.thresholdPassProb L_B
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))))
    (hstd_low :
      L_A_low.standardize
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta) /
                  (priorPrecision + (fixedPrecision + delta))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) =
        quantileScale *
            Real.sqrt (a * sqrtPrecLow ^ 2 + c + d / sqrtPrecLow ^ 2) -
          sqrtPrecLow * (q - mean))
    (hstd_high :
      L_A_high.standardize
          (mean + quantile * Real.sqrt
            ((1 - pi) * sigmaSq *
                ((fixedPrecision + delta') /
                  (priorPrecision + (fixedPrecision + delta'))) +
              pi * sigmaSq *
                (fixedPrecision / (priorPrecision + fixedPrecision)))) =
        quantileScale *
            Real.sqrt (a * sqrtPrecHigh ^ 2 + c + d / sqrtPrecHigh ^ 2) -
          sqrtPrecHigh * (q - mean))
    (hquantile_pos : 0 < quantile)
    (hpriorPrecision_pos : 0 < priorPrecision)
    (hsigmaSq_pos : 0 < sigmaSq)
    (hleftWeight_pos : 0 < 1 - pi)
    (hbase_nonneg : 0 ≤ fixedPrecision + delta)
    (hterm_nonneg :
      0 ≤
        (1 - pi) * sigmaSq *
            ((fixedPrecision + delta) /
              (priorPrecision + (fixedPrecision + delta))) +
          pi * sigmaSq *
            (fixedPrecision / (priorPrecision + fixedPrecision)))
    (hdelta : delta < delta')
    (ha_pos : 0 < a) (ha_le_one : a ≤ 1)
    (hc_nonneg : 0 ≤ c) (hd_nonneg : 0 ≤ d)
    (hquantileScale_pos : 0 < quantileScale)
    (hhighSkill : quantileScale < q - mean)
    (hsqrtLow_pos : 0 < sqrtPrecLow)
    (hprecision : sqrtPrecLow < sqrtPrecHigh) :
    S.individualFairnessGap P_low q <
      S.individualFairnessGap P_high q :=
  paper_proposition1_individual_fairness_gap_increases_of_precision_gap_high_skill_formula
    api hgap_low hgap_high hstd_low hstd_high hquantile_pos
    hpriorPrecision_pos hsigmaSq_pos hleftWeight_pos hbase_nonneg
    hterm_nonneg hdelta ha_pos ha_le_one hc_nonneg hd_nonneg
    hquantileScale_pos hhighSkill hsqrtLow_pos hprecision

