        (glm20Proposition3SigmaTildeSource priorSigma priorPrecision
          (subPrecisionSum + 1 / testVarianceOld)) ≤
      paperProposition9HatGamma groupCapacity populationShare scaleSub
        (glm20Proposition3SigmaTildeSource priorSigma priorPrecision
          (subPrecisionSum + 1 / testVarianceNew)) :=
  paper_proposition9_hatGamma_mono_of_test_variance_increases
    hcapacity_nonneg hpopulation_pos hscaleSub_pos hpriorSigma_pos
    hpriorPrecision_pos hsubPrecision_nonneg hvarianceOld_pos
    hvarianceOld_le_new

