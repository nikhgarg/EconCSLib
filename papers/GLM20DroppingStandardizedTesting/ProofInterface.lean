    (hfull :
      S.diversity J1 (policyPair Pfull Pfull) =
        groupBPopulationShare * sigmaTildeB / capacity1 *
          verticalUpperStripMass
            (paperCorrelatedStandardGaussianLaw
              (-(sigmaTildeB * bB) /
                Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2)))
            ((aB + bB * mu) / Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2))
            ((q1Full - mu) / sigmaTildeB))
    (hsub :
      let threshold :=
        mu + sigmaTildeASub *
          Q.quantile ((1 - capacity1) * (1 - groupBPopulationShare) +
            groupBPopulationShare)
      let groupBLaw : GaussianScaleLaw :=
        { mean := mu, scale := sigmaTildeBSub, scale_pos := hsigmaBSub_pos }
      S.diversity J1 (policyPair Psub Pfull) =
        Q.cdfAPI.thresholdPassProb groupBLaw threshold) :
    paperProposition6J1DropsTestForDiversity S policyPair J1 Psub Pfull ↔
      groupBPopulationShare * sigmaTildeB / capacity1 *
          verticalUpperStripMass
            (paperCorrelatedStandardGaussianLaw
              (-(sigmaTildeB * bB) /
                Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2)))
            ((aB + bB * mu) / Real.sqrt (1 + sigmaTildeB ^ 2 * bB ^ 2))
            ((q1Full - mu) / sigmaTildeB) <
        paperProposition6SubDiversityFormula Q
          capacity1 groupBPopulationShare sigmaTildeASub sigmaTildeBSub :=
  paper_proposition6_j1_drops_test_iff_source_verticalStrip_lt_testFreeFormula
    Q S policyPair J1 hsigmaBSub_pos hfull hsub

