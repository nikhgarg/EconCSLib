/--
Paper Proposition 5(ii), school-`J2` case analysis before the
mass-inequality translation.

Paper statement: fixing `P1 = P_full`, school `J2` drops exactly when the
deviation expands the high-skill pool for exactly one group and that group's
cost lies above the lower positive threshold, with the higher threshold above
it. The no-expanding-group case gives no deviation, and the both-groups case
is ruled out by the capacity assumptions.
-/
theorem paper_interface_proposition5_part_ii_school2_cutoff_objective_iff_exactly_one_cost_case
    {Group Policy : Type*}
    {Psub Pfull : Policy} {groupA groupB : Group}
    {testCost lowCostThreshold highCostThreshold : Group → ℝ} {q2Sub : ℝ}
    {fullFullCutoff : Group → ℝ}
    (objective2 : Policy → Policy → ℝ)
    (hnone :
      ¬ q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ¬ objective2 Pfull Pfull ≤ objective2 Pfull Psub)
    (hboth_impossible :
      q2Sub < fullFullCutoff groupA →
        q2Sub < fullFullCutoff groupB → False)
    (honlyA :
      q2Sub < fullFullCutoff groupA →
        ¬ q2Sub < fullFullCutoff groupB →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            testCost groupA ≥ lowCostThreshold groupA ∧
              0 < lowCostThreshold groupA ∧
                lowCostThreshold groupA < highCostThreshold groupA))
    (honlyB :
      q2Sub < fullFullCutoff groupB →
        ¬ q2Sub < fullFullCutoff groupA →
          ((objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
            testCost groupB ≥ lowCostThreshold groupB ∧
              0 < lowCostThreshold groupB ∧
                lowCostThreshold groupB < highCostThreshold groupB)) :
    (objective2 Pfull Pfull ≤ objective2 Pfull Psub) ↔
      glm20ExactlyOneOfTwo groupA groupB
        (fun g =>
          (testCost g ≥ lowCostThreshold g ∧
              0 < lowCostThreshold g ∧
                lowCostThreshold g < highCostThreshold g) ∧
            q2Sub < fullFullCutoff g) :=
  paper_proposition5_part_ii_school2_cutoff_objective_iff_exactly_one_cost_case
    objective2 hnone hboth_impossible honlyA honlyB

