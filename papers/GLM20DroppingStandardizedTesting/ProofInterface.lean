    {priorPrecision subPrecisionSum fullPrecisionSum : ℝ}
    (hprior : 0 < priorPrecision) (hsub : 0 ≤ subPrecisionSum)
    (hfull : 0 ≤ fullPrecisionSum) :
    paperProposition3BSource
        priorPrecision subPrecisionSum fullPrecisionSum ^ 2 =
