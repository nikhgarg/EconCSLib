/--
Paper Theorem 2(ii) Gaussian-family adapter: the conditional posterior-score
admission probability generated by `GaussianOffsetSignalFamily` is exactly an
affine standard-normal upper tail in true skill.  This is the bridge from the
raw Gaussian feature model to the affine crossing statements.
-/
theorem paper_interface_theorem2_conditional_posterior_tail_eq_affineUpperTail
    {Feature : Type*} [Fintype Feature] [Nonempty Feature]
    (M : GaussianOffsetSignalFamily Feature) (threshold q : ℝ) :
    standardGaussianCDFAPI.thresholdPassProb
        (M.conditionalPosteriorMeanScaleLaw q) threshold =
      standardGaussianDerivativeAPI.affineUpperTail
        ((M.centeredFamily.priorPrecision * (threshold - M.priorMean) +
            M.centeredFamily.signalPrecisionSum * threshold) /
          Real.sqrt M.centeredFamily.signalPrecisionSum)
        (Real.sqrt M.centeredFamily.signalPrecisionSum) q :=
  standardGaussianDerivativeAPI
    |>.thresholdPassProb_conditionalPosteriorMeanScaleLaw_eq_affineUpperTail
      M threshold q

/--
Paper Theorem 2(ii), source-family threshold statement with constructed
capacity cutoffs.

Paper statement: for each group, there is a skill threshold above which the
admission probability decreases after dropping the test.  This interface theorem
constructs the no-barrier `P_sub` and `P_full` capacity-clearing cutoffs from
the concrete Gaussian mixtures and proves the two group-level affine crossing
thresholds.  It does not use the stronger crossed precision-order premise
needed by the bundled high-skill individual-fairness-gap wrapper.
-/
theorem paper_interface_theorem2_group_admission_thresholds_standardGaussian_source_families_capacity_thresholds
    {SubFeature FullFeature : Type*}
    [Fintype SubFeature] [Nonempty SubFeature]
    [Fintype FullFeature] [Nonempty FullFeature]
    {M_A_sub M_B_sub : GaussianOffsetSignalFamily SubFeature}
    {M_A_full M_B_full : GaussianOffsetSignalFamily FullFeature}
    {pi capacity priorPrecision mean subA subB testA testB : ℝ}
    (hcapacity_pos : 0 < capacity)
    (hcapacity_lt_one : capacity < 1)
    (hpriorPrecision : M_A_sub.centeredFamily.priorPrecision = priorPrecision)
    (hsubA_sum : M_A_sub.centeredFamily.signalPrecisionSum = subA)
    (hsubB_sum : M_B_sub.centeredFamily.signalPrecisionSum = subB)
    (hfullA_sum : M_A_full.centeredFamily.signalPrecisionSum = subA + testA)
    (hfullB_sum : M_B_full.centeredFamily.signalPrecisionSum = subB + testB)
    (htestA_pos : 0 < testA) (htestB_pos : 0 < testB)
    (hpi_pos : 0 < pi) (hpi_lt_one : pi < 1) :
    ∃ thresholdSub thresholdFull qA qB : ℝ,
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_sub.posteriorMeanScaleLaw thresholdSub +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_sub.posteriorMeanScaleLaw thresholdSub ∧
      capacity =
        (1 - pi) *
            standardGaussianCDFAPI.thresholdPassProb
              M_A_full.posteriorMeanScaleLaw thresholdFull +
          pi *
            standardGaussianCDFAPI.thresholdPassProb
              M_B_full.posteriorMeanScaleLaw thresholdFull ∧
      (∀ q : ℝ,
        standardGaussianDerivativeAPI.affineUpperTail
            ((priorPrecision * (thresholdFull - mean) +
                (subA + testA) * thresholdFull) /
              Real.sqrt (subA + testA))
            (Real.sqrt (subA + testA)) q >
          standardGaussianDerivativeAPI.affineUpperTail
            ((priorPrecision * (thresholdSub - mean) +
                subA * thresholdSub) /
              Real.sqrt subA)
            (Real.sqrt subA) q ↔
          qA < q) ∧
        (∀ q : ℝ,
          standardGaussianDerivativeAPI.affineUpperTail
              ((priorPrecision * (thresholdFull - mean) +
                  (subB + testB) * thresholdFull) /
                Real.sqrt (subB + testB))
              (Real.sqrt (subB + testB)) q >
            standardGaussianDerivativeAPI.affineUpperTail
              ((priorPrecision * (thresholdSub - mean) +
                  subB * thresholdSub) /
                Real.sqrt subB)
              (Real.sqrt subB) q ↔
            qB < q) :=
  paper_theorem2_group_admission_thresholds_standardGaussian_source_families_capacity_thresholds
    hcapacity_pos hcapacity_lt_one hpriorPrecision hsubA_sum hsubB_sum
    hfullA_sum hfullB_sum htestA_pos htestB_pos hpi_pos hpi_lt_one

