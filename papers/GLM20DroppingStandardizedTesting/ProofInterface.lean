/--
Paper Lemma 3: threshold formula with the school cutoff fixed.

Paper threshold-form statement: under `P_full`, each group has a cutoff
`q^g = q^*_{full} - scale_g * Phi^{-1}(1 - c_g / v)`, and students apply
exactly when projected skill is above that cutoff.
-/
theorem paper_interface_lemma3_full_policy_threshold_form_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold scale value cost : ℝ}
    (hscale : 0 < scale) (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ groupCutoff : ℝ,
      groupCutoff =
        glm20StrategicApplyCutoff Q admissionThreshold scale (cost / value) ∧
      ∀ q : ℝ,
        0 ≤ value *
            Q.cdfAPI.thresholdPassProb
              { mean := q, scale := scale, scale_pos := hscale }
              admissionThreshold - cost ↔
          groupCutoff ≤ q :=
  paper_lemma3_full_policy_threshold_form_standardGaussian Q hscale hvalue
    hcostRatio

/--
Paper Lemma 3: threshold formula with the paper's projected precision scale.

Paper statement: `q^g = q^*_{full} - scale_g * Phi^{-1}(1 - c_g / v)`,
where `scale_g` is the displayed function of prior, non-test, and test
precisions.
-/
theorem paper_interface_lemma3_full_policy_threshold_form_precision_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold priorPrecision subPrecision testPrecision value cost : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    ∃ groupCutoff : ℝ,
      groupCutoff =
        admissionThreshold -
          glm20StrategicProjectedScale
            priorPrecision subPrecision testPrecision *
              Q.quantile (1 - cost / value) ∧
      ∀ q : ℝ,
        0 ≤ value *
            Q.cdfAPI.thresholdPassProb
              { mean := q
                scale :=
                  glm20StrategicProjectedScale
                    priorPrecision subPrecision testPrecision
                scale_pos :=
                  glm20StrategicProjectedScale_pos
                    hprior_pos hsub_pos htest_pos }
              admissionThreshold - cost ↔
          groupCutoff ≤ q :=
  paper_lemma3_full_policy_threshold_form_precision_standardGaussian
    Q hprior_pos hsub_pos htest_pos hvalue hcostRatio

/--
Paper Lemma 3: student best-response part.

Paper statement: with a full-policy test requirement, the cutoff application
rule is optimal for the binary apply/not-apply decision.  This theorem proves
that statement for the displayed precision-scale Gaussian payoff.
-/
theorem paper_interface_lemma3_precision_cutoff_apply_bestResponse_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold priorPrecision subPrecision testPrecision value cost : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    let scale :=
      glm20StrategicProjectedScale priorPrecision subPrecision testPrecision
    let cutoff :=
      admissionThreshold - scale * Q.quantile (1 - cost / value)
    ∀ q : ℝ, ∀ apply : Bool,
      glm20StrategicApplyPayoff value cost
          (Q.cdfAPI.thresholdPassProb
            { mean := q
              scale := scale
              scale_pos :=
                glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
            admissionThreshold)
          apply ≤
        glm20StrategicApplyPayoff value cost
          (Q.cdfAPI.thresholdPassProb
            { mean := q
              scale := scale
              scale_pos :=
                glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
            admissionThreshold)
          (decide (cutoff ≤ q)) :=
  paper_lemma3_precision_cutoff_apply_bestResponse_standardGaussian
    Q hprior_pos hsub_pos htest_pos hvalue hcostRatio

/--
Paper Lemma 3: strict student best-response order.

Paper proof role: strict payoff separation around the displayed cutoff is what
rules out non-threshold student strategies in the one-school full-policy
equilibrium argument.  Below the cutoff, not applying strictly dominates
applying; above the cutoff, applying strictly dominates not applying.
-/
theorem paper_interface_lemma3_precision_cutoff_apply_strict_payoff_order_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold priorPrecision subPrecision testPrecision value cost : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hvalue : 0 < value)
    (hcostRatio : cost / value ∈ Set.Ioo (0 : ℝ) 1) :
    let scale :=
      glm20StrategicProjectedScale priorPrecision subPrecision testPrecision
    let cutoff :=
      admissionThreshold - scale * Q.quantile (1 - cost / value)
    (∀ q : ℝ, cutoff < q →
      glm20StrategicApplyPayoff value cost
          (Q.cdfAPI.thresholdPassProb
            { mean := q
              scale := scale
              scale_pos :=
                glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
            admissionThreshold)
          false <
        glm20StrategicApplyPayoff value cost
          (Q.cdfAPI.thresholdPassProb
            { mean := q
              scale := scale
              scale_pos :=
                glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
            admissionThreshold)
          true) ∧
      (∀ q : ℝ, q < cutoff →
        glm20StrategicApplyPayoff value cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale := scale
                scale_pos :=
                  glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
              admissionThreshold)
            true <
          glm20StrategicApplyPayoff value cost
            (Q.cdfAPI.thresholdPassProb
              { mean := q
                scale := scale
                scale_pos :=
                  glm20StrategicProjectedScale_pos hprior_pos hsub_pos htest_pos }
              admissionThreshold)
            false) :=
  paper_lemma3_precision_cutoff_apply_strict_payoff_order_standardGaussian
    Q hprior_pos hsub_pos htest_pos hvalue hcostRatio

/--
Paper Lemma 3: pointwise best responses have threshold form.

Paper proof role: after strict payoff separation is proved, any student
strategy that pointwise maximizes the displayed binary payoff must apply
strictly above the cutoff and not apply strictly below it.
-/
theorem paper_interface_lemma3_precision_pointwise_bestResponse_threshold_form_standardGaussian
    (Q : StandardGaussianQuantileAPI)
    {admissionThreshold priorPrecision subPrecision testPrecision value cost : ℝ}
    (hprior_pos : 0 < priorPrecision)
    (hsub_pos : 0 < subPrecision)
    (htest_pos : 0 < testPrecision)
    (hvalue : 0 < value)
