/--
Theorem 3.1 optional-reporting every-equilibrium law certificate wrapper with
the reporting decision literalized as the cutoff predicate.
-/
def paper_theorem3_1_optional_reporting_law_strategic_withholding_certificate_for_every_equilibrium_of_full_support_literal_cutoff_and_base_mixed_gaussian_posterior_surface
    {Feature Base Student Equilibrium : Type*}
    [Fintype Feature] [DecidableEq Feature]
    [Fintype Student] [DecidableEq Student] [Nonempty Base]
    (skillGivenBase : Equilibrium → Base → PMF ℝ)
    (baseProfile : Equilibrium → PMF Base)
    (M : Base → GaussianOffsetSignalFamily Feature)
    (theta : Base → Feature → ℝ) (k : Feature)
    (studentLaw : Equilibrium → Base → PMF Student)
    (reporterEvent : Equilibrium → Base → Student → Prop)
    (decReporterEvent : ∀ e base, DecidablePred (reporterEvent e base))
    (hfull_support :
      ∀ e base student, 0 < (studentLaw e base student).toReal)
    (studentScore : Equilibrium → Base → Student → ℝ)
    (cutoff : Equilibrium → Base → ℝ)
    (hEvent :
      ∀ e base student,
        reporterEvent e base student ↔
          cutoff e base ≤ studentScore e base student)
    (hbelow :
      ∀ e base, ∃ student, studentScore e base student < cutoff e base)
    (baseOnlyEstimate : Equilibrium → Base → ℝ)
    (scoreLaw : Equilibrium → Base → GaussianScaleLaw) :
    ∀ e : Equilibrium,
      LG21LawOptionalReportingStrategicWithholdingCertificate
        (lg21BaseMixedGaussianPosteriorLawSurface
          (skillGivenBase e) (baseProfile e) M theta k (scoreLaw e)
          (baseOnlyEstimate e)) := by
  let reportDecision : Equilibrium → Base → ℝ → Bool :=
    fun e base score => if cutoff e base ≤ score then true else false
  have hthreshold :
      ∀ e base score, reportDecision e base score = true ↔
        cutoff e base ≤ score := by
    intro e base score
    simpa [reportDecision] using
      (EconCSLib.bool_lowerCutoff_if_true_iff
        (cutoff := cutoff e base) (value := score))
  have hEventDecision :
      ∀ e base student,
        reporterEvent e base student ↔
          reportDecision e base (studentScore e base student) = true := by
    intro e base student
    rw [hEvent e base student]
    exact (hthreshold e base (studentScore e base student)).symm
  exact
    paper_theorem3_1_optional_reporting_law_strategic_withholding_certificate_for_every_equilibrium_of_full_support_threshold_support_and_base_mixed_gaussian_posterior_surface
      skillGivenBase baseProfile M theta k studentLaw reporterEvent
      decReporterEvent hfull_support studentScore reportDecision
      hEventDecision cutoff hthreshold hbelow baseOnlyEstimate scoreLaw

