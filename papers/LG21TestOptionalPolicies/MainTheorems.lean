  latent_or_observable_implies_test_blank :
    lg21SourceLawLatentSkillFair S ∨ lg21SourceLawObservablyFair S →
      lg21SourceLawTestBlank S

/-- Theorem 3.2 endpoint over arbitrary continuous law objects. -/
