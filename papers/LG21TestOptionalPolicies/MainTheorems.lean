theorem lg21FullFeatureEstimateBlankOnZeroEventShare_no_normalized_relevance_iff_no_raw_relevance_on_nonzero_share
    {Base Test Estimate Student Equilibrium : Type*}
    [Fintype Student] [DecidableEq Student]
