/--
Finite-support bridge for Theorem 3.2 optional reporting: if finite students'
reported-score event is represented by the threshold reporting decision and
each equilibrium/base profile has a student at or above the reporting cutoff,
then the ordinary finite reporter-existence premise follows.
-/
theorem paper_theorem3_2_optional_reporting_finite_reporter_exists_of_threshold_and_student_score_above_cutoff
    {Equilibrium Base Student : Type*}
    (studentScore : Equilibrium → Base → Student → ℝ)
    (reportDecision : Equilibrium → Base → ℝ → Bool)
    (reporterEvent : Equilibrium → Base → Student → Prop)
    (hEvent :
      ∀ e base student,
        reporterEvent e base student ↔
          reportDecision e base (studentScore e base student) = true)
    (cutoff : Equilibrium → Base → ℝ)
    (hthreshold :
      ∀ e base score,
        reportDecision e base score = true ↔ cutoff e base ≤ score)
    (habove :
      ∀ e base, ∃ student, cutoff e base ≤ studentScore e base student) :
    ∀ e base, ∃ student, reporterEvent e base student := by
  intro e base
  rcases habove e base with ⟨student, hle⟩
  refine ⟨student, ?_⟩
  exact
    (hEvent e base student).2
      (EconCSLib.bool_lowerCutoff_true_of_le (hthreshold e base) hle)

/--
Finite-support bridge for Theorem 3.1/3.2 optional reporting: if finite
students' reported-score event is represented by the threshold reporting
decision and each equilibrium/base profile has a student below the reporting
cutoff, then each profile has a finite non-reporter.
-/
theorem paper_theorem3_2_optional_reporting_finite_nonreporter_exists_of_threshold_and_student_score_below_cutoff
    {Equilibrium Base Student : Type*}
    (studentScore : Equilibrium → Base → Student → ℝ)
    (reportDecision : Equilibrium → Base → ℝ → Bool)
    (reporterEvent : Equilibrium → Base → Student → Prop)
    (hEvent :
      ∀ e base student,
        reporterEvent e base student ↔
          reportDecision e base (studentScore e base student) = true)
    (cutoff : Equilibrium → Base → ℝ)
    (hthreshold :
      ∀ e base score,
        reportDecision e base score = true ↔ cutoff e base ≤ score)
    (hbelow :
      ∀ e base, ∃ student, studentScore e base student < cutoff e base) :
    ∀ e base, ∃ student, ¬ reporterEvent e base student := by
  intro e base
  rcases hbelow e base with ⟨student, hlt⟩
  refine ⟨student, ?_⟩
  intro hevent
  have hfalse :
      reportDecision e base (studentScore e base student) = false :=
    EconCSLib.bool_lowerCutoff_false_of_lt (hthreshold e base) hlt
  have htrue := (hEvent e base student).1 hevent
  rw [hfalse] at htrue
  exact Bool.noConfusion htrue

