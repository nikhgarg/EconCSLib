        (S := lg21ExtraSignalPosteriorLawSurface
          Mbase extraNoiseMean extraNoiseVar hextraNoiseVar)
        PUnit.unit PUnit.unit rfl rfl rfl
        (GaussianOffsetSignalFamily.signalPrecisionSum_lt_withExtraSignal
