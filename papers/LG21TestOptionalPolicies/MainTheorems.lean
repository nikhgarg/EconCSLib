        skillGivenBase baseProfile M theta k accessFraction
        baseOnlyEstimate scoreLaw hC_nonneg hC_lt_one
  let W := Classical.choose h
  have hspec := Classical.choose_spec h
  exact
    { all_take := ∀ base skill, W.takes base skill
