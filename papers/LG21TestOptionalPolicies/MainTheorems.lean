  · intro hfair
    exact
      (lg21SkillMixtureBlankOnZeroEventShareRawMixtureSurface_fairness_iff_no_test_relevance_of_raw_observable_identities
        skillGivenBase latentAccessEstimate latentNoAccessEstimate
        demographicAccessEstimate demographicNoAccessEstimate studentLaw event
        decEvent reporterPMF baseOnlyEstimate hObsAccessRaw hObsNoAccessRaw
        testOf).mp hfair

