      LG21SchoolInformationSet.fromAccessAction_accessStatus_of_unobserved
        base test action
  · intro hfair
    exact
      (lg21SkillMixtureBlankOnZeroEventShareRawMixtureSurface_fairness_iff_testBlank_of_raw_observable_identities
        skillGivenBase latentAccessEstimate latentNoAccessEstimate
        demographicAccessEstimate demographicNoAccessEstimate studentLaw event
        decEvent reporterPMF baseOnlyEstimate hObsAccessRaw hObsNoAccessRaw
        testOf).mp hfair

/--
Section 3 closed skill-mixture raw-mixture paper endpoint: hidden access plus
latent-skill or observable fairness implies no test relevance.
-/
theorem paper_theorem3_2_section3_skill_mixture_raw_mixture_fairness_implies_no_test_relevance_of_raw_observable_identities
    {Skill Base Test Estimate Student Equilibrium : Type*}
    [Fintype Student] [DecidableEq Student]
