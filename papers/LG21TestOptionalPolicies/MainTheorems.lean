/--
For the event-share binary-mixture source surface with blank-on-zero
full-feature estimates, failure of test-blankness is exactly the existence of a
positive-mass reporter/taker event atom at a profile where the raw
full-feature estimate differs from the base-only estimate.
-/
theorem lg21EventShareBinaryMixtureEstimateSurface_not_testBlank_iff_exists_positive_event_and_raw_relevance
    {Skill Base Test Estimate Student Equilibrium : Type*}
    [Fintype Student] [DecidableEq Student]
    (latentAccessEstimate latentNoAccessEstimate :
      Equilibrium → Skill → Base → PMF Estimate)
    (demographicAccessEstimate demographicNoAccessEstimate :
      Equilibrium → PMF Estimate)
    (studentLaw : Equilibrium → Base → PMF Student)
    (event : Equilibrium → Base → Student → Prop)
    (decEvent : ∀ e base, DecidablePred (event e base))
    (reporterPMF noReporterPMF : Equilibrium → Base → PMF Estimate)
    (baseOnlyEstimate : Equilibrium → Base → PMF Estimate)
    (rawFullFeatureEstimate : Equilibrium → Base → Test → PMF Estimate) :
    ¬ lg21SourceTestBlank
      (lg21EventShareBinaryMixtureEstimateSurface
        (Skill := Skill) (Base := Base) (Test := Test)
        (Estimate := Estimate) (Student := Student)
        Equilibrium latentAccessEstimate latentNoAccessEstimate
        demographicAccessEstimate demographicNoAccessEstimate
        studentLaw event decEvent reporterPMF noReporterPMF
        baseOnlyEstimate
        (lg21FullFeatureEstimateBlankOnZeroEventShare
          studentLaw event decEvent baseOnlyEstimate
          rawFullFeatureEstimate)) ↔
      ∃ e base student test,
        event e base student ∧
          0 < (studentLaw e base student).toReal ∧
            baseOnlyEstimate e base ≠ rawFullFeatureEstimate e base test := by
  constructor
  · intro hnot
    have hrel :
        ∃ e base test,
          baseOnlyEstimate e base ≠
            lg21FullFeatureEstimateBlankOnZeroEventShare
              studentLaw event decEvent baseOnlyEstimate rawFullFeatureEstimate
              e base test := by
      have hwitness :=
        (lg21_not_testBlank_iff_exists_witness
          (S :=
            lg21EventShareBinaryMixtureEstimateSurface
              (Skill := Skill) (Base := Base) (Test := Test)
              (Estimate := Estimate) (Student := Student)
              Equilibrium latentAccessEstimate latentNoAccessEstimate
              demographicAccessEstimate demographicNoAccessEstimate
              studentLaw event decEvent reporterPMF noReporterPMF
              baseOnlyEstimate
              (lg21FullFeatureEstimateBlankOnZeroEventShare
                studentLaw event decEvent baseOnlyEstimate
                rawFullFeatureEstimate))).1 hnot
      simpa [lg21EventShareBinaryMixtureEstimateSurface,
        lg21BinaryMixtureEstimateSurface] using hwitness
    exact
      (lg21FullFeatureEstimateBlankOnZeroEventShare_exists_ne_baseOnly_iff_exists_positive_event_and_raw_ne
        studentLaw event decEvent baseOnlyEstimate
        rawFullFeatureEstimate).1 hrel
  · intro hraw
    have hrel :
        ∃ e base test,
          baseOnlyEstimate e base ≠
            lg21FullFeatureEstimateBlankOnZeroEventShare
              studentLaw event decEvent baseOnlyEstimate rawFullFeatureEstimate
              e base test :=
      (lg21FullFeatureEstimateBlankOnZeroEventShare_exists_ne_baseOnly_iff_exists_positive_event_and_raw_ne
        studentLaw event decEvent baseOnlyEstimate
        rawFullFeatureEstimate).2 hraw
    apply
      (lg21_not_testBlank_iff_exists_witness
        (S :=
          lg21EventShareBinaryMixtureEstimateSurface
            (Skill := Skill) (Base := Base) (Test := Test)
            (Estimate := Estimate) (Student := Student)
            Equilibrium latentAccessEstimate latentNoAccessEstimate
            demographicAccessEstimate demographicNoAccessEstimate
            studentLaw event decEvent reporterPMF noReporterPMF
            baseOnlyEstimate
            (lg21FullFeatureEstimateBlankOnZeroEventShare
              studentLaw event decEvent baseOnlyEstimate
              rawFullFeatureEstimate))).2
    simpa [lg21EventShareBinaryMixtureEstimateSurface,
      lg21BinaryMixtureEstimateSurface] using hrel

/--
For the event-share binary-mixture source surface with blank-on-zero
full-feature estimates, test-blankness is equivalent to the absence of a raw
test-relevance witness at positive-mass reporter/taker event profiles.
-/
theorem lg21EventShareBinaryMixtureEstimateSurface_testBlank_iff_no_positive_event_raw_relevance
    {Skill Base Test Estimate Student Equilibrium : Type*}
    [Fintype Student] [DecidableEq Student]
    (latentAccessEstimate latentNoAccessEstimate :
      Equilibrium → Skill → Base → PMF Estimate)
    (demographicAccessEstimate demographicNoAccessEstimate :
      Equilibrium → PMF Estimate)
    (studentLaw : Equilibrium → Base → PMF Student)
    (event : Equilibrium → Base → Student → Prop)
    (decEvent : ∀ e base, DecidablePred (event e base))
    (reporterPMF noReporterPMF : Equilibrium → Base → PMF Estimate)
    (baseOnlyEstimate : Equilibrium → Base → PMF Estimate)
    (rawFullFeatureEstimate : Equilibrium → Base → Test → PMF Estimate) :
    lg21SourceTestBlank
      (lg21EventShareBinaryMixtureEstimateSurface
        (Skill := Skill) (Base := Base) (Test := Test)
        (Estimate := Estimate) (Student := Student)
        Equilibrium latentAccessEstimate latentNoAccessEstimate
        demographicAccessEstimate demographicNoAccessEstimate
        studentLaw event decEvent reporterPMF noReporterPMF
        baseOnlyEstimate
        (lg21FullFeatureEstimateBlankOnZeroEventShare
          studentLaw event decEvent baseOnlyEstimate
          rawFullFeatureEstimate)) ↔
      ¬ ∃ e base student, ∃ test : Test,
        event e base student ∧
          0 < (studentLaw e base student).toReal ∧
            baseOnlyEstimate e base ≠ rawFullFeatureEstimate e base test := by
  classical
  constructor
  · intro hblank hraw
    exact
      ((lg21EventShareBinaryMixtureEstimateSurface_not_testBlank_iff_exists_positive_event_and_raw_relevance
        latentAccessEstimate latentNoAccessEstimate
        demographicAccessEstimate demographicNoAccessEstimate
        studentLaw event decEvent reporterPMF noReporterPMF
        baseOnlyEstimate rawFullFeatureEstimate).2 hraw) hblank
  · intro hno_raw
    by_contra hnot_blank
    exact hno_raw
      ((lg21EventShareBinaryMixtureEstimateSurface_not_testBlank_iff_exists_positive_event_and_raw_relevance
        latentAccessEstimate latentNoAccessEstimate
        demographicAccessEstimate demographicNoAccessEstimate
        studentLaw event decEvent reporterPMF noReporterPMF
        baseOnlyEstimate rawFullFeatureEstimate).1 hnot_blank)

