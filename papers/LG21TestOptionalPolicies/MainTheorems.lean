/--
Theorem 3.2 finite-mean support fact, converse direction: if a finite acting
distribution has a positive-mass actor strictly below its mean, then it also
has a positive-mass actor strictly above its mean.
-/
theorem paper_theorem3_2_exists_support_actor_gt_mean_of_exists_actor_lt_mean
    {Actor : Type*} [Fintype Actor] [DecidableEq Actor]
    (actorLaw : PMF Actor) (actorValue : Actor → ℝ)
    (hbelow :
      ∃ actor, 0 < (actorLaw actor).toReal ∧
        actorValue actor < pmfExp actorLaw actorValue) :
    ∃ actor, 0 < (actorLaw actor).toReal ∧
      pmfExp actorLaw actorValue < actorValue actor := by
  rcases hbelow with ⟨actor, hmass, hlt⟩
  have hneg_above :
      ∃ actor, 0 < (actorLaw actor).toReal ∧
        pmfExp actorLaw (fun actor => - actorValue actor) <
          - actorValue actor := by
    refine ⟨actor, hmass, ?_⟩
    rw [pmfExp_neg]
    linarith
  rcases
      paper_theorem3_2_exists_support_actor_lt_mean_of_exists_mean_lt_actor
        actorLaw (fun actor => - actorValue actor) hneg_above with
    ⟨actorHigh, hmassHigh, hneg_below⟩
  refine ⟨actorHigh, hmassHigh, ?_⟩
  rw [pmfExp_neg] at hneg_below
  linarith

/--
Theorem 3.2 finite degeneracy bridge: if no positive-mass actor is strictly
above the acting distribution mean, then every positive-mass actor is exactly
at that mean.
-/
theorem paper_theorem3_2_no_above_mean_actor_forces_support_at_mean
    {Actor : Type*} [Fintype Actor] [DecidableEq Actor]
    (actorLaw : PMF Actor) (actorValue : Actor → ℝ)
    (hno_above :
      ¬ ∃ actor, 0 < (actorLaw actor).toReal ∧
        pmfExp actorLaw actorValue < actorValue actor) :
    ∀ actor, 0 < (actorLaw actor).toReal →
      actorValue actor = pmfExp actorLaw actorValue := by
  intro actor hmass
  by_contra hne
  rcases lt_or_gt_of_ne hne with hlt | hgt
  · have habove :
        ∃ actor, 0 < (actorLaw actor).toReal ∧
          pmfExp actorLaw actorValue < actorValue actor :=
      paper_theorem3_2_exists_support_actor_gt_mean_of_exists_actor_lt_mean
        actorLaw actorValue ⟨actor, hmass, hlt⟩
    exact hno_above habove
  · exact hno_above ⟨actor, hmass, hgt⟩

