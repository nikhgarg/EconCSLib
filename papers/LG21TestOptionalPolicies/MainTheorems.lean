    {Skill Base Test Law : Type*} [Nonempty Skill]
    {S : LG21SourceLawPolicySurface Skill Base Test Law}
    (hAccess :
      ∀ e q base, S.latentAccessLaw e q base =
        S.observableAccessLaw e base)
    (hNoAccess :
