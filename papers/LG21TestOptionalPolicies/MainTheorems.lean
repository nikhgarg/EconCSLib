    {Skill Base Test Law : Type*}
    {S : LG21SourceLawPolicySurface Skill Base Test Law}
    (C : LG21LawFairnessImpossibilityCertificate S) :
    (∀ (base : Base) (test : Test) (action : LG21AccessAction),
