    ∀ e base test,
      baseOnlyEstimate e base =
        lg21FullFeatureEstimateBlankOnZeroEventShare
          studentLaw event decEvent baseOnlyEstimate rawFullFeatureEstimate
          e base test := by
  exact
    EconCSLib.indexedValueBlankOnZeroEventShare_eq_base_of_all_zero_share
      studentLaw event decEvent baseOnlyEstimate rawFullFeatureEstimate hzero

/--
For the event-share binary-mixture source surface, the blank-on-zero-share
constructor gives Definition 5 test-blankness directly when all reporter/taker
event shares are zero.
-/
theorem lg21EventShareBinaryMixtureEstimateSurface_testBlank_of_blankOnZeroEventShare_zero_share
    {Skill Base Test Estimate Student Equilibrium : Type*}
    [Fintype Student] [DecidableEq Student]
    (latentAccessEstimate latentNoAccessEstimate :
      Equilibrium → Skill → Base → PMF Estimate)
