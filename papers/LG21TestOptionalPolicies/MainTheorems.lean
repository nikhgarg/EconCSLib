theorem lg21SkillMixtureBlankOnZeroEventShareRawMixtureSurface_fairness_iff_no_positive_event_raw_relevance
    {Skill Base Test Estimate Student Equilibrium : Type*}
    [Fintype Student] [DecidableEq Student]
