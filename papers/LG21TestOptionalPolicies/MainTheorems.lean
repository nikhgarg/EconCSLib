/-- Observable fairness implies demographic fairness when the base-profile law is shared. -/
theorem lg21_demographicallyFair_of_observableFair
    {ΩBase Estimate : Type*} (baseProfile : PMF ΩBase)
    {access noAccess : ΩBase → PMF Estimate}
    (hobs : lg21ObservableFair access noAccess) :
    lg21DemographicallyFair baseProfile access noAccess := by
  exact demographicallyFair_of_observableFair baseProfile hobs

/--
Definition 6 as a source policy surface.  The single equilibrium represents
the resampling policy: access students receive the observed conditional
test-score pushforward, no-access students receive the resampled conditional
test-score pushforward, and demographic laws mix those kernels over the common
base-profile law.
-/
noncomputable def lg21ResamplingSourcePolicySurface
    {ΩBase ΩTest Estimate : Type*} [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate) :
    LG21SourcePolicySurface PUnit ΩBase ΩTest Estimate where
  Equilibrium := PUnit
  latentAccessEstimate := fun _ _ base => lg21AccessEstimateKernel e base
  latentNoAccessEstimate := fun _ _ base => lg21ResamplingEstimateKernel e base
  observableAccessEstimate := fun _ base => lg21AccessEstimateKernel e base
  observableNoAccessEstimate := fun _ base => lg21ResamplingEstimateKernel e base
  demographicAccessEstimate := fun _ =>
    lg21DemographicEstimateDistribution e.baseProfile
      (lg21AccessEstimateKernel e)
  demographicNoAccessEstimate := fun _ =>
    lg21DemographicEstimateDistribution e.baseProfile
      (lg21ResamplingEstimateKernel e)
  baseOnlyEstimate := fun _ base => lg21ResamplingEstimateKernel e base
  fullFeatureEstimate := fun _ base test => PMF.pure (e.estimate base test)

/--
Definition 6 as a source policy surface over an arbitrary skill type.  Latent
estimate kernels are skill-independent copies of the observable kernels; this
is the source-shaped version of the conditional-resampling construction when
the theorem statement wants to keep a nontrivial skill type in scope.
-/
noncomputable def lg21ResamplingSourcePolicySurfaceForSkill
    (Skill : Type*) {ΩBase ΩTest Estimate : Type*}
    [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate) :
    LG21SourcePolicySurface Skill ΩBase ΩTest Estimate where
  Equilibrium := PUnit
  latentAccessEstimate := fun _ _ base => lg21AccessEstimateKernel e base
  latentNoAccessEstimate := fun _ _ base => lg21ResamplingEstimateKernel e base
  observableAccessEstimate := fun _ base => lg21AccessEstimateKernel e base
  observableNoAccessEstimate := fun _ base => lg21ResamplingEstimateKernel e base
  demographicAccessEstimate := fun _ =>
    lg21DemographicEstimateDistribution e.baseProfile
      (lg21AccessEstimateKernel e)
  demographicNoAccessEstimate := fun _ =>
    lg21DemographicEstimateDistribution e.baseProfile
      (lg21ResamplingEstimateKernel e)
  baseOnlyEstimate := fun _ base => lg21ResamplingEstimateKernel e base
  fullFeatureEstimate := fun _ base test => PMF.pure (e.estimate base test)

/--
Definition 6 source-surface identity: access estimate laws are the conditional
kernel pushforward.
-/
theorem paper_definition6_resampling_source_surface_observable_access_eq_kernel
    {ΩBase ΩTest Estimate : Type*} [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate)
    (base : ΩBase) :
    (lg21ResamplingSourcePolicySurface e).observableAccessEstimate PUnit.unit base =
      lg21AccessEstimateKernel e base := by
  rfl

/--
Definition 6 source-surface identity: no-access estimate laws are the
resampled conditional-kernel pushforward.
-/
theorem paper_definition6_resampling_source_surface_observable_noAccess_eq_kernel
    {ΩBase ΩTest Estimate : Type*} [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate)
    (base : ΩBase) :
    (lg21ResamplingSourcePolicySurface e).observableNoAccessEstimate PUnit.unit base =
      lg21ResamplingEstimateKernel e base := by
  rfl

/--
Definition 6, finite-kernel form: re-sampling uses the same conditional
test-score law that generated observed test scores for access students.
-/
theorem paper_definition6_resampling_policy_observable_kernel
    {ΩBase ΩTest Estimate : Type*} [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate) :
    lg21ResamplingPolicyKernel e = e.signalGivenBase := by
  exact resamplingSignalKernel_eq_signalGivenBase e

/--
Definition 6 access-side estimate law: access students' estimates are obtained
by pushing the observed conditional test-score law through the common
estimation map.
-/
theorem paper_definition6_access_estimate_kernel_eq_map
    {ΩBase ΩTest Estimate : Type*} [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate) (base : ΩBase) :
    lg21AccessEstimateKernel e base =
      (e.signalGivenBase base).map (fun test => e.estimate base test) := by
  rfl

/--
Definition 6 no-access estimate law: the re-sampled test score is drawn from
the same conditional law and then passed through the same estimation map.
-/
theorem paper_definition6_resampling_estimate_kernel_eq_map
    {ΩBase ΩTest Estimate : Type*} [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate) (base : ΩBase) :
    lg21ResamplingEstimateKernel e base =
      (e.signalGivenBase base).map (fun test => e.estimate base test) := by
  rfl

/--
Definition 6 immediate distributional identity: conditional on a base profile,
access and re-sampled no-access estimates use the same test-score law and
estimation map.
-/
theorem paper_definition6_access_estimate_kernel_eq_resampling_estimate_kernel
    {ΩBase ΩTest Estimate : Type*} [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate) (base : ΩBase) :
    lg21AccessEstimateKernel e base = lg21ResamplingEstimateKernel e base := by
  rfl

/--
Theorem 4.4, observable-fairness core.

Conditional on each non-test base profile, the access estimate and the
re-sampled no-access estimate are pushforwards of the same conditional
test-score distribution through the same estimation map.
-/
theorem paper_theorem4_4_resampling_policy_observably_fair
    {ΩBase ΩTest Estimate : Type*} [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate) :
    lg21ObservableFair (lg21AccessEstimateKernel e) (lg21ResamplingEstimateKernel e) := by
  intro base
  rfl

/--
Theorem 4.4, demographic-fairness core.

Mixing the conditional observable-fairness identity over the shared base-profile
distribution gives equality of the overall access and no-access estimate laws.
-/
theorem paper_theorem4_4_resampling_policy_demographically_fair
    {ΩBase ΩTest Estimate : Type*} [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate) :
    lg21DemographicallyFair e.baseProfile
      (lg21AccessEstimateKernel e) (lg21ResamplingEstimateKernel e) := by
  exact lg21_demographicallyFair_of_observableFair e.baseProfile
    (paper_theorem4_4_resampling_policy_observably_fair e)

/--
Theorem 4.4 source-surface latent-skill fairness for Definition 6's
conditional-resampling policy.
-/
theorem paper_theorem4_4_resampling_source_surface_latent_skill_fair
    {ΩBase ΩTest Estimate : Type*} [Fintype ΩBase] [DecidableEq ΩBase]
    (e : LG21ResamplingExperiment ΩBase ΩTest Estimate) :
    lg21SourceLatentSkillFair (lg21ResamplingSourcePolicySurface e) := by
  intro eq skill base
  cases eq
  cases skill
  exact paper_definition6_access_estimate_kernel_eq_resampling_estimate_kernel e base

