          (actorLaw e base) (decisionThreshold e base)
    exact (hthreshold e base skill).2 (le_of_lt (by
      simpa [hskill_eq] using hupper_gt))
  taking_threshold := hthreshold
  signalWeight_pos := by
    intro _e _base
    norm_num
  denom_pos := by
    intro _e _base
    norm_num

