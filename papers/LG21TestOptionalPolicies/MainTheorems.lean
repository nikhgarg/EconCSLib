    {S : LG21SourceLawPolicySurface Skill Base Test Law}
    (W : LG21LawObservableFairTestBlankSourceWitness S) :
    lg21SourceLawObservablyFair S → lg21SourceLawTestBlank S := by
  letI : Fintype W.Actor := W.actorFintype
  letI : DecidableEq W.Actor := W.actorDecidableEq
  exact
    paper_theorem3_2_law_observable_fair_best_response_implies_test_blank_of_off_mean_positive_mass_actor_witness
      (S := S) (Outcome := W.Outcome) (Actor := W.Actor)
      W.chooses W.choosePayoff W.otherPayoff W.bestResponse W.mass W.law_ext
      W.positiveShare W.positiveShare_pos W.reporterLaw W.noReporterLaw
      W.observableNoAccess_eq W.observableAccess_mixture W.actorLaw
      W.actorValue W.chooses_support W.baseTerm W.signalWeight W.denom
      W.choosePayoff_eq W.otherPayoff_eq_of_law_eq W.signalWeight_pos
      W.denom_pos W.nonblank_off_mean

/--
Theorem 3.2 latent-to-observable reduction.  If latent-skill fairness implies
observable fairness, then it is enough to prove the test-blank implication for
observable fairness.
-/
theorem paper_theorem3_2_fairness_impossibility_of_observable_implication
    {Skill Base Test Estimate : Type*}
    {S : LG21SourcePolicySurface Skill Base Test Estimate}
    (hlatent_to_observable :
      lg21SourceLatentSkillFair S → lg21SourceObservablyFair S)
    (hobservable_to_test_blank :
      lg21SourceObservablyFair S → lg21SourceTestBlank S) :
    lg21SourceLatentSkillFair S ∨ lg21SourceObservablyFair S →
      lg21SourceTestBlank S := by
  intro hfair
  cases hfair with
  | inl hlatent =>
      exact hobservable_to_test_blank (hlatent_to_observable hlatent)
  | inr hobservable =>
      exact hobservable_to_test_blank hobservable

/--
Theorem 3.2 logical endpoint for branches that prove the stronger statement
that latent skill fairness or observable fairness is impossible.  This puts
those contradiction-style branches back in the paper's implication form:
fairness implies test-blankness.
-/
theorem paper_theorem3_2_fairness_implies_test_blank_of_not_latent_or_observable_fair
    {Skill Base Test Estimate : Type*}
    {S : LG21SourcePolicySurface Skill Base Test Estimate}
    (hnotFair :
      ¬ (lg21SourceLatentSkillFair S ∨ lg21SourceObservablyFair S)) :
    lg21SourceLatentSkillFair S ∨ lg21SourceObservablyFair S →
      lg21SourceTestBlank S := by
  intro hfair
  exact False.elim (hnotFair hfair)

/--
Theorem 3.2 Section 3 packaging: once a concrete route proves that latent or
observable fairness implies test blankness, the hidden-access information-set
hypothesis can be bundled with that implication.
-/
theorem paper_theorem3_2_section3_fairness_implies_test_blank_of_implication
    {Skill Base Test Estimate : Type*}
    {S : LG21SourcePolicySurface Skill Base Test Estimate}
    (himp :
      lg21SourceLatentSkillFair S ∨ lg21SourceObservablyFair S →
        lg21SourceTestBlank S) :
    (∀ (base : Base) (test : Test) (action : LG21AccessAction),
        (LG21SchoolInformationSet.fromAccessAction false base test action).accessStatus =
          none) ∧
      (lg21SourceLatentSkillFair S ∨ lg21SourceObservablyFair S →
        lg21SourceTestBlank S) := by
  refine ⟨?_, himp⟩
  intro base test action
  exact
    LG21SchoolInformationSet.fromAccessAction_accessStatus_of_unobserved
      base test action

/--
Theorem 3.2 no-relevance packaging: under any route proving that latent or
observable fairness implies test blankness, fairness rules out a concrete
base/test relevance witness.
