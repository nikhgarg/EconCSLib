/--
If a demographic comparison is identified with one observable profile of the
skill-mixture raw-mixture surface, then a positive-mass event with a genuine
reporter/base-only law difference also gives the demographic-fairness witness.
-/
theorem lg21SkillMixtureBlankOnZeroEventShareRawMixtureSurface_demographic_ne_of_positive_event_reporter_ne_baseOnly_of_raw_observable_and_demographic_identities
    {Skill Base Estimate Student Equilibrium : Type*}
    [Fintype Student] [DecidableEq Student]
    (skillGivenBase : Base → PMF Skill)
    (latentAccessEstimate latentNoAccessEstimate :
      Equilibrium → Skill → Base → PMF Estimate)
    (demographicAccessEstimate demographicNoAccessEstimate :
      Equilibrium → PMF Estimate)
    (studentLaw : Equilibrium → Base → PMF Student)
    (event : Equilibrium → Base → Student → Prop)
    (decEvent : ∀ e base, DecidablePred (event e base))
    (reporterPMF : Equilibrium → Base → PMF Estimate)
    (baseOnlyEstimate : Equilibrium → Base → PMF Estimate)
    (hObsAccessRaw :
      ∀ e base,
        lg21LatentSkillEstimateDistribution skillGivenBase
          (latentAccessEstimate e) base =
          lg21BinaryMixturePMF
            (lg21PMFEventShareFn studentLaw event decEvent e base)
            (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
            (reporterPMF e base) (baseOnlyEstimate e base))
    (hObsNoAccessRaw :
      ∀ e base,
        lg21LatentSkillEstimateDistribution skillGivenBase
          (latentNoAccessEstimate e) base =
          baseOnlyEstimate e base)
    (eDemo eRaw : Equilibrium) (baseRaw : Base) (studentRaw : Student)
    (hDemoAccessObservable :
      demographicAccessEstimate eDemo =
        lg21LatentSkillEstimateDistribution skillGivenBase
          (latentAccessEstimate eRaw) baseRaw)
    (hDemoNoAccessObservable :
      demographicNoAccessEstimate eDemo =
        lg21LatentSkillEstimateDistribution skillGivenBase
          (latentNoAccessEstimate eRaw) baseRaw)
    (hRawEvent : event eRaw baseRaw studentRaw)
    (hRawMass : 0 < (studentLaw eRaw baseRaw studentRaw).toReal)
    (hReporterNe :
      reporterPMF eRaw baseRaw ≠ baseOnlyEstimate eRaw baseRaw) :
    demographicAccessEstimate eDemo ≠
      demographicNoAccessEstimate eDemo := by
  have hshare_pos :
      0 < (lg21PMFEventShareFn studentLaw event decEvent eRaw baseRaw).toReal := by
    exact
      (lg21PMFEventShareFn_pos_iff_exists_pos_mass
        studentLaw event decEvent eRaw baseRaw).2
        ⟨studentRaw, hRawEvent, hRawMass⟩
  have hmix_ne :
      lg21BinaryMixturePMF
          (lg21PMFEventShareFn studentLaw event decEvent eRaw baseRaw)
          (lg21PMFEventShareFn_le_one studentLaw event decEvent eRaw baseRaw)
          (reporterPMF eRaw baseRaw) (baseOnlyEstimate eRaw baseRaw) ≠
        baseOnlyEstimate eRaw baseRaw :=
    lg21BinaryMixturePMF_ne_noReporter_of_pos_of_ne
      (lg21PMFEventShareFn studentLaw event decEvent eRaw baseRaw)
      (lg21PMFEventShareFn_le_one studentLaw event decEvent eRaw baseRaw)
      (reporterPMF eRaw baseRaw) (baseOnlyEstimate eRaw baseRaw)
      hshare_pos hReporterNe
  have hDemoAccessRaw :
      demographicAccessEstimate eDemo =
        lg21BinaryMixturePMF
          (lg21PMFEventShareFn studentLaw event decEvent eRaw baseRaw)
          (lg21PMFEventShareFn_le_one studentLaw event decEvent eRaw baseRaw)
          (reporterPMF eRaw baseRaw) (baseOnlyEstimate eRaw baseRaw) :=
    hDemoAccessObservable.trans (hObsAccessRaw eRaw baseRaw)
  have hDemoNoAccessRaw :
      demographicNoAccessEstimate eDemo =
        baseOnlyEstimate eRaw baseRaw :=
    hDemoNoAccessObservable.trans (hObsNoAccessRaw eRaw baseRaw)
  intro hDemoEq
  exact hmix_ne (hDemoAccessRaw.symm.trans (hDemoEq.trans hDemoNoAccessRaw))

