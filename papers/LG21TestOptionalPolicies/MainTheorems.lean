/--
Canonical blank-on-zero event-share source surface for the raw reporter/base-only
binary-mixture route.
-/
noncomputable abbrev lg21BlankOnZeroEventShareRawMixtureSurface
    {Skill Base Test Estimate Student : Type*}
    [Fintype Student] [DecidableEq Student]
    (Equilibrium : Type*)
    (latentAccessEstimate latentNoAccessEstimate :
      Equilibrium → Skill → Base → PMF Estimate)
    (demographicAccessEstimate demographicNoAccessEstimate :
      Equilibrium → PMF Estimate)
    (studentLaw : Equilibrium → Base → PMF Student)
    (event : Equilibrium → Base → Student → Prop)
    (decEvent : ∀ e base, DecidablePred (event e base))
    (reporterPMF : Equilibrium → Base → PMF Estimate)
    (baseOnlyEstimate : Equilibrium → Base → PMF Estimate) :
    LG21SourcePolicySurface Skill Base Test Estimate :=
  lg21BlankOnZeroEventShareBinaryMixtureEstimateSurface
    (Skill := Skill) (Base := Base) (Test := Test)
    (Estimate := Estimate) (Student := Student)
    Equilibrium latentAccessEstimate latentNoAccessEstimate
    demographicAccessEstimate demographicNoAccessEstimate
    studentLaw event decEvent reporterPMF baseOnlyEstimate
    baseOnlyEstimate
    (fun e base _ =>
      lg21BinaryMixturePMF
        (lg21PMFEventShareFn studentLaw event decEvent e base)
        (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
        (reporterPMF e base) (baseOnlyEstimate e base))

/--
Canonical blank-on-zero event-share source surface for the raw
reporter/base-only binary-mixture route, with observable access/no-access laws
defined as mixtures of skill-conditioned latent laws.  This is the paper-shaped
variant of `lg21BlankOnZeroEventShareRawMixtureSurface`: the observable fields
are not assumed constant in skill, but are obtained by integrating over
`skillGivenBase`.
-/
noncomputable abbrev lg21SkillMixtureBlankOnZeroEventShareRawMixtureSurface
    {Skill Base Test Estimate Student : Type*}
    [Fintype Student] [DecidableEq Student]
    (Equilibrium : Type*) (skillGivenBase : Base → PMF Skill)
    (latentAccessEstimate latentNoAccessEstimate :
      Equilibrium → Skill → Base → PMF Estimate)
    (demographicAccessEstimate demographicNoAccessEstimate :
      Equilibrium → PMF Estimate)
    (studentLaw : Equilibrium → Base → PMF Student)
    (event : Equilibrium → Base → Student → Prop)
    (decEvent : ∀ e base, DecidablePred (event e base))
    (reporterPMF : Equilibrium → Base → PMF Estimate)
    (baseOnlyEstimate : Equilibrium → Base → PMF Estimate) :
    LG21SourcePolicySurface Skill Base Test Estimate where
  Equilibrium := Equilibrium
  latentAccessEstimate := latentAccessEstimate
  latentNoAccessEstimate := latentNoAccessEstimate
  observableAccessEstimate := fun e base =>
    lg21LatentSkillEstimateDistribution skillGivenBase
      (latentAccessEstimate e) base
  observableNoAccessEstimate := fun e base =>
    lg21LatentSkillEstimateDistribution skillGivenBase
      (latentNoAccessEstimate e) base
  demographicAccessEstimate := demographicAccessEstimate
  demographicNoAccessEstimate := demographicNoAccessEstimate
  baseOnlyEstimate := baseOnlyEstimate
  fullFeatureEstimate :=
    lg21FullFeatureEstimateBlankOnZeroEventShare
      studentLaw event decEvent baseOnlyEstimate
      (fun e base _ =>
        lg21BinaryMixturePMF
          (lg21PMFEventShareFn studentLaw event decEvent e base)
          (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
          (reporterPMF e base) (baseOnlyEstimate e base))

/--
Observable-identity certificate for the canonical blank-on-zero event-share
surface whose no-reporter/no-taker law is the base-only law and whose raw
full-feature law is the displayed reporter/no-reporter binary mixture.
-/
noncomputable def lg21BlankOnZeroEventShareBinaryMixtureEstimateSurface_observableIdentities_of_raw_mixture
    {Skill Base Test Estimate Student Equilibrium : Type*}
    [Fintype Student] [DecidableEq Student]
    (latentAccessEstimate latentNoAccessEstimate :
      Equilibrium → Skill → Base → PMF Estimate)
    (demographicAccessEstimate demographicNoAccessEstimate :
      Equilibrium → PMF Estimate)
    (studentLaw : Equilibrium → Base → PMF Student)
    (event : Equilibrium → Base → Student → Prop)
    (decEvent : ∀ e base, DecidablePred (event e base))
    (reporterPMF : Equilibrium → Base → PMF Estimate)
    (baseOnlyEstimate : Equilibrium → Base → PMF Estimate)
    (testOf : Equilibrium → Base → Test) :
    LG21FullFeatureBaseOnlyObservableIdentities
      (lg21BlankOnZeroEventShareBinaryMixtureEstimateSurface
        (Skill := Skill) (Base := Base) (Test := Test)
        (Estimate := Estimate) (Student := Student)
        Equilibrium latentAccessEstimate latentNoAccessEstimate
        demographicAccessEstimate demographicNoAccessEstimate
        studentLaw event decEvent reporterPMF baseOnlyEstimate
        baseOnlyEstimate
        (fun e base _ =>
          lg21BinaryMixturePMF
            (lg21PMFEventShareFn studentLaw event decEvent e base)
            (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
            (reporterPMF e base) (baseOnlyEstimate e base))) where
  testOf := testOf
  observableAccess_eq_fullFeature := by
    intro e base
    by_cases hzero :
      (lg21PMFEventShareFn studentLaw event decEvent e base).toReal = 0
    · have hmix :
          lg21BinaryMixturePMF
              (lg21PMFEventShareFn studentLaw event decEvent e base)
              (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
              (reporterPMF e base) (baseOnlyEstimate e base) =
            baseOnlyEstimate e base :=
        lg21BinaryMixturePMF_eq_noReporter_of_zero
          (lg21PMFEventShareFn studentLaw event decEvent e base)
          (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
          (reporterPMF e base) (baseOnlyEstimate e base) hzero
      have hblank :
          lg21FullFeatureEstimateBlankOnZeroEventShare
              studentLaw event decEvent baseOnlyEstimate
              (fun e base _ =>
                lg21BinaryMixturePMF
                  (lg21PMFEventShareFn studentLaw event decEvent e base)
                  (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
                  (reporterPMF e base) (baseOnlyEstimate e base))
              e base (testOf e base) =
            baseOnlyEstimate e base :=
        lg21FullFeatureEstimateBlankOnZeroEventShare_eq_baseOnly_of_zero_share
          studentLaw event decEvent baseOnlyEstimate
          (fun e base _ =>
            lg21BinaryMixturePMF
              (lg21PMFEventShareFn studentLaw event decEvent e base)
              (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
              (reporterPMF e base) (baseOnlyEstimate e base))
          e base hzero (testOf e base)
      simpa [lg21BlankOnZeroEventShareBinaryMixtureEstimateSurface,
        lg21EventShareBinaryMixtureEstimateSurface,
        lg21BinaryMixtureEstimateSurface] using hmix.trans hblank.symm
    · have hraw :
          lg21FullFeatureEstimateBlankOnZeroEventShare
              studentLaw event decEvent baseOnlyEstimate
              (fun e base _ =>
                lg21BinaryMixturePMF
                  (lg21PMFEventShareFn studentLaw event decEvent e base)
                  (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
                  (reporterPMF e base) (baseOnlyEstimate e base))
              e base (testOf e base) =
            lg21BinaryMixturePMF
              (lg21PMFEventShareFn studentLaw event decEvent e base)
              (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
              (reporterPMF e base) (baseOnlyEstimate e base) :=
        lg21FullFeatureEstimateBlankOnZeroEventShare_eq_raw_of_nonzero_share
          studentLaw event decEvent baseOnlyEstimate
          (fun e base _ =>
            lg21BinaryMixturePMF
              (lg21PMFEventShareFn studentLaw event decEvent e base)
              (lg21PMFEventShareFn_le_one studentLaw event decEvent e base)
              (reporterPMF e base) (baseOnlyEstimate e base))
          e base hzero (testOf e base)
      simpa [lg21BlankOnZeroEventShareBinaryMixtureEstimateSurface,
        lg21EventShareBinaryMixtureEstimateSurface,
        lg21BinaryMixtureEstimateSurface] using hraw.symm
  observableNoAccess_eq_baseOnly := by
    intro e base
    rfl

/--
Observable-identity certificate for the skill-mixture raw-mixture surface,
assuming the mixed latent access/no-access laws agree with the paper's
displayed reporter/base-only laws.
-/
noncomputable def lg21SkillMixtureBlankOnZeroEventShareRawMixtureSurface_observableIdentities
    {Skill Base Test Estimate Student Equilibrium : Type*}
    [Fintype Student] [DecidableEq Student]
    (skillGivenBase : Base → PMF Skill)
    (latentAccessEstimate latentNoAccessEstimate :
      Equilibrium → Skill → Base → PMF Estimate)
    (demographicAccessEstimate demographicNoAccessEstimate :
      Equilibrium → PMF Estimate)
    (studentLaw : Equilibrium → Base → PMF Student)
    (event : Equilibrium → Base → Student → Prop)
    (decEvent : ∀ e base, DecidablePred (event e base))
    (reporterPMF : Equilibrium → Base → PMF Estimate)
    (baseOnlyEstimate : Equilibrium → Base → PMF Estimate)
    (hObsAccessRaw :
      ∀ e base,
        lg21LatentSkillEstimateDistribution skillGivenBase
          (latentAccessEstimate e) base =
          lg21BinaryMixturePMF
            (lg21PMFEventShareFn studentLaw event decEvent e base)
