theorem im05_daStateAfterStepsFrom_preserves_currentMatchOrder_of_invariants
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (start : DAState M W) (steps : ℕ)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinvStart : DAInvariants val_m val_w start)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m start) :
    im05_ManCurrentMatchOrderInvariant val_m
      (daStateAfterStepsFrom val_m val_w start steps) := by
  induction steps with
  | zero =>
      simpa using hmatchOrder
  | succ steps ih =>
      have hinvSteps :
          DAInvariants val_m val_w
            (daStateAfterStepsFrom val_m val_w start steps) :=
        daStateAfterStepsFrom_satisfies_invariants
          val_m val_w start steps hinvStart
      have hmatchSteps :
          im05_ManCurrentMatchOrderInvariant val_m
            (daStateAfterStepsFrom val_m val_w start steps) := ih
      simpa [daStateAfterStepsFrom_succ] using
        im05_daStep_preserves_currentMatchOrder_of_invariants
          val_m val_w (daStateAfterStepsFrom val_m val_w start steps)
          hstrictW hacceptable hinvSteps hmatchSteps

theorem im05_deferredAcceptanceState_currentMatchOrder_of_allPairsAcceptable
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
