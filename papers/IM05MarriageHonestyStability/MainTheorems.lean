theorem im05_stableHusband_initial_target_proposal_mem_sourceDivorceTargetAcceptedMen
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    {m : M}
    (hstableHusband : m ∈ im05_stableHusbands val_m val_w g)
    (hactive :
      ∃ a, IsActiveMan val_m
        (im05_algorithm41DivorcedState val_m val_w g) a)
    (hchosen :
      daStepChosenMan val_m (im05_algorithm41DivorcedState val_m val_w g)
        hactive = m)
    (htarget :
      daStepChosenWoman val_m (im05_algorithm41DivorcedState val_m val_w g)
        hactive = g) :
    m ∈ im05_algorithm41SourceDivorceTargetAcceptedMen val_m val_w g := by
  rcases hactive with ⟨a, ha⟩
  have hactive' :
      ∃ a, IsActiveMan val_m
        (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g 0) a := by
    simpa using ⟨a, ha⟩
  have hcardM : 0 < Fintype.card M := Fintype.card_pos_iff.mpr ⟨a⟩
  have hcardW : 0 < Fintype.card W := Fintype.card_pos_iff.mpr ⟨g⟩
  have ht : 0 < Fintype.card M * Fintype.card W := Nat.mul_pos hcardM hcardW
