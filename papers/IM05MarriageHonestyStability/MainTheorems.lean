        μ event hneg
  exact
    paper_im05_lemma4_1_from_variance_and_lemma4_3
      μ X Y g n k hg (EconCSLib.pmfExp μ (fun ω => (Y ω : ℝ)))
      (by simpa [Y] using hEY_lower)
      rfl hvar
      (by
        intro ω
        simpa [Y] using hXY ω)

/--
Corrected Lemma 4.1 bridge using the repaired Lemma 4.4 tail statement.  The
random variable in the Chebyshev step is the absent count over an explicit
rank-tail block, not the false unrestricted `Y_g` count over all ranks up to
