/--
Experiment 4-to-5 monotonicity: if the women named in Experiment 4 are a
subset of the women named in Experiment 5 outcome by outcome, then Experiment 5
has weakly fewer unnamed women. This is the deterministic source of `X4 >= X5`.
-/
theorem paper_im05_experiment4_5_empty_count_mono
    {Ω Slot₄ Slot₅ W : Type*}
    [Fintype Slot₄] [Fintype Slot₅] [Fintype W] [DecidableEq W]
    (names₄ : Ω → Slot₄ → W) (names₅ : Ω → Slot₅ → W)
    (hused : ∀ ω,
      EconCSLib.occupancyUsedBins (names₄ ω) ⊆
        EconCSLib.occupancyUsedBins (names₅ ω)) :
    ∀ ω,
      (EconCSLib.occupancyEmptyBins (names₅ ω)).card ≤
        (EconCSLib.occupancyEmptyBins (names₄ ω)).card := by
  intro ω
  exact EconCSLib.occupancyEmptyBins_card_le_of_usedBins_subset
    (names₄ ω) (names₅ ω) (hused ω)

/--
Experiment 4-to-5 reciprocal-expectation monotonicity: if Experiment 5 names
every woman named in Experiment 4, then `E[1/(X4+1)] <= E[1/(X5+1)]`.
-/
theorem paper_im05_experiment4_5_reciprocal_expectation_mono
    {Ω Slot₄ Slot₅ W : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype Slot₄] [Fintype Slot₅] [Fintype W] [DecidableEq W]
    (μ : PMF Ω)
    (names₄ : Ω → Slot₄ → W) (names₅ : Ω → Slot₅ → W)
    (hused : ∀ ω,
      EconCSLib.occupancyUsedBins (names₄ ω) ⊆
        EconCSLib.occupancyUsedBins (names₅ ω)) :
    im05_reciprocalCountExpectation μ
        (fun ω => (EconCSLib.occupancyEmptyBins (names₄ ω)).card) ≤
      im05_reciprocalCountExpectation μ
        (fun ω => (EconCSLib.occupancyEmptyBins (names₅ ω)).card) := by
  exact EconCSLib.pmfExpReciprocalSucc_mono_of_forall_ge μ _ _
    (paper_im05_experiment4_5_empty_count_mono names₄ names₅ hused)

/--
Experiment 4-to-5 monotonicity from an explicit slot map: if Experiment 4's
named slots are read from Experiment 5's `k+1` slots, then every woman named in
Experiment 4 is also named in Experiment 5.
-/
theorem paper_im05_experiment4_5_empty_count_mono_of_slot_map
    {Ω Slot₄ Slot₅ W : Type*}
    [Fintype Slot₄] [Fintype Slot₅] [Fintype W] [DecidableEq W]
    (slot : Slot₄ → Slot₅) (names₅ : Ω → Slot₅ → W) :
    ∀ ω,
      (EconCSLib.occupancyEmptyBins (names₅ ω)).card ≤
        (EconCSLib.occupancyEmptyBins
          (fun slot₄ => names₅ ω (slot slot₄))).card := by
  refine paper_im05_experiment4_5_empty_count_mono
    (fun ω slot₄ => names₅ ω (slot slot₄)) names₅ ?_
  intro ω
  exact EconCSLib.occupancyUsedBins_comp_subset slot (names₅ ω)

/--
Experiment 4-to-5 reciprocal-expectation monotonicity from an explicit slot
map into Experiment 5's slots.
-/
theorem paper_im05_experiment4_5_reciprocal_expectation_mono_of_slot_map
    {Ω Slot₄ Slot₅ W : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype Slot₄] [Fintype Slot₅] [Fintype W] [DecidableEq W]
    (μ : PMF Ω) (slot : Slot₄ → Slot₅) (names₅ : Ω → Slot₅ → W) :
    im05_reciprocalCountExpectation μ
        (fun ω =>
          (EconCSLib.occupancyEmptyBins
            (fun slot₄ => names₅ ω (slot slot₄))).card) ≤
      im05_reciprocalCountExpectation μ
        (fun ω => (EconCSLib.occupancyEmptyBins (names₅ ω)).card) := by
  exact paper_im05_experiment4_5_reciprocal_expectation_mono μ
    (fun ω slot₄ => names₅ ω (slot slot₄)) names₅
    (fun ω => EconCSLib.occupancyUsedBins_comp_subset slot (names₅ ω))

/--
Lemma 6.3: in the `(m,n)` occupancy problem, if `Y_{m,n}` is the number of
empty bins, then `E[1/(Y_{m,n}+1)] <= exp(m/n)/n`.
-/
theorem paper_im05_lemma6_3_occupancy_reciprocal_bound
    (m n : ℕ) [NeZero n] :
    im05_occupancyReciprocalExpectation m n ≤
      Real.exp ((m : ℝ) / (n : ℝ)) / (n : ℝ) := by
  exact EconCSLib.occupancyReciprocalExpectation_fin_le_exp_div m n

/-- Lemma 6.3 in the `m = (k+1)n` form used in the proof of Lemma 6.1. -/
theorem paper_im05_lemma6_3_k_plus_one_n_bound
    (k n : ℕ) [NeZero n] :
    im05_occupancyReciprocalExpectation ((k + 1) * n) n ≤
      Real.exp ((k : ℝ) + 1) / (n : ℝ) := by
  have h :=
    paper_im05_lemma6_3_occupancy_reciprocal_bound ((k + 1) * n) n
  have hnpos : 0 < (n : ℝ) := by
    exact_mod_cast (NeZero.pos n)
  have harg : (((((k + 1) * n : ℕ) : ℝ) / (n : ℝ))) =
      (k : ℝ) + 1 := by
    rw [Nat.cast_mul, Nat.cast_add, Nat.cast_one]
    field_simp [ne_of_gt hnpos]
  simpa [harg] using h

/-- Lemma 6.1 follows from Lemma 6.2 and the closed occupancy Lemma 6.3. -/
theorem paper_im05_lemma6_1_from_lemma6_2
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (X : Ω → ℕ) (k n : ℕ) [NeZero n]
    (h62 :
      im05_reciprocalCountExpectation μ X ≤
        im05_occupancyReciprocalExpectation ((k + 1) * n) n +
          (k : ℝ) ^ 2 / (n : ℝ)) :
    im05_reciprocalCountExpectation μ X ≤
      im05_uniformTheorem32Bound k / (n : ℝ) := by
  have h63 := paper_im05_lemma6_3_k_plus_one_n_bound k n
  calc
    im05_reciprocalCountExpectation μ X ≤
        im05_occupancyReciprocalExpectation ((k + 1) * n) n +
          (k : ℝ) ^ 2 / (n : ℝ) := h62
    _ ≤ Real.exp ((k : ℝ) + 1) / (n : ℝ) +
          (k : ℝ) ^ 2 / (n : ℝ) :=
        add_le_add h63 le_rfl
    _ = im05_uniformTheorem32Bound k / (n : ℝ) := by
        unfold im05_uniformTheorem32Bound
        ring

/--
Theorem 3.2 algebraic endpoint: the paper reduces the expected number `c_k(n)`
of women with more than one stable husband to `n * E[1/(X+1)]`; Lemma 6.1 then
gives the stated constant bound `e^(k+1) + k^2`.
-/
theorem paper_im05_theorem3_2_from_lemma6_1
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (X : Ω → ℕ) (ck : ℝ) (k n : ℕ) [NeZero n]
    (hck :
      ck ≤ (n : ℝ) * im05_reciprocalCountExpectation μ X)
    (h61 :
      im05_reciprocalCountExpectation μ X ≤
        im05_uniformTheorem32Bound k / (n : ℝ)) :
    ck ≤ im05_uniformTheorem32Bound k := by
  have hnpos : 0 < (n : ℝ) := by
    exact_mod_cast (NeZero.pos n)
  calc
    ck ≤ (n : ℝ) * im05_reciprocalCountExpectation μ X := hck
    _ ≤ (n : ℝ) * (im05_uniformTheorem32Bound k / (n : ℝ)) :=
        mul_le_mul_of_nonneg_left h61 (le_of_lt hnpos)
    _ = im05_uniformTheorem32Bound k := by
        field_simp [ne_of_gt hnpos]

/--
Theorem 3.2 through the paper's Lemma 6.2/Lemma 6.3 route: once the reduction
`c_k(n) <= n * E[1/(X+1)]` and Lemma 6.2 are supplied, the closed occupancy
Lemma 6.3 yields the paper's constant bound.
-/
theorem paper_im05_theorem3_2_from_lemma6_2
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (X : Ω → ℕ) (ck : ℝ) (k n : ℕ) [NeZero n]
    (hck :
      ck ≤ (n : ℝ) * im05_reciprocalCountExpectation μ X)
    (h62 :
      im05_reciprocalCountExpectation μ X ≤
        im05_occupancyReciprocalExpectation ((k + 1) * n) n +
          (k : ℝ) ^ 2 / (n : ℝ)) :
    ck ≤ im05_uniformTheorem32Bound k := by
  exact paper_im05_theorem3_2_from_lemma6_1 μ X ck k n hck
    (paper_im05_lemma6_1_from_lemma6_2 μ X k n h62)

/--
Theorem 3.2 through the source's five-experiment Lemma 6.2 route in the
distinct-name bad-event language. This packages all closed algebra, occupancy,
and `k >= 4` perturbation steps; the remaining hypotheses are the concrete
experiment construction, the reduction to `c_k(n)`, and the source's per-pair
