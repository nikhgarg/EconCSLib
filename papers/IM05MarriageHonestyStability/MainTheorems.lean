prefer the chosen woman in candidate stable matchings that keep the displaced
pair.
-/
theorem im05_SourceStepNonTargetBlockingPairPreferences_of_stableMatchExclusions
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (exception : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinv : DAInvariantsExceptWoman val_m val_w s exception)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s exception)
    (hexcl :
      im05_SourceStepNonTargetStableMatchExclusions val_m val_w
        s exception) :
    im05_SourceStepNonTargetBlockingPairPreferences val_m val_w
      s exception := by
  classical
  intro hactive hnonTarget
  constructor
  · intro hreject mu hstable hmu_w r hr hbetter
    exact
      im05_prior_proposer_prefers_woman_in_stable_match_except_exception
        val_m val_w s exception
        (daStepChosenWoman val_m s hactive)
        hstrictM hacceptable hproposalOrder hmatchOrder hrejected
        hstable hmu_w hnonTarget hr hbetter
        ((hexcl hactive hnonTarget).1 hreject r hr hbetter mu hstable)
  · intro haccept cur hcur mu hstable hcurw
    let a := daStepChosenMan val_m s hactive
    let w := daStepChosenWoman val_m s hactive
    have hact : IsActiveMan val_m s a := by
      simpa [a, daStepChosenMan] using Classical.choose_spec hactive
    have hwbest : BestRemainingWoman val_m s a w := by
      simpa [a, w, daStepChosenWoman, daStepChosenMan, hact] using
        Classical.choose_spec (exists_best_woman val_m s a hact)
    have hda : daStepChosenAccepts val_m val_w s hactive :=
      (im05_algorithm41SourceStepAccepts_iff_daStepChosenAccepts_of_invariantsExceptWoman_nonTarget
        val_m val_w s exception hstrictW hacceptable hinv hactive hnonTarget).1
        haccept
    have hwomanPref : val_w w cur < val_w w a := by
      simpa [daStepChosenAccepts, a, w, hcur] using hda
    have ha_ne_cur : a ≠ cur := by
      intro h
      subst cur
      exact (lt_irrefl (val_w w a)) hwomanPref
    have hcur_w : mu.w_match w = some cur := by
      simpa [w] using (mu.consistent_m cur w).1 hcurw
    have ha_not_w : mu.m_match a ≠ some w := by
      intro ha_w
      have hw_a : mu.w_match w = some a :=
        (mu.consistent_m a w).1 ha_w
      exact ha_ne_cur (Option.some.inj (hw_a.symm.trans hcur_w))
    exact
      im05_active_proposer_prefers_chosen_in_stable_match_except_exception
        val_m val_w s exception hstrictM hacceptable hrejected hstable hact
        hwbest
        ((hexcl hactive hnonTarget).2 haccept cur hcur mu hstable)
        (by simpa [a, w] using ha_not_w)

/--
If a stable husband is the active proposer to the target in a state satisfying
the target-exception rejection-impossibility package, the source step must emit
him as a target-acceptance event.
-/
theorem im05_algorithm41SourceStepTargetAccepted_eq_some_of_stableHusband_target_proposal
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s target)
    (hactive : ∃ a, IsActiveMan val_m s a)
    {b : M}
    (hchosen :
      daStepChosenMan val_m s hactive = b)
    (htarget :
      daStepChosenWoman val_m s hactive = target)
    (hstableHusband : b ∈ im05_stableHusbands val_m val_w target) :
    im05_algorithm41SourceStepTargetAccepted val_m val_w target s = some b := by
  classical
  by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
  · simp [im05_algorithm41SourceStepTargetAccepted, hactive, hacc, htarget,
      hchosen]
  · have hnotStable :=
      im05_algorithm41SourceStep_target_reject_not_mem_stableHusbands_of_rejected_pair_impossible_except_target
        val_m val_w s target hstrictM hacceptable hproposalOrder hmatchOrder
        hrejected hactive hchosen htarget hacc
    exact False.elim (hnotStable hstableHusband)

