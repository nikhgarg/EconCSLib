              (im05_integerMultisetPermutationList sample)).erase j).card) ≤
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          k ≤
            (im05_namesBeforeFirst id i
              (im05_integerMultisetPermutationList sample)).card) := by
  classical
  exact
    paper_im05_lemma4_4_multiset_event_inclusion_probability
      (EconCSLib.uniformPMF
        (im05_integerMultisetPermutationSample Name count))
      im05_integerMultisetPermutationList id i j k

/--
Lemma 4.4 multiset-limit bridge: the source proves the one-man comparison
`Pr[F_i | F_j] <= Pr[F_i]` by approximating the weighted list process with
large random permutations of integer multisets.  The finite multiset event
inclusion gives `approxCond M <= approxBase M` for every multiset scale `M`;
this lemma is the closed limiting step from those finite inequalities to the
one-man comparison.
-/
theorem paper_im05_lemma4_4_one_man_comparison_from_multiset_limits
    (approxCond approxBase : ℕ → ℝ) (condProb baseProb : ℝ)
    (hfinite : ∀ M : ℕ, approxCond M ≤ approxBase M)
    (hcond_lim : Filter.Tendsto approxCond Filter.atTop (nhds condProb))
    (hbase_lim : Filter.Tendsto approxBase Filter.atTop (nhds baseProb)) :
    condProb ≤ baseProb :=
  EconCSLib.Math.le_of_tendsto_atTop_of_forall_le
    hcond_lim hbase_lim hfinite

/--
Lemma 4.4 one-man comparison from the source's finite permutation models.  For
each finite scale, the deletion/inclusion argument proves the finite
inequality; the caller only supplies the two convergence statements identifying
the permutation events' limits.
