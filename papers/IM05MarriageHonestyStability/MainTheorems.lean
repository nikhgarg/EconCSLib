theorem im05_divorceWomanState_preserves_rejectedPairImpossibleExceptWoman
    {M W : Type*} [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s target) :
    im05_DARejectedPairImpossibleExceptWoman val_m val_w
      (divorceWomanState s target) target := by
  intro mu hstable m w hne hnot hnotMatch
  exact hrejected mu hstable m w hne
    (by simpa [divorceWomanState] using hnot)
    (by
      intro hmatchOld
      by_cases hm : s.w_match target = some m
      · have hm_target : s.m_match m = some target := (s.consistent m target).2 hm
        have hw : w = target := Option.some.inj (hmatchOld.symm.trans hm_target)
        exact hne hw
      · exact hnotMatch
          (by simpa [divorceWomanState, hm] using hmatchOld))

theorem im05_algorithm41SourceStepDivorceTarget_preserves_rejectedPairImpossibleExceptWoman_of_target_chosen
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hactive : ∃ a, IsActiveMan val_m s a)
    (htarget : daStepChosenWoman val_m s hactive = target)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s target) :
    im05_DARejectedPairImpossibleExceptWoman val_m val_w
      (im05_algorithm41SourceStepDivorceTarget val_m val_w target s)
      target := by
  classical
  intro mu hstable m w hne hnot hnotMatch
  apply hrejected mu hstable m w hne
  · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · have hnot_remove :
          w ∉ removeProposal s (daStepChosenMan val_m s hactive) target m := by
        simpa [im05_algorithm41SourceStepDivorceTarget,
          im05_algorithm41SourceStep, hactive, hacc, htarget] using hnot
      exact (not_mem_of_not_mem_removeProposal s hnot_remove).elim
        (fun h => h)
        (fun hnew => False.elim (hne hnew.2))
    · have hnot_remove :
          w ∉ removeProposal s (daStepChosenMan val_m s hactive) target m := by
        simpa [im05_algorithm41SourceStepDivorceTarget,
          im05_algorithm41SourceStep, hactive, hacc, htarget] using hnot
      exact (not_mem_of_not_mem_removeProposal s hnot_remove).elim
        (fun h => h)
        (fun hnew => False.elim (hne hnew.2))
  · intro hmatchOld
    by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · let post := im05_algorithm41SourceStep val_m val_w s
      have hpost : post.m_match m = some w := by
        by_cases hm : m = daStepChosenMan val_m s hactive
        · subst m
          have hnone :
              s.m_match (daStepChosenMan val_m s hactive) = none := by
            simpa [daStepChosenMan] using (Classical.choose_spec hactive).1
          rw [hnone] at hmatchOld
          cases hmatchOld
        · by_cases hcur : s.w_match target = some m
          · have hm_target : s.m_match m = some target :=
              (s.consistent m target).2 hcur
            have hw : w = target := Option.some.inj (hmatchOld.symm.trans hm_target)
            exact False.elim (hne hw)
          · simpa [post, im05_algorithm41SourceStep, hactive, hacc, htarget,
              hm, hcur] using hmatchOld
      have hpost_target_ne : post.w_match target ≠ some m := by
        intro hpostTarget
        have hm_target : post.m_match m = some target :=
          (post.consistent m target).2 hpostTarget
        have hw : w = target := Option.some.inj (hpost.symm.trans hm_target)
        exact hne hw
      have hnew :
          (im05_algorithm41SourceStepDivorceTarget val_m val_w target s).m_match
            m = some w := by
        simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc, htarget,
          post, divorceWomanState, hpost_target_ne] using hpost
      exact hnotMatch hnew
    · have hnew :
          (im05_algorithm41SourceStepDivorceTarget val_m val_w target s).m_match
            m = some w := by
        simpa [im05_algorithm41SourceStepDivorceTarget,
          im05_algorithm41SourceStep, hactive, hacc, htarget] using hmatchOld
      exact hnotMatch hnew

theorem im05_algorithm41SourceStepDivorceTarget_preserves_rejectedPairImpossibleExceptWoman_of_nonTarget_exclusions
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s target)
    (hnewReject :
      ∀ hactive : ∃ a, IsActiveMan val_m s a,
        daStepChosenWoman val_m s hactive ≠ target →
          ¬ im05_algorithm41SourceStepAccepts val_m val_w s hactive →
            ∀ mu, IsStable val_m val_w mu →
              mu.m_match (daStepChosenMan val_m s hactive) ≠
                some (daStepChosenWoman val_m s hactive))
    (hdisplaced :
      ∀ hactive : ∃ a, IsActiveMan val_m s a,
        daStepChosenWoman val_m s hactive ≠ target →
          im05_algorithm41SourceStepAccepts val_m val_w s hactive →
            ∀ cur,
              s.w_match (daStepChosenWoman val_m s hactive) = some cur →
                ∀ mu, IsStable val_m val_w mu →
                  mu.m_match cur ≠ some (daStepChosenWoman val_m s hactive)) :
    im05_DARejectedPairImpossibleExceptWoman val_m val_w
      (im05_algorithm41SourceStepDivorceTarget val_m val_w target s)
      target := by
  classical
  by_cases hactive : ∃ a, IsActiveMan val_m s a
  · by_cases htarget : daStepChosenWoman val_m s hactive = target
    · exact
        im05_algorithm41SourceStepDivorceTarget_preserves_rejectedPairImpossibleExceptWoman_of_target_chosen
          val_m val_w s target hactive htarget hrejected
    · intro mu hstable m w hne hnot hnotMatch
      by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
      · have hnotRemove :
            w ∉ removeProposal s (daStepChosenMan val_m s hactive)
              (daStepChosenWoman val_m s hactive) m := by
          simpa [im05_algorithm41SourceStepDivorceTarget,
            im05_algorithm41SourceStep, hactive, hacc, htarget] using hnot
        rcases not_mem_of_not_mem_removeProposal s hnotRemove with
          hnotOld | hnew
        · by_cases hold : s.m_match m = some w
          · by_cases hm : m = daStepChosenMan val_m s hactive
            · subst m
              have hnone :
                  s.m_match (daStepChosenMan val_m s hactive) = none := by
                simpa [daStepChosenMan] using (Classical.choose_spec hactive).1
              rw [hnone] at hold
              cases hold
            · by_cases hcur :
                s.w_match (daStepChosenWoman val_m s hactive) = some m
              · have holdW :
                    s.m_match m = some (daStepChosenWoman val_m s hactive) :=
                  (s.consistent m (daStepChosenWoman val_m s hactive)).2 hcur
                have hw : w = daStepChosenWoman val_m s hactive :=
                  Option.some.inj (hold.symm.trans holdW)
                subst w
                exact hdisplaced hactive htarget hacc m hcur mu hstable
              · exact False.elim
                  (hnotMatch (by
                    simpa [im05_algorithm41SourceStepDivorceTarget,
                      im05_algorithm41SourceStep, hactive, hacc, htarget,
                      hm, hcur] using hold))
          · exact hrejected mu hstable m w hne hnotOld hold
        · rcases hnew with ⟨hm, hw⟩
          subst m
          subst w
          exact False.elim
            (hnotMatch (by
              simp [im05_algorithm41SourceStepDivorceTarget,
                im05_algorithm41SourceStep, hactive, hacc, htarget]))
      · have hnotRemove :
            w ∉ removeProposal s (daStepChosenMan val_m s hactive)
              (daStepChosenWoman val_m s hactive) m := by
          simpa [im05_algorithm41SourceStepDivorceTarget,
            im05_algorithm41SourceStep, hactive, hacc] using hnot
        rcases not_mem_of_not_mem_removeProposal s hnotRemove with
          hnotOld | hnew
        · exact hrejected mu hstable m w hne hnotOld
            (by
              intro hold
              exact hnotMatch (by
                simpa [im05_algorithm41SourceStepDivorceTarget,
                  im05_algorithm41SourceStep, hactive, hacc] using hold))
        · rcases hnew with ⟨hm, hw⟩
          subst m
          subst w
          exact hnewReject hactive htarget hacc mu hstable
  · simpa [im05_algorithm41SourceStepDivorceTarget, hactive] using hrejected

theorem im05_algorithm41SourceStepDivorceTarget_preserves_rejectedPairImpossibleExceptWoman_of_stepNonTargetExclusions
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
