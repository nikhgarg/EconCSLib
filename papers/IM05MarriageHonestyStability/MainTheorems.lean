/--
Theorem 3.1 summation layer: any pointwise upper bounds on the fixed-woman
multi-stable-husband probabilities bound the expected number of women with more
than one stable husband.
-/
theorem paper_im05_expected_multiStableHusbandCount_le_sum_bounds
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype M] [Fintype W] [DecidableEq W]
    (μ : PMF Ω)
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ)
    (bound : W → ℝ)
    (hbound : ∀ w : W,
      @EconCSLib.pmfProb Ω _ _ μ
          (fun ω =>
            im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
          (Classical.decPred _) ≤ bound w) :
    EconCSLib.pmfExp μ
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) ≤
      ∑ w : W, bound w := by
  classical
  calc
    EconCSLib.pmfExp μ
        (fun ω =>
          (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) =
        ∑ w : W,
          @EconCSLib.pmfProb Ω _ _ μ
            (fun ω =>
              im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
            (Classical.decPred _) :=
        paper_im05_ck_linearity_expected_multiStableHusbandCount μ val_m val_w
    _ ≤ ∑ w : W, bound w := by
        exact Finset.sum_le_sum (by
          intro w _hw
          exact hbound w)

/--
Theorem 3.1 split-sum layer: bound exceptional women trivially by probability
`1`, and use supplied pointwise bounds on the non-exceptional tail.
-/
theorem paper_im05_expected_multiStableHusbandCount_le_exceptional_add_tail_bounds
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype M] [Fintype W] [DecidableEq W]
    (μ : PMF Ω)
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ)
    (exceptional : Finset W) (bound : W → ℝ)
    (hbound : ∀ w : W, w ∉ exceptional →
      @EconCSLib.pmfProb Ω _ _ μ
          (fun ω =>
            im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
          (Classical.decPred _) ≤ bound w) :
    EconCSLib.pmfExp μ
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) ≤
      (exceptional.card : ℝ) +
        ∑ w ∈ (Finset.univ : Finset W) \ exceptional, bound w := by
  classical
  let prob : W → ℝ := fun w =>
    @EconCSLib.pmfProb Ω _ _ μ
      (fun ω =>
        im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
      (Classical.decPred _)
  have hlinear :
      EconCSLib.pmfExp μ
          (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) =
        ∑ w : W, prob w := by
    exact paper_im05_ck_linearity_expected_multiStableHusbandCount μ val_m val_w
  have hsplit :
      ∑ w : W, prob w =
        (∑ w ∈ exceptional, prob w) +
          ∑ w ∈ (Finset.univ : Finset W) \ exceptional, prob w := by
    have hsubset : exceptional ⊆ (Finset.univ : Finset W) := by
      intro w _hw
      simp
    have hsum :=
      Finset.sum_sdiff (s₁ := exceptional)
        (s₂ := (Finset.univ : Finset W)) (f := prob) hsubset
    calc
      ∑ w : W, prob w = ∑ w ∈ (Finset.univ : Finset W), prob w := by
        simp
      _ = ∑ w ∈ (Finset.univ : Finset W) \ exceptional, prob w +
            ∑ w ∈ exceptional, prob w := hsum.symm
      _ = (∑ w ∈ exceptional, prob w) +
            ∑ w ∈ (Finset.univ : Finset W) \ exceptional, prob w := by
        rw [add_comm]
  have hexceptional :
      (∑ w ∈ exceptional, prob w) ≤ (exceptional.card : ℝ) := by
    calc
      (∑ w ∈ exceptional, prob w) ≤ ∑ _w ∈ exceptional, (1 : ℝ) := by
          exact Finset.sum_le_sum (by
            intro w _hw
            exact EconCSLib.pmfProb_le_one μ
              (fun ω =>
                im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w))
      _ = (exceptional.card : ℝ) := by
          simp
  have htail :
      (∑ w ∈ (Finset.univ : Finset W) \ exceptional, prob w) ≤
        ∑ w ∈ (Finset.univ : Finset W) \ exceptional, bound w := by
    exact Finset.sum_le_sum (by
      intro w hw
      have hnot : w ∉ exceptional := by
        exact (Finset.mem_sdiff.mp hw).2
      exact hbound w hnot)
  calc
    EconCSLib.pmfExp μ
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) =
        ∑ w : W, prob w := hlinear
    _ = (∑ w ∈ exceptional, prob w) +
          ∑ w ∈ (Finset.univ : Finset W) \ exceptional, prob w := hsplit
    _ ≤ (exceptional.card : ℝ) +
          ∑ w ∈ (Finset.univ : Finset W) \ exceptional, bound w :=
        add_le_add hexceptional htail

/--
Theorem 3.1 tail-term algebra: past the source threshold
`16 n k / log n`, the Lemma 4.1 pointwise bound is at most the uniform summand
used in the displayed proof of Theorem 3.1.
-/
theorem paper_im05_theorem3_1_tail_term_bound
    (n k g : ℕ) (hn : 0 < n) (hk : 0 < k) (hg : 0 < g)
    (hlog_pos : 0 < Real.log (n : ℝ))
    (hthreshold :
      16 * (n : ℝ) * (k : ℝ) / Real.log (n : ℝ) ≤ (g : ℝ)) :
    12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ)) / (g : ℝ) ≤
      3 * Real.log (n : ℝ) * Real.sqrt (n : ℝ) /
        (4 * (n : ℝ) * (k : ℝ)) := by
  have hn_pos : 0 < (n : ℝ) := by exact_mod_cast hn
  have hk_pos : 0 < (k : ℝ) := by exact_mod_cast hk
  have hg_pos : 0 < (g : ℝ) := by exact_mod_cast hg
  have hthreshold_mul :
      16 * (n : ℝ) * (k : ℝ) ≤
        (g : ℝ) * Real.log (n : ℝ) := by
    rw [div_le_iff₀ hlog_pos] at hthreshold
    simpa [mul_assoc] using hthreshold
  have hexp_arg :
      8 * (n : ℝ) * (k : ℝ) / (g : ℝ) ≤
        Real.log (n : ℝ) / 2 := by
    rw [div_le_iff₀ hg_pos]
    nlinarith
  have hexp_le :
      Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ)) ≤
        Real.sqrt (n : ℝ) := by
    calc
      Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ)) ≤
          Real.exp (Real.log (n : ℝ) / 2) :=
          Real.exp_le_exp.mpr hexp_arg
      _ = Real.sqrt (n : ℝ) := by
          rw [Real.exp_half, Real.exp_log hn_pos]
  let threshold : ℝ :=
    16 * (n : ℝ) * (k : ℝ) / Real.log (n : ℝ)
  have hthreshold_pos : 0 < threshold := by
    dsimp [threshold]
    positivity
  have hinv_threshold :
      ((g : ℝ)⁻¹) ≤
        Real.log (n : ℝ) / (16 * (n : ℝ) * (k : ℝ)) := by
    have hinv : ((g : ℝ)⁻¹) ≤ threshold⁻¹ :=
      (inv_le_inv₀ hg_pos hthreshold_pos).mpr
        (by simpa [threshold] using hthreshold)
    have hthreshold_inv :
        threshold⁻¹ =
          Real.log (n : ℝ) / (16 * (n : ℝ) * (k : ℝ)) := by
      dsimp [threshold]
      field_simp [ne_of_gt hlog_pos, ne_of_gt hn_pos, ne_of_gt hk_pos]
    simpa [hthreshold_inv] using hinv
  have hcoef :
      12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ)) ≤
        12 * Real.sqrt (n : ℝ) :=
    mul_le_mul_of_nonneg_left hexp_le (by norm_num)
  have hmul :
      (12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) *
          ((g : ℝ)⁻¹) ≤
        (12 * Real.sqrt (n : ℝ)) *
          (Real.log (n : ℝ) / (16 * (n : ℝ) * (k : ℝ))) := by
    exact mul_le_mul hcoef hinv_threshold
      (inv_nonneg.mpr hg_pos.le)
      (mul_nonneg (by norm_num) (Real.sqrt_nonneg _))
  calc
    12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ)) / (g : ℝ) =
        (12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) *
          ((g : ℝ)⁻¹) := by
          ring
    _ ≤ (12 * Real.sqrt (n : ℝ)) *
          (Real.log (n : ℝ) / (16 * (n : ℝ) * (k : ℝ))) := hmul
    _ = 3 * Real.log (n : ℝ) * Real.sqrt (n : ℝ) /
          (4 * (n : ℝ) * (k : ℝ)) := by
          field_simp [ne_of_gt hn_pos, ne_of_gt hk_pos]
          ring

/--
Theorem 3.1 finite tail-sum algebra: if all tail indices are past
`16 n k / log n` and there are at most `n` of them, the sum of the Lemma 4.1
pointwise bounds is at most the paper's `3 sqrt(n) log(n) / (4k)` term.
-/
theorem paper_im05_theorem3_1_tail_sum_bound
    {α : Type*} (tail : Finset α) (rank : α → ℕ)
    (n k : ℕ) (hn : 0 < n) (hk : 0 < k)
    (hlog_pos : 0 < Real.log (n : ℝ))
    (hcard : tail.card ≤ n)
    (hrank_pos : ∀ a ∈ tail, 0 < rank a)
    (hthreshold : ∀ a ∈ tail,
      16 * (n : ℝ) * (k : ℝ) / Real.log (n : ℝ) ≤ (rank a : ℝ)) :
    (∑ a ∈ tail,
      12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (rank a : ℝ)) /
        (rank a : ℝ)) ≤
      (3 * Real.sqrt (n : ℝ) * Real.log (n : ℝ)) / (4 * (k : ℝ)) := by
  have hn_pos : 0 < (n : ℝ) := by exact_mod_cast hn
  have hk_pos : 0 < (k : ℝ) := by exact_mod_cast hk
  let perTerm : ℝ :=
    3 * Real.log (n : ℝ) * Real.sqrt (n : ℝ) /
      (4 * (n : ℝ) * (k : ℝ))
  have hper_nonneg : 0 ≤ perTerm := by
    dsimp [perTerm]
    positivity
  have hsum_le_card :
      (∑ a ∈ tail,
        12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (rank a : ℝ)) /
          (rank a : ℝ)) ≤
        (tail.card : ℝ) * perTerm := by
    calc
      (∑ a ∈ tail,
        12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (rank a : ℝ)) /
          (rank a : ℝ)) ≤ ∑ _a ∈ tail, perTerm := by
          exact Finset.sum_le_sum (by
            intro a ha
            simpa [perTerm] using
              paper_im05_theorem3_1_tail_term_bound
                n k (rank a) hn hk (hrank_pos a ha) hlog_pos
                (hthreshold a ha))
      _ = (tail.card : ℝ) * perTerm := by
          simp [nsmul_eq_mul]
  have hcard_real : (tail.card : ℝ) ≤ (n : ℝ) := by exact_mod_cast hcard
  calc
    (∑ a ∈ tail,
      12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (rank a : ℝ)) /
        (rank a : ℝ)) ≤ (tail.card : ℝ) * perTerm := hsum_le_card
    _ ≤ (n : ℝ) * perTerm :=
        mul_le_mul_of_nonneg_right hcard_real hper_nonneg
    _ = (3 * Real.sqrt (n : ℝ) * Real.log (n : ℝ)) /
          (4 * (k : ℝ)) := by
          dsimp [perTerm]
          field_simp [ne_of_gt hn_pos, ne_of_gt hk_pos]

/--
Theorem 3.1 displayed finite count bound from the paper's pointwise tail
probability bounds.  This packages the linearity/split-sum step, the
`16nk/log n` exceptional prefix, and the exponential tail-sum estimate.
-/
theorem paper_im05_theorem3_1_count_bound_from_tail_probabilities
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype M] [Fintype W] [DecidableEq W]
    (μ : PMF Ω)
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ)
    (rank : W → ℕ) (exceptional : Finset W)
    (n k : ℕ) (hn : 0 < n) (hk : 0 < k)
    (hcardW : Fintype.card W = n)
    (hlog_pos : 0 < Real.log (n : ℝ))
    (hexceptional :
      (exceptional.card : ℝ) ≤
        16 * (n : ℝ) * (k : ℝ) / Real.log (n : ℝ))
    (hrank_pos : ∀ w : W, w ∉ exceptional → 0 < rank w)
    (hthreshold : ∀ w : W, w ∉ exceptional →
      16 * (n : ℝ) * (k : ℝ) / Real.log (n : ℝ) ≤ (rank w : ℝ))
    (hbound : ∀ w : W, w ∉ exceptional →
      @EconCSLib.pmfProb Ω _ _ μ
          (fun ω =>
            im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
          (Classical.decPred _) ≤
        12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (rank w : ℝ)) /
          (rank w : ℝ)) :
    EconCSLib.pmfExp μ
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) ≤
      16 * (n : ℝ) * (k : ℝ) / Real.log (n : ℝ) +
        (3 * Real.sqrt (n : ℝ) * Real.log (n : ℝ)) / (4 * (k : ℝ)) := by
  classical
  let lemmaBound : W → ℝ := fun w =>
    12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (rank w : ℝ)) /
      (rank w : ℝ)
  have hsplit :
      EconCSLib.pmfExp μ
          (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) ≤
        (exceptional.card : ℝ) +
          ∑ w ∈ (Finset.univ : Finset W) \ exceptional, lemmaBound w :=
    paper_im05_expected_multiStableHusbandCount_le_exceptional_add_tail_bounds
      μ val_m val_w exceptional lemmaBound
      (by
        intro w hw
        simpa [lemmaBound] using hbound w hw)
  have htail_card :
      ((Finset.univ : Finset W) \ exceptional).card ≤ n := by
    calc
      ((Finset.univ : Finset W) \ exceptional).card ≤
          (Finset.univ : Finset W).card :=
          Finset.card_le_card (by
            intro w hw
            exact (Finset.mem_sdiff.mp hw).1)
      _ = Fintype.card W := Finset.card_univ
      _ = n := hcardW
  have htail_sum :
      (∑ w ∈ (Finset.univ : Finset W) \ exceptional, lemmaBound w) ≤
        (3 * Real.sqrt (n : ℝ) * Real.log (n : ℝ)) / (4 * (k : ℝ)) := by
    simpa [lemmaBound] using
      paper_im05_theorem3_1_tail_sum_bound
        ((Finset.univ : Finset W) \ exceptional) rank n k hn hk hlog_pos
        htail_card
        (by
          intro w hw
          exact hrank_pos w (Finset.mem_sdiff.mp hw).2)
        (by
          intro w hw
          exact hthreshold w (Finset.mem_sdiff.mp hw).2)
  calc
    EconCSLib.pmfExp μ
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) ≤
        (exceptional.card : ℝ) +
          ∑ w ∈ (Finset.univ : Finset W) \ exceptional, lemmaBound w := hsplit
    _ ≤ 16 * (n : ℝ) * (k : ℝ) / Real.log (n : ℝ) +
          ∑ w ∈ (Finset.univ : Finset W) \ exceptional, lemmaBound w :=
        by
          simpa [add_comm, add_left_comm, add_assoc] using
            add_le_add_right hexceptional
              (∑ w ∈ (Finset.univ : Finset W) \ exceptional, lemmaBound w)
    _ ≤ 16 * (n : ℝ) * (k : ℝ) / Real.log (n : ℝ) +
        (3 * Real.sqrt (n : ℝ) * Real.log (n : ℝ)) / (4 * (k : ℝ)) :=
        by
          simpa [add_comm, add_left_comm, add_assoc] using
            add_le_add_left htail_sum
              (16 * (n : ℝ) * (k : ℝ) / Real.log (n : ℝ))

/--
Immorlica-Mahdian popularity order: `w` is at least as popular as `g` when its
draw probability is at least `g`'s draw probability.
-/
def im05_morePopular {W : Type*} (popularity : W → ℝ) (w g : W) : Prop :=
  popularity g ≤ popularity w

/--
Equation (4.1) weighted-race core: if every element of `S` is at least as
popular as `g`, then `g`'s weight share inside `{g} ∪ S` is at most
`1 / (|S| + 1)`. This is the finite inequality behind the paper's first-hit
probability bound.
-/
theorem paper_im05_equation4_1_weighted_first_hit_bound
    {W : Type*} (S : Finset W) (g : W) (popularity : W → ℝ)
    (hg_nonneg : 0 ≤ popularity g)
    (hden_pos : 0 < popularity g + ∑ w ∈ S, popularity w)
    (hpopular : ∀ w ∈ S, popularity g ≤ popularity w) :
    popularity g / (popularity g + ∑ w ∈ S, popularity w) ≤
      1 / ((S.card : ℝ) + 1) :=
  EconCSLib.FiniteSum.weight_share_le_inv_card_add_one_of_forall_le
    S popularity g hg_nonneg hden_pos hpopular

/--
Equation (4.1) pointwise reciprocal form: if the conditional chance of another
proposal to `g` is bounded by `g`'s first-hit weight share among `{g} ∪ S`,
then it is bounded by `1/(|S|+1)`.
-/
theorem paper_im05_equation4_1_conditional_probability_le_reciprocal
    {W : Type*} (S : Finset W) (g : W) (popularity : W → ℝ)
    (conditionalProb : ℝ)
    (hg_nonneg : 0 ≤ popularity g)
    (hden_pos : 0 < popularity g + ∑ w ∈ S, popularity w)
    (hpopular : ∀ w ∈ S, popularity g ≤ popularity w)
    (hfirstHit :
      conditionalProb ≤
        popularity g / (popularity g + ∑ w ∈ S, popularity w)) :
    conditionalProb ≤ (((S.card + 1 : ℕ) : ℝ)⁻¹) := by
  have hshare :=
    paper_im05_equation4_1_weighted_first_hit_bound
      S g popularity hg_nonneg hden_pos hpopular
  have hcast :
      (1 / ((S.card : ℝ) + 1) : ℝ) =
        (((S.card + 1 : ℕ) : ℝ)⁻¹) := by
    norm_num
  exact le_trans hfirstHit (by simpa [hcast] using hshare)

/--
Lean encoding of "woman `w` does not appear on any man's preference list":
every man strictly prefers remaining unmatched, whose value is `0`, to `w`.
-/
def im05_absentFromAllMen {M W : Type*}
    (val_m : M → W → ℝ) (w : W) : Prop :=
  ∀ m, val_m m w < 0

/-- Woman `w` is single in matching `mu`. -/
def im05_singleWoman {M W : Type*} (mu : Assignment M W) (w : W) : Prop :=
  mu.w_match w = none

/-- Paper's `S_mu(g)`: women at least as popular as `g` who are single in `mu`. -/
noncomputable def im05_singlePopularWomen {M W : Type*}
    [Fintype W]
    (popularity : W → ℝ) (mu : Assignment M W) (g : W) : Finset W := by
  classical
  exact (Finset.univ : Finset W).filter fun w =>
    im05_morePopular popularity w g ∧ im05_singleWoman mu w

/-- All women single in `mu`. -/
noncomputable def im05_singleWomen {M W : Type*}
    [Fintype W] (mu : Assignment M W) : Finset W := by
  classical
  exact (Finset.univ : Finset W).filter fun w => im05_singleWoman mu w

/-- Man `m` is single in matching `mu`. -/
def im05_singleMan {M W : Type*} (mu : Assignment M W) (m : M) : Prop :=
  mu.m_match m = none

/-- All men single in `mu`. -/
noncomputable def im05_singleMen {M W : Type*}
    [Fintype M] (mu : Assignment M W) : Finset M := by
  classical
  exact (Finset.univ : Finset M).filter fun m => im05_singleMan mu m

/-- Women named by no man, encoded as unacceptable to every man. -/
noncomputable def im05_absentWomen {M W : Type*}
    [Fintype W] (val_m : M → W → ℝ) : Finset W := by
  classical
  exact (Finset.univ : Finset W).filter fun w => im05_absentFromAllMen val_m w

/-- Paper's `Y_g` set: women at least as popular as `g` named by no man. -/
noncomputable def im05_absentPopularWomen {M W : Type*}
    [Fintype W]
    (popularity : W → ℝ) (val_m : M → W → ℝ) (g : W) : Finset W := by
  classical
  exact (Finset.univ : Finset W).filter fun w =>
    im05_morePopular popularity w g ∧ im05_absentFromAllMen val_m w

/-- Paper conclusion shape `c_k(n) / n -> 0`. -/
def im05_fraction_vanishes (ck : ℕ → ℝ) : Prop :=
  EconCSLib.Math.TendsToZero fun n => ck n / (n : ℝ)

/-- The uniform-distribution constant from Theorem 3.2, `e^(k+1) + k^2`. -/
noncomputable def im05_uniformTheorem32Bound (k : ℕ) : ℝ :=
  Real.exp ((k : ℝ) + 1) + (k : ℝ) ^ 2

/--
IM05's complete strict marriage domain: strict preferences on both sides and
every potential pair acceptable relative to the outside option.
-/
def im05_strict_marriage_domain {M W : Type*}
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) : Prop :=
  MenStrictPreferenceProfile val_m ∧
    WomenStrictPreferenceProfile val_w ∧
    AllPairsAcceptable val_m val_w

/--
Women-proposing deferred acceptance, represented on the original `(M, W)` sides
by role reversal.
-/
noncomputable def im05_women_deferredAcceptance
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) : Assignment M W :=
  womenDeferredAcceptance val_m val_w

/-- Paper-facing expectation `E[1/(Y_{m,n}+1)]` for the uniform occupancy model. -/
noncomputable def im05_occupancyReciprocalExpectation
    (m n : ℕ) [NeZero n] : ℝ :=
  EconCSLib.occupancyReciprocalExpectation (Fin m) (Fin n)

/-- Paper-facing expectation `E[1/(X+1)]` for a natural-valued experiment count. -/
noncomputable def im05_reciprocalCountExpectation
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (X : Ω → ℕ) : ℝ :=
  EconCSLib.pmfExpReciprocalSucc μ X

/--
Equation (4.2) expectation lift: a pointwise conditional-probability bound by
`1/(X_mu(g)+1)` integrates to the reciprocal-count expectation.
-/
theorem paper_im05_equation4_2_expectation_le_reciprocal
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (conditionalProb : Ω → ℝ) (X : Ω → ℕ)
    (hbound : ∀ ω,
      conditionalProb ω ≤ (((X ω + 1 : ℕ) : ℝ)⁻¹)) :
    EconCSLib.pmfExp μ conditionalProb ≤
      im05_reciprocalCountExpectation μ X := by
  unfold im05_reciprocalCountExpectation EconCSLib.pmfExpReciprocalSucc
  exact EconCSLib.pmfExp_le_pmfExp_of_forall_le μ _ _ hbound

/--
Experiment 2 count: each man names `k` women. This generic empty-count
statistic is the occupancy count for a supplied assignment of `k` named slots
per man; the paper's without-replacement construction is a separate obligation.
-/
noncomputable def im05_experiment2EmptyCount {M W : Type*}
    [Fintype M] [Fintype W] [DecidableEq W]
    (k : ℕ) (names : M × Fin k → W) : ℕ :=
  (EconCSLib.occupancyEmptyBins names).card

/-- Ordered list of `k` distinct women, used for Experiment 2's
without-replacement random lists. -/
abbrev im05_distinctWomanList (W : Type*) (k : ℕ) :=
  {list : Fin k → W // Function.Injective list}

/--
Algorithm 4.2 one-man sample space for the concrete deferred-decision sampler:
a length-`k` fresh list with no initial forbidden women.
-/
abbrev im05_algorithm42FreshListSample (W : Type*) (k : ℕ) :=
  EconCSLib.finiteFreshList W k (∅ : Finset W)

/-- The concrete list drawn by an Algorithm 4.2 fresh-list sample. -/
def im05_algorithm42FreshListDraw {W : Type*} {k : ℕ}
    (sample : im05_algorithm42FreshListSample W k) : Fin k → W :=
  sample.1

/--
Algorithm 4.2 weighted without-replacement PMF over fresh lists.  The
availability hypothesis is intentionally reusable: full support of the base
weights is one sufficient way to provide it.
-/
noncomputable def im05_algorithm42FreshListPMF
    {W : Type*} [Fintype W] [DecidableEq W]
    (prob : W → ℝ)
    (hprob_nonneg : ∀ w, 0 ≤ prob w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    (k : ℕ) (hk_le_card : k ≤ Fintype.card W) :
    PMF (im05_algorithm42FreshListSample W k) :=
  EconCSLib.finiteWithoutReplacementPMF
    prob hprob_nonneg havailable k (∅ : Finset W) (by simpa using hk_le_card)

theorem im05_algorithm42FreshListDraw_injective
    {W : Type*} {k : ℕ}
    (sample : im05_algorithm42FreshListSample W k) :
    Function.Injective (im05_algorithm42FreshListDraw sample) :=
  sample.2.1

theorem im05_algorithm42FreshListDraw_mem_of_forall
    {W : Type*} {k : ℕ} (all : Finset W)
    (hmem : ∀ w : W, w ∈ all)
    (sample : im05_algorithm42FreshListSample W k) (slot : Fin k) :
    im05_algorithm42FreshListDraw sample slot ∈ all :=
  hmem _

/--
The first `r` positions of a length-`k` list omit woman `w`.  The definition
is meaningful for all natural `r`; when `r > k` it simply quantifies over all
available slots.
-/
def im05_listPrefixOmits {W : Type*} {k : ℕ}
    (w : W) (r : ℕ) (list : Fin k → W) : Prop :=
  ∀ slot : Fin k, slot.val < r → list slot ≠ w

instance im05_listPrefixOmits_decidablePred
    {W : Type*} [DecidableEq W] {k : ℕ} (w : W) (r : ℕ) :
    DecidablePred fun list : Fin k → W => im05_listPrefixOmits w r list := by
  classical
  intro list
  unfold im05_listPrefixOmits
  infer_instance

/-- The set of women appearing in the first `r` positions of a length-`k` list. -/
noncomputable def im05_listPrefixSet
    {W : Type*} [DecidableEq W] {k : ℕ}
    (r : ℕ) (list : Fin k → W) : Finset W :=
  ((Finset.univ : Finset (Fin k)).filter fun slot => slot.val < r).image list

theorem im05_mem_listPrefixSet_iff
    {W : Type*} [DecidableEq W] {k r : ℕ}
    (list : Fin k → W) (u : W) :
    u ∈ im05_listPrefixSet r list ↔
      ∃ slot : Fin k, slot.val < r ∧ list slot = u := by
  classical
  constructor
  · intro hu
    rcases Finset.mem_image.mp hu with ⟨slot, hslot, rfl⟩
    exact ⟨slot, (Finset.mem_filter.mp hslot).2, rfl⟩
  · rintro ⟨slot, hslot_lt, rfl⟩
    exact Finset.mem_image.mpr
      ⟨slot, Finset.mem_filter.mpr ⟨Finset.mem_univ slot, hslot_lt⟩, rfl⟩

/-- The one-slot prefix set is the singleton containing the first slot. -/
theorem im05_listPrefixSet_one_eq_singleton
    {W : Type*} [DecidableEq W] {k : ℕ}
    (list : Fin k → W) (hk : 0 < k) :
    im05_listPrefixSet 1 list = {list ⟨0, hk⟩} := by
  classical
  ext u
  rw [im05_mem_listPrefixSet_iff]
  constructor
  · rintro ⟨slot, hslot_lt, hslot_eq⟩
    have hslot_zero : slot = ⟨0, hk⟩ := by
      apply Fin.ext
      exact Nat.lt_one_iff.mp hslot_lt
    subst slot
    simpa using hslot_eq.symm
  · intro hu
    rw [Finset.mem_singleton] at hu
    refine ⟨⟨0, hk⟩, by simp, ?_⟩
    simpa [hu]

theorem im05_listPrefixSet_subset_of_forall_mem
    {W : Type*} [DecidableEq W] {k r : ℕ}
    (all : Finset W) (list : Fin k → W)
    (hmem : ∀ slot : Fin k, list slot ∈ all) :
    im05_listPrefixSet r list ⊆ all := by
  intro u hu
  rcases (im05_mem_listPrefixSet_iff list u).1 hu with
    ⟨slot, _hslot_lt, rfl⟩
  exact hmem slot

theorem im05_algorithm42FreshListPrefixSet_eq
    {W : Type*} [DecidableEq W] {k r : ℕ}
    (sample : im05_algorithm42FreshListSample W k) :
    im05_listPrefixSet r (im05_algorithm42FreshListDraw sample) =
      EconCSLib.finiteFreshListPrefixSet r sample := by
  rfl

theorem im05_listPrefixOmits_iff_not_mem_prefixSet
    {W : Type*} [DecidableEq W] {k r : ℕ}
    (w : W) (list : Fin k → W) :
    im05_listPrefixOmits w r list ↔
      w ∉ im05_listPrefixSet r list := by
  classical
  constructor
  · intro homit hwmem
    rcases (im05_mem_listPrefixSet_iff list w).1 hwmem with
      ⟨slot, hslot_lt, hslot_eq⟩
    exact (homit slot hslot_lt) hslot_eq
  · intro hnotmem slot hslot_lt hslot_eq
    exact hnotmem ((im05_mem_listPrefixSet_iff list w).2
      ⟨slot, hslot_lt, hslot_eq⟩)

theorem im05_listPrefixSet_card_of_injective
    {W : Type*} [DecidableEq W] {k r : ℕ}
    (list : Fin k → W) (hinj : Function.Injective list) :
    (im05_listPrefixSet r list).card = min k r := by
  classical
  unfold im05_listPrefixSet
  rw [Finset.card_image_of_injective _ hinj]
  exact Fin.card_filter_val_lt (n := k) (m := r)

@[simp]
theorem im05_listPrefixSet_zero
    {W : Type*} [DecidableEq W] {k : ℕ}
    (list : Fin k → W) :
    im05_listPrefixSet 0 list = ∅ := by
  classical
  ext u
  simp [im05_mem_listPrefixSet_iff]

theorem im05_next_slot_not_mem_prefixSet_of_injective
    {W : Type*} [DecidableEq W] {k r : ℕ}
    (list : Fin k → W) (hinj : Function.Injective list) (hr : r < k) :
    list ⟨r, hr⟩ ∉ im05_listPrefixSet r list := by
  classical
  intro hmem
  rcases (im05_mem_listPrefixSet_iff list (list ⟨r, hr⟩)).1 hmem with
    ⟨slot, hslot_lt, hslot_eq⟩
  have hslot : slot = ⟨r, hr⟩ := hinj hslot_eq
  have hval : slot.val = r := by
    exact congrArg Fin.val hslot
  omega

@[simp] theorem im05_listPrefixOmits_zero
    {W : Type*} {k : ℕ} (w : W) (list : Fin k → W) :
    im05_listPrefixOmits w 0 list := by
  intro slot hslot
  omega

/-- Prefix omission is nested as the prefix length grows. -/
theorem im05_listPrefixOmits_nested
    {W : Type*} {k r : ℕ} (w : W) (list : Fin k → W) :
    im05_listPrefixOmits w (r + 1) list →
      im05_listPrefixOmits w r list := by
  intro h slot hslot
  exact h slot (Nat.lt_trans hslot (Nat.lt_succ_self r))

/--
For an in-range next slot, omitting `w` through position `r + 1` is equivalent
to omitting `w` through position `r` and not hitting `w` in slot `r`.
-/
theorem im05_listPrefixOmits_succ_iff
    {W : Type*} {k r : ℕ} (w : W) (list : Fin k → W)
    (hr : r < k) :
    im05_listPrefixOmits w (r + 1) list ↔
      im05_listPrefixOmits w r list ∧ list ⟨r, hr⟩ ≠ w := by
  constructor
  · intro h
    exact ⟨im05_listPrefixOmits_nested w list h,
      h ⟨r, hr⟩ (Nat.lt_succ_self r)⟩
  · rintro ⟨hprefix, hslot_ne⟩
    intro slot hslot
    have hle : slot.val ≤ r := Nat.lt_succ_iff.mp hslot
    rcases lt_or_eq_of_le hle with hlt | heq
    · exact hprefix slot hlt
    · have hslot_eq : slot = ⟨r, hr⟩ := by
        exact Fin.ext heq
      simpa [hslot_eq] using hslot_ne

/--
Prepending a head to a length-`k` list: omitting `w` from all `k + 1` slots is
equivalent to the head avoiding `w` and the tail omitting `w` from its `k`
slots.
-/
theorem im05_listPrefixOmits_finCons_succ_iff
    {W : Type*} {k : ℕ} (w head : W) (tail : Fin k → W) :
    im05_listPrefixOmits w (k + 1) (EconCSLib.finCons head tail) ↔
      head ≠ w ∧ im05_listPrefixOmits w k tail := by
  constructor
  · intro homit
    constructor
    · exact homit ⟨0, Nat.succ_pos k⟩ (Nat.succ_pos k)
    · intro slot hslot
      exact homit slot.succ (Nat.succ_lt_succ hslot)
  · rintro ⟨hhead, htail⟩ slot hslot
    cases slot using Fin.cases with
    | zero =>
        simpa using hhead
    | succ slot =>
        exact htail slot (Nat.succ_lt_succ_iff.mp hslot)

/--
First-step recurrence for a full-prefix omission event under the reusable
without-replacement sampler, stated in the IM05 prefix-omission notation.
-/
theorem im05_finiteWithoutReplacementPMF_listPrefixOmits_succ_prob_eq_sum_head
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (target : W) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          (k + 1) forbidden hbudget)
        (fun sample => im05_listPrefixOmits target (k + 1) sample.1) =
      ∑ head : {w // w ∉ forbidden},
        if head.1 = target then 0 else
          (EconCSLib.finiteWeightedPMFAvailable
            weight forbidden hweight_nonneg
            (havailable forbidden (by omega)) head).toReal *
            EconCSLib.pmfProb
              (EconCSLib.finiteWithoutReplacementPMF
                weight hweight_nonneg havailable
                k (insert head.1 forbidden)
                (by
                  rw [Finset.card_insert_of_notMem head.2]
                  omega))
              (fun tail => im05_listPrefixOmits target k tail.1) := by
  classical
  rw [EconCSLib.finiteWithoutReplacementPMF_event_prob_succ_eq_sum_head
    weight hweight_nonneg havailable forbidden hbudget
    (fun sample : EconCSLib.finiteFreshList W (k + 1) forbidden =>
      im05_listPrefixOmits target (k + 1) sample.1)]
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  by_cases hhead_target : head.1 = target
  · have hzero :
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail =>
            im05_listPrefixOmits target (k + 1)
              (EconCSLib.finiteFreshListCons head tail).1) = 0 := by
      refine EconCSLib.pmfProb_eq_zero_of_no_mass _ _ ?_
      intro tail htail
      have hhead_ne :
          head.1 ≠ target :=
        (im05_listPrefixOmits_finCons_succ_iff
          target head.1 tail.1).1 (by simpa using htail) |>.1
      exact False.elim (hhead_ne hhead_target)
    simp [hhead_target, hzero]
  · have htail_congr :
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail =>
            im05_listPrefixOmits target (k + 1)
              (EconCSLib.finiteFreshListCons head tail).1) =
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail => im05_listPrefixOmits target k tail.1) := by
      refine EconCSLib.pmfProb_congr _ ?_
      intro tail
      have hiff :=
        im05_listPrefixOmits_finCons_succ_iff target head.1 tail.1
      simpa [EconCSLib.finiteFreshListCons, hhead_target] using hiff
    simp [hhead_target, htail_congr]

/--
First-step recurrence for the joint full-prefix omission event under the
reusable without-replacement sampler, stated in IM05 notation.
-/
theorem im05_finiteWithoutReplacementPMF_listPrefixOmits_pair_succ_prob_eq_sum_head
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          (k + 1) forbidden hbudget)
        (fun sample =>
          im05_listPrefixOmits i (k + 1) sample.1 ∧
            im05_listPrefixOmits j (k + 1) sample.1) =
      ∑ head : {w // w ∉ forbidden},
        if head.1 = i ∨ head.1 = j then 0 else
          (EconCSLib.finiteWeightedPMFAvailable
            weight forbidden hweight_nonneg
            (havailable forbidden (by omega)) head).toReal *
            EconCSLib.pmfProb
              (EconCSLib.finiteWithoutReplacementPMF
                weight hweight_nonneg havailable
                k (insert head.1 forbidden)
                (by
                  rw [Finset.card_insert_of_notMem head.2]
                  omega))
              (fun tail =>
                im05_listPrefixOmits i k tail.1 ∧
                  im05_listPrefixOmits j k tail.1) := by
  classical
  rw [EconCSLib.finiteWithoutReplacementPMF_event_prob_succ_eq_sum_head
    weight hweight_nonneg havailable forbidden hbudget
    (fun sample : EconCSLib.finiteFreshList W (k + 1) forbidden =>
      im05_listPrefixOmits i (k + 1) sample.1 ∧
        im05_listPrefixOmits j (k + 1) sample.1)]
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  by_cases hbad : head.1 = i ∨ head.1 = j
  · have hzero :
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail =>
            im05_listPrefixOmits i (k + 1)
                (EconCSLib.finiteFreshListCons head tail).1 ∧
              im05_listPrefixOmits j (k + 1)
                (EconCSLib.finiteFreshListCons head tail).1) = 0 := by
      refine EconCSLib.pmfProb_eq_zero_of_no_mass _ _ ?_
      intro tail htail
      rcases hbad with hi | hj
      · have hhead_ne :
            head.1 ≠ i :=
          (im05_listPrefixOmits_finCons_succ_iff
            i head.1 tail.1).1 (by simpa using htail.1) |>.1
        exact False.elim (hhead_ne hi)
      · have hhead_ne :
            head.1 ≠ j :=
          (im05_listPrefixOmits_finCons_succ_iff
            j head.1 tail.1).1 (by simpa using htail.2) |>.1
        exact False.elim (hhead_ne hj)
    simp [hbad, hzero]
  · have hhead_i : head.1 ≠ i := by
      intro hi
      exact hbad (Or.inl hi)
    have hhead_j : head.1 ≠ j := by
      intro hj
      exact hbad (Or.inr hj)
    have htail_congr :
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail =>
            im05_listPrefixOmits i (k + 1)
                (EconCSLib.finiteFreshListCons head tail).1 ∧
              im05_listPrefixOmits j (k + 1)
                (EconCSLib.finiteFreshListCons head tail).1) =
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail =>
            im05_listPrefixOmits i k tail.1 ∧
              im05_listPrefixOmits j k tail.1) := by
      refine EconCSLib.pmfProb_congr _ ?_
      intro tail
      have hi_iff :
          im05_listPrefixOmits i (k + 1)
              (EconCSLib.finiteFreshListCons head tail).1 ↔
            im05_listPrefixOmits i k tail.1 := by
        simpa [EconCSLib.finiteFreshListCons, hhead_i] using
          (im05_listPrefixOmits_finCons_succ_iff i head.1 tail.1)
      have hj_iff :
          im05_listPrefixOmits j (k + 1)
              (EconCSLib.finiteFreshListCons head tail).1 ↔
            im05_listPrefixOmits j k tail.1 := by
        simpa [EconCSLib.finiteFreshListCons, hhead_j] using
          (im05_listPrefixOmits_finCons_succ_iff j head.1 tail.1)
      exact and_congr hi_iff hj_iff
    simp [hbad, htail_congr]

/--
The first-step marginal omission sum obtained by conditioning on the first
head of a recursive without-replacement draw.
-/
noncomputable def im05_firstStepOmitMarginalSum
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (target : W) : ℝ :=
  ∑ head : {w // w ∉ forbidden},
    if head.1 = target then 0 else
      (EconCSLib.finiteWeightedPMFAvailable
        weight forbidden hweight_nonneg
        (havailable forbidden (by omega)) head).toReal *
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail => im05_listPrefixOmits target k tail.1)

/--
The first-step joint upper-bound sum after applying residual pairwise negative
correlation at every first head.
-/
noncomputable def im05_firstStepOmitPairProductSum
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) : ℝ :=
  ∑ head : {w // w ∉ forbidden},
    if head.1 = i ∨ head.1 = j then 0 else
      (EconCSLib.finiteWeightedPMFAvailable
        weight forbidden hweight_nonneg
        (havailable forbidden (by omega)) head).toReal *
        (EconCSLib.pmfProb
            (EconCSLib.finiteWithoutReplacementPMF
              weight hweight_nonneg havailable
              k (insert head.1 forbidden)
              (by
                rw [Finset.card_insert_of_notMem head.2]
                omega))
            (fun tail => im05_listPrefixOmits i k tail.1) *
          EconCSLib.pmfProb
            (EconCSLib.finiteWithoutReplacementPMF
              weight hweight_nonneg havailable
              k (insert head.1 forbidden)
              (by
                rw [Finset.card_insert_of_notMem head.2]
                omega))
            (fun tail => im05_listPrefixOmits j k tail.1))

/-- First-head probability mass in the compact first-step decomposition. -/
noncomputable def im05_firstStepHeadWeight
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (head : {w // w ∉ forbidden}) : ℝ :=
  (EconCSLib.finiteWeightedPMFAvailable
    weight forbidden hweight_nonneg
    (havailable forbidden (by omega)) head).toReal

/--
Residual omission probability after the first head, zero-extended at the
target head so marginal and pair-product sums can be written uniformly.
-/
noncomputable def im05_firstStepResidualOmitProb
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (target : W) (head : {w // w ∉ forbidden}) : ℝ :=
  if head.1 = target then 0 else
    EconCSLib.pmfProb
      (EconCSLib.finiteWithoutReplacementPMF
        weight hweight_nonneg havailable
        k (insert head.1 forbidden)
        (by
          rw [Finset.card_insert_of_notMem head.2]
          omega))
      (fun tail => im05_listPrefixOmits target k tail.1)

/-- First-head masses sum to one. -/
theorem im05_firstStepHeadWeight_sum_eq_one
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W) :
    (∑ head : {w // w ∉ forbidden},
      im05_firstStepHeadWeight
        weight hweight_nonneg havailable forbidden hbudget head) = 1 := by
  classical
  unfold im05_firstStepHeadWeight
  exact EconCSLib.pmfToRealSum _

/-- First-head masses are nonnegative. -/
theorem im05_firstStepHeadWeight_nonneg
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (head : {w // w ∉ forbidden}) :
    0 ≤ im05_firstStepHeadWeight
      weight hweight_nonneg havailable forbidden hbudget head := by
  unfold im05_firstStepHeadWeight
  exact ENNReal.toReal_nonneg

/-- First-head masses are at most one. -/
theorem im05_firstStepHeadWeight_le_one
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (head : {w // w ∉ forbidden}) :
    im05_firstStepHeadWeight
      weight hweight_nonneg havailable forbidden hbudget head ≤ 1 := by
  unfold im05_firstStepHeadWeight
  exact EconCSLib.pmf_apply_toReal_le_one _ _

/-- Zero-extension at the target head. -/
@[simp]
theorem im05_firstStepResidualOmitProb_eq_zero_of_head_eq
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    {target : W} {head : {w // w ∉ forbidden}}
    (hhead : head.1 = target) :
    im05_firstStepResidualOmitProb
      weight hweight_nonneg havailable forbidden hbudget target head = 0 := by
  simp [im05_firstStepResidualOmitProb, hhead]

/-- Residual omission probability formula away from the target head. -/
theorem im05_firstStepResidualOmitProb_eq_prob_of_head_ne
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    {target : W} {head : {w // w ∉ forbidden}}
    (hhead : head.1 ≠ target) :
    im05_firstStepResidualOmitProb
      weight hweight_nonneg havailable forbidden hbudget target head =
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          k (insert head.1 forbidden)
          (by
            rw [Finset.card_insert_of_notMem head.2]
            omega))
        (fun tail => im05_listPrefixOmits target k tail.1) := by
  simp [im05_firstStepResidualOmitProb, hhead]

/-- Residual omission probabilities are nonnegative. -/
theorem im05_firstStepResidualOmitProb_nonneg
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (target : W) (head : {w // w ∉ forbidden}) :
    0 ≤ im05_firstStepResidualOmitProb
      weight hweight_nonneg havailable forbidden hbudget target head := by
  unfold im05_firstStepResidualOmitProb
  by_cases hhead : head.1 = target
  · simp [hhead]
  · simp [hhead, EconCSLib.pmfProb_nonneg]

/-- Residual omission probabilities are at most one. -/
theorem im05_firstStepResidualOmitProb_le_one
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (target : W) (head : {w // w ∉ forbidden}) :
    im05_firstStepResidualOmitProb
      weight hweight_nonneg havailable forbidden hbudget target head ≤ 1 := by
  unfold im05_firstStepResidualOmitProb
  by_cases hhead : head.1 = target
  · simp [hhead]
  · simp [hhead, EconCSLib.pmfProb_le_one]

/-- Named-function form of the compact first-step marginal sum. -/
theorem im05_firstStepOmitMarginalSum_eq_headWeight_residual
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (target : W) :
    im05_firstStepOmitMarginalSum
        weight hweight_nonneg havailable forbidden hbudget target =
      ∑ head : {w // w ∉ forbidden},
        im05_firstStepHeadWeight
            weight hweight_nonneg havailable forbidden hbudget head *
          im05_firstStepResidualOmitProb
            weight hweight_nonneg havailable forbidden hbudget target head := by
  classical
  unfold im05_firstStepOmitMarginalSum im05_firstStepHeadWeight
    im05_firstStepResidualOmitProb
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  by_cases htarget : head.1 = target
  · simp [htarget]
  · simp [htarget]

/-- Named-function form of the compact first-step pair-product sum. -/
theorem im05_firstStepOmitPairProductSum_eq_headWeight_residual_product
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j =
      ∑ head : {w // w ∉ forbidden},
        im05_firstStepHeadWeight
            weight hweight_nonneg havailable forbidden hbudget head *
          (im05_firstStepResidualOmitProb
              weight hweight_nonneg havailable forbidden hbudget i head *
            im05_firstStepResidualOmitProb
              weight hweight_nonneg havailable forbidden hbudget j head) := by
  classical
  unfold im05_firstStepOmitPairProductSum im05_firstStepHeadWeight
    im05_firstStepResidualOmitProb
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  by_cases hi : head.1 = i
  · simp [hi]
  · by_cases hj : head.1 = j
    · simp [hj]
    · simp [hi, hj]

/--
The named double opposite-spread sum for zero-extended residual omission
probabilities after the first head.
-/
noncomputable def im05_firstStepResidualSpreadSum
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) : ℝ :=
  ∑ head : {w // w ∉ forbidden},
    ∑ tail : {w // w ∉ forbidden},
      im05_firstStepHeadWeight
          weight hweight_nonneg havailable forbidden hbudget head *
        im05_firstStepHeadWeight
          weight hweight_nonneg havailable forbidden hbudget tail *
        ((im05_firstStepResidualOmitProb
            weight hweight_nonneg havailable forbidden hbudget i head -
          im05_firstStepResidualOmitProb
            weight hweight_nonneg havailable forbidden hbudget i tail) *
          (im05_firstStepResidualOmitProb
              weight hweight_nonneg havailable forbidden hbudget j tail -
            im05_firstStepResidualOmitProb
              weight hweight_nonneg havailable forbidden hbudget j head))

/-- The named residual-spread sum is symmetric in the two targets. -/
theorem im05_firstStepResidualSpreadSum_comm
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) :
    im05_firstStepResidualSpreadSum
        weight hweight_nonneg havailable forbidden hbudget i j =
      im05_firstStepResidualSpreadSum
        weight hweight_nonneg havailable forbidden hbudget j i := by
  classical
  unfold im05_firstStepResidualSpreadSum
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  refine Finset.sum_congr rfl ?_
  intro tail _htail
  ring

/--
Nonnegativity of the named residual-spread sum from pointwise opposite
movement of the residual omission probabilities.
-/
theorem im05_firstStepResidualSpreadSum_nonneg_of_pairwise_opposite
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W)
    (hopposite : ∀ head tail : {w // w ∉ forbidden},
      0 ≤
        ((im05_firstStepResidualOmitProb
            weight hweight_nonneg havailable forbidden hbudget i head -
          im05_firstStepResidualOmitProb
            weight hweight_nonneg havailable forbidden hbudget i tail) *
          (im05_firstStepResidualOmitProb
              weight hweight_nonneg havailable forbidden hbudget j tail -
            im05_firstStepResidualOmitProb
              weight hweight_nonneg havailable forbidden hbudget j head))) :
    0 ≤ im05_firstStepResidualSpreadSum
      weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  unfold im05_firstStepResidualSpreadSum
  refine Finset.sum_nonneg ?_
  intro head _hhead
  refine Finset.sum_nonneg ?_
  intro tail _htail
  exact
    mul_nonneg
      (mul_nonneg
        (im05_firstStepHeadWeight_nonneg
          weight hweight_nonneg havailable forbidden hbudget head)
        (im05_firstStepHeadWeight_nonneg
          weight hweight_nonneg havailable forbidden hbudget tail))
      (hopposite head tail)

/-- The compact first-step marginal sum is the actual successor omission probability. -/
theorem im05_firstStepOmitMarginalSum_eq_prob
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (target : W) :
    im05_firstStepOmitMarginalSum
        weight hweight_nonneg havailable forbidden hbudget target =
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          (k + 1) forbidden hbudget)
        (fun sample => im05_listPrefixOmits target (k + 1) sample.1) := by
  simpa [im05_firstStepOmitMarginalSum] using
    (im05_finiteWithoutReplacementPMF_listPrefixOmits_succ_prob_eq_sum_head
      weight hweight_nonneg havailable forbidden hbudget target).symm

/-- The compact first-step marginal sum is nonnegative. -/
theorem im05_firstStepOmitMarginalSum_nonneg
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (target : W) :
    0 ≤ im05_firstStepOmitMarginalSum
        weight hweight_nonneg havailable forbidden hbudget target := by
  rw [im05_firstStepOmitMarginalSum_eq_prob
    weight hweight_nonneg havailable forbidden hbudget target]
  exact EconCSLib.pmfProb_nonneg _ _

/-- The compact first-step pair-product sum is nonnegative. -/
theorem im05_firstStepOmitPairProductSum_nonneg
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) :
    0 ≤ im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  unfold im05_firstStepOmitPairProductSum
  refine Finset.sum_nonneg ?_
  intro head _hhead
  by_cases hbad : head.1 = i ∨ head.1 = j
  · simp [hbad]
  · simp only [hbad, ↓reduceIte]
    exact mul_nonneg ENNReal.toReal_nonneg
      (mul_nonneg (EconCSLib.pmfProb_nonneg _ _)
        (EconCSLib.pmfProb_nonneg _ _))

/-- The compact first-step pair-product sum is symmetric in its two targets. -/
theorem im05_firstStepOmitPairProductSum_comm
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j =
      im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget j i := by
  classical
  unfold im05_firstStepOmitPairProductSum
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  by_cases hi : head.1 = i
  · simp [hi]
  · by_cases hj : head.1 = j
    · simp [hj]
    · simp [hi, hj, mul_comm]

/--
If the target is already forbidden, the compact first-step marginal omission
sum is one.
-/
theorem im05_firstStepOmitMarginalSum_eq_one_of_mem_forbidden
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    {target : W} (htarget_forbidden : target ∈ forbidden) :
    im05_firstStepOmitMarginalSum
        weight hweight_nonneg havailable forbidden hbudget target = 1 := by
  classical
  rw [im05_firstStepOmitMarginalSum_eq_prob
    weight hweight_nonneg havailable forbidden hbudget target]
  refine EconCSLib.pmfProb_eq_one_of_forall _ _ ?_
  intro sample slot _hslot hsample
  exact sample.2.2 slot (by simpa [hsample] using htarget_forbidden)

/--
If the left target is already forbidden, the compact first-step pair-product
sum collapses to the right marginal sum.
-/
theorem im05_firstStepOmitPairProductSum_eq_marginal_of_left_mem_forbidden
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    {i j : W} (hi_forbidden : i ∈ forbidden) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j =
      im05_firstStepOmitMarginalSum
        weight hweight_nonneg havailable forbidden hbudget j := by
  classical
  unfold im05_firstStepOmitPairProductSum im05_firstStepOmitMarginalSum
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  have hhead_i : head.1 ≠ i := by
    intro h
    exact head.2 (by simpa [h] using hi_forbidden)
  by_cases hhead_j : head.1 = j
  · simp [hhead_j]
  · have homit_i :
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail => im05_listPrefixOmits i k tail.1) = 1 := by
      refine EconCSLib.pmfProb_eq_one_of_forall _ _ ?_
      intro tail slot _hslot hsample
      exact tail.2.2 slot (by
        simp [hsample, hi_forbidden])
    simp [hhead_i, hhead_j, homit_i]

/--
If the right target is already forbidden, the compact first-step pair-product
sum collapses to the left marginal sum.
-/
theorem im05_firstStepOmitPairProductSum_eq_marginal_of_right_mem_forbidden
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    {i j : W} (hj_forbidden : j ∈ forbidden) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j =
      im05_firstStepOmitMarginalSum
        weight hweight_nonneg havailable forbidden hbudget i := by
  rw [im05_firstStepOmitPairProductSum_comm
    weight hweight_nonneg havailable forbidden hbudget i j]
  exact
    im05_firstStepOmitPairProductSum_eq_marginal_of_left_mem_forbidden
      weight hweight_nonneg havailable forbidden hbudget hj_forbidden

/--
Promote a compact first-step inequality proved for available targets to the
all-state form by closing already-forbidden target cases internally.
-/
theorem im05_firstStepOmitPairProductSum_le_mul_of_available_firstStep
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W)
    (hstep_available :
      i ∉ forbidden → j ∉ forbidden →
        im05_firstStepOmitPairProductSum
            weight hweight_nonneg havailable forbidden hbudget i j ≤
          im05_firstStepOmitMarginalSum
              weight hweight_nonneg havailable forbidden hbudget i *
            im05_firstStepOmitMarginalSum
              weight hweight_nonneg havailable forbidden hbudget j) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j ≤
      im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget i *
        im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget j := by
  classical
  by_cases hi_forbidden : i ∈ forbidden
  · rw [im05_firstStepOmitPairProductSum_eq_marginal_of_left_mem_forbidden
      weight hweight_nonneg havailable forbidden hbudget hi_forbidden]
    rw [im05_firstStepOmitMarginalSum_eq_one_of_mem_forbidden
      weight hweight_nonneg havailable forbidden hbudget hi_forbidden]
    simp
  · by_cases hj_forbidden : j ∈ forbidden
    · rw [im05_firstStepOmitPairProductSum_eq_marginal_of_right_mem_forbidden
        weight hweight_nonneg havailable forbidden hbudget hj_forbidden]
      rw [im05_firstStepOmitMarginalSum_eq_one_of_mem_forbidden
        weight hweight_nonneg havailable forbidden hbudget hj_forbidden]
      simp
    · exact hstep_available hi_forbidden hj_forbidden

/-- The compact first-step marginal omission sum is at most one. -/
theorem im05_firstStepOmitMarginalSum_le_one
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (target : W) :
    im05_firstStepOmitMarginalSum
        weight hweight_nonneg havailable forbidden hbudget target ≤ 1 := by
  rw [im05_firstStepOmitMarginalSum_eq_prob
    weight hweight_nonneg havailable forbidden hbudget target]
  exact EconCSLib.pmfProb_le_one _ _

/-- The compact first-step pair-product sum is bounded by the left marginal. -/
theorem im05_firstStepOmitPairProductSum_le_marginal_left
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j ≤
      im05_firstStepOmitMarginalSum
        weight hweight_nonneg havailable forbidden hbudget i := by
  classical
  unfold im05_firstStepOmitPairProductSum im05_firstStepOmitMarginalSum
  refine Finset.sum_le_sum ?_
  intro head _hhead
  by_cases hi : head.1 = i
  · simp [hi]
  · by_cases hj : head.1 = j
    · have hright_nonneg :
          0 ≤
            (EconCSLib.finiteWeightedPMFAvailable
              weight forbidden hweight_nonneg
              (havailable forbidden (by omega)) head).toReal *
              EconCSLib.pmfProb
                (EconCSLib.finiteWithoutReplacementPMF
                  weight hweight_nonneg havailable
                  k (insert head.1 forbidden)
                  (by
                    rw [Finset.card_insert_of_notMem head.2]
                    omega))
                (fun tail => im05_listPrefixOmits i k tail.1) :=
          mul_nonneg ENNReal.toReal_nonneg
            (EconCSLib.pmfProb_nonneg _ _)
      have hji : j ≠ i := by
        intro hji
        exact hi (by simpa [hj, hji])
      simpa [hj, hji] using hright_nonneg
    · simp only [hi, hj, or_false, ↓reduceIte]
      let μi :=
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail => im05_listPrefixOmits i k tail.1)
      let μj :=
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail => im05_listPrefixOmits j k tail.1)
      have hμi_nonneg : 0 ≤ μi := by
        dsimp [μi]
        exact EconCSLib.pmfProb_nonneg _ _
      have hμj_nonneg : 0 ≤ μj := by
        dsimp [μj]
        exact EconCSLib.pmfProb_nonneg _ _
      have hμj_le_one : μj ≤ 1 := by
        dsimp [μj]
        exact EconCSLib.pmfProb_le_one _ _
      have hprod_le : μi * μj ≤ μi := by
        nlinarith
      exact mul_le_mul_of_nonneg_left hprod_le ENNReal.toReal_nonneg

/-- The compact first-step pair-product sum is bounded by the right marginal. -/
theorem im05_firstStepOmitPairProductSum_le_marginal_right
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j ≤
      im05_firstStepOmitMarginalSum
        weight hweight_nonneg havailable forbidden hbudget j := by
  rw [im05_firstStepOmitPairProductSum_comm
    weight hweight_nonneg havailable forbidden hbudget i j]
  exact
    im05_firstStepOmitPairProductSum_le_marginal_left
      weight hweight_nonneg havailable forbidden hbudget j i

/--
Finite weighted opposite-spread identity.  Under a unit-mass weight vector,
the double sum of opposite movements equals twice the gap between the product
of weighted marginals and the weighted product.
-/
theorem im05_weighted_opposite_spread_identity
    {α : Type*} [Fintype α]
    (p a b : α → ℝ)
    (hp_sum : ∑ x : α, p x = 1) :
    (∑ x : α, ∑ y : α,
        p x * p y * ((a x - a y) * (b y - b x))) =
      2 * ((∑ x : α, p x * a x) * (∑ x : α, p x * b x) -
        ∑ x : α, p x * (a x * b x)) := by
  classical
  have hxy :
      (∑ x : α, ∑ y : α, p x * p y * (a x * b y)) =
        (∑ x : α, p x * a x) * (∑ y : α, p y * b y) := by
    calc
      (∑ x : α, ∑ y : α, p x * p y * (a x * b y)) =
          ∑ x : α, (p x * a x) * (∑ y : α, p y * b y) := by
            refine Finset.sum_congr rfl ?_
            intro x _hx
            rw [Finset.mul_sum]
            refine Finset.sum_congr rfl ?_
            intro y _hy
            ring
      _ = (∑ x : α, p x * a x) * (∑ y : α, p y * b y) := by
            rw [Finset.sum_mul]
  have hyy :
      (∑ x : α, ∑ y : α, p x * p y * (a y * b y)) =
        ∑ y : α, p y * (a y * b y) := by
    calc
      (∑ x : α, ∑ y : α, p x * p y * (a y * b y)) =
          ∑ x : α, p x * (∑ y : α, p y * (a y * b y)) := by
            refine Finset.sum_congr rfl ?_
            intro x _hx
            rw [Finset.mul_sum]
            refine Finset.sum_congr rfl ?_
            intro y _hy
            ring
      _ = (∑ x : α, p x) * (∑ y : α, p y * (a y * b y)) := by
            rw [Finset.sum_mul]
      _ = ∑ y : α, p y * (a y * b y) := by
            rw [hp_sum]
            ring
  have hxx :
      (∑ x : α, ∑ y : α, p x * p y * (a x * b x)) =
        ∑ x : α, p x * (a x * b x) := by
    calc
      (∑ x : α, ∑ y : α, p x * p y * (a x * b x)) =
          ∑ x : α, (p x * (a x * b x)) * (∑ y : α, p y) := by
            refine Finset.sum_congr rfl ?_
            intro x _hx
            rw [Finset.mul_sum]
            refine Finset.sum_congr rfl ?_
            intro y _hy
            ring
      _ = ∑ x : α, p x * (a x * b x) := by
            rw [hp_sum]
            simp
  have hyx :
      (∑ x : α, ∑ y : α, p x * p y * (a y * b x)) =
        (∑ y : α, p y * a y) * (∑ x : α, p x * b x) := by
    calc
      (∑ x : α, ∑ y : α, p x * p y * (a y * b x)) =
          ∑ x : α, (p x * b x) * (∑ y : α, p y * a y) := by
            refine Finset.sum_congr rfl ?_
            intro x _hx
            rw [Finset.mul_sum]
            refine Finset.sum_congr rfl ?_
            intro y _hy
            ring
      _ = (∑ x : α, p x * b x) * (∑ y : α, p y * a y) := by
            rw [Finset.sum_mul]
      _ = (∑ y : α, p y * a y) * (∑ x : α, p x * b x) := by
            ring
  simp only [sub_mul, mul_sub, Finset.sum_sub_distrib]
  rw [hxy, hyy, hxx, hyx]
  ring_nf

/--
The named residual-spread sum is exactly twice the gap between the product of
the first-step marginals and the first-step pair-product sum.
-/
theorem im05_firstStepResidualSpreadSum_eq_two_mul_gap
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) :
    im05_firstStepResidualSpreadSum
        weight hweight_nonneg havailable forbidden hbudget i j =
      2 *
        (im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j -
          im05_firstStepOmitPairProductSum
            weight hweight_nonneg havailable forbidden hbudget i j) := by
  classical
  let p : {w // w ∉ forbidden} → ℝ := fun head =>
    im05_firstStepHeadWeight
      weight hweight_nonneg havailable forbidden hbudget head
  let a : {w // w ∉ forbidden} → ℝ := fun head =>
    im05_firstStepResidualOmitProb
      weight hweight_nonneg havailable forbidden hbudget i head
  let b : {w // w ∉ forbidden} → ℝ := fun head =>
    im05_firstStepResidualOmitProb
      weight hweight_nonneg havailable forbidden hbudget j head
  have hp_sum : ∑ head : {w // w ∉ forbidden}, p head = 1 := by
    dsimp [p]
    exact
      im05_firstStepHeadWeight_sum_eq_one
        weight hweight_nonneg havailable forbidden hbudget
  have hid := im05_weighted_opposite_spread_identity p a b hp_sum
  calc
    im05_firstStepResidualSpreadSum
        weight hweight_nonneg havailable forbidden hbudget i j =
        ∑ head : {w // w ∉ forbidden}, ∑ tail : {w // w ∉ forbidden},
          p head * p tail * ((a head - a tail) * (b tail - b head)) := by
          simp [im05_firstStepResidualSpreadSum, p, a, b]
    _ =
        2 *
          ((∑ head : {w // w ∉ forbidden}, p head * a head) *
            (∑ head : {w // w ∉ forbidden}, p head * b head) -
            ∑ head : {w // w ∉ forbidden}, p head * (a head * b head)) := by
          exact hid
    _ =
        2 *
          (im05_firstStepOmitMarginalSum
              weight hweight_nonneg havailable forbidden hbudget i *
            im05_firstStepOmitMarginalSum
              weight hweight_nonneg havailable forbidden hbudget j -
            im05_firstStepOmitPairProductSum
              weight hweight_nonneg havailable forbidden hbudget i j) := by
          rw [← im05_firstStepOmitMarginalSum_eq_headWeight_residual
            weight hweight_nonneg havailable forbidden hbudget i]
          rw [← im05_firstStepOmitMarginalSum_eq_headWeight_residual
            weight hweight_nonneg havailable forbidden hbudget j]
          rw [← im05_firstStepOmitPairProductSum_eq_headWeight_residual_product
            weight hweight_nonneg havailable forbidden hbudget i j]

/--
Nonnegativity of the named residual-spread sum is equivalent to the compact
first-step averaging inequality.
-/
theorem im05_firstStepResidualSpreadSum_nonneg_iff
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W) :
    0 ≤ im05_firstStepResidualSpreadSum
        weight hweight_nonneg havailable forbidden hbudget i j ↔
      im05_firstStepOmitPairProductSum
          weight hweight_nonneg havailable forbidden hbudget i j ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j := by
  have hgap :=
    im05_firstStepResidualSpreadSum_eq_two_mul_gap
      weight hweight_nonneg havailable forbidden hbudget i j
  constructor
  · intro hspread
    nlinarith
  · intro hle
    nlinarith

/--
Residual-spread nonnegativity in the zero-residual base case.  After the first
head, a zero-length tail omits every non-head target with probability one and
the realized head with probability zero, so distinct targets have pointwise
opposite movement.
-/
theorem im05_firstStepResidualSpreadSum_nonneg_zero_of_ne
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (forbidden : Finset W)
    (hbudget : forbidden.card + (0 + 1) ≤ Fintype.card W)
    {i j : W} (hij : i ≠ j) :
    0 ≤ im05_firstStepResidualSpreadSum
      weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  apply
    im05_firstStepResidualSpreadSum_nonneg_of_pairwise_opposite
      weight hweight_nonneg havailable forbidden hbudget i j
  intro head tail
  have hres :
      ∀ (target : W) (head : {w // w ∉ forbidden}),
        im05_firstStepResidualOmitProb
          weight hweight_nonneg havailable forbidden hbudget target head =
          if head.1 = target then 0 else 1 := by
    intro target head
    by_cases hhead : head.1 = target
    · simp [im05_firstStepResidualOmitProb, hhead]
    · rw [im05_firstStepResidualOmitProb_eq_prob_of_head_ne
        weight hweight_nonneg havailable forbidden hbudget hhead]
      have hprob :
          EconCSLib.pmfProb
              (EconCSLib.finiteWithoutReplacementPMF
                weight hweight_nonneg havailable
                0 (insert head.1 forbidden)
                (by
                  rw [Finset.card_insert_of_notMem head.2]
                  omega))
              (fun sample => im05_listPrefixOmits target 0 sample.1) = 1 := by
        refine EconCSLib.pmfProb_eq_one_of_forall _ _ ?_
        intro sample
        exact im05_listPrefixOmits_zero target sample.1
      simpa [hhead] using hprob
  rw [hres i head, hres i tail, hres j tail, hres j head]
  by_cases hhi : head.1 = i <;>
    by_cases hti : tail.1 = i <;>
    by_cases hhj : head.1 = j <;>
    by_cases htj : tail.1 = j <;>
    simp [hhi, hti, hhj, htj, hij, hij.symm]

/--
Weighted product-vs-product-of-marginals inequality from a nonnegative
opposite-spread double sum.
-/
theorem im05_weighted_product_sum_le_product_sums_of_opposite_spread_nonneg
    {α : Type*} [Fintype α]
    (p a b : α → ℝ)
    (hp_sum : ∑ x : α, p x = 1)
    (hspread :
      0 ≤ ∑ x : α, ∑ y : α,
        p x * p y * ((a x - a y) * (b y - b x))) :
    (∑ x : α, p x * (a x * b x)) ≤
      (∑ x : α, p x * a x) * (∑ x : α, p x * b x) := by
  have hid :=
    im05_weighted_opposite_spread_identity p a b hp_sum
  nlinarith

/--
Weighted product-vs-product-of-marginals inequality from pairwise opposite
movement of `a` and `b`.
-/
theorem im05_weighted_product_sum_le_product_sums_of_pairwise_opposite
    {α : Type*} [Fintype α]
    (p a b : α → ℝ)
    (hp_nonneg : ∀ x, 0 ≤ p x)
    (hp_sum : ∑ x : α, p x = 1)
    (hopposite : ∀ x y : α, 0 ≤ (a x - a y) * (b y - b x)) :
    (∑ x : α, p x * (a x * b x)) ≤
      (∑ x : α, p x * a x) * (∑ x : α, p x * b x) := by
  exact
    im05_weighted_product_sum_le_product_sums_of_opposite_spread_nonneg
      p a b hp_sum
      (by
        refine Finset.sum_nonneg ?_
        intro x _hx
        refine Finset.sum_nonneg ?_
        intro y _hy
        exact mul_nonneg (mul_nonneg (hp_nonneg x) (hp_nonneg y))
          (hopposite x y))

/--
Compact first-step averaging from nonnegativity of the full opposite-spread
double sum for the zero-extended residual omission probabilities after the
first head.
-/
theorem im05_firstStepOmitPairProductSum_le_mul_of_head_opposite_spread_sum_nonneg
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W)
    (hspread :
      let Head := {w // w ∉ forbidden}
      let headLaw : PMF Head :=
        EconCSLib.finiteWeightedPMFAvailable
          weight forbidden hweight_nonneg
          (havailable forbidden (by omega))
      let p : Head → ℝ := fun head => (headLaw head).toReal
      let a : Head → ℝ := fun head =>
        if head.1 = i then 0 else
          EconCSLib.pmfProb
            (EconCSLib.finiteWithoutReplacementPMF
              weight hweight_nonneg havailable
              k (insert head.1 forbidden)
              (by
                rw [Finset.card_insert_of_notMem head.2]
                omega))
            (fun sample => im05_listPrefixOmits i k sample.1)
      let b : Head → ℝ := fun head =>
        if head.1 = j then 0 else
          EconCSLib.pmfProb
            (EconCSLib.finiteWithoutReplacementPMF
              weight hweight_nonneg havailable
              k (insert head.1 forbidden)
              (by
                rw [Finset.card_insert_of_notMem head.2]
                omega))
            (fun sample => im05_listPrefixOmits j k sample.1)
      0 ≤ ∑ head : Head, ∑ tail : Head,
        p head * p tail * ((a head - a tail) * (b tail - b head))) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j ≤
      im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget i *
        im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget j := by
  classical
  let Head := {w // w ∉ forbidden}
  let headLaw : PMF Head :=
    EconCSLib.finiteWeightedPMFAvailable
      weight forbidden hweight_nonneg
      (havailable forbidden (by omega))
  let p : Head → ℝ := fun head => (headLaw head).toReal
  let a : Head → ℝ := fun head =>
    if head.1 = i then 0 else
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          k (insert head.1 forbidden)
          (by
            rw [Finset.card_insert_of_notMem head.2]
            omega))
        (fun sample => im05_listPrefixOmits i k sample.1)
  let b : Head → ℝ := fun head =>
    if head.1 = j then 0 else
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          k (insert head.1 forbidden)
          (by
            rw [Finset.card_insert_of_notMem head.2]
            omega))
        (fun sample => im05_listPrefixOmits j k sample.1)
  have hp_sum : ∑ head : Head, p head = 1 := by
    dsimp [p, headLaw]
    exact EconCSLib.pmfToRealSum _
  have hspread' :
      0 ≤ ∑ head : Head, ∑ tail : Head,
        p head * p tail * ((a head - a tail) * (b tail - b head)) := by
    simpa [Head, headLaw, p, a, b] using hspread
  have hineq :=
    im05_weighted_product_sum_le_product_sums_of_opposite_spread_nonneg
      p a b hp_sum hspread'
  have hineq' :
      (∑ head : Head,
        if head.1 = j then 0 else
          if head.1 = i then 0 else
            (EconCSLib.finiteWeightedPMFAvailable
              weight forbidden hweight_nonneg
              (havailable forbidden (by omega)) head).toReal *
              (EconCSLib.pmfProb
                  (EconCSLib.finiteWithoutReplacementPMF
                    weight hweight_nonneg havailable
                    k (insert head.1 forbidden)
                    (by
                      rw [Finset.card_insert_of_notMem head.2]
                      omega))
                  (fun sample => im05_listPrefixOmits i k sample.1) *
                EconCSLib.pmfProb
                  (EconCSLib.finiteWithoutReplacementPMF
                    weight hweight_nonneg havailable
                    k (insert head.1 forbidden)
                    (by
                      rw [Finset.card_insert_of_notMem head.2]
                      omega))
                  (fun sample => im05_listPrefixOmits j k sample.1))) ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j := by
    simpa [p, a, b, headLaw, Head, im05_firstStepOmitMarginalSum,
      mul_ite, ite_mul, mul_assoc] using hineq
  unfold im05_firstStepOmitPairProductSum
  refine le_trans ?_ hineq'
  refine Finset.sum_le_sum ?_
  intro head _hhead
  by_cases hi : head.1 = i
  · simp [hi]
  · by_cases hj : head.1 = j
    · simp [hj]
    · simp [hi, hj]

/--
Concise named-function form of
`im05_firstStepOmitPairProductSum_le_mul_of_head_opposite_spread_sum_nonneg`.
-/
theorem im05_firstStepOmitPairProductSum_le_mul_of_residual_spread_sum_nonneg
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W)
    (hspread :
      0 ≤ ∑ head : {w // w ∉ forbidden},
        ∑ tail : {w // w ∉ forbidden},
          im05_firstStepHeadWeight
              weight hweight_nonneg havailable forbidden hbudget head *
            im05_firstStepHeadWeight
              weight hweight_nonneg havailable forbidden hbudget tail *
            ((im05_firstStepResidualOmitProb
                weight hweight_nonneg havailable forbidden hbudget i head -
              im05_firstStepResidualOmitProb
                weight hweight_nonneg havailable forbidden hbudget i tail) *
              (im05_firstStepResidualOmitProb
                  weight hweight_nonneg havailable forbidden hbudget j tail -
                im05_firstStepResidualOmitProb
                  weight hweight_nonneg havailable forbidden hbudget j head))) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j ≤
      im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget i *
        im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget j := by
  rw [im05_firstStepOmitPairProductSum_eq_headWeight_residual_product
    weight hweight_nonneg havailable forbidden hbudget i j]
  rw [im05_firstStepOmitMarginalSum_eq_headWeight_residual
    weight hweight_nonneg havailable forbidden hbudget i]
  rw [im05_firstStepOmitMarginalSum_eq_headWeight_residual
    weight hweight_nonneg havailable forbidden hbudget j]
  exact
    im05_weighted_product_sum_le_product_sums_of_opposite_spread_nonneg
      (fun head : {w // w ∉ forbidden} =>
        im05_firstStepHeadWeight
          weight hweight_nonneg havailable forbidden hbudget head)
      (fun head : {w // w ∉ forbidden} =>
        im05_firstStepResidualOmitProb
          weight hweight_nonneg havailable forbidden hbudget i head)
      (fun head : {w // w ∉ forbidden} =>
        im05_firstStepResidualOmitProb
          weight hweight_nonneg havailable forbidden hbudget j head)
      (im05_firstStepHeadWeight_sum_eq_one
        weight hweight_nonneg havailable forbidden hbudget)
      hspread

/--
First-step averaging from nonnegativity of the named residual-spread sum.
This is definitionally the same target as
`im05_firstStepOmitPairProductSum_le_mul_of_residual_spread_sum_nonneg`, but
keeps later theorem signatures shorter.
-/
theorem im05_firstStepOmitPairProductSum_le_mul_of_residualSpreadSum_nonneg
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W)
    (hspread :
      0 ≤ im05_firstStepResidualSpreadSum
        weight hweight_nonneg havailable forbidden hbudget i j) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j ≤
      im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget i *
        im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget j := by
  exact
    im05_firstStepOmitPairProductSum_le_mul_of_residual_spread_sum_nonneg
      weight hweight_nonneg havailable forbidden hbudget i j
      (by
        simpa [im05_firstStepResidualSpreadSum] using hspread)

/--
Named-function first-step averaging from pointwise opposite movement of the
zero-extended residual omission probabilities.  This is a stronger sufficient
condition than the summed spread target, but is often the most convenient
bridge when a case split proves every head-pair contribution nonnegative.
-/
theorem im05_firstStepOmitPairProductSum_le_mul_of_residual_pairwise_opposite
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W)
    (hopposite : ∀ head tail : {w // w ∉ forbidden},
      0 ≤
        ((im05_firstStepResidualOmitProb
            weight hweight_nonneg havailable forbidden hbudget i head -
          im05_firstStepResidualOmitProb
            weight hweight_nonneg havailable forbidden hbudget i tail) *
          (im05_firstStepResidualOmitProb
              weight hweight_nonneg havailable forbidden hbudget j tail -
            im05_firstStepResidualOmitProb
              weight hweight_nonneg havailable forbidden hbudget j head))) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j ≤
      im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget i *
        im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget j := by
  classical
  exact
    im05_firstStepOmitPairProductSum_le_mul_of_residual_spread_sum_nonneg
      weight hweight_nonneg havailable forbidden hbudget i j
      (by
        refine Finset.sum_nonneg ?_
        intro head _hhead
        refine Finset.sum_nonneg ?_
        intro tail _htail
        exact
          mul_nonneg
            (mul_nonneg
              (im05_firstStepHeadWeight_nonneg
                weight hweight_nonneg havailable forbidden hbudget head)
              (im05_firstStepHeadWeight_nonneg
                weight hweight_nonneg havailable forbidden hbudget tail))
            (hopposite head tail))

/--
Compact first-step averaging from a pairwise opposite-spread condition on the
zero-extended residual omission probabilities after the first head.
-/
theorem im05_firstStepOmitPairProductSum_le_mul_of_head_opposite_spread
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W)
    (hopposite : ∀ head tail : {w // w ∉ forbidden},
      0 ≤
        ((if head.1 = i then 0 else
            EconCSLib.pmfProb
              (EconCSLib.finiteWithoutReplacementPMF
                weight hweight_nonneg havailable
                k (insert head.1 forbidden)
                (by
                  rw [Finset.card_insert_of_notMem head.2]
                  omega))
              (fun sample => im05_listPrefixOmits i k sample.1)) -
          (if tail.1 = i then 0 else
            EconCSLib.pmfProb
              (EconCSLib.finiteWithoutReplacementPMF
                weight hweight_nonneg havailable
                k (insert tail.1 forbidden)
                (by
                  rw [Finset.card_insert_of_notMem tail.2]
                  omega))
              (fun sample => im05_listPrefixOmits i k sample.1))) *
        ((if tail.1 = j then 0 else
            EconCSLib.pmfProb
              (EconCSLib.finiteWithoutReplacementPMF
                weight hweight_nonneg havailable
                k (insert tail.1 forbidden)
                (by
                  rw [Finset.card_insert_of_notMem tail.2]
                  omega))
              (fun sample => im05_listPrefixOmits j k sample.1)) -
          (if head.1 = j then 0 else
            EconCSLib.pmfProb
              (EconCSLib.finiteWithoutReplacementPMF
                weight hweight_nonneg havailable
                k (insert head.1 forbidden)
                (by
                  rw [Finset.card_insert_of_notMem head.2]
                  omega))
              (fun sample => im05_listPrefixOmits j k sample.1)))) :
    im05_firstStepOmitPairProductSum
        weight hweight_nonneg havailable forbidden hbudget i j ≤
      im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget i *
        im05_firstStepOmitMarginalSum
          weight hweight_nonneg havailable forbidden hbudget j := by
  classical
  let Head := {w // w ∉ forbidden}
  let headLaw : PMF Head :=
    EconCSLib.finiteWeightedPMFAvailable
      weight forbidden hweight_nonneg
      (havailable forbidden (by omega))
  let p : Head → ℝ := fun head => (headLaw head).toReal
  let a : Head → ℝ := fun head =>
    if head.1 = i then 0 else
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          k (insert head.1 forbidden)
          (by
            rw [Finset.card_insert_of_notMem head.2]
            omega))
        (fun sample => im05_listPrefixOmits i k sample.1)
  let b : Head → ℝ := fun head =>
    if head.1 = j then 0 else
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          k (insert head.1 forbidden)
          (by
            rw [Finset.card_insert_of_notMem head.2]
            omega))
        (fun sample => im05_listPrefixOmits j k sample.1)
  have hp_nonneg : ∀ head : Head, 0 ≤ p head := by
    intro head
    dsimp [p]
    exact ENNReal.toReal_nonneg
  have hp_sum : ∑ head : Head, p head = 1 := by
    dsimp [p, headLaw]
    exact EconCSLib.pmfToRealSum _
  have hineq :=
    im05_weighted_product_sum_le_product_sums_of_pairwise_opposite
      p a b hp_nonneg hp_sum (by
        intro head tail
        simpa [a, b] using hopposite head tail)
  have hineq' :
      (∑ head : Head,
        if head.1 = j then 0 else
          if head.1 = i then 0 else
            (EconCSLib.finiteWeightedPMFAvailable
              weight forbidden hweight_nonneg
              (havailable forbidden (by omega)) head).toReal *
              (EconCSLib.pmfProb
                  (EconCSLib.finiteWithoutReplacementPMF
                    weight hweight_nonneg havailable
                    k (insert head.1 forbidden)
                    (by
                      rw [Finset.card_insert_of_notMem head.2]
                      omega))
                  (fun sample => im05_listPrefixOmits i k sample.1) *
                EconCSLib.pmfProb
                  (EconCSLib.finiteWithoutReplacementPMF
                    weight hweight_nonneg havailable
                    k (insert head.1 forbidden)
                    (by
                      rw [Finset.card_insert_of_notMem head.2]
                      omega))
                  (fun sample => im05_listPrefixOmits j k sample.1))) ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j := by
    simpa [p, a, b, headLaw, Head, im05_firstStepOmitMarginalSum,
      mul_ite, ite_mul, mul_assoc] using hineq
  unfold im05_firstStepOmitPairProductSum
  refine le_trans ?_ hineq'
  refine Finset.sum_le_sum ?_
  intro head _hhead
  by_cases hi : head.1 = i
  · simp [hi]
  · by_cases hj : head.1 = j
    · simp [hj]
    · simp [hi, hj]

/--
Pairwise negative correlation for two prefix-omission events under a
without-replacement draw started from `forbidden`.
-/
def im05_omissionPairNegativeCorrelation
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + k ≤ Fintype.card W)
    (i j : W) : Prop :=
  EconCSLib.pmfProb
      (EconCSLib.finiteWithoutReplacementPMF
        weight hweight_nonneg havailable k forbidden hbudget)
      (fun sample =>
        im05_listPrefixOmits i k sample.1 ∧
          im05_listPrefixOmits j k sample.1) ≤
    EconCSLib.pmfProb
      (EconCSLib.finiteWithoutReplacementPMF
        weight hweight_nonneg havailable k forbidden hbudget)
      (fun sample => im05_listPrefixOmits i k sample.1) *
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable k forbidden hbudget)
        (fun sample => im05_listPrefixOmits j k sample.1)

/-- Base case: with zero draws, both omission events are certain. -/
theorem im05_omissionPairNegativeCorrelation_zero
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (forbidden : Finset W)
    (hbudget : forbidden.card + 0 ≤ Fintype.card W)
    (i j : W) :
    im05_omissionPairNegativeCorrelation
      (k := 0) weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  unfold im05_omissionPairNegativeCorrelation
  rw [EconCSLib.pmfProb_eq_one_of_forall,
    EconCSLib.pmfProb_eq_one_of_forall,
    EconCSLib.pmfProb_eq_one_of_forall]
  · norm_num
  · intro sample
    exact im05_listPrefixOmits_zero j sample.1
  · intro sample
    exact im05_listPrefixOmits_zero i sample.1
  · intro sample
    exact ⟨im05_listPrefixOmits_zero i sample.1,
      im05_listPrefixOmits_zero j sample.1⟩

/--
One-draw base case for distinct targets: omitting both targets is the event
that the first draw hits neither target.
-/
theorem im05_omissionPairNegativeCorrelation_one_of_ne
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (forbidden : Finset W)
    (hbudget : forbidden.card + 1 ≤ Fintype.card W)
    {i j : W} (hij : i ≠ j) :
    im05_omissionPairNegativeCorrelation
      (k := 1) weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  unfold im05_omissionPairNegativeCorrelation
  let μ :=
    EconCSLib.finiteWithoutReplacementPMF
      weight hweight_nonneg havailable 1 forbidden hbudget
  let firstI : EconCSLib.finiteFreshList W 1 forbidden → Prop :=
    fun sample => sample.1 ⟨0, Nat.succ_pos 0⟩ = i
  let firstJ : EconCSLib.finiteFreshList W 1 forbidden → Prop :=
    fun sample => sample.1 ⟨0, Nat.succ_pos 0⟩ = j
  have homit_i :
      EconCSLib.pmfProb μ
          (fun sample => im05_listPrefixOmits i 1 sample.1) =
        EconCSLib.pmfProb μ (fun sample => ¬ firstI sample) := by
    refine EconCSLib.pmfProb_congr μ ?_
    intro sample
    have h :=
      im05_listPrefixOmits_succ_iff i sample.1 (r := 0)
        (Nat.succ_pos 0)
    simpa [firstI] using h
  have homit_j :
      EconCSLib.pmfProb μ
          (fun sample => im05_listPrefixOmits j 1 sample.1) =
        EconCSLib.pmfProb μ (fun sample => ¬ firstJ sample) := by
    refine EconCSLib.pmfProb_congr μ ?_
    intro sample
    have h :=
      im05_listPrefixOmits_succ_iff j sample.1 (r := 0)
        (Nat.succ_pos 0)
    simpa [firstJ] using h
  have homit_joint :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_listPrefixOmits i 1 sample.1 ∧
              im05_listPrefixOmits j 1 sample.1) =
        EconCSLib.pmfProb μ
          (fun sample => ¬ firstI sample ∧ ¬ firstJ sample) := by
    refine EconCSLib.pmfProb_congr μ ?_
    intro sample
    have hi :
        im05_listPrefixOmits i 1 sample.1 ↔ ¬ firstI sample := by
      have h :=
        im05_listPrefixOmits_succ_iff i sample.1 (r := 0)
          (Nat.succ_pos 0)
      simpa [firstI] using h
    have hj :
        im05_listPrefixOmits j 1 sample.1 ↔ ¬ firstJ sample := by
      have h :=
        im05_listPrefixOmits_succ_iff j sample.1 (r := 0)
          (Nat.succ_pos 0)
      simpa [firstJ] using h
    exact and_congr hi hj
  have hdisjoint : ∀ sample, firstI sample → firstJ sample → False := by
    intro sample hi hj
    exact hij (hi.symm.trans hj)
  rw [show
      EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable 1 forbidden hbudget)
          (fun sample =>
            im05_listPrefixOmits i 1 sample.1 ∧
              im05_listPrefixOmits j 1 sample.1) =
        EconCSLib.pmfProb μ
          (fun sample =>
            im05_listPrefixOmits i 1 sample.1 ∧
              im05_listPrefixOmits j 1 sample.1) by rfl]
  rw [show
      EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable 1 forbidden hbudget)
          (fun sample => im05_listPrefixOmits i 1 sample.1) =
        EconCSLib.pmfProb μ
          (fun sample => im05_listPrefixOmits i 1 sample.1) by rfl]
  rw [show
      EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable 1 forbidden hbudget)
          (fun sample => im05_listPrefixOmits j 1 sample.1) =
        EconCSLib.pmfProb μ
          (fun sample => im05_listPrefixOmits j 1 sample.1) by rfl]
  rw [homit_joint, homit_i, homit_j]
  rw [EconCSLib.pmfProb_not_and_not_eq_one_sub_add_of_disjoint
    μ firstI firstJ hdisjoint]
  rw [EconCSLib.pmfProb_compl μ firstI,
    EconCSLib.pmfProb_compl μ firstJ]
  have hprod_nonneg :
      0 ≤ EconCSLib.pmfProb μ firstI *
          EconCSLib.pmfProb μ firstJ :=
    mul_nonneg (EconCSLib.pmfProb_nonneg μ firstI)
      (EconCSLib.pmfProb_nonneg μ firstJ)
  nlinarith

/--
Induction-step wrapper for omission negative correlation under the recursive
without-replacement sampler.  Once the residual `k`-draw laws are pairwise
negatively correlated after every first head, the only remaining stochastic
content is the displayed first-step averaging inequality.
-/
theorem
    im05_finiteWithoutReplacementPMF_listPrefixOmits_pair_succ_negative_correlation_from_first_step
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W)
    (hresidual_neg : ∀ head : {w // w ∉ forbidden},
      head.1 ≠ i → head.1 ≠ j →
      EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail =>
            im05_listPrefixOmits i k tail.1 ∧
              im05_listPrefixOmits j k tail.1) ≤
        EconCSLib.pmfProb
            (EconCSLib.finiteWithoutReplacementPMF
              weight hweight_nonneg havailable
              k (insert head.1 forbidden)
              (by
                rw [Finset.card_insert_of_notMem head.2]
                omega))
            (fun tail => im05_listPrefixOmits i k tail.1) *
          EconCSLib.pmfProb
            (EconCSLib.finiteWithoutReplacementPMF
              weight hweight_nonneg havailable
              k (insert head.1 forbidden)
              (by
                rw [Finset.card_insert_of_notMem head.2]
                omega))
            (fun tail => im05_listPrefixOmits j k tail.1))
    (hfirst_step :
      (∑ head : {w // w ∉ forbidden},
        if head.1 = i ∨ head.1 = j then 0 else
          (EconCSLib.finiteWeightedPMFAvailable
            weight forbidden hweight_nonneg
            (havailable forbidden (by omega)) head).toReal *
            (EconCSLib.pmfProb
                (EconCSLib.finiteWithoutReplacementPMF
                  weight hweight_nonneg havailable
                  k (insert head.1 forbidden)
                  (by
                    rw [Finset.card_insert_of_notMem head.2]
                    omega))
                (fun tail => im05_listPrefixOmits i k tail.1) *
              EconCSLib.pmfProb
                (EconCSLib.finiteWithoutReplacementPMF
                  weight hweight_nonneg havailable
                  k (insert head.1 forbidden)
                  (by
                    rw [Finset.card_insert_of_notMem head.2]
                    omega))
                (fun tail => im05_listPrefixOmits j k tail.1))) ≤
        (∑ head : {w // w ∉ forbidden},
          if head.1 = i then 0 else
            (EconCSLib.finiteWeightedPMFAvailable
              weight forbidden hweight_nonneg
              (havailable forbidden (by omega)) head).toReal *
              EconCSLib.pmfProb
                (EconCSLib.finiteWithoutReplacementPMF
                  weight hweight_nonneg havailable
                  k (insert head.1 forbidden)
                  (by
                    rw [Finset.card_insert_of_notMem head.2]
                    omega))
                (fun tail => im05_listPrefixOmits i k tail.1)) *
        (∑ head : {w // w ∉ forbidden},
          if head.1 = j then 0 else
            (EconCSLib.finiteWeightedPMFAvailable
              weight forbidden hweight_nonneg
              (havailable forbidden (by omega)) head).toReal *
              EconCSLib.pmfProb
                (EconCSLib.finiteWithoutReplacementPMF
                  weight hweight_nonneg havailable
                  k (insert head.1 forbidden)
                  (by
                    rw [Finset.card_insert_of_notMem head.2]
                    omega))
                (fun tail => im05_listPrefixOmits j k tail.1))) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          (k + 1) forbidden hbudget)
        (fun sample =>
          im05_listPrefixOmits i (k + 1) sample.1 ∧
            im05_listPrefixOmits j (k + 1) sample.1) ≤
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          (k + 1) forbidden hbudget)
        (fun sample => im05_listPrefixOmits i (k + 1) sample.1) *
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            (k + 1) forbidden hbudget)
          (fun sample => im05_listPrefixOmits j (k + 1) sample.1) := by
  classical
  rw [im05_finiteWithoutReplacementPMF_listPrefixOmits_pair_succ_prob_eq_sum_head
    weight hweight_nonneg havailable forbidden hbudget i j]
  rw [im05_finiteWithoutReplacementPMF_listPrefixOmits_succ_prob_eq_sum_head
    weight hweight_nonneg havailable forbidden hbudget i]
  rw [im05_finiteWithoutReplacementPMF_listPrefixOmits_succ_prob_eq_sum_head
    weight hweight_nonneg havailable forbidden hbudget j]
  refine le_trans ?_ hfirst_step
  refine Finset.sum_le_sum ?_
  intro head _hhead
  by_cases hbad : head.1 = i ∨ head.1 = j
  · simp [hbad]
  · have hhead_i : head.1 ≠ i := by
      intro hi
      exact hbad (Or.inl hi)
    have hhead_j : head.1 ≠ j := by
      intro hj
      exact hbad (Or.inr hj)
    simp only [hbad, ↓reduceIte]
    exact
      mul_le_mul_of_nonneg_left
        (hresidual_neg head hhead_i hhead_j)
        ENNReal.toReal_nonneg

/--
Compact version of the first-step induction wrapper using named first-step
sums.  This is the preferred interface for the remaining tail-restricted
algebra.
-/
theorem
    im05_finiteWithoutReplacementPMF_listPrefixOmits_pair_succ_negative_correlation_from_compact_first_step
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W)
    (hresidual_neg : ∀ head : {w // w ∉ forbidden},
      head.1 ≠ i → head.1 ≠ j →
      EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            k (insert head.1 forbidden)
            (by
              rw [Finset.card_insert_of_notMem head.2]
              omega))
          (fun tail =>
            im05_listPrefixOmits i k tail.1 ∧
              im05_listPrefixOmits j k tail.1) ≤
        EconCSLib.pmfProb
            (EconCSLib.finiteWithoutReplacementPMF
              weight hweight_nonneg havailable
              k (insert head.1 forbidden)
              (by
                rw [Finset.card_insert_of_notMem head.2]
                omega))
            (fun tail => im05_listPrefixOmits i k tail.1) *
          EconCSLib.pmfProb
            (EconCSLib.finiteWithoutReplacementPMF
              weight hweight_nonneg havailable
              k (insert head.1 forbidden)
              (by
                rw [Finset.card_insert_of_notMem head.2]
                omega))
            (fun tail => im05_listPrefixOmits j k tail.1))
    (hfirst_step :
      im05_firstStepOmitPairProductSum
          weight hweight_nonneg havailable forbidden hbudget i j ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          (k + 1) forbidden hbudget)
        (fun sample =>
          im05_listPrefixOmits i (k + 1) sample.1 ∧
            im05_listPrefixOmits j (k + 1) sample.1) ≤
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable
          (k + 1) forbidden hbudget)
        (fun sample => im05_listPrefixOmits i (k + 1) sample.1) *
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable
            (k + 1) forbidden hbudget)
          (fun sample => im05_listPrefixOmits j (k + 1) sample.1) := by
  classical
  exact
    im05_finiteWithoutReplacementPMF_listPrefixOmits_pair_succ_negative_correlation_from_first_step
      weight hweight_nonneg havailable forbidden hbudget i j hresidual_neg
      (by
        simpa [im05_firstStepOmitPairProductSum,
          im05_firstStepOmitMarginalSum] using hfirst_step)

/-- A two-slot prefix omits `w` exactly when both first two slots avoid `w`. -/
theorem im05_listPrefixOmits_two_iff
    {W : Type*} {k : ℕ} (w : W) (list : Fin k → W)
    (h0 : 0 < k) (h1 : 1 < k) :
    im05_listPrefixOmits w 2 list ↔
      list ⟨0, h0⟩ ≠ w ∧ list ⟨1, h1⟩ ≠ w := by
  constructor
  · intro homit
    exact ⟨homit ⟨0, h0⟩ (by norm_num),
      homit ⟨1, h1⟩ (by norm_num)⟩
  · rintro ⟨hzero, hone⟩ slot hslot
    have hslot_cases : slot.val = 0 ∨ slot.val = 1 := by omega
    rcases hslot_cases with hval | hval
    · have hslot_eq : slot = ⟨0, h0⟩ := Fin.ext hval
      simpa [hslot_eq] using hzero
    · have hslot_eq : slot = ⟨1, h1⟩ := Fin.ext hval
      simpa [hslot_eq] using hone

/-- A two-slot prefix does not omit `w` exactly when `w` is in one of the two slots. -/
theorem im05_not_listPrefixOmits_two_iff
    {W : Type*} {k : ℕ} (w : W) (list : Fin k → W)
    (h0 : 0 < k) (h1 : 1 < k) :
    ¬ im05_listPrefixOmits w 2 list ↔
      list ⟨0, h0⟩ = w ∨ list ⟨1, h1⟩ = w := by
  rw [im05_listPrefixOmits_two_iff w list h0 h1]
  tauto

/--
For an injective two-slot prefix and distinct targets, hitting both targets
means the first two slots are the two targets in one of the two possible orders.
-/
theorem im05_two_slot_hits_distinct_iff
    {W : Type*} {k : ℕ} (i j : W) (list : Fin k → W)
    (h0 : 0 < k) (h1 : 1 < k)
    (hinj : Function.Injective list) (hij : i ≠ j) :
    (¬ im05_listPrefixOmits i 2 list ∧
        ¬ im05_listPrefixOmits j 2 list) ↔
      (list ⟨0, h0⟩ = i ∧ list ⟨1, h1⟩ = j) ∨
        (list ⟨0, h0⟩ = j ∧ list ⟨1, h1⟩ = i) := by
  rw [im05_not_listPrefixOmits_two_iff i list h0 h1]
  rw [im05_not_listPrefixOmits_two_iff j list h0 h1]
  constructor
  · rintro ⟨hi0 | hi1, hj0 | hj1⟩
    · exact False.elim (hij (hi0.symm.trans hj0))
    · exact Or.inl ⟨hi0, hj1⟩
    · exact Or.inr ⟨hj0, hi1⟩
    · exact False.elim (hij (hi1.symm.trans hj1))
  · rintro (⟨hi0, hj1⟩ | ⟨hj0, hi1⟩)
    · exact ⟨Or.inl hi0, Or.inr hj1⟩
    · exact ⟨Or.inr hi1, Or.inl hj0⟩

/--
Exact ordered two-draw atom probability for the recursive weighted
without-replacement sampler, started from an arbitrary forbidden set.
-/
theorem im05_finiteWithoutReplacementPMF_two_first_second_prob_eq_weight_ratio_mul_ratio
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (forbidden : Finset W)
    (hbudget : forbidden.card + 2 ≤ Fintype.card W)
    (head target : W)
    (hhead : head ∉ forbidden)
    (htarget : target ∉ insert head forbidden) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable 2 forbidden hbudget)
        (fun sample =>
          sample.1 ⟨0, by omega⟩ = head ∧
            sample.1 ⟨1, by omega⟩ = target) =
      (weight head / EconCSLib.finiteAvailableWeight weight forbidden) *
        (weight target /
          EconCSLib.finiteAvailableWeight weight (insert head forbidden)) := by
  classical
  let head₀ : {w // w ∉ forbidden} := ⟨head, hhead⟩
  let target₀ : {w // w ∉ insert head forbidden} := ⟨target, htarget⟩
  let q : EconCSLib.finiteFreshList W 1 (insert head forbidden) → Prop :=
    fun tail => tail.1 ⟨0, by omega⟩ = target
  let lifted : EconCSLib.finiteFreshList W 2 forbidden → Prop :=
    fun sample =>
      ∃ hrealized : sample.1 ⟨0, by omega⟩ = head,
        q (EconCSLib.finiteFreshListTailOfHead sample head₀ hrealized)
  have hevent :
      EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable 2 forbidden hbudget)
          (fun sample =>
            sample.1 ⟨0, by omega⟩ = head ∧
              sample.1 ⟨1, by omega⟩ = target) =
        EconCSLib.pmfProb
          (EconCSLib.finiteWithoutReplacementPMF
            weight hweight_nonneg havailable 2 forbidden hbudget)
          lifted := by
    refine EconCSLib.pmfProb_congr _ ?_
    intro sample
    constructor
    · rintro ⟨hfirst, hsecond⟩
      refine ⟨hfirst, ?_⟩
      simpa [q, EconCSLib.finiteFreshListTailOfHead, EconCSLib.finTail]
        using hsecond
    · rintro ⟨hfirst, htail⟩
      exact ⟨hfirst, by
        simpa [q, EconCSLib.finiteFreshListTailOfHead, EconCSLib.finTail]
          using htail⟩
  rw [hevent]
  rw [EconCSLib.finiteWithoutReplacementPMF_head_tail_prob
    (baseWeight := weight)
    (hbase_nonneg := hweight_nonneg)
    (havailable := havailable)
    (forbidden := forbidden)
    (hbudget := hbudget)
    (head₀ := head₀)
    (q := q)]
  rw [EconCSLib.finiteWithoutReplacementPMF_head_prob
    (baseWeight := weight)
    (hbase_nonneg := hweight_nonneg)
    (havailable := havailable)
    (forbidden := insert head forbidden)
    (hbudget := by
      rw [Finset.card_insert_of_notMem hhead]
      omega)
    (head₀ := target₀)]
  rw [EconCSLib.finiteWeightedPMFAvailable_apply_toReal]
  rw [EconCSLib.finiteWeightedPMFAvailable_apply_toReal]

/--
Two-draw probability of hitting both distinct targets under the recursive
weighted without-replacement sampler, started from an arbitrary forbidden set.
-/
theorem im05_finiteWithoutReplacementPMF_two_hit_both_prob_eq_order_sum
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (forbidden : Finset W)
    (hbudget : forbidden.card + 2 ≤ Fintype.card W)
    {i j : W} (hi : i ∉ forbidden) (hj : j ∉ forbidden) (hij : i ≠ j) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable 2 forbidden hbudget)
        (fun sample =>
          ¬ im05_listPrefixOmits i 2 sample.1 ∧
            ¬ im05_listPrefixOmits j 2 sample.1) =
      (weight i / EconCSLib.finiteAvailableWeight weight forbidden) *
          (weight j /
            EconCSLib.finiteAvailableWeight weight (insert i forbidden)) +
        (weight j / EconCSLib.finiteAvailableWeight weight forbidden) *
          (weight i /
            EconCSLib.finiteAvailableWeight weight (insert j forbidden)) := by
  classical
  let μ :=
    EconCSLib.finiteWithoutReplacementPMF
      weight hweight_nonneg havailable 2 forbidden hbudget
  let orderIJ : EconCSLib.finiteFreshList W 2 forbidden → Prop :=
    fun sample => sample.1 ⟨0, by omega⟩ = i ∧ sample.1 ⟨1, by omega⟩ = j
  let orderJI : EconCSLib.finiteFreshList W 2 forbidden → Prop :=
    fun sample => sample.1 ⟨0, by omega⟩ = j ∧ sample.1 ⟨1, by omega⟩ = i
  have hhit_congr :
      EconCSLib.pmfProb μ
          (fun sample =>
            ¬ im05_listPrefixOmits i 2 sample.1 ∧
              ¬ im05_listPrefixOmits j 2 sample.1) =
        EconCSLib.pmfProb μ (fun sample => orderIJ sample ∨ orderJI sample) := by
    refine EconCSLib.pmfProb_congr μ ?_
    intro sample
    simpa [orderIJ, orderJI] using
      (im05_two_slot_hits_distinct_iff i j sample.1
        (by omega) (by omega) sample.2.1 hij)
  have hdisjoint : ∀ sample, orderIJ sample → orderJI sample → False := by
    intro sample hIJ hJI
    exact hij (hIJ.1.symm.trans hJI.1)
  rw [hhit_congr]
  rw [EconCSLib.pmfProb_or_eq_add_of_disjoint μ orderIJ orderJI hdisjoint]
  rw [im05_finiteWithoutReplacementPMF_two_first_second_prob_eq_weight_ratio_mul_ratio
    weight hweight_nonneg havailable forbidden hbudget i j hi
    (by simp [hj, hij.symm])]
  rw [im05_finiteWithoutReplacementPMF_two_first_second_prob_eq_weight_ratio_mul_ratio
    weight hweight_nonneg havailable forbidden hbudget j i hj
    (by simp [hi, hij])]

/--
Second-slot marginal formula for a two-draw weighted without-replacement
sampler, expanded over the first-slot value.
-/
theorem im05_finiteWithoutReplacementPMF_two_second_prob_eq_sum_first
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (forbidden : Finset W)
    (hbudget : forbidden.card + 2 ≤ Fintype.card W)
    {target : W} (htarget : target ∉ forbidden) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable 2 forbidden hbudget)
        (fun sample => sample.1 ⟨1, by omega⟩ = target) =
      ∑ head : {w // w ∉ forbidden},
        if target ≠ head.1 then
          (weight head.1 /
              EconCSLib.finiteAvailableWeight weight forbidden) *
            (weight target /
              EconCSLib.finiteAvailableWeight weight (insert head.1 forbidden))
        else 0 := by
  classical
  let μ :=
    EconCSLib.finiteWithoutReplacementPMF
      weight hweight_nonneg havailable 2 forbidden hbudget
  let second : EconCSLib.finiteFreshList W 2 forbidden → Prop :=
    fun sample => sample.1 ⟨1, by omega⟩ = target
  let firstValue : EconCSLib.finiteFreshList W 2 forbidden → {w // w ∉ forbidden} :=
    fun sample => ⟨sample.1 ⟨0, by omega⟩, sample.2.2 ⟨0, by omega⟩⟩
  rw [EconCSLib.pmfProb_eq_sum_state_inter μ second firstValue]
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  by_cases hneq : target ≠ head.1
  · have hterm :
        EconCSLib.pmfProb μ
            (fun sample => second sample ∧ firstValue sample = head) =
          EconCSLib.pmfProb μ
            (fun sample =>
              sample.1 ⟨0, by omega⟩ = head.1 ∧
                sample.1 ⟨1, by omega⟩ = target) := by
        refine EconCSLib.pmfProb_congr μ ?_
        intro sample
        constructor
        · intro h
          exact ⟨congrArg Subtype.val h.2, h.1⟩
        · intro h
          exact ⟨h.2, Subtype.ext h.1⟩
    rw [hterm]
    simpa [μ, hneq] using
      (im05_finiteWithoutReplacementPMF_two_first_second_prob_eq_weight_ratio_mul_ratio
        weight hweight_nonneg havailable forbidden hbudget head.1 target
        head.2 (by simp [htarget, hneq]))
  · have hhead_eq : head.1 = target := by
      by_contra hne
      exact hneq (Ne.symm hne)
    subst hhead_eq
    have hzero :
        EconCSLib.pmfProb μ
            (fun sample => second sample ∧ firstValue sample = head) =
          0 := by
      refine EconCSLib.pmfProb_eq_zero_of_no_mass μ _ ?_
      intro sample hsample
      have hinj := sample.2.1
      have hslot_eq :
          (⟨0, by omega⟩ : Fin 2) = ⟨1, by omega⟩ := by
        exact hinj ((congrArg Subtype.val hsample.2).trans hsample.1.symm)
      have hval := congrArg Fin.val hslot_eq
      norm_num at hval
    simp [hneq, hzero]

/--
Two-draw hit probability in the factor form used by the scalar
negative-correlation algebra, for an arbitrary forbidden starting set.
-/
theorem im05_finiteWithoutReplacementPMF_two_hit_prob_eq_factor
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (forbidden : Finset W)
    (hbudget : forbidden.card + 2 ≤ Fintype.card W)
    {target : W} (htarget : target ∉ forbidden) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable 2 forbidden hbudget)
        (fun sample => ¬ im05_listPrefixOmits target 2 sample.1) =
      (weight target / EconCSLib.finiteAvailableWeight weight forbidden) *
        (1 +
          ∑ head : {w // w ∉ forbidden},
            if target ≠ head.1 then
              weight head.1 /
                (EconCSLib.finiteAvailableWeight weight forbidden -
                  weight head.1)
            else 0) := by
  classical
  let μ :=
    EconCSLib.finiteWithoutReplacementPMF
      weight hweight_nonneg havailable 2 forbidden hbudget
  let first : EconCSLib.finiteFreshList W 2 forbidden → Prop :=
    fun sample => sample.1 ⟨0, by omega⟩ = target
  let second : EconCSLib.finiteFreshList W 2 forbidden → Prop :=
    fun sample => sample.1 ⟨1, by omega⟩ = target
  have hhit :
      EconCSLib.pmfProb μ
          (fun sample => ¬ im05_listPrefixOmits target 2 sample.1) =
        EconCSLib.pmfProb μ (fun sample => first sample ∨ second sample) := by
    refine EconCSLib.pmfProb_congr μ ?_
    intro sample
    simpa [first, second] using
      (im05_not_listPrefixOmits_two_iff target sample.1 (by omega) (by omega))
  have hdisjoint : ∀ sample, first sample → second sample → False := by
    intro sample hfirst hsecond
    have hinj := sample.2.1
    have hslot_eq :
        (⟨0, by omega⟩ : Fin 2) = ⟨1, by omega⟩ :=
      hinj (hfirst.trans hsecond.symm)
    have hval := congrArg Fin.val hslot_eq
    norm_num at hval
  rw [hhit]
  rw [EconCSLib.pmfProb_or_eq_add_of_disjoint μ first second hdisjoint]
  rw [EconCSLib.finiteWithoutReplacementPMF_head_prob
    (baseWeight := weight)
    (hbase_nonneg := hweight_nonneg)
    (havailable := havailable)
    (forbidden := forbidden)
    (hbudget := hbudget)
    (head₀ := (⟨target, htarget⟩ : {w // w ∉ forbidden}))]
  rw [EconCSLib.finiteWeightedPMFAvailable_apply_toReal]
  rw [im05_finiteWithoutReplacementPMF_two_second_prob_eq_sum_first
    weight hweight_nonneg havailable forbidden hbudget htarget]
  rw [mul_add]
  rw [mul_one]
  rw [Finset.mul_sum]
  congr 1
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  by_cases hneq : target ≠ head.1
  · rw [EconCSLib.finiteAvailableWeight_insert_eq_sub weight forbidden head.2]
    simp [hneq]
    ring_nf
  · simp [hneq]

/-- Experiment 2 sample space: every man independently has an ordered list of
`k` distinct women. -/
abbrev im05_experiment2Sample (M W : Type*) (k : ℕ) :=
  M → im05_distinctWomanList W k

/-- Uncurry an Experiment 2 sample into the named man-slot assignment. -/
def im05_experiment2Names {M W : Type*} {k : ℕ}
    (sample : im05_experiment2Sample M W k) : M × Fin k → W :=
  fun slot => (sample slot.1).1 slot.2

/-- Experiment 2 empty-count statistic on the explicit without-replacement
sample space. -/
noncomputable def im05_experiment2EmptyCountFromSample {M W : Type*}
    [Fintype M] [Fintype W] [DecidableEq W]
    (k : ℕ) (sample : im05_experiment2Sample M W k) : ℕ :=
  im05_experiment2EmptyCount k (im05_experiment2Names sample)

/-- The explicit Experiment 2 sample statistic is definitionally the supplied
assignment statistic after uncurrying the man-slot names. -/
theorem im05_experiment2EmptyCountFromSample_eq {M W : Type*}
    [Fintype M] [Fintype W] [DecidableEq W]
    (k : ℕ) (sample : im05_experiment2Sample M W k) :
    im05_experiment2EmptyCountFromSample k sample =
      im05_experiment2EmptyCount k (im05_experiment2Names sample) := rfl

/-- Relabel every woman in an Experiment 2 without-replacement sample. -/
def im05_experiment2SampleRelabel {M W : Type*} {k : ℕ}
    (e : W ≃ W) (sample : im05_experiment2Sample M W k) :
    im05_experiment2Sample M W k :=
  fun m => EconCSLib.injectiveFunRangeRelabelEquiv e (sample m)

/-- Uncurried Experiment 2 names commute with woman relabeling. -/
theorem im05_experiment2Names_relabel {M W : Type*} {k : ℕ}
    (e : W ≃ W) (sample : im05_experiment2Sample M W k) :
    im05_experiment2Names (im05_experiment2SampleRelabel e sample) =
      fun slot : M × Fin k => e (im05_experiment2Names sample slot) := by
  funext slot
  rfl

/-- Experiment 2's empty-count statistic is invariant under relabeling women. -/
theorem im05_experiment2EmptyCountFromSample_relabel
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq W]
    {k : ℕ} (e : W ≃ W) (sample : im05_experiment2Sample M W k) :
    im05_experiment2EmptyCountFromSample k
        (im05_experiment2SampleRelabel e sample) =
      im05_experiment2EmptyCountFromSample k sample := by
  unfold im05_experiment2EmptyCountFromSample im05_experiment2EmptyCount
  rw [im05_experiment2Names_relabel e sample]
  rw [EconCSLib.occupancyEmptyBins_bin_equiv e
    (im05_experiment2Names sample)]
  rw [Finset.card_image_of_injective _ e.injective]

/--
Uniform Experiment 2 probability exchangeability: for ordered
without-replacement samples, a woman relabeling applied to every man's list
preserves uniform probabilities.
-/
theorem im05_experiment2_uniform_sample_relabel_prob
    {M W : Type*} [Fintype M] [DecidableEq M]
    [Fintype W] [DecidableEq W]
    {k : ℕ} [Nonempty (im05_distinctWomanList W k)]
    (e : W ≃ W)
    (p q : im05_experiment2Sample M W k → Prop)
    [DecidablePred p] [DecidablePred q]
    (h : ∀ sample : im05_experiment2Sample M W k,
      p (im05_experiment2SampleRelabel e sample) ↔ q sample) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF (im05_experiment2Sample M W k)) p =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF (im05_experiment2Sample M W k)) q := by
  classical
  exact EconCSLib.pmfProb_uniformPMF_fun_range_relabel
    (ι := M) (α := im05_distinctWomanList W k)
    (EconCSLib.injectiveFunRangeRelabelEquiv e) p q h

/--
Experiment 5 count: every man names exactly `k+1` women, with repetitions
allowed, so the single women are precisely the unnamed bins.
-/
noncomputable def im05_experiment5EmptyCount {M W : Type*}
    [Fintype M] [Fintype W] [DecidableEq W]
    (k : ℕ) (names : M × Fin (k + 1) → W) : ℕ :=
  (EconCSLib.occupancyEmptyBins names).card

/-- Experiment 5 sample space: every man names exactly `k+1` women, with
repetitions allowed. -/
abbrev im05_experiment5Sample (M W : Type*) (k : ℕ) :=
  M → Fin (k + 1) → W

/-- Uncurry an Experiment 5 sample into the named man-slot assignment. -/
def im05_experiment5Names {M W : Type*} {k : ℕ}
    (sample : im05_experiment5Sample M W k) : M × Fin (k + 1) → W :=
  fun slot => sample slot.1 slot.2

/-- Experiment 5 empty-count statistic on the explicit with-replacement
sample space. -/
noncomputable def im05_experiment5EmptyCountFromSample {M W : Type*}
    [Fintype M] [Fintype W] [DecidableEq W]
    (k : ℕ) (sample : im05_experiment5Sample M W k) : ℕ :=
  im05_experiment5EmptyCount k (im05_experiment5Names sample)

/-- Relabel every woman in an Experiment 5 with-replacement sample. -/
def im05_experiment5SampleRelabel {M W : Type*} {k : ℕ}
    (e : W ≃ W) (sample : im05_experiment5Sample M W k) :
    im05_experiment5Sample M W k :=
  fun m slot => e (sample m slot)

/-- Uncurried Experiment 5 names commute with woman relabeling. -/
theorem im05_experiment5Names_relabel {M W : Type*} {k : ℕ}
    (e : W ≃ W) (sample : im05_experiment5Sample M W k) :
    im05_experiment5Names (im05_experiment5SampleRelabel e sample) =
      fun slot : M × Fin (k + 1) => e (im05_experiment5Names sample slot) := by
  funext slot
  rfl

/-- Experiment 5's empty-count statistic is invariant under relabeling women. -/
theorem im05_experiment5EmptyCountFromSample_relabel
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq W]
    {k : ℕ} (e : W ≃ W) (sample : im05_experiment5Sample M W k) :
    im05_experiment5EmptyCountFromSample k
        (im05_experiment5SampleRelabel e sample) =
      im05_experiment5EmptyCountFromSample k sample := by
  unfold im05_experiment5EmptyCountFromSample im05_experiment5EmptyCount
  rw [im05_experiment5Names_relabel e sample]
  rw [EconCSLib.occupancyEmptyBins_bin_equiv e
    (im05_experiment5Names sample)]
  rw [Finset.card_image_of_injective _ e.injective]

/-- Uniform Experiment 5 probability exchangeability under woman relabeling. -/
theorem im05_experiment5_uniform_sample_relabel_prob
    {M W : Type*} [Fintype M] [DecidableEq M]
    [Fintype W] [DecidableEq W] [Nonempty W]
    {k : ℕ} (e : W ≃ W)
    (p q : im05_experiment5Sample M W k → Prop)
    [DecidablePred p] [DecidablePred q]
    (h : ∀ sample : im05_experiment5Sample M W k,
      p (im05_experiment5SampleRelabel e sample) ↔ q sample) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF (im05_experiment5Sample M W k)) p =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF (im05_experiment5Sample M W k)) q := by
  classical
  let relabel : im05_experiment5Sample M W k ≃ im05_experiment5Sample M W k :=
    { toFun := im05_experiment5SampleRelabel e
      invFun := im05_experiment5SampleRelabel e.symm
      left_inv := by
        intro sample
        funext m slot
        simp [im05_experiment5SampleRelabel]
      right_inv := by
        intro sample
        funext m slot
        simp [im05_experiment5SampleRelabel] }
  exact EconCSLib.pmfProb_uniformPMF_eq_of_comp_equiv relabel p q h

/--
The unordered distinct pair of proposal positions used in Lemma 6.2's
negligible-perturbation union bound, over the first `k+2` proposals.
-/
abbrev im05_redundantProposalPair (k : ℕ) :=
  { pair : Sym2 (Fin (k + 2)) // ¬ pair.IsDiag }

/-- Lemma 6.2's bad-event index: a man and an unordered pair of proposal slots. -/
abbrev im05_redundantPairIndex (M : Type*) (k : ℕ) :=
  M × im05_redundantProposalPair k

/--
A proposal slot is redundant in a draw prefix if the same woman appeared in an
earlier slot.
-/
def im05_redundantSlot {W : Type*} {T : ℕ}
    (draw : Fin T → W) (slot : Fin T) : Prop :=
  ∃ earlier : Fin T, earlier < slot ∧ draw earlier = draw slot

/-- The number of slots earlier than a `Fin T` slot is its zero-indexed value. -/
theorem im05_earlierSlots_card {T : ℕ} (slot : Fin T) :
    (((Finset.univ : Finset (Fin T)).filter
      (fun earlier => earlier < slot)).card) = slot.val := by
  classical
  let e : {earlier : Fin T // earlier < slot} ≃ Fin slot.val :=
    { toFun := fun earlier => ⟨earlier.1.val, earlier.2⟩
      invFun := fun r =>
        ⟨⟨r.val, lt_trans r.isLt slot.isLt⟩, r.isLt⟩
      left_inv := by
        intro earlier
        ext
        rfl
      right_inv := by
        intro r
        ext
        rfl }
  have hcard_subtype :
      Fintype.card {earlier : Fin T // earlier < slot} =
        (((Finset.univ : Finset (Fin T)).filter
          (fun earlier => earlier < slot)).card) := by
    rw [Fintype.card_subtype]
  have hcard_fin :
      Fintype.card {earlier : Fin T // earlier < slot} = slot.val := by
    rw [Fintype.card_congr e, Fintype.card_fin]
  exact hcard_subtype ▸ hcard_fin

/-- The finite set of redundant slots in a draw prefix. -/
noncomputable def im05_redundantSlots {W : Type*} [DecidableEq W]
    {T : ℕ} (draw : Fin T → W) : Finset (Fin T) := by
  classical
  exact (Finset.univ : Finset (Fin T)).filter fun slot =>
    im05_redundantSlot draw slot

/-- A redundant-pair event: both slots in the unordered pair are redundant. -/
def im05_redundantPairEvent {W : Type*} [DecidableEq W]
    (k : ℕ) (draw : Fin (k + 2) → W)
    (pair : im05_redundantProposalPair k) : Prop :=
  ∀ slot ∈ pair.1.toFinset, im05_redundantSlot draw slot

/--
The paper's redundant-pair bad event for one outcome: the indexed man has both
slots in the indexed unordered pair redundant in his first `k+2` draws.
-/
def im05_redundantPairBadEvent {M W Ω : Type*} [DecidableEq W]
    (k : ℕ) (draws : Ω → M → Fin (k + 2) → W)
    (idx : im05_redundantPairIndex M k) (ω : Ω) : Prop :=
  im05_redundantPairEvent k (draws ω idx.1) idx.2

/--
Concrete Experiment 3 bad event at the first-`k+2` draw-prefix level: some man
has used at most `k` distinct women in those first `k+2` amnesiac draws.
-/
abbrev im05_experiment3PrefixSample (M W : Type*) (k : ℕ) :=
  M → Fin (k + 2) → W

def im05_experiment3BadDrawEvent {M W : Type*} [DecidableEq W]
    (k : ℕ) (draws : im05_experiment3PrefixSample M W k) : Prop :=
  ∃ m : M, (EconCSLib.occupancyUsedBins (draws m)).card ≤ k

/-- Relabel every woman in an Experiment 3 draw-prefix sample. -/
def im05_experiment3PrefixSampleRelabel {M W : Type*} {k : ℕ}
    (e : W ≃ W) (draws : im05_experiment3PrefixSample M W k) :
    im05_experiment3PrefixSample M W k :=
  fun m slot => e (draws m slot)

/-- Redundant-slot status is invariant under relabeling women. -/
theorem im05_redundantSlot_relabel_iff
    {W W' : Type*} {T : ℕ} (e : W ≃ W')
    (draw : Fin T → W) (slot : Fin T) :
    im05_redundantSlot (fun t => e (draw t)) slot ↔
      im05_redundantSlot draw slot := by
  constructor
  · rintro ⟨earlier, hearlier, hsame⟩
    exact ⟨earlier, hearlier, e.injective hsame⟩
  · rintro ⟨earlier, hearlier, hsame⟩
    exact ⟨earlier, hearlier, by simpa [hsame]⟩

/-- Redundant-pair events are invariant under relabeling women. -/
theorem im05_redundantPairEvent_relabel_iff
    {W W' : Type*} [DecidableEq W] [DecidableEq W']
    (e : W ≃ W') (k : ℕ) (draw : Fin (k + 2) → W)
    (pair : im05_redundantProposalPair k) :
    im05_redundantPairEvent k (fun slot => e (draw slot)) pair ↔
      im05_redundantPairEvent k draw pair := by
  constructor
  · intro h slot hslot
    exact (im05_redundantSlot_relabel_iff e draw slot).1 (h slot hslot)
  · intro h slot hslot
    exact (im05_redundantSlot_relabel_iff e draw slot).2 (h slot hslot)

/-- Indexed redundant-pair bad events are invariant under relabeling women. -/
theorem im05_redundantPairBadEvent_relabel_iff
    {Ω M W W' : Type*} [DecidableEq W] [DecidableEq W']
    (e : W ≃ W') (k : ℕ)
    (draws : Ω → M → Fin (k + 2) → W)
    (idx : im05_redundantPairIndex M k) (ω : Ω) :
    im05_redundantPairBadEvent k
        (fun ω m slot => e (draws ω m slot)) idx ω ↔
      im05_redundantPairBadEvent k draws idx ω := by
  exact im05_redundantPairEvent_relabel_iff e k (draws ω idx.1) idx.2

/--
The Experiment 3 draw-prefix bad event is invariant under relabeling women,
because used-bin cardinality is preserved by a bin equivalence.
-/
theorem im05_experiment3BadDrawEvent_relabel_iff
    {M W W' : Type*} [DecidableEq W] [DecidableEq W']
    (e : W ≃ W') (k : ℕ) (draws : M → Fin (k + 2) → W) :
    im05_experiment3BadDrawEvent k
        (fun m slot => e (draws m slot)) ↔
      im05_experiment3BadDrawEvent k draws := by
  constructor
  · rintro ⟨m, hused⟩
    rw [EconCSLib.occupancyUsedBins_card_bin_equiv e (draws m)] at hused
    exact ⟨m, hused⟩
  · rintro ⟨m, hused⟩
    refine ⟨m, ?_⟩
    rwa [EconCSLib.occupancyUsedBins_card_bin_equiv e (draws m)]

/-- Uniform Experiment 3 prefix probability exchangeability under woman
relabeling. -/
theorem im05_experiment3_uniform_prefix_relabel_prob
    {M W : Type*} [Fintype M] [DecidableEq M]
    [Fintype W] [DecidableEq W] [Nonempty W]
    {k : ℕ} (e : W ≃ W)
    (p q : im05_experiment3PrefixSample M W k → Prop)
    [DecidablePred p] [DecidablePred q]
    (h : ∀ draws : im05_experiment3PrefixSample M W k,
      p (im05_experiment3PrefixSampleRelabel e draws) ↔ q draws) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF (im05_experiment3PrefixSample M W k)) p =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF (im05_experiment3PrefixSample M W k)) q := by
  classical
  let relabel :
      im05_experiment3PrefixSample M W k ≃
        im05_experiment3PrefixSample M W k :=
    { toFun := im05_experiment3PrefixSampleRelabel e
      invFun := im05_experiment3PrefixSampleRelabel e.symm
      left_inv := by
        intro draws
        funext m slot
        simp [im05_experiment3PrefixSampleRelabel]
      right_inv := by
        intro draws
        funext m slot
        simp [im05_experiment3PrefixSampleRelabel] }
  exact EconCSLib.pmfProb_uniformPMF_eq_of_comp_equiv relabel p q h

/-! ## Closed deterministic and asymptotic seams -/

/-- Theorem A, stability part: men-proposing deferred acceptance finds a stable matching. -/
theorem paper_im05_theoremA_men_proposing_finds_stable
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) :
    im05_stable_matching val_m val_w (deferredAcceptance val_m val_w) :=
  da_produces_stable_matching val_m val_w

/--
Theorem A, men-optimality part: under strict preferences and all-pairs
acceptability, men-proposing deferred acceptance is weakly best for every man
among stable matchings.
-/
theorem paper_im05_theoremA_men_proposing_men_optimal
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w) :
    ∀ mu, im05_stable_matching val_m val_w mu →
      ∀ m, valM val_m m (mu.m_match m) ≤
        valM val_m m ((deferredAcceptance val_m val_w).m_match m) := by
  intro mu hstable m
  exact da_is_men_optimal_of_strict_preferences
    val_m val_w hstrictM hstrictW hacceptable mu hstable m

/--
Theorem A, women-pessimality part: on the equal-size strict all-acceptable
marriage domain, every woman weakly prefers her partner in any stable matching
to her partner in the men-proposing DA matching.
-/
theorem paper_im05_theoremA_men_proposing_women_pessimal
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (hcard : Fintype.card M = Fintype.card W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w) :
    ∀ mu, im05_stable_matching val_m val_w mu →
      ∀ w, valW val_w w ((deferredAcceptance val_m val_w).w_match w) ≤
        valW val_w w (mu.w_match w) := by
  exact da_is_women_pessimal_of_strict_preferences
    val_m val_w hcard hstrictM hstrictW hacceptable

/-- Women-proposing deferred acceptance also finds a stable matching. -/
theorem paper_im05_theoremA_women_proposing_finds_stable
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) :
    im05_stable_matching val_m val_w
      (im05_women_deferredAcceptance val_m val_w) := by
  exact womenDeferredAcceptance_stable val_m val_w

/--
Theorem A, women-proposing women-optimality part: under strict preferences and
all-pairs acceptability, women-proposing deferred acceptance is weakly best for
every woman among stable matchings.
-/
theorem paper_im05_theoremA_women_proposing_women_optimal
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w) :
    ∀ mu, im05_stable_matching val_m val_w mu →
      ∀ w, valW val_w w (mu.w_match w) ≤
        valW val_w w ((im05_women_deferredAcceptance val_m val_w).w_match w) := by
  exact womenDeferredAcceptance_is_women_optimal_of_strict_preferences
    val_m val_w hstrictM hstrictW hacceptable

/--
Theorem A, women-proposing men-pessimality part: on the equal-size strict
all-acceptable marriage domain, every man weakly prefers his partner in any
stable matching to his partner in the women-proposing DA matching.
-/
theorem paper_im05_theoremA_women_proposing_men_pessimal
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (hcard : Fintype.card M = Fintype.card W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w) :
    ∀ mu, im05_stable_matching val_m val_w mu →
      ∀ m, valM val_m m ((im05_women_deferredAcceptance val_m val_w).m_match m) ≤
        valM val_m m (mu.m_match m) := by
  exact womenDeferredAcceptance_is_men_pessimal_of_strict_preferences
    val_m val_w hcard hstrictM hstrictW hacceptable

/--
Theorem B uniqueness core: on the complete strict marriage domain, two
men-optimal stable matchings are equal. This is the formal version of the
source sentence deriving proposal-order independence from uniqueness of the
men-optimal stable matching.
-/
theorem paper_im05_theoremB_unique_men_optimal_stable_matching
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (hcard : Fintype.card M = Fintype.card W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w) :
    ∀ mu nu : Assignment M W,
      im05_stable_matching val_m val_w mu →
      im05_stable_matching val_m val_w nu →
      (∀ rho, im05_stable_matching val_m val_w rho →
        ∀ m, valM val_m m (rho.m_match m) ≤ valM val_m m (mu.m_match m)) →
      (∀ rho, im05_stable_matching val_m val_w rho →
        ∀ m, valM val_m m (rho.m_match m) ≤ valM val_m m (nu.m_match m)) →
      mu = nu := by
  intro mu nu hmuStable hnuStable hmuOptimal hnuOptimal
  exact men_optimal_stable_matching_unique_of_card_eq_all_pairs_acceptable
    val_m val_w hcard hstrictM hacceptable
    ⟨hmuStable, hmuOptimal⟩ ⟨hnuStable, hnuOptimal⟩

/--
Theorem B canonical-output core: any stable output satisfying the
men-optimality property is the same matching as the repository's
men-proposing deferred-acceptance output.
-/
theorem paper_im05_theoremB_any_men_optimal_output_eq_deferredAcceptance
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (hcard : Fintype.card M = Fintype.card W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w) :
    ∀ mu : Assignment M W,
      im05_stable_matching val_m val_w mu →
      (∀ rho, im05_stable_matching val_m val_w rho →
        ∀ m, valM val_m m (rho.m_match m) ≤ valM val_m m (mu.m_match m)) →
      mu = deferredAcceptance val_m val_w := by
  intro mu hmuStable hmuOptimal
  have hda : IsMenOptimalStable val_m val_w (deferredAcceptance val_m val_w) :=
    ⟨da_produces_stable_matching val_m val_w,
      da_is_men_optimal_of_strict_preferences
        val_m val_w hstrictM hstrictW hacceptable⟩
  exact men_optimal_stable_matching_unique_of_card_eq_all_pairs_acceptable
    val_m val_w hcard hstrictM hacceptable
    ⟨hmuStable, hmuOptimal⟩ hda

/--
Theorem C, complete-domain special case: on equal-size all-acceptable marriage
markets, every stable matching is complete, so the sets of single men and women
are the same across stable matchings (both empty).

The full optional-domain same-singles/rural-hospitals theorem is stronger and
remains a library target.
-/
theorem paper_im05_theoremC_same_singles_on_complete_domain
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (hcard : Fintype.card M = Fintype.card W)
    (hacceptable : AllPairsAcceptable val_m val_w) :
    ∀ mu nu : Assignment M W,
      im05_stable_matching val_m val_w mu →
      im05_stable_matching val_m val_w nu →
        im05_singleMen mu = im05_singleMen nu ∧
          im05_singleWomen mu = im05_singleWomen nu := by
  classical
  intro mu nu hmu hnu
  have hmuComplete :=
    stable_complete_of_card_eq_all_pairs_acceptable
      val_m val_w mu hcard hacceptable hmu
  have hnuComplete :=
    stable_complete_of_card_eq_all_pairs_acceptable
      val_m val_w nu hcard hacceptable hnu
  have hmuMenEmpty : im05_singleMen mu = ∅ := by
    ext m
    constructor
    · intro hm
      simp [im05_singleMen, im05_singleMan] at hm
      rcases hmuComplete.1 m with ⟨w, hw⟩
      rw [hm] at hw
      cases hw
    · intro hm
      simp at hm
  have hnuMenEmpty : im05_singleMen nu = ∅ := by
    ext m
    constructor
    · intro hm
      simp [im05_singleMen, im05_singleMan] at hm
      rcases hnuComplete.1 m with ⟨w, hw⟩
      rw [hm] at hw
      cases hw
    · intro hm
      simp at hm
  have hmuWomenEmpty : im05_singleWomen mu = ∅ := by
    ext w
    constructor
    · intro hwmem
      simp [im05_singleWomen, im05_singleWoman] at hwmem
      rcases hmuComplete.2 w with ⟨m, hm⟩
      rw [hwmem] at hm
      cases hm
    · intro hwmem
      simp at hwmem
  have hnuWomenEmpty : im05_singleWomen nu = ∅ := by
    ext w
    constructor
    · intro hwmem
      simp [im05_singleWomen, im05_singleWoman] at hwmem
      rcases hnuComplete.2 w with ⟨m, hm⟩
      rw [hwmem] at hm
      cases hm
    · intro hwmem
      simp at hwmem
  exact ⟨hmuMenEmpty.trans hnuMenEmpty.symm,
    hmuWomenEmpty.trans hnuWomenEmpty.symm⟩

/--
Theorem D: on the equal-size strict marriage domain, truth-telling is dominant
for the proposing side of the side-optimal deferred-acceptance mechanisms.

This is a thin IM05 wrapper around the already-verified Roth Theorem 5 route.
-/
theorem paper_im05_theoremD_optimal_side_truthful_on_strict_domain_of_card_eq
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W] :
    ∀ (val_m : M → W → ℝ) (val_w : W → M → ℝ),
      Fintype.card M = Fintype.card W →
        im05_strict_marriage_domain val_m val_w →
          (∀ (m : M) (report_m : W → ℝ),
            valM val_m m
                ((deferredAcceptance
                  (Function.update val_m m report_m) val_w).m_match m) ≤
              valM val_m m
                ((deferredAcceptance val_m val_w).m_match m)) ∧
          (∀ (w : W) (report_w : M → ℝ),
            valW val_w w
                ((im05_women_deferredAcceptance val_m
                  (Function.update val_w w report_w)).w_match w) ≤
              valW val_w w
                ((im05_women_deferredAcceptance val_m val_w).w_match w)) := by
  intro val_m val_w hcard hdomain
  rcases hdomain with ⟨hstrictM, hstrictW, hacceptable⟩
  have hrothDomain :
      Roth82StableMatching.paper_strict_marriage_domain val_m val_w :=
    ⟨hstrictM, hstrictW, hacceptable.1, hacceptable.2⟩
  have h :=
    Roth82StableMatching.paper_roth82_theorem5_optimal_side_truthful_on_strict_domain_of_card_eq
      val_m val_w hcard hrothDomain
  simpa [Roth82StableMatching.paper_matching_valM,
    Roth82StableMatching.paper_matching_valW,
    Roth82StableMatching.paper_women_deferredAcceptance,
    im05_women_deferredAcceptance] using h

/--
If a woman is on no man's list, she is single in every stable matching.  This is
the individual-rationality core used in the paper's Lemma 4.2.
-/
theorem im05_absent_woman_single_in_stable
    {M W : Type*}
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (mu : Assignment M W) (w : W)
    (hstable : im05_stable_matching val_m val_w mu)
    (habsent : im05_absentFromAllMen val_m w) :
    im05_singleWoman mu w := by
  rcases hstable with ⟨hMenIR, _hWomenIR, _hNoBlock⟩
  cases hw : mu.w_match w with
  | none => simpa [im05_singleWoman] using hw
  | some m =>
      have hm : mu.m_match m = some w := (mu.consistent_m m w).2 hw
      have hnonneg : 0 ≤ val_m m w := by
        simpa [valM, hm] using hMenIR m
      exact False.elim ((not_le_of_gt (habsent m)) hnonneg)

/--
Lemma 4.2 deterministic set-inclusion form: every at-least-as-popular woman who
appears on no men's list is in the set of at-least-as-popular women single in a
stable matching.
-/
theorem im05_absentPopular_subset_singlePopular_of_stable
    {M W : Type*} [Fintype W]
    (popularity : W → ℝ)
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (mu : Assignment M W) (g : W)
    (hstable : im05_stable_matching val_m val_w mu) :
    im05_absentPopularWomen popularity val_m g ⊆
      im05_singlePopularWomen (M := M) popularity mu g := by
  classical
  intro w hw
  simp [im05_absentPopularWomen, im05_singlePopularWomen] at hw ⊢
  exact ⟨hw.1, im05_absent_woman_single_in_stable
    val_m val_w mu w hstable hw.2⟩

/-- Every woman absent from all men's lists is single in a stable matching. -/
theorem im05_absentWomen_subset_singleWomen_of_stable
    {M W : Type*} [Fintype W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (mu : Assignment M W)
    (hstable : im05_stable_matching val_m val_w mu) :
    im05_absentWomen val_m ⊆ im05_singleWomen mu := by
  classical
  intro w hw
  simp [im05_absentWomen, im05_singleWomen] at hw ⊢
  exact im05_absent_woman_single_in_stable
    val_m val_w mu w hstable hw

/--
Lemma 4.2 cardinality form: `X_mu(g) >= Y_g`, under the Lean encoding of list
absence by negative value.
-/
theorem paper_im05_lemma4_2_absent_popular_card_le_single_popular
    {M W : Type*} [Fintype W]
    (popularity : W → ℝ)
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (mu : Assignment M W) (g : W)
    (hstable : im05_stable_matching val_m val_w mu) :
    (im05_absentPopularWomen popularity val_m g).card ≤
      (im05_singlePopularWomen (M := M) popularity mu g).card :=
  Finset.card_le_card
    (im05_absentPopular_subset_singlePopular_of_stable
      popularity val_m val_w mu g hstable)

/--
Lemma 4.2 random-variable form: if every sampled market is paired with a
stable matching, then the expected absent-popular count `Y_g` is at most the
expected single-popular count `X_mu(g)`.
-/
theorem paper_im05_lemma4_2_expected_absent_popular_le_expected_single_popular
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype W]
    (μ : PMF Ω)
    (popularity : Ω → W → ℝ)
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ)
    (mu : Ω → Assignment M W) (g : W)
    (hstable : ∀ ω, im05_stable_matching (val_m ω) (val_w ω) (mu ω)) :
    EconCSLib.pmfExp μ
        (fun ω =>
          ((im05_absentPopularWomen (popularity ω) (val_m ω) g).card : ℝ)) ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          ((im05_singlePopularWomen (M := M) (popularity ω) (mu ω) g).card : ℝ)) := by
  refine EconCSLib.pmfExp_le_pmfExp_of_forall_le μ _ _ ?_
  intro ω
  exact_mod_cast
    paper_im05_lemma4_2_absent_popular_card_le_single_popular
      (popularity ω) (val_m ω) (val_w ω) (mu ω) g (hstable ω)

/--
Lemma 4.2 reciprocal random-variable form: the same pointwise comparison gives
the reciprocal inequality used in Lemma 4.1.
-/
theorem paper_im05_lemma4_2_reciprocal_single_popular_le_absent_popular
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype W]
    (μ : PMF Ω)
    (popularity : Ω → W → ℝ)
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ)
    (mu : Ω → Assignment M W) (g : W)
    (hstable : ∀ ω, im05_stable_matching (val_m ω) (val_w ω) (mu ω)) :
    EconCSLib.pmfExpReciprocalSucc μ
        (fun ω =>
          (im05_singlePopularWomen (M := M) (popularity ω) (mu ω) g).card) ≤
      EconCSLib.pmfExpReciprocalSucc μ
        (fun ω =>
          (im05_absentPopularWomen (popularity ω) (val_m ω) g).card) := by
  refine EconCSLib.pmfExpReciprocalSucc_mono_of_forall_ge μ _ _ ?_
  intro ω
  exact paper_im05_lemma4_2_absent_popular_card_le_single_popular
    (popularity ω) (val_m ω) (val_w ω) (mu ω) g (hstable ω)

/--
The first `cut` women in the popularity order induced by `prob`, breaking ties
by the ambient linear order.  This ranks by `-prob`, so lower rank indices are
weakly more popular.
-/
noncomputable def im05_popularityTopPrefix
    {W : Type*} [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N : ℕ}
    (hcard : all.card = N) (cut : ℕ) : Finset W :=
  EconCSLib.FiniteRanking.lowerRankFinset all (fun u => -prob u) hcard cut

/--
The popularity interval from the first woman after the top `k` through the
woman with one-indexed rank `rank`, represented as `top rank \ top k`.
-/
noncomputable def im05_popularityRankTail
    {W : Type*} [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N : ℕ}
    (hcard : all.card = N) (rank k : ℕ) : Finset W :=
  im05_popularityTopPrefix all prob hcard rank \
    im05_popularityTopPrefix all prob hcard k

/-- A contiguous block of zero-based rank indices inside `Fin N`. -/
noncomputable def im05_rankIndexBlock
    (N start len : ℕ) (hbound : start + len ≤ N) : Finset (Fin N) :=
  (Finset.univ : Finset (Fin len)).image
    (fun idx =>
      ⟨start + idx.val,
        Nat.lt_of_lt_of_le
          (Nat.add_lt_add_left idx.isLt start)
          hbound⟩)

/-- The rank-index block has its prescribed length. -/
theorem im05_rankIndexBlock_card
    (N start len : ℕ) (hbound : start + len ≤ N) :
    (im05_rankIndexBlock N start len hbound).card = len := by
  classical
  unfold im05_rankIndexBlock
  rw [Finset.card_image_of_injective]
  · simp
  · intro a b hab
    apply Fin.ext
    exact Nat.add_left_cancel (congrArg Fin.val hab)

/-- Every index in a rank-index block lies weakly after the block start. -/
theorem im05_rankIndexBlock_start_le
    (N start len : ℕ) (hbound : start + len ≤ N)
    {idx : Fin N} (hidx : idx ∈ im05_rankIndexBlock N start len hbound) :
    start ≤ idx.val := by
  classical
  rcases Finset.mem_image.mp hidx with ⟨r, _hr, rfl⟩
  exact Nat.le_add_right start r.val

/-- Every index in a rank-index block lies strictly before `start + len`. -/
theorem im05_rankIndexBlock_lt_end
    (N start len : ℕ) (hbound : start + len ≤ N)
    {idx : Fin N} (hidx : idx ∈ im05_rankIndexBlock N start len hbound) :
    idx.val < start + len := by
  classical
  rcases Finset.mem_image.mp hidx with ⟨r, _hr, rfl⟩
  exact Nat.add_lt_add_left r.isLt start

/-- Real-valued cardinality form of `im05_rankIndexBlock_card`. -/
theorem im05_rankIndexBlock_card_real
    (N start len : ℕ) (hbound : start + len ≤ N) :
    ((im05_rankIndexBlock N start len hbound).card : ℝ) = (len : ℝ) := by
  rw [im05_rankIndexBlock_card]

/-- The one-indexed rank of every element in a rank block is at least `start + 1`. -/
theorem im05_rankIndexBlock_succ_start_le_rank
    (N start len : ℕ) (hbound : start + len ≤ N)
    {idx : Fin N} (hidx : idx ∈ im05_rankIndexBlock N start len hbound) :
    start + 1 ≤ idx.val + 1 := by
  exact Nat.succ_le_succ (im05_rankIndexBlock_start_le N start len hbound hidx)

/--
If `len >= g/2`, the rank-index block supplies the cardinality side condition
used by the corrected Lemma 4.3/4.1 tail wrappers.
-/
theorem im05_rankIndexBlock_card_ge_half
    (N start len : ℕ) (hbound : start + len ≤ N) (g : ℕ)
    (hlen : (g : ℝ) / 2 ≤ (len : ℝ)) :
    (g : ℝ) / 2 ≤
      ((im05_rankIndexBlock N start len hbound).card : ℝ) := by
  simpa [im05_rankIndexBlock_card_real] using hlen

/--
If the first one-indexed rank in the block is at least `g/2`, then every rank
in the block satisfies the Lemma 4.3 lower-tail condition.
-/
theorem im05_rankIndexBlock_half_le_rank
    (N start len : ℕ) (hbound : start + len ≤ N) (g : ℕ)
    (hstart : (g : ℝ) / 2 ≤ ((start + 1 : ℕ) : ℝ))
    {idx : Fin N} (hidx : idx ∈ im05_rankIndexBlock N start len hbound) :
    (g : ℝ) / 2 ≤ ((idx.val + 1 : ℕ) : ℝ) := by
  exact
    le_trans hstart
      (by
        exact_mod_cast
          im05_rankIndexBlock_succ_start_le_rank N start len hbound hidx)

/--
If the first one-indexed rank in the block is after `2*k`, then every rank in
the block satisfies the paper's `rank > 2*k` tail condition.
-/
theorem im05_rankIndexBlock_two_mul_k_lt_rank
    (N start len k : ℕ) (hbound : start + len ≤ N)
    (hstart : 2 * k < start + 1)
    {idx : Fin N} (hidx : idx ∈ im05_rankIndexBlock N start len hbound) :
    2 * k < idx.val + 1 :=
  lt_of_lt_of_le hstart
    (im05_rankIndexBlock_succ_start_le_rank N start len hbound hidx)

/--
Bundled side-condition helper for instantiating the corrected rank-index
Lemma 4.1 wrappers with a contiguous popularity-rank block.
-/
theorem im05_rankIndexBlock_tail_conditions
    (N start len k g : ℕ) (hbound : start + len ≤ N)
    (hlen : (g : ℝ) / 2 ≤ (len : ℝ))
    (hstart_half : (g : ℝ) / 2 ≤ ((start + 1 : ℕ) : ℝ))
    (hstart_two_k : 2 * k < start + 1) :
    (g : ℝ) / 2 ≤
        ((im05_rankIndexBlock N start len hbound).card : ℝ) ∧
      (∀ idx ∈ im05_rankIndexBlock N start len hbound,
        (g : ℝ) / 2 ≤ ((idx.val + 1 : ℕ) : ℝ)) ∧
      (∀ idx ∈ im05_rankIndexBlock N start len hbound,
        2 * k < idx.val + 1) := by
  refine
    ⟨im05_rankIndexBlock_card_ge_half N start len hbound g hlen, ?_, ?_⟩
  · intro idx hidx
    exact
      im05_rankIndexBlock_half_le_rank N start len hbound g hstart_half hidx
  · intro idx hidx
    exact
      im05_rankIndexBlock_two_mul_k_lt_rank N start len k hbound
        hstart_two_k hidx

/--
The woman at any rank index in a block ending before `cut` belongs to the
corresponding lower-rank prefix of the popularity ordering.
-/
theorem im05_rankIndexBlock_target_mem_lowerRankFinset_of_end_le
    {W : Type*} [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N : ℕ}
    (hall_card : all.card = N)
    (start len cut : ℕ) (hbound : start + len ≤ N)
    (hend : start + len ≤ cut)
    {idx : Fin N} (hidx : idx ∈ im05_rankIndexBlock N start len hbound) :
    EconCSLib.FiniteRanking.rankAgentByValue
        all (fun v => -prob v) hall_card idx ∈
      EconCSLib.FiniteRanking.lowerRankFinset
        all (fun v => -prob v) hall_card cut := by
  classical
  unfold EconCSLib.FiniteRanking.lowerRankFinset
  refine Finset.mem_image.mpr ⟨idx, ?_, rfl⟩
  rw [Finset.mem_filter]
  exact
    ⟨Finset.mem_univ idx,
      Nat.lt_of_lt_of_le
        (im05_rankIndexBlock_lt_end N start len hbound hidx) hend⟩

/--
Counting absent targets over a contiguous rank-index block is bounded by
counting absent women in the corresponding lower-rank prefix.  This is the
bridge from Lemma 4.2's `X_mu(g) >= Y_g`-style count to the corrected
tail-count wrappers.
-/
theorem im05_rankIndexBlock_filter_card_le_lowerRankFinset_filter_card
    {W : Type*} [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N : ℕ}
    (hall_card : all.card = N)
    (start len cut : ℕ) (hbound : start + len ≤ N)
    (hend : start + len ≤ cut)
    (event : W → Prop) [DecidablePred event] :
    ((im05_rankIndexBlock N start len hbound).filter fun idx =>
        event
          (EconCSLib.FiniteRanking.rankAgentByValue
            all (fun v => -prob v) hall_card idx)).card ≤
      ((EconCSLib.FiniteRanking.lowerRankFinset
          all (fun v => -prob v) hall_card cut).filter event).card := by
  classical
  let target : Fin N → W :=
    fun idx =>
      EconCSLib.FiniteRanking.rankAgentByValue
        all (fun v => -prob v) hall_card idx
  let block := im05_rankIndexBlock N start len hbound
  have himage_card :
      ((block.filter fun idx => event (target idx)).image target).card =
        (block.filter fun idx => event (target idx)).card := by
    exact
      Finset.card_image_of_injective
        (block.filter fun idx => event (target idx))
        (EconCSLib.FiniteRanking.rankAgentByValue_injective
          all (fun v => -prob v) hall_card)
  have hsubset :
      (block.filter fun idx => event (target idx)).image target ⊆
        (EconCSLib.FiniteRanking.lowerRankFinset
          all (fun v => -prob v) hall_card cut).filter event := by
    intro w hw
    rcases Finset.mem_image.mp hw with ⟨idx, hidx, rfl⟩
    rw [Finset.mem_filter] at hidx
    rw [Finset.mem_filter]
    exact
      ⟨by
        simpa [target, block] using
          im05_rankIndexBlock_target_mem_lowerRankFinset_of_end_le
            all prob hall_card start len cut hbound hend hidx.1,
       hidx.2⟩
  calc
    (block.filter fun idx => event (target idx)).card =
        ((block.filter fun idx => event (target idx)).image target).card := by
          rw [himage_card]
    _ ≤
        ((EconCSLib.FiniteRanking.lowerRankFinset
          all (fun v => -prob v) hall_card cut).filter event).card :=
          Finset.card_le_card hsubset

/--
The source Lemma 4.3 final summation block, represented as zero-based rank
indices `g / 2, ..., g - 1` inside `Fin N`.
-/
noncomputable def im05_sourceRankTailBlock
    (N g : ℕ) (hg_le_N : g ≤ N) : Finset (Fin N) :=
  im05_rankIndexBlock N (g / 2) (g - g / 2) (by omega)

/-- The source rank-tail block has cardinality `g - g / 2`. -/
theorem im05_sourceRankTailBlock_card
    (N g : ℕ) (hg_le_N : g ≤ N) :
    (im05_sourceRankTailBlock N g hg_le_N).card = g - g / 2 := by
  unfold im05_sourceRankTailBlock
  rw [im05_rankIndexBlock_card]

/--
The source rank-tail block discharges the three repeated corrected Lemma 4.3
side conditions when `g > 4k`.
-/
theorem im05_sourceRankTailBlock_tail_conditions
    (N g k : ℕ) (hg_le_N : g ≤ N) (hg_four_k : 4 * k < g) :
    (g : ℝ) / 2 ≤
        ((im05_sourceRankTailBlock N g hg_le_N).card : ℝ) ∧
      (∀ idx ∈ im05_sourceRankTailBlock N g hg_le_N,
        (g : ℝ) / 2 ≤ ((idx.val + 1 : ℕ) : ℝ)) ∧
      (∀ idx ∈ im05_sourceRankTailBlock N g hg_le_N,
        2 * k < idx.val + 1) := by
  have hlen_nat : g ≤ 2 * (g - g / 2) := by omega
  have hlen : (g : ℝ) / 2 ≤ ((g - g / 2 : ℕ) : ℝ) := by
    have hlen_real : (g : ℝ) ≤ 2 * ((g - g / 2 : ℕ) : ℝ) := by
      exact_mod_cast hlen_nat
    linarith
  have hstart_half_nat : g ≤ 2 * (g / 2 + 1) := by omega
  have hstart_half : (g : ℝ) / 2 ≤ ((g / 2 + 1 : ℕ) : ℝ) := by
    have hstart_real : (g : ℝ) ≤ 2 * ((g / 2 + 1 : ℕ) : ℝ) := by
      exact_mod_cast hstart_half_nat
    linarith
  have hstart_two_k : 2 * k < g / 2 + 1 := by omega
  simpa [im05_sourceRankTailBlock] using
    im05_rankIndexBlock_tail_conditions
      N (g / 2) (g - g / 2) k g (by omega) hlen
      hstart_half hstart_two_k

/--
If a one-indexed rank is past `2 * k`, then after deleting at most one earlier
name it is still past `2 * (k - 1)`.  This is the deterministic arithmetic
core of the source-tail induction route for the repaired Lemma 4.4 branch.
-/
theorem im05_two_mul_pred_lt_pred_of_two_mul_lt
    {k rank : ℕ} (hk : 0 < k) (hrank : 2 * k < rank) :
    2 * (k - 1) < rank - 1 := by
  omega

/--
Every source-tail rank remains in the corresponding `2 * (k - 1)` tail after
one possible rank drop.  The residual one-indexed rank is at least `idx.val`
when the original zero-based index is `idx.val`.
-/
theorem im05_sourceRankTailBlock_after_one_delete_tail_condition
    (N g k : ℕ) (hg_le_N : g ≤ N) (hg_four_k : 4 * k < g)
    (hk : 0 < k) {idx : Fin N}
    (hidx : idx ∈ im05_sourceRankTailBlock N g hg_le_N) :
    2 * (k - 1) < idx.val := by
  have hrank :
      2 * k < idx.val + 1 :=
    (im05_sourceRankTailBlock_tail_conditions N g k hg_le_N hg_four_k).2.2
      idx hidx
  exact im05_two_mul_pred_lt_pred_of_two_mul_lt hk hrank

/-- Rank indices strictly before `idx`. -/
noncomputable def im05_rankPriorIndexSet
    (N : ℕ) (idx : Fin N) : Finset (Fin N) :=
  (Finset.univ : Finset (Fin N)).filter fun r => r.val < idx.val

/-- The number of rank indices before `idx` is `idx.val`. -/
theorem im05_rankPriorIndexSet_card
    (N : ℕ) (idx : Fin N) :
    (im05_rankPriorIndexSet N idx).card = idx.val := by
  unfold im05_rankPriorIndexSet
  rw [Fin.card_filter_val_lt]
  exact Nat.min_eq_right (Nat.le_of_lt idx.isLt)

/--
Deleting one possible head from the prior-index set removes at most one prior
rank.
-/
theorem im05_rankPriorIndexSet_erase_card_ge_pred
    (N : ℕ) (idx head : Fin N) :
    idx.val - 1 ≤ ((im05_rankPriorIndexSet N idx).erase head).card := by
  classical
  by_cases hhead : head ∈ im05_rankPriorIndexSet N idx
  · rw [Finset.card_erase_of_mem hhead]
    rw [im05_rankPriorIndexSet_card]
  · have herase :
        (im05_rankPriorIndexSet N idx).erase head =
          im05_rankPriorIndexSet N idx := by
      exact Finset.erase_eq_of_notMem hhead
    rw [herase, im05_rankPriorIndexSet_card]
    omega

/--
For a source-tail rank, deleting any one head leaves at least `2 * (k - 1)`
earlier rank indices.  This is the cardinality side of the residual induction
condition.
-/
theorem im05_sourceRankTailBlock_priorIndexSet_erase_card_ge_two_mul_pred
    (N g k : ℕ) (hg_le_N : g ≤ N) (hg_four_k : 4 * k < g)
    (hk : 0 < k) {idx : Fin N}
    (hidx : idx ∈ im05_sourceRankTailBlock N g hg_le_N)
    (head : Fin N) :
    2 * (k - 1) ≤ ((im05_rankPriorIndexSet N idx).erase head).card := by
  have htail :
      2 * (k - 1) < idx.val :=
    im05_sourceRankTailBlock_after_one_delete_tail_condition
      N g k hg_le_N hg_four_k hk hidx
  have hpred :
      2 * (k - 1) ≤ idx.val - 1 := by
    omega
  exact le_trans hpred (im05_rankPriorIndexSet_erase_card_ge_pred N idx head)

/--
Earlier popularity ranks have weakly larger probability mass than later ranks
when the ranking is by `-prob`.
-/
theorem im05_rankAgentByValue_prob_antitone_of_lt
    {W : Type*} [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N : ℕ}
    (hall_card : all.card = N) {lo hi : Fin N}
    (hlo_hi : lo.val < hi.val) :
    prob
        (EconCSLib.FiniteRanking.rankAgentByValue
          all (fun u => -prob u) hall_card hi) ≤
      prob
        (EconCSLib.FiniteRanking.rankAgentByValue
          all (fun u => -prob u) hall_card lo) := by
  have hmono :=
    EconCSLib.FiniteRanking.rankValueByValue_mono
      all (fun u => -prob u) hall_card lo hi hlo_hi
  rw [EconCSLib.FiniteRanking.rankValueByValue_eq_value
    all (fun u => -prob u) hall_card lo] at hmono
  rw [EconCSLib.FiniteRanking.rankValueByValue_eq_value
    all (fun u => -prob u) hall_card hi] at hmono
  linarith

/--
Available names whose base probability is at least the target probability.
This packages the residual tail-depth condition used by the repaired Lemma 4.4
induction route.
-/
noncomputable def im05_highWeightAvailableSet
    {W : Type*} [DecidableEq W]
    (all : Finset W) (prob : W → ℝ)
    (forbidden : Finset W) (target : W) : Finset W :=
  all.filter fun u => u ∉ forbidden ∧ u ≠ target ∧ prob target ≤ prob u

/-- Tail-depth predicate for a target after deleting a forbidden set. -/
def im05_tailDepth
    {W : Type*} [DecidableEq W]
    (all : Finset W) (prob : W → ℝ)
    (forbidden : Finset W) (target : W) (k : ℕ) : Prop :=
  2 * k ≤ (im05_highWeightAvailableSet all prob forbidden target).card

/-- Erasing one element from a finite set removes at most one element. -/
theorem im05_finset_card_pred_le_erase_card
    {α : Type*} [DecidableEq α] (s : Finset α) (a : α) :
    s.card - 1 ≤ (s.erase a).card := by
  classical
  by_cases ha : a ∈ s
  · rw [Finset.card_erase_of_mem ha]
  · have herase : s.erase a = s := Finset.erase_eq_of_notMem ha
    rw [herase]
    omega

/--
If a target has tail depth `k + 1`, then after inserting one additional
forbidden head it still has tail depth `k`.
-/
theorem im05_tailDepth_after_insert_of_tailDepth_succ
    {W : Type*} [DecidableEq W]
    (all : Finset W) (prob : W → ℝ)
    (forbidden : Finset W) (target : W) {k : ℕ}
    (hdepth : im05_tailDepth all prob forbidden target (k + 1))
    (head : {w // w ∉ forbidden}) :
    im05_tailDepth all prob (insert head.1 forbidden) target k := by
  classical
  let s := im05_highWeightAvailableSet all prob forbidden target
  have hpred : 2 * k ≤ s.card - 1 := by
    unfold im05_tailDepth at hdepth
    dsimp [s]
    omega
  have herase_card : s.card - 1 ≤ (s.erase head.1).card :=
    im05_finset_card_pred_le_erase_card s head.1
  have hsubset :
      s.erase head.1 ⊆
        im05_highWeightAvailableSet all prob
          (insert head.1 forbidden) target := by
    intro u hu
    rw [Finset.mem_erase] at hu
    rcases hu with ⟨hu_ne_head, hu_s⟩
    have hu_s' :
        u ∈ im05_highWeightAvailableSet all prob forbidden target := by
      simpa [s] using hu_s
    rw [im05_highWeightAvailableSet, Finset.mem_filter] at hu_s'
    rcases hu_s' with ⟨hu_all, hu_not_forbidden, hu_ne_target, hprob⟩
    rw [im05_highWeightAvailableSet, Finset.mem_filter]
    refine ⟨hu_all, ?_, hu_ne_target, hprob⟩
    rw [Finset.mem_insert]
    intro hmem
    rcases hmem with h_eq | h_forbidden
    · exact hu_ne_head h_eq
    · exact hu_not_forbidden h_forbidden
  unfold im05_tailDepth
  exact le_trans (le_trans hpred herase_card) (Finset.card_le_card hsubset)

/--
The earlier rank indices before `idx`, after deleting one possible first head,
inject into the available names whose probability is at least that of `idx`.
-/
theorem im05_rankPriorIndexSet_erase_image_subset_highWeightAvailableSet
    {W : Type*} [Fintype W] [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N : ℕ}
    (hall_card : all.card = N) (idx head : Fin N) :
    ((im05_rankPriorIndexSet N idx).erase head).image
        (EconCSLib.FiniteRanking.rankAgentByValue
          all (fun u => -prob u) hall_card) ⊆
      im05_highWeightAvailableSet all prob
        ({EconCSLib.FiniteRanking.rankAgentByValue
            all (fun u => -prob u) hall_card head} : Finset W)
        (EconCSLib.FiniteRanking.rankAgentByValue
          all (fun u => -prob u) hall_card idx) := by
  classical
  intro w hw
  rcases Finset.mem_image.mp hw with ⟨r, hr, rfl⟩
  rw [Finset.mem_erase] at hr
  rcases hr with ⟨hr_ne_head, hr_prior⟩
  have hr_lt_idx : r.val < idx.val := by
    simpa [im05_rankPriorIndexSet] using hr_prior
  have hinj :=
    EconCSLib.FiniteRanking.rankAgentByValue_injective
      all (fun u => -prob u) hall_card
  rw [im05_highWeightAvailableSet, Finset.mem_filter]
  refine ⟨EconCSLib.FiniteRanking.rankAgentByValue_mem
      all (fun u => -prob u) hall_card r, ?_, ?_, ?_⟩
  · rw [Finset.mem_singleton]
    intro hhead
    exact hr_ne_head (hinj hhead)
  · intro htarget
    have hidx : r = idx := hinj htarget
    have hlt : idx.val < idx.val := by simpa [hidx] using hr_lt_idx
    exact (Nat.lt_irrefl idx.val) hlt
  · exact
      im05_rankAgentByValue_prob_antitone_of_lt
        all prob hall_card hr_lt_idx

/--
The earlier rank indices before `idx` inject into the names whose probability
is at least that of `idx`, with no first head deleted.
-/
theorem im05_rankPriorIndexSet_image_subset_highWeightAvailableSet_empty
    {W : Type*} [Fintype W] [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N : ℕ}
    (hall_card : all.card = N) (idx : Fin N) :
    (im05_rankPriorIndexSet N idx).image
        (EconCSLib.FiniteRanking.rankAgentByValue
          all (fun u => -prob u) hall_card) ⊆
      im05_highWeightAvailableSet all prob (∅ : Finset W)
        (EconCSLib.FiniteRanking.rankAgentByValue
          all (fun u => -prob u) hall_card idx) := by
  classical
  intro w hw
  rcases Finset.mem_image.mp hw with ⟨r, hr_prior, rfl⟩
  have hr_lt_idx : r.val < idx.val := by
    simpa [im05_rankPriorIndexSet] using hr_prior
  have hinj :=
    EconCSLib.FiniteRanking.rankAgentByValue_injective
      all (fun u => -prob u) hall_card
  rw [im05_highWeightAvailableSet, Finset.mem_filter]
  refine ⟨EconCSLib.FiniteRanking.rankAgentByValue_mem
      all (fun u => -prob u) hall_card r, ?_, ?_, ?_⟩
  · simp
  · intro htarget
    have hidx : r = idx := hinj htarget
    have hlt : idx.val < idx.val := by simpa [hidx] using hr_lt_idx
    exact (Nat.lt_irrefl idx.val) hlt
  · exact
      im05_rankAgentByValue_prob_antitone_of_lt
        all prob hall_card hr_lt_idx

/-- Every source-tail rank has tail depth `k` at the empty forbidden set. -/
theorem im05_sourceRankTailBlock_tailDepth
    {W : Type*} [Fintype W] [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N g k : ℕ}
    (hall_card : all.card = N)
    (hg_le_N : g ≤ N) (hg_four_k : 4 * k < g)
    {idx : Fin N}
    (hidx : idx ∈ im05_sourceRankTailBlock N g hg_le_N) :
    im05_tailDepth all prob (∅ : Finset W)
      (EconCSLib.FiniteRanking.rankAgentByValue
        all (fun u => -prob u) hall_card idx)
      k := by
  classical
  let ranker : Fin N → W :=
    EconCSLib.FiniteRanking.rankAgentByValue
      all (fun u => -prob u) hall_card
  let prior := im05_rankPriorIndexSet N idx
  have hrank :
      2 * k < idx.val + 1 :=
    (im05_sourceRankTailBlock_tail_conditions N g k hg_le_N hg_four_k).2.2
      idx hidx
  have hprior_card : 2 * k ≤ prior.card := by
    rw [show prior.card = idx.val by
      simpa [prior] using im05_rankPriorIndexSet_card N idx]
    omega
  have himage_card :
      (prior.image ranker).card = prior.card := by
    exact
      Finset.card_image_of_injective prior
        (EconCSLib.FiniteRanking.rankAgentByValue_injective
          all (fun u => -prob u) hall_card)
  have hsubset :
      prior.image ranker ⊆
        im05_highWeightAvailableSet all prob (∅ : Finset W) (ranker idx) := by
    simpa [ranker, prior] using
      im05_rankPriorIndexSet_image_subset_highWeightAvailableSet_empty
        all prob hall_card idx
  unfold im05_tailDepth
  calc
    2 * k ≤ prior.card := hprior_card
    _ = (prior.image ranker).card := by rw [himage_card]
    _ ≤
        (im05_highWeightAvailableSet all prob
          (∅ : Finset W) (ranker idx)).card :=
          Finset.card_le_card hsubset

/--
For a source-tail target, deleting any one first head leaves at least
`2 * (k - 1)` available weakly-heavier names.  This is the deterministic
source-tail side condition needed by the residual induction hypothesis.
-/
theorem im05_sourceRankTailBlock_tailDepth_after_one_delete
    {W : Type*} [Fintype W] [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N g k : ℕ}
    (hall_card : all.card = N)
    (hg_le_N : g ≤ N) (hg_four_k : 4 * k < g)
    (hk : 0 < k) {idx : Fin N}
    (hidx : idx ∈ im05_sourceRankTailBlock N g hg_le_N)
    (head : Fin N) :
    im05_tailDepth all prob
      ({EconCSLib.FiniteRanking.rankAgentByValue
          all (fun u => -prob u) hall_card head} : Finset W)
      (EconCSLib.FiniteRanking.rankAgentByValue
        all (fun u => -prob u) hall_card idx)
      (k - 1) := by
  classical
  let ranker : Fin N → W :=
    EconCSLib.FiniteRanking.rankAgentByValue
      all (fun u => -prob u) hall_card
  let priorAfterHead := (im05_rankPriorIndexSet N idx).erase head
  have hprior_card :
      2 * (k - 1) ≤ priorAfterHead.card := by
    simpa [priorAfterHead] using
      im05_sourceRankTailBlock_priorIndexSet_erase_card_ge_two_mul_pred
        N g k hg_le_N hg_four_k hk hidx head
  have himage_card :
      (priorAfterHead.image ranker).card = priorAfterHead.card := by
    exact
      Finset.card_image_of_injective priorAfterHead
        (EconCSLib.FiniteRanking.rankAgentByValue_injective
          all (fun u => -prob u) hall_card)
  have hsubset :
      priorAfterHead.image ranker ⊆
        im05_highWeightAvailableSet all prob
          ({ranker head} : Finset W) (ranker idx) := by
    simpa [ranker, priorAfterHead] using
      im05_rankPriorIndexSet_erase_image_subset_highWeightAvailableSet
        all prob hall_card idx head
  unfold im05_tailDepth
  calc
    2 * (k - 1) ≤ priorAfterHead.card := hprior_card
    _ = (priorAfterHead.image ranker).card := by rw [himage_card]
    _ ≤
        (im05_highWeightAvailableSet all prob
          ({ranker head} : Finset W) (ranker idx)).card :=
          Finset.card_le_card hsubset

/--
Name-level version of `im05_sourceRankTailBlock_tailDepth_after_one_delete`:
the deleted first head is an available name rather than a rank index.
-/
theorem im05_sourceRankTailBlock_tailDepth_after_one_delete_name
    {W : Type*} [Fintype W] [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N g k : ℕ}
    (hall_card : all.card = N)
    (hg_le_N : g ≤ N) (hg_four_k : 4 * k < g)
    (hk : 0 < k) {idx : Fin N}
    (hidx : idx ∈ im05_sourceRankTailBlock N g hg_le_N)
    {head : W} (hhead : head ∈ all) :
    im05_tailDepth all prob ({head} : Finset W)
      (EconCSLib.FiniteRanking.rankAgentByValue
        all (fun u => -prob u) hall_card idx)
      (k - 1) := by
  classical
  have hhead_image :
      head ∈ Finset.image
        (EconCSLib.FiniteRanking.rankAgentByValue
          all (fun u => -prob u) hall_card)
        (Finset.univ : Finset (Fin N)) := by
    rw [EconCSLib.FiniteRanking.image_rankAgentByValue_univ]
    exact hhead
  rcases Finset.mem_image.mp hhead_image with ⟨headIdx, _hmem, hhead_eq⟩
  simpa [hhead_eq] using
    im05_sourceRankTailBlock_tailDepth_after_one_delete
      all prob hall_card hg_le_N hg_four_k hk hidx headIdx

/--
Tail-depth induction step for pairwise omission negative correlation.  Residual
NC may be supplied from any theorem whose hypotheses are the two residual
tail-depth predicates; the only remaining algebra is the compact first-step
averaging inequality.
-/
theorem im05_omissionPairNegativeCorrelation_succ_from_tailDepth_first_step
    {W : Type*} [Fintype W] [DecidableEq W]
    (all : Finset W)
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card W)
    (i j : W)
    (htail_i : ∀ head : {w // w ∉ forbidden},
      head.1 ≠ i → head.1 ≠ j →
      im05_tailDepth all weight (insert head.1 forbidden) i k)
    (htail_j : ∀ head : {w // w ∉ forbidden},
      head.1 ≠ i → head.1 ≠ j →
      im05_tailDepth all weight (insert head.1 forbidden) j k)
    (hresidual_neg : ∀ head : {w // w ∉ forbidden},
      ∀ _hhead_i : head.1 ≠ i, ∀ _hhead_j : head.1 ≠ j,
      im05_tailDepth all weight (insert head.1 forbidden) i k →
      im05_tailDepth all weight (insert head.1 forbidden) j k →
      im05_omissionPairNegativeCorrelation
        weight hweight_nonneg havailable
        (k := k)
        (insert head.1 forbidden)
        (by
          rw [Finset.card_insert_of_notMem head.2]
          omega)
        i j)
    (hfirst_step :
      im05_firstStepOmitPairProductSum
          weight hweight_nonneg havailable forbidden hbudget i j ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j) :
    im05_omissionPairNegativeCorrelation
      (k := k + 1)
      weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  unfold im05_omissionPairNegativeCorrelation
  exact
    im05_finiteWithoutReplacementPMF_listPrefixOmits_pair_succ_negative_correlation_from_compact_first_step
      weight hweight_nonneg havailable forbidden hbudget i j
      (by
        intro head hhead_i hhead_j
        simpa [im05_omissionPairNegativeCorrelation] using
          hresidual_neg head hhead_i hhead_j
            (htail_i head hhead_i hhead_j)
            (htail_j head hhead_i hhead_j))
      hfirst_step

/--
Conditional tail-depth induction theorem.  If the compact first-step averaging
inequality holds at every residual scale and state for distinct targets with
tail depth, then the corresponding pairwise omission negative correlation
holds at every length.
-/
theorem im05_omissionPairNegativeCorrelation_of_tailDepth_firstStep_family
    {W : Type*} [Fintype W] [DecidableEq W]
    (all : Finset W)
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (hfirst_step : ∀ {r : ℕ} (forbidden : Finset W)
      (hbudget : forbidden.card + (r + 1) ≤ Fintype.card W)
      (i j : W), i ≠ j →
      im05_tailDepth all weight forbidden i (r + 1) →
      im05_tailDepth all weight forbidden j (r + 1) →
      im05_firstStepOmitPairProductSum
          weight hweight_nonneg havailable forbidden hbudget i j ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + k ≤ Fintype.card W)
    {i j : W} (hij : i ≠ j)
    (hdepth_i : im05_tailDepth all weight forbidden i k)
    (hdepth_j : im05_tailDepth all weight forbidden j k) :
    im05_omissionPairNegativeCorrelation
      (k := k) weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  induction k generalizing forbidden i j with
  | zero =>
      exact
        im05_omissionPairNegativeCorrelation_zero
          weight hweight_nonneg havailable forbidden hbudget i j
  | succ k ih =>
      exact
        im05_omissionPairNegativeCorrelation_succ_from_tailDepth_first_step
          all weight hweight_nonneg havailable forbidden hbudget i j
          (by
            intro head _hhead_i _hhead_j
            exact
              im05_tailDepth_after_insert_of_tailDepth_succ
                all weight forbidden i hdepth_i head)
          (by
            intro head _hhead_i _hhead_j
            exact
              im05_tailDepth_after_insert_of_tailDepth_succ
                all weight forbidden j hdepth_j head)
          (by
            intro head _hhead_i _hhead_j htail_i htail_j
            exact
              ih (insert head.1 forbidden)
                (by
                  rw [Finset.card_insert_of_notMem head.2]
                  omega)
                hij htail_i htail_j)
          (hfirst_step forbidden hbudget i j hij hdepth_i hdepth_j)

/--
Source-tail one-step reduction for the repaired Lemma 4.4 route.  For two
indices in the source block, the parent `(k + 1)`-draw pairwise-NC claim
follows from residual `k`-draw NC under the residual tail-depth predicate and
the compact first-step averaging inequality.
-/
theorem
    im05_sourceRankTailBlock_omissionPairNegativeCorrelation_succ_from_tailDepth_first_step
    {W : Type*} [Fintype W] [LinearOrder W] [DecidableEq W]
    (all : Finset W) (weight : W → ℝ) {N g k : ℕ}
    (hall_card : all.card = N) (hall_mem : ∀ w : W, w ∈ all)
    (hg_le_N : g ≤ N) (hg_four_succ : 4 * (k + 1) < g)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (hbudget : (∅ : Finset W).card + (k + 1) ≤ Fintype.card W)
    {idx jdx : Fin N}
    (hidx : idx ∈ im05_sourceRankTailBlock N g hg_le_N)
    (hjdx : jdx ∈ im05_sourceRankTailBlock N g hg_le_N)
    (hresidual_neg : ∀ head : {w // w ∉ (∅ : Finset W)},
      head.1 ≠
          EconCSLib.FiniteRanking.rankAgentByValue
            all (fun u => -weight u) hall_card idx →
      head.1 ≠
          EconCSLib.FiniteRanking.rankAgentByValue
            all (fun u => -weight u) hall_card jdx →
      im05_tailDepth all weight (insert head.1 (∅ : Finset W))
          (EconCSLib.FiniteRanking.rankAgentByValue
            all (fun u => -weight u) hall_card idx)
          k →
      im05_tailDepth all weight (insert head.1 (∅ : Finset W))
          (EconCSLib.FiniteRanking.rankAgentByValue
            all (fun u => -weight u) hall_card jdx)
          k →
      im05_omissionPairNegativeCorrelation
        (k := k) weight hweight_nonneg havailable
        (insert head.1 (∅ : Finset W))
        (by
          rw [Finset.card_insert_of_notMem head.2]
          omega)
        (EconCSLib.FiniteRanking.rankAgentByValue
          all (fun u => -weight u) hall_card idx)
        (EconCSLib.FiniteRanking.rankAgentByValue
          all (fun u => -weight u) hall_card jdx))
    (hfirst_step :
      im05_firstStepOmitPairProductSum
          weight hweight_nonneg havailable (∅ : Finset W) hbudget
          (EconCSLib.FiniteRanking.rankAgentByValue
            all (fun u => -weight u) hall_card idx)
          (EconCSLib.FiniteRanking.rankAgentByValue
            all (fun u => -weight u) hall_card jdx) ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable (∅ : Finset W) hbudget
            (EconCSLib.FiniteRanking.rankAgentByValue
              all (fun u => -weight u) hall_card idx) *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable (∅ : Finset W) hbudget
            (EconCSLib.FiniteRanking.rankAgentByValue
              all (fun u => -weight u) hall_card jdx)) :
    im05_omissionPairNegativeCorrelation
      (k := k + 1) weight hweight_nonneg havailable
      (∅ : Finset W) hbudget
      (EconCSLib.FiniteRanking.rankAgentByValue
        all (fun u => -weight u) hall_card idx)
      (EconCSLib.FiniteRanking.rankAgentByValue
        all (fun u => -weight u) hall_card jdx) := by
  classical
  exact
    im05_omissionPairNegativeCorrelation_succ_from_tailDepth_first_step
      all weight hweight_nonneg havailable (∅ : Finset W) hbudget
      (EconCSLib.FiniteRanking.rankAgentByValue
        all (fun u => -weight u) hall_card idx)
      (EconCSLib.FiniteRanking.rankAgentByValue
        all (fun u => -weight u) hall_card jdx)
      (by
        intro head hhead_idx hhead_jdx
        simpa using
          im05_sourceRankTailBlock_tailDepth_after_one_delete_name
            all weight hall_card hg_le_N hg_four_succ (Nat.succ_pos k)
            hidx (hall_mem head.1))
      (by
        intro head hhead_idx hhead_jdx
        simpa using
          im05_sourceRankTailBlock_tailDepth_after_one_delete_name
            all weight hall_card hg_le_N hg_four_succ (Nat.succ_pos k)
            hjdx (hall_mem head.1))
      hresidual_neg hfirst_step

/--
Source-tail pairwise omission NC from the compact first-step inequality family.
This packages the complete induction and the source-rank tail-depth facts; the
only remaining stochastic obligation is the first-step averaging theorem.
-/
theorem im05_sourceRankTailBlock_omissionPairNegativeCorrelation_from_firstStep_family
    {W : Type*} [Fintype W] [LinearOrder W] [DecidableEq W]
    (all : Finset W) (weight : W → ℝ) {N g k : ℕ}
    (hall_card : all.card = N)
    (hg_le_N : g ≤ N) (hg_four_k : 4 * k < g)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (hfirst_step : ∀ {r : ℕ} (forbidden : Finset W)
      (hbudget : forbidden.card + (r + 1) ≤ Fintype.card W)
      (i j : W), i ≠ j →
      im05_tailDepth all weight forbidden i (r + 1) →
      im05_tailDepth all weight forbidden j (r + 1) →
      im05_firstStepOmitPairProductSum
          weight hweight_nonneg havailable forbidden hbudget i j ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j)
    (hbudget : (∅ : Finset W).card + k ≤ Fintype.card W)
    {idx jdx : Fin N}
    (hidx : idx ∈ im05_sourceRankTailBlock N g hg_le_N)
    (hjdx : jdx ∈ im05_sourceRankTailBlock N g hg_le_N)
    (hij : idx ≠ jdx) :
    im05_omissionPairNegativeCorrelation
      (k := k) weight hweight_nonneg havailable (∅ : Finset W) hbudget
      (EconCSLib.FiniteRanking.rankAgentByValue
        all (fun u => -weight u) hall_card idx)
      (EconCSLib.FiniteRanking.rankAgentByValue
        all (fun u => -weight u) hall_card jdx) := by
  classical
  let ranker : Fin N → W :=
    EconCSLib.FiniteRanking.rankAgentByValue
      all (fun u => -weight u) hall_card
  have htarget_ne : ranker idx ≠ ranker jdx := by
    intro htarget
    exact hij
      (EconCSLib.FiniteRanking.rankAgentByValue_injective
        all (fun u => -weight u) hall_card htarget)
  exact
    im05_omissionPairNegativeCorrelation_of_tailDepth_firstStep_family
      all weight hweight_nonneg havailable hfirst_step
      (∅ : Finset W) hbudget htarget_ne
      (by
        simpa [ranker] using
          im05_sourceRankTailBlock_tailDepth
            all weight hall_card hg_le_N hg_four_k hidx)
      (by
        simpa [ranker] using
          im05_sourceRankTailBlock_tailDepth
            all weight hall_card hg_le_N hg_four_k hjdx)

/--
Variant of `im05_omissionPairNegativeCorrelation_of_tailDepth_firstStep_family`
that uses the already-closed one-draw base case.  The remaining first-step
averaging family is only needed when the residual draw length is positive.
-/
theorem im05_omissionPairNegativeCorrelation_of_tailDepth_positive_firstStep_family
    {W : Type*} [Fintype W] [DecidableEq W]
    (all : Finset W)
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (hfirst_step : ∀ {r : ℕ}, 0 < r → ∀ (forbidden : Finset W)
      (hbudget : forbidden.card + (r + 1) ≤ Fintype.card W)
      (i j : W), i ≠ j →
      im05_tailDepth all weight forbidden i (r + 1) →
      im05_tailDepth all weight forbidden j (r + 1) →
      im05_firstStepOmitPairProductSum
          weight hweight_nonneg havailable forbidden hbudget i j ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + k ≤ Fintype.card W)
    {i j : W} (hij : i ≠ j)
    (hdepth_i : im05_tailDepth all weight forbidden i k)
    (hdepth_j : im05_tailDepth all weight forbidden j k) :
    im05_omissionPairNegativeCorrelation
      (k := k) weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  induction k generalizing forbidden i j with
  | zero =>
      exact
        im05_omissionPairNegativeCorrelation_zero
          weight hweight_nonneg havailable forbidden hbudget i j
  | succ k ih =>
      cases k with
      | zero =>
          exact
            im05_omissionPairNegativeCorrelation_one_of_ne
              weight hweight_nonneg havailable forbidden hbudget hij
      | succ r =>
          exact
            im05_omissionPairNegativeCorrelation_succ_from_tailDepth_first_step
              all weight hweight_nonneg havailable forbidden hbudget i j
              (by
                intro head _hhead_i _hhead_j
                exact
                  im05_tailDepth_after_insert_of_tailDepth_succ
                    all weight forbidden i hdepth_i head)
              (by
                intro head _hhead_i _hhead_j
                exact
                  im05_tailDepth_after_insert_of_tailDepth_succ
                    all weight forbidden j hdepth_j head)
              (by
                intro head _hhead_i _hhead_j htail_i htail_j
                exact
                  ih (insert head.1 forbidden)
                    (by
                      rw [Finset.card_insert_of_notMem head.2]
                      omega)
                    hij htail_i htail_j)
              (hfirst_step (Nat.succ_pos r) forbidden hbudget i j hij
                hdepth_i hdepth_j)

