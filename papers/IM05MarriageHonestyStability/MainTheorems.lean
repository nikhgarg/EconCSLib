    daStateAfterSteps_eq_daStateAfterStepsFrom_initial] using hsteps

theorem im05_algorithm41DivorcedState_currentMatchOrder_of_allPairsAcceptable
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
