/-- The initial DA husband output by Algorithm 4.1 is a stable husband of `g`. -/
theorem im05_algorithm41InitialHusband_mem_stableHusbands
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) {m : M}
