/--
A source-shaped step preserves existence of a best proposer so far for a fixed
target woman.  If the step accepts a proposal to the target, the accepted man
becomes the new best; if it rejects that proposal, the previous best remains.
-/
theorem im05_algorithm41SourceStep_preserves_target_bestProposedSoFar
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hbest_exists :
      ∃ best : M, im05_algorithm41BestProposedSoFar val_w s target best) :
    ∃ best : M,
      im05_algorithm41BestProposedSoFar val_w
        (im05_algorithm41SourceStep val_m val_w s) target best := by
  classical
  by_cases hactive : ∃ m, IsActiveMan val_m s m
  · by_cases htarget : daStepChosenWoman val_m s hactive = target
    · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
      · refine ⟨daStepChosenMan val_m s hactive, ?_⟩
        have hhistory :
            im05_algorithm41HistoryAccepts val_w s target
              (daStepChosenMan val_m s hactive) := by
          simpa [im05_algorithm41SourceStepAccepts, htarget] using hacc
        simpa [im05_algorithm41SourceStep, hactive, hacc, htarget,
          im05_algorithm41BestProposedSoFar, im05_algorithm41HasProposedTo]
          using
            im05_algorithm41BestProposedSoFar_after_history_accept
              val_w s target (daStepChosenMan val_m s hactive) hhistory
      · rcases hbest_exists with ⟨best, hbest⟩
        refine ⟨best, ?_⟩
        have hreject :
            ¬ im05_algorithm41HistoryAccepts val_w s target
              (daStepChosenMan val_m s hactive) := by
          simpa [im05_algorithm41SourceStepAccepts, htarget] using hacc
        simpa [im05_algorithm41SourceStep, hactive, hacc, htarget,
          im05_algorithm41BestProposedSoFar, im05_algorithm41HasProposedTo]
          using
            im05_algorithm41BestProposedSoFar_after_target_reject
              val_w s target best (daStepChosenMan val_m s hactive)
              hbest hreject
    · rcases hbest_exists with ⟨best, hbest⟩
      refine ⟨best, ?_⟩
      by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
      · simpa [im05_algorithm41SourceStep, hactive, hacc,
          im05_algorithm41BestProposedSoFar, im05_algorithm41HasProposedTo]
          using
            im05_algorithm41BestProposedSoFar_removeProposal_of_ne
              val_w s (b := daStepChosenMan val_m s hactive)
              (w := daStepChosenWoman val_m s hactive)
              (target := target) htarget hbest
      · simpa [im05_algorithm41SourceStep, hactive, hacc,
          im05_algorithm41BestProposedSoFar, im05_algorithm41HasProposedTo]
          using
            im05_algorithm41BestProposedSoFar_removeProposal_of_ne
              val_w s (b := daStepChosenMan val_m s hactive)
              (w := daStepChosenWoman val_m s hactive)
              (target := target) htarget hbest
  · simpa [im05_algorithm41SourceStep, hactive] using hbest_exists

/--
A source-shaped step preserves the invariant that, whenever the target woman is
matched, her current holder is the best proposer seen so far.
-/
theorem im05_algorithm41SourceStep_preserves_target_match_bestProposedSoFar
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hcurrent_best :
      ∀ m : M, s.w_match target = some m →
        im05_algorithm41BestProposedSoFar val_w s target m) :
    ∀ m : M,
      (im05_algorithm41SourceStep val_m val_w s).w_match target = some m →
        im05_algorithm41BestProposedSoFar val_w
          (im05_algorithm41SourceStep val_m val_w s) target m := by
  classical
  by_cases hactive : ∃ m, IsActiveMan val_m s m
  · by_cases htarget : daStepChosenWoman val_m s hactive = target
    · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
      · intro m hm
        have hm_eq : m = daStepChosenMan val_m s hactive := by
          simpa [im05_algorithm41SourceStep, hactive, hacc, htarget] using hm.symm
        subst m
        have hhistory :
            im05_algorithm41HistoryAccepts val_w s target
              (daStepChosenMan val_m s hactive) := by
          simpa [im05_algorithm41SourceStepAccepts, htarget] using hacc
        simpa [im05_algorithm41SourceStep, hactive, hacc, htarget,
          im05_algorithm41BestProposedSoFar, im05_algorithm41HasProposedTo]
          using
            im05_algorithm41BestProposedSoFar_after_history_accept
              val_w s target (daStepChosenMan val_m s hactive) hhistory
      · intro m hm
        have hold : s.w_match target = some m := by
          simpa [im05_algorithm41SourceStep, hactive, hacc, htarget] using hm
        have hbest := hcurrent_best m hold
        have hreject :
            ¬ im05_algorithm41HistoryAccepts val_w s target
              (daStepChosenMan val_m s hactive) := by
          simpa [im05_algorithm41SourceStepAccepts, htarget] using hacc
        simpa [im05_algorithm41SourceStep, hactive, hacc, htarget,
          im05_algorithm41BestProposedSoFar, im05_algorithm41HasProposedTo]
          using
            im05_algorithm41BestProposedSoFar_after_target_reject
              val_w s target m (daStepChosenMan val_m s hactive)
              hbest hreject
    · intro m hm
      have htarget' : target ≠ daStepChosenWoman val_m s hactive := by
        intro h
        exact htarget h.symm
      by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
      · have hold : s.w_match target = some m := by
          simpa [im05_algorithm41SourceStep, hactive, hacc, Function.update,
            htarget'] using hm
        have hbest := hcurrent_best m hold
        simpa [im05_algorithm41SourceStep, hactive, hacc,
          im05_algorithm41BestProposedSoFar, im05_algorithm41HasProposedTo]
          using
            im05_algorithm41BestProposedSoFar_removeProposal_of_ne
              val_w s (b := daStepChosenMan val_m s hactive)
              (w := daStepChosenWoman val_m s hactive)
              (target := target) htarget hbest
      · have hold : s.w_match target = some m := by
          simpa [im05_algorithm41SourceStep, hactive, hacc] using hm
        have hbest := hcurrent_best m hold
        simpa [im05_algorithm41SourceStep, hactive, hacc,
          im05_algorithm41BestProposedSoFar, im05_algorithm41HasProposedTo]
          using
            im05_algorithm41BestProposedSoFar_removeProposal_of_ne
              val_w s (b := daStepChosenMan val_m s hactive)
              (w := daStepChosenWoman val_m s hactive)
              (target := target) htarget hbest
  · simpa [im05_algorithm41SourceStep, hactive] using hcurrent_best

