/--
Lemma 4.4 fresh-list conditional-comparison family from pair-dependent finite
approximating Algorithm 4.2 laws.  This variant is useful for the named
multiset/deletion route, where the finite count vector may depend on the
ordered pair `(i,j)` but still converges pointwise to the same popularity
vector.
-/
theorem
    paper_im05_lemma4_4_freshList_conditional_comparison_family_from_pair_weight_limits
    {I : Type*} [Fintype I] [DecidableEq I]
    {k : ℕ}
    [∀ i s, DecidablePred fun sample : im05_algorithm42FreshListSample I k =>
      im05_listPrefixOmits i s (im05_algorithm42FreshListDraw sample)]
    (weightSeq : I → I → ℕ → I → ℝ) (prob : I → ℝ)
    (hseq_nonneg : ∀ i j scale u, 0 ≤ weightSeq i j scale u)
    (hseq_available : ∀ i j scale, ∀ forbidden : Finset I,
      forbidden.card < Fintype.card I →
        0 < EconCSLib.finiteAvailableWeight
          (weightSeq i j scale) forbidden)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_pos : ∀ u, 0 < prob u)
    (havailable : ∀ forbidden : Finset I,
      forbidden.card < Fintype.card I →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    (hweight : ∀ i j u : I,
      Filter.Tendsto (fun scale : ℕ => weightSeq i j scale u)
        Filter.atTop (nhds (prob u)))
    (hk_le_card : k ≤ Fintype.card I)
    (hk_lt_card : k < Fintype.card I)
    (hfinite : ∀ i j : I, i ≠ j → ∀ scale : ℕ,
      EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF
            (weightSeq i j scale) (hseq_nonneg i j scale)
            (hseq_available i j scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) ≤
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF
            (weightSeq i j scale) (hseq_nonneg i j scale)
            (hseq_available i j scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample))) :
    ∀ i j : I, i ≠ j →
      EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) ≤
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) := by
  classical
  exact
    paper_im05_lemma4_4_freshList_conditional_comparison_family_from_multiset_limits
      prob hprob_nonneg havailable hk_le_card
      (fun i j scale =>
        EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF
            (weightSeq i j scale) (hseq_nonneg i j scale)
            (hseq_available i j scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)))
      (fun i j scale =>
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF
            (weightSeq i j scale) (hseq_nonneg i j scale)
            (hseq_available i j scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)))
      hfinite
      (fun i j _hij =>
        paper_im05_algorithm4_2_freshList_conditional_omit_tendsto
          (fun scale u => weightSeq i j scale u) prob
          (fun scale u => hseq_nonneg i j scale u)
          (fun scale forbidden hcard =>
            hseq_available i j scale forbidden hcard)
          hprob_nonneg hprob_pos havailable
          (fun u => hweight i j u)
          hk_le_card hk_lt_card i j)
      (fun i j _hij =>
        paper_im05_algorithm4_2_freshList_omit_prob_tendsto
          (fun scale u => weightSeq i j scale u) prob
          (fun scale u => hseq_nonneg i j scale u)
          (fun scale forbidden hcard =>
            hseq_available i j scale forbidden hcard)
          hprob_nonneg havailable
          (fun u => hweight i j u)
          hk_le_card i)

/--
Lemma 4.4 pair-dependent integer-count approximation bridge.  If positive
rescalings of the integer count vectors converge pointwise to the target
popularity vector, then finite conditional comparisons proved for the raw count
weights pass to the Algorithm 4.2 limit.  The scaling invariance of weighted
without-replacement sampling removes the arbitrary normalization factor.
-/
theorem
    paper_im05_lemma4_4_freshList_conditional_comparison_family_from_scaled_count_weight_limits
    {I : Type*} [Fintype I] [DecidableEq I]
    {k : ℕ}
    [∀ i s, DecidablePred fun sample : im05_algorithm42FreshListSample I k =>
      im05_listPrefixOmits i s (im05_algorithm42FreshListDraw sample)]
    (countSeq : I → I → ℕ → I → ℕ) (scaleWeight : ℕ → ℝ)
    (prob : I → ℝ)
    (hscale_pos : ∀ scale, 0 < scaleWeight scale)
    (hcount_available : ∀ i j scale, ∀ forbidden : Finset I,
      forbidden.card < Fintype.card I →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight (countSeq i j scale)) forbidden)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_pos : ∀ u, 0 < prob u)
    (havailable : ∀ forbidden : Finset I,
      forbidden.card < Fintype.card I →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    (hweight : ∀ i j u : I,
      Filter.Tendsto
        (fun scale : ℕ =>
          scaleWeight scale * im05_countWeight (countSeq i j scale) u)
        Filter.atTop (nhds (prob u)))
    (hk_le_card : k ≤ Fintype.card I)
    (hk_lt_card : k < Fintype.card I)
    (hfinite_count : ∀ i j : I, i ≠ j → ∀ scale : ℕ,
      EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF
            (im05_countWeight (countSeq i j scale))
            (im05_countWeight_nonneg (countSeq i j scale))
            (hcount_available i j scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) ≤
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF
            (im05_countWeight (countSeq i j scale))
            (im05_countWeight_nonneg (countSeq i j scale))
            (hcount_available i j scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample))) :
    ∀ i j : I, i ≠ j →
      EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) ≤
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) := by
  classical
  let weightSeq : I → I → ℕ → I → ℝ :=
    fun i j scale u =>
      scaleWeight scale * im05_countWeight (countSeq i j scale) u
  have hseq_nonneg : ∀ i j scale u, 0 ≤ weightSeq i j scale u := by
    intro i j scale u
    exact mul_nonneg (hscale_pos scale).le
      (im05_countWeight_nonneg (countSeq i j scale) u)
  have hseq_available : ∀ i j scale, ∀ forbidden : Finset I,
      forbidden.card < Fintype.card I →
        0 < EconCSLib.finiteAvailableWeight
          (weightSeq i j scale) forbidden := by
    intro i j scale forbidden hcard
    dsimp [weightSeq]
    rw [EconCSLib.finiteAvailableWeight_const_mul]
    exact mul_pos (hscale_pos scale)
      (hcount_available i j scale forbidden hcard)
  refine
    paper_im05_lemma4_4_freshList_conditional_comparison_family_from_pair_weight_limits
      weightSeq prob hseq_nonneg hseq_available
      hprob_nonneg hprob_pos havailable ?_
      hk_le_card hk_lt_card ?_
  · intro i j u
    exact hweight i j u
  · intro i j hij scale
    let countWeight := im05_countWeight (countSeq i j scale)
    let scaledWeight : I → ℝ := fun u => scaleWeight scale * countWeight u
    have hcond_eq :
        EconCSLib.pmfConditionalProb
            (im05_algorithm42FreshListPMF
              scaledWeight
              (fun u => mul_nonneg (hscale_pos scale).le
                (im05_countWeight_nonneg (countSeq i j scale) u))
              (fun forbidden hcard => by
                rw [EconCSLib.finiteAvailableWeight_const_mul]
                exact mul_pos (hscale_pos scale)
                  (hcount_available i j scale forbidden hcard))
              k hk_le_card)
            (fun sample =>
              im05_listPrefixOmits j k
                (im05_algorithm42FreshListDraw sample))
            (fun sample =>
              im05_listPrefixOmits i k
                (im05_algorithm42FreshListDraw sample)) =
          EconCSLib.pmfConditionalProb
            (im05_algorithm42FreshListPMF
              countWeight
              (im05_countWeight_nonneg (countSeq i j scale))
              (hcount_available i j scale) k hk_le_card)
            (fun sample =>
              im05_listPrefixOmits j k
                (im05_algorithm42FreshListDraw sample))
            (fun sample =>
              im05_listPrefixOmits i k
                (im05_algorithm42FreshListDraw sample)) := by
      simpa [im05_algorithm42FreshListPMF, countWeight, scaledWeight] using
        (EconCSLib.finiteWithoutReplacementPMF_conditional_prob_const_mul
          countWeight (scaleWeight scale) (hscale_pos scale)
          (im05_countWeight_nonneg (countSeq i j scale))
          (hcount_available i j scale)
          (∅ : Finset I) (by simpa using hk_le_card)
          (fun sample : im05_algorithm42FreshListSample I k =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))
          (fun sample : im05_algorithm42FreshListSample I k =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)))
    have hbase_eq :
        EconCSLib.pmfProb
            (im05_algorithm42FreshListPMF
              scaledWeight
              (fun u => mul_nonneg (hscale_pos scale).le
                (im05_countWeight_nonneg (countSeq i j scale) u))
              (fun forbidden hcard => by
                rw [EconCSLib.finiteAvailableWeight_const_mul]
                exact mul_pos (hscale_pos scale)
                  (hcount_available i j scale forbidden hcard))
              k hk_le_card)
            (fun sample =>
              im05_listPrefixOmits i k
                (im05_algorithm42FreshListDraw sample)) =
          EconCSLib.pmfProb
            (im05_algorithm42FreshListPMF
              countWeight
              (im05_countWeight_nonneg (countSeq i j scale))
              (hcount_available i j scale) k hk_le_card)
            (fun sample =>
              im05_listPrefixOmits i k
                (im05_algorithm42FreshListDraw sample)) := by
      simpa [im05_algorithm42FreshListPMF, countWeight, scaledWeight] using
        (EconCSLib.finiteWithoutReplacementPMF_event_prob_const_mul
          countWeight (scaleWeight scale) (hscale_pos scale)
          (im05_countWeight_nonneg (countSeq i j scale))
          (hcount_available i j scale)
          (∅ : Finset I) (by simpa using hk_le_card)
          (fun sample : im05_algorithm42FreshListSample I k =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)))
    rw [hcond_eq, hbase_eq]
    exact hfinite_count i j hij scale

/--
Lemma 4.4 finite-law bridge for one ordered pair.  If the uniform
integer-multiset permutation events are identified with the corresponding
raw-count fresh-list conditional and marginal omission probabilities, then the
finite deletion/inclusion inequality gives the desired one-man comparison for
the raw count weights.
-/
theorem
    paper_im05_lemma4_4_freshList_conditional_comparison_from_integerMultiset_finite_law
    {I : Type*} [Fintype I] [DecidableEq I]
    {k : ℕ}
    [∀ i s, DecidablePred fun sample : im05_algorithm42FreshListSample I k =>
      im05_listPrefixOmits i s (im05_algorithm42FreshListDraw sample)]
    (count : I → ℕ)
    (hcount_available : ∀ forbidden : Finset I,
      forbidden.card < Fintype.card I →
        0 < EconCSLib.finiteAvailableWeight (im05_countWeight count) forbidden)
    (hk_le_card : k ≤ Fintype.card I)
    (i j : I)
    (hcond_law :
      EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF
            (im05_countWeight count) (im05_countWeight_nonneg count)
            hcount_available k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) =
        EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample I count))
          (fun sample =>
            k ≤
              ((im05_namesBeforeFirst id i
                (im05_integerMultisetPermutationList sample)).erase j).card))
    (hbase_law :
      EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF
            (im05_countWeight count) (im05_countWeight_nonneg count)
            hcount_available k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) =
        EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample I count))
          (fun sample =>
            k ≤
              (im05_namesBeforeFirst id i
                (im05_integerMultisetPermutationList sample)).card)) :
    EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available k hk_le_card)
        (fun sample =>
          im05_listPrefixOmits j k
            (im05_algorithm42FreshListDraw sample))
        (fun sample =>
          im05_listPrefixOmits i k
            (im05_algorithm42FreshListDraw sample)) ≤
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available k hk_le_card)
        (fun sample =>
          im05_listPrefixOmits i k
            (im05_algorithm42FreshListDraw sample)) := by
  classical
  rw [hcond_law, hbase_law]
  exact
    paper_im05_lemma4_4_integerMultiset_event_inclusion_probability
      count i j k

/--
Corrected Lemma 4.4 finite bridge for one ordered pair.  It is enough to upper
bound the raw-count conditional omission probability by the erased multiset
event; the deterministic erased-to-unerased inclusion and the marginal finite
law then give the desired one-man comparison.
-/
theorem
    paper_im05_lemma4_4_freshList_conditional_comparison_from_integerMultiset_erased_upper_bound
    {I : Type*} [Fintype I] [DecidableEq I]
    {k : ℕ}
    [∀ i s, DecidablePred fun sample : im05_algorithm42FreshListSample I k =>
      im05_listPrefixOmits i s (im05_algorithm42FreshListDraw sample)]
    (count : I → ℕ)
    (hcount_available : ∀ forbidden : Finset I,
