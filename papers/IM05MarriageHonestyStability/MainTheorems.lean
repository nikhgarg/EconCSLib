          hk_le_card hk_lt_card i j)
      (fun i _hi _j _hj _hij =>
        paper_im05_algorithm4_2_freshList_omit_prob_tendsto
          weightSeq prob hseq_nonneg hseq_available
          hprob_nonneg havailable hweight hk_le_card i)

/--
Target-indexed tail version of the finite-weight comparison route.  This is
the rank-index analogue of the repaired tail Lemma 4.4 bridge: finite-scale
conditional inequalities are indexed by a selected tail block, while the
fresh-list draws still live over the actual woman type.
-/
theorem
    paper_im05_lemma4_4_freshList_target_tail_conditional_comparison_family_from_weight_limits
    {W R : Type*} [Fintype W] [DecidableEq W] [DecidableEq R]
    {k : ℕ}
    [∀ w s, DecidablePred fun sample : im05_algorithm42FreshListSample W k =>
      im05_listPrefixOmits w s (im05_algorithm42FreshListDraw sample)]
    (weightSeq : ℕ → W → ℝ) (prob : W → ℝ)
    (hseq_nonneg : ∀ scale u, 0 ≤ weightSeq scale u)
    (hseq_available : ∀ scale, ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight (weightSeq scale) forbidden)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_pos : ∀ u, 0 < prob u)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    (hweight : ∀ u : W,
      Filter.Tendsto (fun scale : ℕ => weightSeq scale u)
        Filter.atTop (nhds (prob u)))
    (hk_le_card : k ≤ Fintype.card W)
    (hk_lt_card : k < Fintype.card W)
    (target : R → W) (tail : Finset R)
    (hfinite : ∀ idx ∈ tail, ∀ jdx ∈ tail, idx ≠ jdx → ∀ scale : ℕ,
      EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF
            (weightSeq scale) (hseq_nonneg scale)
            (hseq_available scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits (target jdx) k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits (target idx) k
              (im05_algorithm42FreshListDraw sample)) ≤
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF
            (weightSeq scale) (hseq_nonneg scale)
            (hseq_available scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits (target idx) k
              (im05_algorithm42FreshListDraw sample))) :
    ∀ idx ∈ tail, ∀ jdx ∈ tail, idx ≠ jdx →
      EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits (target jdx) k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits (target idx) k
              (im05_algorithm42FreshListDraw sample)) ≤
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits (target idx) k
              (im05_algorithm42FreshListDraw sample)) := by
  classical
  exact
    paper_im05_lemma4_4_freshList_target_tail_conditional_comparison_family_from_multiset_limits
      prob hprob_nonneg havailable hk_le_card target tail
      (fun idx jdx scale =>
        EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF
            (weightSeq scale) (hseq_nonneg scale)
            (hseq_available scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits (target jdx) k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits (target idx) k
              (im05_algorithm42FreshListDraw sample)))
      (fun idx _jdx scale =>
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF
            (weightSeq scale) (hseq_nonneg scale)
            (hseq_available scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits (target idx) k
              (im05_algorithm42FreshListDraw sample)))
      hfinite
      (fun idx _hi jdx _hj _hij =>
        paper_im05_algorithm4_2_freshList_conditional_omit_tendsto
          weightSeq prob hseq_nonneg hseq_available
          hprob_nonneg hprob_pos havailable hweight
          hk_le_card hk_lt_card (target idx) (target jdx))
      (fun idx _hi _jdx _hj _hij =>
        paper_im05_algorithm4_2_freshList_omit_prob_tendsto
          weightSeq prob hseq_nonneg hseq_available
          hprob_nonneg havailable hweight hk_le_card (target idx))

/--
Lemma 4.4 variance core: pairwise negative correlation of the absent-woman
events implies that the variance of their count is at most its expectation.
-/
theorem paper_im05_lemma4_4_variance_le_expectation_of_pairwise_negative_correlation
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (event : I → Ω → Prop)
    [∀ ω, DecidablePred fun i => event i ω]
    [∀ i, DecidablePred fun ω => event i ω]
    (hneg : ∀ i j : I, i ≠ j →
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) ≤
        EconCSLib.pmfProb μ (fun ω => event i ω) *
          EconCSLib.pmfProb μ (fun ω => event j ω)) :
    EconCSLib.pmfVariance μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => event i ω).card : ℝ)) ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => event i ω).card : ℝ)) := by
  classical
  exact
    EconCSLib.pmfVariance_card_filter_le_pmfExp_card_filter_of_pairwise_inter_le_mul
      μ (fun ω i => event i ω)
      (by
        intro i j hij
        simpa using hneg i j hij)

/--
Corrected Lemma 4.4 tail core: the variance calculation only needs to count a
chosen tail block of ranks.  If the absent-woman events are pairwise negatively
correlated inside that tail, then the tail count has variance at most its
expectation.

This is the paper-facing replacement for the unrestricted Lemma 4.4 statement,
which is false for arbitrary nonuniform `D^k`.
-/
theorem paper_im05_lemma4_4_tail_variance_le_expectation_of_pairwise_negative_correlation
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (tail : Finset I) (event : I → Ω → Prop)
    [∀ ω, DecidablePred fun i => event i ω]
    [∀ i, DecidablePred fun ω => event i ω]
    (hneg : ∀ i ∈ tail, ∀ j ∈ tail, i ≠ j →
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) ≤
        EconCSLib.pmfProb μ (fun ω => event i ω) *
          EconCSLib.pmfProb μ (fun ω => event j ω)) :
    EconCSLib.pmfVariance μ
        (fun ω =>
          ((tail.filter fun i => event i ω).card : ℝ)) ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          ((tail.filter fun i => event i ω).card : ℝ)) := by
  classical
  let TailIndex := {i : I // i ∈ tail}
  let tailEvent : TailIndex → Ω → Prop := fun i ω => event i.1 ω
  have hneg_tail : ∀ i j : TailIndex, i ≠ j →
      EconCSLib.pmfProb μ (fun ω => tailEvent i ω ∧ tailEvent j ω) ≤
        EconCSLib.pmfProb μ (fun ω => tailEvent i ω) *
          EconCSLib.pmfProb μ (fun ω => tailEvent j ω) := by
    intro i j hij
    have hij_val : i.1 ≠ j.1 := by
      intro h
      exact hij (Subtype.ext h)
    simpa [tailEvent] using hneg i.1 i.2 j.1 j.2 hij_val
  have htail :
      EconCSLib.pmfVariance μ
          (fun ω =>
            (((Finset.univ : Finset TailIndex).filter
                fun i => tailEvent i ω).card : ℝ)) ≤
        EconCSLib.pmfExp μ
          (fun ω =>
            (((Finset.univ : Finset TailIndex).filter
                fun i => tailEvent i ω).card : ℝ)) :=
    paper_im05_lemma4_4_variance_le_expectation_of_pairwise_negative_correlation
      μ tailEvent hneg_tail
  have hcount :
      (fun ω =>
        (((Finset.univ : Finset TailIndex).filter
            fun i => tailEvent i ω).card : ℝ)) =
      (fun ω =>
        ((tail.filter fun i => event i ω).card : ℝ)) := by
    funext ω
    congr 1
    unfold TailIndex tailEvent
    refine Finset.card_bij (fun x _ => x.1) ?_ ?_ ?_
    · intro x hx
      rw [Finset.mem_filter] at hx ⊢
      exact ⟨x.2, hx.2⟩
    · intro x _ y _ hxy
      exact Subtype.ext hxy
    · intro y hy
      rw [Finset.mem_filter] at hy
      refine ⟨⟨y, hy.1⟩, ?_, rfl⟩
      rw [Finset.mem_filter]
      exact ⟨Finset.mem_univ _, hy.2⟩
  simpa [hcount] using htail

/--
Lemma 4.4 paper-route probability step: if the source's conditional comparison
`Pr[E_i | E_j] <= Pr[E_i]` holds for all distinct pairs with positive
conditioning probability, then the pairwise negative-correlation inequality
used in the variance calculation follows.
-/
theorem paper_im05_lemma4_4_pairwise_negative_correlation_from_conditional
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (event : I → Ω → Prop)
    [∀ i, DecidablePred fun ω => event i ω]
    (hpos : ∀ j : I, 0 < EconCSLib.pmfProb μ (fun ω => event j ω))
    (hcond : ∀ i j : I, i ≠ j →
      EconCSLib.pmfConditionalProb μ
          (fun ω => event j ω) (fun ω => event i ω) ≤
        EconCSLib.pmfProb μ (fun ω => event i ω)) :
    ∀ i j : I, i ≠ j →
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) ≤
        EconCSLib.pmfProb μ (fun ω => event i ω) *
          EconCSLib.pmfProb μ (fun ω => event j ω) := by
  intro i j hij
  exact
    EconCSLib.pmfProb_inter_le_mul_of_conditionalProb_le
      μ (fun ω => event i ω) (fun ω => event j ω)
      (hpos j) (hcond i j hij)

/--
Converse probability step for Lemma 4.4: a pairwise negative-correlation
bound directly supplies the source's one-man conditional comparison whenever
the conditioning event has positive probability.
-/
theorem paper_im05_lemma4_4_conditional_from_pairwise_negative_correlation
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (event : I → Ω → Prop)
    [∀ i, DecidablePred fun ω => event i ω]
    (hpos : ∀ j : I, 0 < EconCSLib.pmfProb μ (fun ω => event j ω))
    (hneg : ∀ i j : I, i ≠ j →
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) ≤
        EconCSLib.pmfProb μ (fun ω => event i ω) *
          EconCSLib.pmfProb μ (fun ω => event j ω)) :
    ∀ i j : I, i ≠ j →
      EconCSLib.pmfConditionalProb μ
          (fun ω => event j ω) (fun ω => event i ω) ≤
        EconCSLib.pmfProb μ (fun ω => event i ω) := by
  intro i j hij
  exact
    EconCSLib.pmfConditionalProb_le_of_inter_le_mul
      μ (fun ω => event i ω) (fun ω => event j ω)
      (hpos j) (hneg i j hij)

/--
Algorithm 4.2 one-man conditional comparison from a direct pairwise
negative-correlation theorem for the omission events of the recursive fresh-list
sampler.
-/
theorem
    paper_im05_lemma4_4_freshList_conditional_comparison_from_pairwise_negative_correlation
    {I : Type*} [Fintype I] [DecidableEq I]
    {k : ℕ}
    [∀ i, DecidablePred fun sample : im05_algorithm42FreshListSample I k =>
      im05_listPrefixOmits i k (im05_algorithm42FreshListDraw sample)]
    (prob : I → ℝ)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_pos : ∀ u, 0 < prob u)
    (havailable : ∀ forbidden : Finset I,
      forbidden.card < Fintype.card I →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    (hk_le_card : k ≤ Fintype.card I)
    (hk_lt_card : k < Fintype.card I)
    (hneg : ∀ i j : I, i ≠ j →
      EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits i k
                (im05_algorithm42FreshListDraw sample) ∧
              im05_listPrefixOmits j k
                (im05_algorithm42FreshListDraw sample)) ≤
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) *
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))) :
    ∀ i j : I, i ≠ j →
      EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) ≤
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF prob hprob_nonneg havailable k hk_le_card
  let event : I → im05_algorithm42FreshListSample I k → Prop :=
    fun i sample =>
      im05_listPrefixOmits i k (im05_algorithm42FreshListDraw sample)
  exact
    paper_im05_lemma4_4_conditional_from_pairwise_negative_correlation
      μ event
      (by
        intro j
        simpa [μ, event] using
          (paper_im05_algorithm4_2_freshList_omit_pos_of_full_support
            prob hprob_nonneg hprob_pos havailable
            hk_le_card hk_lt_card j))
      (by
        intro i j hij
        simpa [μ, event] using hneg i j hij)

/--
Raw-count `k = 2` Lemma 4.4 conditional comparison from the closed direct
two-draw negative-correlation theorem.
-/
theorem
    paper_im05_lemma4_4_freshList_conditional_comparison_countWeight_two
    {I : Type*} [Fintype I] [DecidableEq I]
    (count : I → ℕ)
    (hcount_available : ∀ forbidden : Finset I,
      forbidden.card < Fintype.card I →
        0 < EconCSLib.finiteAvailableWeight (im05_countWeight count) forbidden)
    (hcard_two_lt : 2 < Fintype.card I) :
    ∀ i j : I, i ≠ j →
      EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF
            (im05_countWeight count) (im05_countWeight_nonneg count)
            hcount_available 2 (le_of_lt hcard_two_lt))
          (fun sample =>
            im05_listPrefixOmits j 2
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits i 2
              (im05_algorithm42FreshListDraw sample)) ≤
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF
            (im05_countWeight count) (im05_countWeight_nonneg count)
            hcount_available 2 (le_of_lt hcard_two_lt))
          (fun sample =>
            im05_listPrefixOmits i 2
              (im05_algorithm42FreshListDraw sample)) := by
  classical
  exact
    paper_im05_lemma4_4_freshList_conditional_comparison_from_pairwise_negative_correlation
      (k := 2)
      (im05_countWeight count) (im05_countWeight_nonneg count)
      (by
        intro u
        dsimp [im05_countWeight]
        exact_mod_cast
          im05_count_pos_of_countWeight_available count hcount_available u)
      hcount_available (le_of_lt hcard_two_lt) hcard_two_lt
      (fun i j hij =>
        paper_im05_lemma4_4_freshList_pairwise_negative_correlation_countWeight_two
          count hcount_available (le_of_lt hcard_two_lt) i j hij)

/--
Lemma 4.4 source-route wrapper: the conditional comparison supplied by the
multiset/permutation argument is enough to conclude
`Var(Y_g) <= E[Y_g]`.
-/
theorem paper_im05_lemma4_4_variance_le_expectation_from_conditional
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (event : I → Ω → Prop)
    [∀ ω, DecidablePred fun i => event i ω]
    [∀ i, DecidablePred fun ω => event i ω]
    (hpos : ∀ j : I, 0 < EconCSLib.pmfProb μ (fun ω => event j ω))
    (hcond : ∀ i j : I, i ≠ j →
      EconCSLib.pmfConditionalProb μ
          (fun ω => event j ω) (fun ω => event i ω) ≤
        EconCSLib.pmfProb μ (fun ω => event i ω)) :
    EconCSLib.pmfVariance μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => event i ω).card : ℝ)) ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => event i ω).card : ℝ)) := by
  classical
  exact
    paper_im05_lemma4_4_variance_le_expectation_of_pairwise_negative_correlation
      μ event
      (paper_im05_lemma4_4_pairwise_negative_correlation_from_conditional
        μ event hpos hcond)

/--
Lemma 4.4 independence algebra: if a single-man pair event has probability at
most the product of its marginals, then the all-men event obtained by taking
`n` independent copies satisfies the same negative-correlation inequality.
-/
theorem paper_im05_lemma4_4_all_men_probability_power_bound
    (n : ℕ) {singleI singleJ singleIJ allI allJ allIJ : ℝ}
    (hsingleIJ_nonneg : 0 ≤ singleIJ)
    (hsingle : singleIJ ≤ singleI * singleJ)
    (hallIJ : allIJ = singleIJ ^ n)
    (hallI : allI = singleI ^ n)
    (hallJ : allJ = singleJ ^ n) :
    allIJ ≤ allI * allJ := by
  calc
    allIJ = singleIJ ^ n := hallIJ
    _ ≤ (singleI * singleJ) ^ n :=
        pow_le_pow_left₀ hsingleIJ_nonneg hsingle n
    _ = singleI ^ n * singleJ ^ n := by rw [mul_pow]
    _ = allI * allJ := by rw [hallI, hallJ]

/--
Lemma 4.4 event-level independence lift: supplied `n`th-power identities for
the all-men absence events reduce pairwise negative correlation to the
single-man list events.
-/
theorem paper_im05_lemma4_4_pairwise_negative_correlation_from_single_man
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (event : I → Ω → Prop)
    [∀ i, DecidablePred fun ω => event i ω]
    (singleProb : I → ℝ) (singleJointProb : I → I → ℝ) (n : ℕ)
    (hsingleJoint_nonneg : ∀ i j : I, 0 ≤ singleJointProb i j)
    (hsingleNeg : ∀ i j : I, i ≠ j →
      singleJointProb i j ≤ singleProb i * singleProb j)
    (hevent : ∀ i : I,
      EconCSLib.pmfProb μ (fun ω => event i ω) = singleProb i ^ n)
    (hjoint : ∀ i j : I,
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) =
        singleJointProb i j ^ n) :
    ∀ i j : I, i ≠ j →
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) ≤
        EconCSLib.pmfProb μ (fun ω => event i ω) *
          EconCSLib.pmfProb μ (fun ω => event j ω) := by
  intro i j hij
  exact
    paper_im05_lemma4_4_all_men_probability_power_bound
      n
      (hsingleJoint_nonneg i j)
      (hsingleNeg i j hij)
      (hjoint i j)
      (hevent i)
      (hevent j)

/--
Lemma 4.4 source-route one-man wrapper: the conditional comparison for a
single man's random list, plus the `n`th-power identities from independence
across men, yields the pairwise negative correlation of the all-men absence
events.
-/
theorem
    paper_im05_lemma4_4_pairwise_negative_correlation_from_single_man_conditional
    {Λ Ω I : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (ν : PMF Λ) (oneEvent : I → Λ → Prop)
    (μ : PMF Ω) (event : I → Ω → Prop)
    [∀ i, DecidablePred fun sample => oneEvent i sample]
    [∀ i, DecidablePred fun ω => event i ω]
    (n : ℕ)
    (hone_pos : ∀ j : I,
      0 < EconCSLib.pmfProb ν (fun sample => oneEvent j sample))
    (hcond : ∀ i j : I, i ≠ j →
      EconCSLib.pmfConditionalProb ν
          (fun sample => oneEvent j sample) (fun sample => oneEvent i sample) ≤
        EconCSLib.pmfProb ν (fun sample => oneEvent i sample))
    (hevent : ∀ i : I,
      EconCSLib.pmfProb μ (fun ω => event i ω) =
        (EconCSLib.pmfProb ν (fun sample => oneEvent i sample)) ^ n)
    (hjoint : ∀ i j : I,
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) =
        (EconCSLib.pmfProb ν
          (fun sample => oneEvent i sample ∧ oneEvent j sample)) ^ n) :
    ∀ i j : I, i ≠ j →
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) ≤
        EconCSLib.pmfProb μ (fun ω => event i ω) *
          EconCSLib.pmfProb μ (fun ω => event j ω) := by
  classical
  refine
    paper_im05_lemma4_4_pairwise_negative_correlation_from_single_man
      μ event
      (fun i => EconCSLib.pmfProb ν (fun sample => oneEvent i sample))
      (fun i j => EconCSLib.pmfProb ν
        (fun sample => oneEvent i sample ∧ oneEvent j sample))
      n ?_ ?_ hevent hjoint
  · intro i j
    exact EconCSLib.pmfProb_nonneg ν
      (fun sample => oneEvent i sample ∧ oneEvent j sample)
  · intro i j hij
    exact
      EconCSLib.pmfProb_inter_le_mul_of_conditionalProb_le
        ν (fun sample => oneEvent i sample) (fun sample => oneEvent j sample)
        (hone_pos j) (hcond i j hij)

/--
Lemma 4.4 independent-men product identity for one indexed event.
-/
theorem paper_im05_lemma4_4_product_event_probability
    {M Λ I : Type*} [Fintype M] [DecidableEq M]
    [Fintype Λ] [DecidableEq Λ] [Fintype I] [DecidableEq I]
    (ν : PMF Λ) (oneEvent : I → Λ → Prop)
    [∀ i, DecidablePred fun sample => oneEvent i sample]
    (i : I) :
    EconCSLib.pmfProb (EconCSLib.pmfProduct M Λ ν)
        (fun samples : M → Λ =>
          ∀ m : M, oneEvent i (samples m)) =
      (EconCSLib.pmfProb ν (fun sample => oneEvent i sample)) ^
        Fintype.card M := by
  exact
    EconCSLib.pmfProduct_prob_forall (ι := M) (α := Λ) ν
      (fun sample => oneEvent i sample)

/--
Lemma 4.4 independent-men product identity for the joint absence of two indexed
events.  The all-men conjunction is equivalent to every man satisfying the
one-man intersection event.
-/
theorem paper_im05_lemma4_4_product_joint_event_probability
    {M Λ I : Type*} [Fintype M] [DecidableEq M]
    [Fintype Λ] [DecidableEq Λ] [Fintype I] [DecidableEq I]
    (ν : PMF Λ) (oneEvent : I → Λ → Prop)
    [∀ i, DecidablePred fun sample => oneEvent i sample]
    (i j : I) :
    EconCSLib.pmfProb (EconCSLib.pmfProduct M Λ ν)
        (fun samples : M → Λ =>
          (∀ m : M, oneEvent i (samples m)) ∧
            (∀ m : M, oneEvent j (samples m))) =
      (EconCSLib.pmfProb ν
        (fun sample => oneEvent i sample ∧ oneEvent j sample)) ^
        Fintype.card M := by
  classical
  calc
    EconCSLib.pmfProb (EconCSLib.pmfProduct M Λ ν)
        (fun samples : M → Λ =>
          (∀ m : M, oneEvent i (samples m)) ∧
            (∀ m : M, oneEvent j (samples m)))
        =
      EconCSLib.pmfProb (EconCSLib.pmfProduct M Λ ν)
        (fun samples : M → Λ =>
          ∀ m : M, oneEvent i (samples m) ∧ oneEvent j (samples m)) := by
        refine EconCSLib.pmfProb_congr _ ?_
        intro samples
        constructor
        · rintro ⟨hi, hj⟩ m
          exact ⟨hi m, hj m⟩
        · intro h
          exact ⟨fun m => (h m).1, fun m => (h m).2⟩
    _ =
      (EconCSLib.pmfProb ν
        (fun sample => oneEvent i sample ∧ oneEvent j sample)) ^
        Fintype.card M := by
        exact
          EconCSLib.pmfProduct_prob_forall (ι := M) (α := Λ) ν
            (fun sample => oneEvent i sample ∧ oneEvent j sample)

/--
Lemma 4.4 product-model one-man wrapper: the single-man conditional comparison
implies pairwise negative correlation for all-men absence events under the
finite independent product PMF.
-/
theorem
    paper_im05_lemma4_4_pairwise_negative_correlation_from_single_man_conditional_product
    {M Λ I : Type*} [Fintype M] [DecidableEq M]
    [Fintype Λ] [DecidableEq Λ]
    [Fintype I] [DecidableEq I]
    (ν : PMF Λ) (oneEvent : I → Λ → Prop)
    [∀ i, DecidablePred fun sample => oneEvent i sample]
    (hone_pos : ∀ j : I,
      0 < EconCSLib.pmfProb ν (fun sample => oneEvent j sample))
    (hcond : ∀ i j : I, i ≠ j →
      EconCSLib.pmfConditionalProb ν
          (fun sample => oneEvent j sample) (fun sample => oneEvent i sample) ≤
        EconCSLib.pmfProb ν (fun sample => oneEvent i sample)) :
    ∀ i j : I, i ≠ j →
      EconCSLib.pmfProb (EconCSLib.pmfProduct M Λ ν)
          (fun samples : M → Λ =>
            (∀ m : M, oneEvent i (samples m)) ∧
              (∀ m : M, oneEvent j (samples m))) ≤
        EconCSLib.pmfProb (EconCSLib.pmfProduct M Λ ν)
            (fun samples : M → Λ =>
              ∀ m : M, oneEvent i (samples m)) *
          EconCSLib.pmfProb (EconCSLib.pmfProduct M Λ ν)
            (fun samples : M → Λ =>
              ∀ m : M, oneEvent j (samples m)) := by
  classical
  exact
    paper_im05_lemma4_4_pairwise_negative_correlation_from_single_man_conditional
      ν oneEvent (EconCSLib.pmfProduct M Λ ν)
      (fun i samples => ∀ m : M, oneEvent i (samples m))
      (Fintype.card M) hone_pos hcond
      (paper_im05_lemma4_4_product_event_probability
        (M := M) ν oneEvent)
      (paper_im05_lemma4_4_product_joint_event_probability
        (M := M) ν oneEvent)

/--
Lemma 4.4 source-route variance wrapper using the paper's one-man conditional
comparison and independence power identities.
-/
theorem paper_im05_lemma4_4_variance_le_expectation_from_single_man_conditional
    {Λ Ω I : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (ν : PMF Λ) (oneEvent : I → Λ → Prop)
    (μ : PMF Ω) (event : I → Ω → Prop)
    [∀ ω, DecidablePred fun i => event i ω]
    [∀ i, DecidablePred fun sample => oneEvent i sample]
    [∀ i, DecidablePred fun ω => event i ω]
    (n : ℕ)
    (hone_pos : ∀ j : I,
      0 < EconCSLib.pmfProb ν (fun sample => oneEvent j sample))
    (hcond : ∀ i j : I, i ≠ j →
      EconCSLib.pmfConditionalProb ν
          (fun sample => oneEvent j sample) (fun sample => oneEvent i sample) ≤
        EconCSLib.pmfProb ν (fun sample => oneEvent i sample))
    (hevent : ∀ i : I,
      EconCSLib.pmfProb μ (fun ω => event i ω) =
        (EconCSLib.pmfProb ν (fun sample => oneEvent i sample)) ^ n)
    (hjoint : ∀ i j : I,
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) =
        (EconCSLib.pmfProb ν
          (fun sample => oneEvent i sample ∧ oneEvent j sample)) ^ n) :
    EconCSLib.pmfVariance μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => event i ω).card : ℝ)) ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => event i ω).card : ℝ)) := by
  classical
  exact
    paper_im05_lemma4_4_variance_le_expectation_of_pairwise_negative_correlation
      μ event
      (paper_im05_lemma4_4_pairwise_negative_correlation_from_single_man_conditional
        ν oneEvent μ event n hone_pos hcond hevent hjoint)

