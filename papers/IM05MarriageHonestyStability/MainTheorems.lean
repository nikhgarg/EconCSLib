/--
Trace-level backward bridge: if a stable husband is selected to propose to the
target before the finite horizon, and the current prefix state has the local
target-exception rejection-impossibility package, then he appears in the
corrected Algorithm 4.1 accepted-men output.
-/
theorem im05_stableHusband_target_proposal_mem_sourceDivorceTargetAcceptedMen_of_trace_package
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    {t : ℕ} (ht : t < Fintype.card M * Fintype.card W)
    {m : M}
    (hstableHusband : m ∈ im05_stableHusbands val_m val_w g)
    (hproposalOrder :
      ManProposalOrderInvariant val_m
        (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t))
    (hmatchOrder :
      im05_ManCurrentMatchOrderInvariant val_m
        (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t))
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w
        (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t)
        g)
    (hactive :
      ∃ a, IsActiveMan val_m
        (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t) a)
    (hchosen :
      daStepChosenMan val_m
        (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t)
        hactive = m)
    (htarget :
      daStepChosenWoman val_m
        (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t)
        hactive = g) :
    m ∈ im05_algorithm41SourceDivorceTargetAcceptedMen val_m val_w g := by
  have hevent :
      im05_algorithm41SourceStepTargetAccepted val_m val_w g
        (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t) =
          some m :=
    im05_algorithm41SourceStepTargetAccepted_eq_some_of_stableHusband_target_proposal
      val_m val_w
      (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t)
      g hstrictM hacceptable hproposalOrder hmatchOrder hrejected hactive
      hchosen htarget hstableHusband
  exact
    (im05_mem_algorithm41SourceDivorceTargetAcceptedMen_iff
      val_m val_w g m).2 (Or.inr ⟨t, ht, hevent⟩)

