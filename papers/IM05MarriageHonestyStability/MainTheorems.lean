/--
Lemma 4.3 independent-men product identity: if every man independently draws
from the same one-man list law, then the probability that all men omit `w` in
their first `k` slots is the corresponding one-man omission probability raised
to the number of men.
-/
theorem paper_im05_lemma4_3_product_absence_probability
    {M Λ W : Type*} [Fintype M] [DecidableEq M]
    [Fintype Λ] [DecidableEq Λ] [DecidableEq W]
    {k : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    [DecidablePred fun sample => im05_listPrefixOmits w k (draw sample)] :
    EconCSLib.pmfProb (EconCSLib.pmfProduct M Λ ν)
        (fun samples : M → Λ =>
          ∀ m : M, im05_listPrefixOmits w k (draw (samples m))) =
      (EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w k (draw sample))) ^
        Fintype.card M := by
  exact
    EconCSLib.pmfProduct_prob_forall (ι := M) (α := Λ) ν
      (fun sample => im05_listPrefixOmits w k (draw sample))

/--
Lemma 4.3 Algorithm 4.2 product-model route: statewise filtered-draw laws for
the one-man process, plus independent identical one-man draws across men,
imply the all-men rank-power absence lower bound without an externally supplied
product identity.
-/
theorem
    paper_im05_lemma4_3_absence_probability_ge_rank_power_from_algorithm4_2_prefix_states_product
    {M Λ S W : Type*} [Fintype M] [DecidableEq M]
    [Fintype Λ] [DecidableEq Λ]
    [Fintype S] [DecidableEq S] [Fintype W] [DecidableEq W]
    {k : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    (state : ℕ → Λ → S) (tail : Finset W) (prob : W → ℝ)
    (previous : ℕ → S → Finset W) (prevMass : ℕ → S → ℝ)
    (Q : ℝ) (rank : ℕ)
    [∀ s, DecidablePred fun sample => im05_listPrefixOmits w s (draw sample)]
    (hk_rank : k < rank)
    (hprefix_pos : ∀ r, r < k →
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample)))
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_sum : ∑ u : W, prob u = 1)
    (hprevMass : ∀ r s, prevMass r s = ∑ u ∈ previous r s, prob u)
    (havailable_pos : ∀ r, r < k → ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state r sample = s) →
      0 < EconCSLib.finiteAvailableWeight prob (previous r s))
    (hw_not_previous : ∀ r, r < k → ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state r sample = s) →
      w ∉ previous r s)
    (hprev_le_Q : ∀ r, r < k → ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state r sample = s) →
      prevMass r s ≤ Q)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u)
    (hcond_eq : ∀ r, (hr : r < k) → ∀ s : S, (hspos :
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state r sample = s)) →
      EconCSLib.pmfConditionalProb ν
          (fun sample =>
            im05_listPrefixOmits w r (draw sample) ∧ state r sample = s)
          (fun sample => draw sample ⟨r, hr⟩ = w) =
        (EconCSLib.finiteWeightedPMFExcluding
          prob (previous r s) hprob_nonneg (havailable_pos r hr s hspos) w).toReal) :
    (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ (Fintype.card M * k) ≤
      EconCSLib.pmfProb (EconCSLib.pmfProduct M Λ ν)
        (fun samples : M → Λ =>
          ∀ m : M, im05_listPrefixOmits w k (draw (samples m))) := by
  classical
  exact
    paper_im05_lemma4_3_absence_probability_ge_rank_power_from_algorithm4_2_prefix_states
      ν draw w (EconCSLib.pmfProduct M Λ ν)
      (fun samples : M → Λ =>
        ∀ m : M, im05_listPrefixOmits w k (draw (samples m)))
      state tail prob previous prevMass Q rank (Fintype.card M)
      hk_rank hprefix_pos hprob_nonneg hprob_sum hprevMass havailable_pos
      hw_not_previous hprev_le_Q hQ_pos hcard hmass_tail_le hpopular
      hcond_eq
      (paper_im05_lemma4_3_product_absence_probability
        (M := M) ν draw w)

/--
Lemma 4.3 Algorithm 4.2 prefix-set product route: specialize the one-man
state to the already-drawn prefix set and instantiate independent identical
draws across men.
-/
theorem
    paper_im05_lemma4_3_absence_probability_ge_rank_power_from_algorithm4_2_prefix_sets_product
    {M Λ W : Type*} [Fintype M] [DecidableEq M]
    [Fintype Λ] [DecidableEq Λ] [Fintype W] [DecidableEq W]
    {k : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    (tail : Finset W) (prob : W → ℝ)
    (Q : ℝ) (rank : ℕ)
    [∀ s, DecidablePred fun sample => im05_listPrefixOmits w s (draw sample)]
    (hk_rank : k < rank)
    (hprefix_pos : ∀ r, r < k →
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample)))
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_sum : ∑ u : W, prob u = 1)
    (hprev_le_Q : ∀ r, (hr : r < k) → ∀ previous : Finset W,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧
            im05_listPrefixSet r (draw sample) = previous) →
      (∑ u ∈ previous, prob u) ≤ Q)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u)
    (hcond_eq : ∀ r, (hr : r < k) → ∀ previous : Finset W, (hspos :
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧
            im05_listPrefixSet r (draw sample) = previous)) →
      (havailable_pos : 0 < EconCSLib.finiteAvailableWeight prob previous) →
      EconCSLib.pmfConditionalProb ν
          (fun sample =>
            im05_listPrefixOmits w r (draw sample) ∧
              im05_listPrefixSet r (draw sample) = previous)
          (fun sample => draw sample ⟨r, hr⟩ = w) =
        (EconCSLib.finiteWeightedPMFExcluding
          prob previous hprob_nonneg havailable_pos w).toReal) :
    (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ (Fintype.card M * k) ≤
      EconCSLib.pmfProb (EconCSLib.pmfProduct M Λ ν)
        (fun samples : M → Λ =>
          ∀ m : M, im05_listPrefixOmits w k (draw (samples m))) := by
  classical
  exact
    paper_im05_lemma4_3_all_men_absence_probability_ge_rank_power_from_one_man
      rank k (Fintype.card M) hk_rank
      (paper_im05_lemma4_3_one_man_omit_probability_ge_rank_power_from_algorithm4_2_prefix_sets
        ν draw w tail prob Q rank hk_rank hprefix_pos hprob_nonneg
        hprob_sum hprev_le_Q hQ_pos hcard hmass_tail_le
        hpopular hcond_eq)
      (paper_im05_lemma4_3_product_absence_probability
        (M := M) ν draw w)

/--
Lemma 4.3 power lift: if the probability that all `n*k` draws omit `w` is at
least the product lower bound using `p_w`, then the rank denominator gives the
paper's weaker product lower bound.
-/
theorem paper_im05_lemma4_3_absence_probability_ge_rank_power
    {absenceProb p Q : ℝ} (rank k n : ℕ)
    (hQ_pos : 0 < 1 - Q)
    (hk_rank : k < rank)
    (hp : p ≤ (1 - Q) / ((rank - k : ℕ) : ℝ))
    (habsolute :
      (1 - p / (1 - Q)) ^ (n * k) ≤ absenceProb) :
    (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ (n * k) ≤ absenceProb := by
  have hdenom_pos_nat : 0 < rank - k := Nat.sub_pos_of_lt hk_rank
  have hdenom_pos : 0 < ((rank - k : ℕ) : ℝ) := by
    exact_mod_cast hdenom_pos_nat
  have hdenom_ge_one : (1 : ℝ) ≤ ((rank - k : ℕ) : ℝ) := by
    exact_mod_cast (Nat.succ_le_iff.mpr hdenom_pos_nat)
  have hbase_nonneg : 0 ≤ 1 - 1 / ((rank - k : ℕ) : ℝ) := by
    rw [sub_nonneg]
    rw [div_le_one hdenom_pos]
    exact hdenom_ge_one
  have hbase :
      1 - 1 / ((rank - k : ℕ) : ℝ) ≤ 1 - p / (1 - Q) :=
    paper_im05_lemma4_3_single_draw_omit_lower_bound
      hQ_pos hdenom_pos hp
  exact le_trans (pow_le_pow_left₀ hbase_nonneg hbase (n * k)) habsolute

/--
Lemma 4.3 exponential product bound: when `rank > 2k`, the product lower bound
`(1 - 1/(rank-k))^(n*k)` is at least `exp(-2nk/(rank-k))`.
-/
theorem paper_im05_lemma4_3_rank_power_ge_exp_rank_minus_k
    (rank n k : ℕ)
    (hk_pos : 0 < k)
    (htwo_k : 2 * k < rank) :
    Real.exp
        (-(2 * (n : ℝ) * (k : ℝ) / ((rank - k : ℕ) : ℝ))) ≤
      (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ (n * k) := by
  have hdenom_two_nat : 2 ≤ rank - k := by omega
  have hdenom_two : (2 : ℝ) ≤ ((rank - k : ℕ) : ℝ) := by
    exact_mod_cast hdenom_two_nat
  have h :=
    EconCSLib.Math.exp_neg_two_mul_nat_div_le_one_sub_inv_pow_of_two_le
      (N := n * k) (x := ((rank - k : ℕ) : ℝ)) hdenom_two
  have harg :
      2 * ((n : ℝ) * (k : ℝ)) / ((rank - k : ℕ) : ℝ) =
        2 * (n : ℝ) * (k : ℝ) / ((rank - k : ℕ) : ℝ) := by
    ring
  simpa [Nat.cast_mul, harg] using h

/--
Lemma 4.3 exponent relaxation: the source's condition `rank > 2k` implies
`exp(-2nk/(rank-k)) >= exp(-4nk/rank)`.
-/
theorem paper_im05_lemma4_3_exp_rank_le_exp_rank_minus_k
    (rank n k : ℕ)
    (htwo_k : 2 * k < rank) :
    Real.exp (-(4 * (n : ℝ) * (k : ℝ) / (rank : ℝ))) ≤
      Real.exp
        (-(2 * (n : ℝ) * (k : ℝ) / ((rank - k : ℕ) : ℝ))) := by
  have hrank_pos_nat : 0 < rank := by omega
  have hk_rank : k < rank := by omega
  have hdenom_pos_nat : 0 < rank - k := Nat.sub_pos_of_lt hk_rank
  have hrank_pos : 0 < (rank : ℝ) := by
    exact_mod_cast hrank_pos_nat
  have hdenom_pos : 0 < ((rank - k : ℕ) : ℝ) := by
    exact_mod_cast hdenom_pos_nat
  refine Real.exp_le_exp.mpr ?_
  have htwice_nat : rank ≤ 2 * (rank - k) := by omega
  have htwice : (rank : ℝ) ≤ 2 * ((rank - k : ℕ) : ℝ) := by
    exact_mod_cast htwice_nat
  have hnum_nonneg : 0 ≤ 2 * (n : ℝ) * (k : ℝ) := by positivity
  have hdiv :
      2 * (n : ℝ) * (k : ℝ) / ((rank - k : ℕ) : ℝ) ≤
        4 * (n : ℝ) * (k : ℝ) / (rank : ℝ) := by
    rw [div_le_div_iff₀ hdenom_pos hrank_pos]
    have hmul := mul_le_mul_of_nonneg_left htwice hnum_nonneg
    nlinarith
  linarith

/--
Lemma 4.3 exponential wrapper from the rank-power product lower bound.
-/
theorem paper_im05_lemma4_3_absence_probability_ge_exp_rank_from_rank_power
    {absenceProb : ℝ} (rank k n : ℕ)
    (hk_pos : 0 < k)
    (htwo_k : 2 * k < rank)
    (hrank_power :
      (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ (n * k) ≤ absenceProb) :
    Real.exp (-(4 * (n : ℝ) * (k : ℝ) / (rank : ℝ))) ≤
      absenceProb :=
  le_trans
    (le_trans
      (paper_im05_lemma4_3_exp_rank_le_exp_rank_minus_k rank n k htwo_k)
      (paper_im05_lemma4_3_rank_power_ge_exp_rank_minus_k
        rank n k hk_pos htwo_k))
    hrank_power

/--
Lemma 4.3 source-route exponential wrapper: the per-draw deferred-decision
prefix bounds and the across-men independence identity imply the paper's
per-woman absence lower bound `exp(-4nk/rank)`.
-/
theorem paper_im05_lemma4_3_absence_probability_ge_exp_rank_from_prefix_bounds
    {Λ Ω : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype Ω] [DecidableEq Ω]
    (ν : PMF Λ) (prefixOmit : ℕ → Λ → Prop)
    (μ : PMF Ω) (absent : Ω → Prop)
    [∀ r, DecidablePred fun sample => prefixOmit r sample]
    [DecidablePred absent]
    (rank k n : ℕ)
    (hk_pos : 0 < k)
    (htwo_k : 2 * k < rank)
    (hzero : ∀ sample, prefixOmit 0 sample)
    (hnested : ∀ r, r < k →
      ∀ sample, prefixOmit (r + 1) sample → prefixOmit r sample)
    (hcond : ∀ r, r < k →
      1 - 1 / ((rank - k : ℕ) : ℝ) ≤
        EconCSLib.pmfConditionalProb ν
          (fun sample => prefixOmit r sample)
          (fun sample => prefixOmit (r + 1) sample))
    (hall :
      EconCSLib.pmfProb μ absent =
        (EconCSLib.pmfProb ν (fun sample => prefixOmit k sample)) ^ n) :
    Real.exp (-(4 * (n : ℝ) * (k : ℝ) / (rank : ℝ))) ≤
      EconCSLib.pmfProb μ absent := by
  have hk_rank : k < rank := by omega
  exact
    paper_im05_lemma4_3_absence_probability_ge_exp_rank_from_rank_power
      rank k n hk_pos htwo_k
      (paper_im05_lemma4_3_absence_probability_ge_rank_power_from_prefix_bounds
        ν prefixOmit μ absent rank k n hk_rank
        hzero hnested hcond hall)

/--
Lemma 4.3 source-route exponential wrapper for concrete list samples: per-slot
conditional hit upper bounds for the next list position imply the paper's
per-woman absence lower bound after the independence lift across men.
-/
theorem
    paper_im05_lemma4_3_absence_probability_ge_exp_rank_from_next_hit_bounds
    {Λ Ω W : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype Ω] [DecidableEq Ω] [DecidableEq W]
    {k : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    (μ : PMF Ω) (absent : Ω → Prop)
    [∀ s, DecidablePred fun sample => im05_listPrefixOmits w s (draw sample)]
    [DecidablePred absent]
    (rank n : ℕ)
    (hk_pos : 0 < k)
    (htwo_k : 2 * k < rank)
    (hprefix_pos : ∀ r, r < k →
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample)))
    (hhit : ∀ r, (hr : r < k) →
      EconCSLib.pmfConditionalProb ν
          (fun sample => im05_listPrefixOmits w r (draw sample))
          (fun sample => draw sample ⟨r, hr⟩ = w) ≤
        1 / ((rank - k : ℕ) : ℝ))
    (hall :
      EconCSLib.pmfProb μ absent =
        (EconCSLib.pmfProb ν
          (fun sample => im05_listPrefixOmits w k (draw sample))) ^ n) :
    Real.exp (-(4 * (n : ℝ) * (k : ℝ) / (rank : ℝ))) ≤
      EconCSLib.pmfProb μ absent := by
  have hk_rank : k < rank := by omega
  exact
    paper_im05_lemma4_3_absence_probability_ge_exp_rank_from_rank_power
      rank k n hk_pos htwo_k
      (paper_im05_lemma4_3_absence_probability_ge_rank_power_from_next_hit_bounds
        ν draw w μ absent rank n hk_rank hprefix_pos hhit hall)

/--
Lemma 4.3 source per-woman lower-bound wrapper: if the concrete random-list
construction gives the product lower bound using `p_w`, then the popularity
tail and `rank > 2k` imply `Pr[E_w] >= exp(-4nk/rank)`.
-/
theorem paper_im05_lemma4_3_absence_probability_ge_exp_rank_from_tail
    {W : Type*} (tail : Finset W) (prob : W → ℝ) (w : W) (Q : ℝ)
    {absenceProb : ℝ} (rank k n : ℕ)
    (hk_pos : 0 < k)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (htwo_k : 2 * k < rank)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u)
    (habsolute :
      (1 - prob w / (1 - Q)) ^ (n * k) ≤ absenceProb) :
    Real.exp (-(4 * (n : ℝ) * (k : ℝ) / (rank : ℝ))) ≤
      absenceProb := by
  have hk_rank : k < rank := by omega
  have hpower :
      (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ (n * k) ≤ absenceProb :=
    paper_im05_lemma4_3_absence_probability_ge_rank_power
      rank k n hQ_pos hk_rank
      (paper_im05_lemma4_3_popularity_rank_bound
        tail prob w Q rank k hcard hk_rank hmass_tail_le hpopular)
      habsolute
  exact le_trans
    (le_trans
      (paper_im05_lemma4_3_exp_rank_le_exp_rank_minus_k rank n k htwo_k)
      (paper_im05_lemma4_3_rank_power_ge_exp_rank_minus_k
        rank n k hk_pos htwo_k))
    hpower

/--
Lemma 4.3 summation core: once a tail block of women has a uniform lower bound
on the probability of being absent from all men's lists, the expected number of
absent women in the indexed prefix is at least tail-size times that lower
bound.
-/
theorem paper_im05_lemma4_3_expected_absent_count_lower_bound_from_tail
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (absent : I → Ω → Prop)
    [∀ ω, DecidablePred fun i => absent i ω]
    [∀ i, DecidablePred fun ω => absent i ω]
    (tail : Finset I) (rate lowerBound : ℝ)
    (hrate_nonneg : 0 ≤ rate)
    (hlower : lowerBound ≤ (tail.card : ℝ) * rate)
    (hprob : ∀ i ∈ tail,
      rate ≤ EconCSLib.pmfProb μ (fun ω => absent i ω)) :
    lowerBound ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => absent i ω).card : ℝ)) := by
  classical
  exact le_trans hlower
    (EconCSLib.pmfExp_card_filter_ge_card_mul_of_forall_mem_prob_ge
      μ (fun ω i => absent i ω) tail rate hrate_nonneg hprob)

/--
Lemma 4.3 paper endpoint: with a tail block large enough to contribute
`g / 2` women and per-woman absence probability at least `exp(-8nk/g)`, the
expected absent count has the lower bound used in the proof of Lemma 4.1.
-/
theorem paper_im05_lemma4_3_expected_absent_count_lower_bound
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (absent : I → Ω → Prop)
    [∀ ω, DecidablePred fun i => absent i ω]
    [∀ i, DecidablePred fun ω => absent i ω]
    (tail : Finset I) (g n k : ℕ)
    (hcard : (g : ℝ) / 2 ≤ (tail.card : ℝ))
    (hprob : ∀ i ∈ tail,
      Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤
        EconCSLib.pmfProb μ (fun ω => absent i ω)) :
    (g : ℝ) / 2 *
        Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => absent i ω).card : ℝ)) := by
  classical
  let rate : ℝ := Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ)))
  refine
    paper_im05_lemma4_3_expected_absent_count_lower_bound_from_tail
      μ absent tail rate
      ((g : ℝ) / 2 *
        Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))))
      (Real.exp_pos _).le
      ?_ ?_
  · exact mul_le_mul_of_nonneg_right hcard (Real.exp_pos _).le
  · intro i hi
    simpa [rate] using hprob i hi

/--
Corrected Lemma 4.3 summation core for the repaired Lemma 4.4 route: count
