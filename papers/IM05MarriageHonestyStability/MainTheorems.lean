/--
Experiment 2 occupancy identification for a supplied `k`-slot-per-man naming
assignment: the reciprocal empty-count expectation is the occupancy expectation
`Y_{kn,n}` after relabeling men-slots and women to standard finite types.
-/
theorem paper_im05_experiment2_expectation_eq_occupancy
    {M W : Type*} [Fintype M] [DecidableEq M]
    [Fintype W] [DecidableEq W] [Nonempty W]
    (k n : ℕ) [NeZero n]
    (eBalls : M × Fin k ≃ Fin (k * n))
    (eWomen : W ≃ Fin n) :
    im05_reciprocalCountExpectation
        (EconCSLib.occupancyPMF (M × Fin k) W)
        (fun names : M × Fin k → W =>
          im05_experiment2EmptyCount k names) =
      im05_occupancyReciprocalExpectation (k * n) n := by
  calc
    im05_reciprocalCountExpectation
        (EconCSLib.occupancyPMF (M × Fin k) W)
        (fun names : M × Fin k → W =>
          im05_experiment2EmptyCount k names) =
        EconCSLib.occupancyReciprocalExpectation (M × Fin k) W := by
          rfl
    _ = EconCSLib.occupancyReciprocalExpectation (M × Fin k) (Fin n) :=
        EconCSLib.occupancyReciprocalExpectation_bin_equiv
          (Ball := M × Fin k) eWomen
    _ = EconCSLib.occupancyReciprocalExpectation (Fin (k * n)) (Fin n) :=
        EconCSLib.occupancyReciprocalExpectation_domain_equiv
          (Bin := Fin n) eBalls
    _ = im05_occupancyReciprocalExpectation (k * n) n := rfl

/--
Experiment 2 occupancy identification from cardinalities alone.
-/
theorem paper_im05_experiment2_expectation_eq_occupancy_of_card
    {M W : Type*} [Fintype M] [DecidableEq M]
    [Fintype W] [DecidableEq W] [Nonempty W]
    (k n : ℕ) [NeZero n]
    (hM : Fintype.card M = n)
    (hW : Fintype.card W = n) :
    im05_reciprocalCountExpectation
        (EconCSLib.occupancyPMF (M × Fin k) W)
        (fun names : M × Fin k → W =>
          im05_experiment2EmptyCount k names) =
      im05_occupancyReciprocalExpectation (k * n) n := by
  classical
  have hBalls : Fintype.card (M × Fin k) = k * n := by
    rw [Fintype.card_prod, Fintype.card_fin, hM, Nat.mul_comm]
  exact paper_im05_experiment2_expectation_eq_occupancy
    (M := M) (W := W) k n
    (Fintype.equivFinOfCardEq hBalls)
    (Fintype.equivFinOfCardEq hW)

/--
Experiment 2-to-3 deterministic equality core: if the two coupled experiments
name exactly the same set of women in an outcome, their unnamed-women counts
are equal in that outcome.
-/
theorem paper_im05_experiment2_3_empty_count_eq_of_usedBins_eq
    {Ω Slot₂ Slot₃ W : Type*}
    [Fintype Slot₂] [Fintype Slot₃] [Fintype W] [DecidableEq W]
    (names₂ : Ω → Slot₂ → W) (names₃ : Ω → Slot₃ → W)
    (hused : ∀ ω,
      EconCSLib.occupancyUsedBins (names₂ ω) =
        EconCSLib.occupancyUsedBins (names₃ ω)) :
    ∀ ω,
      (EconCSLib.occupancyEmptyBins (names₂ ω)).card =
        (EconCSLib.occupancyEmptyBins (names₃ ω)).card := by
  intro ω
  exact EconCSLib.occupancyEmptyBins_card_eq_of_usedBins_eq
    (names₂ ω) (names₃ ω) (hused ω)

/--
Experiment 2-to-3 reciprocal-expectation equality from a coupling with the same
used-women set outcome by outcome.
-/
theorem paper_im05_experiment2_3_reciprocal_expectation_eq_of_usedBins_eq
    {Ω Slot₂ Slot₃ W : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype Slot₂] [Fintype Slot₃] [Fintype W] [DecidableEq W]
