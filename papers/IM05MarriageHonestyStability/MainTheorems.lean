/--
Lemma 6.2, Experiment 1-to-2 deterministic core: the number of single women in
a stable matching is at least the number of women named by no man.
-/
theorem paper_im05_experiment1_2_absent_card_le_single_count
    {M W : Type*} [Fintype W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (mu : Assignment M W)
    (hstable : im05_stable_matching val_m val_w mu) :
    (im05_absentWomen val_m).card ≤ (im05_singleWomen mu).card :=
  Finset.card_le_card
    (im05_absentWomen_subset_singleWomen_of_stable
      val_m val_w mu hstable)

/--
Lemma 6.2 experiment-chain algebra: once the five random experiments in the
paper satisfy the stated monotonicity, equality, perturbation, and occupancy
identification relations, the paper's reciprocal-singles bound follows.
-/
theorem paper_im05_lemma6_2_experiment_chain
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (X X₂ X₃ X₄ X₅ : Ω → ℕ)
    (k n : ℕ) [NeZero n]
    (h12 : ∀ ω, X₂ ω ≤ X ω)
    (h23 : ∀ ω, X₂ ω = X₃ ω)
    (h34 :
      im05_reciprocalCountExpectation μ X₃ ≤
        im05_reciprocalCountExpectation μ X₄ + (k : ℝ) ^ 2 / (n : ℝ))
    (h45 : ∀ ω, X₅ ω ≤ X₄ ω)
    (h5 :
      im05_reciprocalCountExpectation μ X₅ =
        im05_occupancyReciprocalExpectation ((k + 1) * n) n) :
    im05_reciprocalCountExpectation μ X ≤
      im05_occupancyReciprocalExpectation ((k + 1) * n) n +
        (k : ℝ) ^ 2 / (n : ℝ) := by
  have h12E :
      im05_reciprocalCountExpectation μ X ≤
        im05_reciprocalCountExpectation μ X₂ := by
    simpa [im05_reciprocalCountExpectation] using
      EconCSLib.pmfExpReciprocalSucc_mono_of_forall_ge μ X X₂ h12
  have h23E :
      im05_reciprocalCountExpectation μ X₂ =
        im05_reciprocalCountExpectation μ X₃ := by
    simpa [im05_reciprocalCountExpectation] using
      EconCSLib.pmfExpReciprocalSucc_congr μ X₂ X₃ h23
  have h45E :
      im05_reciprocalCountExpectation μ X₄ ≤
        im05_reciprocalCountExpectation μ X₅ := by
    simpa [im05_reciprocalCountExpectation] using
      EconCSLib.pmfExpReciprocalSucc_mono_of_forall_ge μ X₄ X₅ h45
  calc
    im05_reciprocalCountExpectation μ X ≤
        im05_reciprocalCountExpectation μ X₂ := h12E
    _ = im05_reciprocalCountExpectation μ X₃ := h23E
    _ ≤ im05_reciprocalCountExpectation μ X₄ +
          (k : ℝ) ^ 2 / (n : ℝ) := h34
    _ ≤ im05_reciprocalCountExpectation μ X₅ +
          (k : ℝ) ^ 2 / (n : ℝ) :=
        add_le_add h45E le_rfl
    _ = im05_occupancyReciprocalExpectation ((k + 1) * n) n +
          (k : ℝ) ^ 2 / (n : ℝ) := by
        rw [h5]

/--
Lemma 6.2 perturbation core: if Experiments 3 and 4 have the same unnamed
count on the good event `E`, and the bad event has probability at most
`k^2 / n`, then the reciprocal-expectation loss is at most `k^2 / n`.
-/
theorem paper_im05_lemma6_2_perturbation_from_bad_event
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (X₃ X₄ : Ω → ℕ) (good : Ω → Prop)
    [DecidablePred good]
    (k n : ℕ) [NeZero n]
    (heq : ∀ ω, good ω → X₃ ω = X₄ ω)
    (hbad :
      EconCSLib.pmfProb μ (fun ω => ¬ good ω) ≤
        (k : ℝ) ^ 2 / (n : ℝ)) :
    im05_reciprocalCountExpectation μ X₃ ≤
      im05_reciprocalCountExpectation μ X₄ + (k : ℝ) ^ 2 / (n : ℝ) := by
  have hpert :=
    EconCSLib.pmfExpReciprocalSucc_le_add_prob_of_eq_on_event
      μ X₃ X₄ good heq
  calc
    im05_reciprocalCountExpectation μ X₃ ≤
        im05_reciprocalCountExpectation μ X₄ +
          EconCSLib.pmfProb μ (fun ω => ¬ good ω) := by
          simpa [im05_reciprocalCountExpectation] using hpert
    _ ≤ im05_reciprocalCountExpectation μ X₄ + (k : ℝ) ^ 2 / (n : ℝ) :=
        by
          have h := add_le_add_left hbad (im05_reciprocalCountExpectation μ X₄)
          simpa [add_comm] using h

/--
Lemma 6.2 perturbation union-bound component: if each indexed bad event has
probability at most `eps`, then the probability that some bad event occurs is
at most the number of indexed events times `eps`.

This is the paper's route for bounding the complement of the event `E` in
Experiment 3, before instantiating the index type with the redundant draw pairs
for all men.
-/
theorem paper_im05_lemma6_2_union_bound_pairs
    {Ω Pair : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype Pair]
    (μ : PMF Ω) (badPair : Pair → Ω → Prop)
    [DecidablePred fun ω => ∃ pair, badPair pair ω]
    [∀ pair, DecidablePred (badPair pair)]
    (eps : ℝ)
    (hbad : ∀ pair, EconCSLib.pmfProb μ (badPair pair) ≤ eps) :
    EconCSLib.pmfProb μ (fun ω => ∃ pair, badPair pair ω) ≤
      (Fintype.card Pair : ℝ) * eps := by
  exact EconCSLib.pmfProb_exists_le_card_mul μ badPair eps hbad

/--
Lemma 6.2 perturbation via the paper's union-bound route.  If every failure of
the good event produces one indexed bad pair, every indexed bad pair has
probability at most `eps`, and the resulting union-bound count is at most
`k^2 / n`, then the Experiment 3-to-4 expectation loss is at most `k^2 / n`.
-/
theorem paper_im05_lemma6_2_perturbation_from_union_bound
    {Ω Pair : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype Pair]
    (μ : PMF Ω) (X₃ X₄ : Ω → ℕ) (good : Ω → Prop)
    [DecidablePred good]
    (badPair : Pair → Ω → Prop)
    [DecidablePred fun ω => ∃ pair, badPair pair ω]
    [∀ pair, DecidablePred (badPair pair)]
    (eps : ℝ) (k n : ℕ) [NeZero n]
    (heq : ∀ ω, good ω → X₃ ω = X₄ ω)
    (hbad_subset : ∀ ω, ¬ good ω → ∃ pair, badPair pair ω)
    (hbad_pair : ∀ pair, EconCSLib.pmfProb μ (badPair pair) ≤ eps)
    (hcount : (Fintype.card Pair : ℝ) * eps ≤ (k : ℝ) ^ 2 / (n : ℝ)) :
    im05_reciprocalCountExpectation μ X₃ ≤
      im05_reciprocalCountExpectation μ X₄ + (k : ℝ) ^ 2 / (n : ℝ) := by
  have hbad_event :
      EconCSLib.pmfProb μ (fun ω => ¬ good ω) ≤
        (k : ℝ) ^ 2 / (n : ℝ) := by
    calc
      EconCSLib.pmfProb μ (fun ω => ¬ good ω) ≤
          EconCSLib.pmfProb μ (fun ω => ∃ pair, badPair pair ω) :=
          EconCSLib.pmfProb_le_of_imp μ
            (fun ω => ¬ good ω)
            (fun ω => ∃ pair, badPair pair ω)
            hbad_subset
      _ ≤ (Fintype.card Pair : ℝ) * eps :=
          paper_im05_lemma6_2_union_bound_pairs μ badPair eps hbad_pair
      _ ≤ (k : ℝ) ^ 2 / (n : ℝ) := hcount
  exact paper_im05_lemma6_2_perturbation_from_bad_event
    μ X₃ X₄ good k n heq hbad_event

/-- Cardinality of the exact redundant-pair index used in Lemma 6.2. -/
theorem paper_im05_lemma6_2_redundantPairIndex_card
    (M : Type*) [Fintype M] (k : ℕ) :
    Fintype.card (im05_redundantPairIndex M k) =
      Fintype.card M * (k + 2).choose 2 := by
  unfold im05_redundantPairIndex im05_redundantProposalPair
  rw [Fintype.card_prod, Sym2.card_subtype_not_diag, Fintype.card_fin]

/--
Non-redundant proposal slots inject into the set of women used by the draw
prefix.
-/
theorem im05_nonredundant_slots_card_le_usedBins
    {W : Type*} [DecidableEq W] {T : ℕ} (draw : Fin T → W) :
    ((Finset.univ : Finset (Fin T)) \ im05_redundantSlots draw).card ≤
      (EconCSLib.occupancyUsedBins draw).card := by
  classical
  refine Finset.card_le_card_of_injOn draw ?_ ?_
  · intro slot _hslot
    exact Finset.mem_image.mpr ⟨slot, Finset.mem_univ _, rfl⟩
  · intro a ha b hb hdraw
    by_cases hab : a = b
    · exact hab
    · rcases lt_or_gt_of_ne hab with hlt | hgt
      · have hbNot : b ∉ im05_redundantSlots draw :=
          (Finset.mem_sdiff.mp hb).2
        have hbRed : b ∈ im05_redundantSlots draw := by
          simp [im05_redundantSlots, im05_redundantSlot]
          exact ⟨a, hlt, hdraw⟩
        exact False.elim (hbNot hbRed)
      · have haNot : a ∉ im05_redundantSlots draw :=
          (Finset.mem_sdiff.mp ha).2
        have haRed : a ∈ im05_redundantSlots draw := by
          simp [im05_redundantSlots, im05_redundantSlot]
          exact ⟨b, hgt, hdraw.symm⟩
        exact False.elim (haNot haRed)

/--
Non-redundant proposal slots are exactly first appearances in the ordered draw
prefix.
-/
theorem im05_nonredundant_slots_eq_firstHitBalls
    {W : Type*} [DecidableEq W] {T : ℕ} (draw : Fin T → W) :
    ((Finset.univ : Finset (Fin T)) \ im05_redundantSlots draw) =
      EconCSLib.occupancyFirstHitBalls draw := by
  classical
  ext slot
  constructor
  · intro hslot
    have hnot : slot ∉ im05_redundantSlots draw :=
      (Finset.mem_sdiff.mp hslot).2
    have hfirst : EconCSLib.occupancyFirstHit draw slot := by
      intro earlier hearlier hsame
      apply hnot
      simp [im05_redundantSlots, im05_redundantSlot]
      exact ⟨earlier, hearlier, hsame⟩
    exact Finset.mem_filter.mpr ⟨Finset.mem_univ slot, hfirst⟩
  · intro hslot
    have hfirst : EconCSLib.occupancyFirstHit draw slot := by
      simpa [EconCSLib.occupancyFirstHitBalls] using hslot
    refine Finset.mem_sdiff.mpr ⟨Finset.mem_univ slot, ?_⟩
    intro hred
    have hred' : im05_redundantSlot draw slot := by
      simpa [im05_redundantSlots] using hred
    rcases hred' with ⟨earlier, hearlier, hsame⟩
    exact hfirst earlier hearlier hsame

/--
Every used woman in a finite draw prefix is hit at a non-redundant slot: take
the first slot at which that woman appears.
-/
theorem im05_nonredundant_slots_image_eq_usedBins
    {W : Type*} [DecidableEq W] {T : ℕ} (draw : Fin T → W) :
    (((Finset.univ : Finset (Fin T)) \ im05_redundantSlots draw).image draw) =
      EconCSLib.occupancyUsedBins draw := by
  rw [im05_nonredundant_slots_eq_firstHitBalls draw]
  exact EconCSLib.occupancyFirstHitBalls_image_eq_usedBins draw

/--
The number of used women in a finite draw prefix is exactly the number of
non-redundant slots, i.e. first appearances.
-/
theorem im05_nonredundant_slots_card_eq_usedBins
    {W : Type*} [DecidableEq W] {T : ℕ} (draw : Fin T → W) :
    ((Finset.univ : Finset (Fin T)) \ im05_redundantSlots draw).card =
      (EconCSLib.occupancyUsedBins draw).card := by
  rw [im05_nonredundant_slots_eq_firstHitBalls draw]
  exact EconCSLib.occupancyFirstHitBalls_card_eq_usedBins draw

/--
Lemma 6.2's union bound over the source's exact redundant-pair index:
men times unordered distinct pairs of proposal positions among `{1, ..., k+2}`.
-/
theorem paper_im05_lemma6_2_redundant_pair_union_bound
    {Ω M : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype M]
    (μ : PMF Ω)
    (badPair : im05_redundantPairIndex M k → Ω → Prop)
    [DecidablePred fun ω => ∃ pair, badPair pair ω]
    [∀ pair, DecidablePred (badPair pair)]
    (eps : ℝ)
    (hbad :
      ∀ pair, EconCSLib.pmfProb μ (badPair pair) ≤ eps) :
    EconCSLib.pmfProb μ (fun ω => ∃ pair, badPair pair ω) ≤
      (Fintype.card M * (k + 2).choose 2 : ℕ) * eps := by
  have h :=
    paper_im05_lemma6_2_union_bound_pairs μ badPair eps hbad
  have hcard := paper_im05_lemma6_2_redundantPairIndex_card M k
  rw [hcard] at h
  simpa [Nat.cast_mul] using h

/--
If the first `k+2` draws use at most `k` distinct women, at least two proposal
slots are redundant.
-/
theorem paper_im05_lemma6_2_two_redundant_slots_of_usedBins_card_le
    {W : Type*} [DecidableEq W]
    (k : ℕ) (draw : Fin (k + 2) → W)
    (hused : (EconCSLib.occupancyUsedBins draw).card ≤ k) :
    2 ≤ (im05_redundantSlots draw).card := by
  classical
  let redundant : Finset (Fin (k + 2)) := im05_redundantSlots draw
  let nonredundant : Finset (Fin (k + 2)) :=
    (Finset.univ : Finset (Fin (k + 2))) \ redundant
  have hnonred_le_used : nonredundant.card ≤
      (EconCSLib.occupancyUsedBins draw).card := by
    simpa [nonredundant, redundant] using
      im05_nonredundant_slots_card_le_usedBins draw
  have hnonred_le_k : nonredundant.card ≤ k :=
    le_trans hnonred_le_used hused
  have hsubset : redundant ⊆ (Finset.univ : Finset (Fin (k + 2))) := by
    intro slot _hslot
    simp
  have hsum :
      nonredundant.card + redundant.card = k + 2 := by
    have h :=
      Finset.card_sdiff_add_card_eq_card (s := redundant)
        (t := (Finset.univ : Finset (Fin (k + 2)))) hsubset
    simpa [nonredundant, redundant, Fintype.card_fin] using h
  have hred_ge : 2 ≤ redundant.card := by
    omega
  simpa [redundant] using hred_ge

/--
The converse pigeonhole direction: two redundant slots in a `k+2` prefix force
at most `k` distinct used women.
-/
theorem paper_im05_lemma6_2_usedBins_card_le_of_two_redundant_slots
    {W : Type*} [DecidableEq W]
    (k : ℕ) (draw : Fin (k + 2) → W)
    (htwo : 2 ≤ (im05_redundantSlots draw).card) :
    (EconCSLib.occupancyUsedBins draw).card ≤ k := by
  classical
  have htotal :
      (((Finset.univ : Finset (Fin (k + 2))) \
            im05_redundantSlots draw).card) +
          (im05_redundantSlots draw).card =
        k + 2 := by
    rw [Finset.card_sdiff_add_card_eq_card
      (s := im05_redundantSlots draw)
      (t := (Finset.univ : Finset (Fin (k + 2))))]
    · simp [Fintype.card_fin]
    · intro slot _hslot
      simp
  have hnonred_le :
      (((Finset.univ : Finset (Fin (k + 2))) \
            im05_redundantSlots draw).card) ≤ k := by
    omega
  have hcard_eq := im05_nonredundant_slots_card_eq_usedBins draw
  rwa [hcard_eq] at hnonred_le

/--
The Experiment 3 bad-prefix event is exactly the existence of a man with two
redundant slots in his first `k+2` draw prefix.
-/
theorem paper_im05_lemma6_2_bad_draw_event_iff_exists_two_redundant_slots
    {M W : Type*} [DecidableEq W]
    (k : ℕ) (draws : M → Fin (k + 2) → W) :
    im05_experiment3BadDrawEvent k draws ↔
      ∃ m : M, 2 ≤ (im05_redundantSlots (draws m)).card := by
  constructor
  · rintro ⟨m, hused⟩
    exact ⟨m,
      paper_im05_lemma6_2_two_redundant_slots_of_usedBins_card_le
        k (draws m) hused⟩
  · rintro ⟨m, htwo⟩
    exact ⟨m,
      paper_im05_lemma6_2_usedBins_card_le_of_two_redundant_slots
        k (draws m) htwo⟩

/--
Deterministic pigeonhole step for Lemma 6.2: if at least two proposal slots are
redundant in the first `k+2` draws, then one of the paper's unordered slot-pair
bad events occurs.
-/
theorem paper_im05_lemma6_2_redundant_pair_exists_of_two_redundant_slots
    {W : Type*} [DecidableEq W]
    (k : ℕ) (draw : Fin (k + 2) → W)
    (htwo : 2 ≤ (im05_redundantSlots draw).card) :
    ∃ pair : im05_redundantProposalPair k,
      im05_redundantPairEvent k draw pair := by
  classical
  have hone : 1 < (im05_redundantSlots draw).card :=
    lt_of_lt_of_le (by norm_num) htwo
  rcases Finset.one_lt_card.mp hone with ⟨a, ha, b, hb, hne⟩
  have haRed : im05_redundantSlot draw a := by
    simpa [im05_redundantSlots] using ha
  have hbRed : im05_redundantSlot draw b := by
    simpa [im05_redundantSlots] using hb
  refine ⟨⟨s(a, b), ?_⟩, ?_⟩
  · intro hdiag
    have hab : a = b := by
      simpa [Sym2.mk_isDiag_iff] using hdiag
    exact hne hab
  · intro slot hslot
    have hslot' : slot = a ∨ slot = b := by
      simpa [Sym2.toFinset_mk_eq] using hslot
    rcases hslot' with rfl | rfl
    · exact haRed
    · exact hbRed

/--
Conversely, any redundant-pair event gives two redundant proposal slots.
-/
theorem paper_im05_lemma6_2_two_redundant_slots_of_redundant_pair_event
    {W : Type*} [DecidableEq W]
    (k : ℕ) (draw : Fin (k + 2) → W)
    (pair : im05_redundantProposalPair k)
    (hpair : im05_redundantPairEvent k draw pair) :
    2 ≤ (im05_redundantSlots draw).card := by
  classical
  have hsubset : pair.1.toFinset ⊆ im05_redundantSlots draw := by
    intro slot hslot
    have hred : im05_redundantSlot draw slot := hpair slot hslot
    simpa [im05_redundantSlots] using hred
  have hcard : pair.1.toFinset.card = 2 := by
    rw [Sym2.card_toFinset]
    simp [pair.2]
  have hle := Finset.card_le_card hsubset
  simpa [hcard] using hle

/--
If an indexed redundant-pair event occurs in a man's first `k+2` draws, then
that prefix uses at most `k` distinct women.
-/
theorem paper_im05_lemma6_2_usedBins_card_le_of_redundant_pair_event
    {W : Type*} [DecidableEq W]
    (k : ℕ) (draw : Fin (k + 2) → W)
    (pair : im05_redundantProposalPair k)
    (hpair : im05_redundantPairEvent k draw pair) :
    (EconCSLib.occupancyUsedBins draw).card ≤ k := by
  have hred_ge :
      2 ≤ (im05_redundantSlots draw).card :=
    paper_im05_lemma6_2_two_redundant_slots_of_redundant_pair_event
      k draw pair hpair
  exact paper_im05_lemma6_2_usedBins_card_le_of_two_redundant_slots
    k draw hred_ge

/--
Deterministic bridge from failure of the good event to the union-bound event:
if every bad outcome has some man with at least two redundant proposal slots in
his first `k+2` draws, then some indexed redundant-pair bad event occurs.
-/
theorem paper_im05_lemma6_2_bad_event_subset_redundant_pair_events
    {Ω M W : Type*} [DecidableEq W]
    (k : ℕ) (draws : Ω → M → Fin (k + 2) → W)
    (good : Ω → Prop)
    (hbad_man :
      ∀ ω, ¬ good ω →
        ∃ m : M, 2 ≤ (im05_redundantSlots (draws ω m)).card) :
    ∀ ω, ¬ good ω →
      ∃ idx : im05_redundantPairIndex M k,
        im05_redundantPairBadEvent k draws idx ω := by
  intro ω hnot
  rcases hbad_man ω hnot with ⟨m, htwo⟩
  rcases paper_im05_lemma6_2_redundant_pair_exists_of_two_redundant_slots
      k (draws ω m) htwo with ⟨pair, hpair⟩
  exact ⟨(m, pair), hpair⟩

/--
Bad-event subset bridge in the paper's distinct-name language: if every failure
of `E` has some man whose first `k+2` draws use at most `k` distinct women, then
one indexed redundant-pair bad event occurs.
-/
theorem paper_im05_lemma6_2_bad_event_subset_redundant_pair_events_of_usedBins
    {Ω M W : Type*} [DecidableEq W]
    (k : ℕ) (draws : Ω → M → Fin (k + 2) → W)
    (good : Ω → Prop)
    (hbad_man :
      ∀ ω, ¬ good ω →
        ∃ m : M, (EconCSLib.occupancyUsedBins (draws ω m)).card ≤ k) :
    ∀ ω, ¬ good ω →
      ∃ idx : im05_redundantPairIndex M k,
        im05_redundantPairBadEvent k draws idx ω := by
  refine paper_im05_lemma6_2_bad_event_subset_redundant_pair_events
    k draws good ?_
  intro ω hnot
  rcases hbad_man ω hnot with ⟨m, hused⟩
  exact ⟨m,
    paper_im05_lemma6_2_two_redundant_slots_of_usedBins_card_le
      k (draws ω m) hused⟩

/--
Concrete draw-prefix version of the deterministic bad-event bridge in Lemma
6.2: if a man has at most `k` distinct women in his first `k+2` amnesiac draws,
then one of the paper's indexed redundant-pair events occurs.
-/
theorem paper_im05_lemma6_2_bad_draw_event_subset_redundant_pair_events
    {M W : Type*} [DecidableEq W]
    (k : ℕ) (draws : M → Fin (k + 2) → W) :
    im05_experiment3BadDrawEvent k draws →
      ∃ idx : im05_redundantPairIndex M k,
        im05_redundantPairEvent k (draws idx.1) idx.2 := by
  rintro ⟨m, hused⟩
  rcases paper_im05_lemma6_2_redundant_pair_exists_of_two_redundant_slots k
      (draws m)
      (paper_im05_lemma6_2_two_redundant_slots_of_usedBins_card_le
        k (draws m) hused) with ⟨pair, hpair⟩
  exact ⟨(m, pair), hpair⟩

/--
The reverse deterministic bridge: an indexed redundant-pair event forces the
Experiment 3 prefix bad event.
-/
theorem paper_im05_lemma6_2_redundant_pair_event_subset_bad_draw_event
    {M W : Type*} [DecidableEq W]
    (k : ℕ) (draws : M → Fin (k + 2) → W)
    (idx : im05_redundantPairIndex M k) :
    im05_redundantPairEvent k (draws idx.1) idx.2 →
      im05_experiment3BadDrawEvent k draws := by
  intro hidx
  exact ⟨idx.1,
    paper_im05_lemma6_2_usedBins_card_le_of_redundant_pair_event
      k (draws idx.1) idx.2 hidx⟩

/--
Concrete first-`k+2` prefix characterization: the Experiment 3 bad draw event
is exactly the existence of one of the paper's indexed redundant-pair events.
-/
theorem paper_im05_lemma6_2_bad_draw_event_iff_exists_redundant_pair_event
    {M W : Type*} [DecidableEq W]
    (k : ℕ) (draws : M → Fin (k + 2) → W) :
    im05_experiment3BadDrawEvent k draws ↔
      ∃ idx : im05_redundantPairIndex M k,
        im05_redundantPairEvent k (draws idx.1) idx.2 := by
  constructor
  · exact paper_im05_lemma6_2_bad_draw_event_subset_redundant_pair_events
      k draws
  · rintro ⟨idx, hidx⟩
    exact paper_im05_lemma6_2_redundant_pair_event_subset_bad_draw_event
      k draws idx hidx

/--
Probability-level form of the concrete bad-prefix characterization.
-/
theorem paper_im05_lemma6_2_bad_draw_event_prob_eq_redundant_pair_exists
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [DecidableEq W]
    (μ : PMF Ω) (k : ℕ) (draws : Ω → M → Fin (k + 2) → W)
    [DecidablePred fun ω => im05_experiment3BadDrawEvent k (draws ω)]
    [DecidablePred fun ω =>
      ∃ idx : im05_redundantPairIndex M k,
        im05_redundantPairBadEvent k draws idx ω] :
    EconCSLib.pmfProb μ
        (fun ω => im05_experiment3BadDrawEvent k (draws ω)) =
      EconCSLib.pmfProb μ
        (fun ω =>
          ∃ idx : im05_redundantPairIndex M k,
            im05_redundantPairBadEvent k draws idx ω) := by
  classical
  unfold EconCSLib.pmfProb
  refine EconCSLib.pmfExp_congr μ ?_
  intro ω
  have hiff :
      im05_experiment3BadDrawEvent k (draws ω) ↔
        ∃ idx : im05_redundantPairIndex M k,
          im05_redundantPairBadEvent k draws idx ω := by
    simpa [im05_redundantPairBadEvent] using
      paper_im05_lemma6_2_bad_draw_event_iff_exists_redundant_pair_event
        k (draws ω)
  by_cases hbad : im05_experiment3BadDrawEvent k (draws ω)
  · have hexists := hiff.1 hbad
    simp [hbad, hexists]
  · have hnexists :
        ¬ ∃ idx : im05_redundantPairIndex M k,
          im05_redundantPairBadEvent k draws idx ω := fun hexists =>
        hbad (hiff.2 hexists)
    simp [hbad, hnexists]

/--
Union-bound form for the concrete Experiment 3 bad-prefix event.
-/
theorem paper_im05_lemma6_2_bad_draw_event_prob_le_card_mul
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype M]
    [DecidableEq W]
    (μ : PMF Ω) (k : ℕ) (draws : Ω → M → Fin (k + 2) → W)
    [DecidablePred fun ω => im05_experiment3BadDrawEvent k (draws ω)]
    [DecidablePred fun ω =>
      ∃ idx : im05_redundantPairIndex M k,
        im05_redundantPairBadEvent k draws idx ω]
    [∀ idx, DecidablePred (im05_redundantPairBadEvent k draws idx)]
    (eps : ℝ)
    (hpair :
      ∀ idx,
        EconCSLib.pmfProb μ
          (im05_redundantPairBadEvent k draws idx) ≤ eps) :
    EconCSLib.pmfProb μ
        (fun ω => im05_experiment3BadDrawEvent k (draws ω)) ≤
      (Fintype.card (im05_redundantPairIndex M k) : ℝ) * eps := by
  calc
    EconCSLib.pmfProb μ
        (fun ω => im05_experiment3BadDrawEvent k (draws ω)) =
        EconCSLib.pmfProb μ
          (fun ω =>
            ∃ idx : im05_redundantPairIndex M k,
              im05_redundantPairBadEvent k draws idx ω) :=
          paper_im05_lemma6_2_bad_draw_event_prob_eq_redundant_pair_exists
            μ k draws
    _ ≤ (Fintype.card (im05_redundantPairIndex M k) : ℝ) * eps :=
        EconCSLib.pmfProb_exists_le_card_mul μ
          (fun idx ω => im05_redundantPairBadEvent k draws idx ω)
          eps hpair

/--
Algebraic count bound behind Lemma 6.2's negligible perturbation estimate. The
source uses the coarse comparison `choose(k+2, 2) <= k^2`; it is kept explicit
because that inequality is a separate arithmetic side condition.
-/
theorem paper_im05_lemma6_2_redundant_pair_count_bound
    (M : Type*) [Fintype M] (k n : ℕ) [NeZero n]
    (hcardM : Fintype.card M = n)
    (hchoose : (((k + 2).choose 2 : ℕ) : ℝ) ≤ (k : ℝ) ^ 2) :
    (Fintype.card (im05_redundantPairIndex M k) : ℝ) *
        (n : ℝ)⁻¹ ^ 2 ≤
      (k : ℝ) ^ 2 / (n : ℝ) := by
  have hnpos : 0 < (n : ℝ) := by
    exact_mod_cast (NeZero.pos n)
  calc
    (Fintype.card (im05_redundantPairIndex M k) : ℝ) *
        (n : ℝ)⁻¹ ^ 2 =
        ((n : ℝ) * (((k + 2).choose 2 : ℕ) : ℝ)) *
          (n : ℝ)⁻¹ ^ 2 := by
          rw [paper_im05_lemma6_2_redundantPairIndex_card, hcardM]
          norm_num [Nat.cast_mul]
    _ = (((k + 2).choose 2 : ℕ) : ℝ) / (n : ℝ) := by
          field_simp [ne_of_gt hnpos]
    _ ≤ (k : ℝ) ^ 2 / (n : ℝ) :=
          div_le_div_of_nonneg_right hchoose (le_of_lt hnpos)

/--
The paper's coarse arithmetic comparison `choose(k+2,2) <= k^2` is valid once
`k >= 4`.  For smaller `k` it is not a theorem and should remain an explicit
side condition.
-/
theorem paper_im05_lemma6_2_choose_le_sq_of_four_le
    (k : ℕ) (hk : 4 ≤ k) :
    (((k + 2).choose 2 : ℕ) : ℝ) ≤ (k : ℝ) ^ 2 := by
  rw [Nat.cast_choose_two ℝ (k + 2)]
  have hk_real : (4 : ℝ) ≤ k := by
    exact_mod_cast hk
  norm_num
  nlinarith

/-- Exact threshold for the paper's coarse `choose(k+2,2) <= k^2` comparison. -/
theorem paper_im05_lemma6_2_choose_le_sq_iff_four_le
    (k : ℕ) :
    ((((k + 2).choose 2 : ℕ) : ℝ) ≤ (k : ℝ) ^ 2) ↔ 4 ≤ k := by
  constructor
  · intro h
    by_contra hk
    have hk_le_three : k ≤ 3 := by omega
    interval_cases k <;> norm_num [Nat.choose_two_right] at h
  · exact paper_im05_lemma6_2_choose_le_sq_of_four_le k

/-- Count bound version using the valid range `k >= 4` for the paper's coarse
`choose(k+2,2) <= k^2` comparison. -/
theorem paper_im05_lemma6_2_redundant_pair_count_bound_of_four_le
    (M : Type*) [Fintype M] (k n : ℕ) [NeZero n]
    (hcardM : Fintype.card M = n) (hk : 4 ≤ k) :
    (Fintype.card (im05_redundantPairIndex M k) : ℝ) *
        (n : ℝ)⁻¹ ^ 2 ≤
      (k : ℝ) ^ 2 / (n : ℝ) :=
  paper_im05_lemma6_2_redundant_pair_count_bound M k n hcardM
    (paper_im05_lemma6_2_choose_le_sq_of_four_le k hk)

/--
Concrete bad-prefix probability bound after substituting the paper's index
cardinality and coarse `choose(k+2,2) <= k^2` comparison.
-/
theorem paper_im05_lemma6_2_bad_draw_event_prob_le_k_sq_div
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype M]
    [DecidableEq W]
    (μ : PMF Ω) (k n : ℕ) [NeZero n]
    (draws : Ω → M → Fin (k + 2) → W)
    [DecidablePred fun ω => im05_experiment3BadDrawEvent k (draws ω)]
    [DecidablePred fun ω =>
      ∃ idx : im05_redundantPairIndex M k,
        im05_redundantPairBadEvent k draws idx ω]
    [∀ idx, DecidablePred (im05_redundantPairBadEvent k draws idx)]
    (hcardM : Fintype.card M = n)
    (hchoose : (((k + 2).choose 2 : ℕ) : ℝ) ≤ (k : ℝ) ^ 2)
    (hpair :
      ∀ idx,
        EconCSLib.pmfProb μ
          (im05_redundantPairBadEvent k draws idx) ≤ (n : ℝ)⁻¹ ^ 2) :
    EconCSLib.pmfProb μ
        (fun ω => im05_experiment3BadDrawEvent k (draws ω)) ≤
      (k : ℝ) ^ 2 / (n : ℝ) := by
  calc
    EconCSLib.pmfProb μ
        (fun ω => im05_experiment3BadDrawEvent k (draws ω)) ≤
        (Fintype.card (im05_redundantPairIndex M k) : ℝ) *
          ((n : ℝ)⁻¹ ^ 2) :=
          paper_im05_lemma6_2_bad_draw_event_prob_le_card_mul
            μ k draws ((n : ℝ)⁻¹ ^ 2) hpair
    _ ≤ (k : ℝ) ^ 2 / (n : ℝ) :=
        paper_im05_lemma6_2_redundant_pair_count_bound
          M k n hcardM hchoose

/--
Lemma 6.2 probability primitive: two specified independent uniform draws hit
two prescribed women with probability `1/n^2`.

This is the correct reusable atom behind the paper's informal per-pair
`1/n^2` claim; the broader "both proposal positions are redundant" event still
needs a source-faithful reduction to prescribed coordinate values.
-/
theorem paper_im05_lemma6_2_prescribed_two_uniform_draws_prob
    {W : Type*} [Fintype W] [DecidableEq W] [Nonempty W]
    (n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n) (w₁ w₂ : W) :
    EconCSLib.pmfProb (EconCSLib.uniformPMF (W × W))
        (fun pair : W × W => pair.1 = w₁ ∧ pair.2 = w₂) =
      (n : ℝ)⁻¹ ^ 2 := by
  calc
    EconCSLib.pmfProb (EconCSLib.uniformPMF (W × W))
        (fun pair : W × W => pair.1 = w₁ ∧ pair.2 = w₂) =
        (Fintype.card W : ℝ)⁻¹ * (Fintype.card W : ℝ)⁻¹ := by
          exact EconCSLib.pmfProb_uniformPMF_prod_eq_pair w₁ w₂
    _ = (n : ℝ)⁻¹ ^ 2 := by
          rw [hcardW]
          ring

/--
First-`k+2` draw-prefix version of the same probability atom: two distinct
specified proposal slots hit two prescribed women with probability `1/n^2`.
-/
theorem paper_im05_lemma6_2_prescribed_two_draw_slots_prob
    {W : Type*} [Fintype W] [DecidableEq W] [Nonempty W]
    (k n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n)
    {i j : Fin (k + 2)} (hij : i ≠ j) (w₁ w₂ : W) :
    EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
        (fun draw : Fin (k + 2) → W => draw i = w₁ ∧ draw j = w₂) =
      (n : ℝ)⁻¹ ^ 2 := by
  calc
    EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
        (fun draw : Fin (k + 2) → W => draw i = w₁ ∧ draw j = w₂) =
        (Fintype.card W : ℝ)⁻¹ ^ 2 := by
          exact EconCSLib.pmfProb_uniformPMF_fun_eq_pair_of_ne
            (i := i) (j := j) hij w₁ w₂
    _ = (n : ℝ)⁻¹ ^ 2 := by
          rw [hcardW]

/--
Uncurried all-men draw-prefix version: for a fixed man and two distinct slots,
the two specified coordinates have prescribed values with probability `1/n^2`.
-/
theorem paper_im05_lemma6_2_prescribed_two_man_draw_slots_prob
    {M W : Type*} [Fintype M] [DecidableEq M]
    [Fintype W] [DecidableEq W] [Nonempty W]
    (k n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n) (m : M)
    {i j : Fin (k + 2)} (hij : i ≠ j) (w₁ w₂ : W) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF (M × Fin (k + 2) → W))
        (fun draws : M × Fin (k + 2) → W =>
          draws (m, i) = w₁ ∧ draws (m, j) = w₂) =
      (n : ℝ)⁻¹ ^ 2 := by
  have hcoord : (m, i) ≠ (m, j) := by
    intro h
    exact hij (Prod.ext_iff.mp h).2
  calc
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF (M × Fin (k + 2) → W))
        (fun draws : M × Fin (k + 2) → W =>
          draws (m, i) = w₁ ∧ draws (m, j) = w₂) =
        (Fintype.card W : ℝ)⁻¹ ^ 2 := by
          exact EconCSLib.pmfProb_uniformPMF_fun_eq_pair_of_ne
            (i := (m, i)) (j := (m, j)) hcoord w₁ w₂
    _ = (n : ℝ)⁻¹ ^ 2 := by
          rw [hcardW]

/--
First-`k+2` draw-prefix collision check: two distinct proposal slots collide
with probability `1/n`.
-/
theorem paper_im05_lemma6_2_two_draw_slots_collision_prob
    {W : Type*} [Fintype W] [DecidableEq W] [Nonempty W]
    (k n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n)
    {i j : Fin (k + 2)} (hij : i ≠ j) :
    EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
        (fun draw : Fin (k + 2) → W => draw i = draw j) =
      (n : ℝ)⁻¹ := by
  calc
    EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
        (fun draw : Fin (k + 2) → W => draw i = draw j) =
        (Fintype.card W : ℝ)⁻¹ := by
          exact EconCSLib.pmfProb_uniformPMF_fun_eq_of_ne
            (i := i) (j := j) hij
    _ = (n : ℝ)⁻¹ := by
          rw [hcardW]

/--
For a fixed proposal slot in an amnesiac draw prefix, the probability that it is
redundant is at most the number of earlier slots divided by `n`.
-/
theorem paper_im05_lemma6_2_redundantSlot_prob_le_earlier_count_div
    {W : Type*} [Fintype W] [DecidableEq W] [Nonempty W]
    (k n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n) (slot : Fin (k + 2))
    [DecidablePred fun draw : Fin (k + 2) → W =>
      im05_redundantSlot draw slot] :
    EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
        (fun draw : Fin (k + 2) → W => im05_redundantSlot draw slot) ≤
      (((Finset.univ : Finset (Fin (k + 2))).filter
          (fun earlier => earlier < slot)).card : ℝ) / (n : ℝ) := by
  classical
  let Earlier := {earlier : Fin (k + 2) // earlier < slot}
  let badEarlier : Earlier → (Fin (k + 2) → W) → Prop :=
    fun earlier draw => draw earlier.1 = draw slot
  have hsubset :
      ∀ draw : Fin (k + 2) → W,
        im05_redundantSlot draw slot → ∃ earlier : Earlier, badEarlier earlier draw := by
    intro draw hred
    rcases hred with ⟨earlier, hearlier, hsame⟩
    exact ⟨⟨earlier, hearlier⟩, hsame⟩
  have hbad :
      ∀ earlier : Earlier,
        EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
          (badEarlier earlier) ≤ (n : ℝ)⁻¹ := by
    intro earlier
    have hne : earlier.1 ≠ slot := by
      exact ne_of_lt earlier.2
    have hprob :
        EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
            (badEarlier earlier) =
          (n : ℝ)⁻¹ := by
      calc
        EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
            (badEarlier earlier) =
            (Fintype.card W : ℝ)⁻¹ := by
            exact EconCSLib.pmfProb_uniformPMF_fun_eq_of_ne
              (i := earlier.1) (j := slot) hne
        _ = (n : ℝ)⁻¹ := by
            rw [hcardW]
    exact le_of_eq hprob
  calc
    EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
        (fun draw : Fin (k + 2) → W => im05_redundantSlot draw slot) ≤
        EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
          (fun draw => ∃ earlier : Earlier, badEarlier earlier draw) :=
        EconCSLib.pmfProb_le_of_imp
          (EconCSLib.uniformPMF (Fin (k + 2) → W))
          (fun draw : Fin (k + 2) → W => im05_redundantSlot draw slot)
          (fun draw => ∃ earlier : Earlier, badEarlier earlier draw)
          hsubset
    _ ≤ (Fintype.card Earlier : ℝ) * (n : ℝ)⁻¹ :=
        paper_im05_lemma6_2_union_bound_pairs
          (EconCSLib.uniformPMF (Fin (k + 2) → W))
          badEarlier ((n : ℝ)⁻¹) hbad
    _ = (((Finset.univ : Finset (Fin (k + 2))).filter
          (fun earlier => earlier < slot)).card : ℝ) / (n : ℝ) := by
        have hcard :
            Fintype.card Earlier =
              ((Finset.univ : Finset (Fin (k + 2))).filter
                (fun earlier => earlier < slot)).card := by
          rw [Fintype.card_subtype]
        rw [hcard, div_eq_mul_inv]

/-- Cleaner redundant-slot probability bound using the slot's zero-indexed value. -/
theorem paper_im05_lemma6_2_redundantSlot_prob_le_slot_div
    {W : Type*} [Fintype W] [DecidableEq W] [Nonempty W]
    (k n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n) (slot : Fin (k + 2))
    [DecidablePred fun draw : Fin (k + 2) → W =>
      im05_redundantSlot draw slot] :
    EconCSLib.pmfProb (EconCSLib.uniformPMF (Fin (k + 2) → W))
        (fun draw : Fin (k + 2) → W => im05_redundantSlot draw slot) ≤
      (slot.val : ℝ) / (n : ℝ) := by
  simpa [im05_earlierSlots_card slot] using
    paper_im05_lemma6_2_redundantSlot_prob_le_earlier_count_div
      k n hcardW slot

/--
Companion check for Lemma 6.2: two independent uniform draws collide with
probability `1/n`, not `1/n^2`.  The paper's `1/n^2` perturbation step must
therefore be justified by a sharper prescribed-coordinate event, not by the
plain equality/collision event alone.
-/
theorem paper_im05_lemma6_2_two_uniform_draws_collision_prob
    {W : Type*} [Fintype W] [DecidableEq W] [Nonempty W]
    (n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n) :
    EconCSLib.pmfProb (EconCSLib.uniformPMF (W × W))
        (fun pair : W × W => pair.1 = pair.2) =
      (n : ℝ)⁻¹ := by
  calc
    EconCSLib.pmfProb (EconCSLib.uniformPMF (W × W))
        (fun pair : W × W => pair.1 = pair.2) =
        (Fintype.card W : ℝ)⁻¹ := by
          exact EconCSLib.pmfProb_uniformPMF_prod_eq_diag
    _ = (n : ℝ)⁻¹ := by
          rw [hcardW]

/--
Audit check for the Lemma 6.2 perturbation step: once `n > 1`, the plain
two-draw collision event has probability strictly larger than `1/n^2`.
-/
theorem paper_im05_lemma6_2_two_uniform_draws_collision_prob_gt_inv_sq
    {W : Type*} [Fintype W] [DecidableEq W] [Nonempty W]
    (n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n) (hn : 1 < n) :
    (n : ℝ)⁻¹ ^ 2 <
      EconCSLib.pmfProb (EconCSLib.uniformPMF (W × W))
        (fun pair : W × W => pair.1 = pair.2) := by
  rw [paper_im05_lemma6_2_two_uniform_draws_collision_prob n hcardW]
  have hnpos : 0 < (n : ℝ) := by
    exact_mod_cast (NeZero.pos n)
  have hngt : 1 < (n : ℝ) := by
    exact_mod_cast hn
  rw [pow_two]
  field_simp [ne_of_gt hnpos]
  nlinarith

/--
Lemma 6.2 perturbation specialized to the paper's redundant-pair index. The
remaining probabilistic obligation is exactly the per-pair `1/n^2` bound and
the deterministic implication from failure of `E` to one indexed redundant pair.
-/
theorem paper_im05_lemma6_2_perturbation_from_redundant_pairs
    {Ω M : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype M]
    (μ : PMF Ω) (X₃ X₄ : Ω → ℕ) (good : Ω → Prop)
    [DecidablePred good]
    (k n : ℕ) [NeZero n]
    (badPair : im05_redundantPairIndex M k → Ω → Prop)
    [DecidablePred fun ω => ∃ pair, badPair pair ω]
    [∀ pair, DecidablePred (badPair pair)]
    (hcardM : Fintype.card M = n)
    (hchoose : (((k + 2).choose 2 : ℕ) : ℝ) ≤ (k : ℝ) ^ 2)
    (heq : ∀ ω, good ω → X₃ ω = X₄ ω)
    (hbad_subset : ∀ ω, ¬ good ω → ∃ pair, badPair pair ω)
    (hbad_pair :
      ∀ pair, EconCSLib.pmfProb μ (badPair pair) ≤ (n : ℝ)⁻¹ ^ 2) :
    im05_reciprocalCountExpectation μ X₃ ≤
      im05_reciprocalCountExpectation μ X₄ + (k : ℝ) ^ 2 / (n : ℝ) := by
  exact paper_im05_lemma6_2_perturbation_from_union_bound
    μ X₃ X₄ good badPair ((n : ℝ)⁻¹ ^ 2) k n heq hbad_subset
    hbad_pair
    (paper_im05_lemma6_2_redundant_pair_count_bound
      M k n hcardM hchoose)

/-- `k >= 4` version of `paper_im05_lemma6_2_perturbation_from_redundant_pairs`. -/
theorem paper_im05_lemma6_2_perturbation_from_redundant_pairs_of_four_le
    {Ω M : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype M]
    (μ : PMF Ω) (X₃ X₄ : Ω → ℕ) (good : Ω → Prop)
    [DecidablePred good]
    (k n : ℕ) [NeZero n]
    (badPair : im05_redundantPairIndex M k → Ω → Prop)
    [DecidablePred fun ω => ∃ pair, badPair pair ω]
    [∀ pair, DecidablePred (badPair pair)]
    (hcardM : Fintype.card M = n)
    (hk : 4 ≤ k)
    (heq : ∀ ω, good ω → X₃ ω = X₄ ω)
    (hbad_subset : ∀ ω, ¬ good ω → ∃ pair, badPair pair ω)
    (hbad_pair :
      ∀ pair, EconCSLib.pmfProb μ (badPair pair) ≤ (n : ℝ)⁻¹ ^ 2) :
    im05_reciprocalCountExpectation μ X₃ ≤
      im05_reciprocalCountExpectation μ X₄ + (k : ℝ) ^ 2 / (n : ℝ) := by
  exact paper_im05_lemma6_2_perturbation_from_redundant_pairs
    μ X₃ X₄ good k n badPair hcardM
    (paper_im05_lemma6_2_choose_le_sq_of_four_le k hk)
    heq hbad_subset hbad_pair

/--
Lemma 6.2 perturbation specialized to concrete first-`k+2` draw prefixes for
each man. It packages the deterministic bad-event subset bridge with the
redundant-pair perturbation theorem.
-/
theorem paper_im05_lemma6_2_perturbation_from_draw_redundant_pairs
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype M] [DecidableEq W]
    (μ : PMF Ω) (X₃ X₄ : Ω → ℕ) (good : Ω → Prop)
    [DecidablePred good]
    (k n : ℕ) [NeZero n]
    (draws : Ω → M → Fin (k + 2) → W)
    [DecidablePred fun ω =>
      ∃ pair : im05_redundantPairIndex M k,
        im05_redundantPairBadEvent k draws pair ω]
    [∀ pair, DecidablePred (im05_redundantPairBadEvent k draws pair)]
    (hcardM : Fintype.card M = n)
    (hchoose : (((k + 2).choose 2 : ℕ) : ℝ) ≤ (k : ℝ) ^ 2)
