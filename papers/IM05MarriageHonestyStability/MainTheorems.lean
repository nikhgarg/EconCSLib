/--
If the source final target holder is also the target woman's best proposer in
the final proposal history, then no target blocking pair remains.
-/
theorem im05_algorithm41SourceFinalState_no_target_block_of_bestProposedSoFar
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) {m : M}
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hmatch : (im05_algorithm41SourceFinalState val_m val_w g).w_match g = some m)
    (hbest :
      im05_algorithm41BestProposedSoFar val_w
        (im05_algorithm41SourceFinalState val_m val_w g) g m) :
    ∀ r : M,
      valM val_m r ((im05_algorithm41SourceFinalState val_m val_w g).m_match r) <
          val_m r g →
        valW val_w g ((im05_algorithm41SourceFinalState val_m val_w g).w_match g) <
          val_w g r → False := by
  classical
  intro r hman_pref htarget_pref
  let final := im05_algorithm41SourceFinalState val_m val_w g
  have hproposed : im05_algorithm41HasProposedTo final r g := by
    by_contra hnot
    have hg_mem : g ∈ final.m_proposals r := by
      simpa [im05_algorithm41HasProposedTo, final] using hnot
    cases hrmatch : final.m_match r with
    | none =>
        have hactive : IsActiveMan val_m final r := by
          refine ⟨hrmatch, ?_⟩
          exact ⟨g, hg_mem, le_of_lt (hacceptable.1 r g)⟩
        exact
          (im05_algorithm41SourceFinalState_terminated val_m val_w g)
            ⟨r, by simpa [final] using hactive⟩
    | some wcur =>
        have hmatched_proposed :
            wcur ∉ final.m_proposals r :=
          im05_algorithm41SourceFinalState_matchedProposedInvariant
            val_m val_w g r wcur (by simpa [final] using hrmatch)
        have horder :
            val_m r g ≤ val_m r wcur :=
          im05_algorithm41SourceFinalState_manProposalOrderInvariant
            val_m val_w g r wcur g hmatched_proposed hg_mem
            (le_of_lt (hacceptable.1 r g))
        have hpref : val_m r wcur < val_m r g := by
          simpa [valM, final, hrmatch] using hman_pref
        linarith
  have hr_le_m : val_w g r ≤ val_w g m := hbest.2 r hproposed
  have hm_lt_r : val_w g m < val_w g r := by
    simpa [valW, hmatch] using htarget_pref
  linarith

