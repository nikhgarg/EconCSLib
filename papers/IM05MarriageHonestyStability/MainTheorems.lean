/--
At any forbidden set, the raw-count without-replacement sampler draws the next
head with probability `count target / available mass`.
-/
theorem im05_finiteWithoutReplacement_countWeight_head_prob_eq_available_ratio
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (forbidden : Finset Name)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card Name)
    (target : Name) (hnot : target ∉ forbidden) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 1) forbidden hbudget)
        (fun sample => sample.1 ⟨0, Nat.succ_pos k⟩ = target) =
      (count target : ℝ) /
        EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden := by
  classical
  rw [EconCSLib.finiteWithoutReplacementPMF_head_prob
    (head₀ := ⟨target, hnot⟩)]
  rw [EconCSLib.finiteWeightedPMFAvailable_apply_toReal]
  simp [im05_countWeight]

/--
Residual finite-law bridge for one recursive step: the first symbol of the
zero-forbidden residual count-vector model has the same law as the next head of
the raw-count fresh-list sampler.
-/
theorem im05_countOutside_first_prob_eq_countWeight_freshList_head_prob
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (forbidden : Finset Name)
    (hbudget : forbidden.card + (k + 1) ≤ Fintype.card Name)
    (target : Name) (hnot : target ∉ forbidden)
    (hpos : 0 < count target) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name
            (im05_countOutside count forbidden)))
        (fun sample =>
          im05_integerMultisetPermutationFirst target
            (by
              simpa [im05_countOutside, hnot] using hpos)
            sample = target) =
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 1) forbidden hbudget)
        (fun sample => sample.1 ⟨0, Nat.succ_pos k⟩ = target) := by
  rw [im05_integerMultisetPermutation_countOutside_first_prob_eq_available_ratio
    count forbidden target hnot hpos]
  rw [im05_finiteWithoutReplacement_countWeight_head_prob_eq_available_ratio
    count hcount_available forbidden hbudget target hnot]

/--
Forbidden-set marginal finite law for one draw: after deleting an arbitrary
forbidden set from the count-vector word, the first residual name avoids
`target` with the same probability as the first draw of the raw-count
fresh-list sampler started from that forbidden set.
-/
theorem im05_integerMultisetPermutation_countOutside_base_finite_law_one
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {forbidden : Finset Name}
    (hbudget : forbidden.card + 1 ≤ Fintype.card Name)
    (target : Name) (hnot : target ∉ forbidden)
    (hpos : 0 < count target) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 forbidden hbudget)
        (fun sample =>
          im05_listPrefixOmits target 1 sample.1) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name
            (im05_countOutside count forbidden)))
        (fun residual =>
          1 ≤
            (im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList residual)).card) := by
  classical
  let μA :=
    EconCSLib.finiteWithoutReplacementPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 1 forbidden hbudget
  let μM :=
    EconCSLib.uniformPMF
      (im05_integerMultisetPermutationSample Name
        (im05_countOutside count forbidden))
  have houtside_pos :
      0 < im05_countOutside count forbidden target := by
    simpa [im05_countOutside, hnot] using hpos
  have hA :
      EconCSLib.pmfProb μA
          (fun sample =>
            im05_listPrefixOmits target 1 sample.1) =
        EconCSLib.pmfProb μA
          (fun sample =>
            ¬ sample.1 ⟨0, Nat.succ_pos 0⟩ = target) :=
    EconCSLib.pmfProb_congr μA
      (by
        intro sample
        have h :=
          im05_listPrefixOmits_succ_iff target sample.1 (r := 0)
            (Nat.succ_pos 0)
        simpa using h)
  have hM :
      EconCSLib.pmfProb μM
          (fun residual =>
            1 ≤
              (im05_namesBeforeFirst id target
                (im05_integerMultisetPermutationList residual)).card) =
        EconCSLib.pmfProb μM
          (fun residual =>
            ¬ im05_integerMultisetPermutationFirst target
                houtside_pos residual = target) :=
    EconCSLib.pmfProb_congr μM
      (by
        intro residual
        have htarget_mem :
            target ∈ im05_integerMultisetPermutationList residual := by
          by_contra hnot_mem
          have hcount_zero :
              (im05_integerMultisetPermutationList residual).count target = 0 :=
            List.count_eq_zero_of_not_mem hnot_mem
          rw [im05_integerMultisetPermutationList_count residual target] at hcount_zero
          exact houtside_pos.ne' hcount_zero
        have hlist_pos :
            0 < (im05_integerMultisetPermutationList residual).length := by
          exact List.length_pos_of_mem htarget_mem
        have hhead :
            im05_integerMultisetPermutationFirst target houtside_pos residual =
              (im05_integerMultisetPermutationList residual).get
                ⟨0, hlist_pos⟩ := by
          simp [im05_integerMultisetPermutationFirst,
            im05_integerMultisetPermutationList]
        rw [im05_one_le_namesBeforeFirst_card_iff_head_ne
          target (im05_integerMultisetPermutationList residual)
          hlist_pos htarget_mem]
        rw [hhead])
  rw [hA, hM]
  rw [EconCSLib.pmfProb_compl, EconCSLib.pmfProb_compl]
  rw [im05_countOutside_first_prob_eq_countWeight_freshList_head_prob
    count hcount_available forbidden hbudget target hnot hpos]

/--
Recursive transition bridge: conditioned on `head` being the first
first-appearance name in the count-vector model, the next residual first symbol
has the same atom probability as the raw-count fresh-list sampler after
forbidding `head`.
-/
theorem
    im05_integerMultisetPermutationAllowedSample_head_conditional_first_prob_eq_countWeight_freshList_head_prob
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (head : Name) (hhead_pos : 0 < count head)
    (hbudget : ({head} : Finset Name).card + (k + 1) ≤ Fintype.card Name)
    (target : Name) (hneq : target ≠ head) (hpos : 0 < count target) :
    EconCSLib.pmfConditionalProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst head hhead_pos sample = head)
        (fun sample =>
          im05_integerMultisetPermutationFirst target
              (by
                have hnot : target ∉ ({head} : Finset Name) := by
                  simpa [Finset.mem_singleton] using hneq
                simpa [im05_countOutside, hnot] using hpos)
              (im05_integerMultisetPermutationAllowedSample
                ({head} : Finset Name) sample) =
            target) =
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 1) ({head} : Finset Name) hbudget)
        (fun sample => sample.1 ⟨0, Nat.succ_pos k⟩ = target) := by
  have hnot : target ∉ ({head} : Finset Name) := by
    simpa [Finset.mem_singleton] using hneq
  rw [im05_integerMultisetPermutationAllowedSample_head_conditional_first_prob_eq_available_ratio
    count head hhead_pos target hneq hpos]
  rw [im05_finiteWithoutReplacement_countWeight_head_prob_eq_available_ratio
    count hcount_available ({head} : Finset Name) hbudget target hnot]

/--
Under the one-draw raw-count sampler, the event that the first draw is not a
fixed excluded name has positive probability as soon as another positive-count
target exists.
-/
theorem im05_countWeight_freshList_first_ne_prob_pos
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (target excluded : Name) (hneq : target ≠ excluded) :
    0 <
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 (by
            simpa using Fintype.card_pos_iff.mpr ⟨target⟩))
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨0, Nat.succ_pos 0⟩ ≠ excluded) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 1 (by
        simpa using Fintype.card_pos_iff.mpr ⟨target⟩)
  have htarget_prob :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ = target) =
        (count target : ℝ) / (∑ name : Name, count name : ℝ) := by
    simpa [μ] using
      (im05_algorithm42FreshList_countWeight_first_draw_prob_eq_count_ratio
        (Name := Name) count hcount_available
        (k := 0)
        (hk_le_card := by
          simpa using Fintype.card_pos_iff.mpr ⟨target⟩)
        target)
  have htotal_pos_nat : 0 < ∑ name : Name, count name :=
    im05_sum_count_pos_of_pos count target (hcount_pos target)
  have htarget_prob_pos :
      0 <
        EconCSLib.pmfProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ = target) := by
    rw [htarget_prob]
    exact div_pos (by exact_mod_cast hcount_pos target)
      (by exact_mod_cast htotal_pos_nat)
  have hle :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ = target) ≤
        EconCSLib.pmfProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ ≠ excluded) :=
    EconCSLib.pmfProb_le_of_imp μ
      (fun sample =>
        im05_algorithm42FreshListDraw sample
            ⟨0, Nat.succ_pos 0⟩ = target)
      (fun sample =>
        im05_algorithm42FreshListDraw sample
            ⟨0, Nat.succ_pos 0⟩ ≠ excluded)
      (by
        intro sample htarget
        rw [htarget]
        exact hneq)
  exact lt_of_lt_of_le htarget_prob_pos hle

/--
One-draw conditional first-hit law for the raw-count sampler: conditioning on
not drawing `excluded` renormalizes the first draw by the available mass outside
`{excluded}`.
-/
theorem im05_countWeight_freshList_conditional_first_eq_of_first_ne
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (target excluded : Name) (hneq : target ≠ excluded) :
    EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 (by
            simpa using Fintype.card_pos_iff.mpr ⟨target⟩))
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨0, Nat.succ_pos 0⟩ ≠ excluded)
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨0, Nat.succ_pos 0⟩ = target) =
      (count target : ℝ) /
        EconCSLib.finiteAvailableWeight
          (im05_countWeight count) ({excluded} : Finset Name) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 1 (by
        simpa using Fintype.card_pos_iff.mpr ⟨target⟩)
  let total : ℝ := (∑ name : Name, count name : ℕ)
  let available : ℝ :=
    EconCSLib.finiteAvailableWeight
      (im05_countWeight count) ({excluded} : Finset Name)
  have htarget_prob :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ = target) =
        (count target : ℝ) / total := by
    simpa [μ, total] using
      (im05_algorithm42FreshList_countWeight_first_draw_prob_eq_count_ratio
        (Name := Name) count hcount_available
        (k := 0)
        (hk_le_card := by
          simpa using Fintype.card_pos_iff.mpr ⟨target⟩)
        target)
  have hexcluded_prob :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ = excluded) =
        (count excluded : ℝ) / total := by
    simpa [μ, total] using
      (im05_algorithm42FreshList_countWeight_first_draw_prob_eq_count_ratio
        (Name := Name) count hcount_available
        (k := 0)
        (hk_le_card := by
          simpa using Fintype.card_pos_iff.mpr ⟨target⟩)
        excluded)
  have hcondition_prob :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ ≠ excluded) =
        1 - (count excluded : ℝ) / total := by
    rw [EconCSLib.pmfProb_compl]
    exact congrArg (fun x => 1 - x) hexcluded_prob
  have hcondition_pos :
      0 <
        EconCSLib.pmfProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ ≠ excluded) := by
    simpa [μ] using
      (im05_countWeight_freshList_first_ne_prob_pos
        (Name := Name) count hcount_pos hcount_available target excluded hneq)
  have hinter :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ ≠ excluded ∧
              im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ = target) =
        EconCSLib.pmfProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ = target) :=
    EconCSLib.pmfProb_inter_eq_right_of_imp μ
      (fun sample =>
        im05_algorithm42FreshListDraw sample
            ⟨0, Nat.succ_pos 0⟩ ≠ excluded)
      (fun sample =>
        im05_algorithm42FreshListDraw sample
            ⟨0, Nat.succ_pos 0⟩ = target)
      (by
        intro sample htarget
        rw [htarget]
        exact hneq)
  have htotal_pos_nat : 0 < ∑ name : Name, count name :=
    im05_sum_count_pos_of_pos count target (hcount_pos target)
  have htotal_pos : 0 < total := by
    dsimp [total]
    exact_mod_cast htotal_pos_nat
  have htotal_ne : total ≠ 0 := ne_of_gt htotal_pos
  have hnot : target ∉ ({excluded} : Finset Name) := by
    simpa [Finset.mem_singleton] using hneq
  have havailable_pos : 0 < available := by
    dsimp [available]
    exact
      EconCSLib.finiteAvailableWeight_pos_of_exists_not_mem_pos
        (im05_countWeight count) ({excluded} : Finset Name)
        (im05_countWeight_nonneg count) hnot
        (by simpa [im05_countWeight] using hcount_pos target)
  have havailable_ne : available ≠ 0 := ne_of_gt havailable_pos
  have havailable_add :
      available + (count excluded : ℝ) = total := by
    dsimp [available, total]
    simpa [im05_countWeight] using
      (EconCSLib.finiteAvailableWeight_add_forbidden_sum
        (im05_countWeight count) ({excluded} : Finset Name))
  have hden :
      1 - (count excluded : ℝ) / total = available / total := by
    field_simp [htotal_ne]
    linarith
  rw [EconCSLib.pmfConditionalProb_eq_inter_div_of_pos
    μ
    (fun sample =>
      im05_algorithm42FreshListDraw sample
          ⟨0, Nat.succ_pos 0⟩ ≠ excluded)
    (fun sample =>
      im05_algorithm42FreshListDraw sample
          ⟨0, Nat.succ_pos 0⟩ = target)
    hcondition_pos]
  rw [hinter, htarget_prob, hcondition_prob, hden]
  change ((count target : ℝ) / total) / (available / total) =
    (count target : ℝ) / available
  field_simp [htotal_ne, havailable_ne]

/--
The one-draw conditional avoidance law of the raw-count sampler agrees with the
first-symbol avoidance law of the count-vector model after deleting the
excluded name.
-/
theorem im05_countWeight_freshList_conditional_first_ne_eq_countOutside_first_ne_prob
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (target excluded : Name) (hneq : target ≠ excluded) :
    EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 (by
            simpa using Fintype.card_pos_iff.mpr ⟨target⟩))
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨0, Nat.succ_pos 0⟩ ≠ excluded)
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨0, Nat.succ_pos 0⟩ ≠ target) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name
            (im05_countOutside count ({excluded} : Finset Name))))
        (fun sample =>
          ¬ im05_integerMultisetPermutationFirst target
              (by
                have hnot : target ∉ ({excluded} : Finset Name) := by
                  simpa [Finset.mem_singleton] using hneq
                simpa [im05_countOutside, hnot] using hcount_pos target)
              sample = target) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 1 (by
        simpa using Fintype.card_pos_iff.mpr ⟨target⟩)
  let condition : im05_algorithm42FreshListSample Name 1 → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample
          ⟨0, Nat.succ_pos 0⟩ ≠ excluded
  let hit : im05_algorithm42FreshListSample Name 1 → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample
          ⟨0, Nat.succ_pos 0⟩ = target
  have hcondition_pos :
      0 < EconCSLib.pmfProb μ condition := by
    simpa [μ, condition] using
      (im05_countWeight_freshList_first_ne_prob_pos
        (Name := Name) count hcount_pos hcount_available target excluded hneq)
  have hnot : target ∉ ({excluded} : Finset Name) := by
    simpa [Finset.mem_singleton] using hneq
  have hhit_residual :
      EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name
              (im05_countOutside count ({excluded} : Finset Name))))
          (fun sample =>
            im05_integerMultisetPermutationFirst target
              (by simpa [im05_countOutside, hnot] using hcount_pos target)
              sample = target) =
        (count target : ℝ) /
          EconCSLib.finiteAvailableWeight
            (im05_countWeight count) ({excluded} : Finset Name) := by
    exact
      im05_integerMultisetPermutation_countOutside_first_prob_eq_available_ratio
        count ({excluded} : Finset Name) target hnot (hcount_pos target)
  rw [EconCSLib.pmfConditionalProb_compl_eq_one_sub_of_pos
    μ condition hit hcondition_pos]
  rw [EconCSLib.pmfProb_compl]
  rw [im05_countWeight_freshList_conditional_first_eq_of_first_ne
    (Name := Name) count hcount_pos hcount_available target excluded hneq]
  rw [hhit_residual]

/--
Conditional finite-law bridge for the singleton-deletion event at `k = 1`.
The only remaining combinatorial input is the constant positive fiber
cardinality of the map that deletes all copies of `excluded` from a uniform
count-vector word.
-/
theorem im05_integerMultisetPermutation_conditional_finite_law_one_of_allowedSample_constant_fiber
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (target excluded : Name) (hneq : target ≠ excluded)
    [DecidablePred fun sample : im05_algorithm42FreshListSample Name 1 =>
      im05_listPrefixOmits excluded 1
        (im05_algorithm42FreshListDraw sample)]
    [DecidablePred fun sample : im05_algorithm42FreshListSample Name 1 =>
      im05_listPrefixOmits target 1
        (im05_algorithm42FreshListDraw sample)]
    (fiberCard : ℕ) (hfiber_pos : 0 < fiberCard)
    (hfiber : ∀ residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)),
      ((Finset.univ :
          Finset (im05_integerMultisetPermutationSample Name count)).filter
        (fun sample =>
          im05_integerMultisetPermutationAllowedSample
              ({excluded} : Finset Name) sample =
            residual)).card = fiberCard) :
    EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 (by
            simpa using Fintype.card_pos_iff.mpr ⟨target⟩))
        (fun sample =>
          im05_listPrefixOmits excluded 1
            (im05_algorithm42FreshListDraw sample))
        (fun sample =>
          im05_listPrefixOmits target 1
            (im05_algorithm42FreshListDraw sample)) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          1 ≤
            ((im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList sample)).erase
                excluded).card) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 1 (by
        simpa using Fintype.card_pos_iff.mpr ⟨target⟩)
  have htarget_not_excluded : target ∉ ({excluded} : Finset Name) := by
    simpa [Finset.mem_singleton] using hneq
  have houtside_pos :
      0 < im05_countOutside count ({excluded} : Finset Name) target := by
    simpa [im05_countOutside, htarget_not_excluded] using hcount_pos target
  let residualEvent :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)) → Prop :=
    fun sample =>
      ¬ im05_integerMultisetPermutationFirst target
          houtside_pos
          sample = target
  have hcond_congr :
      EconCSLib.pmfConditionalProb μ
          (fun sample =>
            im05_listPrefixOmits excluded 1
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits target 1
              (im05_algorithm42FreshListDraw sample)) =
        EconCSLib.pmfConditionalProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ ≠ excluded)
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ ≠ target) := by
    refine
      EconCSLib.pmfConditionalProb_congr μ
        (fun sample =>
          im05_listPrefixOmits excluded 1
            (im05_algorithm42FreshListDraw sample))
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨0, Nat.succ_pos 0⟩ ≠ excluded)
        (fun sample =>
          im05_listPrefixOmits target 1
            (im05_algorithm42FreshListDraw sample))
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨0, Nat.succ_pos 0⟩ ≠ target)
        ?_ ?_
    · intro sample
      have h :=
        im05_listPrefixOmits_succ_iff excluded
          (im05_algorithm42FreshListDraw sample) (r := 0)
          (Nat.succ_pos 0)
      simpa using h
    · intro sample _hcondition
      have h :=
        im05_listPrefixOmits_succ_iff target
          (im05_algorithm42FreshListDraw sample) (r := 0)
          (Nat.succ_pos 0)
      simpa using h
  have hresidual_law :
      EconCSLib.pmfConditionalProb μ
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ ≠ excluded)
          (fun sample =>
            im05_algorithm42FreshListDraw sample
                ⟨0, Nat.succ_pos 0⟩ ≠ target) =
        EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name
              (im05_countOutside count ({excluded} : Finset Name))))
          residualEvent := by
    simpa [μ, residualEvent] using
      (im05_countWeight_freshList_conditional_first_ne_eq_countOutside_first_ne_prob
        (Name := Name) count hcount_pos hcount_available
        target excluded hneq)
  have hprojection :
      EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name count))
          (fun sample =>
            residualEvent
              (im05_integerMultisetPermutationAllowedSample
                ({excluded} : Finset Name) sample)) =
        EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name
              (im05_countOutside count ({excluded} : Finset Name))))
          residualEvent :=
    im05_integerMultisetPermutationAllowedSample_uniform_event_eq_of_constant_fiber
      ({excluded} : Finset Name) fiberCard hfiber_pos hfiber
      residualEvent
  have hsource_congr :
      EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name count))
          (fun sample =>
            residualEvent
              (im05_integerMultisetPermutationAllowedSample
                ({excluded} : Finset Name) sample)) =
        EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name count))
          (fun sample =>
            1 ≤
              ((im05_namesBeforeFirst id target
                (im05_integerMultisetPermutationList sample)).erase
                  excluded).card) := by
    refine
      EconCSLib.pmfProb_congr
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        ?_
    intro sample
    have hallowed_pos :
        0 <
          (im05_integerMultisetPermutationAllowedList
            ({excluded} : Finset Name) sample).length :=
      im05_integerMultisetPermutationAllowedList_length_pos_of_count_pos
        ({excluded} : Finset Name) sample target htarget_not_excluded
        (hcount_pos target)
    have hfirst_eq :
        im05_integerMultisetPermutationFirst target
            houtside_pos
            (im05_integerMultisetPermutationAllowedSample
              ({excluded} : Finset Name) sample) =
          (im05_integerMultisetPermutationAllowedList
              ({excluded} : Finset Name) sample).get
            ⟨0, hallowed_pos⟩ :=
      im05_integerMultisetPermutationAllowedSample_first_eq_allowedList_get
        ({excluded} : Finset Name) sample target htarget_not_excluded
        (hcount_pos target) hallowed_pos
    have hresidual_iff :
        residualEvent
            (im05_integerMultisetPermutationAllowedSample
              ({excluded} : Finset Name) sample) ↔
          (im05_integerMultisetPermutationAllowedList
              ({excluded} : Finset Name) sample).get
            ⟨0, hallowed_pos⟩ ≠ target := by
      dsimp [residualEvent]
      rw [hfirst_eq]
      simp only [List.get_eq_getElem]
    have herased_iff :
        1 ≤
            ((im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList sample)).erase
                excluded).card ↔
          (im05_integerMultisetPermutationAllowedList
              ({excluded} : Finset Name) sample).get
            ⟨0, hallowed_pos⟩ ≠ target :=
      im05_integerMultisetPermutation_erased_namesBeforeFirst_one_iff_allowedList_head_ne
        hcount_pos sample target excluded hneq hallowed_pos
    exact hresidual_iff.trans herased_iff.symm
  rw [hcond_congr, hresidual_law, ← hprojection, hsource_congr]

/--
The conditional finite law is trivial at `k = 0`: both the conditioning event
and the target omission event always hold.
-/
theorem im05_integerMultisetPermutation_conditional_finite_law_zero
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (target excluded : Name)
    [DecidablePred fun sample : im05_algorithm42FreshListSample Name 0 =>
      im05_listPrefixOmits excluded 0
        (im05_algorithm42FreshListDraw sample)]
    [DecidablePred fun sample : im05_algorithm42FreshListSample Name 0 =>
      im05_listPrefixOmits target 0
        (im05_algorithm42FreshListDraw sample)] :
    EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 0 (Nat.zero_le _))
        (fun sample =>
          im05_listPrefixOmits excluded 0
            (im05_algorithm42FreshListDraw sample))
        (fun sample =>
          im05_listPrefixOmits target 0
            (im05_algorithm42FreshListDraw sample)) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          0 ≤
            ((im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList sample)).erase
                excluded).card) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 0 (Nat.zero_le _)
  rw [EconCSLib.pmfConditionalProb_eq_pmfProb_of_forall_condition
    μ
    (fun sample =>
      im05_listPrefixOmits excluded 0
        (im05_algorithm42FreshListDraw sample))
    (fun sample =>
      im05_listPrefixOmits target 0
        (im05_algorithm42FreshListDraw sample))]
  · rw [EconCSLib.pmfProb_eq_one_of_forall μ
      (fun sample =>
        im05_listPrefixOmits target 0
          (im05_algorithm42FreshListDraw sample))]
    · rw [EconCSLib.pmfProb_eq_one_of_forall
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          0 ≤
            ((im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList sample)).erase
                excluded).card)]
      intro sample
      exact Nat.zero_le _
    · intro sample
      exact im05_listPrefixOmits_zero target
        (im05_algorithm42FreshListDraw sample)
  · intro sample
    exact im05_listPrefixOmits_zero excluded
      (im05_algorithm42FreshListDraw sample)

/--
Conditional finite-law bridge for the singleton-deletion event at `k = 1`,
with the concrete constant-fiber cardinality theorem for deleting all copies of
`excluded` discharged.
-/
theorem im05_integerMultisetPermutation_conditional_finite_law_one
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (target excluded : Name) (hneq : target ≠ excluded)
    [DecidablePred fun sample : im05_algorithm42FreshListSample Name 1 =>
      im05_listPrefixOmits excluded 1
        (im05_algorithm42FreshListDraw sample)]
    [DecidablePred fun sample : im05_algorithm42FreshListSample Name 1 =>
      im05_listPrefixOmits target 1
        (im05_algorithm42FreshListDraw sample)] :
    EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 (by
            simpa using Fintype.card_pos_iff.mpr ⟨target⟩))
        (fun sample =>
          im05_listPrefixOmits excluded 1
            (im05_algorithm42FreshListDraw sample))
        (fun sample =>
          im05_listPrefixOmits target 1
            (im05_algorithm42FreshListDraw sample)) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          1 ≤
            ((im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList sample)).erase
                excluded).card) := by
  classical
  let fiberCard :=
    ((Finset.univ : Finset (Fin (∑ name : Name, count name))).powersetCard
      (count excluded)).card
  exact
    im05_integerMultisetPermutation_conditional_finite_law_one_of_allowedSample_constant_fiber
      count hcount_pos hcount_available target excluded hneq
      (fiberCard := fiberCard)
      (hfiber_pos := by
        simpa [fiberCard] using
          im05_integerMultisetPermutationAllowedSample_singleton_fiber_card_pos
            count excluded)
      (hfiber := by
        intro residual
        simpa [fiberCard] using
          im05_integerMultisetPermutationAllowedSample_singleton_fiber_card
            count excluded residual)

/--
Projection form of the singleton-deletion finite law: the erased
`namesBeforeFirst` event in the original uniform count-vector model is the
ordinary first-appearance omission event in the residual count-vector model
obtained by deleting all copies of `excluded`.
-/
theorem
    im05_integerMultisetPermutation_erased_namesBeforeFirst_prob_eq_countOutside_firstAppearance_not_mem_take
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (target excluded : Name) (hneq : target ≠ excluded) (k : ℕ) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          k ≤
            ((im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList sample)).erase
                excluded).card) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name
            (im05_countOutside count ({excluded} : Finset Name))))
        (fun residual =>
          target ∉
            (im05_firstAppearanceList
              (im05_integerMultisetPermutationList residual)).take k) := by
  classical
  let residualEvent :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)) → Prop :=
    fun residual =>
      target ∉
        (im05_firstAppearanceList
          (im05_integerMultisetPermutationList residual)).take k
  have hsource_congr :
      EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name count))
          (fun sample =>
            k ≤
              ((im05_namesBeforeFirst id target
                (im05_integerMultisetPermutationList sample)).erase
                  excluded).card) =
        EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name count))
          (fun sample =>
            residualEvent
              (im05_integerMultisetPermutationAllowedSample
                ({excluded} : Finset Name) sample)) := by
    refine
      EconCSLib.pmfProb_congr
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        ?_
    intro sample
    have hdet :=
      im05_integerMultisetPermutation_erased_namesBeforeFirst_iff_allowedList_firstAppearance_not_mem_take
        hcount_pos sample target excluded hneq k
    have hlist :
        im05_integerMultisetPermutationList
            (im05_integerMultisetPermutationAllowedSample
              ({excluded} : Finset Name) sample) =
          im05_integerMultisetPermutationAllowedList
            ({excluded} : Finset Name) sample :=
      im05_integerMultisetPermutationList_allowedSample
        ({excluded} : Finset Name) sample
    simpa [residualEvent, hlist] using hdet
  rw [hsource_congr]
  exact
    im05_integerMultisetPermutationAllowedSample_uniform_event_eq
      count ({excluded} : Finset Name) residualEvent

/--
Equivalent projection form using the residual count-vector word's ordinary
`namesBeforeFirst` event.
-/
theorem
    im05_integerMultisetPermutation_erased_namesBeforeFirst_prob_eq_countOutside_namesBeforeFirst
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (target excluded : Name) (hneq : target ≠ excluded) (k : ℕ) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          k ≤
            ((im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList sample)).erase
                excluded).card) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name
            (im05_countOutside count ({excluded} : Finset Name))))
        (fun residual =>
          k ≤
            (im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList residual)).card) := by
  classical
  rw [im05_integerMultisetPermutation_erased_namesBeforeFirst_prob_eq_countOutside_firstAppearance_not_mem_take
    count hcount_pos target excluded hneq k]
  refine
    EconCSLib.pmfProb_congr
      (EconCSLib.uniformPMF
        (im05_integerMultisetPermutationSample Name
          (im05_countOutside count ({excluded} : Finset Name))))
      ?_
  intro residual
  have hnot : target ∉ ({excluded} : Finset Name) := by
    simpa [Finset.mem_singleton] using hneq
  have htarget_mem :
      target ∈ im05_integerMultisetPermutationList residual := by
    by_contra hnot_mem
    have hcount_zero :
        (im05_integerMultisetPermutationList residual).count target = 0 :=
      List.count_eq_zero_of_not_mem hnot_mem
    rw [im05_integerMultisetPermutationList_count residual target] at hcount_zero
    have houtside_pos :
        0 < im05_countOutside count ({excluded} : Finset Name) target := by
      simpa [im05_countOutside, hnot] using hcount_pos target
    exact houtside_pos.ne' hcount_zero
  exact
    im05_firstAppearanceList_not_mem_take_iff_le_namesBeforeFirst_card
      target (im05_integerMultisetPermutationList residual) htarget_mem k

/--
Lemma 4.4 finite-multiset probability inequality.  Under any PMF over
permutation/list samples, the event that `k` distinct non-`j` names occur before
the first `i` is a subevent of the event that `k` distinct names occur before
the first `i`.
-/
theorem paper_im05_lemma4_4_multiset_event_inclusion_probability
    {Ω Token Name : Type*} [Fintype Ω] [DecidableEq Ω] [DecidableEq Name]
    (μ : PMF Ω) (perm : Ω → List Token) (name : Token → Name)
    (i j : Name) (k : ℕ) :
    EconCSLib.pmfProb μ
        (fun ω =>
          k ≤ ((im05_namesBeforeFirst name i (perm ω)).erase j).card) ≤
      EconCSLib.pmfProb μ
        (fun ω =>
          k ≤ (im05_namesBeforeFirst name i (perm ω)).card) := by
  classical
  exact
    EconCSLib.pmfProb_le_of_imp μ
      (fun ω =>
        k ≤ ((im05_namesBeforeFirst name i (perm ω)).erase j).card)
      (fun ω =>
        k ≤ (im05_namesBeforeFirst name i (perm ω)).card)
      (by
        intro ω h
        exact im05_kDistinctNamesBefore_excluding_imp
          name i j (perm ω) k h)

/--
Lemma 4.4 finite inequality specialized to the paper's integer-multiset
permutation sample space with the uniform law over all words with the prescribed
counts.
-/
theorem paper_im05_lemma4_4_integerMultiset_event_inclusion_probability
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
