/--
After the initial DA run and the target divorce, the divorced husband is the
best proposer seen so far by the target woman.  This is the source-history
standard that Algorithm 4.1 carries forward after Step 2.
-/
theorem im05_algorithm41DivorcedState_bestProposedSoFar_of_initial_match
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) {g : W} {m : M}
    (hmatch : (deferredAcceptanceState val_m val_w).w_match g = some m) :
    im05_algorithm41BestProposedSoFar val_w
