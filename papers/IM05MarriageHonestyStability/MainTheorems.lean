    im05_stableHusband_target_proposal_mem_sourceDivorceTargetAcceptedMen_of_trace_rejected_package_of_allPairsAcceptable
      val_m val_w g hstrictM hstrictW hacceptable ht hstableHusband
      (by
        simpa using
          im05_algorithm41DivorcedState_rejectedPairImpossibleExceptTarget
            val_m val_w g hstrictM hstrictW hacceptable)
      hactive'
      (by simpa using hchosen)
      (by simpa using htarget)

/--
Target-proposal coverage for the corrected Algorithm 4.1 trace, excluding the
initial DA husband that the paper outputs before entering the continued
proposal loop.
-/
def im05_SourceTraceStableHusbandTargetProposalCoverageExceptInitial
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) (steps : ℕ) : Prop :=
  ∀ m : M,
    m ∈ im05_stableHusbands val_m val_w g →
      im05_algorithm41InitialHusband val_m val_w g ≠ some m →
        ∃ t : ℕ,
          t < steps ∧
            ∃ hactive :
              ∃ a, IsActiveMan val_m
                (im05_algorithm41SourceDivorceTargetStateAfterSteps
                  val_m val_w g t) a,
              daStepChosenMan val_m
                (im05_algorithm41SourceDivorceTargetStateAfterSteps
                  val_m val_w g t) hactive = m ∧
                daStepChosenWoman val_m
                  (im05_algorithm41SourceDivorceTargetStateAfterSteps
                    val_m val_w g t) hactive = g

/--
Compact remaining-obligation certificate for the corrected Algorithm 4.1
source trace.  The first field is the local non-target blocker package; the
second says every non-initial stable husband strictly prefers `g` to any final
match he holds in the corrected final state.
-/
def im05_Algorithm41SourceCompletionCertificate
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : Prop :=
  (∀ t : ℕ,
    t < Fintype.card M * Fintype.card W →
      im05_SourceStepNonTargetBlockersNotStableHusbands val_m val_w
        (im05_algorithm41SourceDivorceTargetStateAfterSteps
          val_m val_w g t) g) ∧
  (∀ m : M,
    m ∈ im05_stableHusbands val_m val_w g →
      im05_algorithm41InitialHusband val_m val_w g ≠ some m →
        ∀ wcur : W,
            (im05_algorithm41SourceDivorceTargetFinalState
              val_m val_w g).m_match m = some wcur →
            val_m m wcur < val_m m g)

/--
Pair-level completion certificate for the preferred Algorithm 4.1 reduction.
The first field is the sharper non-target blocking-preference obligation; the
second is final removal of the target woman from every non-initial stable
husband's proposal set.
-/
def im05_Algorithm41SourcePairCompletionCertificate
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : Prop :=
  (∀ t : ℕ,
    t < Fintype.card M * Fintype.card W →
      im05_SourceStepNonTargetBlockingPairPreferences val_m val_w
        (im05_algorithm41SourceDivorceTargetStateAfterSteps
          val_m val_w g t) g) ∧
  (∀ m : M,
    m ∈ im05_stableHusbands val_m val_w g →
      im05_algorithm41InitialHusband val_m val_w g ≠ some m →
        g ∉
          (im05_algorithm41SourceDivorceTargetFinalState
            val_m val_w g).m_proposals m)

/--
Witness-form completion certificate for the weakest current Algorithm 4.1
reduction.  Rejected non-target steps only need one prior blocking proposer in
each candidate stable matching; accepted non-target steps keep the pair-level
displaced-match premise.
-/
def im05_Algorithm41SourcePairWitnessCompletionCertificate
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : Prop :=
  (∀ t : ℕ,
    t < Fintype.card M * Fintype.card W →
      im05_SourceStepNonTargetBlockingPairWitnessPreferences val_m val_w
        (im05_algorithm41SourceDivorceTargetStateAfterSteps
          val_m val_w g t) g) ∧
  (∀ m : M,
    m ∈ im05_stableHusbands val_m val_w g →
      im05_algorithm41InitialHusband val_m val_w g ≠ some m →
        g ∉
          (im05_algorithm41SourceDivorceTargetFinalState
            val_m val_w g).m_proposals m)

/--
Final-state target-blocking form of the second Algorithm 4.1 certificate
field.  It says that every non-initial stable husband strictly prefers the
target woman `g` to his final target-divorced assignment, including the
unmatched case through `valM`.
-/
def im05_SourceFinalNoninitialStableHusbandTargetBlocks
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : Prop :=
  ∀ m : M,
    m ∈ im05_stableHusbands val_m val_w g →
      im05_algorithm41InitialHusband val_m val_w g ≠ some m →
        valM val_m m
          ((im05_algorithm41SourceDivorceTargetFinalState
            val_m val_w g).m_match m) < val_m m g

theorem im05_SourceFinalNoninitialStableHusbandTargetBlocks.finalPref
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (hblocks :
      im05_SourceFinalNoninitialStableHusbandTargetBlocks val_m val_w g) :
    ∀ m : M,
      m ∈ im05_stableHusbands val_m val_w g →
        im05_algorithm41InitialHusband val_m val_w g ≠ some m →
          ∀ wcur : W,
            (im05_algorithm41SourceDivorceTargetFinalState
              val_m val_w g).m_match m = some wcur →
              val_m m wcur < val_m m g := by
  intro m hm hnotInitial wcur hmatch
  have hb := hblocks m hm hnotInitial
  simpa [valM, hmatch] using hb

theorem im05_SourceFinalNoninitialStableHusbandTargetBlocks_of_finalPref
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hfinalPref :
      ∀ m : M,
        m ∈ im05_stableHusbands val_m val_w g →
          im05_algorithm41InitialHusband val_m val_w g ≠ some m →
            ∀ wcur : W,
              (im05_algorithm41SourceDivorceTargetFinalState
                val_m val_w g).m_match m = some wcur →
                val_m m wcur < val_m m g) :
    im05_SourceFinalNoninitialStableHusbandTargetBlocks val_m val_w g := by
  intro m hm hnotInitial
  cases hmatch :
      (im05_algorithm41SourceDivorceTargetFinalState
        val_m val_w g).m_match m with
  | none =>
      simpa [valM, hmatch] using hacceptable.1 m g
  | some wcur =>
      simpa [valM, hmatch] using hfinalPref m hm hnotInitial wcur hmatch

theorem im05_SourceFinalNoninitialStableHusbandTargetBlocks_iff_finalPref
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (hacceptable : AllPairsAcceptable val_m val_w) :
    im05_SourceFinalNoninitialStableHusbandTargetBlocks val_m val_w g ↔
      ∀ m : M,
