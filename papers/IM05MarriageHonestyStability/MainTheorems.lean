          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            2 (le_of_lt hcard_two_lt)))
        (fun samples : M → im05_algorithm42FreshListSample I 2 =>
          (((Finset.univ : Finset I).filter fun i =>
            ∀ m : M,
              im05_listPrefixOmits i 2
                (im05_algorithm42FreshListDraw (samples m))).card : ℝ)) := by
  classical
  let ν := im05_algorithm42FreshListPMF prob hprob_nonneg havailable
    2 (le_of_lt hcard_two_lt)
  exact
    paper_im05_lemma4_4_variance_le_expectation_from_single_man_conditional_product
      (M := M) ν
      (fun i sample =>
        im05_listPrefixOmits i 2 (im05_algorithm42FreshListDraw sample))
      (fun j =>
        by
          simpa [ν] using
            paper_im05_algorithm4_2_freshList_omit_pos_of_full_support
              prob hprob_nonneg hprob_pos havailable
              (le_of_lt hcard_two_lt) hcard_two_lt j)
      (by
        simpa [ν] using
          paper_im05_lemma4_4_freshList_conditional_comparison_family_from_scaled_count_negative_correlation_limits_two
            countSeq scaleWeight prob hscale_pos hcount_available
            hprob_nonneg hprob_pos havailable hweight hcard_two_lt)

/--
Lemma 4.1 algebra endpoint: once Lemma 4.3 supplies
`E[Y_g] >= (g / 2) * exp(-8nk/g)` and the variance/Chebyshev part supplies
`E[1/(X_\mu(g)+1)] <= 6 / E[Y_g]`, the source's displayed reciprocal
expectation bound follows.
-/
theorem paper_im05_lemma4_1_algebra_from_lemma4_3
    (g n k : ℕ) (hg : 0 < g)
    (EY reciprocal : ℝ)
    (hEY :
      (g : ℝ) / 2 *
          Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤ EY)
    (hreciprocal : reciprocal ≤ 6 / EY) :
    reciprocal ≤
      12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ)) / (g : ℝ) := by
  let a : ℝ := 8 * (n : ℝ) * (k : ℝ) / (g : ℝ)
  have hg_pos : 0 < (g : ℝ) := by exact_mod_cast hg
  have hL_pos : 0 < (g : ℝ) / 2 * Real.exp (-a) := by positivity
  have h6 :
      6 / EY ≤ 6 / ((g : ℝ) / 2 * Real.exp (-a)) := by
    exact div_le_div_of_nonneg_left
      (by norm_num : (0 : ℝ) ≤ 6) hL_pos hEY
  calc
    reciprocal ≤ 6 / EY := hreciprocal
    _ ≤ 6 / ((g : ℝ) / 2 * Real.exp (-a)) := h6
    _ = 12 * Real.exp a / (g : ℝ) := by
      have hexp_ne : Real.exp (-a) ≠ 0 := ne_of_gt (Real.exp_pos _)
      have hexp_mul : Real.exp (-a) * Real.exp a = 1 := by
        rw [← Real.exp_add, neg_add_cancel, Real.exp_zero]
      field_simp [a, ne_of_gt hg_pos, hexp_ne, Real.exp_neg]
      nlinarith [hexp_mul]

/--
Lemma 4.1 Chebyshev/variance core: if `Y_g` has positive mean `EY`, variance
at most its mean, and `X_mu(g) >= Y_g` pointwise, then the reciprocal
expectation is at most `6 / EY`.
-/
theorem paper_im05_lemma4_1_reciprocal_bound_from_variance
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (X Y : Ω → ℕ) (EY : ℝ)
    (hEY :
      EconCSLib.pmfExp μ (fun ω => (Y ω : ℝ)) = EY)
    (hEY_pos : 0 < EY)
    (hvar :
      EconCSLib.pmfVariance μ (fun ω => (Y ω : ℝ)) ≤ EY)
    (hXY : ∀ ω, Y ω ≤ X ω) :
    im05_reciprocalCountExpectation μ X ≤ 6 / EY := by
  classical
  let low : Ω → Prop := fun ω => (Y ω : ℝ) < EY / 2
  have hq :
      EconCSLib.pmfProb μ low ≤ 4 / EY := by
    simpa [low] using
      (EconCSLib.pmfProb_lt_half_expectation_le_four_div_expectation_of_variance_le_expectation
          μ (fun ω => (Y ω : ℝ)) EY hEY hEY_pos hvar)
  have htwo_nonneg : 0 ≤ 2 / EY :=
    div_nonneg (by norm_num : (0 : ℝ) ≤ 2) hEY_pos.le
  have hhalf_pos : 0 < EY / 2 := by positivity
  have hpoint :
      ∀ ω,
        ((((Y ω + 1 : ℕ) : ℝ)⁻¹) ≤
          (if low ω then (1 : ℝ) else 0) + 2 / EY) := by
    intro ω
    by_cases hlow : low ω
    · have hrec_le_one :
          ((((Y ω + 1 : ℕ) : ℝ)⁻¹) ≤ 1) := by
        simpa using
          (EconCSLib.reciprocal_succ_nat_antitone
            (x := 0) (y := Y ω) (Nat.zero_le (Y ω)))
      have hone_le : (1 : ℝ) ≤ 1 + 2 / EY := by linarith
      exact le_trans hrec_le_one (by simpa [low, hlow] using hone_le)
    · have hY_ge : EY / 2 ≤ (Y ω : ℝ) := le_of_not_gt hlow
      have hY_succ : (Y ω : ℝ) ≤ ((Y ω + 1 : ℕ) : ℝ) := by
        exact_mod_cast Nat.le_succ (Y ω)
      have hden_ge : EY / 2 ≤ ((Y ω + 1 : ℕ) : ℝ) :=
        le_trans hY_ge hY_succ
      have hden_pos : 0 < ((Y ω + 1 : ℕ) : ℝ) := by
        exact_mod_cast Nat.succ_pos (Y ω)
      have hinv :
          (((Y ω + 1 : ℕ) : ℝ)⁻¹) ≤ (EY / 2)⁻¹ :=
        (inv_le_inv₀ hden_pos hhalf_pos).mpr hden_ge
      have hhalf_inv : (EY / 2)⁻¹ = 2 / EY := by
        field_simp [ne_of_gt hEY_pos]
      calc
        (((Y ω + 1 : ℕ) : ℝ)⁻¹) ≤ (EY / 2)⁻¹ := hinv
        _ = 2 / EY := hhalf_inv
        _ = (if low ω then (1 : ℝ) else 0) + 2 / EY := by
              simp [low, hlow]
  have hYrec :
      im05_reciprocalCountExpectation μ Y ≤
        EconCSLib.pmfProb μ low + 2 / EY := by
    unfold im05_reciprocalCountExpectation EconCSLib.pmfExpReciprocalSucc
    calc
      EconCSLib.pmfExp μ (fun ω => (((Y ω + 1 : ℕ) : ℝ)⁻¹)) ≤
          EconCSLib.pmfExp μ
            (fun ω => (if low ω then (1 : ℝ) else 0) + 2 / EY) :=
            EconCSLib.pmfExp_le_pmfExp_of_forall_le μ _ _ hpoint
      _ = EconCSLib.pmfProb μ low + 2 / EY := by
            rw [EconCSLib.pmfExp_add]
            simp [EconCSLib.pmfProb]
  have hXYrec :
      im05_reciprocalCountExpectation μ X ≤
        im05_reciprocalCountExpectation μ Y := by
    simpa [im05_reciprocalCountExpectation] using
      (EconCSLib.pmfExpReciprocalSucc_mono_of_forall_ge μ X Y hXY)
  calc
    im05_reciprocalCountExpectation μ X ≤
        im05_reciprocalCountExpectation μ Y := hXYrec
    _ ≤ EconCSLib.pmfProb μ low + 2 / EY := hYrec
    _ ≤ 4 / EY + 2 / EY := by
          simpa [add_comm, add_left_comm, add_assoc] using
            add_le_add_right hq (2 / EY)
    _ = 6 / EY := by ring

/--
Constant-factor variant of the Chebyshev/variance core.  If the corrected
tail count only satisfies `Var(Y_g) <= C * E[Y_g]`, the reciprocal expectation
bound survives with constant `(4C + 2) / E[Y_g]`.
-/
theorem paper_im05_lemma4_1_reciprocal_bound_from_variance_factor
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (X Y : Ω → ℕ) (EY C : ℝ)
    (hEY :
      EconCSLib.pmfExp μ (fun ω => (Y ω : ℝ)) = EY)
    (hEY_pos : 0 < EY)
    (hC_nonneg : 0 ≤ C)
    (hvar :
      EconCSLib.pmfVariance μ (fun ω => (Y ω : ℝ)) ≤ C * EY)
    (hXY : ∀ ω, Y ω ≤ X ω) :
    im05_reciprocalCountExpectation μ X ≤ (4 * C + 2) / EY := by
  classical
  let low : Ω → Prop := fun ω => (Y ω : ℝ) < EY / 2
  have hq :
      EconCSLib.pmfProb μ low ≤ 4 * C / EY := by
    simpa [low] using
      (EconCSLib.pmfProb_lt_half_expectation_le_four_mul_div_expectation_of_variance_le_mul_expectation
          μ (fun ω => (Y ω : ℝ)) EY C hEY hEY_pos hC_nonneg hvar)
  have htwo_nonneg : 0 ≤ 2 / EY :=
    div_nonneg (by norm_num : (0 : ℝ) ≤ 2) hEY_pos.le
  have hhalf_pos : 0 < EY / 2 := by positivity
  have hpoint :
      ∀ ω,
        ((((Y ω + 1 : ℕ) : ℝ)⁻¹) ≤
          (if low ω then (1 : ℝ) else 0) + 2 / EY) := by
    intro ω
    by_cases hlow : low ω
    · have hrec_le_one :
          ((((Y ω + 1 : ℕ) : ℝ)⁻¹) ≤ 1) := by
        simpa using
          (EconCSLib.reciprocal_succ_nat_antitone
            (x := 0) (y := Y ω) (Nat.zero_le (Y ω)))
      have hone_le : (1 : ℝ) ≤ 1 + 2 / EY := by linarith
      exact le_trans hrec_le_one (by simpa [low, hlow] using hone_le)
    · have hY_ge : EY / 2 ≤ (Y ω : ℝ) := le_of_not_gt hlow
      have hY_succ : (Y ω : ℝ) ≤ ((Y ω + 1 : ℕ) : ℝ) := by
        exact_mod_cast Nat.le_succ (Y ω)
      have hden_ge : EY / 2 ≤ ((Y ω + 1 : ℕ) : ℝ) :=
        le_trans hY_ge hY_succ
      have hden_pos : 0 < ((Y ω + 1 : ℕ) : ℝ) := by
        exact_mod_cast Nat.succ_pos (Y ω)
      have hinv :
          (((Y ω + 1 : ℕ) : ℝ)⁻¹) ≤ (EY / 2)⁻¹ :=
        (inv_le_inv₀ hden_pos hhalf_pos).mpr hden_ge
      have hhalf_inv : (EY / 2)⁻¹ = 2 / EY := by
        field_simp [ne_of_gt hEY_pos]
      calc
        (((Y ω + 1 : ℕ) : ℝ)⁻¹) ≤ (EY / 2)⁻¹ := hinv
        _ = 2 / EY := hhalf_inv
        _ = (if low ω then (1 : ℝ) else 0) + 2 / EY := by
              simp [low, hlow]
  have hYrec :
      im05_reciprocalCountExpectation μ Y ≤
        EconCSLib.pmfProb μ low + 2 / EY := by
    unfold im05_reciprocalCountExpectation EconCSLib.pmfExpReciprocalSucc
    calc
      EconCSLib.pmfExp μ (fun ω => (((Y ω + 1 : ℕ) : ℝ)⁻¹)) ≤
          EconCSLib.pmfExp μ
            (fun ω => (if low ω then (1 : ℝ) else 0) + 2 / EY) :=
            EconCSLib.pmfExp_le_pmfExp_of_forall_le μ _ _ hpoint
      _ = EconCSLib.pmfProb μ low + 2 / EY := by
            rw [EconCSLib.pmfExp_add]
            simp [EconCSLib.pmfProb]
  have hXYrec :
      im05_reciprocalCountExpectation μ X ≤
        im05_reciprocalCountExpectation μ Y := by
    simpa [im05_reciprocalCountExpectation] using
      (EconCSLib.pmfExpReciprocalSucc_mono_of_forall_ge μ X Y hXY)
  calc
    im05_reciprocalCountExpectation μ X ≤
        im05_reciprocalCountExpectation μ Y := hXYrec
    _ ≤ EconCSLib.pmfProb μ low + 2 / EY := hYrec
    _ ≤ 4 * C / EY + 2 / EY := by
          simpa [add_comm, add_left_comm, add_assoc] using
            add_le_add_right hq (2 / EY)
    _ = (4 * C + 2) / EY := by ring

/--
Constant-factor algebra endpoint for a repaired Lemma 4.1 route.  The exact
paper constant `12` corresponds to `C = 1`; any constant variance factor still
gives the same exponential-over-rank shape.
-/
theorem paper_im05_lemma4_1_algebra_from_lemma4_3_variance_factor
    (g n k : ℕ) (hg : 0 < g) (C EY reciprocal : ℝ)
    (hC_nonneg : 0 ≤ C)
    (hEY :
      (g : ℝ) / 2 *
          Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤ EY)
    (hreciprocal : reciprocal ≤ (4 * C + 2) / EY) :
    reciprocal ≤
      (8 * C + 4) * Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ)) /
        (g : ℝ) := by
  let a : ℝ := 8 * (n : ℝ) * (k : ℝ) / (g : ℝ)
  let B : ℝ := 4 * C + 2
  have hg_pos : 0 < (g : ℝ) := by exact_mod_cast hg
  have hL_pos : 0 < (g : ℝ) / 2 * Real.exp (-a) := by positivity
  have hB_nonneg : 0 ≤ B := by
    dsimp [B]
    nlinarith
  have hB :
      B / EY ≤ B / ((g : ℝ) / 2 * Real.exp (-a)) := by
    exact div_le_div_of_nonneg_left hB_nonneg hL_pos hEY
  calc
    reciprocal ≤ B / EY := by simpa [B] using hreciprocal
    _ ≤ B / ((g : ℝ) / 2 * Real.exp (-a)) := hB
    _ = (8 * C + 4) * Real.exp a / (g : ℝ) := by
      have hexp_ne : Real.exp (-a) ≠ 0 := ne_of_gt (Real.exp_pos _)
      have hexp_mul : Real.exp (-a) * Real.exp a = 1 := by
        rw [← Real.exp_add, neg_add_cancel, Real.exp_zero]
      field_simp [B, a, ne_of_gt hg_pos, hexp_ne, Real.exp_neg]
      nlinarith [hexp_mul]

/--
Lemma 4.1 paper-facing bridge: combine the variance/Chebyshev reciprocal
bound with the Lemma 4.3 expectation lower bound to obtain the displayed
`12 exp(8nk/g) / g` bound.
