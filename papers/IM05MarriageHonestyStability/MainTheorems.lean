mean rather than exactly by its mean.
-/
theorem paper_im05_lemma4_1_from_variance_factor_and_lemma4_3
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (X Y : Ω → ℕ)
