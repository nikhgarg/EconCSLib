/--
Lemma 4.3 expected-count wrapper from the deferred-decision prefix route.  For
each woman in the tail block, per-draw prefix conditional lower bounds and the
all-men independence identity provide the per-woman absence lower bound needed
for the tail-count expectation argument.
-/
theorem paper_im05_lemma4_3_expected_absent_count_lower_bound_from_prefix_bounds
    {Λ Ω I : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (ν : PMF Λ) (prefixOmit : I → ℕ → Λ → Prop)
    (μ : PMF Ω) (absent : I → Ω → Prop)
    [∀ i r, DecidablePred fun sample => prefixOmit i r sample]
    [∀ ω, DecidablePred fun i => absent i ω]
    [∀ i, DecidablePred fun ω => absent i ω]
    (tail : Finset I) (rank : I → ℕ) (g n k : ℕ)
    (hk_pos : 0 < k)
    (hg : 0 < g)
    (hcard : (g : ℝ) / 2 ≤ (tail.card : ℝ))
    (hhalf : ∀ i ∈ tail, (g : ℝ) / 2 ≤ (rank i : ℝ))
    (htwo_k : ∀ i ∈ tail, 2 * k < rank i)
    (hzero : ∀ i ∈ tail, ∀ sample, prefixOmit i 0 sample)
    (hnested : ∀ i ∈ tail, ∀ r, r < k →
      ∀ sample, prefixOmit i (r + 1) sample → prefixOmit i r sample)
    (hcond : ∀ i ∈ tail, ∀ r, r < k →
      1 - 1 / ((rank i - k : ℕ) : ℝ) ≤
        EconCSLib.pmfConditionalProb ν
          (fun sample => prefixOmit i r sample)
          (fun sample => prefixOmit i (r + 1) sample))
    (hall : ∀ i ∈ tail,
      EconCSLib.pmfProb μ (fun ω => absent i ω) =
        (EconCSLib.pmfProb ν (fun sample => prefixOmit i k sample)) ^ n) :
    (g : ℝ) / 2 *
        Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => absent i ω).card : ℝ)) := by
  classical
  refine
    paper_im05_lemma4_3_expected_absent_count_lower_bound_from_rank_tail
      μ absent tail rank g n k hg hcard ?_ hhalf ?_
  · intro i hi
    have h := htwo_k i hi
    omega
  · intro i hi
    exact
      paper_im05_lemma4_3_absence_probability_ge_exp_rank_from_prefix_bounds
        ν (prefixOmit i) μ (fun ω => absent i ω)
        (rank i) k n hk_pos (htwo_k i hi)
        (hzero i hi) (hnested i hi) (hcond i hi) (hall i hi)

/--
Lemma 4.3 expected-count wrapper from concrete list-prefix hit bounds.  This is
