-/
theorem paper_im05_theorem3_2_from_draw_usedBins_experiments_of_four_le
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype M] [DecidableEq W]
    (μ : PMF Ω) (X X₂ X₃ X₄ X₅ : Ω → ℕ) (good : Ω → Prop)
    [DecidablePred good]
    (ck : ℝ) (k n : ℕ) [NeZero n]
    (draws : Ω → M → Fin (k + 2) → W)
    [DecidablePred fun ω =>
      ∃ pair : im05_redundantPairIndex M k,
        im05_redundantPairBadEvent k draws pair ω]
    [∀ pair, DecidablePred (im05_redundantPairBadEvent k draws pair)]
    (hcardM : Fintype.card M = n)
    (hk : 4 ≤ k)
    (hck :
      ck ≤ (n : ℝ) * im05_reciprocalCountExpectation μ X)
    (h12 : ∀ ω, X₂ ω ≤ X ω)
    (h23 : ∀ ω, X₂ ω = X₃ ω)
    (heq : ∀ ω, good ω → X₃ ω = X₄ ω)
    (hbad_man :
      ∀ ω, ¬ good ω →
        ∃ m : M, (EconCSLib.occupancyUsedBins (draws ω m)).card ≤ k)
    (hbad_pair :
      ∀ pair,
        EconCSLib.pmfProb μ
          (im05_redundantPairBadEvent k draws pair) ≤ (n : ℝ)⁻¹ ^ 2)
    (h45 : ∀ ω, X₅ ω ≤ X₄ ω)
    (h5 :
      im05_reciprocalCountExpectation μ X₅ =
        im05_occupancyReciprocalExpectation ((k + 1) * n) n) :
    ck ≤ im05_uniformTheorem32Bound k := by
  exact paper_im05_theorem3_2_from_lemma6_2 μ X ck k n hck
    (paper_im05_lemma6_2_from_draw_usedBins_experiments_of_four_le
      μ X X₂ X₃ X₄ X₅ good k n draws hcardM hk
      h12 h23 heq hbad_man hbad_pair h45 h5)

/--
Uniform-symmetry bridge toward Corollary 3.1: if Theorem 3.2 bounds the
expected number of women with more than one stable husband, and all women have
the same probability of that event, then any fixed woman's probability is at
most the Theorem 3.2 bound divided by `n`.
-/
theorem paper_im05_theorem3_2_fixed_woman_probability_bound_of_symmetry
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype M] [Fintype W] [DecidableEq W]
    (μ : PMF Ω)
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ)
    (k n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n)
    (hbound :
      EconCSLib.pmfExp μ
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) ≤
          im05_uniformTheorem32Bound k)
    (hsym : ∀ w₁ w₂ : W,
      @EconCSLib.pmfProb Ω _ _ μ
          (fun ω =>
            im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w₁)
          (Classical.decPred _) =
        @EconCSLib.pmfProb Ω _ _ μ
          (fun ω =>
            im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w₂)
          (Classical.decPred _))
    (w : W) :
    @EconCSLib.pmfProb Ω _ _ μ
        (fun ω =>
          im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
        (Classical.decPred _) ≤
      im05_uniformTheorem32Bound k / (n : ℝ) := by
  classical
  let prob : W → ℝ := fun w' =>
    @EconCSLib.pmfProb Ω _ _ μ
      (fun ω =>
        im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w')
      (Classical.decPred _)
  have hnpos : 0 < (n : ℝ) := by
    exact_mod_cast (NeZero.pos n)
  have hsum_const :
      ∑ w' : W, prob w' = (n : ℝ) * prob w := by
    calc
      ∑ w' : W, prob w' = ∑ _w' : W, prob w := by
          refine Finset.sum_congr rfl ?_
          intro w' _
          exact hsym w' w
      _ = (Fintype.card W : ℝ) * prob w := by
          simp
      _ = (n : ℝ) * prob w := by
          rw [hcardW]
  have hlinearity :=
    paper_im05_ck_linearity_expected_multiStableHusbandCount μ val_m val_w
  have hmul_le :
      (n : ℝ) * prob w ≤ im05_uniformTheorem32Bound k := by
    calc
      (n : ℝ) * prob w = ∑ w' : W, prob w' := hsum_const.symm
      _ = EconCSLib.pmfExp μ
            (fun ω =>
              (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) := by
          simpa [prob] using hlinearity.symm
      _ ≤ im05_uniformTheorem32Bound k := hbound
  rw [le_div_iff₀ hnpos]
  simpa [prob, mul_comm] using hmul_le

/--
Uniform-relabeling certificate for the symmetry hypothesis in the fixed-woman
Corollary 3.1 bridge.  If every pair of women can be exchanged by a
sample-space equivalence that carries the multi-stable-husband event for the
first woman to the corresponding event for the second, then the event
probabilities are equal under the uniform law.
-/
theorem paper_im05_fixed_woman_probability_symmetry_of_uniform_relabeling
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [Nonempty Ω]
    [Fintype M] [Fintype W] [DecidableEq W]
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ)
    (relabel : W → W → Ω ≃ Ω)
    (hrel :
      ∀ w₁ w₂ ω,
        im05_hasMoreThanOneStableHusband
            (val_m ((relabel w₁ w₂) ω))
            (val_w ((relabel w₁ w₂) ω)) w₁ ↔
          im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w₂) :
    ∀ w₁ w₂ : W,
      @EconCSLib.pmfProb Ω _ _
          (EconCSLib.uniformPMF Ω)
          (fun ω =>
            im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w₁)
          (Classical.decPred _) =
        @EconCSLib.pmfProb Ω _ _
          (EconCSLib.uniformPMF Ω)
          (fun ω =>
            im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w₂)
          (Classical.decPred _) := by
  classical
  intro w₁ w₂
  exact EconCSLib.pmfProb_uniformPMF_eq_of_comp_equiv
    (relabel w₁ w₂)
    (fun ω =>
      im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w₁)
    (fun ω =>
      im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w₂)
    (hrel w₁ w₂)

/--
Corollary 3.1 fixed-woman probability bound under a concrete uniform
exchangeability certificate, rather than an already-simplified symmetry
hypothesis.
-/
theorem paper_im05_theorem3_2_fixed_woman_probability_bound_of_uniform_relabeling
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [Nonempty Ω]
    [Fintype M] [Fintype W] [DecidableEq W]
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ)
    (k n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n)
    (hbound :
      EconCSLib.pmfExp (EconCSLib.uniformPMF Ω)
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) ≤
          im05_uniformTheorem32Bound k)
    (relabel : W → W → Ω ≃ Ω)
    (hrel :
      ∀ w₁ w₂ ω,
        im05_hasMoreThanOneStableHusband
            (val_m ((relabel w₁ w₂) ω))
            (val_w ((relabel w₁ w₂) ω)) w₁ ↔
          im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w₂)
    (w : W) :
    @EconCSLib.pmfProb Ω _ _
        (EconCSLib.uniformPMF Ω)
        (fun ω =>
          im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
        (Classical.decPred _) ≤
      im05_uniformTheorem32Bound k / (n : ℝ) := by
  exact paper_im05_theorem3_2_fixed_woman_probability_bound_of_symmetry
    (EconCSLib.uniformPMF Ω) val_m val_w k n hcardW hbound
    (paper_im05_fixed_woman_probability_symmetry_of_uniform_relabeling
      val_m val_w relabel hrel) w

/--
Fully factored exchangeability wrapper for the fixed-woman uniform corollary.
The remaining concrete random-list obligation is to provide, for each pair of
women, a sample-space relabeling and a woman permutation such that the
transformed sample's valuation profile is exactly the woman-relabelled original
profile.
-/
theorem paper_im05_theorem3_2_fixed_woman_probability_bound_of_uniform_sample_woman_relabeling
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [Nonempty Ω]
    [Fintype M] [DecidableEq M] [Fintype W] [DecidableEq W]
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ)
    (k n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n)
    (hbound :
      EconCSLib.pmfExp (EconCSLib.uniformPMF Ω)
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) ≤
          im05_uniformTheorem32Bound k)
    (sampleRelabel : W → W → Ω ≃ Ω)
    (womanRelabel : W → W → W ≃ W)
    (hwomanRelabel : ∀ w₁ w₂, womanRelabel w₁ w₂ w₂ = w₁)
    (hm_relabel :
      ∀ w₁ w₂ ω m x,
        val_m ((sampleRelabel w₁ w₂) ω) m x =
          val_m ω m ((womanRelabel w₁ w₂).symm x))
    (hw_relabel :
      ∀ w₁ w₂ ω x m,
        val_w ((sampleRelabel w₁ w₂) ω) x m =
          val_w ω ((womanRelabel w₁ w₂).symm x) m)
    (w : W) :
    @EconCSLib.pmfProb Ω _ _
        (EconCSLib.uniformPMF Ω)
        (fun ω =>
          im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
        (Classical.decPred _) ≤
      im05_uniformTheorem32Bound k / (n : ℝ) := by
  refine paper_im05_theorem3_2_fixed_woman_probability_bound_of_uniform_relabeling
    val_m val_w k n hcardW hbound sampleRelabel ?_ w
  intro w₁ w₂ ω
  exact
    paper_im05_hasMoreThanOneStableHusband_of_woman_relabeling
      (womanRelabel w₁ w₂)
      (val_m ω) (val_m ((sampleRelabel w₁ w₂) ω))
      (val_w ω) (val_w ((sampleRelabel w₁ w₂) ω))
      w₂ w₁ (hwomanRelabel w₁ w₂)
      (hm_relabel w₁ w₂ ω)
      (hw_relabel w₁ w₂ ω)

/--
Uniform finite-function sample-space specialization of the fixed-woman
exchangeability wrapper. This covers with-replacement draw spaces such as the
amnesiac prefixes in Experiments 3 and 5: relabel the sample by applying the
woman permutation pointwise to every coordinate.
-/
theorem paper_im05_theorem3_2_fixed_woman_probability_bound_of_uniform_function_sample_woman_relabeling
    {ι M W : Type*} [Fintype ι] [DecidableEq ι]
    [Fintype M] [DecidableEq M] [Fintype W] [DecidableEq W] [Nonempty W]
    (val_m : (ι → W) → M → W → ℝ)
    (val_w : (ι → W) → W → M → ℝ)
    (k n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n)
    (hbound :
      EconCSLib.pmfExp (EconCSLib.uniformPMF (ι → W))
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) ≤
          im05_uniformTheorem32Bound k)
    (womanRelabel : W → W → W ≃ W)
    (hwomanRelabel : ∀ w₁ w₂, womanRelabel w₁ w₂ w₂ = w₁)
    (hm_relabel :
      ∀ w₁ w₂ ω m x,
        val_m (fun i => womanRelabel w₁ w₂ (ω i)) m x =
          val_m ω m ((womanRelabel w₁ w₂).symm x))
    (hw_relabel :
      ∀ w₁ w₂ ω x m,
        val_w (fun i => womanRelabel w₁ w₂ (ω i)) x m =
          val_w ω ((womanRelabel w₁ w₂).symm x) m)
    (w : W) :
    @EconCSLib.pmfProb (ι → W) _ _
        (EconCSLib.uniformPMF (ι → W))
        (fun ω =>
          im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
        (Classical.decPred _) ≤
      im05_uniformTheorem32Bound k / (n : ℝ) := by
  classical
  let sampleRelabel : W → W → (ι → W) ≃ (ι → W) := fun w₁ w₂ =>
    { toFun := fun ω i => womanRelabel w₁ w₂ (ω i)
      invFun := fun ω i => (womanRelabel w₁ w₂).symm (ω i)
      left_inv := by
        intro ω
        funext i
        simp
      right_inv := by
        intro ω
        funext i
        simp }
  exact
    paper_im05_theorem3_2_fixed_woman_probability_bound_of_uniform_sample_woman_relabeling
      val_m val_w k n hcardW hbound sampleRelabel womanRelabel
      hwomanRelabel
      (by
        intro w₁ w₂ ω m x
        exact hm_relabel w₁ w₂ ω m x)
      (by
        intro w₁ w₂ ω x m
        exact hw_relabel w₁ w₂ ω x m)
      w

/--
Ordered without-replacement sample-space specialization of the fixed-woman
exchangeability wrapper, modeled as a uniform draw from injective finite
functions. This is the sample-space shape of Experiment 2's `k` different
women per man, before connecting those lists to valuation profiles.
-/
theorem paper_im05_theorem3_2_fixed_woman_probability_bound_of_uniform_injective_function_sample_woman_relabeling
    {ι M W : Type*} [Fintype ι] [DecidableEq ι]
    [Fintype M] [DecidableEq M] [Fintype W] [DecidableEq W]
    [Nonempty {f : ι → W // Function.Injective f}]
    (val_m : {f : ι → W // Function.Injective f} → M → W → ℝ)
    (val_w : {f : ι → W // Function.Injective f} → W → M → ℝ)
    (k n : ℕ) [NeZero n]
    (hcardW : Fintype.card W = n)
    (hbound :
      EconCSLib.pmfExp
          (EconCSLib.uniformPMF {f : ι → W // Function.Injective f})
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) ≤
          im05_uniformTheorem32Bound k)
    (womanRelabel : W → W → W ≃ W)
    (hwomanRelabel : ∀ w₁ w₂, womanRelabel w₁ w₂ w₂ = w₁)
    (hm_relabel :
      ∀ w₁ w₂ ω m x,
        val_m (EconCSLib.injectiveFunRangeRelabelEquiv
            (womanRelabel w₁ w₂) ω) m x =
          val_m ω m ((womanRelabel w₁ w₂).symm x))
    (hw_relabel :
      ∀ w₁ w₂ ω x m,
        val_w (EconCSLib.injectiveFunRangeRelabelEquiv
            (womanRelabel w₁ w₂) ω) x m =
          val_w ω ((womanRelabel w₁ w₂).symm x) m)
    (w : W) :
    @EconCSLib.pmfProb {f : ι → W // Function.Injective f} _ _
        (EconCSLib.uniformPMF {f : ι → W // Function.Injective f})
        (fun ω =>
          im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
        (Classical.decPred _) ≤
      im05_uniformTheorem32Bound k / (n : ℝ) := by
  classical
  let sampleRelabel :
      W → W →
        {f : ι → W // Function.Injective f} ≃
          {f : ι → W // Function.Injective f} :=
    fun w₁ w₂ =>
      EconCSLib.injectiveFunRangeRelabelEquiv (womanRelabel w₁ w₂)
  exact
    paper_im05_theorem3_2_fixed_woman_probability_bound_of_uniform_sample_woman_relabeling
      val_m val_w k n hcardW hbound sampleRelabel womanRelabel
      hwomanRelabel
      (by
        intro w₁ w₂ ω m x
        exact hm_relabel w₁ w₂ ω m x)
      (by
        intro w₁ w₂ ω x m
        exact hw_relabel w₁ w₂ ω x m)
      w

/--
Corollary 3.1 asymptotic endpoint: any nonnegative fixed-agent failure
probability sequence bounded by the uniform Theorem 3.2 constant divided by
`n` vanishes.
-/
theorem paper_im05_corollary3_1_probability_bound_implies_o_one
    (k : ℕ) (p : ℕ → ℝ)
    (hnonneg : ∀ n, 0 ≤ p n)
    (hbound : ∀ n, 0 < n →
      p n ≤ im05_uniformTheorem32Bound k / (n : ℝ)) :
    EconCSLib.Math.TendsToZero p := by
  have hC : 0 < im05_uniformTheorem32Bound k := by
    unfold im05_uniformTheorem32Bound
    have hexp : 0 < Real.exp ((k : ℝ) + 1) := Real.exp_pos _
    have hsq : 0 ≤ (k : ℝ) ^ 2 := sq_nonneg _
    nlinarith
  exact EconCSLib.Math.TendsToZero_of_nonneg_le_const_div
    p hC hnonneg hbound

/--
Theorem 3.2-to-Theorem 3.1 asymptotic bridge: once the uniform model supplies
the paper's constant bound on `c_k(n)`, the fraction `c_k(n)/n` vanishes.
-/
theorem paper_im05_theorem3_2_bound_implies_fraction_vanishes
    (k : ℕ) (ck : ℕ → ℝ)
    (h_nonneg : ∀ n, 0 ≤ ck n)
    (h_bound : ∀ n, ck n ≤ im05_uniformTheorem32Bound k) :
    im05_fraction_vanishes ck := by
  unfold im05_fraction_vanishes
  have hC : 0 < im05_uniformTheorem32Bound k := by
    unfold im05_uniformTheorem32Bound
    have hexp : 0 < Real.exp ((k : ℝ) + 1) := Real.exp_pos _
    have hsq : 0 ≤ (k : ℝ) ^ 2 := sq_nonneg _
    nlinarith
  exact EconCSLib.Math.TendsToZero_ratio_of_nonneg_bounded
    ck hC h_nonneg h_bound

/--
Theorem 3.1 final asymptotic summation shape.  After Lemma 4.1, IM05 bound
`c_k(n) / n` by a sum of a `1 / log n` term and a `log n / sqrt n` term; both
vanish for fixed `k`.
-/
theorem paper_im05_theorem3_1_log_sqrt_ratio_bound_implies_fraction_vanishes
    (k : ℕ) (ck : ℕ → ℝ)
    (h_nonneg : ∀ n, 0 ≤ ck n)
    (h_bound : ∀ᶠ n in Filter.atTop,
      ck n / (n : ℝ) ≤
        (16 * (k : ℝ)) / Real.log (n : ℝ) +
          (3 / (4 * (k : ℝ))) *
            (Real.log (n : ℝ) / Real.sqrt (n : ℝ))) :
    im05_fraction_vanishes ck := by
  unfold im05_fraction_vanishes
  let bound : ℕ → ℝ := fun n =>
    (16 * (k : ℝ)) / Real.log (n : ℝ) +
      (3 / (4 * (k : ℝ))) *
        (Real.log (n : ℝ) / Real.sqrt (n : ℝ))
  have hbound_zero : Filter.Tendsto bound Filter.atTop (nhds 0) := by
    have hlog :
        Filter.Tendsto
          (fun n : ℕ => (16 * (k : ℝ)) / Real.log (n : ℝ))
          Filter.atTop (nhds 0) :=
      EconCSLib.Math.tendsto_const_div_log_nat_nhds_zero (16 * (k : ℝ))
    have hsqrt :
        Filter.Tendsto
          (fun n : ℕ =>
            (3 / (4 * (k : ℝ))) *
              (Real.log (n : ℝ) / Real.sqrt (n : ℝ)))
          Filter.atTop (nhds 0) :=
      by
        simpa using
          EconCSLib.Math.tendsto_log_div_sqrt_nat_nhds_zero.const_mul
            (3 / (4 * (k : ℝ)))
    simpa [bound] using hlog.add hsqrt
  refine
    EconCSLib.Math.TendsToZero_of_eventually_abs_le_tendsto_zero
      (fun n => ck n / (n : ℝ)) bound hbound_zero ?_
  filter_upwards [h_bound, Filter.eventually_gt_atTop 0] with n hn_bound hn_pos
  have hn_pos_real : 0 < (n : ℝ) := by
    exact_mod_cast hn_pos
  have hratio_nonneg : 0 ≤ ck n / (n : ℝ) :=
    div_nonneg (h_nonneg n) hn_pos_real.le
  rw [abs_of_nonneg hratio_nonneg]
  simpa [bound] using hn_bound

/--
The same Theorem 3.1 asymptotic endpoint in the paper's pre-division count
form:
`c_k(n) <= 16nk / log n + 3 sqrt(n) log(n) / (4k)` implies
`c_k(n) / n -> 0`.
-/
theorem paper_im05_theorem3_1_log_sqrt_count_bound_implies_fraction_vanishes
    (k : ℕ) (hk : 0 < k) (ck : ℕ → ℝ)
    (h_nonneg : ∀ n, 0 ≤ ck n)
    (h_bound : ∀ᶠ n in Filter.atTop,
      ck n ≤
        (16 * (n : ℝ) * (k : ℝ)) / Real.log (n : ℝ) +
          (3 * Real.sqrt (n : ℝ) * Real.log (n : ℝ)) /
            (4 * (k : ℝ))) :
    im05_fraction_vanishes ck := by
  refine
    paper_im05_theorem3_1_log_sqrt_ratio_bound_implies_fraction_vanishes
      k ck h_nonneg ?_
  filter_upwards [h_bound, Filter.eventually_ge_atTop 3] with n hn_bound hn_ge
  have hn_pos_nat : 0 < n := lt_of_lt_of_le (by norm_num : 0 < 3) hn_ge
  have hn_gt_one_nat : 1 < n := lt_of_lt_of_le (by norm_num : 1 < 3) hn_ge
  have hn_pos : 0 < (n : ℝ) := by
    exact_mod_cast hn_pos_nat
  have hn_nonneg : 0 ≤ (n : ℝ) := hn_pos.le
  have hk_pos : 0 < (k : ℝ) := by
    exact_mod_cast hk
  have hsqrt_pos : 0 < Real.sqrt (n : ℝ) := Real.sqrt_pos.mpr hn_pos
  have hlog_pos : 0 < Real.log (n : ℝ) := by
    exact Real.log_pos (by exact_mod_cast hn_gt_one_nat)
  calc
    ck n / (n : ℝ) ≤
        ((16 * (n : ℝ) * (k : ℝ)) / Real.log (n : ℝ) +
          (3 * Real.sqrt (n : ℝ) * Real.log (n : ℝ)) /
            (4 * (k : ℝ))) / (n : ℝ) :=
        div_le_div_of_nonneg_right hn_bound hn_pos.le
    _ = (16 * (k : ℝ)) / Real.log (n : ℝ) +
          (3 / (4 * (k : ℝ))) *
            (Real.log (n : ℝ) / Real.sqrt (n : ℝ)) := by
        have hsqrt_sq :
            Real.sqrt (n : ℝ) * Real.sqrt (n : ℝ) = (n : ℝ) := by
          rw [← pow_two, Real.sq_sqrt hn_nonneg]
        field_simp [ne_of_gt hn_pos, ne_of_gt hk_pos, ne_of_gt hsqrt_pos,
          ne_of_gt hlog_pos]
        nlinarith [hsqrt_sq]

end IM05MarriageHonestyStability
