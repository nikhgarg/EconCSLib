/--
A source-shaped step weakly improves the target woman's current held value when
her proposal history has a nonnegative best-so-far proposer and matched men
have already proposed.
-/
theorem im05_algorithm41SourceStep_target_value_mono
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hmatched : MatchedProposedInvariant s)
    (hbest_nonneg :
      ∃ best : M,
        im05_algorithm41BestProposedSoFar val_w s target best ∧
          0 ≤ val_w target best) :
    valW val_w target (s.w_match target) ≤
      valW val_w target
        ((im05_algorithm41SourceStep val_m val_w s).w_match target) := by
  classical
  by_cases hactive : ∃ m, IsActiveMan val_m s m
  · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · by_cases htarget : daStepChosenWoman val_m s hactive = target
      · subst target
        have hhistory :
            im05_algorithm41HistoryAccepts val_w s
              (daStepChosenWoman val_m s hactive)
              (daStepChosenMan val_m s hactive) := by
          simpa [im05_algorithm41SourceStepAccepts] using hacc
        cases hcur : s.w_match (daStepChosenWoman val_m s hactive) with
        | none =>
            rcases hbest_nonneg with ⟨best, hbest, hbest_nonneg⟩
            have hle :
                val_w (daStepChosenWoman val_m s hactive) best ≤
                  val_w (daStepChosenWoman val_m s hactive)
                    (daStepChosenMan val_m s hactive) :=
              not_lt.mp (hhistory best hbest.1)
            have hnew_nonneg :
                0 ≤
                  val_w (daStepChosenWoman val_m s hactive)
                    (daStepChosenMan val_m s hactive) := by
              linarith
            simpa [im05_algorithm41SourceStep, hactive, hacc, hcur, valW]
              using hnew_nonneg
        | some current =>
            have hcurrent_match :
                s.m_match current = some (daStepChosenWoman val_m s hactive) :=
              (s.consistent current (daStepChosenWoman val_m s hactive)).2 hcur
            have hcurrent_proposed :
                im05_algorithm41HasProposedTo s current
                  (daStepChosenWoman val_m s hactive) :=
              hmatched current (daStepChosenWoman val_m s hactive) hcurrent_match
            have hle :
                val_w (daStepChosenWoman val_m s hactive) current ≤
                  val_w (daStepChosenWoman val_m s hactive)
                    (daStepChosenMan val_m s hactive) :=
              not_lt.mp (hhistory current hcurrent_proposed)
            simpa [im05_algorithm41SourceStep, hactive, hacc, hcur, valW]
              using hle
      · have hsame :
          (im05_algorithm41SourceStep val_m val_w s).w_match target =
            s.w_match target := by
          have htarget' :
              target ≠ daStepChosenWoman val_m s hactive := by
            intro h
            exact htarget h.symm
          simp [im05_algorithm41SourceStep, hactive, hacc, Function.update,
            htarget']
        simp [hsame]
    · have hsame :
        (im05_algorithm41SourceStep val_m val_w s).w_match target =
          s.w_match target := by
        simp [im05_algorithm41SourceStep, hactive, hacc]
      simp [hsame]
  · simp [im05_algorithm41SourceStep, hactive]

/--
Paper-facing output certificate for Algorithm 4.1/Theorem 4.1.

The source algorithm is supposed to output exactly the stable husbands of `g`,
from `g`'s worst stable husband to her best stable husband. This certificate
isolates that contract from the still-open continued-proposal trace.
-/
noncomputable def im05_algorithm41StableHusbandOutput
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (output : List M) : Prop :=
  output.Nodup ∧
    output.toFinset = im05_stableHusbands val_m val_w g ∧
      im05_worstToBestForWoman val_w g output

/-- Membership in a certified Algorithm 4.1 output is stable-husband membership. -/
theorem im05_algorithm41StableHusbandOutput_mem_iff
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (output : List M)
    (houtput : im05_algorithm41StableHusbandOutput val_m val_w g output)
    (m : M) :
    m ∈ output ↔ m ∈ im05_stableHusbands val_m val_w g := by
  classical
  rcases houtput with ⟨_hnodup, hset, _horder⟩
  rw [← hset]
  simp

/-- A certified Algorithm 4.1 output has the stable-husband cardinality. -/
theorem im05_algorithm41StableHusbandOutput_length_eq_card
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (output : List M)
    (houtput : im05_algorithm41StableHusbandOutput val_m val_w g output) :
    output.length = (im05_stableHusbands val_m val_w g).card := by
  classical
  rcases houtput with ⟨hnodup, hset, _horder⟩
  have hcard := congrArg Finset.card hset
  rw [List.card_toFinset, List.dedup_eq_self.2 hnodup] at hcard
  simpa using hcard

/--
Theorem 4.1, conditional output-contract form: any Algorithm 4.1 output
certificate contains exactly the stable husbands of `g`, has the corresponding
cardinality, and is ordered from `g`'s worst stable husband to her best.
-/
theorem paper_im05_theorem4_1_outputs_exactly_stable_husbands_of_algorithm41_certificate
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (output : List M)
    (houtput : im05_algorithm41StableHusbandOutput val_m val_w g output) :
    (∀ m : M, m ∈ output ↔ m ∈ im05_stableHusbands val_m val_w g) ∧
      output.length = (im05_stableHusbands val_m val_w g).card ∧
        im05_worstToBestForWoman val_w g output := by
  refine ⟨?_, ?_, ?_⟩
  · intro m
    exact im05_algorithm41StableHusbandOutput_mem_iff
      val_m val_w g output houtput m
  · exact im05_algorithm41StableHusbandOutput_length_eq_card
      val_m val_w g output houtput
  · exact houtput.2.2

/--
Under strict woman preferences, the stable-husband set admits a worst-to-best
output certificate. This is an abstract list existence result, not the
Algorithm 4.1 trace theorem.
-/
theorem im05_algorithm41StableHusbandOutput_exists_of_strictWomen
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (hstrictW : WomenStrictPreferenceProfile val_w) :
    ∃ output : List M,
      im05_algorithm41StableHusbandOutput val_m val_w g output := by
  classical
  let r : M → M → Prop := fun m₁ m₂ => val_w g m₁ ≤ val_w g m₂
  letI : IsTrans M r := ⟨by
    intro a b c hab hbc
    exact le_trans hab hbc⟩
  letI : Std.Antisymm r := ⟨by
    intro a b hab hba
    exact hstrictW g a b (le_antisymm hab hba)⟩
  letI : Std.Total r := ⟨by
    intro a b
    exact le_total (val_w g a) (val_w g b)⟩
  refine ⟨(im05_stableHusbands val_m val_w g).sort r, ?_⟩
  refine ⟨?_, ?_, ?_⟩
  · exact (im05_stableHusbands val_m val_w g).sort_nodup r
  · exact (im05_stableHusbands val_m val_w g).sort_toFinset r
  · exact (im05_stableHusbands val_m val_w g).pairwise_sort r

/--
Abstract Theorem 4.1 list existence: strict woman preferences are enough to
enumerate the target woman's stable husbands from worst to best. The remaining
Algorithm 4.1 work is to prove the paper's continued-proposal run realizes such
a certificate.
-/
theorem paper_im05_theorem4_1_ordered_stable_husband_list_exists
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (hstrictW : WomenStrictPreferenceProfile val_w) :
    ∃ output : List M,
      (∀ m : M, m ∈ output ↔ m ∈ im05_stableHusbands val_m val_w g) ∧
        output.length = (im05_stableHusbands val_m val_w g).card ∧
          im05_worstToBestForWoman val_w g output := by
  rcases im05_algorithm41StableHusbandOutput_exists_of_strictWomen
      val_m val_w g hstrictW with
    ⟨output, houtput⟩
  exact ⟨output,
    paper_im05_theorem4_1_outputs_exactly_stable_husbands_of_algorithm41_certificate
      val_m val_w g output houtput⟩

/--
The Algorithm 4.1 starting state: run men-proposing DA once, divorce the target
woman `g`, and keep the accumulated proposal histories.

This is a resumed-DA scaffold for the paper proof, not yet the full source
Algorithm 4.1 state.  The source algorithm remembers the best proposer to `g`
so far after each divorce and has `g` reject future suitors below that standard;
the plain `DAState` only stores the current match, so the threshold still needs
a separate model before this trace can be called source-faithful.
-/
noncomputable def im05_algorithm41DivorcedState
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : DAState M W :=
  divorceWomanState (deferredAcceptanceState val_m val_w) g

/-- The Algorithm 4.1 continued-proposal state after `steps` resumed DA steps. -/
noncomputable def im05_algorithm41StateAfterSteps
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (steps : ℕ) : DAState M W :=
  daStateAfterStepsFrom val_m val_w
    (im05_algorithm41DivorcedState val_m val_w g) steps

/--
The source-shaped Algorithm 4.1 state after `steps` continued-proposal steps.
This uses the proposal-history acceptance rule from Step 4(a), unlike
`im05_algorithm41StateAfterSteps`, which is only the ordinary resumed-DA
scaffold.
-/
noncomputable def im05_algorithm41SourceStateAfterSteps
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (steps : ℕ) : DAState M W :=
  im05_algorithm41SourceStateAfterStepsFrom val_m val_w
    (im05_algorithm41DivorcedState val_m val_w g) steps

/--
The corrected source-shaped Algorithm 4.1 state after `steps` proposal steps,
with the target immediately divorced after every accepted proposal to her.
-/
noncomputable def im05_algorithm41SourceDivorceTargetStateAfterSteps
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (steps : ℕ) : DAState M W :=
  im05_algorithm41SourceDivorceTargetStateAfterStepsFrom val_m val_w g
    (im05_algorithm41DivorcedState val_m val_w g) steps

/-- The initial husband output by Algorithm 4.1 before the first divorce. -/
noncomputable def im05_algorithm41InitialHusband
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : Option M :=
  (deferredAcceptanceState val_m val_w).w_match g

/--
The men who hold `g` at some point in the first `steps + 1` states of the
Algorithm 4.1 resumed run, in first-appearance order.
-/
noncomputable def im05_algorithm41HeldMenPrefix
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (steps : ℕ) : List M :=
  ((List.range (steps + 1)).filterMap fun t =>
    (im05_algorithm41StateAfterSteps val_m val_w g t).w_match g).dedup

/--
The men who hold `g` at some point in the first `steps + 1` states of the
source-shaped Algorithm 4.1 run, in first-appearance order.
-/
noncomputable def im05_algorithm41SourceHeldMenPrefix
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (steps : ℕ) : List M :=
  ((List.range (steps + 1)).filterMap fun t =>
    (im05_algorithm41SourceStateAfterSteps val_m val_w g t).w_match g).dedup

/--
The output-event list for the corrected source-shaped Algorithm 4.1 trace:
the initial DA husband, followed by every later suitor accepted by the target
before the immediate Step 2 divorce.
-/
noncomputable def im05_algorithm41SourceDivorceTargetAcceptedMenPrefix
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (steps : ℕ) : List M :=
  (match im05_algorithm41InitialHusband val_m val_w g with
    | none => []
    | some m => [m]) ++
  ((List.range steps).filterMap fun t =>
    im05_algorithm41SourceStepTargetAccepted val_m val_w g
      (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t))

/-- The resumed Algorithm 4.1 state at the uniform finite termination horizon. -/
noncomputable def im05_algorithm41FinalState
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : DAState M W :=
  im05_algorithm41StateAfterSteps val_m val_w g
    (Fintype.card M * Fintype.card W)

/-- The source-shaped Algorithm 4.1 state at the uniform finite horizon. -/
noncomputable def im05_algorithm41SourceFinalState
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : DAState M W :=
  im05_algorithm41SourceStateAfterSteps val_m val_w g
    (Fintype.card M * Fintype.card W)

/-- The corrected target-divorcing source state at the uniform finite horizon. -/
noncomputable def im05_algorithm41SourceDivorceTargetFinalState
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : DAState M W :=
  im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g
    (Fintype.card M * Fintype.card W)

/-- The men who hold `g` during the finite resumed Algorithm 4.1 run. -/
noncomputable def im05_algorithm41HeldMen
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : List M :=
  im05_algorithm41HeldMenPrefix val_m val_w g
    (Fintype.card M * Fintype.card W)

/-- The men who hold `g` during the finite source-shaped Algorithm 4.1 run. -/
noncomputable def im05_algorithm41SourceHeldMen
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : List M :=
  im05_algorithm41SourceHeldMenPrefix val_m val_w g
    (Fintype.card M * Fintype.card W)

/-- The corrected finite Algorithm 4.1 output-event list. -/
noncomputable def im05_algorithm41SourceDivorceTargetAcceptedMen
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) : List M :=
  im05_algorithm41SourceDivorceTargetAcceptedMenPrefix val_m val_w g
    (Fintype.card M * Fintype.card W)

@[simp] theorem im05_algorithm41DivorcedState_w_match_target
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) :
    (im05_algorithm41DivorcedState val_m val_w g).w_match g = none := by
  simp [im05_algorithm41DivorcedState]

theorem im05_algorithm41SourceDivorceTargetStateAfterSteps_w_match_target_none
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (steps : ℕ) :
    (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g steps).w_match
      g = none := by
  exact
    im05_algorithm41SourceDivorceTargetStateAfterStepsFrom_w_match_target_none_of_none
      val_m val_w g (im05_algorithm41DivorcedState val_m val_w g) steps
      (im05_algorithm41DivorcedState_w_match_target val_m val_w g)

theorem im05_algorithm41SourceDivorceTargetFinalState_w_match_target_none
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) :
    (im05_algorithm41SourceDivorceTargetFinalState val_m val_w g).w_match
      g = none := by
  simpa [im05_algorithm41SourceDivorceTargetFinalState] using
    im05_algorithm41SourceDivorceTargetStateAfterSteps_w_match_target_none
      val_m val_w g (Fintype.card M * Fintype.card W)

theorem im05_algorithm41DivorcedState_atMostOneActiveMan
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) :
    im05_atMostOneActiveMan val_m
      (im05_algorithm41DivorcedState val_m val_w g) := by
  simpa [im05_algorithm41DivorcedState] using
    im05_divorceWomanState_atMostOneActiveMan_of_not_active
      val_m (deferredAcceptanceState val_m val_w) g
      (deferredAcceptanceState_terminated val_m val_w)

theorem im05_algorithm41SourceDivorceTargetStateAfterSteps_atMostOneActiveMan
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (steps : ℕ) :
    im05_atMostOneActiveMan val_m
      (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g steps) := by
  exact
    im05_algorithm41SourceDivorceTargetStateAfterStepsFrom_atMostOneActive_of_target_unmatched
      val_m val_w g (im05_algorithm41DivorcedState val_m val_w g) steps
      (im05_algorithm41DivorcedState_w_match_target val_m val_w g)
      (im05_algorithm41DivorcedState_atMostOneActiveMan val_m val_w g)

theorem im05_algorithm41SourceDivorceTargetFinalState_atMostOneActiveMan
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) :
    im05_atMostOneActiveMan val_m
      (im05_algorithm41SourceDivorceTargetFinalState val_m val_w g) := by
  simpa [im05_algorithm41SourceDivorceTargetFinalState] using
    im05_algorithm41SourceDivorceTargetStateAfterSteps_atMostOneActiveMan
      val_m val_w g (Fintype.card M * Fintype.card W)

theorem im05_algorithm41SourceStepTargetAccepted_sourceStep_terminated
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    {t : ℕ} {m : M}
    (hevent :
      im05_algorithm41SourceStepTargetAccepted val_m val_w g
        (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t) =
          some m) :
    ¬ ∃ r, IsActiveMan val_m
      (im05_algorithm41SourceStep val_m val_w
        (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t)) r := by
  rcases im05_algorithm41SourceStepTargetAccepted_eq_some_imp
      val_m val_w g
      (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t)
      hevent with
    ⟨hactive, hacc, htarget, _hm⟩
  exact
    im05_no_active_sourceStep_of_target_accept_of_atMostOneActive
      val_m val_w g
      (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t)
      hactive hacc htarget
      (im05_algorithm41SourceDivorceTargetStateAfterSteps_w_match_target_none
        val_m val_w g t)
      (im05_algorithm41SourceDivorceTargetStateAfterSteps_atMostOneActiveMan
        val_m val_w g t)

theorem im05_algorithm41SourceStep_target_rejectionInvariant_of_target_accept
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hactive : ∃ a, IsActiveMan val_m s a)
    (hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive)
    (htarget : daStepChosenWoman val_m s hactive = target) :
    ∀ r : M,
      target ∉ (im05_algorithm41SourceStep val_m val_w s).m_proposals r →
        (im05_algorithm41SourceStep val_m val_w s).m_match r ≠ some target →
          ∃ cur : M,
            (im05_algorithm41SourceStep val_m val_w s).w_match target =
                some cur ∧
              val_w target r ≤ val_w target cur := by
  classical
  let chosen := daStepChosenMan val_m s hactive
  have hhistory :
      im05_algorithm41HistoryAccepts val_w s target chosen := by
    simpa [im05_algorithm41SourceStepAccepts, htarget, chosen] using hacc
  intro r hnot hnotMatch
  refine ⟨chosen, ?_, ?_⟩
  · simp [im05_algorithm41SourceStep, hactive, hacc, htarget, chosen]
  · by_cases hrchosen : r = chosen
    · subst r
      exfalso
      exact hnotMatch (by
        simp [im05_algorithm41SourceStep, hactive, hacc, htarget, chosen])
    · have hnot_remove :
          target ∉ removeProposal s chosen target r := by
        simpa [im05_algorithm41SourceStep, hactive, hacc, htarget, chosen]
          using hnot
      have hnot_old : target ∉ s.m_proposals r := by
        rcases not_mem_of_not_mem_removeProposal s hnot_remove with hnotOld | hnew
        · exact hnotOld
        · exact False.elim (hrchosen hnew.1)
      exact le_of_not_gt (hhistory r hnot_old)

/--
A prior proposer whom the target strictly prefers blocks any stable matching
that matches the target to the rejected man, provided that proposer also
strictly prefers the target to his partner in that stable matching.
-/
theorem im05_prior_better_proposer_blocks_stable_target_match
    {M W : Type*}
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) {b r : M} {mu : Assignment M W}
    (hstable : im05_stable_matching val_m val_w mu)
    (hmu_target : mu.w_match target = some b)
    (hr_prefers_target : valM val_m r (mu.m_match r) < val_m r target)
    (htarget_prefers_r : val_w target b < val_w target r) :
    False := by
  have htarget_block :
      valW val_w target (mu.w_match target) < val_w target r := by
    simpa [valW, hmu_target] using htarget_prefers_r
  exact hstable.2.2 r target hr_prefers_target htarget_block

/--
Proposal-order strengthened to include the current match: once a man has
already proposed to `w`, his current match is no better for him than `w`.
-/
def im05_ManCurrentMatchOrderInvariant
    {M W : Type*} (val_m : M → W → ℝ) (s : DAState M W) : Prop :=
  ∀ m w wcur, w ∉ s.m_proposals m → s.m_match m = some wcur →
    val_m m wcur ≤ val_m m w

/-- Rejected-pair impossibility away from one exceptional woman. -/
def im05_DARejectedPairImpossibleExceptWoman
    {M W : Type*} (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W) : Prop :=
  ∀ mu, IsStable val_m val_w mu →
    ∀ m w, w ≠ target → w ∉ s.m_proposals m → s.m_match m ≠ some w →
      mu.m_match m ≠ some w

/--
The two non-target stable-matching exclusions needed to preserve
target-exception rejected-pair impossibility through one corrected Algorithm 4.1
source step.  They isolate the hard case where the allowed target exception can
interact with a rejected or displaced non-target pair.
-/
def im05_SourceStepNonTargetRejectedPairExclusions
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W) : Prop :=
  ∀ hactive : ∃ a, IsActiveMan val_m s a,
    daStepChosenWoman val_m s hactive ≠ target →
      (¬ im05_algorithm41SourceStepAccepts val_m val_w s hactive →
        ∀ mu, IsStable val_m val_w mu →
          mu.m_match (daStepChosenMan val_m s hactive) ≠
            some (daStepChosenWoman val_m s hactive)) ∧
      (im05_algorithm41SourceStepAccepts val_m val_w s hactive →
        ∀ cur,
          s.w_match (daStepChosenWoman val_m s hactive) = some cur →
            ∀ mu, IsStable val_m val_w mu →
              mu.m_match cur ≠ some (daStepChosenWoman val_m s hactive))

/--
Prefix-level side condition that reduces the target-exception rejected-pair
package to two exception-partner exclusions at each non-target source step.
-/
def im05_SourceTraceExceptionPartnerExclusions
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) (steps : ℕ) : Prop :=
  (∀ t : ℕ,
    t < steps →
      ∀ hactive :
        ∃ a, IsActiveMan val_m
          (im05_algorithm41SourceDivorceTargetStateAfterSteps
            val_m val_w g t) a,
        daStepChosenWoman val_m
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) hactive ≠ g →
          ¬ im05_algorithm41SourceStepAccepts val_m val_w
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) hactive →
            ∀ (mu : Assignment M W),
              im05_stable_matching val_m val_w mu →
                mu.w_match
                    (daStepChosenWoman val_m
                      (im05_algorithm41SourceDivorceTargetStateAfterSteps
                        val_m val_w g t) hactive) =
                  some
                    (daStepChosenMan val_m
                      (im05_algorithm41SourceDivorceTargetStateAfterSteps
                        val_m val_w g t) hactive) →
                  ∀ r : M,
                    im05_algorithm41HasProposedTo
                      (im05_algorithm41SourceDivorceTargetStateAfterSteps
                        val_m val_w g t) r
                      (daStepChosenWoman val_m
                        (im05_algorithm41SourceDivorceTargetStateAfterSteps
                          val_m val_w g t) hactive) →
                      val_w
                          (daStepChosenWoman val_m
                            (im05_algorithm41SourceDivorceTargetStateAfterSteps
                              val_m val_w g t) hactive)
                          (daStepChosenMan val_m
                            (im05_algorithm41SourceDivorceTargetStateAfterSteps
                              val_m val_w g t) hactive) <
                        val_w
                          (daStepChosenWoman val_m
                            (im05_algorithm41SourceDivorceTargetStateAfterSteps
                              val_m val_w g t) hactive) r →
                        mu.m_match r ≠ some g) ∧
  (∀ t : ℕ,
    t < steps →
      ∀ hactive :
        ∃ a, IsActiveMan val_m
          (im05_algorithm41SourceDivorceTargetStateAfterSteps
            val_m val_w g t) a,
        daStepChosenWoman val_m
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) hactive ≠ g →
          im05_algorithm41SourceStepAccepts val_m val_w
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) hactive →
            ∀ cur,
              (im05_algorithm41SourceDivorceTargetStateAfterSteps
                val_m val_w g t).w_match
                  (daStepChosenWoman val_m
                    (im05_algorithm41SourceDivorceTargetStateAfterSteps
                      val_m val_w g t) hactive) = some cur →
                ∀ mu, IsStable val_m val_w mu →
                  mu.m_match
                      (daStepChosenMan val_m
                        (im05_algorithm41SourceDivorceTargetStateAfterSteps
                          val_m val_w g t) hactive) ≠ some g)

theorem im05_DARejectedPairImpossibleInvariant.except
    {M W : Type*}
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hrejected : DARejectedPairImpossibleInvariant val_m val_w s) :
    im05_DARejectedPairImpossibleExceptWoman val_m val_w s target := by
  intro mu hstable m w _hne hnot hnotMatch
  exact hrejected mu hstable m w hnot hnotMatch

theorem im05_SourceStepNonTargetRejectedPairExclusions_of_full_rejectedPairImpossible
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinv : DAInvariants val_m val_w s)
    (hrejected : DARejectedPairImpossibleInvariant val_m val_w s) :
    im05_SourceStepNonTargetRejectedPairExclusions val_m val_w s target := by
  classical
  intro hactive _hnonTarget
  let chosen := daStepChosenMan val_m s hactive
  let chosenW := daStepChosenWoman val_m s hactive
  have hact : IsActiveMan val_m s chosen := by
    simpa [chosen, daStepChosenMan] using Classical.choose_spec hactive
  have hstepEq :
      im05_algorithm41SourceStep val_m val_w s = daStep val_m val_w s :=
    im05_algorithm41SourceStep_eq_daStep_of_invariants
      val_m val_w s hstrictW hacceptable hinv
  have hpost :
      DARejectedPairImpossibleInvariant val_m val_w (daStep val_m val_w s) :=
    daStep_preserves_rejected_pair_impossible
      val_m val_w hstrictM hstrictW hacceptable s hinv hrejected
  constructor
  · intro hreject mu hstable
    have hchosenProposal :
        (im05_algorithm41SourceStep val_m val_w s).m_proposals chosen =
          s.m_proposals chosen \ {chosenW} := by
      simpa [chosen, chosenW] using
        im05_algorithm41SourceStep_m_proposals_chosen val_m val_w s hactive
    have hnotSource :
        chosenW ∉ (im05_algorithm41SourceStep val_m val_w s).m_proposals
          chosen := by
      rw [hchosenProposal]
      simp
    have hnotDA :
        chosenW ∉ (daStep val_m val_w s).m_proposals chosen := by
      simpa [hstepEq] using hnotSource
    have hnotMatchSource :
        (im05_algorithm41SourceStep val_m val_w s).m_match chosen ≠
          some chosenW := by
      intro hmatch
      have hold : s.m_match chosen = some chosenW := by
        simpa [im05_algorithm41SourceStep, hactive, hreject, chosen, chosenW]
          using hmatch
      rw [hact.1] at hold
      cases hold
    have hnotMatchDA :
        (daStep val_m val_w s).m_match chosen ≠ some chosenW := by
      simpa [hstepEq] using hnotMatchSource
    exact hpost mu hstable chosen chosenW hnotDA hnotMatchDA
  · intro haccept cur hcur mu hstable
    have hcurMatch : s.m_match cur = some chosenW :=
      (s.consistent cur chosenW).2 hcur
    have hcur_ne_chosen : cur ≠ chosen := by
      intro h
      subst cur
      rw [hact.1] at hcurMatch
      cases hcurMatch
    have hnotOld : chosenW ∉ s.m_proposals cur := hinv.2.2.1 cur chosenW hcurMatch
    have hnotSource :
        chosenW ∉ (im05_algorithm41SourceStep val_m val_w s).m_proposals cur := by
      have hnotRemove : chosenW ∉ removeProposal s chosen chosenW cur := by
        simpa [removeProposal, hcur_ne_chosen] using hnotOld
      simpa [im05_algorithm41SourceStep, hactive, haccept, chosen, chosenW]
        using hnotRemove
    have hnotDA :
        chosenW ∉ (daStep val_m val_w s).m_proposals cur := by
      simpa [hstepEq] using hnotSource
    have hnotMatchSource :
        (im05_algorithm41SourceStep val_m val_w s).m_match cur ≠ some chosenW := by
      intro hmatch
      have hnone : (none : Option W) = some chosenW := by
        simpa [im05_algorithm41SourceStep, hactive, haccept, chosen, chosenW,
          hcur_ne_chosen, hcur] using hmatch
      cases hnone
    have hnotMatchDA :
        (daStep val_m val_w s).m_match cur ≠ some chosenW := by
      simpa [hstepEq] using hnotMatchSource
    exact hpost mu hstable cur chosenW hnotDA hnotMatchDA

theorem im05_algorithm41SourceStep_preserves_currentMatchOrder
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s) :
    im05_ManCurrentMatchOrderInvariant val_m
      (im05_algorithm41SourceStep val_m val_w s) := by
  classical
  intro x w0 wcur hnot hmatch
  by_cases hactive : ∃ a, IsActiveMan val_m s a
  · let chosen := daStepChosenMan val_m s hactive
    let chosenW := daStepChosenWoman val_m s hactive
    have hchosen_active : IsActiveMan val_m s chosen := by
      simpa [chosen, daStepChosenMan] using Classical.choose_spec hactive
    have hwbest : BestRemainingWoman val_m s chosen chosenW := by
      simpa [chosen, chosenW, daStepChosenWoman, daStepChosenMan,
        hchosen_active] using
        Classical.choose_spec (exists_best_woman val_m s chosen hchosen_active)
    by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · by_cases hx : x = chosen
      · subst x
        have hwcur : wcur = chosenW := by
          have hsome : some chosenW = some wcur := by
            simpa [im05_algorithm41SourceStep, hactive, hacc, chosen, chosenW]
              using hmatch
          exact Option.some.inj hsome.symm
        subst wcur
        have hnot_remove :
            w0 ∉ removeProposal s chosen chosenW chosen := by
          simpa [im05_algorithm41SourceStep, hactive, hacc, chosen, chosenW]
            using hnot
        rcases not_mem_of_not_mem_removeProposal s hnot_remove with hnot_old | hnew
        · exact hproposalOrder chosen w0 chosenW hnot_old hwbest.1 hwbest.2.1
        · rcases hnew with ⟨_, hw0⟩
          subst w0
          exact le_rfl
      · by_cases hcur : s.w_match chosenW = some x
        · have hnone : (none : Option W) = some wcur := by
            simpa [im05_algorithm41SourceStep, hactive, hacc, chosen, chosenW,
              hx, hcur] using hmatch
          cases hnone
        · have hmatch_old : s.m_match x = some wcur := by
            simpa [im05_algorithm41SourceStep, hactive, hacc, chosen, chosenW,
              hx, hcur] using hmatch
          have hnot_old : w0 ∉ s.m_proposals x := by
            have hnot_remove : w0 ∉ removeProposal s chosen chosenW x := by
              simpa [im05_algorithm41SourceStep, hactive, hacc, chosen,
                chosenW] using hnot
            exact (not_mem_of_not_mem_removeProposal s hnot_remove).elim
              (fun h => h)
              (fun hnew => False.elim (hx hnew.1))
          exact hmatchOrder x w0 wcur hnot_old hmatch_old
    · by_cases hx : x = chosen
      · subst x
        have hmatch_old : s.m_match chosen = some wcur := by
          simpa [im05_algorithm41SourceStep, hactive, hacc, chosen, chosenW]
            using hmatch
        rw [hchosen_active.1] at hmatch_old
        cases hmatch_old
      · have hmatch_old : s.m_match x = some wcur := by
          simpa [im05_algorithm41SourceStep, hactive, hacc, chosen, chosenW,
            hx] using hmatch
        have hnot_old : w0 ∉ s.m_proposals x := by
          have hnot_remove : w0 ∉ removeProposal s chosen chosenW x := by
            simpa [im05_algorithm41SourceStep, hactive, hacc, chosen,
              chosenW] using hnot
          exact (not_mem_of_not_mem_removeProposal s hnot_remove).elim
            (fun h => h)
            (fun hnew => False.elim (hx hnew.1))
        exact hmatchOrder x w0 wcur hnot_old hmatch_old
  · have hnot_old : w0 ∉ s.m_proposals x := by
      simpa [im05_algorithm41SourceStep, hactive] using hnot
    have hmatch_old : s.m_match x = some wcur := by
      simpa [im05_algorithm41SourceStep, hactive] using hmatch
    exact hmatchOrder x w0 wcur hnot_old hmatch_old

theorem im05_divorceWomanState_preserves_currentMatchOrder
    {M W : Type*} [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (s : DAState M W) (target : W)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s) :
    im05_ManCurrentMatchOrderInvariant val_m
      (divorceWomanState s target) := by
  intro m w wcur hnot hmatch
  by_cases hm : s.w_match target = some m
  · have hnone : (none : Option W) = some wcur := by
      simpa [divorceWomanState, hm] using hmatch
    cases hnone
  · exact hmatchOrder m w wcur (by simpa [divorceWomanState] using hnot)
      (by simpa [divorceWomanState, hm] using hmatch)

theorem im05_initialDAState_currentMatchOrder
