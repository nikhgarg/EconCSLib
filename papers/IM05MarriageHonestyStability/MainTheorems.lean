    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    (hk_le_card : k ≤ Fintype.card W)
    (hmass_tail_le : ∀ idx ∈ tailIdx,
      (∑ u ∈ im05_popularityRankTail all prob hall_card (idx.val + 1) k,
        prob u) ≤ 1 - Q)
    (hprefix_pos : ∀ idx ∈ tailIdx, ∀ r, r < k →
      0 < EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
          k hk_le_card)
        (fun sample =>
          im05_listPrefixOmits
            (EconCSLib.FiniteRanking.rankAgentByValue
              all (fun v => -prob v) hall_card idx)
            r
            (im05_algorithm42FreshListDraw sample)))
    (hk_le_N : k ≤ N)
    (htop_mass_le :
      (∑ u ∈ im05_popularityTopPrefix all prob hall_card k, prob u) ≤ Q) :
    (g : ℝ) / 2 *
        Real.exp (-(8 * (Fintype.card M : ℝ) * (k : ℝ) / (g : ℝ))) ≤
      EconCSLib.pmfExp
        (EconCSLib.pmfProduct M
          (im05_algorithm42FreshListSample W k)
          (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
            k hk_le_card))
        (fun samples : M → im05_algorithm42FreshListSample W k =>
          ((tailIdx.filter fun idx =>
            ∀ m : M,
              im05_listPrefixOmits
                (EconCSLib.FiniteRanking.rankAgentByValue
                  all (fun v => -prob v) hall_card idx)
                k
                (im05_algorithm42FreshListDraw (samples m))).card : ℝ)) := by
  classical
  let ν := im05_algorithm42FreshListPMF prob hprob_nonneg havailable
    k hk_le_card
  let μ := EconCSLib.pmfProduct M (im05_algorithm42FreshListSample W k) ν
  let target : Fin N → W :=
    fun idx =>
      EconCSLib.FiniteRanking.rankAgentByValue
        all (fun v => -prob v) hall_card idx
  let event : Fin N → (M → im05_algorithm42FreshListSample W k) → Prop :=
    fun idx samples =>
      ∀ m : M,
        im05_listPrefixOmits (target idx) k
          (im05_algorithm42FreshListDraw (samples m))
  refine
    paper_im05_lemma4_3_tail_expected_absent_count_lower_bound_from_rank_tail
      μ event tailIdx (fun idx : Fin N => idx.val + 1) g (Fintype.card M) k
      hg hcard ?_ hhalf ?_
  · intro idx _hi
    exact Nat.succ_pos idx.val
  · intro idx hi
    have hrank_pos : 0 < idx.val + 1 := Nat.succ_pos idx.val
    have hrank_le : idx.val + 1 ≤ N := Nat.succ_le_of_lt idx.isLt
    have hk_rank_idx : k < idx.val + 1 := by
      have h := htwo_k idx hi
      omega
    have htail_card :
        (im05_popularityRankTail all prob hall_card (idx.val + 1) k).card =
          idx.val + 1 - k :=
      im05_popularityRankTail_card all prob hall_card hk_rank_idx hrank_le
    have hpopular_idx :
        ∀ u ∈ im05_popularityRankTail all prob hall_card (idx.val + 1) k,
          prob (target idx) ≤ prob u := by
      intro u hu
      have hpop :=
        im05_popularityRankTail_popular all prob hall_card
          hrank_pos hrank_le u hu
      simpa [target] using hpop
    have hrank_power :
        (1 - 1 / ((idx.val + 1 - k : ℕ) : ℝ)) ^ (Fintype.card M * k) ≤
          EconCSLib.pmfProb μ (fun samples => event idx samples) := by
      simpa [μ, ν, event, target] using
        (paper_im05_lemma4_3_absence_probability_ge_rank_power_from_algorithm4_2_prefix_sets_product
          (M := M)
          ν im05_algorithm42FreshListDraw (target idx)
          (im05_popularityRankTail all prob hall_card (idx.val + 1) k)
          prob Q (idx.val + 1) hk_rank_idx
          (hprefix_pos idx hi)
          hprob_nonneg hprob_sum
          (by
            intro r _hr previous hspos
            exact
              paper_im05_lemma4_3_realized_prefixSet_mass_le_Q_of_top_prefix_of_pos_support
                ν im05_algorithm42FreshListDraw (target idx) all hall_card prob Q
                (by
                  intro sample _hmass slot
                  exact hall_mem (im05_algorithm42FreshListDraw sample slot))
                (by
                  intro sample _hmass
                  exact im05_algorithm42FreshListDraw_injective sample)
                hk_le_N
                (by intro u _hu; exact hprob_nonneg u)
                htop_mass_le previous hspos)
          hQ_pos htail_card (hmass_tail_le idx hi) hpopular_idx
          (by
            intro r hr previous hspos havailable_pos
            exact
              paper_im05_algorithm4_2_freshList_prefixSet_omit_conditional_atom_formula
                prob hprob_nonneg havailable hr hk_le_card previous (target idx)
                hspos havailable_pos))
    simpa [event, target] using
      (paper_im05_lemma4_3_absence_probability_ge_exp_rank_from_rank_power
        (idx.val + 1) k (Fintype.card M) hk_pos (htwo_k idx hi) hrank_power)

/--
Lemma 4.3 source-route composition: if each indexed tail woman has the paper's
popularity witness set outside the top block and the concrete random-list model
supplies the product lower bound, then the expected absent-count lower bound
follows.
-/
theorem
    paper_im05_lemma4_3_expected_absent_count_lower_bound_from_popularity_tails
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (absent : I → Ω → Prop)
    [∀ ω, DecidablePred fun i => absent i ω]
    [∀ i, DecidablePred fun ω => absent i ω]
    (prob : I → ℝ) (Q : ℝ)
    (tail : Finset I) (witnessTail : I → Finset I)
    (rank : I → ℕ) (g n k : ℕ)
    (hk_pos : 0 < k)
    (hQ_pos : 0 < 1 - Q)
    (hg : 0 < g)
    (hcard : (g : ℝ) / 2 ≤ (tail.card : ℝ))
    (hhalf : ∀ i ∈ tail, (g : ℝ) / 2 ≤ (rank i : ℝ))
    (htwo_k : ∀ i ∈ tail, 2 * k < rank i)
    (hwitness_card : ∀ i ∈ tail, (witnessTail i).card = rank i - k)
    (hmass_tail_le : ∀ i ∈ tail,
      (∑ u ∈ witnessTail i, prob u) ≤ 1 - Q)
    (hpopular : ∀ i ∈ tail, ∀ u ∈ witnessTail i, prob i ≤ prob u)
    (hproduct : ∀ i ∈ tail,
      (1 - prob i / (1 - Q)) ^ (n * k) ≤
        EconCSLib.pmfProb μ (fun ω => absent i ω)) :
    (g : ℝ) / 2 *
        Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => absent i ω).card : ℝ)) := by
  classical
  refine
    paper_im05_lemma4_3_expected_absent_count_lower_bound_from_rank_tail
      μ absent tail rank g n k hg hcard ?_ hhalf ?_
  · intro i hi
    have h := htwo_k i hi
    omega
  · intro i hi
    exact
      paper_im05_lemma4_3_absence_probability_ge_exp_rank_from_tail
        (witnessTail i) prob i Q (rank i) k n
        hk_pos hQ_pos
        (hwitness_card i hi)
        (htwo_k i hi)
        (hmass_tail_le i hi)
        (hpopular i hi)
      (hproduct i hi)

/--
For the finite multiset proof in Lemma 4.4, this is the set of distinct names
seen before the first occurrence of a target name in a permutation/list.
-/
noncomputable def im05_namesBeforeFirst
    {Token Name : Type*} [DecidableEq Name]
    (name : Token → Name) (target : Name) (π : List Token) : Finset Name :=
  ((π.takeWhile fun token => name token ≠ target).map name).toFinset

/-- For name-valued lists, membership in `namesBeforeFirst` is prefix membership. -/
theorem im05_mem_namesBeforeFirst_id_iff
    {Name : Type*} [DecidableEq Name]
    (target : Name) (π : List Name) (x : Name) :
    x ∈ im05_namesBeforeFirst id target π ↔
      x ∈ π.takeWhile (fun name => name != target) := by
  classical
  rw [im05_namesBeforeFirst]
  simp only [List.mem_toFinset, List.mem_map, id_eq, exists_eq_right]
  change x ∈ π.takeWhile (fun name : Name => name ≠ target) ↔
    x ∈ π.takeWhile (fun name => name != target)
  have htake :
      π.takeWhile (fun name : Name => name ≠ target) =
        π.takeWhile (fun name => name != target) := by
    congr 1
    funext name
    by_cases h : name = target <;> simp [h]
  exact by rw [htake]

/-- Names in first-appearance order in a list. -/
def im05_firstAppearanceList
    {Name : Type*} [DecidableEq Name] (π : List Name) : List Name :=
  π.eraseDups

/-- Lean's first-occurrence duplicate erasure produces a duplicate-free list. -/
theorem im05_eraseDups_nodup
    {Name : Type*} [DecidableEq Name] (π : List Name) :
    π.eraseDups.Nodup := by
  classical
  suffices h : ∀ n : ℕ, ∀ π : List Name, π.length = n → π.eraseDups.Nodup by
    exact h π.length π rfl
  intro n
  induction n using Nat.strong_induction_on with
  | h n ih =>
      intro π hlen
      cases π with
      | nil => simp [List.eraseDups]
      | cons head tail =>
          rw [List.eraseDups_cons]
          constructor
          · intro x hx
            rw [List.mem_eraseDups, List.mem_filter] at hx
            intro hheadx
            subst x
            simp at hx
          · exact
              ih (tail.filter fun b => !b == head).length
                (by
                  rw [← hlen]
                  exact lt_of_le_of_lt (List.length_filter_le _ tail)
                    (Nat.lt_succ_self tail.length))
                (tail.filter fun b => !b == head) rfl

/-- The first-appearance list has no duplicates. -/
theorem im05_firstAppearanceList_nodup
    {Name : Type*} [DecidableEq Name] (π : List Name) :
    (im05_firstAppearanceList π).Nodup := by
  exact im05_eraseDups_nodup π

/-- The first element of a nonempty first-appearance list is the original head. -/
theorem im05_firstAppearanceList_get_zero_eq
    {Name : Type*} [DecidableEq Name] (π : List Name)
    (hπ : 0 < π.length) :
    (im05_firstAppearanceList π).get
        ⟨0, by
          cases π with
          | nil => cases hπ
          | cons head tail =>
              simp [im05_firstAppearanceList, List.eraseDups_cons]⟩ =
      π.get ⟨0, hπ⟩ := by
  cases π with
  | nil => cases hπ
  | cons head tail =>
      simp [im05_firstAppearanceList, List.eraseDups_cons]

/--
If a list starts with `head`, then its second first-appearance is the first
first-appearance after filtering out all copies of `head`.
-/
theorem im05_firstAppearanceList_get_one_eq_filter_ne_head_get_zero
    {Name : Type*} [DecidableEq Name] (π : List Name) (head : Name)
    (hπ_pos : 0 < π.length)
    (hhead : π.get ⟨0, hπ_pos⟩ = head)
    (hfilter_pos : 0 < (π.filter fun name => name != head).length)
    (happearance_two : 1 < (im05_firstAppearanceList π).length) :
    (im05_firstAppearanceList π).get ⟨1, happearance_two⟩ =
      (π.filter fun name => name != head).get ⟨0, hfilter_pos⟩ := by
  classical
  cases π with
  | nil => cases hπ_pos
  | cons first tail =>
      change first = head at hhead
      subst first
      have hfilter_eq :
          ((head :: tail).filter fun name => name != head) =
            tail.filter fun name => name != head := by
        simp
      have htail_filter_pos :
          0 < (tail.filter fun name => name != head).length := by
        simpa [hfilter_eq] using hfilter_pos
      simpa [im05_firstAppearanceList, List.eraseDups_cons, hfilter_eq] using
        im05_firstAppearanceList_get_zero_eq
          (tail.filter fun name => name != head) htail_filter_pos

/-- The first-appearance list contains exactly the names appearing in the list. -/
theorem im05_mem_firstAppearanceList_iff
    {Name : Type*} [DecidableEq Name] (π : List Name) (target : Name) :
    target ∈ im05_firstAppearanceList π ↔ target ∈ π := by
  simp [im05_firstAppearanceList, List.mem_eraseDups]

/-- Passing from a list to first-appearance order preserves its underlying finset. -/
theorem im05_firstAppearanceList_toFinset
    {Name : Type*} [DecidableEq Name] (π : List Name) :
    (im05_firstAppearanceList π).toFinset = π.toFinset := by
  ext target
  simp [im05_mem_firstAppearanceList_iff]

/--
`namesBeforeFirst` is the finset underlying the first-appearance order in the
pre-target prefix.
-/
theorem im05_namesBeforeFirst_eq_firstAppearanceList_toFinset
    {Token Name : Type*} [DecidableEq Name]
    (name : Token → Name) (target : Name) (π : List Token) :
    im05_namesBeforeFirst name target π =
      (im05_firstAppearanceList
        ((π.takeWhile fun token => name token ≠ target).map name)).toFinset := by
  rw [im05_namesBeforeFirst, im05_firstAppearanceList_toFinset]

/-- The pre-target prefix length is the index of the first target occurrence. -/
theorem im05_length_takeWhile_ne_eq_idxOf
    {Name : Type*} [DecidableEq Name] (target : Name) :
    ∀ π : List Name,
      (π.takeWhile fun name => name != target).length = π.idxOf target
  | [] => by simp [List.takeWhile]
  | name :: tail => by
      by_cases hname : name = target
      · subst name
        simp [List.takeWhile]
      · have hneq_bool : (name != target) = true := bne_iff_ne.mpr hname
        rw [List.takeWhile, hneq_bool, List.idxOf_cons_ne _ hname]
        simp [im05_length_takeWhile_ne_eq_idxOf target tail]

/--
For a list containing `target`, omitting `target` from the first `k` entries is
equivalent to `k` being at most the pre-target prefix length.
-/
theorem im05_not_mem_take_iff_le_takeWhile_ne_length
    {Name : Type*} [DecidableEq Name] (target : Name)
    (π : List Name) (htarget : target ∈ π) (k : ℕ) :
    target ∉ π.take k ↔
      k ≤ (π.takeWhile fun name => name != target).length := by
  rw [im05_length_takeWhile_ne_eq_idxOf target π]
  constructor
  · intro hnot
    by_contra hlt
    rw [not_le] at hlt
    exact hnot ((List.mem_take_iff_idxOf_lt htarget).2 hlt)
  · intro hle hmem
    have hlt := (List.mem_take_iff_idxOf_lt htarget).1 hmem
    omega

/--
If `head` is not the stopping name, filtering out copies of `head` preserves
membership in the pre-`target` prefix for every other name.
-/
theorem im05_mem_takeWhile_filter_ne_head_iff
    {Name : Type*} [DecidableEq Name]
    {head target x : Name} (hhead : head ≠ target) (hx : x ≠ head) :
    ∀ tail : List Name,
      x ∈ (tail.filter fun b => !b == head).takeWhile
          (fun name => name != target) ↔
        x ∈ tail.takeWhile (fun name => name != target)
  | [] => by simp
  | y :: ys => by
      by_cases hytarget : y = target
      · subst y
        have hkeep : (!target == head) = true := by
          simp [Ne.symm hhead]
        simp [List.takeWhile, hkeep]
      · have hyneq : (y != target) = true := bne_iff_ne.mpr hytarget
        by_cases hyhead : y = head
        · subst y
          have hhead_neq_bool : (head != target) = true :=
            bne_iff_ne.mpr hhead
          simp [List.takeWhile, hhead_neq_bool,
            im05_mem_takeWhile_filter_ne_head_iff hhead hx ys, hx]
        · have hkeep : (!y == head) = true := by
            simp [hyhead]
          simp [List.takeWhile, hkeep, hyneq,
            im05_mem_takeWhile_filter_ne_head_iff hhead hx ys]

/--
Erasing an excluded name from the set of names before first `target` is the same
as first filtering that excluded name out of the word, provided it is not the
target.
-/
theorem im05_namesBeforeFirst_erase_eq_namesBeforeFirst_filter_ne
    {Name : Type*} [DecidableEq Name]
    (target excluded : Name) (hneq : target ≠ excluded) (π : List Name) :
    (im05_namesBeforeFirst id target π).erase excluded =
      im05_namesBeforeFirst id target
        (π.filter fun name => name != excluded) := by
  classical
  ext x
  by_cases hx : x = excluded
  · subst x
    simp only [Finset.mem_erase, ne_eq, not_true_eq_false, false_and]
    rw [im05_mem_namesBeforeFirst_id_iff]
    constructor
    · intro h
      exact False.elim h
    · intro hmem
      have hmem_filter :
          excluded ∈ π.filter (fun name => name != excluded) :=
        (List.takeWhile_sublist _).subset hmem
      simpa using hmem_filter
  · have hfilter :=
      im05_mem_takeWhile_filter_ne_head_iff
        (head := excluded) (target := target) (x := x)
        (Ne.symm hneq) hx π
    rw [Finset.mem_erase]
    rw [im05_mem_namesBeforeFirst_id_iff]
    rw [im05_mem_namesBeforeFirst_id_iff]
    have hfilter' :
        x ∈ (π.filter fun b => !b == excluded).takeWhile
            (fun name => name != target) ↔
          x ∈ (π.filter fun name => name != excluded).takeWhile
            (fun name => name != target) := by
      have hfilter_list :
          (π.filter fun b => !b == excluded) =
            (π.filter fun name => name != excluded) := by
        rfl
      rw [hfilter_list]
    constructor
    · intro hmem
      exact hfilter'.1 (hfilter.2 hmem.2)
    · intro hmem
      exact ⟨hx, hfilter.1 (hfilter'.2 hmem)⟩

/--
If the current head is not the target, the two-distinct-names-before-target
event recurses to a one-distinct-name event after filtering out that head.
-/
theorem im05_two_le_namesBeforeFirst_card_iff_filter_ne_head_one_le
    {Name : Type*} [DecidableEq Name]
    (target head : Name) (π : List Name)
    (hπ_pos : 0 < π.length)
    (hhead : π.get ⟨0, hπ_pos⟩ = head)
    (hhead_ne : target ≠ head) :
    2 ≤ (im05_namesBeforeFirst id target π).card ↔
      1 ≤
        (im05_namesBeforeFirst id target
          (π.filter fun name => name != head)).card := by
  classical
  have hhead_mem :
      head ∈ im05_namesBeforeFirst id target π := by
    rw [im05_mem_namesBeforeFirst_id_iff]
    cases π with
    | nil => cases hπ_pos
    | cons first tail =>
        change first = head at hhead
        subst first
        have hneq_bool : (head != target) = true := by
          exact bne_iff_ne.mpr (Ne.symm hhead_ne)
        simp [List.takeWhile, hneq_bool]
  have herase :
      (im05_namesBeforeFirst id target π).erase head =
        im05_namesBeforeFirst id target
          (π.filter fun name => name != head) :=
    im05_namesBeforeFirst_erase_eq_namesBeforeFirst_filter_ne
      target head hhead_ne π
  rw [← herase]
  rw [Finset.card_erase_of_mem hhead_mem]
  omega

/--
For a nonempty list containing `target`, having at least one distinct name before
the first `target` is equivalent to the head not being `target`.
-/
theorem im05_one_le_namesBeforeFirst_card_iff_head_ne
    {Name : Type*} [DecidableEq Name]
    (target : Name) (π : List Name)
    (hπ_pos : 0 < π.length) (htarget : target ∈ π) :
    1 ≤ (im05_namesBeforeFirst id target π).card ↔
      π.get ⟨0, hπ_pos⟩ ≠ target := by
  classical
  cases π with
  | nil => cases hπ_pos
  | cons head tail =>
      by_cases hhead : head = target
      · subst head
        simp [im05_namesBeforeFirst, List.takeWhile]
      · simp [im05_namesBeforeFirst, List.takeWhile, hhead]

/--
The first-appearance list restricted before `target` has the same underlying
set as the original list prefix before `target`.
-/
theorem im05_firstAppearanceList_takeWhile_ne_toFinset
    {Name : Type*} [DecidableEq Name] (target : Name) (π : List Name) :
    ((im05_firstAppearanceList π).takeWhile fun name => name != target).toFinset =
      (π.takeWhile fun name => name != target).toFinset := by
  classical
  suffices h : ∀ n : ℕ, ∀ π : List Name, π.length = n →
      ((im05_firstAppearanceList π).takeWhile fun name => name != target).toFinset =
        (π.takeWhile fun name => name != target).toFinset by
    exact h π.length π rfl
  intro n
  induction n using Nat.strong_induction_on with
  | h n ih =>
      intro π hlen
      cases π with
      | nil => simp [im05_firstAppearanceList, List.eraseDups]
      | cons head tail =>
          by_cases hhead : head = target
          · subst head
            simp [im05_firstAppearanceList, List.eraseDups_cons, List.takeWhile]
          · have hneq : (head != target) = true := bne_iff_ne.mpr hhead
            rw [List.takeWhile, hneq]
            rw [im05_firstAppearanceList, List.eraseDups_cons]
            ext x
            by_cases hx : x = head
            · subst x
              rw [List.takeWhile, hneq]
              simp
            · have hfiltered :
                ((im05_firstAppearanceList
                    (tail.filter fun b => !b == head)).takeWhile
                    fun name => name != target).toFinset =
                  ((tail.filter fun b => !b == head).takeWhile
                    fun name => name != target).toFinset :=
                ih (tail.filter fun b => !b == head).length
                  (by
                    rw [← hlen]
                    exact lt_of_le_of_lt (List.length_filter_le _ tail)
                      (Nat.lt_succ_self tail.length))
                  (tail.filter fun b => !b == head) rfl
              have hmem_filtered :
                  x ∈ (im05_firstAppearanceList
                        (tail.filter fun b => !b == head)).takeWhile
                      (fun name => name != target) ↔
                    x ∈ (tail.filter fun b => !b == head).takeWhile
                      (fun name => name != target) := by
                have := congrArg (fun s : Finset Name => x ∈ s) hfiltered
                simpa using this
              have hmem_tail :=
                im05_mem_takeWhile_filter_ne_head_iff
                  (head := head) (target := target) (x := x) hhead hx tail
              rw [List.takeWhile, hneq]
              simpa [im05_firstAppearanceList, hx] using
                hmem_filtered.trans hmem_tail

/--
The length of the first-appearance prefix before `target` is exactly the number
of distinct names before the first `target` in the original list.
-/
theorem im05_firstAppearanceList_takeWhile_ne_length_eq_namesBeforeFirst_card
    {Name : Type*} [DecidableEq Name] (target : Name) (π : List Name) :
    ((im05_firstAppearanceList π).takeWhile
      (fun name => name != target)).length =
      (im05_namesBeforeFirst id target π).card := by
  classical
  let prefixList :=
    (im05_firstAppearanceList π).takeWhile (fun name => name != target)
  have hnodup_prefix : prefixList.Nodup := by
    dsimp [prefixList]
    exact
      (im05_firstAppearanceList_nodup π).sublist
        (List.takeWhile_sublist _)
  have hlen_card : prefixList.length = prefixList.toFinset.card := by
    rw [List.card_toFinset, List.dedup_eq_self.2 hnodup_prefix]
  have hset :
      prefixList.toFinset =
        (π.takeWhile fun name => name != target).toFinset := by
    dsimp [prefixList]
    exact im05_firstAppearanceList_takeWhile_ne_toFinset target π
  calc
    ((im05_firstAppearanceList π).takeWhile
        (fun name => name != target)).length =
        prefixList.length := rfl
    _ = prefixList.toFinset.card := hlen_card
    _ = (π.takeWhile fun name => name != target).toFinset.card := by
        rw [hset]
    _ = (im05_namesBeforeFirst id target π).card := by
        congr 1
        have hpred :
            (fun name : Name => name != target) =
              (fun name : Name => !decide (name = target)) := by
          funext name
          by_cases h : name = target <;> simp [h]
        rw [hpred]
        simp [im05_namesBeforeFirst]

/--
Omitting `target` from a prefix of the first-appearance list is exactly the
paper event that at least that many distinct names appear before `target`.
-/
theorem im05_firstAppearanceList_not_mem_take_iff_le_namesBeforeFirst_card
    {Name : Type*} [DecidableEq Name] (target : Name) (π : List Name)
    (htarget : target ∈ π) (k : ℕ) :
    target ∉ (im05_firstAppearanceList π).take k ↔
      k ≤ (im05_namesBeforeFirst id target π).card := by
  rw [im05_not_mem_take_iff_le_takeWhile_ne_length]
  · rw [im05_firstAppearanceList_takeWhile_ne_length_eq_namesBeforeFirst_card]
  · exact (im05_mem_firstAppearanceList_iff π target).2 htarget

/--
The deterministic inclusion in the finite multiset argument for Lemma 4.4:
if `k` distinct names other than `excluded` occur before the first `target`,
then at least `k` distinct names occur before the first `target`.
-/
theorem im05_kDistinctNamesBefore_excluding_imp
    {Token Name : Type*} [DecidableEq Name]
    (name : Token → Name) (target excluded : Name) (π : List Token) (k : ℕ)
    (h :
      k ≤ ((im05_namesBeforeFirst name target π).erase excluded).card) :
    k ≤ (im05_namesBeforeFirst name target π).card :=
  le_trans h Finset.card_erase_le

/-- Number of occurrences of a name in a finite word. -/
def im05_nameCountInWord
    {Name : Type*} [DecidableEq Name] {total : ℕ}
    (word : Fin total → Name) (target : Name) : ℕ :=
  ((Finset.univ : Finset (Fin total)).filter fun slot =>
    word slot = target).card

/-- Counting slots in a finite word agrees with `List.count` on `List.ofFn`. -/
theorem im05_nameCountInWord_eq_count_ofFn
    {Name : Type*} [DecidableEq Name] {total : ℕ}
    (word : Fin total → Name) (target : Name) :
    im05_nameCountInWord word target = (List.ofFn word).count target := by
  classical
  rw [im05_nameCountInWord, Finset.card_def, Finset.filter_val,
    ← Multiset.countP_eq_card_filter]
  rw [Finset.val_univ_fin]
  have hfun :
      (fun slot : Fin total => decide (word slot = target)) =
        ((fun name => name == target) ∘ word) := by
    funext slot
    rw [Bool.eq_iff_iff]
    change decide (word slot = target) = true ↔ (word slot == target) = true
    rw [beq_iff_eq, decide_eq_true_iff]
  simp [List.ofFn_eq_map, List.count, hfun]

/-- Decrement the copy count of one name by one, leaving all other names fixed. -/
def im05_decrementCount
    {Name : Type*} [DecidableEq Name]
    (count : Name → ℕ) (target : Name) : Name → ℕ :=
  fun name => if name = target then count name - 1 else count name

@[simp]
theorem im05_decrementCount_self
    {Name : Type*} [DecidableEq Name]
    (count : Name → ℕ) (target : Name) :
    im05_decrementCount count target target = count target - 1 := by
  simp [im05_decrementCount]

@[simp]
theorem im05_decrementCount_of_ne
    {Name : Type*} [DecidableEq Name]
    (count : Name → ℕ) {target name : Name} (hne : name ≠ target) :
    im05_decrementCount count target name = count name := by
  simp [im05_decrementCount, hne]

/-- Drop the first slot of a nonempty finite word. -/
def im05_wordTail {Name : Type*} {total : ℕ}
    (word : Fin (total + 1) → Name) : Fin total → Name :=
  fun slot => word slot.succ

@[simp]
theorem im05_wordTail_apply {Name : Type*} {total : ℕ}
    (word : Fin (total + 1) → Name) (slot : Fin total) :
    im05_wordTail word slot = word slot.succ := rfl

/-- `List.ofFn` of a nonempty finite word splits into its head and tail. -/
theorem im05_list_ofFn_eq_cons_wordTail
    {Name : Type*} {total : ℕ}
    (word : Fin (total + 1) → Name) :
    List.ofFn word =
      word ⟨0, Nat.succ_pos total⟩ :: List.ofFn (im05_wordTail word) := by
  rw [List.ofFn_succ]
  rfl

/-- Occurrence counts in a nonempty finite word split into head plus tail. -/
theorem im05_nameCountInWord_succ
    {Name : Type*} [DecidableEq Name] {total : ℕ}
    (word : Fin (total + 1) → Name) (target : Name) :
    im05_nameCountInWord word target =
      (if word ⟨0, Nat.succ_pos total⟩ = target then 1 else 0) +
        im05_nameCountInWord (im05_wordTail word) target := by
  classical
  rw [im05_nameCountInWord_eq_count_ofFn]
  rw [im05_nameCountInWord_eq_count_ofFn]
  rw [im05_list_ofFn_eq_cons_wordTail]
  simp [List.count_cons, Nat.add_comm]

/--
If a nonempty finite word has count vector `count` and its head is `target`,
then its tail has the count vector with one `target` copy removed.
-/
theorem im05_nameCountInWord_wordTail_eq_decrement
    {Name : Type*} [DecidableEq Name] {total : ℕ}
    (word : Fin (total + 1) → Name) (count : Name → ℕ)
    (target : Name)
    (hcount : ∀ name : Name, im05_nameCountInWord word name = count name)
    (hhead : word ⟨0, Nat.succ_pos total⟩ = target) :
    ∀ name : Name,
      im05_nameCountInWord (im05_wordTail word) name =
        im05_decrementCount count target name := by
  classical
  intro name
  by_cases hname : name = target
  · subst name
    have hsplit := im05_nameCountInWord_succ word target
    rw [hcount target] at hsplit
    rw [if_pos hhead] at hsplit
    rw [im05_decrementCount_self]
    omega
  · have hsplit := im05_nameCountInWord_succ word name
    rw [hcount name] at hsplit
    have hhead_ne : word ⟨0, Nat.succ_pos total⟩ ≠ name := by
      intro h
      exact hname (h.symm.trans hhead)
    rw [if_neg hhead_ne] at hsplit
    rw [im05_decrementCount_of_ne count hname]
    omega

/-- Reindexing a finite word along an equality of lengths preserves counts. -/
theorem im05_nameCountInWord_cast
    {Name : Type*} [DecidableEq Name] {m n : ℕ}
    (h : m = n) (word : Fin n → Name) (target : Name) :
    im05_nameCountInWord
        (fun slot : Fin m => word (Fin.cast h slot)) target =
      im05_nameCountInWord word target := by
  classical
  rw [im05_nameCountInWord_eq_count_ofFn]
  rw [im05_nameCountInWord_eq_count_ofFn]
  exact congrArg (fun list : List Name => list.count target)
    ((List.ofFn_congr h.symm word).symm)

/-- Reindexing a finite word along a permutation of slots preserves counts. -/
theorem im05_nameCountInWord_comp_equiv
    {Name : Type*} [DecidableEq Name] {total : ℕ}
    (word : Fin total → Name) (e : Fin total ≃ Fin total)
    (target : Name) :
    im05_nameCountInWord (fun slot => word (e slot)) target =
      im05_nameCountInWord word target := by
  classical
  unfold im05_nameCountInWord
  refine Finset.card_bij (fun slot _hslot => e slot) ?_ ?_ ?_
  · intro slot hslot
    rw [Finset.mem_filter] at hslot
    rw [Finset.mem_filter]
    exact ⟨Finset.mem_univ _, hslot.2⟩
  · intro slot₁ _hslot₁ slot₂ _hslot₂ hmap
    exact e.injective hmap
  · intro slot hslot
    refine ⟨e.symm slot, ?_, ?_⟩
    · rw [Finset.mem_filter] at hslot
      rw [Finset.mem_filter]
      exact ⟨Finset.mem_univ _, by simpa using hslot.2⟩
    · simp

@[simp]
theorem im05_wordTail_finCons
    {Name : Type*} {total : ℕ} (head : Name) (tail : Fin total → Name) :
    im05_wordTail (EconCSLib.finCons head tail) = tail := by
  funext slot
  simp [im05_wordTail]

/-- The finite multiset with `count name` copies of each name. -/
noncomputable def im05_countVectorMultiset
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) : Multiset Name :=
  (Finset.univ : Finset Name).val.bind fun name =>
    Multiset.replicate (count name) name

/-- The canonical count-vector multiset has the prescribed multiplicities. -/
theorem im05_countVectorMultiset_count
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (target : Name) :
    (im05_countVectorMultiset count).count target = count target := by
  classical
  simp [im05_countVectorMultiset, Multiset.count_bind,
    Multiset.count_replicate]

/-- The canonical count-vector multiset has total size `sum count`. -/
theorem im05_countVectorMultiset_card
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) :
    (im05_countVectorMultiset count).card = ∑ name : Name, count name := by
  classical
  simp [im05_countVectorMultiset]

/-- A canonical list representative of the count-vector multiset. -/
noncomputable def im05_countVectorList
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) : List Name :=
  (im05_countVectorMultiset count).toList

/-- The real-valued weight vector associated with an integer count vector. -/
def im05_countWeight {Name : Type*} (count : Name → ℕ) : Name → ℝ :=
  fun name => (count name : ℝ)

/-- Zero the counts of names that have already been forbidden/seen. -/
def im05_countOutside
    {Name : Type*} [DecidableEq Name]
    (count : Name → ℕ) (forbidden : Finset Name) : Name → ℕ :=
  fun name => if name ∈ forbidden then 0 else count name

@[simp]
theorem im05_countOutside_of_mem
    {Name : Type*} [DecidableEq Name]
    (count : Name → ℕ) {forbidden : Finset Name} {name : Name}
    (hmem : name ∈ forbidden) :
    im05_countOutside count forbidden name = 0 := by
  simp [im05_countOutside, hmem]

@[simp]
theorem im05_countOutside_of_not_mem
    {Name : Type*} [DecidableEq Name]
    (count : Name → ℕ) {forbidden : Finset Name} {name : Name}
    (hmem : name ∉ forbidden) :
    im05_countOutside count forbidden name = count name := by
  simp [im05_countOutside, hmem]

@[simp]
theorem im05_countOutside_empty
    {Name : Type*} [DecidableEq Name]
    (count : Name → ℕ) :
    im05_countOutside count (∅ : Finset Name) = count := by
  funext name
  simp [im05_countOutside]

/--
Deleting names outside `forbidden₁` and then outside `forbidden₂` is the same
count vector as deleting outside the union.
-/
theorem im05_countOutside_countOutside_union
    {Name : Type*} [DecidableEq Name]
    (count : Name → ℕ) (forbidden₁ forbidden₂ : Finset Name) :
    im05_countOutside (im05_countOutside count forbidden₁) forbidden₂ =
      im05_countOutside count (forbidden₁ ∪ forbidden₂) := by
  funext name
  by_cases h₁ : name ∈ forbidden₁
  · simp [im05_countOutside, h₁]
  · by_cases h₂ : name ∈ forbidden₂
    · simp [im05_countOutside, h₁, h₂]
    · simp [im05_countOutside, h₁, h₂]

/--
Singleton step of the union deletion identity, stated in the orientation used
when iterating prefix deletions.
-/
theorem im05_countOutside_countOutside_singleton
    {Name : Type*} [DecidableEq Name]
    (count : Name → ℕ) (forbidden : Finset Name) (excluded : Name) :
    im05_countOutside (im05_countOutside count forbidden)
        ({excluded} : Finset Name) =
      im05_countOutside count (insert excluded forbidden) := by
  rw [im05_countOutside_countOutside_union]
  ext name
  by_cases hname : name = excluded
  · simp [im05_countOutside, hname]
  · by_cases hmem : name ∈ forbidden
    · simp [im05_countOutside, hname, hmem]
    · simp [im05_countOutside, hname, hmem]

/-- Integer count weights are nonnegative as real weights. -/
theorem im05_countWeight_nonneg {Name : Type*} (count : Name → ℕ) :
    ∀ name : Name, 0 ≤ im05_countWeight count name := by
  intro name
  dsimp [im05_countWeight]
  exact_mod_cast Nat.zero_le (count name)

/-- Available raw count mass equals the total outside the forbidden set. -/
theorem im05_countWeight_available_eq_sum_countOutside
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (forbidden : Finset Name) :
    EconCSLib.finiteAvailableWeight
        (im05_countWeight count) forbidden =
      (∑ name : Name, im05_countOutside count forbidden name : ℝ) := by
  classical
  simp [EconCSLib.finiteAvailableWeight, im05_countWeight,
    im05_countOutside]

/-- A positive non-forbidden coordinate makes the outside total positive. -/
theorem im05_sum_countOutside_pos_of_not_mem_pos
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (forbidden : Finset Name)
    {target : Name} (hnot : target ∉ forbidden)
    (hpos : 0 < count target) :
    0 < ∑ name : Name, im05_countOutside count forbidden name := by
  classical
  have htarget :
      im05_countOutside count forbidden target = count target := by
    simp [im05_countOutside, hnot]
  have hle :
      im05_countOutside count forbidden target ≤
        ∑ name : Name, im05_countOutside count forbidden name :=
    Finset.single_le_sum
      (fun name _hname => Nat.zero_le (im05_countOutside count forbidden name))
      (Finset.mem_univ target)
  rw [htarget] at hle
  exact lt_of_lt_of_le hpos hle

/--
For a singleton forbidden set, the outside total plus the deleted coordinate is
the original total count.
-/
theorem im05_sum_countOutside_singleton_add_count
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name) :
    (∑ name : Name,
        im05_countOutside count ({excluded} : Finset Name) name) +
      count excluded =
        ∑ name : Name, count name := by
  classical
  have houtside_erase :
      (∑ name : Name,
          im05_countOutside count ({excluded} : Finset Name) name) =
        ∑ name ∈ (Finset.univ : Finset Name).erase excluded,
          count name := by
    calc
      (∑ name : Name,
          im05_countOutside count ({excluded} : Finset Name) name) =
          ∑ name ∈ (Finset.univ : Finset Name).erase excluded,
            im05_countOutside count ({excluded} : Finset Name) name := by
            symm
            exact Finset.sum_erase
              (s := (Finset.univ : Finset Name))
              (a := excluded)
              (f := fun name =>
                im05_countOutside count ({excluded} : Finset Name) name)
              (by simp [im05_countOutside])
      _ = ∑ name ∈ (Finset.univ : Finset Name).erase excluded,
            count name := by
            refine Finset.sum_congr rfl ?_
            intro name hname
            have hne : name ≠ excluded := by
              exact (Finset.mem_erase.mp hname).1
            simp [im05_countOutside, hne]
  rw [houtside_erase]
  exact
    Finset.sum_erase_add
      (s := (Finset.univ : Finset Name))
      (f := count)
      (a := excluded)
      (by simp)

/-- Positive integer counts give full support for the real count weights. -/
theorem im05_countWeight_available_pos_of_count_pos
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (forbidden : Finset Name)
    (hcard_lt : forbidden.card < Fintype.card Name) :
    0 < EconCSLib.finiteAvailableWeight
      (im05_countWeight count) forbidden := by
  classical
  exact
    EconCSLib.finiteAvailableWeight_pos_of_full_support_of_card_lt
      (im05_countWeight count) forbidden
      (im05_countWeight_nonneg count)
      (fun name => by
        dsimp [im05_countWeight]
        exact_mod_cast hcount_pos name)
      hcard_lt

/--
If every proper forbidden set leaves positive raw count mass, then every name
has positive count.  This is the support direction used when finite
without-replacement availability is the only paper-facing support assumption.
-/
theorem im05_count_pos_of_countWeight_available
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (target : Name) :
    0 < count target := by
  classical
  let forbidden := (Finset.univ : Finset Name).erase target
  have hcard :
      forbidden.card < Fintype.card Name := by
    have hlt :=
      Finset.card_erase_lt_of_mem
        (s := (Finset.univ : Finset Name)) (a := target)
        (by simp)
    simpa [forbidden] using hlt
  have havail := hcount_available forbidden hcard
  have havail_eq :
      EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden =
        (count target : ℝ) := by
    dsimp [forbidden]
    simp [EconCSLib.finiteAvailableWeight, im05_countWeight]
  rw [havail_eq] at havail
  exact_mod_cast havail

/--
Scalar algebra behind the two-draw weighted-without-replacement
negative-correlation proof.  Here `S` is the total weight outside `{i,j}` and
`C` is any upper-refined sum satisfying `S / (wi + wj + S) <= C`.
-/
theorem im05_two_draw_hit_negative_correlation_core
    {wi wj S C : ℝ}
    (hwi : 0 < wi) (hwj : 0 < wj) (hS : 0 ≤ S)
    (hC : S / (wi + wj + S) ≤ C) :
    2 + wi / (wj + S) + wj / (wi + S) ≤
      (1 + C + wi / (wj + S)) *
        (1 + C + wj / (wi + S)) := by
  have hden_i : 0 < wj + S := by linarith
  have hden_j : 0 < wi + S := by linarith
  have hT : 0 < wi + wj + S := by linarith
  let c := S / (wi + wj + S)
  have hc_nonneg : 0 ≤ c := by
    dsimp [c]
    exact div_nonneg hS (le_of_lt hT)
  have hx_nonneg : 0 ≤ wi / (wj + S) :=
    div_nonneg (le_of_lt hwi) (le_of_lt hden_i)
  have hy_nonneg : 0 ≤ wj / (wi + S) :=
    div_nonneg (le_of_lt hwj) (le_of_lt hden_j)
  have hbase :
      2 + wi / (wj + S) + wj / (wi + S) ≤
        (1 + c + wi / (wj + S)) *
          (1 + c + wj / (wi + S)) := by
    dsimp [c]
    rw [← sub_nonneg]
    field_simp [hden_i.ne', hden_j.ne', hT.ne']
    ring_nf
    positivity
  have hC_nonneg : 0 ≤ C := le_trans hc_nonneg hC
  have hmono :
      (1 + c + wi / (wj + S)) *
          (1 + c + wj / (wi + S)) ≤
        (1 + C + wi / (wj + S)) *
          (1 + C + wj / (wi + S)) := by
    nlinarith [hC, hc_nonneg, hC_nonneg, hx_nonneg, hy_nonneg]
  exact le_trans hbase hmono

/--
Probability-shaped form of `im05_two_draw_hit_negative_correlation_core`.
-/
theorem im05_two_draw_hit_negative_correlation_core_prob_shape
    {wi wj S C T : ℝ}
    (hT_eq : T = wi + wj + S)
    (hwi : 0 < wi) (hwj : 0 < wj) (hS : 0 ≤ S)
    (hC : S / T ≤ C) :
    wi / T * (wj / (T - wi)) +
        wj / T * (wi / (T - wj)) ≤
      (wi / T * (1 + C + wj / (T - wj))) *
        (wj / T * (1 + C + wi / (T - wi))) := by
  subst T
  have hcore :=
    im05_two_draw_hit_negative_correlation_core
      hwi hwj hS hC
  have hden_i : 0 < wj + S := by linarith
  have hden_j : 0 < wi + S := by linarith
  have hT : 0 < wi + wj + S := by linarith
  have hscale_nonneg :
      0 ≤ (wi * wj) / (wi + wj + S) ^ 2 := by
    positivity
  have hscaled :
      (wi * wj) / (wi + wj + S) ^ 2 *
          (2 + wi / (wj + S) + wj / (wi + S)) ≤
        (wi * wj) / (wi + wj + S) ^ 2 *
          ((1 + C + wi / (wj + S)) *
            (1 + C + wj / (wi + S))) :=
    mul_le_mul_of_nonneg_left hcore hscale_nonneg
  have hleft :
      wi / (wi + wj + S) * (wj / (wi + wj + S - wi)) +
          wj / (wi + wj + S) * (wi / (wi + wj + S - wj)) =
        (wi * wj) / (wi + wj + S) ^ 2 *
          (2 + wi / (wj + S) + wj / (wi + S)) := by
    have hsub_i : wi + wj + S - wi = wj + S := by ring
    have hsub_j : wi + wj + S - wj = wi + S := by ring
    rw [hsub_i, hsub_j]
    field_simp [hden_i.ne', hden_j.ne', hT.ne']
    ring_nf
  have hright :
      (wi / (wi + wj + S) *
          (1 + C + wj / (wi + wj + S - wj))) *
        (wj / (wi + wj + S) *
          (1 + C + wi / (wi + wj + S - wi))) =
        (wi * wj) / (wi + wj + S) ^ 2 *
          ((1 + C + wi / (wj + S)) *
            (1 + C + wj / (wi + S))) := by
    have hsub_i : wi + wj + S - wi = wj + S := by ring
    have hsub_j : wi + wj + S - wj = wi + S := by ring
    rw [hsub_i, hsub_j]
    field_simp [hden_i.ne', hden_j.ne', hT.ne']
  rw [hleft, hright]
  exact hscaled

/--
Termwise denominator comparison used in the two-draw algebra: replacing
`T - weight x` by the larger denominator `T` can only decrease each
nonnegative summand.
-/
theorem im05_sum_div_total_le_sum_div_total_sub
    {Name : Type*} [DecidableEq Name]
    (outside : Finset Name) (weight : Name → ℝ) (T : ℝ)
    (hweight_nonneg : ∀ x ∈ outside, 0 ≤ weight x)
    (hT_pos : 0 < T)
    (hlt : ∀ x ∈ outside, weight x < T) :
    outside.sum (fun x => weight x / T) ≤
      outside.sum (fun x => weight x / (T - weight x)) := by
  classical
  refine Finset.sum_le_sum ?_
  intro x hx
  have hw_nonneg : 0 ≤ weight x := hweight_nonneg x hx
  have hden_pos : 0 < T - weight x := by
    linarith [hlt x hx]
  have hden_le : T - weight x ≤ T := by
    linarith [hw_nonneg]
  have hinv_le : 1 / T ≤ 1 / (T - weight x) :=
    one_div_le_one_div_of_le hden_pos hden_le
  calc
    weight x / T = weight x * (1 / T) := by ring
    _ ≤ weight x * (1 / (T - weight x)) :=
        mul_le_mul_of_nonneg_left hinv_le hw_nonneg
    _ = weight x / (T - weight x) := by ring

/--
Exact scalar witness that the arbitrary-`k` extension of the paper's
negative-correlation claim is false for the Plackett--Luce
without-replacement sampler.  Enumerating ordered top-three draws for weights
`[30, 1, 1, 1, 30, 1]` gives
`P[A_0] = P[A_4] = 6009/649264` and `P[A_0 ∧ A_4] = 1/10416`, where `A_u` is
omission of `u` from the first three draws.  The joint probability is strictly
larger than the product.
-/
theorem im05_plackettLuce_k3_omission_negative_correlation_counterexample_scalar :
    ((1 : ℝ) / 10416) >
      ((6009 : ℝ) / 649264) * ((6009 : ℝ) / 649264) := by
  norm_num

/--
Same scalar counterexample in the paper's conditional-comparison form:
`P[A_0 | A_4] = 187/18027` is strictly larger than `P[A_0]`.
-/
theorem im05_plackettLuce_k3_conditional_comparison_counterexample_scalar :
    ((187 : ℝ) / 18027) > ((6009 : ℝ) / 649264) := by
  norm_num

/--
Scalar variance-level counterexample to Lemma 4.4 as stated for the paper's
nonuniform `D^k` model.  With five men, five women, `k = 3`, and weights
`[50, 50, 1, 1, 1]`, let `p = P[A_0] = P[A_1]` be the one-man omission
probability for either popular woman and let `q = P[A_0 ∧ A_1]`.  Exact
enumeration of the Plackett--Luce top-three sampler gives
`p = 461653/243700678` and `q = 1/176851`.  For
`Y = 1_{E_0} + 1_{E_1}`, where `E_i` is omission by all five men,

`Var(Y) - E[Y] = 2 * q^5 - 4 * p^10`.

This theorem records that this scalar quantity is positive.
-/
theorem im05_lemma4_4_variance_counterexample_scalar :
    2 * ((1 : ℝ) / 176851) ^ 5 >
      4 * ((461653 : ℝ) / 243700678) ^ 10 := by
  norm_num

/--
Split a finite sum over all names except `i` into the `j` term plus the names
outside `{i,j}`.
-/
theorem im05_sum_if_ne_eq_pair_term_add_outside
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (f : Name → ℝ) (i j : Name) (hij : i ≠ j) :
    (∑ head : Name, if i ≠ head then f head else 0) =
      f j + (((Finset.univ : Finset Name).erase i).erase j).sum f := by
  classical
  let s := (Finset.univ : Finset Name).erase i
  have hsum_univ :
      (∑ head : Name, if i ≠ head then f head else 0) =
        s.sum f := by
    dsimp [s]
    symm
    rw [← Finset.sum_filter]
    congr 1
    ext head
    by_cases h : i = head <;> simp [h, eq_comm]
  have hj_mem : j ∈ s := by
    dsimp [s]
    simp [hij.symm]
  have hsplit :=
    Finset.sum_erase_add (s := s) (a := j) (f := f) hj_mem
  rw [hsum_univ]
  change s.sum f = f j + (s.erase j).sum f
  calc
    s.sum f = (s.erase j).sum f + f j := hsplit.symm
    _ = f j + (s.erase j).sum f := by ring

/--
Symmetric split of a finite sum over all names except `j`, using the same
outside set ordering as `im05_sum_if_ne_eq_pair_term_add_outside`.
-/
theorem im05_sum_if_ne_eq_pair_term_add_outside_symm
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (f : Name → ℝ) (i j : Name) (hij : i ≠ j) :
    (∑ head : Name, if j ≠ head then f head else 0) =
      f i + (((Finset.univ : Finset Name).erase i).erase j).sum f := by
  classical
  have hsplit :=
    im05_sum_if_ne_eq_pair_term_add_outside f j i hij.symm
  have houtside :
      (((Finset.univ : Finset Name).erase j).erase i) =
        (((Finset.univ : Finset Name).erase i).erase j) := by
    ext head
    simp [and_comm]
  simpa [houtside] using hsplit

/--
Split the total finite sum into the two named terms and the remaining names.
-/
theorem im05_sum_univ_eq_pair_add_outside
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (f : Name → ℝ) (i j : Name) (hij : i ≠ j) :
    (∑ name : Name, f name) =
      f i + f j + (((Finset.univ : Finset Name).erase i).erase j).sum f := by
  classical
  let s := (Finset.univ : Finset Name).erase i
  have hi_mem : i ∈ (Finset.univ : Finset Name) := by simp
  have hj_mem : j ∈ s := by
    dsimp [s]
    simp [hij.symm]
  have hsplit_i :=
    Finset.sum_erase_add
      (s := (Finset.univ : Finset Name)) (a := i) (f := f) hi_mem
  have hsplit_j :=
    Finset.sum_erase_add (s := s) (a := j) (f := f) hj_mem
  change (Finset.univ : Finset Name).sum f =
    f i + f j + (s.erase j).sum f
  calc
    (Finset.univ : Finset Name).sum f = s.sum f + f i := hsplit_i.symm
    _ = ((s.erase j).sum f + f j) + f i := by rw [hsplit_j.symm]
    _ = f i + f j + (s.erase j).sum f := by ring

/--
Two-draw negative correlation for the events that two distinct available
targets are hit by a weighted without-replacement sampler, started from an
arbitrary forbidden set.
-/
theorem im05_finiteWithoutReplacementPMF_two_hit_negative_correlation_of_not_mem
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (forbidden : Finset W)
    (hbudget : forbidden.card + 2 ≤ Fintype.card W)
    {i j : W} (hi : i ∉ forbidden) (hj : j ∉ forbidden) (hij : i ≠ j) :
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable 2 forbidden hbudget)
        (fun sample =>
          ¬ im05_listPrefixOmits i 2 sample.1 ∧
            ¬ im05_listPrefixOmits j 2 sample.1) ≤
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable 2 forbidden hbudget)
        (fun sample => ¬ im05_listPrefixOmits i 2 sample.1) *
      EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable 2 forbidden hbudget)
        (fun sample => ¬ im05_listPrefixOmits j 2 sample.1) := by
  classical
  let Available := {w // w ∉ forbidden}
  let ai : Available := ⟨i, hi⟩
  let aj : Available := ⟨j, hj⟩
  let μ :=
    EconCSLib.finiteWithoutReplacementPMF
      weight hweight_nonneg havailable 2 forbidden hbudget
  let T : ℝ := EconCSLib.finiteAvailableWeight weight forbidden
  let wi : ℝ := weight i
  let wj : ℝ := weight j
  let outside := ((Finset.univ : Finset Available).erase ai).erase aj
  let S : ℝ := outside.sum (fun head => weight head.1)
  let C : ℝ := outside.sum (fun head => weight head.1 / (T - weight head.1))
  have hai_ne_aj : ai ≠ aj := by
    intro h
    exact hij (congrArg Subtype.val h)
  have hwi_pos : 0 < wi := by
    dsimp [wi]
    exact EconCSLib.finiteWeight_pos_of_available weight havailable i
  have hwj_pos : 0 < wj := by
    dsimp [wj]
    exact EconCSLib.finiteWeight_pos_of_available weight havailable j
  have hS_nonneg : 0 ≤ S := by
    dsimp [S]
    exact Finset.sum_nonneg (by
      intro head _hhead
      exact hweight_nonneg head.1)
  have hT_pos : 0 < T := by
    dsimp [T]
    exact havailable forbidden (by omega)
  have hT_eq : T = wi + wj + S := by
    dsimp [T, wi, wj, S, outside, ai, aj, Available]
    rw [EconCSLib.finiteAvailableWeight_eq_subtype_sum]
    simpa using
      (im05_sum_univ_eq_pair_add_outside
        (fun head : {w // w ∉ forbidden} => weight head.1)
        ⟨i, hi⟩ ⟨j, hj⟩ (by
          intro h
          exact hij (congrArg Subtype.val h)))
  have hC : S / T ≤ C := by
    dsimp [S, C, T, outside]
    have hle :=
      im05_sum_div_total_le_sum_div_total_sub
        (((Finset.univ : Finset Available).erase ai).erase aj)
        (fun head : Available => weight head.1)
        (EconCSLib.finiteAvailableWeight weight forbidden)
        (by
          intro head _hhead
          exact hweight_nonneg head.1)
        hT_pos
        (by
          intro head _hhead
          have havail_insert :
              0 <
                EconCSLib.finiteAvailableWeight weight
                  (insert head.1 forbidden) :=
            havailable (insert head.1 forbidden) (by
              rw [Finset.card_insert_of_notMem head.2]
              omega)
          rw [EconCSLib.finiteAvailableWeight_insert_eq_sub
            weight forbidden head.2] at havail_insert
          linarith)
    simpa [div_eq_mul_inv, Finset.sum_mul] using hle
  have hcore :=
    im05_two_draw_hit_negative_correlation_core_prob_shape
      hT_eq hwi_pos hwj_pos hS_nonneg hC
  have hsum_i :
      (∑ head : Available,
        if i ≠ head.1 then weight head.1 / (T - weight head.1) else 0) =
        wj / (T - wj) + C := by
    have hcongr :
        (∑ head : Available,
          if i ≠ head.1 then weight head.1 / (T - weight head.1) else 0) =
          ∑ head : Available,
            if ai ≠ head then weight head.1 / (T - weight head.1) else 0 := by
      refine Finset.sum_congr rfl ?_
      intro head _hhead
      by_cases h : ai = head
      · have hval : i = head.1 := congrArg Subtype.val h
        simp [h, hval]
      · have hval : i ≠ head.1 := by
          intro hval
          exact h (Subtype.ext hval)
        simp [h, hval]
    have hsplit :=
      im05_sum_if_ne_eq_pair_term_add_outside
        (fun head : Available => weight head.1 / (T - weight head.1))
        ai aj hai_ne_aj
    rw [hcongr]
    simpa [ai, aj, wi, wj, C, outside] using hsplit
  have hsum_j :
      (∑ head : Available,
        if j ≠ head.1 then weight head.1 / (T - weight head.1) else 0) =
        wi / (T - wi) + C := by
    have hcongr :
        (∑ head : Available,
          if j ≠ head.1 then weight head.1 / (T - weight head.1) else 0) =
          ∑ head : Available,
            if aj ≠ head then weight head.1 / (T - weight head.1) else 0 := by
      refine Finset.sum_congr rfl ?_
      intro head _hhead
      by_cases h : aj = head
      · have hval : j = head.1 := congrArg Subtype.val h
        simp [h, hval]
      · have hval : j ≠ head.1 := by
          intro hval
          exact h (Subtype.ext hval)
        simp [h, hval]
    have hsplit :=
      im05_sum_if_ne_eq_pair_term_add_outside_symm
        (fun head : Available => weight head.1 / (T - weight head.1))
        ai aj hai_ne_aj
    rw [hcongr]
    simpa [ai, aj, wi, wj, C, outside] using hsplit
  have hboth :
      EconCSLib.pmfProb μ
          (fun sample =>
            ¬ im05_listPrefixOmits i 2 sample.1 ∧
              ¬ im05_listPrefixOmits j 2 sample.1) =
        wi / T * (wj / (T - wi)) +
          wj / T * (wi / (T - wj)) := by
    dsimp [μ, T, wi, wj]
    rw [im05_finiteWithoutReplacementPMF_two_hit_both_prob_eq_order_sum
      weight hweight_nonneg havailable forbidden hbudget hi hj hij]
    rw [EconCSLib.finiteAvailableWeight_insert_eq_sub weight forbidden hi]
    rw [EconCSLib.finiteAvailableWeight_insert_eq_sub weight forbidden hj]
  have hi_prob :
      EconCSLib.pmfProb μ
          (fun sample => ¬ im05_listPrefixOmits i 2 sample.1) =
        wi / T * (1 + C + wj / (T - wj)) := by
    dsimp [μ, T, wi, wj]
    rw [im05_finiteWithoutReplacementPMF_two_hit_prob_eq_factor
      weight hweight_nonneg havailable forbidden hbudget hi]
    rw [hsum_i]
    ring
  have hj_prob :
      EconCSLib.pmfProb μ
          (fun sample => ¬ im05_listPrefixOmits j 2 sample.1) =
        wj / T * (1 + C + wi / (T - wi)) := by
    dsimp [μ, T, wi, wj]
    rw [im05_finiteWithoutReplacementPMF_two_hit_prob_eq_factor
      weight hweight_nonneg havailable forbidden hbudget hj]
    rw [hsum_j]
    ring
  calc
    EconCSLib.pmfProb μ
        (fun sample =>
          ¬ im05_listPrefixOmits i 2 sample.1 ∧
            ¬ im05_listPrefixOmits j 2 sample.1)
        =
      wi / T * (wj / (T - wi)) +
        wj / T * (wi / (T - wj)) := hboth
    _ ≤
      (wi / T * (1 + C + wj / (T - wj))) *
        (wj / T * (1 + C + wi / (T - wi))) := hcore
    _ =
      EconCSLib.pmfProb μ
          (fun sample => ¬ im05_listPrefixOmits i 2 sample.1) *
        EconCSLib.pmfProb μ
          (fun sample => ¬ im05_listPrefixOmits j 2 sample.1) := by
        rw [hi_prob, hj_prob]

/--
Two-draw negative correlation for omission events when both targets are still
available.
-/
theorem im05_omissionPairNegativeCorrelation_two_of_not_mem
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (forbidden : Finset W)
    (hbudget : forbidden.card + 2 ≤ Fintype.card W)
    {i j : W} (hi : i ∉ forbidden) (hj : j ∉ forbidden) (hij : i ≠ j) :
    im05_omissionPairNegativeCorrelation
      (k := 2) weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  unfold im05_omissionPairNegativeCorrelation
  let μ :=
    EconCSLib.finiteWithoutReplacementPMF
      weight hweight_nonneg havailable 2 forbidden hbudget
  let hit : W → EconCSLib.finiteFreshList W 2 forbidden → Prop :=
    fun target sample => ¬ im05_listPrefixOmits target 2 sample.1
  have hhit :
      EconCSLib.pmfProb μ (fun sample => hit i sample ∧ hit j sample) ≤
        EconCSLib.pmfProb μ (hit i) *
          EconCSLib.pmfProb μ (hit j) := by
    simpa [μ, hit] using
      im05_finiteWithoutReplacementPMF_two_hit_negative_correlation_of_not_mem
        weight hweight_nonneg havailable forbidden hbudget hi hj hij
  have hcomp :=
    EconCSLib.pmfProb_not_and_not_le_mul_of_inter_le_mul
      μ (hit i) (hit j) hhit
  have hleft :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_listPrefixOmits i 2 sample.1 ∧
              im05_listPrefixOmits j 2 sample.1) =
        EconCSLib.pmfProb μ
          (fun sample => ¬ hit i sample ∧ ¬ hit j sample) := by
    exact EconCSLib.pmfProb_congr μ (by
      intro sample
      simp [hit])
  have hi_prob :
      EconCSLib.pmfProb μ
          (fun sample => im05_listPrefixOmits i 2 sample.1) =
        EconCSLib.pmfProb μ (fun sample => ¬ hit i sample) := by
    exact EconCSLib.pmfProb_congr μ (by
      intro sample
      simp [hit])
  have hj_prob :
      EconCSLib.pmfProb μ
          (fun sample => im05_listPrefixOmits j 2 sample.1) =
        EconCSLib.pmfProb μ (fun sample => ¬ hit j sample) := by
    exact EconCSLib.pmfProb_congr μ (by
      intro sample
      simp [hit])
  rw [hleft, hi_prob, hj_prob]
  exact hcomp

/--
Two-draw omission negative correlation for distinct targets.  If a target is
already forbidden, its omission event is certain; otherwise this is the
two-draw hit negative-correlation theorem plus complementation.
-/
theorem im05_omissionPairNegativeCorrelation_two_of_ne
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (forbidden : Finset W)
    (hbudget : forbidden.card + 2 ≤ Fintype.card W)
    {i j : W} (hij : i ≠ j) :
    im05_omissionPairNegativeCorrelation
      (k := 2) weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  by_cases hi_forbidden : i ∈ forbidden
  · unfold im05_omissionPairNegativeCorrelation
    let μ :=
      EconCSLib.finiteWithoutReplacementPMF
        weight hweight_nonneg havailable 2 forbidden hbudget
    have homit_i :
        EconCSLib.pmfProb μ
            (fun sample => im05_listPrefixOmits i 2 sample.1) = 1 := by
      refine EconCSLib.pmfProb_eq_one_of_forall μ _ ?_
      intro sample slot _hslot hsample
      exact sample.2.2 slot (by simpa [hsample] using hi_forbidden)
    have hjoint :
        EconCSLib.pmfProb μ
            (fun sample =>
              im05_listPrefixOmits i 2 sample.1 ∧
                im05_listPrefixOmits j 2 sample.1) =
          EconCSLib.pmfProb μ
            (fun sample => im05_listPrefixOmits j 2 sample.1) := by
      refine EconCSLib.pmfProb_congr μ ?_
      intro sample
      constructor
      · intro h
        exact h.2
      · intro hj
        exact ⟨(by
          intro slot hslot hsample
          exact sample.2.2 slot (by simpa [hsample] using hi_forbidden)), hj⟩
    rw [hjoint, homit_i]
    simp [μ]
  · by_cases hj_forbidden : j ∈ forbidden
    · unfold im05_omissionPairNegativeCorrelation
      let μ :=
        EconCSLib.finiteWithoutReplacementPMF
          weight hweight_nonneg havailable 2 forbidden hbudget
      have homit_j :
          EconCSLib.pmfProb μ
              (fun sample => im05_listPrefixOmits j 2 sample.1) = 1 := by
        refine EconCSLib.pmfProb_eq_one_of_forall μ _ ?_
        intro sample slot _hslot hsample
        exact sample.2.2 slot (by simpa [hsample] using hj_forbidden)
      have hjoint :
          EconCSLib.pmfProb μ
              (fun sample =>
                im05_listPrefixOmits i 2 sample.1 ∧
                  im05_listPrefixOmits j 2 sample.1) =
            EconCSLib.pmfProb μ
              (fun sample => im05_listPrefixOmits i 2 sample.1) := by
        refine EconCSLib.pmfProb_congr μ ?_
        intro sample
        constructor
        · intro h
          exact h.1
        · intro hi
          exact ⟨hi, by
            intro slot hslot hsample
            exact sample.2.2 slot (by simpa [hsample] using hj_forbidden)⟩
      rw [hjoint, homit_j]
      simp [μ]
    · exact
        im05_omissionPairNegativeCorrelation_two_of_not_mem
          weight hweight_nonneg havailable forbidden hbudget
          hi_forbidden hj_forbidden hij

/--
If the left target is already forbidden, its omission event is certain, so
pairwise omission negative correlation reduces to the right marginal event.
-/
theorem im05_omissionPairNegativeCorrelation_of_left_mem_forbidden
    {W : Type*} [Fintype W] [DecidableEq W]
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + k ≤ Fintype.card W)
    {i j : W} (hi_forbidden : i ∈ forbidden) :
    im05_omissionPairNegativeCorrelation
      (k := k) weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  unfold im05_omissionPairNegativeCorrelation
  let μ :=
    EconCSLib.finiteWithoutReplacementPMF
      weight hweight_nonneg havailable k forbidden hbudget
  have homit_i :
      EconCSLib.pmfProb μ
          (fun sample => im05_listPrefixOmits i k sample.1) = 1 := by
    refine EconCSLib.pmfProb_eq_one_of_forall μ _ ?_
    intro sample slot _hslot hsample
    exact sample.2.2 slot (by simpa [hsample] using hi_forbidden)
  have hjoint :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_listPrefixOmits i k sample.1 ∧
              im05_listPrefixOmits j k sample.1) =
        EconCSLib.pmfProb μ
          (fun sample => im05_listPrefixOmits j k sample.1) := by
    refine EconCSLib.pmfProb_congr μ ?_
    intro sample
    constructor
    · intro h
      exact h.2
    · intro hj
      exact ⟨(by
        intro slot hslot hsample
        exact sample.2.2 slot (by simpa [hsample] using hi_forbidden)), hj⟩
  rw [hjoint, homit_i]
  simp [μ]

/--
If the right target is already forbidden, its omission event is certain, so
pairwise omission negative correlation reduces to the left marginal event.
-/
theorem im05_omissionPairNegativeCorrelation_of_right_mem_forbidden
    {W : Type*} [Fintype W] [DecidableEq W]
