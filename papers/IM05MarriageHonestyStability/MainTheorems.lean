/--
Membership in the corrected target-divorcing Algorithm 4.1 output prefix: a
man is listed iff he is the initial DA husband or he is accepted by the target
at one of the first `steps` source-divorcing transitions.
-/
theorem im05_mem_algorithm41SourceDivorceTargetAcceptedMenPrefix_iff
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (steps : ℕ) (m : M) :
    m ∈ im05_algorithm41SourceDivorceTargetAcceptedMenPrefix val_m val_w g steps ↔
      im05_algorithm41InitialHusband val_m val_w g = some m ∨
        ∃ t < steps,
          im05_algorithm41SourceStepTargetAccepted val_m val_w g
            (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g t) =
              some m := by
  classical
  cases hinit : im05_algorithm41InitialHusband val_m val_w g with
  | none =>
      simp [im05_algorithm41SourceDivorceTargetAcceptedMenPrefix, hinit]
  | some init =>
      by_cases hinitm : init = m
      · subst init
        simp [im05_algorithm41SourceDivorceTargetAcceptedMenPrefix, hinit]
      · simp [im05_algorithm41SourceDivorceTargetAcceptedMenPrefix, hinit,
          hinitm, show m ≠ init by
            intro hm
            exact hinitm hm.symm]

theorem im05_algorithm41HeldMenPrefix_worstToBest
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (steps : ℕ) :
    im05_worstToBestForWoman val_w g
      (im05_algorithm41HeldMenPrefix val_m val_w g steps) := by
  classical
  let raw : List M :=
    (List.range (steps + 1)).filterMap fun t =>
      (im05_algorithm41StateAfterSteps val_m val_w g t).w_match g
  have hraw : raw.Pairwise fun m₁ m₂ => val_w g m₁ ≤ val_w g m₂ := by
    dsimp [raw]
    apply (List.sortedLT_range (steps + 1)).pairwise.filterMap
    intro t₁ t₂ ht m₁ hm₁ m₂ hm₂
    have hmatch₁ :
        (im05_algorithm41StateAfterSteps val_m val_w g t₁).w_match g =
          some m₁ := by
      simpa using hm₁
    have hmatch₂ :
        (im05_algorithm41StateAfterSteps val_m val_w g t₂).w_match g =
          some m₂ := by
      simpa using hm₂
    have hmono :=
      im05_algorithm41StateAfterSteps_target_value_mono_of_le
        val_m val_w g (Nat.le_of_lt ht)
    simpa [valW, hmatch₁, hmatch₂] using hmono
  exact hraw.sublist (List.dedup_sublist raw)

