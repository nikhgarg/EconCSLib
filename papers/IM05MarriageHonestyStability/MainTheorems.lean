  have hmem_after :
      g ∈
        (im05_algorithm41SourceDivorceTargetStateAfterSteps
          val_m val_w g (t₁ + 1)).m_proposals m₁ :=
    im05_algorithm41SourceDivorceTargetStateAfterSteps_m_proposals_subset_of_le
