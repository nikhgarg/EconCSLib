/--
Along the source-shaped Algorithm 4.1 trace, the target woman's held value is
monotone once the initial DA run matched her.
-/
theorem im05_algorithm41SourceStateAfterSteps_target_value_mono_of_initial_match
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) {g : W} {m : M}
    (hmatch : (deferredAcceptanceState val_m val_w).w_match g = some m)
    {steps later : ℕ} (hle : steps ≤ later) :
    valW val_w g
        ((im05_algorithm41SourceStateAfterSteps val_m val_w g steps).w_match g) ≤
      valW val_w g
        ((im05_algorithm41SourceStateAfterSteps val_m val_w g later).w_match g) := by
  obtain ⟨d, rfl⟩ := Nat.exists_eq_add_of_le hle
  induction d with
  | zero =>
      simp
  | succ d ih =>
    have hmatched :
        MatchedProposedInvariant
          (im05_algorithm41SourceStateAfterSteps val_m val_w g (steps + d)) :=
      im05_algorithm41SourceStateAfterSteps_matchedProposedInvariant
        val_m val_w g (steps + d)
    have hbest_nonneg :
        ∃ best : M,
          im05_algorithm41BestProposedSoFar val_w
              (im05_algorithm41SourceStateAfterSteps val_m val_w g (steps + d)) g best ∧
            0 ≤ val_w g best :=
      im05_algorithm41SourceStateAfterSteps_target_nonneg_bestProposedSoFar_of_initial_match
        val_m val_w hmatch (steps + d)
    have hone :
        valW val_w g
            ((im05_algorithm41SourceStateAfterSteps val_m val_w g (steps + d)).w_match g) ≤
          valW val_w g
            ((im05_algorithm41SourceStateAfterSteps val_m val_w g (steps + d + 1)).w_match g) := by
      simpa [im05_algorithm41SourceStateAfterSteps_succ] using
        im05_algorithm41SourceStep_target_value_mono
          val_m val_w
          (im05_algorithm41SourceStateAfterSteps val_m val_w g (steps + d))
          g hmatched hbest_nonneg
    exact le_trans (ih (Nat.le_add_right steps d)) (by
      simpa [Nat.add_assoc] using hone)

