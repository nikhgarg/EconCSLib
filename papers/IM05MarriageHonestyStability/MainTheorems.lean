    {Token Name : Type*} [DecidableEq Name]
    (Ω : ℕ → Type*) [∀ scale, Fintype (Ω scale)]
    [∀ scale, DecidableEq (Ω scale)]
    (μ : ∀ scale, PMF (Ω scale))
    (perm : ∀ scale, Ω scale → List Token)
    (name : Token → Name) (i j : Name) (k : ℕ)
    (condProb baseProb : ℝ)
    (hcond_lim :
      Filter.Tendsto
        (fun scale : ℕ =>
          EconCSLib.pmfProb (μ scale)
            (fun ω =>
              k ≤ ((im05_namesBeforeFirst name i (perm scale ω)).erase j).card))
        Filter.atTop (nhds condProb))
    (hbase_lim :
      Filter.Tendsto
        (fun scale : ℕ =>
          EconCSLib.pmfProb (μ scale)
            (fun ω =>
              k ≤ (im05_namesBeforeFirst name i (perm scale ω)).card))
        Filter.atTop (nhds baseProb)) :
    condProb ≤ baseProb := by
  classical
  exact
    paper_im05_lemma4_4_one_man_comparison_from_multiset_limits
      (fun scale : ℕ =>
        EconCSLib.pmfProb (μ scale)
          (fun ω =>
            k ≤ ((im05_namesBeforeFirst name i (perm scale ω)).erase j).card))
      (fun scale : ℕ =>
        EconCSLib.pmfProb (μ scale)
          (fun ω =>
            k ≤ (im05_namesBeforeFirst name i (perm scale ω)).card))
      condProb baseProb
      (fun scale =>
        paper_im05_lemma4_4_multiset_event_inclusion_probability
          (μ scale) (perm scale) name i j k)
      hcond_lim hbase_lim

