  · exact mul_le_mul_of_nonneg_right hcard (Real.exp_pos _).le
  · intro i hi
    simpa [rate] using hprob i hi

/--
Lemma 4.3 tail arithmetic: for indices in the upper half of `{1, ..., g}`,
the source's pointwise bound `exp(-4nk/w)` is at least the common tail rate
`exp(-8nk/g)`.
-/
theorem paper_im05_lemma4_3_exp_tail_rate_le
    (g w n k : ℕ) (hg : 0 < g) (hw : 0 < w)
    (hhalf : (g : ℝ) / 2 ≤ (w : ℝ)) :
    Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤
      Real.exp (-(4 * (n : ℝ) * (k : ℝ) / (w : ℝ))) := by
  have hg_pos : 0 < (g : ℝ) := by exact_mod_cast hg
  have hw_pos : 0 < (w : ℝ) := by exact_mod_cast hw
  refine Real.exp_le_exp.mpr ?_
  have hgw : (g : ℝ) ≤ 2 * (w : ℝ) := by linarith
  have hn : 0 ≤ (n : ℝ) := by exact_mod_cast Nat.zero_le n
  have hk : 0 ≤ (k : ℝ) := by exact_mod_cast Nat.zero_le k
  have hprod_nonneg : 0 ≤ 4 * (n : ℝ) * (k : ℝ) :=
    mul_nonneg (mul_nonneg (by norm_num) hn) hk
  have hmain :
      4 * (n : ℝ) * (k : ℝ) * (g : ℝ) ≤
        8 * (n : ℝ) * (k : ℝ) * (w : ℝ) := by
    nlinarith [mul_le_mul_of_nonneg_left hgw hprod_nonneg]
  have hdiv :
      4 * (n : ℝ) * (k : ℝ) / (w : ℝ) ≤
        8 * (n : ℝ) * (k : ℝ) / (g : ℝ) := by
    rw [div_le_div_iff₀ hw_pos hg_pos]
    nlinarith
  linarith

/--
Lemma 4.3 ranked-tail wrapper: if each indexed tail element `i` has rank
`w_i >= g/2` and absence probability at least `exp(-4nk/w_i)`, then the
common `exp(-8nk/g)` tail-sum lower bound follows.
-/
theorem paper_im05_lemma4_3_expected_absent_count_lower_bound_from_rank_tail
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (absent : I → Ω → Prop)
    [∀ ω, DecidablePred fun i => absent i ω]
    [∀ i, DecidablePred fun ω => absent i ω]
    (tail : Finset I) (rank : I → ℕ) (g n k : ℕ)
    (hg : 0 < g)
    (hcard : (g : ℝ) / 2 ≤ (tail.card : ℝ))
    (hrank_pos : ∀ i ∈ tail, 0 < rank i)
    (hhalf : ∀ i ∈ tail, (g : ℝ) / 2 ≤ (rank i : ℝ))
    (hprob : ∀ i ∈ tail,
      Real.exp (-(4 * (n : ℝ) * (k : ℝ) / (rank i : ℝ))) ≤
        EconCSLib.pmfProb μ (fun ω => absent i ω)) :
    (g : ℝ) / 2 *
        Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => absent i ω).card : ℝ)) := by
  classical
  refine
    paper_im05_lemma4_3_expected_absent_count_lower_bound
      μ absent tail g n k hcard ?_
  intro i hi
  exact le_trans
    (paper_im05_lemma4_3_exp_tail_rate_le
      g (rank i) n k hg (hrank_pos i hi) (hhalf i hi))
    (hprob i hi)

