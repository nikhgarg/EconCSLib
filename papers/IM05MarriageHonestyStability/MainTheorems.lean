        (fun ω => (EconCSLib.occupancyEmptyBins (names₃ ω)).card) := by
  exact EconCSLib.pmfExpReciprocalSucc_congr μ _ _
    (paper_im05_experiment2_3_empty_count_eq_of_usedBins_eq
      names₂ names₃ hused)

