/--
Algorithm 4.1 base case: the first output, the men-proposing DA husband of
`g`, is weakly worst among `g`'s stable husbands.
-/
theorem im05_algorithm41InitialHusband_worst_stableHusband
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (hcard : Fintype.card M = Fintype.card W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    {m : M}
    (hinit : im05_algorithm41InitialHusband val_m val_w g = some m) :
    ∀ r : M, r ∈ im05_stableHusbands val_m val_w g →
      val_w g m ≤ val_w g r := by
  classical
  intro r hr
  rcases (by simpa [im05_stableHusbands] using hr) with
    ⟨mu, hstable, hmu_g⟩
  have hpess :=
    da_is_women_pessimal_of_strict_preferences
      val_m val_w hcard hstrictM hstrictW hacceptable mu hstable g
  have hda_g : (deferredAcceptance val_m val_w).w_match g = some m := by
    simpa [deferredAcceptance, im05_algorithm41InitialHusband] using hinit
  simpa [valW, hda_g, hmu_g] using hpess

/--
With strict woman preferences, every other stable husband is strictly better
for `g` than Algorithm 4.1's first output.
-/
theorem im05_algorithm41InitialHusband_strictly_worst_stableHusband_of_ne
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
