-/
theorem paper_im05_lemma4_1_from_stable_sample_variance_and_lemma4_3
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω] [Fintype W]
    (μ : PMF Ω)
    (popularity : Ω → W → ℝ)
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ)
