/--
Concrete Algorithm 4.2 `k = 2` pairwise omission negative correlation for
arbitrary nonnegative real weights with positive availability.  This supersedes
the older raw-count-only `k = 2` endpoint when no finite approximation layer is
needed.
-/
theorem paper_im05_lemma4_4_freshList_pairwise_negative_correlation_two
    {I : Type*} [Fintype I] [DecidableEq I]
    (weight : I → ℝ)
    (hweight_nonneg : ∀ u, 0 ≤ weight u)
    (havailable : ∀ forbidden : Finset I,
      forbidden.card < Fintype.card I →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (hcard_two : 2 ≤ Fintype.card I)
    (i j : I) (hij : i ≠ j) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          weight hweight_nonneg havailable 2 hcard_two)
        (fun sample =>
          im05_listPrefixOmits i 2
              (im05_algorithm42FreshListDraw sample) ∧
            im05_listPrefixOmits j 2
              (im05_algorithm42FreshListDraw sample)) ≤
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          weight hweight_nonneg havailable 2 hcard_two)
        (fun sample =>
          im05_listPrefixOmits i 2
            (im05_algorithm42FreshListDraw sample)) *
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          weight hweight_nonneg havailable 2 hcard_two)
        (fun sample =>
          im05_listPrefixOmits j 2
            (im05_algorithm42FreshListDraw sample)) := by
  classical
  simpa [im05_algorithm42FreshListPMF, im05_algorithm42FreshListDraw,
    im05_omissionPairNegativeCorrelation] using
    im05_omissionPairNegativeCorrelation_two_of_ne
      weight hweight_nonneg havailable (∅ : Finset I)
      (by simpa using hcard_two) hij

/--
Tail-depth induction with the two-draw base discharged by the generic
two-draw weighted-without-replacement negative-correlation theorem.  The only
remaining stochastic input is the compact first-step inequality at residual
lengths at least two.
-/
theorem im05_omissionPairNegativeCorrelation_of_tailDepth_twoStepBase_firstStep_family
    {W : Type*} [Fintype W] [DecidableEq W]
    (all : Finset W)
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (hfirst_step : ∀ {r : ℕ}, 1 < r → ∀ (forbidden : Finset W)
      (hbudget : forbidden.card + (r + 1) ≤ Fintype.card W)
      (i j : W), i ≠ j →
      im05_tailDepth all weight forbidden i (r + 1) →
      im05_tailDepth all weight forbidden j (r + 1) →
      im05_firstStepOmitPairProductSum
          weight hweight_nonneg havailable forbidden hbudget i j ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + k ≤ Fintype.card W)
    {i j : W} (hij : i ≠ j)
    (hdepth_i : im05_tailDepth all weight forbidden i k)
    (hdepth_j : im05_tailDepth all weight forbidden j k) :
    im05_omissionPairNegativeCorrelation
      (k := k) weight hweight_nonneg havailable forbidden hbudget i j := by
  exact
    im05_omissionPairNegativeCorrelation_of_tailDepth_twoStep_firstStep_family
      all weight hweight_nonneg havailable
      (fun forbidden hbudget i j hij _hdepth_i _hdepth_j =>
        im05_omissionPairNegativeCorrelation_two_of_ne
          weight hweight_nonneg havailable forbidden hbudget hij)
      hfirst_step forbidden hbudget hij hdepth_i hdepth_j

/--
Tail-depth induction with the two-draw base discharged and the first-step
algebra required only when both targets are still available.  If either target
has already been forbidden, the corresponding omission event is certain and
the boundary lemmas close the branch.
-/
theorem
    im05_omissionPairNegativeCorrelation_of_tailDepth_twoStepBase_available_firstStep_family
    {W : Type*} [Fintype W] [DecidableEq W]
    (all : Finset W)
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (hfirst_step : ∀ {r : ℕ}, 1 < r → ∀ (forbidden : Finset W)
      (hbudget : forbidden.card + (r + 1) ≤ Fintype.card W)
      (i j : W), i ≠ j → i ∉ forbidden → j ∉ forbidden →
      im05_tailDepth all weight forbidden i (r + 1) →
      im05_tailDepth all weight forbidden j (r + 1) →
      im05_firstStepOmitPairProductSum
          weight hweight_nonneg havailable forbidden hbudget i j ≤
        im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget i *
          im05_firstStepOmitMarginalSum
            weight hweight_nonneg havailable forbidden hbudget j)
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + k ≤ Fintype.card W)
    {i j : W} (hij : i ≠ j)
    (hdepth_i : im05_tailDepth all weight forbidden i k)
    (hdepth_j : im05_tailDepth all weight forbidden j k) :
    im05_omissionPairNegativeCorrelation
      (k := k) weight hweight_nonneg havailable forbidden hbudget i j := by
  classical
  induction k generalizing forbidden i j with
  | zero =>
      exact
        im05_omissionPairNegativeCorrelation_zero
          weight hweight_nonneg havailable forbidden hbudget i j
  | succ k ih =>
      by_cases hi_forbidden : i ∈ forbidden
      · exact
          im05_omissionPairNegativeCorrelation_of_left_mem_forbidden
            weight hweight_nonneg havailable forbidden hbudget hi_forbidden
      · by_cases hj_forbidden : j ∈ forbidden
        · exact
            im05_omissionPairNegativeCorrelation_of_right_mem_forbidden
              weight hweight_nonneg havailable forbidden hbudget hj_forbidden
        · cases k with
          | zero =>
              exact
                im05_omissionPairNegativeCorrelation_one_of_ne
                  weight hweight_nonneg havailable forbidden hbudget hij
          | succ r =>
              cases r with
              | zero =>
                  exact
                    im05_omissionPairNegativeCorrelation_two_of_ne
                      weight hweight_nonneg havailable forbidden hbudget hij
              | succ s =>
                  exact
                    im05_omissionPairNegativeCorrelation_succ_from_tailDepth_first_step
                      all weight hweight_nonneg havailable forbidden hbudget i j
                      (by
                        intro head _hhead_i _hhead_j
                        exact
                          im05_tailDepth_after_insert_of_tailDepth_succ
                            all weight forbidden i hdepth_i head)
                      (by
                        intro head _hhead_i _hhead_j
                        exact
                          im05_tailDepth_after_insert_of_tailDepth_succ
                            all weight forbidden j hdepth_j head)
                      (by
                        intro head _hhead_i _hhead_j htail_i htail_j
                        exact
                          ih (insert head.1 forbidden)
                            (by
                              rw [Finset.card_insert_of_notMem head.2]
                              omega)
                            hij htail_i htail_j)
                      (hfirst_step (by omega) forbidden hbudget i j hij
                        hi_forbidden hj_forbidden hdepth_i hdepth_j)

/--
Tail-depth induction from the exact named residual-spread family.  This is the
preferred induction-facing form of the remaining repaired Lemma 4.4 stochastic
obligation: prove the displayed double-spread nonnegativity in every available
tail-depth state, and the pairwise omission negative-correlation conclusion
follows with the zero-, one-, two-draw, and already-forbidden boundary cases
closed internally.
-/
theorem
    im05_omissionPairNegativeCorrelation_of_tailDepth_twoStepBase_available_residual_spread_family
    {W : Type*} [Fintype W] [DecidableEq W]
    (all : Finset W)
    (weight : W → ℝ)
    (hweight_nonneg : ∀ w, 0 ≤ weight w)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (hspread : ∀ {r : ℕ}, 1 < r → ∀ (forbidden : Finset W)
      (hbudget : forbidden.card + (r + 1) ≤ Fintype.card W)
      (i j : W), i ≠ j → i ∉ forbidden → j ∉ forbidden →
      im05_tailDepth all weight forbidden i (r + 1) →
      im05_tailDepth all weight forbidden j (r + 1) →
      0 ≤ ∑ head : {w // w ∉ forbidden},
        ∑ tail : {w // w ∉ forbidden},
          im05_firstStepHeadWeight
              weight hweight_nonneg havailable forbidden hbudget head *
            im05_firstStepHeadWeight
              weight hweight_nonneg havailable forbidden hbudget tail *
            ((im05_firstStepResidualOmitProb
                weight hweight_nonneg havailable forbidden hbudget i head -
              im05_firstStepResidualOmitProb
                weight hweight_nonneg havailable forbidden hbudget i tail) *
              (im05_firstStepResidualOmitProb
                  weight hweight_nonneg havailable forbidden hbudget j tail -
                im05_firstStepResidualOmitProb
                  weight hweight_nonneg havailable forbidden hbudget j head)))
    {k : ℕ} (forbidden : Finset W)
    (hbudget : forbidden.card + k ≤ Fintype.card W)
    {i j : W} (hij : i ≠ j)
    (hdepth_i : im05_tailDepth all weight forbidden i k)
    (hdepth_j : im05_tailDepth all weight forbidden j k) :
    im05_omissionPairNegativeCorrelation
      (k := k) weight hweight_nonneg havailable forbidden hbudget i j := by
  exact
    im05_omissionPairNegativeCorrelation_of_tailDepth_twoStepBase_available_firstStep_family
      all weight hweight_nonneg havailable
      (fun hr forbidden hbudget i j hij hi_available hj_available hdepth_i hdepth_j =>
        im05_firstStepOmitPairProductSum_le_mul_of_residual_spread_sum_nonneg
          weight hweight_nonneg havailable forbidden hbudget i j
          (hspread hr forbidden hbudget i j hij hi_available hj_available
            hdepth_i hdepth_j))
      forbidden hbudget hij hdepth_i hdepth_j

