/--
The source rank-tail block is contained in the lower-rank prefix of size `g`;
therefore its absent count is bounded by the `Y_g`-style count over that
prefix.
-/
theorem im05_sourceRankTailBlock_filter_card_le_lowerRankFinset_filter_card
    {W : Type*} [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N : ℕ}
    (hall_card : all.card = N)
    (g : ℕ) (hg_le_N : g ≤ N)
    (event : W → Prop) [DecidablePred event] :
    ((im05_sourceRankTailBlock N g hg_le_N).filter fun idx =>
        event
          (EconCSLib.FiniteRanking.rankAgentByValue
            all (fun v => -prob v) hall_card idx)).card ≤
      ((EconCSLib.FiniteRanking.lowerRankFinset
          all (fun v => -prob v) hall_card g).filter event).card := by
  simpa [im05_sourceRankTailBlock] using
    im05_rankIndexBlock_filter_card_le_lowerRankFinset_filter_card
      all prob hall_card (g / 2) (g - g / 2) g (by omega) (by omega)
      event

/--
The ranked popularity tail has the paper's cardinality `rank - k` whenever the
one-indexed target rank lies after the top `k` positions and inside the finite
universe.
-/
theorem im05_popularityRankTail_card
    {W : Type*} [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N : ℕ}
    (hcard : all.card = N) {rank k : ℕ}
    (hk_rank : k < rank) (hrank_le : rank ≤ N) :
    (im05_popularityRankTail all prob hcard rank k).card = rank - k := by
  classical
  unfold im05_popularityRankTail im05_popularityTopPrefix
  have hsubset :
      EconCSLib.FiniteRanking.lowerRankFinset all (fun u => -prob u) hcard k ⊆
        EconCSLib.FiniteRanking.lowerRankFinset all (fun u => -prob u) hcard rank :=
    EconCSLib.FiniteRanking.lowerRankFinset_mono
      all (fun u => -prob u) hcard (Nat.le_of_lt hk_rank)
  rw [Finset.card_sdiff_of_subset hsubset]
  have hrank_card :=
    EconCSLib.FiniteRanking.lowerRankFinset_card
      all (fun u => -prob u) hcard rank
  have hk_card :=
    EconCSLib.FiniteRanking.lowerRankFinset_card
      all (fun u => -prob u) hcard k
  have hk_le_N : k ≤ N := le_trans (Nat.le_of_lt hk_rank) hrank_le
  rw [hrank_card, hk_card, min_eq_right hrank_le, min_eq_right hk_le_N]

/--
Every woman in the ranked tail is at least as popular as the target woman at
one-indexed rank `rank`.
-/
theorem im05_popularityRankTail_popular
    {W : Type*} [LinearOrder W] [DecidableEq W]
    (all : Finset W) (prob : W → ℝ) {N : ℕ}
    (hcard : all.card = N) {rank k : ℕ}
    (hrank_pos : 0 < rank) (hrank_le : rank ≤ N) :
    let targetIdx : Fin N :=
      ⟨rank - 1,
        Nat.lt_of_lt_of_le
          (Nat.sub_lt hrank_pos (Nat.succ_pos 0)) hrank_le⟩
    ∀ u ∈ im05_popularityRankTail all prob hcard rank k,
      prob (EconCSLib.FiniteRanking.rankAgentByValue
        all (fun v => -prob v) hcard targetIdx) ≤ prob u := by
  classical
  intro targetIdx u hu
  have hutop :
      u ∈ im05_popularityTopPrefix all prob hcard rank :=
    (Finset.mem_sdiff.mp hu).1
  unfold im05_popularityTopPrefix at hutop
  rcases Finset.mem_image.mp hutop with ⟨idx, hidx_mem, rfl⟩
  have hidx_lt_rank : idx.val < rank := (Finset.mem_filter.mp hidx_mem).2
  have hidx_le_target : idx.val ≤ targetIdx.val := by
    dsimp [targetIdx]
    omega
  rcases lt_or_eq_of_le hidx_le_target with hidx_lt_target | hidx_eq_target
  · have hmono :=
      EconCSLib.FiniteRanking.rankValueByValue_mono
        all (fun v => -prob v) hcard idx targetIdx hidx_lt_target
    rw [EconCSLib.FiniteRanking.rankValueByValue_eq_value
      all (fun v => -prob v) hcard idx] at hmono
    rw [EconCSLib.FiniteRanking.rankValueByValue_eq_value
      all (fun v => -prob v) hcard targetIdx] at hmono
    linarith
  · have hidx_eq : idx = targetIdx := Fin.ext hidx_eq_target
    simp [hidx_eq]

/--
Lemma 4.3 popularity-mass algebra: if a finite tail block lies outside the
first `k` women, has total probability at most `1 - Q`, and every member is at
least as popular as `w`, then `p_w <= (1-Q)/|tail|`.
-/
theorem paper_im05_lemma4_3_popularity_mass_bound_from_tail_set
    {W : Type*} (tail : Finset W) (prob : W → ℝ) (w : W) (Q : ℝ)
    (hcard_pos : 0 < tail.card)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u) :
    prob w ≤ (1 - Q) / (tail.card : ℝ) :=
  EconCSLib.FiniteSum.le_div_card_of_sum_le_of_forall_le
    tail prob hcard_pos hmass_tail_le hpopular

/--
Lemma 4.3 rank form of the popularity-mass algebra: if the relevant outside-top
tail has size `rank - k`, then `p_w <= (1-Q)/(rank-k)`.
-/
theorem paper_im05_lemma4_3_popularity_rank_bound
    {W : Type*} (tail : Finset W) (prob : W → ℝ) (w : W) (Q : ℝ)
    (rank k : ℕ)
    (hcard : tail.card = rank - k)
    (hk_rank : k < rank)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u) :
    prob w ≤ (1 - Q) / ((rank - k : ℕ) : ℝ) := by
  have hcard_pos : 0 < tail.card := by
    rw [hcard]
    exact Nat.sub_pos_of_lt hk_rank
  simpa [hcard] using
    paper_im05_lemma4_3_popularity_mass_bound_from_tail_set
      tail prob w Q hcard_pos hmass_tail_le hpopular

/--
Lemma 4.3 single-draw omission algebra: after conditioning on draws outside the
top block, the bound `p_w <= (1-Q)/denom` implies the source lower bound
`1 - p_w/(1-Q) >= 1 - 1/denom`.
-/
theorem paper_im05_lemma4_3_single_draw_omit_lower_bound
    {p Q denom : ℝ}
    (hQ_pos : 0 < 1 - Q)
    (hdenom_pos : 0 < denom)
    (hp : p ≤ (1 - Q) / denom) :
    1 - 1 / denom ≤ 1 - p / (1 - Q) := by
  have hdiv :
      p / (1 - Q) ≤ 1 / denom := by
    have h :=
      div_le_div_of_nonneg_right hp (le_of_lt hQ_pos)
    have hsimp : ((1 - Q) / denom) / (1 - Q) = 1 / denom := by
      field_simp [ne_of_gt hQ_pos, ne_of_gt hdenom_pos]
    simpa [hsimp] using h
  linarith

/--
Lemma 4.3 top-block domination algebra: if the previous-draw block injects
into the top block with weakly larger probabilities, then its total mass is at
most the top block's mass.
-/
theorem paper_im05_lemma4_3_previous_mass_le_top_mass_of_injection
    {W : Type*} [DecidableEq W]
    (previous top : Finset W) (prob : W → ℝ) (φ : W → W)
    (hφ_mem : ∀ u ∈ previous, φ u ∈ top)
    (hφ_inj : Set.InjOn φ (↑previous : Set W))
    (hprob_le : ∀ u ∈ previous, prob u ≤ prob (φ u))
    (htop_nonneg : ∀ u ∈ top, 0 ≤ prob u) :
    (∑ u ∈ previous, prob u) ≤ ∑ u ∈ top, prob u :=
  EconCSLib.FiniteSum.finset_sum_le_sum_of_injOn_nonneg
    previous top φ prob prob hφ_mem hφ_inj hprob_le htop_nonneg

/--
Lemma 4.3 top-mass wrapper: if the top block has total mass at most `Q`, the
previous-draw mass is also at most `Q`.
-/
theorem paper_im05_lemma4_3_previous_mass_le_Q_of_top_injection
    {W : Type*} [DecidableEq W]
    (previous top : Finset W) (prob : W → ℝ) (φ : W → W) (Q : ℝ)
    (hφ_mem : ∀ u ∈ previous, φ u ∈ top)
    (hφ_inj : Set.InjOn φ (↑previous : Set W))
    (hprob_le : ∀ u ∈ previous, prob u ≤ prob (φ u))
    (htop_nonneg : ∀ u ∈ top, 0 ≤ prob u)
    (htop_mass_le : (∑ u ∈ top, prob u) ≤ Q) :
    (∑ u ∈ previous, prob u) ≤ Q :=
  le_trans
    (paper_im05_lemma4_3_previous_mass_le_top_mass_of_injection
      previous top prob φ hφ_mem hφ_inj hprob_le htop_nonneg)
    htop_mass_le

/--
Lemma 4.3 top-block domination without an explicit injection: any realized
previous-draw set inside the ranked universe with cardinality at most the top
popularity prefix has mass at most that top prefix's mass.
-/
theorem paper_im05_lemma4_3_previous_mass_le_top_mass_of_card_le_top_prefix
    {W : Type*} [LinearOrder W] [DecidableEq W]
    (all previous : Finset W) (prob : W → ℝ) {N cut : ℕ}
    (hall_card : all.card = N)
    (hprevious_subset : previous ⊆ all)
    (hprevious_card :
      previous.card ≤ (im05_popularityTopPrefix all prob hall_card cut).card)
    (htop_nonneg : ∀ u ∈ im05_popularityTopPrefix all prob hall_card cut,
      0 ≤ prob u) :
    (∑ u ∈ previous, prob u) ≤
      ∑ u ∈ im05_popularityTopPrefix all prob hall_card cut, prob u := by
  classical
  let top := im05_popularityTopPrefix all prob hall_card cut
  refine
    EconCSLib.FiniteSum.finset_sum_le_sum_of_card_le_pairwise_sdiff
      previous top prob ?_ ?_ ?_
  · simpa [top] using hprevious_card
  · intro a ha b hb
    have ha_prev : a ∈ previous := (Finset.mem_sdiff.mp ha).1
    have ha_not_top : a ∉ top := (Finset.mem_sdiff.mp ha).2
    have hb_top : b ∈ top := (Finset.mem_sdiff.mp hb).1
    have ha_upper :
        a ∈ EconCSLib.FiniteRanking.upperRankFinset
          all (fun u => -prob u) hall_card cut := by
      rw [EconCSLib.FiniteRanking.upperRankFinset_eq_sdiff_lowerRankFinset]
      exact Finset.mem_sdiff.mpr
        ⟨hprevious_subset ha_prev, by simpa [top, im05_popularityTopPrefix] using ha_not_top⟩
    have hb_lower :
        b ∈ EconCSLib.FiniteRanking.lowerRankFinset
          all (fun u => -prob u) hall_card cut := by
      simpa [top, im05_popularityTopPrefix] using hb_top
    have hvalue :=
      EconCSLib.FiniteRanking.lowerRank_value_le_upperRank_value
        all (fun u => -prob u) hall_card cut a ha_upper b hb_lower
    linarith
  · intro b hb
    exact htop_nonneg b (by
      exact (Finset.mem_sdiff.mp hb).1)

/--
Lemma 4.3 top-mass wrapper from the ranked cardinal comparison: if the top
popularity prefix has mass at most `Q`, every no-larger realized prefix set has
mass at most `Q`.
-/
theorem paper_im05_lemma4_3_previous_mass_le_Q_of_card_le_top_prefix
    {W : Type*} [LinearOrder W] [DecidableEq W]
    (all previous : Finset W) (prob : W → ℝ) {N cut : ℕ}
    (hall_card : all.card = N) (Q : ℝ)
    (hprevious_subset : previous ⊆ all)
    (hprevious_card :
      previous.card ≤ (im05_popularityTopPrefix all prob hall_card cut).card)
    (htop_nonneg : ∀ u ∈ im05_popularityTopPrefix all prob hall_card cut,
      0 ≤ prob u)
    (htop_mass_le :
      (∑ u ∈ im05_popularityTopPrefix all prob hall_card cut, prob u) ≤ Q) :
    (∑ u ∈ previous, prob u) ≤ Q :=
  le_trans
    (paper_im05_lemma4_3_previous_mass_le_top_mass_of_card_le_top_prefix
      all previous prob hall_card hprevious_subset hprevious_card htop_nonneg)
    htop_mass_le

/--
Concrete realized-prefix mass bound for Algorithm 4.2-style distinct lists:
from any positive-probability exact prefix-set state, distinctness of the list
and membership in the ranked universe imply the previous mass is bounded by the
top-`k` popularity mass.
-/
theorem paper_im05_lemma4_3_realized_prefixSet_mass_le_Q_of_top_prefix
    {Λ W : Type*} [Fintype Λ] [DecidableEq Λ]
    [LinearOrder W] [DecidableEq W]
    {k N r : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    (all : Finset W) (hall_card : all.card = N)
    (prob : W → ℝ) (Q : ℝ)
    [DecidablePred fun sample => im05_listPrefixOmits w r (draw sample)]
    (hdraw_mem : ∀ sample slot, draw sample slot ∈ all)
    (hinj : ∀ sample, Function.Injective (draw sample))
    (hk_le_N : k ≤ N)
    (htop_nonneg : ∀ u ∈ im05_popularityTopPrefix all prob hall_card k,
      0 ≤ prob u)
    (htop_mass_le :
      (∑ u ∈ im05_popularityTopPrefix all prob hall_card k, prob u) ≤ Q)
    (previous : Finset W)
    (hspos :
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧
            im05_listPrefixSet r (draw sample) = previous)) :
    (∑ u ∈ previous, prob u) ≤ Q := by
  classical
  rcases
    (EconCSLib.pmfProb_pos_iff_exists_pos_mass ν
      (fun sample =>
        im05_listPrefixOmits w r (draw sample) ∧
          im05_listPrefixSet r (draw sample) = previous)).1 hspos
    with ⟨sample, hsample, _hmass⟩
  have hprev_eq : previous = im05_listPrefixSet r (draw sample) := hsample.2.symm
  have hprev_subset : previous ⊆ all := by
    intro u hu
    rw [hprev_eq] at hu
    exact im05_listPrefixSet_subset_of_forall_mem
      all (draw sample) (hdraw_mem sample) hu
  have htop_card :
      (im05_popularityTopPrefix all prob hall_card k).card = k := by
    unfold im05_popularityTopPrefix
    rw [EconCSLib.FiniteRanking.lowerRankFinset_card]
    exact min_eq_right hk_le_N
  have hprev_card :
      previous.card ≤ (im05_popularityTopPrefix all prob hall_card k).card := by
    rw [hprev_eq, htop_card]
    rw [im05_listPrefixSet_card_of_injective (draw sample) (hinj sample)]
    exact min_le_left k r
  exact
    paper_im05_lemma4_3_previous_mass_le_Q_of_card_le_top_prefix
      all previous prob hall_card Q hprev_subset hprev_card
      htop_nonneg htop_mass_le

/--
Positive-support version of the realized-prefix mass bound.  This is the form
needed when a concrete sampler is represented on a larger function space whose
invalid atoms have zero probability.
-/
theorem paper_im05_lemma4_3_realized_prefixSet_mass_le_Q_of_top_prefix_of_pos_support
    {Λ W : Type*} [Fintype Λ] [DecidableEq Λ]
    [LinearOrder W] [DecidableEq W]
    {k N r : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    (all : Finset W) (hall_card : all.card = N)
    (prob : W → ℝ) (Q : ℝ)
    [DecidablePred fun sample => im05_listPrefixOmits w r (draw sample)]
    (hdraw_mem : ∀ sample, 0 < (ν sample).toReal →
      ∀ slot, draw sample slot ∈ all)
    (hinj : ∀ sample, 0 < (ν sample).toReal →
      Function.Injective (draw sample))
    (hk_le_N : k ≤ N)
    (htop_nonneg : ∀ u ∈ im05_popularityTopPrefix all prob hall_card k,
      0 ≤ prob u)
    (htop_mass_le :
      (∑ u ∈ im05_popularityTopPrefix all prob hall_card k, prob u) ≤ Q)
    (previous : Finset W)
    (hspos :
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧
            im05_listPrefixSet r (draw sample) = previous)) :
    (∑ u ∈ previous, prob u) ≤ Q := by
  classical
  rcases
    (EconCSLib.pmfProb_pos_iff_exists_pos_mass ν
      (fun sample =>
        im05_listPrefixOmits w r (draw sample) ∧
          im05_listPrefixSet r (draw sample) = previous)).1 hspos
    with ⟨sample, hsample, hmass⟩
  have hprev_eq : previous = im05_listPrefixSet r (draw sample) := hsample.2.symm
  have hprev_subset : previous ⊆ all := by
    intro u hu
    rw [hprev_eq] at hu
    exact im05_listPrefixSet_subset_of_forall_mem
      all (draw sample) (hdraw_mem sample hmass) hu
  have htop_card :
      (im05_popularityTopPrefix all prob hall_card k).card = k := by
    unfold im05_popularityTopPrefix
    rw [EconCSLib.FiniteRanking.lowerRankFinset_card]
    exact min_eq_right hk_le_N
  have hprev_card :
      previous.card ≤ (im05_popularityTopPrefix all prob hall_card k).card := by
    rw [hprev_eq, htop_card]
    rw [im05_listPrefixSet_card_of_injective
      (draw sample) (hinj sample hmass)]
    exact min_le_left k r
  exact
    paper_im05_lemma4_3_previous_mass_le_Q_of_card_le_top_prefix
      all previous prob hall_card Q hprev_subset hprev_card
      htop_nonneg htop_mass_le

/--
Lemma 4.3 conditional-denominator algebra: if the mass of the already drawn
women is at most `Q`, then the conditional probability of omitting `w` at the
next draw is at least the denominator-`1-Q` lower bound used in the source.
-/
theorem paper_im05_lemma4_3_conditional_omit_ge_top_mass_bound
    {p prevMass Q : ℝ}
    (hp_nonneg : 0 ≤ p)
    (hprev_le_Q : prevMass ≤ Q)
    (hQ_pos : 0 < 1 - Q) :
    1 - p / (1 - Q) ≤ 1 - p / (1 - prevMass) := by
  have hden_le : 1 - Q ≤ 1 - prevMass := by linarith
  have hfrac :
      p / (1 - prevMass) ≤ p / (1 - Q) :=
    div_le_div_of_nonneg_left hp_nonneg hQ_pos hden_le
  linarith

/--
Lemma 4.3 rank-specialized single-draw omission algebra, combining the
popularity/rank mass bound with the conditional draw denominator.
-/
theorem paper_im05_lemma4_3_single_draw_omit_lower_bound_from_rank_tail
    {W : Type*} (tail : Finset W) (prob : W → ℝ) (w : W) (Q : ℝ)
    (rank k : ℕ)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (hk_rank : k < rank)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u) :
    1 - 1 / ((rank - k : ℕ) : ℝ) ≤
      1 - prob w / (1 - Q) := by
  have hdenom_pos : 0 < ((rank - k : ℕ) : ℝ) := by
    exact_mod_cast (Nat.sub_pos_of_lt hk_rank)
  exact
    paper_im05_lemma4_3_single_draw_omit_lower_bound
      hQ_pos hdenom_pos
      (paper_im05_lemma4_3_popularity_rank_bound
        tail prob w Q rank k hcard hk_rank hmass_tail_le hpopular)

/--
Lemma 4.3 full one-step omission algebra: combine the source's
previous-draw-mass bound with the popularity/rank bound to get the
`1 - 1/(rank-k)` lower bound for a conditional draw.
-/
theorem paper_im05_lemma4_3_conditional_single_draw_omit_lower_bound_from_rank_tail
    {W : Type*} (tail : Finset W) (prob : W → ℝ) (w : W)
    (Q prevMass : ℝ) (rank k : ℕ)
    (hp_nonneg : 0 ≤ prob w)
    (hprev_le_Q : prevMass ≤ Q)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (hk_rank : k < rank)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u) :
    1 - 1 / ((rank - k : ℕ) : ℝ) ≤
      1 - prob w / (1 - prevMass) := by
  exact le_trans
    (paper_im05_lemma4_3_single_draw_omit_lower_bound_from_rank_tail
      tail prob w Q rank k hQ_pos hcard hk_rank hmass_tail_le hpopular)
    (paper_im05_lemma4_3_conditional_omit_ge_top_mass_bound
      hp_nonneg hprev_le_Q hQ_pos)

/--
Lemma 4.3 next-hit upper-bound algebra: the same popularity/rank and
previous-mass hypotheses imply that the conditional probability of hitting `w`
at the next draw, when it has formula `p_w/(1-prevMass)`, is at most
`1/(rank-k)`.
-/
theorem paper_im05_lemma4_3_next_hit_upper_bound_from_rank_tail
    {W : Type*} (tail : Finset W) (prob : W → ℝ) (w : W)
    (Q prevMass : ℝ) (rank k : ℕ)
    (hp_nonneg : 0 ≤ prob w)
    (hprev_le_Q : prevMass ≤ Q)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (hk_rank : k < rank)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u) :
    prob w / (1 - prevMass) ≤
      1 / ((rank - k : ℕ) : ℝ) := by
  have homit :
      1 - 1 / ((rank - k : ℕ) : ℝ) ≤
        1 - prob w / (1 - prevMass) :=
    paper_im05_lemma4_3_conditional_single_draw_omit_lower_bound_from_rank_tail
      tail prob w Q prevMass rank k hp_nonneg hprev_le_Q hQ_pos
      hcard hk_rank hmass_tail_le hpopular
  linarith

/--
Lemma 4.3 next-hit formula wrapper: once Algorithm 4.2 supplies the filtered
without-replacement formula for the next-hit conditional probability, the
rank-tail algebra gives the `1/(rank-k)` upper bound needed by the prefix
product route.
-/
theorem paper_im05_lemma4_3_conditional_next_hit_le_from_rank_tail_formula
    {W : Type*} (tail : Finset W) (prob : W → ℝ) (w : W)
    (Q prevMass hitProb : ℝ) (rank k : ℕ)
    (hp_nonneg : 0 ≤ prob w)
    (hprev_le_Q : prevMass ≤ Q)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (hk_rank : k < rank)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u)
    (hhit_formula : hitProb = prob w / (1 - prevMass)) :
    hitProb ≤ 1 / ((rank - k : ℕ) : ℝ) := by
  rw [hhit_formula]
  exact
    paper_im05_lemma4_3_next_hit_upper_bound_from_rank_tail
      tail prob w Q prevMass rank k hp_nonneg hprev_le_Q hQ_pos
      hcard hk_rank hmass_tail_le hpopular

/--
Algorithm 4.2 one-step filtered-draw law: after deleting the already drawn
women, the next draw assigns atom probability `p_w / (1 - prevMass)` to any
not-yet-drawn woman `w`, when the original probabilities sum to one.
-/
theorem paper_im05_algorithm4_2_filtered_draw_atom_formula
    {W : Type*} [Fintype W] [DecidableEq W]
    (prob : W → ℝ) (previous : Finset W) (w : W) (prevMass : ℝ)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_sum : ∑ u : W, prob u = 1)
    (hprevMass : prevMass = ∑ u ∈ previous, prob u)
    (havailable_pos : 0 < EconCSLib.finiteAvailableWeight prob previous)
    (hw_not_previous : w ∉ previous) :
    (EconCSLib.finiteWeightedPMFExcluding
        prob previous hprob_nonneg havailable_pos w).toReal =
      prob w / (1 - prevMass) :=
  EconCSLib.finiteWeightedPMFExcluding_apply_toReal_eq_div_one_sub
    prob previous prevMass hprob_nonneg hprob_sum hprevMass
    havailable_pos hw_not_previous

/--
Concrete Algorithm 4.2 first-draw atom formula for the recursive fresh-list
sampler: before any woman has been drawn, the first slot has the base
distribution.
-/
theorem paper_im05_algorithm4_2_freshList_first_draw_atom_formula
    {W : Type*} [Fintype W] [DecidableEq W]
    (prob : W → ℝ)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_sum : ∑ u : W, prob u = 1)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    {k : ℕ} (hk_le_card : k + 1 ≤ Fintype.card W) (w : W) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
          (k + 1) hk_le_card)
        (fun sample =>
          im05_algorithm42FreshListDraw sample ⟨0, Nat.succ_pos k⟩ = w) =
      prob w := by
  classical
  rw [im05_algorithm42FreshListPMF]
  change EconCSLib.pmfProb
      (EconCSLib.finiteWithoutReplacementPMF
        prob hprob_nonneg havailable (k + 1) (∅ : Finset W) _)
      (fun sample => sample.1 ⟨0, Nat.succ_pos k⟩ = w) = prob w
  rw [EconCSLib.finiteWithoutReplacementPMF_head_prob
    (head₀ := ⟨w, by simp⟩)]
  rw [EconCSLib.finiteWeightedPMFAvailable_apply_toReal]
  have havail_empty :
      EconCSLib.finiteAvailableWeight prob (∅ : Finset W) = 1 := by
    rw [EconCSLib.finiteAvailableWeight_eq_one_sub_forbidden_mass
      prob (∅ : Finset W) (0 : ℝ) hprob_sum (by simp)]
    norm_num
  rw [havail_empty]
  ring

/--
Concrete Algorithm 4.2 zero-prefix conditional atom formula.  This is the
base case of the statewise filtered-draw law: conditioning on the empty prefix
does not change the first-slot distribution.
-/
theorem paper_im05_algorithm4_2_freshList_zero_prefix_conditional_atom_formula
    {W : Type*} [Fintype W] [DecidableEq W]
    (prob : W → ℝ)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_sum : ∑ u : W, prob u = 1)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    {k : ℕ} (hk_le_card : k + 1 ≤ Fintype.card W) (w : W)
    [DecidablePred fun sample : im05_algorithm42FreshListSample W (k + 1) =>
      im05_listPrefixOmits w 0 (im05_algorithm42FreshListDraw sample) ∧
        im05_listPrefixSet 0 (im05_algorithm42FreshListDraw sample) =
          (∅ : Finset W)] :
    EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
          (k + 1) hk_le_card)
        (fun sample =>
          im05_listPrefixOmits w 0 (im05_algorithm42FreshListDraw sample) ∧
            im05_listPrefixSet 0 (im05_algorithm42FreshListDraw sample) =
              (∅ : Finset W))
        (fun sample =>
          im05_algorithm42FreshListDraw sample ⟨0, Nat.succ_pos k⟩ = w) =
      prob w := by
  classical
  rw [EconCSLib.pmfConditionalProb_eq_pmfProb_of_forall_condition]
  · exact
      paper_im05_algorithm4_2_freshList_first_draw_atom_formula
        prob hprob_nonneg hprob_sum havailable hk_le_card w
  · intro sample
    simp

/--
Concrete Algorithm 4.2 prefix-set conditional atom formula.  Given a positive
probability realized prefix set, the next slot is distributed as the filtered
weighted draw after deleting that set.
-/
theorem paper_im05_algorithm4_2_freshList_prefixSet_conditional_atom_formula
    {W : Type*} [Fintype W] [DecidableEq W]
    (prob : W → ℝ)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    {k r : ℕ} (hr : r < k) (hk_le_card : k ≤ Fintype.card W)
    (previous : Finset W) (w : W)
    (hstate_pos :
      0 < EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
          k hk_le_card)
        (fun sample =>
          im05_listPrefixSet r (im05_algorithm42FreshListDraw sample) =
            previous))
    (havailable_pos :
      0 < EconCSLib.finiteAvailableWeight prob previous) :
    EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
          k hk_le_card)
        (fun sample =>
          im05_listPrefixSet r (im05_algorithm42FreshListDraw sample) =
            previous)
        (fun sample => im05_algorithm42FreshListDraw sample ⟨r, hr⟩ = w) =
      (EconCSLib.finiteWeightedPMFExcluding
        prob previous hprob_nonneg havailable_pos w).toReal := by
  classical
  have hk_len : k = k - (r + 1) + r + 1 := by
    omega
  simpa [im05_algorithm42FreshListPMF, im05_algorithm42FreshListDraw,
    im05_listPrefixSet, EconCSLib.finiteFreshListPrefixSet] using
    (EconCSLib.finiteWithoutReplacementPMF_prefixSet_conditional_next_prob_excluding_of_length
      prob hprob_nonneg havailable
      r (k - (r + 1)) k (∅ : Finset W) previous
      hr hk_len
      (hbudget := by
        simpa using hk_le_card)
      (hstate_pos := by
        simpa [im05_algorithm42FreshListPMF, im05_algorithm42FreshListDraw,
          im05_listPrefixSet, EconCSLib.finiteFreshListPrefixSet]
          using hstate_pos)
      (havailable_previous := by
        simpa using havailable_pos)
      w)

/--
Concrete Algorithm 4.2 prefix-set atom formula in the exact form used by Lemma
4.3: the extra prefix-omission conjunct is redundant on any positive realized
state with the same prefix set.
-/
theorem paper_im05_algorithm4_2_freshList_prefixSet_omit_conditional_atom_formula
    {W : Type*} [Fintype W] [DecidableEq W]
    (prob : W → ℝ)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    {k r : ℕ} (hr : r < k) (hk_le_card : k ≤ Fintype.card W)
    (previous : Finset W) (w : W)
    [DecidablePred fun sample : im05_algorithm42FreshListSample W k =>
      im05_listPrefixOmits w r (im05_algorithm42FreshListDraw sample) ∧
        im05_listPrefixSet r (im05_algorithm42FreshListDraw sample) =
          previous]
    (hspos :
      0 < EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
          k hk_le_card)
        (fun sample =>
          im05_listPrefixOmits w r (im05_algorithm42FreshListDraw sample) ∧
            im05_listPrefixSet r (im05_algorithm42FreshListDraw sample) =
              previous))
    (havailable_pos :
      0 < EconCSLib.finiteAvailableWeight prob previous) :
    EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
          k hk_le_card)
        (fun sample =>
          im05_listPrefixOmits w r (im05_algorithm42FreshListDraw sample) ∧
            im05_listPrefixSet r (im05_algorithm42FreshListDraw sample) =
              previous)
        (fun sample => im05_algorithm42FreshListDraw sample ⟨r, hr⟩ = w) =
      (EconCSLib.finiteWeightedPMFExcluding
        prob previous hprob_nonneg havailable_pos w).toReal := by
  classical
  let ν := im05_algorithm42FreshListPMF prob hprob_nonneg havailable
    k hk_le_card
  let draw : im05_algorithm42FreshListSample W k → Fin k → W :=
    im05_algorithm42FreshListDraw
  have hw_not_previous : w ∉ previous := by
    rcases
      (EconCSLib.pmfProb_pos_iff_exists_pos_mass ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧
            im05_listPrefixSet r (draw sample) = previous)).1 hspos with
      ⟨sample, hsample, _hmass⟩
    have hnot :
        w ∉ im05_listPrefixSet r (draw sample) :=
      (im05_listPrefixOmits_iff_not_mem_prefixSet w (draw sample)).1
        hsample.1
    simpa [hsample.2] using hnot
  have hprefix_pos :
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixSet r (draw sample) = previous) := by
    rcases
      (EconCSLib.pmfProb_pos_iff_exists_pos_mass ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧
            im05_listPrefixSet r (draw sample) = previous)).1 hspos with
      ⟨sample, hsample, hmass⟩
    exact (EconCSLib.pmfProb_pos_iff_exists_pos_mass ν
      (fun sample => im05_listPrefixSet r (draw sample) = previous)).2
      ⟨sample, hsample.2, hmass⟩
  have hcond_congr :
      EconCSLib.pmfConditionalProb ν
          (fun sample =>
            im05_listPrefixOmits w r (draw sample) ∧
              im05_listPrefixSet r (draw sample) = previous)
          (fun sample => draw sample ⟨r, hr⟩ = w) =
        EconCSLib.pmfConditionalProb ν
          (fun sample => im05_listPrefixSet r (draw sample) = previous)
          (fun sample => draw sample ⟨r, hr⟩ = w) := by
    exact EconCSLib.pmfConditionalProb_congr ν
      (fun sample =>
        im05_listPrefixOmits w r (draw sample) ∧
          im05_listPrefixSet r (draw sample) = previous)
      (fun sample => im05_listPrefixSet r (draw sample) = previous)
      (fun sample => draw sample ⟨r, hr⟩ = w)
      (fun sample => draw sample ⟨r, hr⟩ = w)
      (by
        intro sample
        constructor
        · intro hsample
          exact hsample.2
        · intro hprefix
          constructor
          · exact
              (im05_listPrefixOmits_iff_not_mem_prefixSet w (draw sample)).2
                (by simpa [hprefix] using hw_not_previous)
          · exact hprefix)
      (by intro sample _hcondition; rfl)
  rw [hcond_congr]
  exact
    paper_im05_algorithm4_2_freshList_prefixSet_conditional_atom_formula
      prob hprob_nonneg havailable hr hk_le_card previous w
      hprefix_pos havailable_pos

/--
Concrete Algorithm 4.2 omission positivity: under full support and `k < #W`,
a fixed woman is omitted by the whole length-`k` fresh list with positive
probability.
-/
theorem paper_im05_algorithm4_2_freshList_omit_pos_of_full_support
    {W : Type*} [Fintype W] [DecidableEq W]
    (prob : W → ℝ)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_pos : ∀ u, 0 < prob u)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    {k : ℕ} (hk_le_card : k ≤ Fintype.card W)
    (hk_lt_card : k < Fintype.card W) (w : W)
    [DecidablePred fun sample : im05_algorithm42FreshListSample W k =>
      im05_listPrefixOmits w k (im05_algorithm42FreshListDraw sample)] :
    0 < EconCSLib.pmfProb
      (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
        k hk_le_card)
      (fun sample =>
        im05_listPrefixOmits w k
          (im05_algorithm42FreshListDraw sample)) := by
  classical
  simpa [im05_algorithm42FreshListPMF, im05_algorithm42FreshListDraw,
    im05_listPrefixOmits] using
    (EconCSLib.finiteWithoutReplacementPMF_omit_atom_pos
      prob hprob_nonneg hprob_pos havailable
      (∅ : Finset W) (by simpa using hk_le_card) w
      (by simp) (by simpa using hk_lt_card))

/--
Concrete Algorithm 4.2 prefix-omission positivity. Full-list omission is a
positive-mass subevent of every prefix-omission event.
-/
theorem paper_im05_algorithm4_2_freshList_prefix_omit_pos_of_full_support
    {W : Type*} [Fintype W] [DecidableEq W]
    (prob : W → ℝ)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_pos : ∀ u, 0 < prob u)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    {k : ℕ} (hk_le_card : k ≤ Fintype.card W)
    (hk_lt_card : k < Fintype.card W) (w : W) (r : ℕ)
    [DecidablePred fun sample : im05_algorithm42FreshListSample W k =>
      im05_listPrefixOmits w k (im05_algorithm42FreshListDraw sample)]
    [DecidablePred fun sample : im05_algorithm42FreshListSample W k =>
      im05_listPrefixOmits w r (im05_algorithm42FreshListDraw sample)] :
    0 < EconCSLib.pmfProb
      (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
        k hk_le_card)
      (fun sample =>
        im05_listPrefixOmits w r
          (im05_algorithm42FreshListDraw sample)) := by
  classical
  let ν := im05_algorithm42FreshListPMF prob hprob_nonneg havailable
    k hk_le_card
  let fullEvent : im05_algorithm42FreshListSample W k → Prop :=
    fun sample =>
      im05_listPrefixOmits w k (im05_algorithm42FreshListDraw sample)
  let prefixEvent : im05_algorithm42FreshListSample W k → Prop :=
    fun sample =>
      im05_listPrefixOmits w r (im05_algorithm42FreshListDraw sample)
  have hfull_pos : 0 < EconCSLib.pmfProb ν fullEvent := by
    simpa [ν, fullEvent] using
      paper_im05_algorithm4_2_freshList_omit_pos_of_full_support
        prob hprob_nonneg hprob_pos havailable hk_le_card hk_lt_card w
  have hle : EconCSLib.pmfProb ν fullEvent ≤
      EconCSLib.pmfProb ν prefixEvent := by
    refine EconCSLib.pmfProb_le_of_imp ν fullEvent prefixEvent ?_
    intro sample hfull slot hslot_lt
    exact hfull slot slot.isLt
  exact lt_of_lt_of_le hfull_pos (by simpa [ν, prefixEvent] using hle)

/--
Algorithm 4.2 event probabilities are continuous under pointwise convergence
of the finite weight vector.  This is the paper-level wrapper around the
library atom-sum continuity theorem for fresh lists.
-/
theorem paper_im05_algorithm4_2_freshList_event_prob_tendsto
    {W : Type*} [Fintype W] [DecidableEq W]
    (weightSeq : ℕ → W → ℝ) (prob : W → ℝ)
    (hseq_nonneg : ∀ scale u, 0 ≤ weightSeq scale u)
    (hseq_available : ∀ scale, ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight (weightSeq scale) forbidden)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    (hweight : ∀ u : W,
      Filter.Tendsto (fun scale : ℕ => weightSeq scale u)
        Filter.atTop (nhds (prob u)))
    {k : ℕ} (hk_le_card : k ≤ Fintype.card W)
    (event : im05_algorithm42FreshListSample W k → Prop)
    [DecidablePred event] :
    Filter.Tendsto
      (fun scale : ℕ =>
        EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF
            (weightSeq scale) (hseq_nonneg scale)
            (hseq_available scale) k hk_le_card)
          event)
      Filter.atTop
      (nhds
        (EconCSLib.pmfProb
          (im05_algorithm42FreshListPMF
            prob hprob_nonneg havailable k hk_le_card)
          event)) := by
  classical
  simpa [im05_algorithm42FreshListPMF] using
    (EconCSLib.finiteWithoutReplacementPMF_event_prob_tendsto
      weightSeq prob hseq_nonneg hseq_available
      hprob_nonneg havailable hweight
      (∅ : Finset W) (by simpa using hk_le_card) event)

/--
Algorithm 4.2 marginal omission probability convergence, specialized to the
one-man events used in Lemma 4.4.
-/
theorem paper_im05_algorithm4_2_freshList_omit_prob_tendsto
    {W : Type*} [Fintype W] [DecidableEq W]
    (weightSeq : ℕ → W → ℝ) (prob : W → ℝ)
    (hseq_nonneg : ∀ scale u, 0 ≤ weightSeq scale u)
    (hseq_available : ∀ scale, ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight (weightSeq scale) forbidden)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    (hweight : ∀ u : W,
      Filter.Tendsto (fun scale : ℕ => weightSeq scale u)
        Filter.atTop (nhds (prob u)))
    {k : ℕ} (hk_le_card : k ≤ Fintype.card W) (w : W)
    [DecidablePred fun sample : im05_algorithm42FreshListSample W k =>
