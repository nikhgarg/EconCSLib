theorem im05_algorithm41SourceDivorceTargetStateAfterSteps_m_proposals_subset_of_le
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    {steps later : ℕ} (hle : steps ≤ later) (m : M) :
    (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g later).m_proposals m ⊆
      (im05_algorithm41SourceDivorceTargetStateAfterSteps val_m val_w g steps).m_proposals m := by
  obtain ⟨d, rfl⟩ := Nat.exists_eq_add_of_le hle
  induction d with
  | zero =>
      intro w hmem
      simpa using hmem
  | succ d ih =>
      intro w hmem
      have hmid :
          w ∈
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g (steps + d)).m_proposals m := by
        have hmem_succ :
            w ∈
              (im05_algorithm41SourceDivorceTargetStateAfterSteps
                val_m val_w g ((steps + d) + 1)).m_proposals m := by
          simpa [Nat.add_assoc] using hmem
        exact
          im05_algorithm41SourceStepDivorceTarget_m_proposals_subset
            val_m val_w g
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g (steps + d)) m
            (by
              simpa [im05_algorithm41SourceDivorceTargetStateAfterSteps_succ]
                using hmem_succ)
      exact ih (Nat.le_add_right steps d) hmid

theorem im05_algorithm41SourceDivorceTargetStateAfterSteps_removed_proposal_exists_chosen
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    {steps : ℕ} {m : M} {w : W}
    (hstart :
      w ∈ (im05_algorithm41DivorcedState val_m val_w g).m_proposals m)
    (hend :
      w ∉ (im05_algorithm41SourceDivorceTargetStateAfterSteps
        val_m val_w g steps).m_proposals m) :
    ∃ t : ℕ,
      t < steps ∧
        ∃ hactive :
          ∃ a, IsActiveMan val_m
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) a,
          daStepChosenMan val_m
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) hactive = m ∧
            daStepChosenWoman val_m
              (im05_algorithm41SourceDivorceTargetStateAfterSteps
                val_m val_w g t) hactive = w := by
  induction steps with
  | zero =>
      exact False.elim (hend (by simpa using hstart))
  | succ steps ih =>
      by_cases hprev :
          w ∈
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g steps).m_proposals m
      · have hnotNext :
            w ∉
              (im05_algorithm41SourceStepDivorceTarget val_m val_w g
                (im05_algorithm41SourceDivorceTargetStateAfterSteps
                  val_m val_w g steps)).m_proposals m := by
          simpa [im05_algorithm41SourceDivorceTargetStateAfterSteps_succ]
            using hend
        rcases
          im05_algorithm41SourceStepDivorceTarget_removed_proposal_eq_chosen
            val_m val_w g
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g steps) hprev hnotNext with
          ⟨hactive, hchosen, hwoman⟩
        exact ⟨steps, Nat.lt_succ_self steps, hactive, hchosen, hwoman⟩
      · rcases ih hprev with ⟨t, ht, hactive, hchosen, hwoman⟩
        exact ⟨t, Nat.lt_trans ht (Nat.lt_succ_self steps), hactive,
          hchosen, hwoman⟩

