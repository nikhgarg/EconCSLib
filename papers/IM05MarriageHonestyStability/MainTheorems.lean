  have hstable : IsStable val_m val_w mu := by
    simpa [mu] using da_produces_stable_matching val_m val_w
  simp [im05_stableHusbands]
  refine ⟨mu, hstable, ?_⟩
  simpa [mu, deferredAcceptance, im05_algorithm41InitialHusband] using hinit

