-/
theorem paper_im05_lemma4_1_from_tail_negative_correlation_and_lemma4_3
    {Ω I : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype I] [DecidableEq I]
    (μ : PMF Ω) (tail : Finset I) (event : I → Ω → Prop) (X : Ω → ℕ)
    [∀ ω, DecidablePred fun i => event i ω]
    [∀ i, DecidablePred fun ω => event i ω]
    (g n k : ℕ) (hg : 0 < g)
    (hEY_lower :
      (g : ℝ) / 2 *
          Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤
        EconCSLib.pmfExp μ
          (fun ω =>
            ((tail.filter fun i => event i ω).card : ℝ)))
    (hXY : ∀ ω,
      (tail.filter fun i => event i ω).card ≤ X ω)
    (hneg : ∀ i ∈ tail, ∀ j ∈ tail, i ≠ j →
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) ≤
