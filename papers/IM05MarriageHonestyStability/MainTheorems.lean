      (steps.foldl (fun s _ => im05_algorithm41SourceStep val_m val_w s) s) := by
  induction steps generalizing s with
  | nil =>
      simpa using hinv
  | cons _ steps ih =>
      simp [List.foldl_cons]
      exact ih (im05_algorithm41SourceStep val_m val_w s)
        (im05_algorithm41SourceStep_preserves_manIRInvariant val_m val_w s hinv)

