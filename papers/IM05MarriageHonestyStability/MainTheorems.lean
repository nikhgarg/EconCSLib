/--
If a non-exceptional woman accepts proposer `a` over `cur`, then `cur` cannot
be her partner in a stable matching, provided the blocking proposer `a` is not
matched to the exceptional target in that stable matching.
-/
theorem im05_accepted_proposer_blocks_displaced_match_except_exception
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (exception : W) (mu : Assignment M W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s exception)
    (hstable : im05_stable_matching val_m val_w mu)
    {a cur : M} {w : W}
    (hw_ne_exception : w ≠ exception)
    (hact : IsActiveMan val_m s a)
    (hwbest : BestRemainingWoman val_m s a w)
    (hwomanPref : val_w w cur < val_w w a)
    (ha_not_exception : mu.m_match a ≠ some exception) :
    mu.m_match cur ≠ some w := by
  intro hcurw
  have hw_mu : mu.w_match w = some cur := (mu.consistent_m cur w).1 hcurw
  have hne : a ≠ cur := by
    intro h
    subst cur
    exact (lt_irrefl (val_w w a)) hwomanPref
  have hmanPref : valM val_m a (mu.m_match a) < val_m a w := by
    cases ha_mu : mu.m_match a with
    | none =>
        simpa [valM, ha_mu] using hacceptable.1 a w
    | some wmu =>
        have hwmu_ne_w : wmu ≠ w := by
          intro hw
          subst wmu
          have hw_a : mu.w_match w = some a :=
            (mu.consistent_m a w).1 ha_mu
          exact hne (Option.some.inj (hw_a.symm.trans hw_mu))
        by_cases hle : val_m a wmu ≤ val_m a w
        · have hneq : val_m a wmu ≠ val_m a w := by
            intro heq
            exact hwmu_ne_w (hstrictM a wmu w heq)
          exact lt_of_le_of_ne hle hneq
        · have hbetter : val_m a w < val_m a wmu := lt_of_not_ge hle
          have hnotRemaining : wmu ∉ s.m_proposals a :=
            better_than_best_not_remaining val_m s hacceptable.1 hwbest
              wmu hbetter
          have hnotCurrent : s.m_match a ≠ some wmu := by
            intro hmatch
            rw [hact.1] at hmatch
            cases hmatch
          have hwmu_ne_exception : wmu ≠ exception := by
            intro hw
            subst wmu
            exact ha_not_exception ha_mu
          exact False.elim
            (hrejected mu hstable a wmu hwmu_ne_exception hnotRemaining
              hnotCurrent ha_mu)
  have hwomanPref' : valW val_w w (mu.w_match w) < val_w w a := by
    simpa [valW, hw_mu] using hwomanPref
  exact hstable.2.2 a w hmanPref hwomanPref'

/--
If the source history rule rejects `b` at the target and every better prior
proposer would prefer the target to his partner in any stable matching that
matches the target to `b`, then `b` is not a stable husband of the target.
-/
theorem im05_history_reject_not_mem_stableHusbands_of_prior_blockers
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W) (b : M)
    (hreject : ¬ im05_algorithm41HistoryAccepts val_w s target b)
    (hprior_block :
      ∀ (mu : Assignment M W),
        im05_stable_matching val_m val_w mu →
          mu.w_match target = some b →
            ∀ r : M,
              im05_algorithm41HasProposedTo s r target →
                val_w target b < val_w target r →
                  valM val_m r (mu.m_match r) < val_m r target) :
    b ∉ im05_stableHusbands val_m val_w target := by
  classical
  intro hb
  rcases (by simpa [im05_stableHusbands] using hb) with
    ⟨mu, hstable, hmu_target⟩
  have hnot : ¬ ∀ r : M,
      im05_algorithm41HasProposedTo s r target →
        ¬ val_w target b < val_w target r := by
    simpa [im05_algorithm41HistoryAccepts] using hreject
  push Not at hnot
  rcases hnot with ⟨r, hr_proposed, htarget_prefers_r⟩
  exact
    im05_prior_better_proposer_blocks_stable_target_match
      val_m val_w target hstable hmu_target
      (hprior_block mu hstable hmu_target r hr_proposed htarget_prefers_r)
      htarget_prefers_r

/--
Rejected-pair-impossibility form of the target-rejection exclusion bridge.
This is the main local lemma needed for Algorithm 4.1's backward inclusion.
-/
theorem im05_history_reject_not_mem_stableHusbands_of_rejected_pair_impossible
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W) (b : M)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejectedImpossible : DARejectedPairImpossibleInvariant val_m val_w s)
    (hreject : ¬ im05_algorithm41HistoryAccepts val_w s target b) :
    b ∉ im05_stableHusbands val_m val_w target := by
  exact
    im05_history_reject_not_mem_stableHusbands_of_prior_blockers
      val_m val_w s target b hreject
      (fun mu hstable hmu_target r hr_proposed htarget_prefers_r =>
        im05_prior_proposer_prefers_target_in_stable_match
          val_m val_w s target hstrictM hacceptable hproposalOrder hmatchOrder
          hrejectedImpossible hstable hmu_target hr_proposed htarget_prefers_r)

/--
Target-exception rejected-pair-impossibility form of the target-rejection
exclusion bridge.
-/
theorem im05_history_reject_not_mem_stableHusbands_of_rejected_pair_impossible_except_target
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W) (b : M)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s target)
    (hreject : ¬ im05_algorithm41HistoryAccepts val_w s target b) :
    b ∉ im05_stableHusbands val_m val_w target := by
  exact
    im05_history_reject_not_mem_stableHusbands_of_prior_blockers
      val_m val_w s target b hreject
      (fun mu hstable hmu_target r hr_proposed htarget_prefers_r =>
        im05_prior_proposer_prefers_target_in_stable_match_except_target
          val_m val_w s target hstrictM hacceptable hproposalOrder hmatchOrder
          hrejected hstable hmu_target hr_proposed htarget_prefers_r)

/--
History rejection at a non-exceptional woman excludes the rejected man from her
stable-husband set, provided every better prior proposer used for the blocking
argument is not matched to the exceptional target in the candidate stable
matching.
-/
theorem im05_history_reject_not_mem_stableHusbands_of_rejected_pair_impossible_except_exception
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (exception w : W) (b : M)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s exception)
    (hw_ne_exception : w ≠ exception)
    (hreject : ¬ im05_algorithm41HistoryAccepts val_w s w b)
    (hprior_not_exception :
      ∀ (mu : Assignment M W),
        im05_stable_matching val_m val_w mu →
          mu.w_match w = some b →
            ∀ r : M,
              im05_algorithm41HasProposedTo s r w →
                val_w w b < val_w w r →
                  mu.m_match r ≠ some exception) :
    b ∉ im05_stableHusbands val_m val_w w := by
  exact
    im05_history_reject_not_mem_stableHusbands_of_prior_blockers
      val_m val_w s w b hreject
      (fun mu hstable hmu_w r hr_proposed hw_prefers_r =>
        im05_prior_proposer_prefers_woman_in_stable_match_except_exception
          val_m val_w s exception w hstrictM hacceptable hproposalOrder
          hmatchOrder hrejected hstable hmu_w hw_ne_exception hr_proposed
          hw_prefers_r
          (hprior_not_exception mu hstable hmu_w r hr_proposed hw_prefers_r))

/--
Source-step form of the target-rejection exclusion bridge.  This is the local
backward-inclusion proof obligation for Algorithm 4.1 target proposals that are
rejected by the history rule.
-/
theorem im05_algorithm41SourceStep_target_reject_not_mem_stableHusbands_of_prior_blockers
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hactive : ∃ a, IsActiveMan val_m s a)
    {b : M}
    (hchosen :
      daStepChosenMan val_m s hactive = b)
    (htarget :
      daStepChosenWoman val_m s hactive = target)
    (hreject :
      ¬ im05_algorithm41SourceStepAccepts val_m val_w s hactive)
    (hprior_block :
      ∀ (mu : Assignment M W),
        im05_stable_matching val_m val_w mu →
          mu.w_match target = some b →
            ∀ r : M,
              im05_algorithm41HasProposedTo s r target →
                val_w target b < val_w target r →
                  valM val_m r (mu.m_match r) < val_m r target) :
    b ∉ im05_stableHusbands val_m val_w target := by
  refine
    im05_history_reject_not_mem_stableHusbands_of_prior_blockers
      val_m val_w s target b ?_ hprior_block
  simpa [im05_algorithm41SourceStepAccepts, hchosen, htarget] using hreject

/--
Usable source-step rejection exclusion: if a proposal to the target is rejected
in a state with proposal order, current-match order, and rejected-pair
impossibility, then the rejected man is not a stable husband of the target.
-/
theorem im05_algorithm41SourceStep_target_reject_not_mem_stableHusbands_of_rejected_pair_impossible
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejectedImpossible : DARejectedPairImpossibleInvariant val_m val_w s)
    (hactive : ∃ a, IsActiveMan val_m s a)
    {b : M}
    (hchosen :
      daStepChosenMan val_m s hactive = b)
    (htarget :
      daStepChosenWoman val_m s hactive = target)
    (hreject :
      ¬ im05_algorithm41SourceStepAccepts val_m val_w s hactive) :
    b ∉ im05_stableHusbands val_m val_w target := by
  refine
    im05_history_reject_not_mem_stableHusbands_of_rejected_pair_impossible
      val_m val_w s target b hstrictM hacceptable hproposalOrder hmatchOrder
      hrejectedImpossible ?_
  simpa [im05_algorithm41SourceStepAccepts, hchosen, htarget] using hreject

/--
Usable source-step rejection exclusion with the correct target exception for
Algorithm 4.1 after prior accepted target pairs have been removed.
-/
theorem im05_algorithm41SourceStep_target_reject_not_mem_stableHusbands_of_rejected_pair_impossible_except_target
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s target)
    (hactive : ∃ a, IsActiveMan val_m s a)
    {b : M}
    (hchosen :
      daStepChosenMan val_m s hactive = b)
    (htarget :
      daStepChosenWoman val_m s hactive = target)
    (hreject :
      ¬ im05_algorithm41SourceStepAccepts val_m val_w s hactive) :
    b ∉ im05_stableHusbands val_m val_w target := by
  refine
    im05_history_reject_not_mem_stableHusbands_of_rejected_pair_impossible_except_target
      val_m val_w s target b hstrictM hacceptable hproposalOrder hmatchOrder
      hrejected ?_
  simpa [im05_algorithm41SourceStepAccepts, hchosen, htarget] using hreject

theorem im05_algorithm41SourceStep_nonTarget_reject_exclusion_of_prior_not_exception
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (exception : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s exception)
    (hactive : ∃ a, IsActiveMan val_m s a)
    (hnonTarget : daStepChosenWoman val_m s hactive ≠ exception)
    (hreject :
      ¬ im05_algorithm41SourceStepAccepts val_m val_w s hactive)
    (hprior_not_exception :
      ∀ (mu : Assignment M W),
        im05_stable_matching val_m val_w mu →
          mu.w_match (daStepChosenWoman val_m s hactive) =
              some (daStepChosenMan val_m s hactive) →
            ∀ r : M,
              im05_algorithm41HasProposedTo s r
                (daStepChosenWoman val_m s hactive) →
                val_w (daStepChosenWoman val_m s hactive)
                    (daStepChosenMan val_m s hactive) <
                  val_w (daStepChosenWoman val_m s hactive) r →
                  mu.m_match r ≠ some exception) :
    ∀ mu, IsStable val_m val_w mu →
      mu.m_match (daStepChosenMan val_m s hactive) ≠
        some (daStepChosenWoman val_m s hactive) := by
  classical
  let b := daStepChosenMan val_m s hactive
  let w := daStepChosenWoman val_m s hactive
  have hhistoryReject : ¬ im05_algorithm41HistoryAccepts val_w s w b := by
    simpa [im05_algorithm41SourceStepAccepts, b, w] using hreject
  have hnotStable :
      b ∉ im05_stableHusbands val_m val_w w :=
    im05_history_reject_not_mem_stableHusbands_of_rejected_pair_impossible_except_exception
      val_m val_w s exception w b hstrictM hacceptable hproposalOrder
      hmatchOrder hrejected (by simpa [w] using hnonTarget) hhistoryReject
      (by
        intro mu hstable hmu_w r hr hbetter
        exact hprior_not_exception mu hstable
          (by simpa [b, w] using hmu_w) r
          (by simpa [w] using hr)
          (by simpa [b, w] using hbetter))
  intro mu hstable hmatch
  have hw : mu.w_match w = some b := (mu.consistent_m b w).1 hmatch
  exact hnotStable (by
    simpa [im05_stableHusbands] using ⟨mu, hstable, hw⟩)

theorem im05_algorithm41SourceStep_nonTarget_accept_displaced_exclusion_of_proposer_not_exception
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (exception : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinv : DAInvariantsExceptWoman val_m val_w s exception)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s exception)
    (hactive : ∃ a, IsActiveMan val_m s a)
    (hnonTarget : daStepChosenWoman val_m s hactive ≠ exception)
    (haccept :
      im05_algorithm41SourceStepAccepts val_m val_w s hactive)
    (cur : M)
    (hcur : s.w_match (daStepChosenWoman val_m s hactive) = some cur)
    (hproposer_not_exception :
      ∀ mu, IsStable val_m val_w mu →
        mu.m_match (daStepChosenMan val_m s hactive) ≠ some exception) :
    ∀ mu, IsStable val_m val_w mu →
      mu.m_match cur ≠ some (daStepChosenWoman val_m s hactive) := by
  classical
  let a := daStepChosenMan val_m s hactive
  let w := daStepChosenWoman val_m s hactive
  have hact : IsActiveMan val_m s a := by
    simpa [a, daStepChosenMan] using Classical.choose_spec hactive
  have hwbest : BestRemainingWoman val_m s a w := by
    simpa [a, w, daStepChosenWoman, daStepChosenMan, hact] using
      Classical.choose_spec (exists_best_woman val_m s a hact)
  have hda : daStepChosenAccepts val_m val_w s hactive :=
    (im05_algorithm41SourceStepAccepts_iff_daStepChosenAccepts_of_invariantsExceptWoman_nonTarget
      val_m val_w s exception hstrictW hacceptable hinv hactive hnonTarget).1
      haccept
  have hwomanPref : val_w w cur < val_w w a := by
    simpa [daStepChosenAccepts, a, w, hcur] using hda
  intro mu hstable
  exact
    im05_accepted_proposer_blocks_displaced_match_except_exception
      val_m val_w s exception mu hstrictM hacceptable hrejected hstable
      (by simpa [w] using hnonTarget) hact hwbest hwomanPref
      (by
        simpa [a] using hproposer_not_exception mu hstable)

theorem im05_algorithm41SourceStep_nonTarget_reject_exclusion_of_prior_blockers
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W)
    (hactive : ∃ a, IsActiveMan val_m s a)
    (hreject :
      ¬ im05_algorithm41SourceStepAccepts val_m val_w s hactive)
    (hprior_block :
      ∀ (mu : Assignment M W),
        im05_stable_matching val_m val_w mu →
          mu.w_match (daStepChosenWoman val_m s hactive) =
              some (daStepChosenMan val_m s hactive) →
            ∀ r : M,
              im05_algorithm41HasProposedTo s r
                (daStepChosenWoman val_m s hactive) →
                val_w (daStepChosenWoman val_m s hactive)
                    (daStepChosenMan val_m s hactive) <
                  val_w (daStepChosenWoman val_m s hactive) r →
                  valM val_m r (mu.m_match r) <
                    val_m r (daStepChosenWoman val_m s hactive)) :
    ∀ mu, IsStable val_m val_w mu →
      mu.m_match (daStepChosenMan val_m s hactive) ≠
        some (daStepChosenWoman val_m s hactive) := by
  classical
  let b := daStepChosenMan val_m s hactive
  let w := daStepChosenWoman val_m s hactive
  have hhistoryReject : ¬ im05_algorithm41HistoryAccepts val_w s w b := by
    simpa [im05_algorithm41SourceStepAccepts, b, w] using hreject
  have hnotStable : b ∉ im05_stableHusbands val_m val_w w :=
    im05_history_reject_not_mem_stableHusbands_of_prior_blockers
      val_m val_w s w b hhistoryReject
      (fun mu hstable hmu_w r hr hbetter =>
        hprior_block mu hstable (by simpa [b, w] using hmu_w) r
          (by simpa [w] using hr)
          (by simpa [b, w] using hbetter))
  intro mu hstable hmatch
  have hw : mu.w_match w = some b := (mu.consistent_m b w).1 hmatch
  exact hnotStable (by
    simpa [im05_stableHusbands] using ⟨mu, hstable, hw⟩)

/--
Existential version of the non-target rejection bridge.  To rule out a stable
matching that pairs the rejected proposer with the chosen non-target woman, it
is enough to exhibit one prior proposer whom that woman prefers and who also
prefers her to his partner in the candidate stable matching.
-/
theorem im05_algorithm41SourceStep_nonTarget_reject_exclusion_of_prior_blocker_exists
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W)
    (hactive : ∃ a, IsActiveMan val_m s a)
    (hprior_block :
      ∀ (mu : Assignment M W),
        im05_stable_matching val_m val_w mu →
          mu.w_match (daStepChosenWoman val_m s hactive) =
              some (daStepChosenMan val_m s hactive) →
            ∃ r : M,
              im05_algorithm41HasProposedTo s r
                (daStepChosenWoman val_m s hactive) ∧
              val_w (daStepChosenWoman val_m s hactive)
                  (daStepChosenMan val_m s hactive) <
                val_w (daStepChosenWoman val_m s hactive) r ∧
              valM val_m r (mu.m_match r) <
                val_m r (daStepChosenWoman val_m s hactive)) :
    ∀ mu, IsStable val_m val_w mu →
      mu.m_match (daStepChosenMan val_m s hactive) ≠
        some (daStepChosenWoman val_m s hactive) := by
  classical
  let b := daStepChosenMan val_m s hactive
  let w := daStepChosenWoman val_m s hactive
  intro mu hstable hmatch
  have hmu_w : mu.w_match w = some b := (mu.consistent_m b w).1 hmatch
  rcases hprior_block mu hstable (by simpa [b, w] using hmu_w) with
    ⟨r, _hr, hbetter, hmanPref⟩
  have hwomanPref : valW val_w w (mu.w_match w) < val_w w r := by
    simpa [valW, hmu_w, b, w] using hbetter
  exact hstable.2.2 r w (by simpa [w] using hmanPref) hwomanPref

theorem im05_algorithm41SourceStep_nonTarget_accept_displaced_exclusion_of_proposer_prefers
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (exception : W)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinv : DAInvariantsExceptWoman val_m val_w s exception)
    (hactive : ∃ a, IsActiveMan val_m s a)
    (hnonTarget : daStepChosenWoman val_m s hactive ≠ exception)
    (haccept :
      im05_algorithm41SourceStepAccepts val_m val_w s hactive)
    (cur : M)
    (hcur : s.w_match (daStepChosenWoman val_m s hactive) = some cur)
    (hproposer_prefers :
      ∀ mu, IsStable val_m val_w mu →
        valM val_m (daStepChosenMan val_m s hactive)
            (mu.m_match (daStepChosenMan val_m s hactive)) <
          val_m (daStepChosenMan val_m s hactive)
            (daStepChosenWoman val_m s hactive)) :
    ∀ mu, IsStable val_m val_w mu →
      mu.m_match cur ≠ some (daStepChosenWoman val_m s hactive) := by
  classical
  let a := daStepChosenMan val_m s hactive
  let w := daStepChosenWoman val_m s hactive
  have hda : daStepChosenAccepts val_m val_w s hactive :=
    (im05_algorithm41SourceStepAccepts_iff_daStepChosenAccepts_of_invariantsExceptWoman_nonTarget
      val_m val_w s exception hstrictW hacceptable hinv hactive hnonTarget).1
      haccept
  have hwomanPref : val_w w cur < val_w w a := by
    simpa [daStepChosenAccepts, a, w, hcur] using hda
  intro mu hstable hcurw
  have hw_mu : mu.w_match w = some cur := (mu.consistent_m cur w).1 hcurw
  have hwomanPref' : valW val_w w (mu.w_match w) < val_w w a := by
    simpa [valW, hw_mu] using hwomanPref
  exact
    hstable.2.2 a w
      (by simpa [a, w] using hproposer_prefers mu hstable)
      hwomanPref'

