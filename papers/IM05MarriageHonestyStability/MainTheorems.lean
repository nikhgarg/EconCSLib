    im05_DARejectedPairImpossibleExceptWoman val_m val_w
      (im05_algorithm41SourceStepDivorceTarget val_m val_w target s)
      target := by
  exact
    im05_algorithm41SourceStepDivorceTarget_preserves_rejectedPairImpossibleExceptWoman_of_nonTarget_exclusions
      val_m val_w s target hrejected
      (fun hactive hnonTarget hreject =>
        (hexcl hactive hnonTarget).1 hreject)
      (fun hactive hnonTarget haccept =>
