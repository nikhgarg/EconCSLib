    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    {m : M}
    (hinit : im05_algorithm41InitialHusband val_m val_w g = some m) :
    ∀ r : M, r ∈ im05_stableHusbands val_m val_w g → r ≠ m →
      val_w g m < val_w g r := by
  intro r hr hne
  have hle :=
    im05_algorithm41InitialHusband_worst_stableHusband
      val_m val_w g hcard hstrictM hstrictW hacceptable hinit r hr
  exact lt_of_le_of_ne hle (by
    intro heq
    exact hne ((hstrictW g m r heq).symm))

theorem im05_noninitial_stableHusband_mem_divorced_proposals
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (hcard : Fintype.card M = Fintype.card W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    {init m : M}
    (hinit : im05_algorithm41InitialHusband val_m val_w g = some init)
    (hm : m ∈ im05_stableHusbands val_m val_w g)
    (hnotInitial : im05_algorithm41InitialHusband val_m val_w g ≠ some m) :
    g ∈ (im05_algorithm41DivorcedState val_m val_w g).m_proposals m := by
  classical
  by_contra hnotDivorced
  let s0 := deferredAcceptanceState val_m val_w
  have hinv : DAInvariants val_m val_w s0 := by
    simpa [s0] using deferredAcceptanceState_satisfies_invariants_closed
      val_m val_w
  have hreject : WomanRejectionInvariant val_w s0 := hinv.2.2.2.1
  have hinit_w : s0.w_match g = some init := by
    simpa [s0, im05_algorithm41InitialHusband] using hinit
  have hnot0 : g ∉ s0.m_proposals m := by
    simpa [s0, im05_algorithm41DivorcedState] using hnotDivorced
  have hne : m ≠ init := by
    intro hmi
    subst m
    exact hnotInitial hinit
  have hnotMatch : s0.m_match m ≠ some g := by
    intro hmatch
    have hw : s0.w_match g = some m := (s0.consistent m g).1 hmatch
    exact hne (Option.some.inj (hw.symm.trans hinit_w))
  have hlt_init_m :
      val_w g init < val_w g m :=
    im05_algorithm41InitialHusband_strictly_worst_stableHusband_of_ne
      val_m val_w g hcard hstrictM hstrictW hacceptable hinit
      m hm hne
  rcases hreject g m hnot0 hnotMatch with hneg | ⟨cur, hcur, hle⟩
  · have hpos : 0 < val_w g m := hacceptable.2 g m
    linarith
  · have hcur_eq : cur = init := Option.some.inj (hcur.symm.trans hinit_w)
    subst cur
    linarith

