/--
After conditioning a uniform count-vector word on `head` being first, the first
symbol of the residual word obtained by deleting all `head` copies has the
raw-count available-mass law.
-/
theorem
    im05_integerMultisetPermutationAllowedSample_head_conditional_first_prob_eq_available_ratio
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (head : Name) (hhead_pos : 0 < count head)
    (target : Name) (hneq : target ≠ head) (hpos : 0 < count target) :
    EconCSLib.pmfConditionalProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst head hhead_pos sample = head)
        (fun sample =>
          im05_integerMultisetPermutationFirst target
              (by
                have hnot : target ∉ ({head} : Finset Name) := by
                  simpa [Finset.mem_singleton] using hneq
                simpa [im05_countOutside, hnot] using hpos)
              (im05_integerMultisetPermutationAllowedSample
                ({head} : Finset Name) sample) =
            target) =
      (count target : ℝ) /
        EconCSLib.finiteAvailableWeight
          (im05_countWeight count) ({head} : Finset Name) := by
  classical
  have hnot : target ∉ ({head} : Finset Name) := by
    simpa [Finset.mem_singleton] using hneq
  have houtside_pos :
      0 < im05_countOutside count ({head} : Finset Name) target := by
    simpa [im05_countOutside, hnot] using hpos
  let event :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({head} : Finset Name)) → Prop :=
    fun residual =>
      im05_integerMultisetPermutationFirst target houtside_pos residual =
        target
  calc
    EconCSLib.pmfConditionalProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst head hhead_pos sample = head)
        (fun sample =>
          im05_integerMultisetPermutationFirst target
              (by
                have hnot : target ∉ ({head} : Finset Name) := by
                  simpa [Finset.mem_singleton] using hneq
                simpa [im05_countOutside, hnot] using hpos)
              (im05_integerMultisetPermutationAllowedSample
                ({head} : Finset Name) sample) =
            target)
        =
      EconCSLib.pmfConditionalProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst head hhead_pos sample = head)
        (fun sample =>
          event
            (im05_integerMultisetPermutationAllowedSample
              ({head} : Finset Name) sample)) := by
          refine
            EconCSLib.pmfConditionalProb_congr_of_condition
              (EconCSLib.uniformPMF
                (im05_integerMultisetPermutationSample Name count))
              (fun sample =>
                im05_integerMultisetPermutationFirst head hhead_pos sample =
                  head)
              (fun sample =>
                im05_integerMultisetPermutationFirst target
                    (by
                      have hnot : target ∉ ({head} : Finset Name) := by
                        simpa [Finset.mem_singleton] using hneq
                      simpa [im05_countOutside, hnot] using hpos)
                    (im05_integerMultisetPermutationAllowedSample
                      ({head} : Finset Name) sample) =
                  target)
              (fun sample =>
                event
                  (im05_integerMultisetPermutationAllowedSample
                    ({head} : Finset Name) sample))
              ?_
          intro sample _hcondition
          simp [event]
    _ =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name
            (im05_countOutside count ({head} : Finset Name))))
        event := by
          exact
            im05_integerMultisetPermutationAllowedSample_head_conditional_uniform_event_eq
              count head hhead_pos event
    _ =
      (count target : ℝ) /
        EconCSLib.finiteAvailableWeight
          (im05_countWeight count) ({head} : Finset Name) := by
          dsimp [event]
          exact
            im05_integerMultisetPermutation_countOutside_first_prob_eq_available_ratio
              count ({head} : Finset Name) target hnot hpos

/--
Second-position transition law for the first-appearance list induced by a
uniform count-vector word: conditioned on first appearance `head`, the next
first-appearance atom is proportional to the residual count outside `head`.
-/
theorem
    im05_integerMultisetPermutationFirstAppearanceFreshList_second_conditional_prob_eq_available_ratio
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (hcount_pos : ∀ name : Name, 0 < count name)
    (head target : Name) (hneq : target ≠ head)
    (hcard_two : 1 < Fintype.card Name) :
    EconCSLib.pmfConditionalProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          (im05_integerMultisetPermutationFirstAppearanceFreshList
            hcount_pos sample).1
              ⟨0, Fintype.card_pos_iff.mpr ⟨head⟩⟩ = head)
        (fun sample =>
          (im05_integerMultisetPermutationFirstAppearanceFreshList
            hcount_pos sample).1 ⟨1, hcard_two⟩ = target) =
      (count target : ℝ) /
        EconCSLib.finiteAvailableWeight
          (im05_countWeight count) ({head} : Finset Name) := by
  classical
  let μ :=
    EconCSLib.uniformPMF
      (im05_integerMultisetPermutationSample Name count)
  let firstCondition :
      im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      (im05_integerMultisetPermutationFirstAppearanceFreshList
        hcount_pos sample).1
          ⟨0, Fintype.card_pos_iff.mpr ⟨head⟩⟩ = head
  let headCondition :
      im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      im05_integerMultisetPermutationFirst head (hcount_pos head) sample =
        head
  let secondEvent :
      im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      (im05_integerMultisetPermutationFirstAppearanceFreshList
        hcount_pos sample).1 ⟨1, hcard_two⟩ = target
  let residualEvent :
      im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      im05_integerMultisetPermutationFirst target
          (by
            have hnot : target ∉ ({head} : Finset Name) := by
              simpa [Finset.mem_singleton] using hneq
            simpa [im05_countOutside, hnot] using hcount_pos target)
          (im05_integerMultisetPermutationAllowedSample
            ({head} : Finset Name) sample) =
        target
  have hcondition_iff : ∀ sample, firstCondition sample ↔ headCondition sample := by
    intro sample
    dsimp [firstCondition, headCondition]
    rw [im05_integerMultisetPermutationFirstAppearanceFreshList_zero
      hcount_pos sample head]
  have hcond_congr :
      EconCSLib.pmfConditionalProb μ firstCondition secondEvent =
        EconCSLib.pmfConditionalProb μ headCondition residualEvent := by
    refine
      EconCSLib.pmfConditionalProb_congr μ
        firstCondition headCondition secondEvent residualEvent
        hcondition_iff ?_
    intro sample hfirstCondition
    have hfirst : headCondition sample :=
      (hcondition_iff sample).1 hfirstCondition
    have hsecond :=
      im05_integerMultisetPermutationFirstAppearanceFreshList_one_eq_allowedSample_first
        hcount_pos sample head target hneq hcard_two hfirst
    dsimp [secondEvent, residualEvent]
    rw [hsecond]
  rw [hcond_congr]
  exact
    im05_integerMultisetPermutationAllowedSample_head_conditional_first_prob_eq_available_ratio
      count head (hcount_pos head) target hneq (hcount_pos target)

/--
Second-position transition law for Algorithm 4.2 with raw integer count
weights, stated with ordinary first-slot conditioning.
-/
theorem im05_algorithm42FreshList_countWeight_second_conditional_prob_eq_available_ratio
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (hk_le_card : k + 2 ≤ Fintype.card Name)
    (head target : Name) (hneq : target ≠ head) :
    EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 2) hk_le_card)
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨0, by omega⟩ = head)
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨1, by omega⟩ = target) =
      (count target : ℝ) /
        EconCSLib.finiteAvailableWeight
          (im05_countWeight count) ({head} : Finset Name) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available (k + 2) hk_le_card
  let draw : im05_algorithm42FreshListSample Name (k + 2) → Fin (k + 2) → Name :=
    im05_algorithm42FreshListDraw
  let firstCond : im05_algorithm42FreshListSample Name (k + 2) → Prop :=
    fun sample => draw sample ⟨0, by omega⟩ = head
  let prefixCond : im05_algorithm42FreshListSample Name (k + 2) → Prop :=
    fun sample => im05_listPrefixSet 1 (draw sample) = ({head} : Finset Name)
  let secondEvent : im05_algorithm42FreshListSample Name (k + 2) → Prop :=
    fun sample => draw sample ⟨1, by omega⟩ = target
  have hcondition_iff : ∀ sample, firstCond sample ↔ prefixCond sample := by
    intro sample
    dsimp [firstCond, prefixCond, draw]
    rw [im05_listPrefixSet_one_eq_singleton
      (im05_algorithm42FreshListDraw sample) (by omega)]
    simp
  have hfirst_prob :
      EconCSLib.pmfProb μ firstCond =
        (count head : ℝ) / (∑ name : Name, count name : ℝ) := by
    simpa [μ, firstCond, draw] using
      (im05_algorithm42FreshList_countWeight_first_draw_prob_eq_count_ratio
        (Name := Name) count hcount_available
        (k := k + 1) hk_le_card head)
  have hfirst_pos : 0 < EconCSLib.pmfProb μ firstCond := by
    rw [hfirst_prob]
    exact div_pos
      (by exact_mod_cast hcount_pos head)
      (by
        exact_mod_cast
          im05_sum_count_pos_of_pos count head (hcount_pos head))
  have hprefix_pos : 0 < EconCSLib.pmfProb μ prefixCond := by
    have hprob_congr :
        EconCSLib.pmfProb μ firstCond =
          EconCSLib.pmfProb μ prefixCond :=
      EconCSLib.pmfProb_congr μ hcondition_iff
    rwa [← hprob_congr]
  have havailable_pos :
      0 < EconCSLib.finiteAvailableWeight
        (im05_countWeight count) ({head} : Finset Name) := by
    exact
      hcount_available ({head} : Finset Name)
        (by
          simp
          omega)
  have hcond_congr :
      EconCSLib.pmfConditionalProb μ firstCond secondEvent =
        EconCSLib.pmfConditionalProb μ prefixCond secondEvent := by
    exact
      EconCSLib.pmfConditionalProb_congr μ
        firstCond prefixCond secondEvent secondEvent hcondition_iff
        (by intro sample _hcondition; rfl)
  rw [hcond_congr]
  have hprefix_formula :
      EconCSLib.pmfConditionalProb μ prefixCond secondEvent =
        (EconCSLib.finiteWeightedPMFExcluding
          (im05_countWeight count) ({head} : Finset Name)
          (im05_countWeight_nonneg count) havailable_pos target).toReal := by
    simpa [μ, prefixCond, secondEvent, draw] using
      (paper_im05_algorithm4_2_freshList_prefixSet_conditional_atom_formula
        (prob := im05_countWeight count)
        (hprob_nonneg := im05_countWeight_nonneg count)
        (havailable := hcount_available)
        (hr := by omega)
        (hk_le_card := hk_le_card)
        ({head} : Finset Name) target hprefix_pos havailable_pos)
  rw [hprefix_formula]
  have hnot : target ∉ ({head} : Finset Name) := by
    simpa [Finset.mem_singleton] using hneq
  rw [EconCSLib.finiteWeightedPMFExcluding_apply_toReal_of_not_mem
    (im05_countWeight count) ({head} : Finset Name)
    (im05_countWeight_nonneg count) havailable_pos hnot]
  simp [im05_countWeight]

/--
Ordered two-draw atom formula for Algorithm 4.2 with raw integer count weights.
-/
theorem im05_algorithm42FreshList_countWeight_first_second_prob_eq_ratio_mul_ratio
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (hcard_two : 2 ≤ Fintype.card Name)
    (head target : Name) (hneq : target ≠ head) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          im05_algorithm42FreshListDraw sample ⟨0, by omega⟩ = head ∧
            im05_algorithm42FreshListDraw sample ⟨1, by omega⟩ = target) =
      ((count head : ℝ) / (∑ name : Name, count name : ℝ)) *
        ((count target : ℝ) /
          EconCSLib.finiteAvailableWeight
            (im05_countWeight count) ({head} : Finset Name)) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 2 hcard_two
  let first : im05_algorithm42FreshListSample Name 2 → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample ⟨0, by omega⟩ = head
  let second : im05_algorithm42FreshListSample Name 2 → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample ⟨1, by omega⟩ = target
  let joint : im05_algorithm42FreshListSample Name 2 → Prop :=
    fun sample => first sample ∧ second sample
  have hcount_pos : ∀ name : Name, 0 < count name :=
    im05_count_pos_of_countWeight_available count hcount_available
  have hfirst_prob :
      EconCSLib.pmfProb μ first =
        (count head : ℝ) / (∑ name : Name, count name : ℝ) := by
    simpa [μ, first] using
      (im05_algorithm42FreshList_countWeight_first_draw_prob_eq_count_ratio
        (Name := Name) count hcount_available
        (k := 1) hcard_two head)
  have hfirst_pos : 0 < EconCSLib.pmfProb μ first := by
    rw [hfirst_prob]
    exact div_pos
      (by exact_mod_cast hcount_pos head)
      (by
        exact_mod_cast
          im05_sum_count_pos_of_pos count head (hcount_pos head))
  have hcond_joint :
      EconCSLib.pmfConditionalProb μ first joint =
        EconCSLib.pmfConditionalProb μ first second :=
    EconCSLib.pmfConditionalProb_congr_of_condition μ
      first joint second
      (by
        intro sample hfirst
        constructor
        · intro h
          exact h.2
        · intro hsecond
          exact ⟨hfirst, hsecond⟩)
  have hcond_second :
      EconCSLib.pmfConditionalProb μ first second =
        (count target : ℝ) /
          EconCSLib.finiteAvailableWeight
            (im05_countWeight count) ({head} : Finset Name) := by
    simpa [μ, first, second] using
      (im05_algorithm42FreshList_countWeight_second_conditional_prob_eq_available_ratio
        (Name := Name) count hcount_pos hcount_available
        (k := 0) hcard_two head target hneq)
  have hchain :
      EconCSLib.pmfProb μ joint =
        EconCSLib.pmfConditionalProb μ first joint *
          EconCSLib.pmfProb μ first :=
    EconCSLib.pmfProb_eq_mul_conditionalProb_of_imp
      μ first joint (by intro sample h; exact h.1) hfirst_pos
  change EconCSLib.pmfProb μ joint =
    ((count head : ℝ) / (∑ name : Name, count name : ℝ)) *
      ((count target : ℝ) /
        EconCSLib.finiteAvailableWeight
          (im05_countWeight count) ({head} : Finset Name))
  rw [hchain, hcond_joint, hcond_second, hfirst_prob]
  ring

/--
Two-draw probability of hitting both distinct targets under Algorithm 4.2 with
raw integer count weights.
-/
theorem im05_algorithm42FreshList_countWeight_two_hit_both_prob_eq_order_sum
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (hcard_two : 2 ≤ Fintype.card Name)
    (i j : Name) (hij : i ≠ j) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          ¬ im05_listPrefixOmits i 2
              (im05_algorithm42FreshListDraw sample) ∧
            ¬ im05_listPrefixOmits j 2
              (im05_algorithm42FreshListDraw sample)) =
      ((count i : ℝ) / (∑ name : Name, count name : ℝ)) *
          ((count j : ℝ) /
            EconCSLib.finiteAvailableWeight
              (im05_countWeight count) ({i} : Finset Name)) +
        ((count j : ℝ) / (∑ name : Name, count name : ℝ)) *
          ((count i : ℝ) /
            EconCSLib.finiteAvailableWeight
              (im05_countWeight count) ({j} : Finset Name)) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 2 hcard_two
  let orderIJ : im05_algorithm42FreshListSample Name 2 → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample ⟨0, by omega⟩ = i ∧
        im05_algorithm42FreshListDraw sample ⟨1, by omega⟩ = j
  let orderJI : im05_algorithm42FreshListSample Name 2 → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample ⟨0, by omega⟩ = j ∧
        im05_algorithm42FreshListDraw sample ⟨1, by omega⟩ = i
  have hhit_congr :
      EconCSLib.pmfProb μ
          (fun sample =>
            ¬ im05_listPrefixOmits i 2
                (im05_algorithm42FreshListDraw sample) ∧
              ¬ im05_listPrefixOmits j 2
                (im05_algorithm42FreshListDraw sample)) =
        EconCSLib.pmfProb μ (fun sample => orderIJ sample ∨ orderJI sample) := by
    refine EconCSLib.pmfProb_congr μ ?_
    intro sample
    simpa [orderIJ, orderJI] using
      (im05_two_slot_hits_distinct_iff i j
        (im05_algorithm42FreshListDraw sample)
        (by omega) (by omega)
        (im05_algorithm42FreshListDraw_injective sample) hij)
  have hdisjoint : ∀ sample, orderIJ sample → orderJI sample → False := by
    intro sample hIJ hJI
    exact hij (hIJ.1.symm.trans hJI.1)
  rw [hhit_congr]
  rw [EconCSLib.pmfProb_or_eq_add_of_disjoint μ orderIJ orderJI hdisjoint]
  rw [im05_algorithm42FreshList_countWeight_first_second_prob_eq_ratio_mul_ratio
    count hcount_available hcard_two i j (Ne.symm hij)]
  rw [im05_algorithm42FreshList_countWeight_first_second_prob_eq_ratio_mul_ratio
    count hcount_available hcard_two j i hij]

/--
Second-slot marginal formula for the two-draw raw-count fresh-list sampler,
expanded by the first-slot value.
-/
theorem im05_algorithm42FreshList_countWeight_second_prob_eq_sum_first
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (hcard_two : 2 ≤ Fintype.card Name)
    (target : Name) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          im05_algorithm42FreshListDraw sample ⟨1, by omega⟩ = target) =
      ∑ head : Name,
        if hneq : target ≠ head then
          ((count head : ℝ) / (∑ name : Name, count name : ℝ)) *
            ((count target : ℝ) /
              EconCSLib.finiteAvailableWeight
                (im05_countWeight count) ({head} : Finset Name))
        else 0 := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 2 hcard_two
  let second : im05_algorithm42FreshListSample Name 2 → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample ⟨1, by omega⟩ = target
  let firstValue : im05_algorithm42FreshListSample Name 2 → Name :=
    fun sample => im05_algorithm42FreshListDraw sample ⟨0, by omega⟩
  rw [EconCSLib.pmfProb_eq_sum_state_inter μ second firstValue]
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  by_cases hneq : target ≠ head
  · have hterm :
        EconCSLib.pmfProb μ
            (fun sample => second sample ∧ firstValue sample = head) =
          EconCSLib.pmfProb μ
            (fun sample =>
              im05_algorithm42FreshListDraw sample ⟨0, by omega⟩ = head ∧
                im05_algorithm42FreshListDraw sample ⟨1, by omega⟩ =
                  target) := by
        exact EconCSLib.pmfProb_congr μ (by
          intro sample
          constructor
          · intro h
            exact ⟨h.2, h.1⟩
          · intro h
            exact ⟨h.2, h.1⟩)
    rw [hterm]
    simpa [μ, hneq] using
      (im05_algorithm42FreshList_countWeight_first_second_prob_eq_ratio_mul_ratio
        count hcount_available hcard_two head target hneq)
  · have hhead_eq : head = target := by
      by_contra hne
      exact hneq (Ne.symm hne)
    subst head
    have hzero :
        EconCSLib.pmfProb μ
            (fun sample => second sample ∧ firstValue sample = target) =
          0 := by
      refine EconCSLib.pmfProb_eq_zero_of_no_mass μ _ ?_
      intro sample hsample
      have hinj := im05_algorithm42FreshListDraw_injective sample
      have hslot_eq :
          (⟨0, by omega⟩ : Fin 2) = ⟨1, by omega⟩ := by
        exact hinj (hsample.2.trans hsample.1.symm)
      have hval := congrArg Fin.val hslot_eq
      norm_num at hval
    simp [hneq, hzero]

/--
Two-draw hit probability for one target under raw integer count weights.
-/
theorem im05_algorithm42FreshList_countWeight_two_hit_prob_eq_first_add_sum
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (hcard_two : 2 ≤ Fintype.card Name)
    (target : Name) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          ¬ im05_listPrefixOmits target 2
            (im05_algorithm42FreshListDraw sample)) =
      (count target : ℝ) / (∑ name : Name, count name : ℝ) +
        ∑ head : Name,
          if hneq : target ≠ head then
            ((count head : ℝ) / (∑ name : Name, count name : ℝ)) *
              ((count target : ℝ) /
                EconCSLib.finiteAvailableWeight
                  (im05_countWeight count) ({head} : Finset Name))
          else 0 := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 2 hcard_two
  let first : im05_algorithm42FreshListSample Name 2 → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample ⟨0, by omega⟩ = target
  let second : im05_algorithm42FreshListSample Name 2 → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample ⟨1, by omega⟩ = target
  have hhit :
      EconCSLib.pmfProb μ
          (fun sample =>
            ¬ im05_listPrefixOmits target 2
              (im05_algorithm42FreshListDraw sample)) =
        EconCSLib.pmfProb μ (fun sample => first sample ∨ second sample) := by
    refine EconCSLib.pmfProb_congr μ ?_
    intro sample
    simpa [first, second] using
      (im05_not_listPrefixOmits_two_iff target
        (im05_algorithm42FreshListDraw sample) (by omega) (by omega))
  have hdisjoint : ∀ sample, first sample → second sample → False := by
    intro sample hfirst hsecond
    have hinj := im05_algorithm42FreshListDraw_injective sample
    have hslot_eq :
        (⟨0, by omega⟩ : Fin 2) = ⟨1, by omega⟩ :=
      hinj (hfirst.trans hsecond.symm)
    have hval := congrArg Fin.val hslot_eq
    norm_num at hval
  rw [hhit]
  rw [EconCSLib.pmfProb_or_eq_add_of_disjoint μ first second hdisjoint]
  rw [im05_algorithm42FreshList_countWeight_first_draw_prob_eq_count_ratio
    (Name := Name) count hcount_available (k := 1) hcard_two target]
  rw [im05_algorithm42FreshList_countWeight_second_prob_eq_sum_first
    count hcount_available hcard_two target]

/--
Two-draw hit probability in the factor form used by the scalar
negative-correlation algebra.
-/
theorem im05_algorithm42FreshList_countWeight_two_hit_prob_eq_factor
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (hcard_two : 2 ≤ Fintype.card Name)
    (target : Name) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          ¬ im05_listPrefixOmits target 2
            (im05_algorithm42FreshListDraw sample)) =
      ((count target : ℝ) / (∑ name : Name, count name : ℝ)) *
        (1 +
          ∑ head : Name,
            if target ≠ head then
              (count head : ℝ) /
                ((∑ name : Name, count name : ℝ) - count head)
            else 0) := by
  classical
  rw [im05_algorithm42FreshList_countWeight_two_hit_prob_eq_first_add_sum
    count hcount_available hcard_two target]
  rw [mul_add]
  rw [mul_one]
  rw [Finset.mul_sum]
  congr 1
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  by_cases hneq : target ≠ head
  · simp [hneq, im05_countWeight_available_singleton_eq_total_sub]
    ring
  · simp [hneq]

/--
Two-draw negative correlation for the events that two distinct targets are hit
by the raw-count Algorithm 4.2 fresh-list sampler.
-/
theorem
    im05_algorithm42FreshList_countWeight_two_hit_negative_correlation
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (hcard_two : 2 ≤ Fintype.card Name)
    (i j : Name) (hij : i ≠ j) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          ¬ im05_listPrefixOmits i 2
              (im05_algorithm42FreshListDraw sample) ∧
            ¬ im05_listPrefixOmits j 2
              (im05_algorithm42FreshListDraw sample)) ≤
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          ¬ im05_listPrefixOmits i 2
            (im05_algorithm42FreshListDraw sample)) *
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          ¬ im05_listPrefixOmits j 2
            (im05_algorithm42FreshListDraw sample)) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 2 hcard_two
  let T : ℝ := ∑ name : Name, count name
  let wi : ℝ := count i
  let wj : ℝ := count j
  let outside := ((Finset.univ : Finset Name).erase i).erase j
  let S : ℝ := outside.sum (fun head => (count head : ℝ))
  let C : ℝ :=
    outside.sum
      (fun head =>
        (count head : ℝ) /
          ((∑ name : Name, count name : ℝ) - count head))
  have hcount_pos : ∀ name : Name, 0 < count name :=
    im05_count_pos_of_countWeight_available count hcount_available
  have hwi_pos : 0 < wi := by
    dsimp [wi]
    exact_mod_cast hcount_pos i
  have hwj_pos : 0 < wj := by
    dsimp [wj]
    exact_mod_cast hcount_pos j
  have hS_nonneg : 0 ≤ S := by
    dsimp [S]
    exact Finset.sum_nonneg (by
      intro head _hhead
      exact_mod_cast (Nat.zero_le (count head) : 0 ≤ count head))
  have hT_eq : T = wi + wj + S := by
    dsimp [T, wi, wj, S, outside]
    exact
      im05_sum_univ_eq_pair_add_outside
        (fun head : Name => (count head : ℝ)) i j hij
  have hC : S / T ≤ C := by
    dsimp [S, C, T, outside]
    exact
      im05_outside_count_div_total_le_sum_div_total_sub
        count hcount_available hcard_two i j
  have hcore :=
    im05_two_draw_hit_negative_correlation_core_prob_shape
      hT_eq hwi_pos hwj_pos hS_nonneg hC
  have hsum_i :
      (∑ head : Name,
        if i ≠ head then
          (count head : ℝ) /
            ((∑ name : Name, count name : ℝ) - count head)
        else 0) =
        wj / (T - wj) + C := by
    have hsplit :=
      im05_sum_if_ne_eq_pair_term_add_outside
        (fun head : Name =>
          (count head : ℝ) /
            ((∑ name : Name, count name : ℝ) - count head))
        i j hij
    simpa [T, wj, C, outside] using hsplit
  have hsum_j :
      (∑ head : Name,
        if j ≠ head then
          (count head : ℝ) /
            ((∑ name : Name, count name : ℝ) - count head)
        else 0) =
        wi / (T - wi) + C := by
    have hsplit :=
      im05_sum_if_ne_eq_pair_term_add_outside_symm
        (fun head : Name =>
          (count head : ℝ) /
            ((∑ name : Name, count name : ℝ) - count head))
        i j hij
    simpa [T, wi, C, outside] using hsplit
  have hboth :
      EconCSLib.pmfProb μ
          (fun sample =>
            ¬ im05_listPrefixOmits i 2
                (im05_algorithm42FreshListDraw sample) ∧
              ¬ im05_listPrefixOmits j 2
                (im05_algorithm42FreshListDraw sample)) =
        wi / T * (wj / (T - wi)) +
          wj / T * (wi / (T - wj)) := by
    dsimp [μ, T, wi, wj]
    rw [im05_algorithm42FreshList_countWeight_two_hit_both_prob_eq_order_sum
      count hcount_available hcard_two i j hij]
    simp [im05_countWeight_available_singleton_eq_total_sub]
  have hi_prob :
      EconCSLib.pmfProb μ
          (fun sample =>
            ¬ im05_listPrefixOmits i 2
              (im05_algorithm42FreshListDraw sample)) =
        wi / T * (1 + C + wj / (T - wj)) := by
    dsimp [μ, T, wi, wj]
    rw [im05_algorithm42FreshList_countWeight_two_hit_prob_eq_factor
      count hcount_available hcard_two i]
    rw [hsum_i]
    ring
  have hj_prob :
      EconCSLib.pmfProb μ
          (fun sample =>
            ¬ im05_listPrefixOmits j 2
              (im05_algorithm42FreshListDraw sample)) =
        wj / T * (1 + C + wi / (T - wi)) := by
    dsimp [μ, T, wi, wj]
    rw [im05_algorithm42FreshList_countWeight_two_hit_prob_eq_factor
      count hcount_available hcard_two j]
    rw [hsum_j]
    ring
  calc
    EconCSLib.pmfProb μ
        (fun sample =>
          ¬ im05_listPrefixOmits i 2
              (im05_algorithm42FreshListDraw sample) ∧
            ¬ im05_listPrefixOmits j 2
              (im05_algorithm42FreshListDraw sample))
        =
      wi / T * (wj / (T - wi)) +
        wj / T * (wi / (T - wj)) := hboth
    _ ≤
      (wi / T * (1 + C + wj / (T - wj))) *
        (wj / T * (1 + C + wi / (T - wi))) := hcore
    _ =
      EconCSLib.pmfProb μ
          (fun sample =>
            ¬ im05_listPrefixOmits i 2
              (im05_algorithm42FreshListDraw sample)) *
        EconCSLib.pmfProb μ
          (fun sample =>
            ¬ im05_listPrefixOmits j 2
              (im05_algorithm42FreshListDraw sample)) := by
        rw [hi_prob, hj_prob]

/--
Two-draw negative correlation for omission events under the raw-count Algorithm
4.2 fresh-list sampler.
-/
theorem
    paper_im05_lemma4_4_freshList_pairwise_negative_correlation_countWeight_two
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (hcard_two : 2 ≤ Fintype.card Name)
    (i j : Name) (hij : i ≠ j) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          im05_listPrefixOmits i 2
              (im05_algorithm42FreshListDraw sample) ∧
            im05_listPrefixOmits j 2
              (im05_algorithm42FreshListDraw sample)) ≤
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          im05_listPrefixOmits i 2
            (im05_algorithm42FreshListDraw sample)) *
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          im05_listPrefixOmits j 2
            (im05_algorithm42FreshListDraw sample)) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 2 hcard_two
  let hit : Name → im05_algorithm42FreshListSample Name 2 → Prop :=
    fun target sample =>
      ¬ im05_listPrefixOmits target 2
        (im05_algorithm42FreshListDraw sample)
  have hhit :
      EconCSLib.pmfProb μ (fun sample => hit i sample ∧ hit j sample) ≤
        EconCSLib.pmfProb μ (hit i) *
          EconCSLib.pmfProb μ (hit j) := by
    simpa [μ, hit] using
      im05_algorithm42FreshList_countWeight_two_hit_negative_correlation
        count hcount_available hcard_two i j hij
  have hcomp :=
    EconCSLib.pmfProb_not_and_not_le_mul_of_inter_le_mul
      μ (hit i) (hit j) hhit
  have hleft :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_listPrefixOmits i 2
                (im05_algorithm42FreshListDraw sample) ∧
              im05_listPrefixOmits j 2
                (im05_algorithm42FreshListDraw sample)) =
        EconCSLib.pmfProb μ
          (fun sample => ¬ hit i sample ∧ ¬ hit j sample) := by
    exact EconCSLib.pmfProb_congr μ (by
      intro sample
      simp [hit])
  have hi :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_listPrefixOmits i 2
              (im05_algorithm42FreshListDraw sample)) =
        EconCSLib.pmfProb μ (fun sample => ¬ hit i sample) := by
    exact EconCSLib.pmfProb_congr μ (by
      intro sample
      simp [hit])
  have hj :
      EconCSLib.pmfProb μ
          (fun sample =>
            im05_listPrefixOmits j 2
              (im05_algorithm42FreshListDraw sample)) =
        EconCSLib.pmfProb μ (fun sample => ¬ hit j sample) := by
    exact EconCSLib.pmfProb_congr μ (by
      intro sample
      simp [hit])
  rw [hleft, hi, hj]
  exact hcomp

/--
Two-step recursive finite-law bridge: the second first-appearance atom in the
uniform count-vector model, conditioned on the first first-appearance name,
matches the second draw atom in Algorithm 4.2 with raw count weights under the
same conditioning.
-/
theorem
    im05_integerMultisetPermutationFirstAppearanceFreshList_second_conditional_prob_eq_countWeight_freshList_second_conditional_prob
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (hk_le_card : k + 2 ≤ Fintype.card Name)
    (head target : Name) (hneq : target ≠ head) :
    EconCSLib.pmfConditionalProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          (im05_integerMultisetPermutationFirstAppearanceFreshList
            hcount_pos sample).1
              ⟨0, Fintype.card_pos_iff.mpr ⟨head⟩⟩ = head)
        (fun sample =>
          (im05_integerMultisetPermutationFirstAppearanceFreshList
            hcount_pos sample).1
              ⟨1, by omega⟩ = target) =
      EconCSLib.pmfConditionalProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 2) hk_le_card)
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨0, by omega⟩ = head)
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨1, by omega⟩ = target) := by
  rw [im05_integerMultisetPermutationFirstAppearanceFreshList_second_conditional_prob_eq_available_ratio
    count hcount_pos head target hneq (by omega)]
  rw [im05_algorithm42FreshList_countWeight_second_conditional_prob_eq_available_ratio
    count hcount_pos hcount_available hk_le_card head target hneq]

/--
Two-prefix atom finite-law bridge: the probability of the first two
first-appearance names being `(head, target)` in the uniform count-vector model
matches the corresponding first-two-draw atom in Algorithm 4.2 with raw count
weights.
-/
theorem
    im05_integerMultisetPermutationFirstAppearanceFreshList_first_second_prob_eq_countWeight_freshList_first_second_prob
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (hk_le_card : k + 2 ≤ Fintype.card Name)
    (head target : Name) (hneq : target ≠ head) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          (im05_integerMultisetPermutationFirstAppearanceFreshList
            hcount_pos sample).1
              ⟨0, Fintype.card_pos_iff.mpr ⟨head⟩⟩ = head ∧
            (im05_integerMultisetPermutationFirstAppearanceFreshList
              hcount_pos sample).1
                ⟨1, by omega⟩ = target) =
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 2) hk_le_card)
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨0, by omega⟩ = head ∧
            im05_algorithm42FreshListDraw sample
              ⟨1, by omega⟩ = target) := by
  classical
  let μM :=
    EconCSLib.uniformPMF
      (im05_integerMultisetPermutationSample Name count)
  let μA :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available (k + 2) hk_le_card
  let firstM : im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      (im05_integerMultisetPermutationFirstAppearanceFreshList
        hcount_pos sample).1
          ⟨0, Fintype.card_pos_iff.mpr ⟨head⟩⟩ = head
  let secondM : im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      (im05_integerMultisetPermutationFirstAppearanceFreshList
        hcount_pos sample).1
          ⟨1, by omega⟩ = target
  let jointM : im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample => firstM sample ∧ secondM sample
  let firstA : im05_algorithm42FreshListSample Name (k + 2) → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample
        ⟨0, by omega⟩ = head
  let secondA : im05_algorithm42FreshListSample Name (k + 2) → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample
        ⟨1, by omega⟩ = target
  let jointA : im05_algorithm42FreshListSample Name (k + 2) → Prop :=
    fun sample => firstA sample ∧ secondA sample
  have hfirst_eq :
      EconCSLib.pmfProb μM firstM =
        EconCSLib.pmfProb μA firstA := by
    simpa [μM, μA, firstM, firstA] using
      (im05_integerMultisetPermutationFirstAppearanceFreshList_first_prob_eq_countWeight_freshList_first_prob
        (Name := Name) count hcount_pos hcount_available
        (k := k + 1) hk_le_card head)
  have hfirstA_ratio :
      EconCSLib.pmfProb μA firstA =
        (count head : ℝ) / (∑ name : Name, count name : ℝ) := by
    simpa [μA, firstA] using
      (im05_algorithm42FreshList_countWeight_first_draw_prob_eq_count_ratio
        (Name := Name) count hcount_available
        (k := k + 1) hk_le_card head)
  have hfirstA_pos : 0 < EconCSLib.pmfProb μA firstA := by
    rw [hfirstA_ratio]
    exact div_pos
      (by exact_mod_cast hcount_pos head)
      (by
        exact_mod_cast
          im05_sum_count_pos_of_pos count head (hcount_pos head))
  have hfirstM_pos : 0 < EconCSLib.pmfProb μM firstM := by
    rw [hfirst_eq]
    exact hfirstA_pos
  have hcond_eq :
      EconCSLib.pmfConditionalProb μM firstM secondM =
        EconCSLib.pmfConditionalProb μA firstA secondA := by
    simpa [μM, μA, firstM, secondM, firstA, secondA] using
      (im05_integerMultisetPermutationFirstAppearanceFreshList_second_conditional_prob_eq_countWeight_freshList_second_conditional_prob
        (Name := Name) count hcount_pos hcount_available hk_le_card
        head target hneq)
  have hchainM :
      EconCSLib.pmfProb μM jointM =
        EconCSLib.pmfConditionalProb μM firstM secondM *
          EconCSLib.pmfProb μM firstM := by
    rw [EconCSLib.pmfProb_eq_mul_conditionalProb_of_imp
      μM firstM jointM (by intro sample h; exact h.1) hfirstM_pos]
    have hcond :
        EconCSLib.pmfConditionalProb μM firstM jointM =
          EconCSLib.pmfConditionalProb μM firstM secondM :=
      EconCSLib.pmfConditionalProb_congr_of_condition μM
        firstM jointM secondM
        (by
          intro sample hfirst
          constructor
          · intro hjoint
            exact hjoint.2
          · intro hsecond
            exact ⟨hfirst, hsecond⟩)
    rw [hcond]
  have hchainA :
      EconCSLib.pmfProb μA jointA =
        EconCSLib.pmfConditionalProb μA firstA secondA *
          EconCSLib.pmfProb μA firstA := by
    rw [EconCSLib.pmfProb_eq_mul_conditionalProb_of_imp
      μA firstA jointA (by intro sample h; exact h.1) hfirstA_pos]
    have hcond :
        EconCSLib.pmfConditionalProb μA firstA jointA =
          EconCSLib.pmfConditionalProb μA firstA secondA :=
      EconCSLib.pmfConditionalProb_congr_of_condition μA
        firstA jointA secondA
        (by
          intro sample hfirst
          constructor
          · intro hjoint
            exact hjoint.2
          · intro hsecond
            exact ⟨hfirst, hsecond⟩)
    rw [hcond]
  change EconCSLib.pmfProb μM jointM = EconCSLib.pmfProb μA jointA
  rw [hchainM, hchainA, hcond_eq, hfirst_eq]

/--
Second-slot marginal finite-law bridge: the second first-appearance name in the
uniform count-vector model has the same marginal law as the second draw in
Algorithm 4.2 with raw count weights.
-/
theorem
    im05_integerMultisetPermutationFirstAppearanceFreshList_second_prob_eq_countWeight_freshList_second_prob
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (hk_le_card : k + 2 ≤ Fintype.card Name)
    (target : Name) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          (im05_integerMultisetPermutationFirstAppearanceFreshList
            hcount_pos sample).1
              ⟨1, by omega⟩ = target) =
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 2) hk_le_card)
        (fun sample =>
          im05_algorithm42FreshListDraw sample
              ⟨1, by omega⟩ = target) := by
  classical
  let μM :=
    EconCSLib.uniformPMF
      (im05_integerMultisetPermutationSample Name count)
  let μA :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available (k + 2) hk_le_card
  let secondM : im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      (im05_integerMultisetPermutationFirstAppearanceFreshList
        hcount_pos sample).1
          ⟨1, by omega⟩ = target
  let firstValueM : im05_integerMultisetPermutationSample Name count → Name :=
    fun sample =>
      (im05_integerMultisetPermutationFirstAppearanceFreshList
        hcount_pos sample).1
          ⟨0, Fintype.card_pos_iff.mpr ⟨target⟩⟩
  let secondA : im05_algorithm42FreshListSample Name (k + 2) → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample
        ⟨1, by omega⟩ = target
  let firstValueA : im05_algorithm42FreshListSample Name (k + 2) → Name :=
    fun sample =>
      im05_algorithm42FreshListDraw sample
        ⟨0, by omega⟩
  rw [EconCSLib.pmfProb_eq_sum_state_inter μM secondM firstValueM]
  rw [EconCSLib.pmfProb_eq_sum_state_inter μA secondA firstValueA]
  refine Finset.sum_congr rfl ?_
  intro head _hhead
  by_cases hneq : target ≠ head
  · have htermM :
        EconCSLib.pmfProb μM
            (fun sample => secondM sample ∧ firstValueM sample = head) =
          EconCSLib.pmfProb μM
            (fun sample =>
              firstValueM sample = head ∧ secondM sample) := by
        exact
          EconCSLib.pmfProb_congr μM
            (by intro sample; exact and_comm)
    have htermA :
        EconCSLib.pmfProb μA
            (fun sample => secondA sample ∧ firstValueA sample = head) =
          EconCSLib.pmfProb μA
            (fun sample =>
              firstValueA sample = head ∧ secondA sample) := by
        exact
          EconCSLib.pmfProb_congr μA
            (by intro sample; exact and_comm)
    rw [htermM, htermA]
    simpa [μM, μA, firstValueM, secondM, firstValueA, secondA] using
      (im05_integerMultisetPermutationFirstAppearanceFreshList_first_second_prob_eq_countWeight_freshList_first_second_prob
        (Name := Name) count hcount_pos hcount_available hk_le_card
        head target hneq)
  · have hhead_eq : head = target := by
      by_contra hne
      exact hneq (Ne.symm hne)
    subst head
    have hzeroM :
        EconCSLib.pmfProb μM
            (fun sample => secondM sample ∧ firstValueM sample = target) =
          0 := by
      refine EconCSLib.pmfProb_eq_zero_of_no_mass μM _ ?_
      intro sample hsample
      exfalso
      let fresh :=
        im05_integerMultisetPermutationFirstAppearanceFreshList
          hcount_pos sample
      have hinj : Function.Injective fresh.1 := fresh.2.1
      have hvalue_eq :
          fresh.1 ⟨0, Fintype.card_pos_iff.mpr ⟨target⟩⟩ =
            fresh.1 ⟨1, by omega⟩ := by
        dsimp [secondM, firstValueM, fresh] at hsample
        exact hsample.2.trans hsample.1.symm
      have hslot_eq := hinj hvalue_eq
      have hslot_ne :
          (⟨0, Fintype.card_pos_iff.mpr ⟨target⟩⟩ :
            Fin (Fintype.card Name)) ≠
            ⟨1, by omega⟩ := by
        intro h
        have hval := congrArg Fin.val h
        norm_num at hval
      exact hslot_ne hslot_eq
    have hzeroA :
        EconCSLib.pmfProb μA
            (fun sample => secondA sample ∧ firstValueA sample = target) =
          0 := by
      refine EconCSLib.pmfProb_eq_zero_of_no_mass μA _ ?_
      intro sample hsample
      exfalso
      have hinj : Function.Injective (im05_algorithm42FreshListDraw sample) :=
        im05_algorithm42FreshListDraw_injective sample
      have hvalue_eq :
          im05_algorithm42FreshListDraw sample ⟨0, by omega⟩ =
            im05_algorithm42FreshListDraw sample ⟨1, by omega⟩ := by
        dsimp [secondA, firstValueA] at hsample
        exact hsample.2.trans hsample.1.symm
      have hslot_eq := hinj hvalue_eq
      have hslot_ne :
          (⟨0, by omega⟩ : Fin (k + 2)) ≠ ⟨1, by omega⟩ := by
        intro h
        have hval := congrArg Fin.val h
        norm_num at hval
      exact hslot_ne hslot_eq
    rw [hzeroM, hzeroA]

/--
Two-prefix omission finite-law bridge: the first two distinct names in a
uniform count-vector word omit `target` with the same probability as the first
two draws of Algorithm 4.2 with raw count weights.
-/
theorem
    im05_integerMultisetPermutationFirstAppearanceFreshList_prefix_two_omits_prob_eq_countWeight_freshList_prefix_two_omits_prob
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (hk_le_card : k + 2 ≤ Fintype.card Name)
    (target : Name) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_listPrefixOmits target 2
            (im05_integerMultisetPermutationFirstAppearanceFreshList
              hcount_pos sample).1) =
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 2) hk_le_card)
        (fun sample =>
          im05_listPrefixOmits target 2
            (im05_algorithm42FreshListDraw sample)) := by
  classical
  let μM :=
    EconCSLib.uniformPMF
      (im05_integerMultisetPermutationSample Name count)
  let μA :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available (k + 2) hk_le_card
  have hcard_pos : 0 < Fintype.card Name :=
    Fintype.card_pos_iff.mpr ⟨target⟩
  have hcard_two : 1 < Fintype.card Name := by omega
  have halg_pos : 0 < k + 2 := by omega
  have halg_two : 1 < k + 2 := by omega
  let firstM : im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      (im05_integerMultisetPermutationFirstAppearanceFreshList
        hcount_pos sample).1 ⟨0, hcard_pos⟩ = target
  let secondM : im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      (im05_integerMultisetPermutationFirstAppearanceFreshList
        hcount_pos sample).1 ⟨1, hcard_two⟩ = target
  let firstA : im05_algorithm42FreshListSample Name (k + 2) → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample ⟨0, halg_pos⟩ = target
  let secondA : im05_algorithm42FreshListSample Name (k + 2) → Prop :=
    fun sample =>
      im05_algorithm42FreshListDraw sample ⟨1, halg_two⟩ = target
  have homitM :
      EconCSLib.pmfProb μM
          (fun sample =>
            im05_listPrefixOmits target 2
              (im05_integerMultisetPermutationFirstAppearanceFreshList
                hcount_pos sample).1) =
        EconCSLib.pmfProb μM
          (fun sample => ¬ firstM sample ∧ ¬ secondM sample) :=
    EconCSLib.pmfProb_congr μM
      (by
        intro sample
        simpa [firstM, secondM] using
          (im05_listPrefixOmits_two_iff target
            (im05_integerMultisetPermutationFirstAppearanceFreshList
              hcount_pos sample).1 hcard_pos hcard_two))
  have homitA :
      EconCSLib.pmfProb μA
          (fun sample =>
            im05_listPrefixOmits target 2
              (im05_algorithm42FreshListDraw sample)) =
        EconCSLib.pmfProb μA
          (fun sample => ¬ firstA sample ∧ ¬ secondA sample) :=
    EconCSLib.pmfProb_congr μA
      (by
        intro sample
        simpa [firstA, secondA] using
          (im05_listPrefixOmits_two_iff target
            (im05_algorithm42FreshListDraw sample) halg_pos halg_two))
  have hdisjointM : ∀ sample, firstM sample → secondM sample → False := by
    intro sample hfirst hsecond
    let fresh :=
      im05_integerMultisetPermutationFirstAppearanceFreshList
        hcount_pos sample
    have hinj : Function.Injective fresh.1 := fresh.2.1
    have hvalue_eq :
        fresh.1 ⟨0, hcard_pos⟩ = fresh.1 ⟨1, hcard_two⟩ := by
      dsimp [firstM, secondM, fresh] at hfirst hsecond
      exact hfirst.trans hsecond.symm
    have hslot_eq := hinj hvalue_eq
    have hslot_ne :
        (⟨0, hcard_pos⟩ : Fin (Fintype.card Name)) ≠
          ⟨1, hcard_two⟩ := by
      intro h
      have hval := congrArg Fin.val h
      norm_num at hval
    exact hslot_ne hslot_eq
  have hdisjointA : ∀ sample, firstA sample → secondA sample → False := by
    intro sample hfirst hsecond
    have hinj : Function.Injective (im05_algorithm42FreshListDraw sample) :=
      im05_algorithm42FreshListDraw_injective sample
    have hvalue_eq :
        im05_algorithm42FreshListDraw sample ⟨0, halg_pos⟩ =
          im05_algorithm42FreshListDraw sample ⟨1, halg_two⟩ := by
      dsimp [firstA, secondA] at hfirst hsecond
      exact hfirst.trans hsecond.symm
    have hslot_eq := hinj hvalue_eq
    have hslot_ne :
        (⟨0, halg_pos⟩ : Fin (k + 2)) ≠ ⟨1, halg_two⟩ := by
      intro h
      have hval := congrArg Fin.val h
      norm_num at hval
    exact hslot_ne hslot_eq
  have hfirst_eq :
      EconCSLib.pmfProb μM firstM =
        EconCSLib.pmfProb μA firstA := by
    simpa [μM, μA, firstM, firstA] using
      (im05_integerMultisetPermutationFirstAppearanceFreshList_first_prob_eq_countWeight_freshList_first_prob
        (Name := Name) count hcount_pos hcount_available
        (k := k + 1) hk_le_card target)
  have hsecond_eq :
      EconCSLib.pmfProb μM secondM =
        EconCSLib.pmfProb μA secondA := by
    simpa [μM, μA, secondM, secondA] using
      (im05_integerMultisetPermutationFirstAppearanceFreshList_second_prob_eq_countWeight_freshList_second_prob
        (Name := Name) count hcount_pos hcount_available hk_le_card target)
  change
      EconCSLib.pmfProb μM
          (fun sample =>
            im05_listPrefixOmits target 2
              (im05_integerMultisetPermutationFirstAppearanceFreshList
                hcount_pos sample).1) =
        EconCSLib.pmfProb μA
          (fun sample =>
            im05_listPrefixOmits target 2
              (im05_algorithm42FreshListDraw sample))
  rw [homitM, homitA]
  rw [EconCSLib.pmfProb_not_and_not_eq_one_sub_add_of_disjoint
    μM firstM secondM hdisjointM]
  rw [EconCSLib.pmfProb_not_and_not_eq_one_sub_add_of_disjoint
    μA firstA secondA hdisjointA]
  rw [hfirst_eq, hsecond_eq]

/--
The marginal finite law required by the Lemma 4.4 wrapper is closed for
`k = 2`.
-/
theorem im05_integerMultisetPermutation_base_finite_law_two
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (hcard_two : 2 ≤ Fintype.card Name)
    (target : Name) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 2 hcard_two)
        (fun sample =>
          im05_listPrefixOmits target 2
            (im05_algorithm42FreshListDraw sample)) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          2 ≤
            (im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList sample)).card) := by
  classical
  let μM :=
    EconCSLib.uniformPMF
      (im05_integerMultisetPermutationSample Name count)
  have hsource :
      EconCSLib.pmfProb μM
          (fun sample =>
            im05_listPrefixOmits target 2
              (im05_integerMultisetPermutationFirstAppearanceFreshList
                hcount_pos sample).1) =
        EconCSLib.pmfProb μM
          (fun sample =>
            2 ≤
              (im05_namesBeforeFirst id target
                (im05_integerMultisetPermutationList sample)).card) :=
    EconCSLib.pmfProb_congr μM
      (by
        intro sample
        exact
          im05_integerMultisetPermutationFirstAppearanceFreshList_prefix_omits_iff_namesBeforeFirst_card
            hcount_pos sample target 2)
  rw [← hsource]
  exact
    (im05_integerMultisetPermutationFirstAppearanceFreshList_prefix_two_omits_prob_eq_countWeight_freshList_prefix_two_omits_prob
      (Name := Name) count hcount_pos hcount_available
      (k := 0) (by simpa using hcard_two) target).symm

/--
`k = 2` marginal finite law with support derived from the availability
assumption.
-/
theorem im05_integerMultisetPermutation_base_finite_law_two_of_available
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
