        (hblockers.1 t ht hactive hnonTarget hreject mu hstable hmu_w
          r hr hbetter)
  · intro t ht hactive hnonTarget haccept cur hcur mu hstable
    exact
      im05_not_exception_match_of_not_mem_stableHusbands
