/--
Algorithm 4.2 conditional omission probability convergence.  Full support of
the limiting weights supplies the positive limiting conditioning event, so the
conditional probability follows from convergence of the intersection and
conditioning events.
-/
theorem paper_im05_algorithm4_2_freshList_conditional_omit_tendsto
    {W : Type*} [Fintype W] [DecidableEq W]
    (weightSeq : ℕ → W → ℝ) (prob : W → ℝ)
    (hseq_nonneg : ∀ scale u, 0 ≤ weightSeq scale u)
    (hseq_available : ∀ scale, ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight (weightSeq scale) forbidden)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_pos : ∀ u, 0 < prob u)
    (havailable : ∀ forbidden : Finset W,
      forbidden.card < Fintype.card W →
        0 < EconCSLib.finiteAvailableWeight prob forbidden)
    (hweight : ∀ u : W,
      Filter.Tendsto (fun scale : ℕ => weightSeq scale u)
        Filter.atTop (nhds (prob u)))
    {k : ℕ} (hk_le_card : k ≤ Fintype.card W)
    (hk_lt_card : k < Fintype.card W) (i j : W)
    [DecidablePred fun sample : im05_algorithm42FreshListSample W k =>
      im05_listPrefixOmits i k (im05_algorithm42FreshListDraw sample)]
    [DecidablePred fun sample : im05_algorithm42FreshListSample W k =>
      im05_listPrefixOmits j k (im05_algorithm42FreshListDraw sample)] :
    Filter.Tendsto
      (fun scale : ℕ =>
        EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF
            (weightSeq scale) (hseq_nonneg scale)
            (hseq_available scale) k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)))
      Filter.atTop
      (nhds
        (EconCSLib.pmfConditionalProb
          (im05_algorithm42FreshListPMF
            prob hprob_nonneg havailable k hk_le_card)
          (fun sample =>
            im05_listPrefixOmits j k
              (im05_algorithm42FreshListDraw sample))
          (fun sample =>
            im05_listPrefixOmits i k
              (im05_algorithm42FreshListDraw sample)))) := by
  classical
  let μSeq : ℕ → PMF (im05_algorithm42FreshListSample W k) :=
    fun scale =>
      im05_algorithm42FreshListPMF
        (weightSeq scale) (hseq_nonneg scale)
        (hseq_available scale) k hk_le_card
  let μ : PMF (im05_algorithm42FreshListSample W k) :=
    im05_algorithm42FreshListPMF
      prob hprob_nonneg havailable k hk_le_card
  let condition : im05_algorithm42FreshListSample W k → Prop :=
    fun sample =>
      im05_listPrefixOmits j k (im05_algorithm42FreshListDraw sample)
  let target : im05_algorithm42FreshListSample W k → Prop :=
    fun sample =>
      im05_listPrefixOmits i k (im05_algorithm42FreshListDraw sample)
  have hcondition_pos : 0 < EconCSLib.pmfProb μ condition := by
    simpa [μ, condition] using
      paper_im05_algorithm4_2_freshList_omit_pos_of_full_support
        prob hprob_nonneg hprob_pos havailable hk_le_card hk_lt_card j
  have hinter :
      Filter.Tendsto
        (fun scale : ℕ =>
          EconCSLib.pmfProb (μSeq scale)
            (fun sample => condition sample ∧ target sample))
        Filter.atTop
        (nhds
          (EconCSLib.pmfProb μ
            (fun sample => condition sample ∧ target sample))) := by
    simpa [μSeq, μ, condition, target] using
      paper_im05_algorithm4_2_freshList_event_prob_tendsto
        weightSeq prob hseq_nonneg hseq_available
        hprob_nonneg havailable hweight hk_le_card
        (fun sample : im05_algorithm42FreshListSample W k =>
          im05_listPrefixOmits j k (im05_algorithm42FreshListDraw sample) ∧
            im05_listPrefixOmits i k (im05_algorithm42FreshListDraw sample))
  have hcondition :
      Filter.Tendsto
        (fun scale : ℕ => EconCSLib.pmfProb (μSeq scale) condition)
        Filter.atTop
        (nhds (EconCSLib.pmfProb μ condition)) := by
    simpa [μSeq, μ, condition] using
      paper_im05_algorithm4_2_freshList_omit_prob_tendsto
        weightSeq prob hseq_nonneg hseq_available
        hprob_nonneg havailable hweight hk_le_card j
  have hcond_tendsto :=
    EconCSLib.pmfConditionalProb_tendsto_of_inter_tendsto_of_condition_tendsto
      μSeq μ condition target hcondition_pos hinter hcondition
  simpa [μSeq, μ, condition, target] using hcond_tendsto

/--
Lemma 4.3 Algorithm 4.2 instantiation: the exact filtered-draw atom formula,
combined with the rank-tail algebra, gives the per-prefix next-hit upper bound
used by the deferred-decision product route.
-/
theorem paper_im05_lemma4_3_next_hit_le_from_algorithm4_2_filtered_draw
    {W : Type*} [Fintype W] [DecidableEq W]
    (tail previous : Finset W) (prob : W → ℝ) (w : W)
    (Q prevMass : ℝ) (rank k : ℕ)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_sum : ∑ u : W, prob u = 1)
    (hprevMass : prevMass = ∑ u ∈ previous, prob u)
    (havailable_pos : 0 < EconCSLib.finiteAvailableWeight prob previous)
    (hw_not_previous : w ∉ previous)
    (hprev_le_Q : prevMass ≤ Q)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (hk_rank : k < rank)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u) :
    (EconCSLib.finiteWeightedPMFExcluding
        prob previous hprob_nonneg havailable_pos w).toReal ≤
      1 / ((rank - k : ℕ) : ℝ) := by
  exact
    paper_im05_lemma4_3_conditional_next_hit_le_from_rank_tail_formula
      tail prob w Q prevMass
      ((EconCSLib.finiteWeightedPMFExcluding
        prob previous hprob_nonneg havailable_pos w).toReal)
      rank k (hprob_nonneg w) hprev_le_Q hQ_pos hcard hk_rank
      hmass_tail_le hpopular
      (paper_im05_algorithm4_2_filtered_draw_atom_formula
        prob previous w prevMass hprob_nonneg hprob_sum hprevMass
        havailable_pos hw_not_previous)

/--
Lemma 4.3 prefix-state refinement: if every positive-probability realized
prefix state has next-hit probability at most `1/(rank-k)`, then the same bound
holds after conditioning only on the coarser event that the prefix omits `w`.
-/
theorem paper_im05_lemma4_3_next_hit_le_from_prefix_state_bounds
    {Λ S W : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype S] [DecidableEq S] [DecidableEq W]
    {k r : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    (state : Λ → S) (rank : ℕ) (hr : r < k)
    [DecidablePred fun sample => im05_listPrefixOmits w r (draw sample)]
    (hprefix_pos :
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample)))
    (hstate_hit : ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state sample = s) →
      EconCSLib.pmfConditionalProb ν
          (fun sample =>
            im05_listPrefixOmits w r (draw sample) ∧ state sample = s)
          (fun sample => draw sample ⟨r, hr⟩ = w) ≤
        1 / ((rank - k : ℕ) : ℝ)) :
    EconCSLib.pmfConditionalProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample))
        (fun sample => draw sample ⟨r, hr⟩ = w) ≤
      1 / ((rank - k : ℕ) : ℝ) := by
  classical
  have hc_nonneg : 0 ≤ 1 / ((rank - k : ℕ) : ℝ) := by
    positivity
  exact
    EconCSLib.pmfConditionalProb_le_of_state_refinement
      ν
      (fun sample => im05_listPrefixOmits w r (draw sample))
      (fun sample => draw sample ⟨r, hr⟩ = w)
      state hc_nonneg hprefix_pos hstate_hit

/--
Algorithm 4.2 prefix-state instantiation of the Lemma 4.3 next-hit bound.  A
statewise exact filtered-draw law for every realized prefix state implies the
coarser next-hit upper bound needed by the list-prefix product argument.
-/
theorem paper_im05_lemma4_3_next_hit_le_from_algorithm4_2_prefix_states
    {Λ S W : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype S] [DecidableEq S] [Fintype W] [DecidableEq W]
    {k r : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    (state : Λ → S) (tail : Finset W) (prob : W → ℝ)
    (previous : S → Finset W) (prevMass : S → ℝ)
    (Q : ℝ) (rank : ℕ) (hr : r < k)
    [DecidablePred fun sample => im05_listPrefixOmits w r (draw sample)]
    (hprefix_pos :
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample)))
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_sum : ∑ u : W, prob u = 1)
    (hprevMass : ∀ s, prevMass s = ∑ u ∈ previous s, prob u)
    (havailable_pos : ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state sample = s) →
      0 < EconCSLib.finiteAvailableWeight prob (previous s))
    (hw_not_previous : ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state sample = s) →
      w ∉ previous s)
    (hprev_le_Q : ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state sample = s) →
      prevMass s ≤ Q)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (hk_rank : k < rank)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u)
    (hcond_eq : ∀ s : S, (hspos :
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state sample = s)) →
      EconCSLib.pmfConditionalProb ν
          (fun sample =>
            im05_listPrefixOmits w r (draw sample) ∧ state sample = s)
          (fun sample => draw sample ⟨r, hr⟩ = w) =
        (EconCSLib.finiteWeightedPMFExcluding
          prob (previous s) hprob_nonneg (havailable_pos s hspos) w).toReal) :
    EconCSLib.pmfConditionalProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample))
        (fun sample => draw sample ⟨r, hr⟩ = w) ≤
      1 / ((rank - k : ℕ) : ℝ) := by
  classical
  exact
    paper_im05_lemma4_3_next_hit_le_from_prefix_state_bounds
      ν draw w state rank hr hprefix_pos
      (by
        intro s hspos
        rw [hcond_eq s hspos]
        exact
          paper_im05_lemma4_3_next_hit_le_from_algorithm4_2_filtered_draw
            tail (previous s) prob w Q (prevMass s) rank k
            hprob_nonneg hprob_sum (hprevMass s) (havailable_pos s hspos)
            (hw_not_previous s hspos) (hprev_le_Q s hspos) hQ_pos hcard hk_rank
            hmass_tail_le hpopular)

/--
Lemma 4.3 one-man deferred-decision product step: if the prefix-omission
events are nested and every exposed draw has conditional omission probability
at least `1 - 1/(rank-k)`, then a single man's length-`k` list omits `w` with
probability at least `(1 - 1/(rank-k))^k`.
-/
theorem
    paper_im05_lemma4_3_one_man_omit_probability_ge_rank_power_from_prefix_bounds
    {Λ : Type*} [Fintype Λ] [DecidableEq Λ]
    (ν : PMF Λ) (prefixOmit : ℕ → Λ → Prop)
    [∀ r, DecidablePred fun sample => prefixOmit r sample]
    (rank k : ℕ)
    (hk_rank : k < rank)
    (hzero : ∀ sample, prefixOmit 0 sample)
    (hnested : ∀ r, r < k →
      ∀ sample, prefixOmit (r + 1) sample → prefixOmit r sample)
    (hcond : ∀ r, r < k →
      1 - 1 / ((rank - k : ℕ) : ℝ) ≤
        EconCSLib.pmfConditionalProb ν
          (fun sample => prefixOmit r sample)
          (fun sample => prefixOmit (r + 1) sample)) :
    (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ k ≤
      EconCSLib.pmfProb ν (fun sample => prefixOmit k sample) := by
  classical
  have hdenom_pos_nat : 0 < rank - k := Nat.sub_pos_of_lt hk_rank
  have hdenom_pos : 0 < ((rank - k : ℕ) : ℝ) := by
    exact_mod_cast hdenom_pos_nat
  have hdenom_ge_one : (1 : ℝ) ≤ ((rank - k : ℕ) : ℝ) := by
    exact_mod_cast (Nat.succ_le_iff.mpr hdenom_pos_nat)
  have hbase_nonneg : 0 ≤ 1 - 1 / ((rank - k : ℕ) : ℝ) := by
    rw [sub_nonneg]
    rw [div_le_one hdenom_pos]
    exact hdenom_ge_one
  exact
    EconCSLib.pmfProb_ge_pow_of_nested_conditionalProb_ge
      ν prefixOmit k hbase_nonneg hzero hnested hcond

/--
Lemma 4.3 independence algebra: if a single man's list omits `w` with
probability at least `(1 - 1/(rank-k))^k`, and the all-men absence event is the
`n`th power of the single-man event, then the all-men absence probability is at
least `(1 - 1/(rank-k))^(n*k)`.
-/
theorem paper_im05_lemma4_3_all_men_absence_probability_ge_rank_power_from_one_man
    {oneProb absenceProb : ℝ} (rank k n : ℕ)
    (hk_rank : k < rank)
    (hone :
      (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ k ≤ oneProb)
    (hall : absenceProb = oneProb ^ n) :
    (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ (n * k) ≤ absenceProb := by
  have hdenom_pos_nat : 0 < rank - k := Nat.sub_pos_of_lt hk_rank
  have hdenom_pos : 0 < ((rank - k : ℕ) : ℝ) := by
    exact_mod_cast hdenom_pos_nat
  have hdenom_ge_one : (1 : ℝ) ≤ ((rank - k : ℕ) : ℝ) := by
    exact_mod_cast (Nat.succ_le_iff.mpr hdenom_pos_nat)
  let base : ℝ := 1 - 1 / ((rank - k : ℕ) : ℝ)
  have hbase_nonneg : 0 ≤ base := by
    dsimp [base]
    rw [sub_nonneg]
    rw [div_le_one hdenom_pos]
    exact hdenom_ge_one
  have hpow_nonneg : 0 ≤ base ^ k := pow_nonneg hbase_nonneg k
  calc
    (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ (n * k)
        = (base ^ k) ^ n := by
          dsimp [base]
          rw [Nat.mul_comm n k]
          rw [pow_mul]
    _ ≤ oneProb ^ n := pow_le_pow_left₀ hpow_nonneg (by simpa [base] using hone) n
    _ = absenceProb := hall.symm

/--
Lemma 4.3 source-route product wrapper: one-man deferred-decision prefix
bounds plus an `n`th-power independence identity imply the rank-power lower
bound for the all-men absence event.
-/
theorem
    paper_im05_lemma4_3_absence_probability_ge_rank_power_from_prefix_bounds
    {Λ Ω : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype Ω] [DecidableEq Ω]
    (ν : PMF Λ) (prefixOmit : ℕ → Λ → Prop)
    (μ : PMF Ω) (absent : Ω → Prop)
    [∀ r, DecidablePred fun sample => prefixOmit r sample]
    [DecidablePred absent]
    (rank k n : ℕ)
    (hk_rank : k < rank)
    (hzero : ∀ sample, prefixOmit 0 sample)
    (hnested : ∀ r, r < k →
      ∀ sample, prefixOmit (r + 1) sample → prefixOmit r sample)
    (hcond : ∀ r, r < k →
      1 - 1 / ((rank - k : ℕ) : ℝ) ≤
        EconCSLib.pmfConditionalProb ν
          (fun sample => prefixOmit r sample)
          (fun sample => prefixOmit (r + 1) sample))
    (hall :
      EconCSLib.pmfProb μ absent =
        (EconCSLib.pmfProb ν (fun sample => prefixOmit k sample)) ^ n) :
    (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ (n * k) ≤
      EconCSLib.pmfProb μ absent := by
  exact
    paper_im05_lemma4_3_all_men_absence_probability_ge_rank_power_from_one_man
      rank k n hk_rank
      (paper_im05_lemma4_3_one_man_omit_probability_ge_rank_power_from_prefix_bounds
        ν prefixOmit rank k hk_rank hzero hnested hcond)
      hall

/--
Lemma 4.3 list-prefix step: if, conditional on the current prefix having
omitted `w`, the next in-range list slot hits `w` with probability at most
`1/(rank-k)`, then the next prefix omits `w` with conditional probability at
least `1 - 1/(rank-k)`.
-/
theorem paper_im05_lemma4_3_conditional_prefix_omit_ge_of_next_hit_le
    {Λ W : Type*} [Fintype Λ] [DecidableEq Λ] [DecidableEq W]
    {k r : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    [DecidablePred fun sample => im05_listPrefixOmits w r (draw sample)]
    [DecidablePred fun sample => im05_listPrefixOmits w (r + 1) (draw sample)]
    (rank : ℕ) (hr : r < k)
    (hprefix_pos :
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample)))
    (hhit :
      EconCSLib.pmfConditionalProb ν
          (fun sample => im05_listPrefixOmits w r (draw sample))
          (fun sample => draw sample ⟨r, hr⟩ = w) ≤
        1 / ((rank - k : ℕ) : ℝ)) :
    1 - 1 / ((rank - k : ℕ) : ℝ) ≤
      EconCSLib.pmfConditionalProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample))
        (fun sample => im05_listPrefixOmits w (r + 1) (draw sample)) := by
  classical
  have homit_slot :
      1 - 1 / ((rank - k : ℕ) : ℝ) ≤
        EconCSLib.pmfConditionalProb ν
          (fun sample => im05_listPrefixOmits w r (draw sample))
          (fun sample => draw sample ⟨r, hr⟩ ≠ w) := by
    exact
      EconCSLib.one_sub_le_pmfConditionalProb_compl_of_conditionalProb_le
        ν
        (fun sample => im05_listPrefixOmits w r (draw sample))
        (fun sample => draw sample ⟨r, hr⟩ = w)
        hprefix_pos hhit
  have hcongr :
      EconCSLib.pmfConditionalProb ν
          (fun sample => im05_listPrefixOmits w r (draw sample))
          (fun sample => draw sample ⟨r, hr⟩ ≠ w) =
        EconCSLib.pmfConditionalProb ν
          (fun sample => im05_listPrefixOmits w r (draw sample))
          (fun sample => im05_listPrefixOmits w (r + 1) (draw sample)) := by
    refine
      EconCSLib.pmfConditionalProb_congr_of_condition
        ν (fun sample => im05_listPrefixOmits w r (draw sample))
        (fun sample => draw sample ⟨r, hr⟩ ≠ w)
        (fun sample => im05_listPrefixOmits w (r + 1) (draw sample))
        ?_
    intro sample hprefix_sample
    constructor
    · intro hslot
      exact
        (im05_listPrefixOmits_succ_iff w (draw sample) hr).2
          ⟨hprefix_sample, hslot⟩
    · intro hnext
      exact ((im05_listPrefixOmits_succ_iff w (draw sample) hr).1 hnext).2
  rw [hcongr] at homit_slot
  exact homit_slot

/--
Lemma 4.3 one-man list-law wrapper: for concrete length-`k` list samples, per
prefix positive probability plus per-slot conditional hit upper bounds imply
the one-man rank-power omission lower bound.
-/
theorem
    paper_im05_lemma4_3_one_man_omit_probability_ge_rank_power_from_next_hit_bounds
    {Λ W : Type*} [Fintype Λ] [DecidableEq Λ] [DecidableEq W]
    {k : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    [∀ s, DecidablePred fun sample => im05_listPrefixOmits w s (draw sample)]
    (rank : ℕ)
    (hk_rank : k < rank)
    (hprefix_pos : ∀ r, r < k →
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample)))
    (hhit : ∀ r, (hr : r < k) →
      EconCSLib.pmfConditionalProb ν
          (fun sample => im05_listPrefixOmits w r (draw sample))
          (fun sample => draw sample ⟨r, hr⟩ = w) ≤
        1 / ((rank - k : ℕ) : ℝ)) :
    (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ k ≤
      EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w k (draw sample)) := by
  classical
  exact
    paper_im05_lemma4_3_one_man_omit_probability_ge_rank_power_from_prefix_bounds
      ν (fun r sample => im05_listPrefixOmits w r (draw sample))
      rank k hk_rank
      (by intro sample; exact im05_listPrefixOmits_zero w (draw sample))
      (by
        intro r _hr sample hnext
        exact im05_listPrefixOmits_nested w (draw sample) hnext)
      (by
        intro r hr
        exact
          paper_im05_lemma4_3_conditional_prefix_omit_ge_of_next_hit_le
            ν draw w rank hr (hprefix_pos r hr) (hhit r hr))

/--
Lemma 4.3 one-man Algorithm 4.2 route: statewise filtered-draw laws for every
realized prefix state imply the one-man rank-power omission lower bound.
-/
theorem
    paper_im05_lemma4_3_one_man_omit_probability_ge_rank_power_from_algorithm4_2_prefix_states
    {Λ S W : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype S] [DecidableEq S] [Fintype W] [DecidableEq W]
    {k : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    (state : ℕ → Λ → S) (tail : Finset W) (prob : W → ℝ)
    (previous : ℕ → S → Finset W) (prevMass : ℕ → S → ℝ)
    (Q : ℝ) (rank : ℕ)
    [∀ s, DecidablePred fun sample => im05_listPrefixOmits w s (draw sample)]
    (hk_rank : k < rank)
    (hprefix_pos : ∀ r, r < k →
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample)))
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_sum : ∑ u : W, prob u = 1)
    (hprevMass : ∀ r s, prevMass r s = ∑ u ∈ previous r s, prob u)
    (havailable_pos : ∀ r, r < k → ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state r sample = s) →
      0 < EconCSLib.finiteAvailableWeight prob (previous r s))
    (hw_not_previous : ∀ r, r < k → ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state r sample = s) →
      w ∉ previous r s)
    (hprev_le_Q : ∀ r, r < k → ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state r sample = s) →
      prevMass r s ≤ Q)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u)
    (hcond_eq : ∀ r, (hr : r < k) → ∀ s : S, (hspos :
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧ state r sample = s)) →
      EconCSLib.pmfConditionalProb ν
          (fun sample =>
            im05_listPrefixOmits w r (draw sample) ∧ state r sample = s)
          (fun sample => draw sample ⟨r, hr⟩ = w) =
        (EconCSLib.finiteWeightedPMFExcluding
          prob (previous r s) hprob_nonneg (havailable_pos r hr s hspos) w).toReal) :
    (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ k ≤
      EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w k (draw sample)) := by
  classical
  exact
    paper_im05_lemma4_3_one_man_omit_probability_ge_rank_power_from_next_hit_bounds
      ν draw w rank hk_rank hprefix_pos
      (by
        intro r hr
        exact
          paper_im05_lemma4_3_next_hit_le_from_algorithm4_2_prefix_states
            ν draw w (state r) tail prob (previous r) (prevMass r)
            Q rank hr (hprefix_pos r hr) hprob_nonneg hprob_sum
            (hprevMass r) (havailable_pos r hr) (hw_not_previous r hr)
            (hprev_le_Q r hr) hQ_pos hcard hk_rank hmass_tail_le hpopular
            (hcond_eq r hr))

/--
Lemma 4.3 one-man Algorithm 4.2 prefix-set route: specialize the abstract
state to the actual set of women already drawn in the first `r` slots.  The
fact that the target woman is not in the previous set is then derived from the
coarse prefix-omission event.
-/
theorem
    paper_im05_lemma4_3_one_man_omit_probability_ge_rank_power_from_algorithm4_2_prefix_sets
    {Λ W : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype W] [DecidableEq W]
    {k : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → W) (w : W)
    (tail : Finset W) (prob : W → ℝ)
    (Q : ℝ) (rank : ℕ)
    [∀ s, DecidablePred fun sample => im05_listPrefixOmits w s (draw sample)]
    (hk_rank : k < rank)
    (hprefix_pos : ∀ r, r < k →
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w r (draw sample)))
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_sum : ∑ u : W, prob u = 1)
    (hprev_le_Q : ∀ r, (hr : r < k) → ∀ previous : Finset W,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧
            im05_listPrefixSet r (draw sample) = previous) →
      (∑ u ∈ previous, prob u) ≤ Q)
    (hQ_pos : 0 < 1 - Q)
    (hcard : tail.card = rank - k)
    (hmass_tail_le : (∑ u ∈ tail, prob u) ≤ 1 - Q)
    (hpopular : ∀ u ∈ tail, prob w ≤ prob u)
    (hcond_eq : ∀ r, (hr : r < k) → ∀ previous : Finset W, (hspos :
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits w r (draw sample) ∧
            im05_listPrefixSet r (draw sample) = previous)) →
      (havailable_pos : 0 < EconCSLib.finiteAvailableWeight prob previous) →
      EconCSLib.pmfConditionalProb ν
          (fun sample =>
            im05_listPrefixOmits w r (draw sample) ∧
              im05_listPrefixSet r (draw sample) = previous)
          (fun sample => draw sample ⟨r, hr⟩ = w) =
        (EconCSLib.finiteWeightedPMFExcluding
          prob previous hprob_nonneg havailable_pos w).toReal) :
    (1 - 1 / ((rank - k : ℕ) : ℝ)) ^ k ≤
      EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits w k (draw sample)) := by
  classical
  refine
    paper_im05_lemma4_3_one_man_omit_probability_ge_rank_power_from_algorithm4_2_prefix_states
      ν draw w
      (fun r sample => im05_listPrefixSet r (draw sample))
      tail prob
      (fun _r previous => previous)
      (fun _r previous => ∑ u ∈ previous, prob u)
      Q rank hk_rank hprefix_pos hprob_nonneg hprob_sum
      (by intro _r _previous; rfl)
      (by
        intro r hr previous hspos
        have hprev := hprev_le_Q r hr previous hspos
        have havail_eq :
            EconCSLib.finiteAvailableWeight prob previous =
              1 - ∑ u ∈ previous, prob u :=
          EconCSLib.finiteAvailableWeight_eq_one_sub_forbidden_mass
            prob previous (∑ u ∈ previous, prob u) hprob_sum rfl
        rw [havail_eq]
        linarith)
      ?_
      hprev_le_Q hQ_pos hcard hmass_tail_le hpopular
      (by
        intro r hr previous hspos
        exact hcond_eq r hr previous hspos (by
          have hprev := hprev_le_Q r hr previous hspos
          have havail_eq :
              EconCSLib.finiteAvailableWeight prob previous =
                1 - ∑ u ∈ previous, prob u :=
            EconCSLib.finiteAvailableWeight_eq_one_sub_forbidden_mass
              prob previous (∑ u ∈ previous, prob u) hprob_sum rfl
          rw [havail_eq]
          linarith))
  intro r _hr previous hspos
  rcases
    (EconCSLib.pmfProb_pos_iff_exists_pos_mass ν
      (fun sample =>
        im05_listPrefixOmits w r (draw sample) ∧
          im05_listPrefixSet r (draw sample) = previous)).1 hspos
    with ⟨sample, hsample, _hmass⟩
  have hnot :
      w ∉ im05_listPrefixSet r (draw sample) :=
    (im05_listPrefixOmits_iff_not_mem_prefixSet w (draw sample)).1 hsample.1
  simpa [hsample.2] using hnot

