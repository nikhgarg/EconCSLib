/-- Decrementing a positive coordinate removes exactly one unit of total mass. -/
theorem im05_sum_decrementCount_of_pos
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (target : Name) (hpos : 0 < count target) :
    (∑ name : Name, im05_decrementCount count target name) =
      (∑ name : Name, count name) - 1 := by
  classical
  have hmem : target ∈ (Finset.univ : Finset Name) := by simp
  have hsum_dec :=
    Finset.sum_erase_add
      (s := (Finset.univ : Finset Name))
      (f := im05_decrementCount count target) (a := target) hmem
  have hsum_count :=
    Finset.sum_erase_add
      (s := (Finset.univ : Finset Name))
      (f := count) (a := target) hmem
  have herase :
      ∑ name ∈ (Finset.univ : Finset Name).erase target,
          im05_decrementCount count target name =
        ∑ name ∈ (Finset.univ : Finset Name).erase target,
          count name := by
    refine Finset.sum_congr rfl ?_
    intro name hname
    have hne : name ≠ target := by
      simpa using hname
    simp [im05_decrementCount_of_ne count hne]
  rw [herase] at hsum_dec
  calc
    (∑ name : Name, im05_decrementCount count target name)
        =
          (∑ name ∈ (Finset.univ : Finset Name).erase target,
              count name) + (count target - 1) := by
            rw [← hsum_dec]
            simp
    _ =
          ((∑ name ∈ (Finset.univ : Finset Name).erase target,
              count name) + count target) - 1 := by
            omega
      _ = (∑ name : Name, count name) - 1 := by
            rw [hsum_count]

/-- A positive coordinate makes the total count positive. -/
theorem im05_sum_count_pos_of_pos
    {Name : Type*} [Fintype Name]
    (count : Name → ℕ) (target : Name) (hpos : 0 < count target) :
    0 < ∑ name : Name, count name := by
  classical
  have hle : count target ≤ ∑ name : Name, count name :=
    Finset.single_le_sum
      (fun name _hname => Nat.zero_le (count name))
      (Finset.mem_univ target)
  exact lt_of_lt_of_le hpos hle

/-- After decrementing a positive coordinate, adding one recovers total mass. -/
theorem im05_sum_decrementCount_add_one_of_pos
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (target : Name) (hpos : 0 < count target) :
    (∑ name : Name, im05_decrementCount count target name) + 1 =
      ∑ name : Name, count name := by
  have hsum := im05_sum_decrementCount_of_pos count target hpos
  have htotal_pos := im05_sum_count_pos_of_pos count target hpos
  omega

/-- The decremented real count weight is the decremented natural count coerced. -/
theorem im05_countWeight_decrement
    {Name : Type*} [DecidableEq Name]
    (count : Name → ℕ) (target name : Name) :
    im05_countWeight (im05_decrementCount count target) name =
      (im05_decrementCount count target name : ℝ) := rfl

/-- The canonical count-vector list has the expected length. -/
theorem im05_countVectorList_length
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) :
    (im05_countVectorList count).length = ∑ name : Name, count name := by
  classical
  rw [im05_countVectorList, Multiset.length_toList,
    im05_countVectorMultiset_card]

/-- The canonical count-vector list has the prescribed occurrence counts. -/
theorem im05_countVectorList_count
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (target : Name) :
    (im05_countVectorList count).count target = count target := by
  classical
  rw [im05_countVectorList]
  rw [← Multiset.coe_count target (im05_countVectorMultiset count).toList]
  rw [Multiset.coe_toList]
  exact im05_countVectorMultiset_count count target

/--
Finite integer-multiset permutation sample space used in the source proof of
Lemma 4.4: a word of total length `sum count` whose occurrence count for each
name is the prescribed integer count.
-/
abbrev im05_integerMultisetPermutationSample
    (Name : Type*) [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) :=
  {word : Fin (∑ name : Name, count name) → Name //
    ∀ name : Name, im05_nameCountInWord word name = count name}

/-- Equal count vectors give equivalent integer-multiset sample spaces. -/
def im05_integerMultisetPermutationCountEquiv
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count₁ count₂ : Name → ℕ} (hcount : count₁ = count₂) :
    im05_integerMultisetPermutationSample Name count₁ ≃
      im05_integerMultisetPermutationSample Name count₂ := by
  subst hcount
  exact Equiv.refl _

/--
Reindexing the positions of an integer-multiset sample preserves the prescribed
count vector.
-/
noncomputable def im05_integerMultisetPermutationReindexEquiv
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (e :
      Fin (∑ name : Name, count name) ≃
        Fin (∑ name : Name, count name)) :
    im05_integerMultisetPermutationSample Name count ≃
      im05_integerMultisetPermutationSample Name count where
  toFun sample :=
    ⟨(fun slot => sample.1 (e slot)), by
      intro name
      rw [im05_nameCountInWord_comp_equiv sample.1 e name]
      exact sample.2 name⟩
  invFun sample :=
    ⟨(fun slot => sample.1 (e.symm slot)), by
      intro name
      rw [im05_nameCountInWord_comp_equiv sample.1 e.symm name]
      exact sample.2 name⟩
  left_inv sample := by
    ext slot
    simp
  right_inv sample := by
    ext slot
    simp

/-- The name list associated with an integer-multiset permutation sample. -/
def im05_integerMultisetPermutationList
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count) : List Name :=
  List.ofFn sample.1

@[simp]
theorem im05_integerMultisetPermutationList_countEquiv
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count₁ count₂ : Name → ℕ} (hcount : count₁ = count₂)
    (sample : im05_integerMultisetPermutationSample Name count₁) :
    im05_integerMultisetPermutationList
        (im05_integerMultisetPermutationCountEquiv hcount sample) =
      im05_integerMultisetPermutationList sample := by
  subst hcount
  rfl

@[simp]
theorem im05_integerMultisetPermutationCountEquiv_apply_symm
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count₁ count₂ : Name → ℕ} (hcount : count₁ = count₂)
    (sample : im05_integerMultisetPermutationSample Name count₂) :
    im05_integerMultisetPermutationCountEquiv hcount
        (im05_integerMultisetPermutationCountEquiv hcount.symm sample) =
      sample := by
  subst hcount
  rfl

@[simp]
theorem im05_integerMultisetPermutationCountEquiv_symm_apply
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count₁ count₂ : Name → ℕ} (hcount : count₁ = count₂)
    (sample : im05_integerMultisetPermutationSample Name count₁) :
    im05_integerMultisetPermutationCountEquiv hcount.symm
        (im05_integerMultisetPermutationCountEquiv hcount sample) =
      sample := by
  subst hcount
  rfl

/-- A sample's associated list has exactly the sample-space count vector. -/
theorem im05_integerMultisetPermutationList_count
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    (target : Name) :
    (im05_integerMultisetPermutationList sample).count target =
      count target := by
  classical
  rw [im05_integerMultisetPermutationList]
  rw [← im05_nameCountInWord_eq_count_ofFn sample.1 target]
  exact sample.2 target

/-- The slots in a count-vector sample occupied by a given target name. -/
def im05_integerMultisetPermutationNameSlots
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    (target : Name) : Finset (Fin (∑ name : Name, count name)) :=
  (Finset.univ : Finset (Fin (∑ name : Name, count name))).filter
    fun slot => sample.1 slot = target

@[simp]
theorem im05_mem_integerMultisetPermutationNameSlots_iff
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    (target : Name) (slot : Fin (∑ name : Name, count name)) :
    slot ∈ im05_integerMultisetPermutationNameSlots sample target ↔
      sample.1 slot = target := by
  simp [im05_integerMultisetPermutationNameSlots]

/-- The target-slot set in a count-vector sample has cardinality `count target`. -/
theorem im05_integerMultisetPermutationNameSlots_card
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    (target : Name) :
    (im05_integerMultisetPermutationNameSlots sample target).card =
      count target := by
  simpa [im05_integerMultisetPermutationNameSlots, im05_nameCountInWord]
    using sample.2 target

/-- A zero prescribed count means no slot of the sample carries that name. -/
theorem im05_integerMultisetPermutation_ne_of_count_zero
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    {target : Name} (hzero : count target = 0)
    (slot : Fin (∑ name : Name, count name)) :
    sample.1 slot ≠ target := by
  intro hslot
  have hmem :
      slot ∈ im05_integerMultisetPermutationNameSlots sample target := by
    simpa [im05_integerMultisetPermutationNameSlots, hslot]
  have hcard_pos :
      0 < (im05_integerMultisetPermutationNameSlots sample target).card :=
    Finset.card_pos.mpr ⟨slot, hmem⟩
  rw [im05_integerMultisetPermutationNameSlots_card sample target, hzero] at hcard_pos
  exact (Nat.lt_irrefl 0) hcard_pos

/--
The excluded-slot set of any count-vector sample belongs to the fixed
`powersetCard` family of subsets with size `count excluded`.
-/
theorem im05_integerMultisetPermutationNameSlots_mem_powersetCard
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    (excluded : Name) :
    im05_integerMultisetPermutationNameSlots sample excluded ∈
      (Finset.univ : Finset (Fin (∑ name : Name, count name))).powersetCard
        (count excluded) := by
  classical
  rw [Finset.mem_powersetCard]
  constructor
  · intro slot hslot
    simp
  · exact im05_integerMultisetPermutationNameSlots_card sample excluded

/-- The complement of a singleton-deletion slot set has the residual length. -/
theorem im05_slotComplement_card_eq_sum_countOutside_singleton
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded) :
    ((Finset.univ : Finset (Fin (∑ name : Name, count name))).filter
        fun slot => slot ∉ deletedSlots).card =
      ∑ name : Name, im05_countOutside count ({excluded} : Finset Name) name := by
  classical
  let total := ∑ name : Name, count name
  let residualTotal :=
    ∑ name : Name, im05_countOutside count ({excluded} : Finset Name) name
  let complementSlots :
      Finset (Fin total) :=
    (Finset.univ : Finset (Fin total)).filter fun slot =>
      slot ∉ deletedSlots
  have hdeleted_filter :
      ((Finset.univ : Finset (Fin total)).filter
          fun slot => ¬ slot ∉ deletedSlots) = deletedSlots := by
    ext slot
    simp
  have hsplit :
      complementSlots.card + deletedSlots.card = total := by
    have hpartition :=
      Finset.card_filter_add_card_filter_not
        (s := (Finset.univ : Finset (Fin total)))
        (p := fun slot : Fin total => slot ∉ deletedSlots)
    simpa [complementSlots, hdeleted_filter, total] using hpartition
  have hresidual_add :
      residualTotal + count excluded = total := by
    dsimp [residualTotal, total]
    exact im05_sum_countOutside_singleton_add_count count excluded
  dsimp [complementSlots, residualTotal, total] at hsplit ⊢
  rw [hdeleted_card] at hsplit
  omega

/-- Rank an element of a finite slot set by its increasing `Finset` order. -/
noncomputable def im05_finsetOrderRank
    {n r : ℕ} (slots : Finset (Fin n)) (hcard : slots.card = r)
    (slot : Fin n) (hslot : slot ∈ slots) : Fin r :=
  Classical.choose (by
    have hrange : Set.range (slots.orderEmbOfFin hcard) = slots :=
      Finset.range_orderEmbOfFin slots hcard
    have hslot_set : slot ∈ (slots : Set (Fin n)) := by
      simpa using hslot
    rw [← hrange] at hslot_set
    exact hslot_set)

/-- The ordered-rank index maps back to the original slot. -/
theorem im05_finsetOrderRank_spec
    {n r : ℕ} (slots : Finset (Fin n)) (hcard : slots.card = r)
    (slot : Fin n) (hslot : slot ∈ slots) :
    slots.orderEmbOfFin hcard
        (im05_finsetOrderRank slots hcard slot hslot) = slot := by
  classical
  unfold im05_finsetOrderRank
  exact Classical.choose_spec (by
    have hrange : Set.range (slots.orderEmbOfFin hcard) = slots :=
      Finset.range_orderEmbOfFin slots hcard
    have hslot_set : slot ∈ (slots : Set (Fin n)) := by
      simpa using hslot
    rw [← hrange] at hslot_set
    exact hslot_set)

/-- Filtering the canonical `Fin` range gives the sorted filtered finset. -/
theorem im05_finRange_filter_eq_sort_filter
    {n : ℕ} (p : Fin n → Prop) [DecidablePred p] :
    (List.finRange n).filter (fun slot => decide (p slot)) =
      ((Finset.univ : Finset (Fin n)).filter p).sort (· ≤ ·) := by
  classical
  have hsorted_left :
      ((List.finRange n).filter (fun slot => decide (p slot))).SortedLT := by
    exact
      ((List.sortedLT_finRange n).pairwise.filter
        (fun slot => decide (p slot))).sortedLT
  have hsorted_right :
      (((Finset.univ : Finset (Fin n)).filter p).sort (· ≤ ·)).SortedLT :=
    ((Finset.univ : Finset (Fin n)).filter p).sortedLT_sort
  exact hsorted_left.eq_of_mem_iff hsorted_right (by
    intro slot
    simp)

/--
Filtering `List.ofFn f` by a value predicate that agrees with a slot predicate
enumerates the filtered slots in increasing order.
-/
theorem im05_list_ofFn_filter_eq_orderEmb
    {n k : ℕ} {α : Type*}
    (f : Fin n → α)
    (p : Fin n → Prop) [DecidablePred p]
    (q : α → Prop) [DecidablePred q]
    (hiff : ∀ slot : Fin n, q (f slot) ↔ p slot)
    (hcard : ((Finset.univ : Finset (Fin n)).filter p).card = k) :
    (List.ofFn f).filter (fun value => decide (q value)) =
      List.ofFn
        (fun idx : Fin k =>
          f (((Finset.univ : Finset (Fin n)).filter p).orderEmbOfFin
            hcard idx)) := by
  classical
  calc
    (List.ofFn f).filter (fun value => decide (q value))
        = ((List.finRange n).map f).filter
            (fun value => decide (q value)) := by
            rw [List.ofFn_eq_map]
    _ = ((List.finRange n).filter
            (fun slot => decide (p slot))).map f := by
            rw [List.filter_map]
            apply congrArg (List.map f)
            apply List.filter_congr
            intro slot _hslot
            simp [hiff slot]
    _ = (((Finset.univ : Finset (Fin n)).filter p).sort (· ≤ ·)).map f := by
            rw [im05_finRange_filter_eq_sort_filter]
    _ =
      List.ofFn
        (fun idx : Fin k =>
          f (((Finset.univ : Finset (Fin n)).filter p).orderEmbOfFin
            hcard idx)) := by
            rw [List.ofFn_eq_map]
            rw [← Finset.listMap_orderEmbOfFin_finRange
              ((Finset.univ : Finset (Fin n)).filter p) hcard]
            rw [List.map_map]
            rfl

/-- The slots outside a chosen deleted-slot set. -/
def im05_slotComplement
    {n : ℕ} (deletedSlots : Finset (Fin n)) : Finset (Fin n) :=
  (Finset.univ : Finset (Fin n)).filter fun slot =>
    slot ∉ deletedSlots

@[simp]
theorem im05_mem_slotComplement_iff
    {n : ℕ} (deletedSlots : Finset (Fin n)) (slot : Fin n) :
    slot ∈ im05_slotComplement deletedSlots ↔ slot ∉ deletedSlots := by
  simp [im05_slotComplement]

/-- Rank a non-deleted slot among the complement slots. -/
noncomputable def im05_slotComplementRank
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded)
    (slot : Fin (∑ name : Name, count name))
    (hslot : slot ∉ deletedSlots) :
    Fin (∑ name : Name,
      im05_countOutside count ({excluded} : Finset Name) name) :=
  im05_finsetOrderRank
    (im05_slotComplement deletedSlots)
    (im05_slotComplement_card_eq_sum_countOutside_singleton
      count excluded deletedSlots hdeleted_card)
    slot (by simpa [im05_slotComplement] using hslot)

/-- The complement-rank embedding returns the original non-deleted slot. -/
theorem im05_slotComplementRank_spec
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded)
    (slot : Fin (∑ name : Name, count name))
    (hslot : slot ∉ deletedSlots) :
    (im05_slotComplement deletedSlots).orderEmbOfFin
        (im05_slotComplement_card_eq_sum_countOutside_singleton
          count excluded deletedSlots hdeleted_card)
        (im05_slotComplementRank
          count excluded deletedSlots hdeleted_card slot hslot) =
      slot := by
  classical
  unfold im05_slotComplementRank
  exact
    im05_finsetOrderRank_spec
      (im05_slotComplement deletedSlots)
      (im05_slotComplement_card_eq_sum_countOutside_singleton
        count excluded deletedSlots hdeleted_card)
      slot (by simpa [im05_slotComplement] using hslot)

/--
Reconstruct a full word by inserting `excluded` in the chosen deleted slots and
reading the residual sample along the complement slots in increasing order.
-/
noncomputable def im05_integerMultisetPermutationInsertSingletonWord
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded) :
    Fin (∑ name : Name, count name) → Name :=
  fun slot =>
    if hslot : slot ∈ deletedSlots then excluded
    else
      residual.1
        (im05_slotComplementRank
          count excluded deletedSlots hdeleted_card slot hslot)

@[simp]
theorem im05_integerMultisetPermutationInsertSingletonWord_of_mem
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded)
    (slot : Fin (∑ name : Name, count name))
    (hslot : slot ∈ deletedSlots) :
    im05_integerMultisetPermutationInsertSingletonWord
        count excluded residual deletedSlots hdeleted_card slot =
      excluded := by
  simp [im05_integerMultisetPermutationInsertSingletonWord, hslot]

@[simp]
theorem im05_integerMultisetPermutationInsertSingletonWord_of_not_mem
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded)
    (slot : Fin (∑ name : Name, count name))
    (hslot : slot ∉ deletedSlots) :
    im05_integerMultisetPermutationInsertSingletonWord
        count excluded residual deletedSlots hdeleted_card slot =
      residual.1
        (im05_slotComplementRank
          count excluded deletedSlots hdeleted_card slot hslot) := by
  simp [im05_integerMultisetPermutationInsertSingletonWord, hslot]

/-- The reconstructed singleton-insertion word has the prescribed deleted-name count. -/
theorem im05_integerMultisetPermutationInsertSingletonWord_count_excluded
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded) :
    im05_nameCountInWord
        (im05_integerMultisetPermutationInsertSingletonWord
          count excluded residual deletedSlots hdeleted_card)
        excluded =
      count excluded := by
  classical
  let word :=
    im05_integerMultisetPermutationInsertSingletonWord
      count excluded residual deletedSlots hdeleted_card
  have hfilter :
      ((Finset.univ : Finset (Fin (∑ name : Name, count name))).filter
          fun slot => word slot = excluded) =
        deletedSlots := by
    ext slot
    by_cases hslot : slot ∈ deletedSlots
    · simp [word, hslot]
    · have hres_ne :
          residual.1
              (im05_slotComplementRank
                count excluded deletedSlots hdeleted_card slot hslot) ≠
            excluded :=
        im05_integerMultisetPermutation_ne_of_count_zero
          residual
          (by simp [im05_countOutside])
          (im05_slotComplementRank
            count excluded deletedSlots hdeleted_card slot hslot)
      simp [word, hslot, hres_ne]
  unfold im05_nameCountInWord
  rw [hfilter, hdeleted_card]

/-- The reconstructed singleton-insertion word has the prescribed count for every non-deleted name. -/
theorem im05_integerMultisetPermutationInsertSingletonWord_count_ne
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded)
    (target : Name) (hneq : target ≠ excluded) :
    im05_nameCountInWord
        (im05_integerMultisetPermutationInsertSingletonWord
          count excluded residual deletedSlots hdeleted_card)
        target =
      count target := by
  classical
  let word :=
    im05_integerMultisetPermutationInsertSingletonWord
      count excluded residual deletedSlots hdeleted_card
  let hcomp :
      (im05_slotComplement deletedSlots).card =
        ∑ name : Name,
          im05_countOutside count ({excluded} : Finset Name) name :=
    im05_slotComplement_card_eq_sum_countOutside_singleton
      count excluded deletedSlots hdeleted_card
  let compEmb :=
    (im05_slotComplement deletedSlots).orderEmbOfFin hcomp
  let residualSlots :=
    im05_integerMultisetPermutationNameSlots residual target
  have hfilter :
      ((Finset.univ : Finset (Fin (∑ name : Name, count name))).filter
          fun slot => word slot = target) =
        residualSlots.map compEmb.toEmbedding := by
    ext slot
    constructor
    · intro hslot_filter
      have hword : word slot = target :=
        (Finset.mem_filter.mp hslot_filter).2
      by_cases hslot_deleted : slot ∈ deletedSlots
      · have hexcluded_eq_target : excluded = target := by
          simpa [word, hslot_deleted] using hword
        exact False.elim (hneq hexcluded_eq_target.symm)
      · rw [Finset.mem_map]
        refine
          ⟨im05_slotComplementRank
              count excluded deletedSlots hdeleted_card slot hslot_deleted,
            ?_, ?_⟩
        · have hres :
              residual.1
                  (im05_slotComplementRank
                    count excluded deletedSlots hdeleted_card slot
                    hslot_deleted) = target := by
            simpa [word, hslot_deleted] using hword
          simpa [residualSlots,
            im05_integerMultisetPermutationNameSlots, hres]
        · exact
            by
              simpa [compEmb] using
                (im05_slotComplementRank_spec
                  count excluded deletedSlots hdeleted_card slot
                  hslot_deleted)
    · intro hslot_map
      rw [Finset.mem_map] at hslot_map
      rcases hslot_map with ⟨idx, hidx, hidx_slot⟩
      subst slot
      have hidx_mem_complement :
          compEmb idx ∈ im05_slotComplement deletedSlots :=
        Finset.orderEmbOfFin_mem
          (im05_slotComplement deletedSlots) hcomp idx
      have hidx_not_deleted :
          compEmb idx ∉ deletedSlots := by
        simpa [im05_slotComplement] using hidx_mem_complement
      have hrank_eq :
          im05_slotComplementRank
              count excluded deletedSlots hdeleted_card
              (compEmb idx) hidx_not_deleted = idx := by
        apply compEmb.injective
        rw [im05_slotComplementRank_spec]
      have hres : residual.1 idx = target := by
        simpa [residualSlots, im05_integerMultisetPermutationNameSlots]
          using hidx
      rw [Finset.mem_filter]
      constructor
      · simp
      · simp [word, hidx_not_deleted, hrank_eq, hres]
  unfold im05_nameCountInWord
  rw [hfilter]
  rw [Finset.card_map]
  dsimp [residualSlots]
  rw [im05_integerMultisetPermutationNameSlots_card residual target]
  simp [im05_countOutside, hneq]

/-- The reconstructed singleton-insertion word has the full prescribed count vector. -/
theorem im05_integerMultisetPermutationInsertSingletonWord_count
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded)
    (target : Name) :
    im05_nameCountInWord
        (im05_integerMultisetPermutationInsertSingletonWord
          count excluded residual deletedSlots hdeleted_card)
        target =
      count target := by
  by_cases htarget : target = excluded
  · subst target
    exact
      im05_integerMultisetPermutationInsertSingletonWord_count_excluded
        count excluded residual deletedSlots hdeleted_card
  · exact
      im05_integerMultisetPermutationInsertSingletonWord_count_ne
        count excluded residual deletedSlots hdeleted_card target htarget

/-- Reconstruct a count-vector sample by inserting one deleted name into residual slots. -/
noncomputable def im05_integerMultisetPermutationInsertSingletonSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded) :
    im05_integerMultisetPermutationSample Name count :=
  ⟨im05_integerMultisetPermutationInsertSingletonWord
      count excluded residual deletedSlots hdeleted_card,
    by
      intro target
      exact
        im05_integerMultisetPermutationInsertSingletonWord_count
          count excluded residual deletedSlots hdeleted_card target⟩

@[simp]
theorem im05_integerMultisetPermutationInsertSingletonSample_apply
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded)
    (slot : Fin (∑ name : Name, count name)) :
    (im05_integerMultisetPermutationInsertSingletonSample
        count excluded residual deletedSlots hdeleted_card).1 slot =
      im05_integerMultisetPermutationInsertSingletonWord
        count excluded residual deletedSlots hdeleted_card slot := rfl

/-- The reconstructed sample's deleted-name slots are exactly the chosen slots. -/
theorem im05_integerMultisetPermutationNameSlots_insertSingletonSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded) :
    im05_integerMultisetPermutationNameSlots
        (im05_integerMultisetPermutationInsertSingletonSample
          count excluded residual deletedSlots hdeleted_card)
        excluded =
      deletedSlots := by
  classical
  ext slot
  by_cases hslot : slot ∈ deletedSlots
  · simp [hslot]
  · have hres_ne :
        residual.1
            (im05_slotComplementRank
              count excluded deletedSlots hdeleted_card slot hslot) ≠
          excluded :=
      im05_integerMultisetPermutation_ne_of_count_zero
        residual
        (by simp [im05_countOutside])
        (im05_slotComplementRank
          count excluded deletedSlots hdeleted_card slot hslot)
    simp [hslot, hres_ne,
      im05_integerMultisetPermutationInsertSingletonWord]

/-- The sample list with all forbidden names removed. -/
def im05_integerMultisetPermutationAllowedList
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (forbidden : Finset Name)
    (sample : im05_integerMultisetPermutationSample Name count) : List Name :=
  (im05_integerMultisetPermutationList sample).filter fun name =>
    decide (name ∉ forbidden)

/-- Filtering forbidden names leaves exactly the outside count vector. -/
theorem im05_integerMultisetPermutationAllowedList_count
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (forbidden : Finset Name)
    (sample : im05_integerMultisetPermutationSample Name count)
    (target : Name) :
    (im05_integerMultisetPermutationAllowedList forbidden sample).count target =
      im05_countOutside count forbidden target := by
  classical
  by_cases htarget : target ∈ forbidden
  · have hnot_mem :
        target ∉ im05_integerMultisetPermutationAllowedList forbidden sample := by
      intro hmem
      rw [im05_integerMultisetPermutationAllowedList, List.mem_filter] at hmem
      have hnot : target ∉ forbidden := by simpa using hmem.2
      exact hnot htarget
    rw [List.count_eq_zero_of_not_mem hnot_mem]
    simp [im05_countOutside, htarget]
  · rw [im05_integerMultisetPermutationAllowedList]
    rw [List.count_filter]
    · rw [im05_integerMultisetPermutationList_count sample target]
      simp [im05_countOutside, htarget]
    · simp [htarget]

/-- The allowed-list length is the total outside count. -/
theorem im05_integerMultisetPermutationAllowedList_length
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (forbidden : Finset Name)
    (sample : im05_integerMultisetPermutationSample Name count) :
    (im05_integerMultisetPermutationAllowedList forbidden sample).length =
      ∑ name : Name, im05_countOutside count forbidden name := by
  classical
  let allowed := im05_integerMultisetPermutationAllowedList forbidden sample
  have hsum_count :
      ∑ name : Name, allowed.count name = allowed.length := by
    simpa [allowed] using
      (Multiset.sum_count_eq_card
        (s := (Finset.univ : Finset Name))
        (m := (allowed : Multiset Name))
        (by intro name _hmem; simp))
  calc
    allowed.length = ∑ name : Name, allowed.count name := hsum_count.symm
    _ = ∑ name : Name, im05_countOutside count forbidden name := by
        refine Finset.sum_congr rfl ?_
        intro name _hname
        exact im05_integerMultisetPermutationAllowedList_count
          forbidden sample name

/-- If a positive-count target is allowed, the filtered allowed list is nonempty. -/
theorem im05_integerMultisetPermutationAllowedList_length_pos_of_count_pos
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (forbidden : Finset Name)
    (sample : im05_integerMultisetPermutationSample Name count)
    (target : Name) (hnot : target ∉ forbidden)
    (hpos : 0 < count target) :
    0 < (im05_integerMultisetPermutationAllowedList forbidden sample).length := by
  classical
  have hcount :=
    im05_integerMultisetPermutationAllowedList_count
      forbidden sample target
  rw [im05_countOutside, if_neg hnot] at hcount
  have hcount_pos :
      0 < (im05_integerMultisetPermutationAllowedList
        forbidden sample).count target := by
    rw [hcount]
    exact hpos
  exact List.length_pos_of_mem (List.count_pos_iff.mp hcount_pos)

/--
Filtering an integer-multiset sample outside a forbidden set gives a
count-vector sample for the zero-forbidden residual count vector.
-/
noncomputable def im05_integerMultisetPermutationAllowedSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (forbidden : Finset Name)
    (sample : im05_integerMultisetPermutationSample Name count) :
    im05_integerMultisetPermutationSample Name
      (im05_countOutside count forbidden) := by
  classical
  let allowed := im05_integerMultisetPermutationAllowedList forbidden sample
  have hlen :
      allowed.length =
        ∑ name : Name, im05_countOutside count forbidden name := by
    dsimp [allowed]
    exact im05_integerMultisetPermutationAllowedList_length forbidden sample
  refine ⟨(fun slot => allowed.get (Fin.cast hlen.symm slot)), ?_⟩
  intro target
  rw [im05_nameCountInWord_eq_count_ofFn]
  have hlist :
      List.ofFn
          (fun slot :
              Fin (∑ name : Name, im05_countOutside count forbidden name) =>
            allowed.get (Fin.cast hlen.symm slot)) =
        allowed := by
    refine List.ext_get_iff.mpr ?_
    constructor
    · simp [hlen]
    · intro n hleft hright
      rw [List.get_ofFn]
      congr 1
  rw [hlist]
  exact im05_integerMultisetPermutationAllowedList_count
    forbidden sample target

/--
The list associated to an allowed residual sample is exactly the original
sample list filtered outside the forbidden set.
-/
theorem im05_integerMultisetPermutationList_allowedSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (forbidden : Finset Name)
    (sample : im05_integerMultisetPermutationSample Name count) :
    im05_integerMultisetPermutationList
        (im05_integerMultisetPermutationAllowedSample forbidden sample) =
      im05_integerMultisetPermutationAllowedList forbidden sample := by
  classical
  let allowed := im05_integerMultisetPermutationAllowedList forbidden sample
  have hlen :
      allowed.length =
        ∑ name : Name, im05_countOutside count forbidden name := by
    dsimp [allowed]
    exact im05_integerMultisetPermutationAllowedList_length forbidden sample
  dsimp [im05_integerMultisetPermutationAllowedSample,
    im05_integerMultisetPermutationList]
  change
    List.ofFn
        (fun slot :
            Fin (∑ name : Name, im05_countOutside count forbidden name) =>
          allowed.get (Fin.cast hlen.symm slot)) =
      allowed
  refine List.ext_get_iff.mpr ?_
  constructor
  · simp [hlen]
  · intro n hleft _hright
    rw [List.get_ofFn]
    congr 1

/--
Filtering an already-filtered count-vector sample outside a second forbidden
set equals filtering the original list outside the union of the two forbidden
sets.
-/
theorem im05_integerMultisetPermutationAllowedList_allowedSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (forbidden₁ forbidden₂ : Finset Name)
    (sample : im05_integerMultisetPermutationSample Name count) :
    im05_integerMultisetPermutationAllowedList forbidden₂
        (im05_integerMultisetPermutationAllowedSample forbidden₁ sample) =
      im05_integerMultisetPermutationAllowedList
        (forbidden₁ ∪ forbidden₂) sample := by
  classical
  dsimp [im05_integerMultisetPermutationAllowedList]
  rw [im05_integerMultisetPermutationList_allowedSample forbidden₁ sample]
  dsimp [im05_integerMultisetPermutationAllowedList]
  induction im05_integerMultisetPermutationList sample with
  | nil =>
      simp
  | cons head tail _ih =>
      have hcomm :
          List.filter
              (fun name =>
                !decide (name ∈ forbidden₂) &&
                  !decide (name ∈ forbidden₁)) tail =
            List.filter
              (fun name =>
                !decide (name ∈ forbidden₁) &&
                  !decide (name ∈ forbidden₂)) tail := by
        apply List.filter_congr
        intro name _hname
        by_cases hname₁ : name ∈ forbidden₁ <;>
          by_cases hname₂ : name ∈ forbidden₂ <;>
          simp [hname₁, hname₂]
      by_cases h₁ : head ∈ forbidden₁
      · simpa [h₁] using hcomm
      · by_cases h₂ : head ∈ forbidden₂
        · simpa [h₁, h₂] using hcomm
        · simpa [h₁, h₂] using hcomm

/-- Filtering outside the empty forbidden set leaves the sample list unchanged. -/
theorem im05_integerMultisetPermutationAllowedList_empty
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count) :
    im05_integerMultisetPermutationAllowedList
        (∅ : Finset Name) sample =
      im05_integerMultisetPermutationList sample := by
  classical
  dsimp [im05_integerMultisetPermutationAllowedList]
  induction im05_integerMultisetPermutationList sample with
  | nil => simp
  | cons head tail _ih => simp

/--
Deleting the empty forbidden set gives the original sample, transported across
the `countOutside_empty` count-vector equality.
-/
theorem im05_integerMultisetPermutationAllowedSample_empty
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count) :
    im05_integerMultisetPermutationAllowedSample
        (∅ : Finset Name) sample =
      im05_integerMultisetPermutationCountEquiv
        (im05_countOutside_empty count).symm sample := by
  classical
  apply Subtype.ext
  apply List.ofFn_inj.mp
  have hleft :
      im05_integerMultisetPermutationList
          (im05_integerMultisetPermutationAllowedSample
            (∅ : Finset Name) sample) =
        im05_integerMultisetPermutationAllowedList
          (∅ : Finset Name) sample :=
    im05_integerMultisetPermutationList_allowedSample
      (∅ : Finset Name) sample
  have hright :
      im05_integerMultisetPermutationList
          (im05_integerMultisetPermutationCountEquiv
            (im05_countOutside_empty count).symm sample) =
        im05_integerMultisetPermutationList sample := by
    rw [im05_integerMultisetPermutationList_countEquiv]
  have hallowed :
      im05_integerMultisetPermutationAllowedList
          (∅ : Finset Name) sample =
        im05_integerMultisetPermutationList sample :=
    im05_integerMultisetPermutationAllowedList_empty sample
  have hlists :
      im05_integerMultisetPermutationList
          (im05_integerMultisetPermutationAllowedSample
            (∅ : Finset Name) sample) =
        im05_integerMultisetPermutationList
          (im05_integerMultisetPermutationCountEquiv
            (im05_countOutside_empty count).symm sample) := by
    rw [hleft, hright, hallowed]
  simpa [im05_integerMultisetPermutationList] using hlists

/-- The empty-deletion map has singleton fibers. -/
theorem im05_integerMultisetPermutationAllowedSample_empty_fiber_card
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count (∅ : Finset Name))) :
    ((Finset.univ :
        Finset (im05_integerMultisetPermutationSample Name count)).filter
      (fun sample =>
        im05_integerMultisetPermutationAllowedSample
            (∅ : Finset Name) sample =
          residual)).card = 1 := by
  classical
  let e :
      im05_integerMultisetPermutationSample Name count ≃
        im05_integerMultisetPermutationSample Name
          (im05_countOutside count (∅ : Finset Name)) :=
    im05_integerMultisetPermutationCountEquiv
      (im05_countOutside_empty count).symm
  have hfilter :
      ((Finset.univ :
          Finset (im05_integerMultisetPermutationSample Name count)).filter
        (fun sample =>
          im05_integerMultisetPermutationAllowedSample
              (∅ : Finset Name) sample =
            residual)) =
        ((Finset.univ :
          Finset (im05_integerMultisetPermutationSample Name count)).filter
        (fun sample => e sample = residual)) := by
    ext sample
    rw [Finset.mem_filter, Finset.mem_filter]
    constructor
    · intro hsample
      exact ⟨hsample.1, by
        rw [← hsample.2]
        exact (im05_integerMultisetPermutationAllowedSample_empty sample).symm⟩
    · intro hsample
      exact ⟨hsample.1, by
        rw [im05_integerMultisetPermutationAllowedSample_empty sample]
        exact hsample.2⟩
  rw [hfilter]
  exact EconCSLib.finite_equiv_fiber_card e residual

/--
Sample-level composition of allowed-sample deletion, with the union-deletion
sample transported back across the `countOutside` union identity.
-/
theorem im05_integerMultisetPermutationAllowedSample_allowedSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (forbidden₁ forbidden₂ : Finset Name)
    (sample : im05_integerMultisetPermutationSample Name count) :
    im05_integerMultisetPermutationAllowedSample forbidden₂
        (im05_integerMultisetPermutationAllowedSample forbidden₁ sample) =
      im05_integerMultisetPermutationCountEquiv
        (im05_countOutside_countOutside_union count forbidden₁ forbidden₂).symm
        (im05_integerMultisetPermutationAllowedSample
          (forbidden₁ ∪ forbidden₂) sample) := by
  classical
  apply Subtype.ext
  apply List.ofFn_inj.mp
  have hleft :
      im05_integerMultisetPermutationList
          (im05_integerMultisetPermutationAllowedSample forbidden₂
            (im05_integerMultisetPermutationAllowedSample forbidden₁ sample)) =
        im05_integerMultisetPermutationAllowedList forbidden₂
          (im05_integerMultisetPermutationAllowedSample forbidden₁ sample) :=
    im05_integerMultisetPermutationList_allowedSample forbidden₂
      (im05_integerMultisetPermutationAllowedSample forbidden₁ sample)
  have hright :
      im05_integerMultisetPermutationList
          (im05_integerMultisetPermutationCountEquiv
            (im05_countOutside_countOutside_union count forbidden₁ forbidden₂).symm
            (im05_integerMultisetPermutationAllowedSample
              (forbidden₁ ∪ forbidden₂) sample)) =
        im05_integerMultisetPermutationAllowedList
          (forbidden₁ ∪ forbidden₂) sample := by
    rw [im05_integerMultisetPermutationList_countEquiv]
    exact
      im05_integerMultisetPermutationList_allowedSample
        (forbidden₁ ∪ forbidden₂) sample
  have hallowed :
      im05_integerMultisetPermutationAllowedList forbidden₂
          (im05_integerMultisetPermutationAllowedSample forbidden₁ sample) =
        im05_integerMultisetPermutationAllowedList
          (forbidden₁ ∪ forbidden₂) sample :=
    im05_integerMultisetPermutationAllowedList_allowedSample
      forbidden₁ forbidden₂ sample
  have hlists :
      im05_integerMultisetPermutationList
          (im05_integerMultisetPermutationAllowedSample forbidden₂
            (im05_integerMultisetPermutationAllowedSample forbidden₁ sample)) =
        im05_integerMultisetPermutationList
          (im05_integerMultisetPermutationCountEquiv
            (im05_countOutside_countOutside_union count forbidden₁ forbidden₂).symm
            (im05_integerMultisetPermutationAllowedSample
              (forbidden₁ ∪ forbidden₂) sample)) := by
    rw [hleft, hright, hallowed]
  simpa [im05_integerMultisetPermutationList] using hlists

/--
Filtering the reconstructed singleton-insertion sample outside the deleted name
recovers the residual sample list, in order.
-/
theorem im05_integerMultisetPermutationAllowedList_insertSingletonSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded) :
    im05_integerMultisetPermutationAllowedList
        ({excluded} : Finset Name)
        (im05_integerMultisetPermutationInsertSingletonSample
          count excluded residual deletedSlots hdeleted_card) =
      im05_integerMultisetPermutationList residual := by
  classical
  let word :=
    im05_integerMultisetPermutationInsertSingletonWord
      count excluded residual deletedSlots hdeleted_card
  let p : Fin (∑ name : Name, count name) → Prop :=
    fun slot => slot ∉ deletedSlots
  let q : Name → Prop :=
    fun name => name ∉ ({excluded} : Finset Name)
  let hcomp :
      (im05_slotComplement deletedSlots).card =
        ∑ name : Name,
          im05_countOutside count ({excluded} : Finset Name) name :=
    im05_slotComplement_card_eq_sum_countOutside_singleton
      count excluded deletedSlots hdeleted_card
  have hfilter :
      (List.ofFn word).filter (fun value => decide (q value)) =
        List.ofFn
          (fun idx :
              Fin (∑ name : Name,
                im05_countOutside count ({excluded} : Finset Name) name) =>
            word
              ((im05_slotComplement deletedSlots).orderEmbOfFin hcomp idx)) := by
    have hiff : ∀ slot : Fin (∑ name : Name, count name),
        q (word slot) ↔ p slot := by
      intro slot
      by_cases hslot : slot ∈ deletedSlots
      · simp [word, p, q, hslot]
      · have hres_ne :
            residual.1
                (im05_slotComplementRank
                  count excluded deletedSlots hdeleted_card slot hslot) ≠
              excluded :=
          im05_integerMultisetPermutation_ne_of_count_zero
            residual
            (by simp [im05_countOutside])
            (im05_slotComplementRank
              count excluded deletedSlots hdeleted_card slot hslot)
        simp [word, p, q, hslot, hres_ne]
    simpa [p, im05_slotComplement] using
      (im05_list_ofFn_filter_eq_orderEmb
        word p q hiff hcomp)
  dsimp [im05_integerMultisetPermutationAllowedList,
    im05_integerMultisetPermutationList,
    im05_integerMultisetPermutationInsertSingletonSample]
  change (List.ofFn word).filter (fun value => decide (q value)) =
    List.ofFn residual.1
  rw [hfilter]
  rw [List.ofFn_inj]
  funext idx
  let compEmb :=
    (im05_slotComplement deletedSlots).orderEmbOfFin hcomp
  have hidx_mem :
      compEmb idx ∈ im05_slotComplement deletedSlots :=
    Finset.orderEmbOfFin_mem
      (im05_slotComplement deletedSlots) hcomp idx
  have hidx_not_deleted :
      compEmb idx ∉ deletedSlots := by
    simpa [im05_slotComplement] using hidx_mem
  have hrank_eq :
      im05_slotComplementRank
          count excluded deletedSlots hdeleted_card
          (compEmb idx) hidx_not_deleted = idx := by
    apply compEmb.injective
    rw [im05_slotComplementRank_spec]
  simp [word, compEmb, hidx_not_deleted, hrank_eq]

/-- Deleting the inserted singleton name from the reconstructed sample recovers the residual sample. -/
theorem im05_integerMultisetPermutationAllowedSample_insertSingletonSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (deletedSlots : Finset (Fin (∑ name : Name, count name)))
    (hdeleted_card : deletedSlots.card = count excluded) :
    im05_integerMultisetPermutationAllowedSample
        ({excluded} : Finset Name)
        (im05_integerMultisetPermutationInsertSingletonSample
          count excluded residual deletedSlots hdeleted_card) =
      residual := by
  classical
  apply Subtype.ext
  funext slot
  let inserted :=
    im05_integerMultisetPermutationInsertSingletonSample
      count excluded residual deletedSlots hdeleted_card
  let allowed :=
    im05_integerMultisetPermutationAllowedList
      ({excluded} : Finset Name) inserted
  have hallowed :
      allowed = im05_integerMultisetPermutationList residual := by
    dsimp [allowed, inserted]
    exact
      im05_integerMultisetPermutationAllowedList_insertSingletonSample
        count excluded residual deletedSlots hdeleted_card
  have hlen :
      allowed.length =
        ∑ name : Name, im05_countOutside count ({excluded} : Finset Name) name := by
    dsimp [allowed]
    exact
      im05_integerMultisetPermutationAllowedList_length
        ({excluded} : Finset Name) inserted
  dsimp [im05_integerMultisetPermutationAllowedSample]
  change allowed[slot.val]'(by simpa [hlen] using slot.isLt) =
    residual.1 slot
  have hget? :
      allowed[slot.val]? =
        (im05_integerMultisetPermutationList residual)[slot.val]? :=
    congrArg (fun l : List Name => l[slot.val]?) hallowed
  have hleft :
      allowed[slot.val]? =
        some (allowed[slot.val]'(by simpa [hlen] using slot.isLt)) := by
    rw [List.getElem?_eq_getElem]
  have hright :
      (im05_integerMultisetPermutationList residual)[slot.val]? =
        some (residual.1 slot) := by
    dsimp [im05_integerMultisetPermutationList]
    rw [List.getElem?_eq_getElem (by simp)]
    simp
  have hsome :
      some (allowed[slot.val]'(by simpa [hlen] using slot.isLt)) =
        some (residual.1 slot) := by
    rw [← hleft, hget?, hright]
  exact Option.some.inj hsome

/--
For singleton deletion, the allowed list is the original word read along the
complement of the deleted-name slot set.
-/
theorem im05_integerMultisetPermutationAllowedList_singleton_eq_orderEmb
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    (excluded : Name) :
    im05_integerMultisetPermutationAllowedList
        ({excluded} : Finset Name) sample =
      List.ofFn
        (fun idx :
            Fin (∑ name : Name,
              im05_countOutside count ({excluded} : Finset Name) name) =>
          sample.1
            (((im05_slotComplement
                  (im05_integerMultisetPermutationNameSlots sample excluded)).orderEmbOfFin
                (im05_slotComplement_card_eq_sum_countOutside_singleton
                  count excluded
                  (im05_integerMultisetPermutationNameSlots sample excluded)
                  (im05_integerMultisetPermutationNameSlots_card
                    sample excluded)))
              idx)) := by
  classical
  let deletedSlots := im05_integerMultisetPermutationNameSlots sample excluded
  let p : Fin (∑ name : Name, count name) → Prop :=
    fun slot => slot ∉ deletedSlots
  let q : Name → Prop :=
    fun name => name ∉ ({excluded} : Finset Name)
  let hcomp :
      (im05_slotComplement deletedSlots).card =
        ∑ name : Name,
          im05_countOutside count ({excluded} : Finset Name) name :=
    im05_slotComplement_card_eq_sum_countOutside_singleton
      count excluded deletedSlots
      (im05_integerMultisetPermutationNameSlots_card sample excluded)
  dsimp [im05_integerMultisetPermutationAllowedList,
    im05_integerMultisetPermutationList]
  have hiff : ∀ slot : Fin (∑ name : Name, count name),
      q (sample.1 slot) ↔ p slot := by
    intro slot
    by_cases hslot : sample.1 slot = excluded
    · have hdeleted : slot ∈ deletedSlots := by
        simpa [deletedSlots,
          im05_integerMultisetPermutationNameSlots] using hslot
      simp [p, q, hslot, hdeleted]
    · have hnot_deleted : slot ∉ deletedSlots := by
        simpa [deletedSlots,
          im05_integerMultisetPermutationNameSlots] using hslot
      simp [p, q, hslot, hnot_deleted]
  simpa [deletedSlots, p, q, im05_slotComplement] using
    (im05_list_ofFn_filter_eq_orderEmb
      sample.1 p q hiff hcomp)

/--
Pointwise form of singleton deletion: the residual sample's `idx`-th entry is
the original sample at the `idx`-th non-deleted slot.
-/
theorem im05_integerMultisetPermutationAllowedSample_singleton_apply
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    (excluded : Name)
    (idx :
      Fin (∑ name : Name,
        im05_countOutside count ({excluded} : Finset Name) name)) :
    (im05_integerMultisetPermutationAllowedSample
        ({excluded} : Finset Name) sample).1 idx =
      sample.1
        (((im05_slotComplement
              (im05_integerMultisetPermutationNameSlots sample excluded)).orderEmbOfFin
            (im05_slotComplement_card_eq_sum_countOutside_singleton
              count excluded
              (im05_integerMultisetPermutationNameSlots sample excluded)
              (im05_integerMultisetPermutationNameSlots_card
                sample excluded)))
          idx) := by
  classical
  let deletedSlots := im05_integerMultisetPermutationNameSlots sample excluded
  let allowed :=
    im05_integerMultisetPermutationAllowedList
      ({excluded} : Finset Name) sample
  let hcomp :
      (im05_slotComplement deletedSlots).card =
        ∑ name : Name,
          im05_countOutside count ({excluded} : Finset Name) name :=
    im05_slotComplement_card_eq_sum_countOutside_singleton
      count excluded deletedSlots
      (im05_integerMultisetPermutationNameSlots_card sample excluded)
  let orderedList : List Name :=
    List.ofFn
      (fun idx :
          Fin (∑ name : Name,
            im05_countOutside count ({excluded} : Finset Name) name) =>
        sample.1
          (((im05_slotComplement deletedSlots).orderEmbOfFin hcomp) idx))
  have hallowed :
      allowed = orderedList := by
    dsimp [allowed, orderedList, deletedSlots, hcomp]
    exact
      im05_integerMultisetPermutationAllowedList_singleton_eq_orderEmb
        sample excluded
  have hlen :
      allowed.length =
        ∑ name : Name, im05_countOutside count ({excluded} : Finset Name) name := by
    dsimp [allowed]
    exact
      im05_integerMultisetPermutationAllowedList_length
        ({excluded} : Finset Name) sample
  dsimp [im05_integerMultisetPermutationAllowedSample]
  change allowed[idx.val]'(by simpa [hlen] using idx.isLt) =
    sample.1 (((im05_slotComplement deletedSlots).orderEmbOfFin hcomp) idx)
  have hget? : allowed[idx.val]? = orderedList[idx.val]? :=
    congrArg (fun l : List Name => l[idx.val]?) hallowed
  have hleft :
      allowed[idx.val]? =
        some (allowed[idx.val]'(by simpa [hlen] using idx.isLt)) := by
    rw [List.getElem?_eq_getElem]
  have hright :
      orderedList[idx.val]? =
        some (sample.1 (((im05_slotComplement deletedSlots).orderEmbOfFin hcomp) idx)) := by
    dsimp [orderedList]
    rw [List.getElem?_eq_getElem (by simp)]
    simp
  have hsome :
      some (allowed[idx.val]'(by simpa [hlen] using idx.isLt)) =
        some (sample.1 (((im05_slotComplement deletedSlots).orderEmbOfFin hcomp) idx)) := by
    rw [← hleft, hget?, hright]
  exact Option.some.inj hsome

/--
Any sample in a singleton-deletion fiber is reconstructed by inserting the
deleted name in its own deleted-name slots.
-/
theorem im05_integerMultisetPermutationInsertSingletonSample_of_allowedSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name)))
    (hresidual :
      im05_integerMultisetPermutationAllowedSample
          ({excluded} : Finset Name) sample =
        residual) :
    im05_integerMultisetPermutationInsertSingletonSample
        count excluded residual
        (im05_integerMultisetPermutationNameSlots sample excluded)
        (im05_integerMultisetPermutationNameSlots_card sample excluded) =
      sample := by
  classical
  apply Subtype.ext
  funext slot
  let deletedSlots := im05_integerMultisetPermutationNameSlots sample excluded
  let hdeleted_card :
      deletedSlots.card = count excluded :=
    im05_integerMultisetPermutationNameSlots_card sample excluded
  by_cases hslot : slot ∈ deletedSlots
  · have hsample : sample.1 slot = excluded := by
      simpa [deletedSlots,
        im05_integerMultisetPermutationNameSlots] using hslot
    simp [im05_integerMultisetPermutationInsertSingletonSample,
      im05_integerMultisetPermutationInsertSingletonWord,
      deletedSlots, hslot, hsample]
  · let rank :=
      im05_slotComplementRank
        count excluded deletedSlots hdeleted_card slot hslot
    have hres_eq_allowed :
        residual.1 rank =
          (im05_integerMultisetPermutationAllowedSample
              ({excluded} : Finset Name) sample).1 rank := by
      exact congrFun (congrArg Subtype.val hresidual.symm) rank
    have hallowed_rank :
        (im05_integerMultisetPermutationAllowedSample
            ({excluded} : Finset Name) sample).1 rank =
          sample.1 slot := by
      have happly :=
        im05_integerMultisetPermutationAllowedSample_singleton_apply
          sample excluded rank
      have hslot_spec :
          (((im05_slotComplement deletedSlots).orderEmbOfFin
              (im05_slotComplement_card_eq_sum_countOutside_singleton
                count excluded deletedSlots hdeleted_card))
              rank) = slot :=
        im05_slotComplementRank_spec
          count excluded deletedSlots hdeleted_card slot hslot
      simpa [deletedSlots, hdeleted_card, rank, hslot_spec] using happly
    have hres_rank : residual.1 rank = sample.1 slot := by
      rw [hres_eq_allowed, hallowed_rank]
    simp [im05_integerMultisetPermutationInsertSingletonSample,
      im05_integerMultisetPermutationInsertSingletonWord,
      deletedSlots, hslot, rank, hres_rank]

/--
The fiber over a singleton-deleted residual sample is equivalent to choosing
the slots occupied by the deleted name.
-/
noncomputable def im05_integerMultisetPermutationAllowedSampleSingletonFiberEquiv
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name))) :
    {deletedSlots : Finset (Fin (∑ name : Name, count name)) //
      deletedSlots ∈
        (Finset.univ : Finset (Fin (∑ name : Name, count name))).powersetCard
          (count excluded)} ≃
      {sample : im05_integerMultisetPermutationSample Name count //
        im05_integerMultisetPermutationAllowedSample
            ({excluded} : Finset Name) sample =
          residual} where
  toFun slotChoice :=
    let hcard : slotChoice.1.card = count excluded :=
      (Finset.mem_powersetCard.mp slotChoice.2).2
    ⟨im05_integerMultisetPermutationInsertSingletonSample
        count excluded residual slotChoice.1 hcard,
      im05_integerMultisetPermutationAllowedSample_insertSingletonSample
        count excluded residual slotChoice.1 hcard⟩
  invFun fiberSample :=
    ⟨im05_integerMultisetPermutationNameSlots fiberSample.1 excluded,
      im05_integerMultisetPermutationNameSlots_mem_powersetCard
        fiberSample.1 excluded⟩
  left_inv slotChoice := by
    apply Subtype.ext
    dsimp
    exact
      im05_integerMultisetPermutationNameSlots_insertSingletonSample
        count excluded residual slotChoice.1
        ((Finset.mem_powersetCard.mp slotChoice.2).2)
  right_inv fiberSample := by
    apply Subtype.ext
    dsimp
    exact
      im05_integerMultisetPermutationInsertSingletonSample_of_allowedSample
        fiberSample.1 excluded residual fiberSample.2

/-- Concrete cardinality of every singleton allowed-sample fiber. -/
theorem im05_integerMultisetPermutationAllowedSample_singleton_fiber_card
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({excluded} : Finset Name))) :
    ((Finset.univ :
        Finset (im05_integerMultisetPermutationSample Name count)).filter
      (fun sample =>
        im05_integerMultisetPermutationAllowedSample
            ({excluded} : Finset Name) sample =
          residual)).card =
      ((Finset.univ : Finset (Fin (∑ name : Name, count name))).powersetCard
        (count excluded)).card := by
  classical
  let fiberPred :
      im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      im05_integerMultisetPermutationAllowedSample
          ({excluded} : Finset Name) sample =
        residual
  let slotChoices :=
    {deletedSlots : Finset (Fin (∑ name : Name, count name)) //
      deletedSlots ∈
        (Finset.univ : Finset (Fin (∑ name : Name, count name))).powersetCard
          (count excluded)}
  have hslot_card :
      Fintype.card slotChoices =
        ((Finset.univ : Finset (Fin (∑ name : Name, count name))).powersetCard
          (count excluded)).card := by
    dsimp [slotChoices]
    rw [Fintype.card_subtype]
    congr 1
    ext deletedSlots
    simp
  calc
    ((Finset.univ :
        Finset (im05_integerMultisetPermutationSample Name count)).filter
      (fun sample =>
        im05_integerMultisetPermutationAllowedSample
            ({excluded} : Finset Name) sample =
          residual)).card
        = Fintype.card
            {sample : im05_integerMultisetPermutationSample Name count //
              fiberPred sample} := by
            rw [Fintype.card_subtype]
    _ = Fintype.card slotChoices := by
            exact
              Fintype.card_congr
                (im05_integerMultisetPermutationAllowedSampleSingletonFiberEquiv
                  count excluded residual).symm
    _ =
      ((Finset.univ : Finset (Fin (∑ name : Name, count name))).powersetCard
        (count excluded)).card := hslot_card

/-- The singleton allowed-sample fiber cardinality is positive. -/
theorem im05_integerMultisetPermutationAllowedSample_singleton_fiber_card_pos
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name) :
    0 <
      ((Finset.univ : Finset (Fin (∑ name : Name, count name))).powersetCard
        (count excluded)).card := by
  classical
  have hle : count excluded ≤ ∑ name : Name, count name :=
    Finset.single_le_sum
      (fun name _hname => Nat.zero_le (count name))
      (Finset.mem_univ excluded)
  have hle_univ :
      count excluded ≤
        (Finset.univ : Finset (Fin (∑ name : Name, count name))).card := by
    simpa using hle
  exact Finset.card_pos.mpr
    (Finset.powersetCard_nonempty.mpr hle_univ)

/--
Constant-fiber induction step for forbidden-set deletion: if deleting
`forbidden` has constant fiber size, then deleting
`forbidden ∪ {excluded}` has constant fiber size obtained by multiplying by
the singleton-deletion fiber size in the residual count vector.
-/
theorem
    im05_integerMultisetPermutationAllowedSample_union_singleton_fiber_card_of_constant_fiber
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (forbidden : Finset Name) (excluded : Name)
    (baseFiber : ℕ)
    (hbase : ∀ residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count forbidden),
      ((Finset.univ :
          Finset (im05_integerMultisetPermutationSample Name count)).filter
        (fun sample =>
          im05_integerMultisetPermutationAllowedSample forbidden sample =
            residual)).card = baseFiber)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count
          (forbidden ∪ ({excluded} : Finset Name)))) :
    ((Finset.univ :
        Finset (im05_integerMultisetPermutationSample Name count)).filter
      (fun sample =>
        im05_integerMultisetPermutationAllowedSample
            (forbidden ∪ ({excluded} : Finset Name)) sample =
          residual)).card =
      baseFiber *
        ((Finset.univ :
            Finset
              (Fin (∑ name : Name,
                im05_countOutside count forbidden name))).powersetCard
          (im05_countOutside count forbidden excluded)).card := by
  classical
  let Middle :=
    im05_integerMultisetPermutationSample Name
      (im05_countOutside count forbidden)
  let FinalNested :=
    im05_integerMultisetPermutationSample Name
      (im05_countOutside
        (im05_countOutside count forbidden)
        ({excluded} : Finset Name))
  let Final :=
    im05_integerMultisetPermutationSample Name
      (im05_countOutside count
        (forbidden ∪ ({excluded} : Finset Name)))
  let hcount :
      im05_countOutside
          (im05_countOutside count forbidden)
          ({excluded} : Finset Name) =
        im05_countOutside count
          (forbidden ∪ ({excluded} : Finset Name)) :=
    im05_countOutside_countOutside_union
      count forbidden ({excluded} : Finset Name)
  let e : FinalNested ≃ Final :=
    im05_integerMultisetPermutationCountEquiv hcount
  let f :
      im05_integerMultisetPermutationSample Name count → Middle :=
    fun sample =>
      im05_integerMultisetPermutationAllowedSample forbidden sample
  let g : Middle → Final :=
    fun middle =>
      e (im05_integerMultisetPermutationAllowedSample
        ({excluded} : Finset Name) middle)
  let singletonFiber :=
    ((Finset.univ :
        Finset
          (Fin (∑ name : Name,
            im05_countOutside count forbidden name))).powersetCard
      (im05_countOutside count forbidden excluded)).card
  have hg : ∀ final : Final,
      ((Finset.univ : Finset Middle).filter
        (fun middle => g middle = final)).card = singletonFiber := by
    intro final
    exact
      EconCSLib.finite_constant_fiber_card_equiv_comp
        (fun middle : Middle =>
          im05_integerMultisetPermutationAllowedSample
            ({excluded} : Finset Name) middle)
        e singletonFiber
        (fun nested : FinalNested => by
          dsimp [singletonFiber, Middle, FinalNested]
          exact
            im05_integerMultisetPermutationAllowedSample_singleton_fiber_card
              (im05_countOutside count forbidden) excluded nested)
        final
  have hcomp_point :
      ∀ sample : im05_integerMultisetPermutationSample Name count,
        g (f sample) =
          im05_integerMultisetPermutationAllowedSample
            (forbidden ∪ ({excluded} : Finset Name)) sample := by
    intro sample
    dsimp [g, f, e, hcount]
    calc
      im05_integerMultisetPermutationCountEquiv
          (im05_countOutside_countOutside_union
            count forbidden ({excluded} : Finset Name))
          (im05_integerMultisetPermutationAllowedSample
            ({excluded} : Finset Name)
            (im05_integerMultisetPermutationAllowedSample forbidden sample))
          =
        im05_integerMultisetPermutationCountEquiv
          (im05_countOutside_countOutside_union
            count forbidden ({excluded} : Finset Name))
          (im05_integerMultisetPermutationCountEquiv
            (im05_countOutside_countOutside_union
              count forbidden ({excluded} : Finset Name)).symm
            (im05_integerMultisetPermutationAllowedSample
              (forbidden ∪ ({excluded} : Finset Name)) sample)) := by
            rw [im05_integerMultisetPermutationAllowedSample_allowedSample]
      _ =
        im05_integerMultisetPermutationAllowedSample
          (forbidden ∪ ({excluded} : Finset Name)) sample := by
            rw [im05_integerMultisetPermutationCountEquiv_apply_symm]
  have hcomp_card :
      ((Finset.univ :
          Finset (im05_integerMultisetPermutationSample Name count)).filter
        (fun sample => g (f sample) = residual)).card =
        baseFiber * singletonFiber := by
    exact
      EconCSLib.finite_constant_fiber_card_comp
        f g baseFiber singletonFiber hbase hg residual
  have hfilter :
      ((Finset.univ :
          Finset (im05_integerMultisetPermutationSample Name count)).filter
        (fun sample =>
          im05_integerMultisetPermutationAllowedSample
              (forbidden ∪ ({excluded} : Finset Name)) sample =
            residual)) =
        ((Finset.univ :
          Finset (im05_integerMultisetPermutationSample Name count)).filter
        (fun sample => g (f sample) = residual)) := by
    ext sample
    simp [hcomp_point sample]
  rw [hfilter, hcomp_card]

/--
Deleting any finite forbidden set from count-vector samples has constant
positive fiber cardinality.  This is the arbitrary-prefix version of the
singleton fiber theorem and is the main combinatorial certificate needed for
the recursive finite-law route.
-/
theorem im05_integerMultisetPermutationAllowedSample_fiber_card_exists
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (forbidden : Finset Name) :
    ∃ fiberCard : ℕ, 0 < fiberCard ∧
      ∀ residual :
        im05_integerMultisetPermutationSample Name
          (im05_countOutside count forbidden),
        ((Finset.univ :
            Finset (im05_integerMultisetPermutationSample Name count)).filter
          (fun sample =>
            im05_integerMultisetPermutationAllowedSample forbidden sample =
              residual)).card = fiberCard := by
  classical
  refine Finset.induction_on forbidden ?base ?step
  · refine ⟨1, Nat.succ_pos 0, ?_⟩
    intro residual
    exact
      im05_integerMultisetPermutationAllowedSample_empty_fiber_card
        count residual
  · intro excluded forbidden hexcluded_not_forbidden ih
    rcases ih with ⟨baseFiber, hbase_pos, hbase⟩
    let singletonFiber :=
      ((Finset.univ :
          Finset
            (Fin (∑ name : Name,
              im05_countOutside count forbidden name))).powersetCard
        (im05_countOutside count forbidden excluded)).card
    refine
      ⟨baseFiber * singletonFiber,
        Nat.mul_pos hbase_pos ?_, ?_⟩
    · dsimp [singletonFiber]
      exact
        im05_integerMultisetPermutationAllowedSample_singleton_fiber_card_pos
          (im05_countOutside count forbidden) excluded
    · rw [← Finset.union_singleton excluded forbidden]
      intro residual
      simpa [singletonFiber] using
        (im05_integerMultisetPermutationAllowedSample_union_singleton_fiber_card_of_constant_fiber
          count forbidden excluded baseFiber hbase residual)

/--
With full positive support, the first-appearance list of a count-vector sample
contains every name exactly once.
-/
theorem im05_integerMultisetPermutation_firstAppearanceList_length
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (hcount_pos : ∀ name : Name, 0 < count name)
    (sample : im05_integerMultisetPermutationSample Name count) :
    (im05_firstAppearanceList
      (im05_integerMultisetPermutationList sample)).length =
      Fintype.card Name := by
  classical
  let appearance :=
    im05_firstAppearanceList (im05_integerMultisetPermutationList sample)
  have hnodup : appearance.Nodup := by
    dsimp [appearance]
    exact im05_firstAppearanceList_nodup _
  have hmem_all : ∀ name : Name,
      name ∈ im05_integerMultisetPermutationList sample := by
    intro name
    by_contra hnot
    have hcount_zero :
        (im05_integerMultisetPermutationList sample).count name = 0 :=
      List.count_eq_zero_of_not_mem hnot
    rw [im05_integerMultisetPermutationList_count sample name] at hcount_zero
    exact (hcount_pos name).ne' hcount_zero
  have htoFinset : appearance.toFinset = (Finset.univ : Finset Name) := by
    ext name
    simp [appearance, im05_firstAppearanceList_toFinset, hmem_all name]
  have hcard := congrArg Finset.card htoFinset
  rw [List.card_toFinset] at hcard
  have hdedup : appearance.dedup = appearance :=
    List.dedup_eq_self.2 hnodup
  rw [hdedup, Finset.card_univ] at hcard
  simpa [appearance] using hcard

/--
The ordered first appearances of a full-support count-vector sample form a
fresh list containing every name once.
-/
noncomputable def im05_integerMultisetPermutationFirstAppearanceFreshList
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (hcount_pos : ∀ name : Name, 0 < count name)
    (sample : im05_integerMultisetPermutationSample Name count) :
    EconCSLib.finiteFreshList Name (Fintype.card Name) (∅ : Finset Name) := by
  classical
  let appearance :=
    im05_firstAppearanceList (im05_integerMultisetPermutationList sample)
  have hlen : appearance.length = Fintype.card Name := by
    dsimp [appearance]
    exact
      im05_integerMultisetPermutation_firstAppearanceList_length
        hcount_pos sample
  have hnodup : appearance.Nodup := by
    dsimp [appearance]
    exact im05_firstAppearanceList_nodup _
  refine
    ⟨(fun slot : Fin (Fintype.card Name) =>
        appearance.get (Fin.cast hlen.symm slot)), ?_, ?_⟩
  · intro slot₁ slot₂ hvalue
    have hcast :
        Fin.cast hlen.symm slot₁ = Fin.cast hlen.symm slot₂ :=
      hnodup.injective_get hvalue
    apply Fin.ext
    have hval := congrArg Fin.val hcast
    simpa using hval
  · intro slot
    simp

/--
Prefix omission in the first-appearance fresh list is ordinary omission from
the corresponding prefix of the first-appearance list.
-/
theorem im05_integerMultisetPermutationFirstAppearanceFreshList_prefix_omits_iff
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (hcount_pos : ∀ name : Name, 0 < count name)
    (sample : im05_integerMultisetPermutationSample Name count)
    (target : Name) (k : ℕ) :
    im05_listPrefixOmits target k
        (im05_integerMultisetPermutationFirstAppearanceFreshList
          hcount_pos sample).1 ↔
      target ∉
        (im05_firstAppearanceList
          (im05_integerMultisetPermutationList sample)).take k := by
  classical
  let appearance :=
    im05_firstAppearanceList (im05_integerMultisetPermutationList sample)
  let fresh :=
    im05_integerMultisetPermutationFirstAppearanceFreshList
      hcount_pos sample
  have hlen : appearance.length = Fintype.card Name := by
    dsimp [appearance]
    exact
      im05_integerMultisetPermutation_firstAppearanceList_length
        hcount_pos sample
  have htarget_mem : target ∈ appearance := by
    dsimp [appearance]
    rw [im05_mem_firstAppearanceList_iff]
    by_contra hnot
    have hcount_zero :
        (im05_integerMultisetPermutationList sample).count target = 0 :=
      List.count_eq_zero_of_not_mem hnot
    rw [im05_integerMultisetPermutationList_count sample target] at hcount_zero
    exact (hcount_pos target).ne' hcount_zero
  constructor
  · intro homit hmem_take
    have hidx_lt_k : appearance.idxOf target < k :=
      (List.mem_take_iff_idxOf_lt htarget_mem).1 hmem_take
    have hidx_lt_len : appearance.idxOf target < appearance.length :=
      List.idxOf_lt_length_iff.2 htarget_mem
    let slot : Fin (Fintype.card Name) :=
      ⟨appearance.idxOf target, by simpa [hlen] using hidx_lt_len⟩
    have hslot_lt : slot.val < k := hidx_lt_k
    have hcast :
        Fin.cast hlen.symm slot =
          (⟨appearance.idxOf target, hidx_lt_len⟩ :
            Fin appearance.length) := by
      ext
      rfl
    have hdraw : fresh.1 slot = target := by
      dsimp [fresh, im05_integerMultisetPermutationFirstAppearanceFreshList]
      change appearance.get (Fin.cast hlen.symm slot) = target
      rw [hcast]
      exact List.getElem_idxOf hidx_lt_len
    exact homit slot hslot_lt hdraw
  · intro hnot_mem slot hslot_lt hdraw
    have hcast_lt :
        (Fin.cast hlen.symm slot).val < appearance.length :=
      (Fin.cast hlen.symm slot).isLt
    have htake_lt :
        (Fin.cast hlen.symm slot).val < (appearance.take k).length := by
      rw [List.length_take]
      have hval_eq : (Fin.cast hlen.symm slot).val = slot.val := rfl
      rw [hval_eq]
      exact lt_min hslot_lt (by simpa [hval_eq] using hcast_lt)
    have happearance_get :
        appearance[(Fin.cast hlen.symm slot).val] = target := by
      dsimp [fresh, im05_integerMultisetPermutationFirstAppearanceFreshList]
        at hdraw
      change appearance.get (Fin.cast hlen.symm slot) = target at hdraw
      simpa using hdraw
    have hmem_take : target ∈ appearance.take k := by
      rw [List.mem_iff_getElem]
      refine ⟨(Fin.cast hlen.symm slot).val, htake_lt, ?_⟩
      rw [List.getElem_take]
      exact happearance_get
    exact hnot_mem hmem_take

/--
For a positive count-vector sample, prefix omission in the first-appearance
fresh list is exactly the paper event that at least `k` distinct names appear
before the first `target` in the sampled word.
-/
theorem im05_integerMultisetPermutationFirstAppearanceFreshList_prefix_omits_iff_namesBeforeFirst_card
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (hcount_pos : ∀ name : Name, 0 < count name)
    (sample : im05_integerMultisetPermutationSample Name count)
    (target : Name) (k : ℕ) :
    im05_listPrefixOmits target k
        (im05_integerMultisetPermutationFirstAppearanceFreshList
          hcount_pos sample).1 ↔
      k ≤
        (im05_namesBeforeFirst id target
          (im05_integerMultisetPermutationList sample)).card := by
  classical
  have htarget_mem :
      target ∈ im05_integerMultisetPermutationList sample := by
    by_contra hnot
    have hcount_zero :
        (im05_integerMultisetPermutationList sample).count target = 0 :=
      List.count_eq_zero_of_not_mem hnot
    rw [im05_integerMultisetPermutationList_count sample target] at hcount_zero
    exact (hcount_pos target).ne' hcount_zero
  rw [im05_integerMultisetPermutationFirstAppearanceFreshList_prefix_omits_iff
    hcount_pos sample target k]
  exact
    im05_firstAppearanceList_not_mem_take_iff_le_namesBeforeFirst_card
      target (im05_integerMultisetPermutationList sample) htarget_mem k

/--
For count-vector samples, erasing `excluded` from the names before first
`target` agrees with computing names before first `target` after filtering
`excluded` out of the sampled word.
-/
theorem im05_integerMultisetPermutation_namesBeforeFirst_erase_eq_allowedList
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    (target excluded : Name) (hneq : target ≠ excluded) :
    (im05_namesBeforeFirst id target
      (im05_integerMultisetPermutationList sample)).erase excluded =
      im05_namesBeforeFirst id target
        (im05_integerMultisetPermutationAllowedList
          ({excluded} : Finset Name) sample) := by
  classical
  rw [im05_namesBeforeFirst_erase_eq_namesBeforeFirst_filter_ne
    target excluded hneq]
  congr 1
  rw [im05_integerMultisetPermutationAllowedList]
  congr 1
  funext name
  by_cases h : name = excluded <;> simp [h]

/--
For the singleton-deletion event at `k = 1`, the erased paper event is
equivalent to the first remaining non-excluded symbol not being the target.
-/
theorem im05_integerMultisetPermutation_erased_namesBeforeFirst_one_iff_allowedList_head_ne
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (hcount_pos : ∀ name : Name, 0 < count name)
    (sample : im05_integerMultisetPermutationSample Name count)
    (target excluded : Name) (hneq : target ≠ excluded)
    (hallowed_pos :
      0 <
        (im05_integerMultisetPermutationAllowedList
          ({excluded} : Finset Name) sample).length) :
    1 ≤
        ((im05_namesBeforeFirst id target
          (im05_integerMultisetPermutationList sample)).erase excluded).card ↔
      (im05_integerMultisetPermutationAllowedList
          ({excluded} : Finset Name) sample).get
        ⟨0, hallowed_pos⟩ ≠ target := by
  classical
  have htarget_allowed :
      target ∈ im05_integerMultisetPermutationAllowedList
        ({excluded} : Finset Name) sample := by
    have hcount :=
      im05_integerMultisetPermutationAllowedList_count
        ({excluded} : Finset Name) sample target
    have hnot : target ∉ ({excluded} : Finset Name) := by
      simpa [Finset.mem_singleton] using hneq
    rw [im05_countOutside, if_neg hnot] at hcount
    exact List.count_pos_iff.mp (by
      rw [hcount]
      exact hcount_pos target)
  rw [im05_integerMultisetPermutation_namesBeforeFirst_erase_eq_allowedList
    sample target excluded hneq]
  exact
    im05_one_le_namesBeforeFirst_card_iff_head_ne
      target
      (im05_integerMultisetPermutationAllowedList
        ({excluded} : Finset Name) sample)
      hallowed_pos htarget_allowed

/--
For singleton deletion, the erased paper event is exactly omission from the
first `k` first appearances of the word with all copies of `excluded` removed.
-/
theorem
    im05_integerMultisetPermutation_erased_namesBeforeFirst_iff_allowedList_firstAppearance_not_mem_take
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (hcount_pos : ∀ name : Name, 0 < count name)
    (sample : im05_integerMultisetPermutationSample Name count)
    (target excluded : Name) (hneq : target ≠ excluded) (k : ℕ) :
    k ≤
        ((im05_namesBeforeFirst id target
          (im05_integerMultisetPermutationList sample)).erase excluded).card ↔
      target ∉
        (im05_firstAppearanceList
          (im05_integerMultisetPermutationAllowedList
            ({excluded} : Finset Name) sample)).take k := by
  classical
  have htarget_allowed :
      target ∈ im05_integerMultisetPermutationAllowedList
        ({excluded} : Finset Name) sample := by
    have hcount :=
      im05_integerMultisetPermutationAllowedList_count
        ({excluded} : Finset Name) sample target
    have hnot : target ∉ ({excluded} : Finset Name) := by
      simpa [Finset.mem_singleton] using hneq
    rw [im05_countOutside, if_neg hnot] at hcount
    exact List.count_pos_iff.mp (by
      rw [hcount]
      exact hcount_pos target)
  rw [im05_integerMultisetPermutation_namesBeforeFirst_erase_eq_allowedList
    sample target excluded hneq]
  exact
    (im05_firstAppearanceList_not_mem_take_iff_le_namesBeforeFirst_card
      target
      (im05_integerMultisetPermutationAllowedList
        ({excluded} : Finset Name) sample)
      htarget_allowed k).symm

/-- The first symbol of a nonempty integer-multiset permutation sample. -/
def im05_integerMultisetPermutationFirst
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (sample : im05_integerMultisetPermutationSample Name count) : Name :=
  sample.1 ⟨0, im05_sum_count_pos_of_pos count target hpos⟩

/--
Slot choices for inserting all copies of `head`, restricted to choices that
put one copy in the first slot.  These are the insertion certificates for
samples whose first symbol is `head` and whose `head` copies are then deleted.
-/
abbrev im05_integerMultisetPermutationHeadDeletedSlotChoices
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (head : Name) (hpos : 0 < count head) :=
  {deletedSlots : Finset (Fin (∑ name : Name, count name)) //
    deletedSlots ∈
      (Finset.univ : Finset (Fin (∑ name : Name, count name))).powersetCard
        (count head) ∧
    (⟨0, im05_sum_count_pos_of_pos count head hpos⟩ :
      Fin (∑ name : Name, count name)) ∈ deletedSlots}

/--
The conditional singleton-deletion fiber over a residual word is equivalent to
the slot choices that contain the first slot.
-/
noncomputable def im05_integerMultisetPermutationAllowedSampleHeadFiberEquiv
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (head : Name) (hpos : 0 < count head)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({head} : Finset Name))) :
    im05_integerMultisetPermutationHeadDeletedSlotChoices count head hpos ≃
      {sample : im05_integerMultisetPermutationSample Name count //
        im05_integerMultisetPermutationFirst head hpos sample = head ∧
          im05_integerMultisetPermutationAllowedSample
              ({head} : Finset Name) sample =
            residual} where
  toFun slotChoice :=
    let hcard : slotChoice.1.card = count head :=
      (Finset.mem_powersetCard.mp slotChoice.2.1).2
    ⟨im05_integerMultisetPermutationInsertSingletonSample
        count head residual slotChoice.1 hcard,
      by
        constructor
        · dsimp [im05_integerMultisetPermutationFirst]
          exact
            im05_integerMultisetPermutationInsertSingletonWord_of_mem
              count head residual slotChoice.1 hcard
              ⟨0, im05_sum_count_pos_of_pos count head hpos⟩
              slotChoice.2.2
        · exact
            im05_integerMultisetPermutationAllowedSample_insertSingletonSample
              count head residual slotChoice.1 hcard⟩
  invFun fiberSample :=
    ⟨im05_integerMultisetPermutationNameSlots fiberSample.1 head,
      ⟨im05_integerMultisetPermutationNameSlots_mem_powersetCard
          fiberSample.1 head,
        by
          rw [im05_mem_integerMultisetPermutationNameSlots_iff]
          exact fiberSample.2.1⟩⟩
  left_inv slotChoice := by
    apply Subtype.ext
    dsimp
    exact
      im05_integerMultisetPermutationNameSlots_insertSingletonSample
        count head residual slotChoice.1
        ((Finset.mem_powersetCard.mp slotChoice.2.1).2)
  right_inv fiberSample := by
    apply Subtype.ext
    dsimp
    exact
      im05_integerMultisetPermutationInsertSingletonSample_of_allowedSample
        fiberSample.1 head residual fiberSample.2.2

/--
The conditional fiber of singleton deletion, additionally requiring `head` in
the first slot, has a residual-independent cardinality.
-/
theorem im05_integerMultisetPermutationAllowedSample_head_fiber_card
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (head : Name) (hpos : 0 < count head)
    (residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({head} : Finset Name))) :
    ((Finset.univ :
        Finset (im05_integerMultisetPermutationSample Name count)).filter
      (fun sample =>
        im05_integerMultisetPermutationFirst head hpos sample = head ∧
          im05_integerMultisetPermutationAllowedSample
              ({head} : Finset Name) sample =
            residual)).card =
      Fintype.card
        (im05_integerMultisetPermutationHeadDeletedSlotChoices
          count head hpos) := by
  classical
  let fiberPred :
      im05_integerMultisetPermutationSample Name count → Prop :=
    fun sample =>
      im05_integerMultisetPermutationFirst head hpos sample = head ∧
        im05_integerMultisetPermutationAllowedSample
            ({head} : Finset Name) sample =
          residual
  calc
    ((Finset.univ :
        Finset (im05_integerMultisetPermutationSample Name count)).filter
      (fun sample =>
        im05_integerMultisetPermutationFirst head hpos sample = head ∧
          im05_integerMultisetPermutationAllowedSample
              ({head} : Finset Name) sample =
            residual)).card
        = Fintype.card
            {sample : im05_integerMultisetPermutationSample Name count //
              fiberPred sample} := by
            rw [Fintype.card_subtype]
    _ =
      Fintype.card
        (im05_integerMultisetPermutationHeadDeletedSlotChoices
          count head hpos) := by
        exact
          Fintype.card_congr
            (im05_integerMultisetPermutationAllowedSampleHeadFiberEquiv
              count head hpos residual).symm

/-- There is at least one insertion slot choice that contains the first slot. -/
theorem im05_integerMultisetPermutationHeadDeletedSlotChoices_card_pos
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (head : Name) (hpos : 0 < count head) :
    0 <
      Fintype.card
        (im05_integerMultisetPermutationHeadDeletedSlotChoices
          count head hpos) := by
  classical
  let total := ∑ name : Name, count name
  let firstSlot : Fin total :=
    ⟨0, im05_sum_count_pos_of_pos count head hpos⟩
  have hle_count_total : count head ≤ total :=
    Finset.single_le_sum
      (fun name _hname => Nat.zero_le (count name))
      (Finset.mem_univ head)
  have hfirst_mem_univ :
      firstSlot ∈ (Finset.univ : Finset (Fin total)) := by
    simp
  have htail_le :
      count head - 1 ≤
        ((Finset.univ : Finset (Fin total)).erase firstSlot).card := by
    rw [Finset.card_erase_of_mem hfirst_mem_univ]
    simpa [total] using Nat.sub_le_sub_right hle_count_total 1
  have htail_nonempty :
      (((Finset.univ : Finset (Fin total)).erase firstSlot).powersetCard
          (count head - 1)).Nonempty :=
    Finset.powersetCard_nonempty.mpr htail_le
  rcases htail_nonempty with ⟨tailSlots, htailSlots⟩
  have htail_subset :
      tailSlots ⊆ (Finset.univ : Finset (Fin total)).erase firstSlot :=
    (Finset.mem_powersetCard.mp htailSlots).1
  have htail_card :
      tailSlots.card = count head - 1 :=
    (Finset.mem_powersetCard.mp htailSlots).2
  have hfirst_not_tail : firstSlot ∉ tailSlots := by
    intro hmem
    have hmem_erase : firstSlot ∈
        (Finset.univ : Finset (Fin total)).erase firstSlot :=
      htail_subset hmem
    simpa using hmem_erase
  refine Fintype.card_pos_iff.mpr ?_
  refine
    ⟨⟨insert firstSlot tailSlots, ⟨?_, by simp [firstSlot]⟩⟩⟩
  rw [Finset.mem_powersetCard]
  constructor
  · intro slot hslot
    simp
  · rw [Finset.card_insert_of_notMem hfirst_not_tail, htail_card]
    omega

/--
The first entry of the first-appearance fresh list is the first symbol of the
underlying count-vector word.
-/
theorem im05_integerMultisetPermutationFirstAppearanceFreshList_zero
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (hcount_pos : ∀ name : Name, 0 < count name)
    (sample : im05_integerMultisetPermutationSample Name count)
    (target : Name) :
    (im05_integerMultisetPermutationFirstAppearanceFreshList
      hcount_pos sample).1
        ⟨0, Fintype.card_pos_iff.mpr ⟨target⟩⟩ =
      im05_integerMultisetPermutationFirst target (hcount_pos target) sample := by
  classical
  let list := im05_integerMultisetPermutationList sample
  let appearance := im05_firstAppearanceList list
  have hlen : appearance.length = Fintype.card Name := by
    dsimp [appearance, list]
    exact im05_integerMultisetPermutation_firstAppearanceList_length
      hcount_pos sample
  have htotal_pos : 0 < ∑ name : Name, count name :=
    im05_sum_count_pos_of_pos count target (hcount_pos target)
  have hlist_pos : 0 < list.length := by
    dsimp [list, im05_integerMultisetPermutationList]
    simpa using htotal_pos
  have happ_pos : 0 < appearance.length := by
    rw [hlen]
    exact Fintype.card_pos_iff.mpr ⟨target⟩
  have hcast :
      Fin.cast hlen.symm ⟨0, Fintype.card_pos_iff.mpr ⟨target⟩⟩ =
        (⟨0, happ_pos⟩ : Fin appearance.length) := by
    ext
    rfl
  dsimp [im05_integerMultisetPermutationFirstAppearanceFreshList,
    im05_integerMultisetPermutationFirst, appearance, list]
  change appearance.get
      (Fin.cast hlen.symm ⟨0, Fintype.card_pos_iff.mpr ⟨target⟩⟩) =
    sample.1 ⟨0, im05_sum_count_pos_of_pos count target (hcount_pos target)⟩
  rw [hcast]
  rw [im05_firstAppearanceList_get_zero_eq list hlist_pos]
  dsimp [list, im05_integerMultisetPermutationList]
  simp

/-- The first symbol of a sample, using only a proof that the total count is positive. -/
def im05_integerMultisetPermutationFirstOfTotal
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (htotal : 0 < ∑ name : Name, count name)
    (sample : im05_integerMultisetPermutationSample Name count) : Name :=
  sample.1 ⟨0, htotal⟩

/-- The first symbol of a nonempty count-vector sample has positive count. -/
theorem im05_integerMultisetPermutationFirstOfTotal_count_pos
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (htotal : 0 < ∑ name : Name, count name)
    (sample : im05_integerMultisetPermutationSample Name count) :
    0 < count (im05_integerMultisetPermutationFirstOfTotal htotal sample) := by
  classical
  let first := im05_integerMultisetPermutationFirstOfTotal htotal sample
  have hcount := sample.2 first
  have hname_count_pos : 0 < im05_nameCountInWord sample.1 first := by
    unfold im05_nameCountInWord
    refine Finset.card_pos.mpr ?_
    refine ⟨⟨0, htotal⟩, ?_⟩
    simp [first, im05_integerMultisetPermutationFirstOfTotal]
  rwa [hcount] at hname_count_pos

/-- The target-indexed and total-indexed first-symbol definitions agree. -/
theorem im05_integerMultisetPermutationFirst_eq_firstOfTotal
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (htotal : 0 < ∑ name : Name, count name)
    (sample : im05_integerMultisetPermutationSample Name count) :
    im05_integerMultisetPermutationFirst target hpos sample =
      im05_integerMultisetPermutationFirstOfTotal htotal sample := by
  unfold im05_integerMultisetPermutationFirst
  unfold im05_integerMultisetPermutationFirstOfTotal
  congr 1

/--
For a fixed target, the samples whose first slot is `target` are equinumerous
with the samples whose arbitrary slot is `target`.
-/
noncomputable def im05_integerMultisetPermutationFirstSlotEventEquiv
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (slot : Fin (∑ name : Name, count name)) :
    {sample : im05_integerMultisetPermutationSample Name count //
      im05_integerMultisetPermutationFirst target hpos sample = target} ≃
      {sample : im05_integerMultisetPermutationSample Name count //
        sample.1 slot = target} := by
  classical
  let firstSlot : Fin (∑ name : Name, count name) :=
    ⟨0, im05_sum_count_pos_of_pos count target hpos⟩
  let swapSlots : Fin (∑ name : Name, count name) ≃
      Fin (∑ name : Name, count name) :=
    Equiv.swap firstSlot slot
  let reindex :=
    im05_integerMultisetPermutationReindexEquiv
      (Name := Name) (count := count) swapSlots
  refine
    { toFun := fun sample =>
        ⟨reindex sample.1, ?_⟩
      invFun := fun sample =>
        ⟨reindex sample.1, ?_⟩
      left_inv := ?_
      right_inv := ?_ }
  · dsimp [reindex, im05_integerMultisetPermutationReindexEquiv, swapSlots]
    change sample.1.1 ((Equiv.swap firstSlot slot) slot) = target
    rw [Equiv.swap_apply_right]
    simpa [firstSlot, im05_integerMultisetPermutationFirst] using sample.2
  · dsimp [reindex, im05_integerMultisetPermutationReindexEquiv, swapSlots]
    change sample.1.1 ((Equiv.swap firstSlot slot) firstSlot) = target
    rw [Equiv.swap_apply_left]
    exact sample.2
  · intro sample
    apply Subtype.ext
    ext idx
    dsimp [reindex, im05_integerMultisetPermutationReindexEquiv, swapSlots]
    rw [Equiv.swap_apply_self]
  · intro sample
    apply Subtype.ext
    ext idx
    dsimp [reindex, im05_integerMultisetPermutationReindexEquiv, swapSlots]
    rw [Equiv.swap_apply_self]

/--
The tail word of an integer-multiset sample after casting its length to
`sum (decrement count target) + 1`.
-/
noncomputable def im05_integerMultisetPermutationTailWordOfHead
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (sample : im05_integerMultisetPermutationSample Name count) :
    Fin (∑ name : Name, im05_decrementCount count target name) → Name :=
  im05_wordTail
    (fun slot :
        Fin ((∑ name : Name, im05_decrementCount count target name) + 1) =>
      sample.1
        (Fin.cast
          (im05_sum_decrementCount_add_one_of_pos count target hpos)
          slot))

/--
If the first symbol of an integer-multiset sample is `target`, its tail has the
decremented count vector.
-/
theorem im05_integerMultisetPermutationTailWordOfHead_count
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (sample : im05_integerMultisetPermutationSample Name count)
    (hhead :
      im05_integerMultisetPermutationFirst target hpos sample = target)
    (name : Name) :
    im05_nameCountInWord
        (im05_integerMultisetPermutationTailWordOfHead target hpos sample)
        name =
      im05_decrementCount count target name := by
  classical
  let hsum :=
    im05_sum_decrementCount_add_one_of_pos count target hpos
  let castWord :
      Fin ((∑ name : Name, im05_decrementCount count target name) + 1) →
        Name :=
    fun slot => sample.1 (Fin.cast hsum slot)
  have hcast_count : ∀ name : Name,
      im05_nameCountInWord castWord name = count name := by
    intro name
    dsimp [castWord]
    rw [im05_nameCountInWord_cast hsum sample.1 name]
    exact sample.2 name
  have hcast_head :
      castWord ⟨0, Nat.succ_pos _⟩ = target := by
    dsimp [castWord]
    simpa [im05_integerMultisetPermutationFirst] using hhead
  simpa [im05_integerMultisetPermutationTailWordOfHead, castWord, hsum] using
    im05_nameCountInWord_wordTail_eq_decrement
      castWord count target hcast_count hcast_head name

/-- The tail of a sample whose first symbol is `target`, as a decremented-count sample. -/
noncomputable def im05_integerMultisetPermutationTailSampleOfHead
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (sample : im05_integerMultisetPermutationSample Name count)
    (hhead :
      im05_integerMultisetPermutationFirst target hpos sample = target) :
    im05_integerMultisetPermutationSample Name
      (im05_decrementCount count target) :=
  ⟨im05_integerMultisetPermutationTailWordOfHead target hpos sample,
    im05_integerMultisetPermutationTailWordOfHead_count
      target hpos sample hhead⟩

/-- Prepend `target` to a decremented-count sample, recovering a full-count word. -/
noncomputable def im05_integerMultisetPermutationConsSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (tail :
      im05_integerMultisetPermutationSample Name
        (im05_decrementCount count target)) :
    im05_integerMultisetPermutationSample Name count := by
  classical
  let hsum :=
    im05_sum_decrementCount_add_one_of_pos count target hpos
  let consWord :
      Fin ((∑ name : Name, im05_decrementCount count target name) + 1) →
        Name :=
    EconCSLib.finCons target tail.1
  refine
    ⟨(fun slot : Fin (∑ name : Name, count name) =>
        consWord (Fin.cast hsum.symm slot)), ?_⟩
  intro name
  rw [im05_nameCountInWord_cast hsum.symm consWord name]
  have hsplit := im05_nameCountInWord_succ consWord name
  have htail_eq : im05_wordTail consWord = tail.1 := by
    dsimp [consWord]
    simp
  rw [htail_eq] at hsplit
  by_cases hname : name = target
  · subst name
    have hhead_eq : consWord ⟨0, Nat.succ_pos _⟩ = target := by
      dsimp [consWord]
      exact EconCSLib.finCons_zero target tail.1
    rw [if_pos hhead_eq] at hsplit
    rw [tail.2 target] at hsplit
    rw [im05_decrementCount_self] at hsplit
    omega
  · have hhead_ne : consWord ⟨0, Nat.succ_pos _⟩ ≠ name := by
      intro h
      exact hname h.symm
    rw [if_neg hhead_ne] at hsplit
    rw [tail.2 name] at hsplit
    rw [im05_decrementCount_of_ne count hname] at hsplit
    omega

/-- The cons construction really has `target` as its first symbol. -/
theorem im05_integerMultisetPermutationConsSample_first
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (tail :
      im05_integerMultisetPermutationSample Name
        (im05_decrementCount count target)) :
    im05_integerMultisetPermutationFirst target hpos
        (im05_integerMultisetPermutationConsSample target hpos tail) =
      target := by
  classical
  unfold im05_integerMultisetPermutationFirst
  unfold im05_integerMultisetPermutationConsSample
  dsimp only
  let hsum :=
    im05_sum_decrementCount_add_one_of_pos count target hpos
  let consWord :
      Fin ((∑ name : Name, im05_decrementCount count target name) + 1) →
        Name :=
    EconCSLib.finCons target tail.1
  have hslot :
      Fin.cast hsum.symm
          ⟨0, im05_sum_count_pos_of_pos count target hpos⟩ =
        (⟨0, Nat.succ_pos _⟩ :
          Fin ((∑ name : Name, im05_decrementCount count target name) + 1)) := by
    ext
    rfl
  rw [hslot]
  exact EconCSLib.finCons_zero target tail.1

/-- The total-indexed first symbol of a consed sample is the consed head. -/
theorem im05_integerMultisetPermutationFirstOfTotal_consSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (htotal : 0 < ∑ name : Name, count name)
    (tail :
      im05_integerMultisetPermutationSample Name
        (im05_decrementCount count target)) :
    im05_integerMultisetPermutationFirstOfTotal htotal
        (im05_integerMultisetPermutationConsSample target hpos tail) =
      target := by
  rw [← im05_integerMultisetPermutationFirst_eq_firstOfTotal
    target hpos htotal]
  exact im05_integerMultisetPermutationConsSample_first target hpos tail

/-- Taking the tail of a consed integer-multiset sample recovers the tail sample. -/
theorem im05_integerMultisetPermutationTailSampleOfHead_consSample
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (tail :
      im05_integerMultisetPermutationSample Name
        (im05_decrementCount count target)) :
    im05_integerMultisetPermutationTailSampleOfHead target hpos
        (im05_integerMultisetPermutationConsSample target hpos tail)
        (im05_integerMultisetPermutationConsSample_first target hpos tail) =
      tail := by
  classical
  ext slot
  unfold im05_integerMultisetPermutationTailSampleOfHead
  unfold im05_integerMultisetPermutationTailWordOfHead
  unfold im05_integerMultisetPermutationConsSample
  change EconCSLib.finCons target tail.1 slot.succ = tail.1 slot
  exact EconCSLib.finCons_succ target tail.1 slot

/-- Consing the tail of a sample in the `target`-head fiber recovers the sample. -/
theorem im05_integerMultisetPermutationConsSample_tailSampleOfHead
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target)
    (sample : im05_integerMultisetPermutationSample Name count)
    (hhead :
      im05_integerMultisetPermutationFirst target hpos sample = target) :
    im05_integerMultisetPermutationConsSample target hpos
        (im05_integerMultisetPermutationTailSampleOfHead target hpos sample hhead) =
      sample := by
  classical
  ext slot
  let hsum :=
    im05_sum_decrementCount_add_one_of_pos count target hpos
  unfold im05_integerMultisetPermutationConsSample
  unfold im05_integerMultisetPermutationTailSampleOfHead
  unfold im05_integerMultisetPermutationTailWordOfHead
  dsimp only
  generalize hcast :
      Fin.cast hsum.symm slot = castSlot
  cases castSlot using Fin.cases with
  | zero =>
      have hslot_zero :
          slot = ⟨0, im05_sum_count_pos_of_pos count target hpos⟩ := by
        apply Fin.ext
        have hval := congrArg Fin.val hcast
        simpa using hval
      change target = sample.1 slot
      rw [hslot_zero]
      exact hhead.symm
  | succ pred =>
      have hslot_back : Fin.cast hsum pred.succ = slot := by
        apply Fin.ext
        have hval := congrArg Fin.val hcast
        simpa using hval.symm
      change
        im05_wordTail
            (fun slot :
                Fin ((∑ name : Name, im05_decrementCount count target name) + 1) =>
              sample.1 (Fin.cast hsum slot))
            pred =
          sample.1 slot
      dsimp [im05_wordTail]
      rw [hslot_back]

/--
The first-symbol fiber over `target` is equivalent to the decremented-count
sample space.
-/
noncomputable def im05_integerMultisetPermutationHeadFiberEquiv
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target) :
    {sample : im05_integerMultisetPermutationSample Name count //
      im05_integerMultisetPermutationFirst target hpos sample = target} ≃
      im05_integerMultisetPermutationSample Name
        (im05_decrementCount count target) where
  toFun sample :=
    im05_integerMultisetPermutationTailSampleOfHead
      target hpos sample.1 sample.2
  invFun tail :=
    ⟨im05_integerMultisetPermutationConsSample target hpos tail,
      im05_integerMultisetPermutationConsSample_first target hpos tail⟩
  left_inv sample := by
    apply Subtype.ext
    exact
      im05_integerMultisetPermutationConsSample_tailSampleOfHead
        target hpos sample.1 sample.2
  right_inv tail :=
    im05_integerMultisetPermutationTailSampleOfHead_consSample
      target hpos tail

/-- Cardinality form of the first-symbol fiber equivalence. -/
theorem im05_integerMultisetPermutationHeadFiber_card
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (target : Name) (hpos : 0 < count target) :
    Fintype.card
        {sample : im05_integerMultisetPermutationSample Name count //
          im05_integerMultisetPermutationFirst target hpos sample = target} =
      Fintype.card
        (im05_integerMultisetPermutationSample Name
          (im05_decrementCount count target)) := by
  exact Fintype.card_congr
    (im05_integerMultisetPermutationHeadFiberEquiv target hpos)

/--
The fiber over a positive total-indexed first symbol is equivalent to the
decremented-count tail sample space.
-/
noncomputable def im05_integerMultisetPermutationFirstOfTotalFiberEquiv
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (htotal : 0 < ∑ name : Name, count name)
    (head : {name : Name // 0 < count name}) :
    {sample : im05_integerMultisetPermutationSample Name count //
      (⟨im05_integerMultisetPermutationFirstOfTotal htotal sample,
        im05_integerMultisetPermutationFirstOfTotal_count_pos htotal sample⟩ :
        {name : Name // 0 < count name}) = head} ≃
        im05_integerMultisetPermutationSample Name
          (im05_decrementCount count head.1) where
  toFun sample :=
    let hfirst_name :
        im05_integerMultisetPermutationFirstOfTotal htotal sample.1 =
          head.1 :=
      congrArg Subtype.val sample.2
    let hhead :
        im05_integerMultisetPermutationFirst head.1 head.2 sample.1 =
          head.1 := by
      rw [im05_integerMultisetPermutationFirst_eq_firstOfTotal
        head.1 head.2 htotal sample.1]
      exact hfirst_name
    im05_integerMultisetPermutationTailSampleOfHead
      head.1 head.2 sample.1 hhead
  invFun tail :=
    ⟨im05_integerMultisetPermutationConsSample head.1 head.2 tail, by
      apply Subtype.ext
      exact
        im05_integerMultisetPermutationFirstOfTotal_consSample
          head.1 head.2 htotal tail⟩
  left_inv sample := by
    apply Subtype.ext
    let hfirst_name :
        im05_integerMultisetPermutationFirstOfTotal htotal sample.1 =
          head.1 :=
      congrArg Subtype.val sample.2
    let hhead :
        im05_integerMultisetPermutationFirst head.1 head.2 sample.1 =
          head.1 := by
      rw [im05_integerMultisetPermutationFirst_eq_firstOfTotal
        head.1 head.2 htotal sample.1]
      exact hfirst_name
    exact
      im05_integerMultisetPermutationConsSample_tailSampleOfHead
        head.1 head.2 sample.1 hhead
  right_inv tail :=
    im05_integerMultisetPermutationTailSampleOfHead_consSample
      head.1 head.2 tail

/--
A nonempty count-vector sample is equivalently a positive-count head name
together with a tail sample for the decremented count vector.
-/
noncomputable def im05_integerMultisetPermutationFirstSigmaEquiv
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (htotal : 0 < ∑ name : Name, count name) :
    im05_integerMultisetPermutationSample Name count ≃
      Sigma (fun head : {name : Name // 0 < count name} =>
        im05_integerMultisetPermutationSample Name
          (im05_decrementCount count head.1)) :=
  (Equiv.sigmaFiberEquiv
      (fun sample : im05_integerMultisetPermutationSample Name count =>
        (⟨im05_integerMultisetPermutationFirstOfTotal htotal sample,
          im05_integerMultisetPermutationFirstOfTotal_count_pos htotal sample⟩ :
          {name : Name // 0 < count name}))).symm.trans
    (Equiv.sigmaCongrRight
      (im05_integerMultisetPermutationFirstOfTotalFiberEquiv
        (Name := Name) (count := count) htotal))

/-- The integer-multiset sample space is inhabited for every count vector. -/
theorem im05_integerMultisetPermutationSample_nonempty
    (Name : Type*) [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) :
    Nonempty (im05_integerMultisetPermutationSample Name count) := by
  classical
  let list := im05_countVectorList count
  have hlen : list.length = ∑ name : Name, count name := by
    dsimp [list]
    exact im05_countVectorList_length count
  refine ⟨⟨(fun slot => list.get (Fin.cast hlen.symm slot)), ?_⟩⟩
  intro target
  rw [im05_nameCountInWord_eq_count_ofFn]
  have hlist :
      List.ofFn (fun slot : Fin (∑ name : Name, count name) =>
        list.get (Fin.cast hlen.symm slot)) = list := by
    refine List.ext_get_iff.mpr ?_
    constructor
    · simp [hlen]
    · intro n hleft hright
      rw [List.get_ofFn]
      congr 1
  rw [hlist]
  dsimp [list]
  exact im05_countVectorList_count count target

/-- Typeclass instance: every prescribed finite count vector has a word sample. -/
noncomputable instance im05_integerMultisetPermutationSample.instNonempty
    (Name : Type*) [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) :
    Nonempty (im05_integerMultisetPermutationSample Name count) :=
  im05_integerMultisetPermutationSample_nonempty Name count

/--
Conditioning a uniform count-vector word on `head` being the first symbol,
then deleting all copies of `head`, leaves the uniform law over residual
count-vector words.
-/
theorem im05_integerMultisetPermutationAllowedSample_head_conditional_uniform_event_eq
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (head : Name) (hpos : 0 < count head)
    (event :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count ({head} : Finset Name)) → Prop)
    [DecidablePred event] :
    EconCSLib.pmfConditionalProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst head hpos sample = head)
        (fun sample =>
          event
            (im05_integerMultisetPermutationAllowedSample
              ({head} : Finset Name) sample)) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name
            (im05_countOutside count ({head} : Finset Name))))
        event := by
  classical
  let fiberCard :=
    Fintype.card
      (im05_integerMultisetPermutationHeadDeletedSlotChoices
        count head hpos)
  exact
    EconCSLib.pmfConditionalProb_uniformPMF_comp_eq_of_constant_conditional_fiber_card
      (condition := fun sample :
          im05_integerMultisetPermutationSample Name count =>
        im05_integerMultisetPermutationFirst head hpos sample = head)
      (f := fun sample =>
        im05_integerMultisetPermutationAllowedSample
          ({head} : Finset Name) sample)
      fiberCard
      (by
        simpa [fiberCard] using
          im05_integerMultisetPermutationHeadDeletedSlotChoices_card_pos
            count head hpos)
      (by
        intro residual
        simpa [fiberCard] using
          im05_integerMultisetPermutationAllowedSample_head_fiber_card
            count head hpos residual)
      event

/--
Uniform projection law for filtered count-vector samples, assuming the
filtering map has constant positive fiber cardinality.  This packages the
remaining combinatorial obligation in the finite-law proof: prove the fiber
cardinality is constant, then every residual event has the uniform residual
law.
-/
theorem im05_integerMultisetPermutationAllowedSample_uniform_event_eq_of_constant_fiber
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (forbidden : Finset Name)
    (fiberCard : ℕ) (hfiber_pos : 0 < fiberCard)
    (hfiber : ∀ residual :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count forbidden),
      ((Finset.univ :
          Finset (im05_integerMultisetPermutationSample Name count)).filter
        (fun sample =>
          im05_integerMultisetPermutationAllowedSample forbidden sample =
            residual)).card = fiberCard)
    (event :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count forbidden) → Prop)
    [DecidablePred event] :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          event (im05_integerMultisetPermutationAllowedSample forbidden sample)) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name
            (im05_countOutside count forbidden)))
        event := by
  classical
  exact
    EconCSLib.pmfProb_uniformPMF_comp_eq_of_constant_fiber_card
      (fun sample : im05_integerMultisetPermutationSample Name count =>
        im05_integerMultisetPermutationAllowedSample forbidden sample)
      fiberCard hfiber_pos hfiber event

/--
Uniform projection law for filtered count-vector samples, with the arbitrary
forbidden-set constant-fiber certificate discharged.
-/
theorem im05_integerMultisetPermutationAllowedSample_uniform_event_eq
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (forbidden : Finset Name)
    (event :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count forbidden) → Prop)
    [DecidablePred event] :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          event (im05_integerMultisetPermutationAllowedSample forbidden sample)) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name
            (im05_countOutside count forbidden)))
        event := by
  classical
  rcases
    im05_integerMultisetPermutationAllowedSample_fiber_card_exists
      count forbidden with
    ⟨fiberCard, hfiber_pos, hfiber⟩
  exact
    im05_integerMultisetPermutationAllowedSample_uniform_event_eq_of_constant_fiber
      forbidden fiberCard hfiber_pos hfiber event

/--
The first symbol of the residual allowed sample is the head of the filtered
allowed list.
-/
theorem im05_integerMultisetPermutationAllowedSample_first_eq_allowedList_get
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (forbidden : Finset Name)
    (sample : im05_integerMultisetPermutationSample Name count)
    (target : Name) (hnot : target ∉ forbidden)
    (hpos : 0 < count target)
    (hallowed_pos :
      0 <
        (im05_integerMultisetPermutationAllowedList
          forbidden sample).length) :
    im05_integerMultisetPermutationFirst target
        (by simpa [im05_countOutside, hnot] using hpos)
        (im05_integerMultisetPermutationAllowedSample forbidden sample) =
      (im05_integerMultisetPermutationAllowedList
        forbidden sample).get ⟨0, hallowed_pos⟩ := by
  classical
  let allowed := im05_integerMultisetPermutationAllowedList forbidden sample
  have hlen :
      allowed.length =
        ∑ name : Name, im05_countOutside count forbidden name := by
    dsimp [allowed]
    exact im05_integerMultisetPermutationAllowedList_length forbidden sample
  have hposOutside :
      0 < im05_countOutside count forbidden target := by
    simpa [im05_countOutside, hnot] using hpos
  have hcast :
      Fin.cast hlen.symm
          ⟨0,
            im05_sum_count_pos_of_pos
              (im05_countOutside count forbidden) target hposOutside⟩ =
        (⟨0, by simpa [allowed] using hallowed_pos⟩ :
          Fin allowed.length) := by
    ext
    rfl
  dsimp [im05_integerMultisetPermutationFirst,
    im05_integerMultisetPermutationAllowedSample]
  change allowed.get
      (Fin.cast hlen.symm
        ⟨0,
          im05_sum_count_pos_of_pos
            (im05_countOutside count forbidden) target hposOutside⟩) =
    allowed.get ⟨0, by simpa [allowed] using hallowed_pos⟩
  rw [hcast]

/--
For a count-vector sample whose first residual name is a non-target `head`,
the event that two distinct names precede `target` recurses to a one-name event
after deleting all copies of `head`.
-/
theorem im05_integerMultisetPermutation_two_namesBeforeFirst_iff_allowedSample_one
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ}
    (sample : im05_integerMultisetPermutationSample Name count)
    (target head : Name) (hhead_pos : 0 < count head)
    (hfirst :
      im05_integerMultisetPermutationFirst head hhead_pos sample = head)
    (hneq : target ≠ head) :
    2 ≤
        (im05_namesBeforeFirst id target
          (im05_integerMultisetPermutationList sample)).card ↔
      1 ≤
        (im05_namesBeforeFirst id target
          (im05_integerMultisetPermutationList
            (im05_integerMultisetPermutationAllowedSample
              ({head} : Finset Name) sample))).card := by
  classical
  have hlist_pos :
      0 < (im05_integerMultisetPermutationList sample).length := by
    dsimp [im05_integerMultisetPermutationList]
    simp [im05_sum_count_pos_of_pos count head hhead_pos]
  have hhead_get :
      (im05_integerMultisetPermutationList sample).get ⟨0, hlist_pos⟩ =
        head := by
    have hfirst_list :
        im05_integerMultisetPermutationFirst head hhead_pos sample =
          (im05_integerMultisetPermutationList sample).get
            ⟨0, hlist_pos⟩ := by
      simp [im05_integerMultisetPermutationFirst,
        im05_integerMultisetPermutationList]
    exact hfirst_list.symm.trans hfirst
  have hrec :=
    im05_two_le_namesBeforeFirst_card_iff_filter_ne_head_one_le
      target head (im05_integerMultisetPermutationList sample)
      hlist_pos hhead_get hneq
  have hallowed :
      im05_integerMultisetPermutationList
          (im05_integerMultisetPermutationAllowedSample
            ({head} : Finset Name) sample) =
        (im05_integerMultisetPermutationList sample).filter
          (fun name => name != head) := by
    rw [im05_integerMultisetPermutationList_allowedSample
      ({head} : Finset Name) sample]
    dsimp [im05_integerMultisetPermutationAllowedList]
    congr 1
    funext name
    by_cases h : name = head <;> simp [h]
  rw [hallowed]
  exact hrec

/--
If `head` is the first first-appearance name, then the second entry of the
first-appearance fresh list is the first symbol of the word with all `head`
copies deleted.
-/
theorem im05_integerMultisetPermutationFirstAppearanceFreshList_one_eq_allowedSample_first
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    {count : Name → ℕ} (hcount_pos : ∀ name : Name, 0 < count name)
    (sample : im05_integerMultisetPermutationSample Name count)
    (head target : Name) (hneq : target ≠ head)
    (hcard_two : 1 < Fintype.card Name)
    (hfirst :
      im05_integerMultisetPermutationFirst head (hcount_pos head) sample =
        head) :
    (im05_integerMultisetPermutationFirstAppearanceFreshList
      hcount_pos sample).1 ⟨1, hcard_two⟩ =
      im05_integerMultisetPermutationFirst target
        (by
          have hnot : target ∉ ({head} : Finset Name) := by
            simpa [Finset.mem_singleton] using hneq
          simpa [im05_countOutside, hnot] using hcount_pos target)
        (im05_integerMultisetPermutationAllowedSample
          ({head} : Finset Name) sample) := by
  classical
  let list := im05_integerMultisetPermutationList sample
  let appearance := im05_firstAppearanceList list
  let fresh :=
    im05_integerMultisetPermutationFirstAppearanceFreshList
      hcount_pos sample
  let allowed :=
    im05_integerMultisetPermutationAllowedList
      ({head} : Finset Name) sample
  have hlen : appearance.length = Fintype.card Name := by
    dsimp [appearance, list]
    exact
      im05_integerMultisetPermutation_firstAppearanceList_length
        hcount_pos sample
  have happearance_two : 1 < appearance.length := by
    simpa [hlen] using hcard_two
  have hlist_pos : 0 < list.length := by
    simpa [list, im05_integerMultisetPermutationList] using
      im05_sum_count_pos_of_pos count head (hcount_pos head)
  have hlist_head : list.get ⟨0, hlist_pos⟩ = head := by
    dsimp [list, im05_integerMultisetPermutationList,
      im05_integerMultisetPermutationFirst] at hfirst ⊢
    simpa using hfirst
  have hnot : target ∉ ({head} : Finset Name) := by
    simpa [Finset.mem_singleton] using hneq
  have hallowed_pos : 0 < allowed.length := by
    dsimp [allowed]
    exact
      im05_integerMultisetPermutationAllowedList_length_pos_of_count_pos
        ({head} : Finset Name) sample target hnot (hcount_pos target)
  have hallowed_eq_filter :
      allowed = list.filter fun name => name != head := by
    dsimp [allowed, list, im05_integerMultisetPermutationAllowedList]
    congr 1
    funext name
    by_cases h : name = head <;> simp [h]
  have hfilter_pos :
      0 < (list.filter fun name => name != head).length := by
    simpa [hallowed_eq_filter] using hallowed_pos
  have hfresh_get :
      fresh.1 ⟨1, hcard_two⟩ =
        appearance.get ⟨1, happearance_two⟩ := by
    have hcast :
        Fin.cast hlen.symm ⟨1, hcard_two⟩ =
          (⟨1, happearance_two⟩ : Fin appearance.length) := by
      ext
      rfl
    dsimp [fresh, im05_integerMultisetPermutationFirstAppearanceFreshList]
    change appearance.get (Fin.cast hlen.symm ⟨1, hcard_two⟩) =
      appearance.get ⟨1, happearance_two⟩
    rw [hcast]
  have happearance_get_allowed :
      appearance.get ⟨1, happearance_two⟩ =
        allowed.get ⟨0, hallowed_pos⟩ := by
    have hget :=
      im05_firstAppearanceList_get_one_eq_filter_ne_head_get_zero
        list head hlist_pos hlist_head hfilter_pos happearance_two
    simpa [appearance, hallowed_eq_filter] using hget
  have hallowed_first :
      im05_integerMultisetPermutationFirst target
          (by
            have hnot : target ∉ ({head} : Finset Name) := by
              simpa [Finset.mem_singleton] using hneq
            simpa [im05_countOutside, hnot] using hcount_pos target)
          (im05_integerMultisetPermutationAllowedSample
            ({head} : Finset Name) sample) =
        allowed.get ⟨0, hallowed_pos⟩ := by
    dsimp [allowed]
    exact
      im05_integerMultisetPermutationAllowedSample_first_eq_allowedList_get
        ({head} : Finset Name) sample target hnot (hcount_pos target)
        (by simpa [allowed] using hallowed_pos)
  rw [hfresh_get, happearance_get_allowed, hallowed_first]

/--
Uniform probability of a first-symbol event, expressed as the decremented
sample-space cardinality divided by the original sample-space cardinality.
-/
theorem im05_integerMultisetPermutation_first_prob_eq_card_ratio
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (target : Name) (hpos : 0 < count target) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst target hpos sample = target) =
      (Fintype.card
        (im05_integerMultisetPermutationSample Name
          (im05_decrementCount count target)) : ℝ) /
        (Fintype.card
          (im05_integerMultisetPermutationSample Name count) : ℝ) := by
  classical
  let eventSet :
      Finset (im05_integerMultisetPermutationSample Name count) :=
    (Finset.univ.filter fun sample =>
      im05_integerMultisetPermutationFirst target hpos sample = target)
  have hevent :
      ∀ sample : im05_integerMultisetPermutationSample Name count,
        (im05_integerMultisetPermutationFirst target hpos sample = target) ↔
          sample ∈ eventSet := by
    intro sample
    simp [eventSet]
  have hcard_event :
      Fintype.card
          {sample : im05_integerMultisetPermutationSample Name count //
            im05_integerMultisetPermutationFirst target hpos sample = target} =
        eventSet.card := by
    rw [Fintype.card_subtype]
  calc
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst target hpos sample = target)
        =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample => sample ∈ eventSet) := by
          exact EconCSLib.pmfProb_congr
            (EconCSLib.uniformPMF
              (im05_integerMultisetPermutationSample Name count))
            hevent
    _ =
      (eventSet.card : ℝ) /
        (Fintype.card
          (im05_integerMultisetPermutationSample Name count) : ℝ) := by
          exact EconCSLib.pmfProb_uniformPMF_finset eventSet
    _ =
      (Fintype.card
        (im05_integerMultisetPermutationSample Name
          (im05_decrementCount count target)) : ℝ) /
        (Fintype.card
          (im05_integerMultisetPermutationSample Name count) : ℝ) := by
          rw [← hcard_event]
          rw [im05_integerMultisetPermutationHeadFiber_card]

/--
Double-counting target occurrences across all count-vector samples: the number
of samples with `target` in the first slot, times the total length, equals the
number of all samples times the number of `target` copies.
-/
theorem im05_integerMultisetPermutation_first_event_card_mul_total
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (target : Name) (hpos : 0 < count target) :
    Fintype.card
        {sample : im05_integerMultisetPermutationSample Name count //
          im05_integerMultisetPermutationFirst target hpos sample = target} *
        (∑ name : Name, count name) =
      Fintype.card (im05_integerMultisetPermutationSample Name count) *
        count target := by
  classical
  let total := ∑ name : Name, count name
  let Sample := im05_integerMultisetPermutationSample Name count
  let firstEvent :=
    {sample : Sample //
      im05_integerMultisetPermutationFirst target hpos sample = target}
  let sampleSlot :=
    Sigma (fun sample : Sample =>
      {slot : Fin total // sample.1 slot = target})
  let slotSample :=
    Sigma (fun slot : Fin total =>
      {sample : Sample // sample.1 slot = target})
  have hcomm : Fintype.card sampleSlot = Fintype.card slotSample := by
    apply Fintype.card_congr
    exact
      { toFun := fun pair => ⟨pair.2.1, ⟨pair.1, pair.2.2⟩⟩
        invFun := fun pair => ⟨pair.2.1, ⟨pair.1, pair.2.2⟩⟩
        left_inv := by
          intro pair
          cases pair with
          | mk sample slot =>
              cases slot
              rfl
        right_inv := by
          intro pair
          cases pair with
          | mk slot sample =>
              cases sample
              rfl }
  have hcard_by_sample :
      Fintype.card sampleSlot = Fintype.card Sample * count target := by
    dsimp [sampleSlot]
    rw [Fintype.card_sigma]
    calc
      (∑ sample : Sample,
          Fintype.card {slot : Fin total // sample.1 slot = target})
          = ∑ _sample : Sample, count target := by
              refine Finset.sum_congr rfl ?_
              intro sample _hsample
              rw [Fintype.card_subtype]
              change im05_nameCountInWord sample.1 target = count target
              exact sample.2 target
      _ = Fintype.card Sample * count target := by
              simp
  have hslot_card : ∀ slot : Fin total,
      Fintype.card {sample : Sample // sample.1 slot = target} =
        Fintype.card firstEvent := by
    intro slot
    exact
      (Fintype.card_congr
        (im05_integerMultisetPermutationFirstSlotEventEquiv
          (Name := Name) (count := count) target hpos slot)).symm
  have hcard_by_slot :
      Fintype.card slotSample = total * Fintype.card firstEvent := by
    dsimp [slotSample]
    rw [Fintype.card_sigma]
    calc
      (∑ slot : Fin total,
          Fintype.card {sample : Sample // sample.1 slot = target})
          = ∑ _slot : Fin total, Fintype.card firstEvent := by
              refine Finset.sum_congr rfl ?_
              intro slot _hslot
              exact hslot_card slot
      _ = total * Fintype.card firstEvent := by
              simp [total]
  have hmain :
      Fintype.card Sample * count target =
        total * Fintype.card firstEvent := by
    calc
      Fintype.card Sample * count target = Fintype.card sampleSlot :=
        hcard_by_sample.symm
      _ = Fintype.card slotSample := hcomm
      _ = total * Fintype.card firstEvent := hcard_by_slot
  change Fintype.card firstEvent * total =
    Fintype.card Sample * count target
  rw [Nat.mul_comm (Fintype.card firstEvent) total]
  exact hmain.symm

/--
Cardinality recurrence for count-vector sample spaces after deleting one
`target` copy.
-/
theorem im05_integerMultisetPermutation_decrement_card_mul_total
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (target : Name) (hpos : 0 < count target) :
    Fintype.card
        (im05_integerMultisetPermutationSample Name
          (im05_decrementCount count target)) *
        (∑ name : Name, count name) =
      Fintype.card (im05_integerMultisetPermutationSample Name count) *
        count target := by
  rw [← im05_integerMultisetPermutationHeadFiber_card
    (Name := Name) (count := count) target hpos]
  exact
    im05_integerMultisetPermutation_first_event_card_mul_total
      (Name := Name) count target hpos

/--
Exact first-symbol law for a uniform count-vector word: the probability that
the first slot is `target` is its multiplicity divided by the total
multiplicity.
-/
theorem im05_integerMultisetPermutation_first_prob_eq_count_ratio
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (target : Name) (hpos : 0 < count target) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst target hpos sample = target) =
      (count target : ℝ) / (∑ name : Name, count name : ℝ) := by
  classical
  rw [im05_integerMultisetPermutation_first_prob_eq_card_ratio
    count target hpos]
  let Sample := im05_integerMultisetPermutationSample Name count
  let DecSample :=
    im05_integerMultisetPermutationSample Name
      (im05_decrementCount count target)
  have hcard_head :
      Fintype.card
          {sample : Sample //
            im05_integerMultisetPermutationFirst target hpos sample = target} =
        Fintype.card DecSample := by
    simpa [Sample, DecSample] using
      im05_integerMultisetPermutationHeadFiber_card
        (Name := Name) (count := count) target hpos
  have hcard_mul :
      Fintype.card DecSample * (∑ name : Name, count name) =
        Fintype.card Sample * count target := by
    rw [← hcard_head]
    simpa [Sample] using
      im05_integerMultisetPermutation_first_event_card_mul_total
        (Name := Name) count target hpos
  have hcard_real :
      (Fintype.card DecSample : ℝ) *
          (∑ name : Name, count name : ℝ) =
        (Fintype.card Sample : ℝ) * (count target : ℝ) := by
    exact_mod_cast hcard_mul
  have htotal_pos : 0 < ∑ name : Name, count name :=
    im05_sum_count_pos_of_pos count target hpos
  have htotal_ne : (∑ name : Name, count name : ℝ) ≠ 0 := by
    exact_mod_cast htotal_pos.ne'
  have hsample_pos : 0 < Fintype.card Sample :=
    Fintype.card_pos_iff.mpr
      (im05_integerMultisetPermutationSample_nonempty Name count)
  have hsample_ne : (Fintype.card Sample : ℝ) ≠ 0 := by
    exact_mod_cast hsample_pos.ne'
  field_simp [Sample, DecSample, hsample_ne, htotal_ne]
  nlinarith [hcard_real]

/--
After deleting any forbidden set from a uniform count-vector word, the first
remaining symbol has probability proportional to its remaining count.
-/
theorem im05_integerMultisetPermutationAllowedSample_first_prob_eq_count_ratio
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (forbidden : Finset Name)
    (target : Name) (hnot : target ∉ forbidden)
    (hpos : 0 < count target) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst target
              (by simpa [im05_countOutside, hnot] using hpos)
              (im05_integerMultisetPermutationAllowedSample forbidden sample) =
            target) =
      (count target : ℝ) /
        (∑ name : Name, im05_countOutside count forbidden name : ℝ) := by
  classical
  have houtside_pos :
      0 < im05_countOutside count forbidden target := by
    simpa [im05_countOutside, hnot] using hpos
  let event :
      im05_integerMultisetPermutationSample Name
        (im05_countOutside count forbidden) → Prop :=
    fun residual =>
      im05_integerMultisetPermutationFirst target houtside_pos residual =
        target
  calc
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst target
              (by simpa [im05_countOutside, hnot] using hpos)
              (im05_integerMultisetPermutationAllowedSample forbidden sample) =
            target)
        =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          event
            (im05_integerMultisetPermutationAllowedSample forbidden sample)) := by
          refine
            EconCSLib.pmfProb_congr
              (EconCSLib.uniformPMF
                (im05_integerMultisetPermutationSample Name count))
              ?_
          intro sample
          simp [event]
    _ =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name
            (im05_countOutside count forbidden)))
        event := by
          exact
            im05_integerMultisetPermutationAllowedSample_uniform_event_eq
              count forbidden event
    _ =
      (count target : ℝ) /
        (∑ name : Name, im05_countOutside count forbidden name : ℝ) := by
          dsimp [event]
          rw [im05_integerMultisetPermutation_first_prob_eq_count_ratio
            (im05_countOutside count forbidden) target houtside_pos]
          simp [im05_countOutside, hnot]

/--
The same first-residual-symbol law stated as the filtered weighted PMF atom
used by Algorithm 4.2.
-/
theorem im05_integerMultisetPermutationAllowedSample_first_prob_eq_countWeight_excluding
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (forbidden : Finset Name)
    (target : Name) (hnot : target ∉ forbidden)
    (hpos : 0 < count target)
    (havailable_pos :
      0 < EconCSLib.finiteAvailableWeight
        (im05_countWeight count) forbidden) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst target
              (by simpa [im05_countOutside, hnot] using hpos)
              (im05_integerMultisetPermutationAllowedSample forbidden sample) =
            target) =
      (EconCSLib.finiteWeightedPMFExcluding
        (im05_countWeight count) forbidden
        (im05_countWeight_nonneg count) havailable_pos target).toReal := by
  classical
  rw [im05_integerMultisetPermutationAllowedSample_first_prob_eq_count_ratio
    count forbidden target hnot hpos]
  rw [EconCSLib.finiteWeightedPMFExcluding_apply_toReal_of_not_mem
    (im05_countWeight count) forbidden (im05_countWeight_nonneg count)
    havailable_pos hnot]
  rw [im05_countWeight_available_eq_sum_countOutside count forbidden]
  simp [im05_countWeight]

/-- With no forbidden names, the available raw count mass is total count. -/
theorem im05_countWeight_available_empty
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) :
    EconCSLib.finiteAvailableWeight
        (im05_countWeight count) (∅ : Finset Name) =
      ∑ name : Name, count name := by
  classical
  simp [EconCSLib.finiteAvailableWeight, im05_countWeight]

/-- For raw count weights, forbidding one name subtracts that count from total mass. -/
theorem im05_countWeight_available_singleton_eq_total_sub
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ) (excluded : Name) :
    EconCSLib.finiteAvailableWeight
        (im05_countWeight count) ({excluded} : Finset Name) =
      (∑ name : Name, count name : ℝ) - count excluded := by
  classical
  have hsum_nat := im05_sum_countOutside_singleton_add_count count excluded
  have hsum_real :
      (∑ name : Name,
          im05_countOutside count ({excluded} : Finset Name) name : ℝ) +
        (count excluded : ℝ) =
          (∑ name : Name, count name : ℝ) := by
    exact_mod_cast hsum_nat
  rw [im05_countWeight_available_eq_sum_countOutside count
    ({excluded} : Finset Name)]
  linarith

/--
For positive raw counts, the outside mass divided by total mass is bounded by
the outside sum of one-step hazard terms.
-/
theorem im05_outside_count_div_total_le_sum_div_total_sub
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (hcard_two : 2 ≤ Fintype.card Name)
    (i j : Name) :
    (((Finset.univ : Finset Name).erase i).erase j).sum
        (fun head => (count head : ℝ)) /
      (∑ name : Name, count name : ℝ) ≤
    (((Finset.univ : Finset Name).erase i).erase j).sum
      (fun head =>
        (count head : ℝ) /
          ((∑ name : Name, count name : ℝ) - count head)) := by
  classical
  let outside := ((Finset.univ : Finset Name).erase i).erase j
  let T : ℝ := ∑ name : Name, count name
  have hcount_pos : ∀ name : Name, 0 < count name :=
    im05_count_pos_of_countWeight_available count hcount_available
  have hT_pos : 0 < T := by
    dsimp [T]
    exact_mod_cast im05_sum_count_pos_of_pos count i (hcount_pos i)
  have hlt : ∀ head ∈ outside, (count head : ℝ) < T := by
    intro head _hhead
    have havail :
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) ({head} : Finset Name) :=
      hcount_available ({head} : Finset Name)
        (by
          simp
          omega)
    rw [im05_countWeight_available_singleton_eq_total_sub count head] at havail
    change (count head : ℝ) < (∑ name : Name, count name : ℝ)
    linarith
  have hle :=
    im05_sum_div_total_le_sum_div_total_sub
      outside (fun head => (count head : ℝ)) T
      (by
        intro head _hhead
        have hnonneg : (0 : ℝ) ≤ (count head : ℝ) := by
          exact_mod_cast (Nat.zero_le (count head) : 0 ≤ count head)
        simpa using hnonneg)
      hT_pos hlt
  simpa [outside, T, div_eq_mul_inv, Finset.sum_mul] using hle

/--
Exact first-draw law for Algorithm 4.2 with raw integer count weights.
-/
theorem im05_algorithm42FreshList_countWeight_first_draw_prob_eq_count_ratio
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (hk_le_card : k + 1 ≤ Fintype.card Name)
    (target : Name) :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 1) hk_le_card)
        (fun sample =>
          im05_algorithm42FreshListDraw sample ⟨0, Nat.succ_pos k⟩ =
            target) =
      (count target : ℝ) / (∑ name : Name, count name : ℝ) := by
  classical
  rw [im05_algorithm42FreshListPMF]
  change
    EconCSLib.pmfProb
        (EconCSLib.finiteWithoutReplacementPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 1) (∅ : Finset Name) _)
        (fun sample => sample.1 ⟨0, Nat.succ_pos k⟩ = target) =
      (count target : ℝ) / (∑ name : Name, count name : ℝ)
  rw [EconCSLib.finiteWithoutReplacementPMF_head_prob
    (head₀ := ⟨target, by simp⟩)]
  rw [EconCSLib.finiteWeightedPMFAvailable_apply_toReal]
  rw [im05_countWeight_available_empty count]
  simp [im05_countWeight]

/--
Base finite-law bridge: the first-symbol law of the uniform count-vector word
matches the first draw of the raw-count Algorithm 4.2 sampler.
-/
theorem im05_integerMultisetPermutation_first_prob_eq_countWeight_freshList_first_prob
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (hk_le_card : k + 1 ≤ Fintype.card Name)
    (target : Name) (hpos : 0 < count target) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          im05_integerMultisetPermutationFirst target hpos sample = target) =
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 1) hk_le_card)
        (fun sample =>
          im05_algorithm42FreshListDraw sample ⟨0, Nat.succ_pos k⟩ =
            target) := by
  rw [im05_integerMultisetPermutation_first_prob_eq_count_ratio count target hpos]
  rw [im05_algorithm42FreshList_countWeight_first_draw_prob_eq_count_ratio
    count hcount_available hk_le_card target]

/--
Base first-appearance finite-law bridge: the first distinct name in a uniform
count-vector word has the same law as the first draw of the raw-count
Algorithm 4.2 sampler.
-/
theorem im05_integerMultisetPermutationFirstAppearanceFreshList_first_prob_eq_countWeight_freshList_first_prob
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    {k : ℕ} (hk_le_card : k + 1 ≤ Fintype.card Name)
    (target : Name) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          (im05_integerMultisetPermutationFirstAppearanceFreshList
            hcount_pos sample).1
              ⟨0, Fintype.card_pos_iff.mpr ⟨target⟩⟩ = target) =
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available (k + 1) hk_le_card)
        (fun sample =>
          im05_algorithm42FreshListDraw sample ⟨0, Nat.succ_pos k⟩ =
            target) := by
  classical
  have hfirst :
      EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name count))
          (fun sample =>
            (im05_integerMultisetPermutationFirstAppearanceFreshList
              hcount_pos sample).1
                ⟨0, Fintype.card_pos_iff.mpr ⟨target⟩⟩ = target) =
        EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name count))
          (fun sample =>
            im05_integerMultisetPermutationFirst target
              (hcount_pos target) sample = target) :=
    EconCSLib.pmfProb_congr
      (EconCSLib.uniformPMF
        (im05_integerMultisetPermutationSample Name count))
      (by
        intro sample
        rw [im05_integerMultisetPermutationFirstAppearanceFreshList_zero
          hcount_pos sample target])
  rw [hfirst]
  exact
    im05_integerMultisetPermutation_first_prob_eq_countWeight_freshList_first_prob
      count hcount_available hk_le_card target (hcount_pos target)

/--
Base complement law for one draw: the first distinct name in a uniform
count-vector word avoids `target` with the same probability as the first draw
of the raw-count Algorithm 4.2 sampler avoids `target`.
-/
theorem im05_integerMultisetPermutationFirstAppearanceFreshList_first_ne_prob_eq_countWeight_freshList_first_ne_prob
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (target : Name) :
    EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          ¬ (im05_integerMultisetPermutationFirstAppearanceFreshList
              hcount_pos sample).1
              ⟨0, Fintype.card_pos_iff.mpr ⟨target⟩⟩ = target) =
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 (by
            simpa using Fintype.card_pos_iff.mpr ⟨target⟩))
        (fun sample =>
          ¬ im05_algorithm42FreshListDraw sample
              ⟨0, Nat.succ_pos 0⟩ = target) := by
  classical
  rw [EconCSLib.pmfProb_compl, EconCSLib.pmfProb_compl]
  rw [im05_integerMultisetPermutationFirstAppearanceFreshList_first_prob_eq_countWeight_freshList_first_prob
    count hcount_pos hcount_available
    (hk_le_card := by
      simpa using Fintype.card_pos_iff.mpr ⟨target⟩)
    target]

/--
The marginal finite law is trivial at `k = 0`: both sides are the probability
of an always-true event.
-/
theorem im05_integerMultisetPermutation_base_finite_law_zero
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (target : Name)
    [DecidablePred fun sample : im05_algorithm42FreshListSample Name 0 =>
      im05_listPrefixOmits target 0
        (im05_algorithm42FreshListDraw sample)] :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 0 (Nat.zero_le _))
        (fun sample =>
          im05_listPrefixOmits target 0
            (im05_algorithm42FreshListDraw sample)) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          0 ≤
            (im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList sample)).card) := by
  classical
  rw [EconCSLib.pmfProb_eq_one_of_forall
    (im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 0 (Nat.zero_le _))
    (fun sample =>
      im05_listPrefixOmits target 0
        (im05_algorithm42FreshListDraw sample))]
  · rw [EconCSLib.pmfProb_eq_one_of_forall
      (EconCSLib.uniformPMF
        (im05_integerMultisetPermutationSample Name count))
      (fun sample =>
        0 ≤
          (im05_namesBeforeFirst id target
            (im05_integerMultisetPermutationList sample)).card)]
    intro sample
    exact Nat.zero_le _
  · intro sample
    exact im05_listPrefixOmits_zero target
      (im05_algorithm42FreshListDraw sample)

/--
The marginal finite law required by the Lemma 4.4 wrapper is closed for
`k = 1`.
-/
theorem im05_integerMultisetPermutation_base_finite_law_one
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (count : Name → ℕ)
    (hcount_pos : ∀ name : Name, 0 < count name)
    (hcount_available : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight
          (im05_countWeight count) forbidden)
    (target : Name)
    [DecidablePred fun sample : im05_algorithm42FreshListSample Name 1 =>
      im05_listPrefixOmits target 1
        (im05_algorithm42FreshListDraw sample)] :
    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 (by
            simpa using Fintype.card_pos_iff.mpr ⟨target⟩))
        (fun sample =>
          im05_listPrefixOmits target 1
            (im05_algorithm42FreshListDraw sample)) =
      EconCSLib.pmfProb
        (EconCSLib.uniformPMF
          (im05_integerMultisetPermutationSample Name count))
        (fun sample =>
          1 ≤
            (im05_namesBeforeFirst id target
              (im05_integerMultisetPermutationList sample)).card) := by
  classical
  let hcard_pos : 0 < Fintype.card Name :=
    Fintype.card_pos_iff.mpr ⟨target⟩
  have hsource :
      EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name count))
          (fun sample =>
            ¬ (im05_integerMultisetPermutationFirstAppearanceFreshList
                hcount_pos sample).1 ⟨0, hcard_pos⟩ = target) =
        EconCSLib.pmfProb
          (EconCSLib.uniformPMF
            (im05_integerMultisetPermutationSample Name count))
          (fun sample =>
            1 ≤
              (im05_namesBeforeFirst id target
                (im05_integerMultisetPermutationList sample)).card) :=
    EconCSLib.pmfProb_congr
      (EconCSLib.uniformPMF
        (im05_integerMultisetPermutationSample Name count))
      (by
        intro sample
        have homit :
            im05_listPrefixOmits target 1
              (im05_integerMultisetPermutationFirstAppearanceFreshList
                hcount_pos sample).1 ↔
              1 ≤
                (im05_namesBeforeFirst id target
                  (im05_integerMultisetPermutationList sample)).card :=
          im05_integerMultisetPermutationFirstAppearanceFreshList_prefix_omits_iff_namesBeforeFirst_card
            hcount_pos sample target 1
        have hhead :
            im05_listPrefixOmits target 1
              (im05_integerMultisetPermutationFirstAppearanceFreshList
                hcount_pos sample).1 ↔
              ¬ (im05_integerMultisetPermutationFirstAppearanceFreshList
                  hcount_pos sample).1 ⟨0, hcard_pos⟩ = target := by
          have h :=
            im05_listPrefixOmits_succ_iff target
              (im05_integerMultisetPermutationFirstAppearanceFreshList
                hcount_pos sample).1 (r := 0) hcard_pos
          simpa using h
        exact hhead.symm.trans homit)
  have htarget :
