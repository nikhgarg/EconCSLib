theorem im05_not_mem_proposals_of_terminated_prefers_target_to_current
    {M W : Type*} [DecidableEq W]
    (val_m : M → W → ℝ) (s : DAState M W) (m : M) (target : W)
    (hterminated : ¬ ∃ a, IsActiveMan val_m s a)
    (hmatched : MatchedProposedInvariant s)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (htargetAcceptable : 0 ≤ val_m m target)
    (hpref :
      ∀ wcur : W, s.m_match m = some wcur →
        val_m m wcur < val_m m target) :
    target ∉ s.m_proposals m := by
  intro htargetMem
  cases hmatch : s.m_match m with
  | none =>
      exact hterminated ⟨m, hmatch, ⟨target, htargetMem, htargetAcceptable⟩⟩
  | some wcur =>
      have hnotCurrent : wcur ∉ s.m_proposals m := hmatched m wcur hmatch
      have hle : val_m m target ≤ val_m m wcur :=
        hproposalOrder m wcur target hnotCurrent htargetMem htargetAcceptable
      have hlt : val_m m wcur < val_m m target := hpref wcur hmatch
      linarith

