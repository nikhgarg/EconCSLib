/--
If every proper forbidden set has positive available mass, then each individual
weight is positive.  This is the real-weight analogue of
`im05_count_pos_of_countWeight_available`.
-/
theorem im05_weight_pos_of_available
    {Name : Type*} [Fintype Name] [DecidableEq Name]
    (weight : Name → ℝ)
    (havailable : ∀ forbidden : Finset Name,
      forbidden.card < Fintype.card Name →
        0 < EconCSLib.finiteAvailableWeight weight forbidden)
    (target : Name) :
    0 < weight target := by
  classical
  let forbidden := (Finset.univ : Finset Name).erase target
  have hcard :
      forbidden.card < Fintype.card Name := by
    have hlt :=
      Finset.card_erase_lt_of_mem
        (s := (Finset.univ : Finset Name)) (a := target)
        (by simp)
    simpa [forbidden] using hlt
  have havail := havailable forbidden hcard
  have havail_eq :
      EconCSLib.finiteAvailableWeight weight forbidden = weight target := by
    dsimp [forbidden]
    simp [EconCSLib.finiteAvailableWeight]
  simpa [havail_eq] using havail

