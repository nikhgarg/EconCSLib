              k hk_le_card)
            (fun sample =>
              im05_listPrefixOmits (target jdx) k
                (im05_algorithm42FreshListDraw sample))
            (fun sample =>
              im05_listPrefixOmits (target idx) k
                (im05_algorithm42FreshListDraw sample)))))
    (hbase_lim : ∀ idx ∈ tail, ∀ jdx ∈ tail, idx ≠ jdx →
      Filter.Tendsto (approxBase idx jdx) Filter.atTop
        (nhds
          (EconCSLib.pmfProb
            (im05_algorithm42FreshListPMF prob hprob_nonneg havailable
              k hk_le_card)
            (fun sample =>
              im05_listPrefixOmits (target idx) k
