/--
Lemma 4.3 expected-count wrapper from Algorithm 4.2 prefix states.  For every
tail woman, statewise exact filtered-draw laws at each realized one-man prefix,
together with the across-men product identity, imply the paper's expected
absent-count lower bound.
-/
theorem
    paper_im05_lemma4_3_expected_absent_count_lower_bound_from_algorithm4_2_prefix_states
    {Λ Ω S I : Type*} [Fintype Λ] [DecidableEq Λ]
    [Fintype Ω] [DecidableEq Ω]
    [Fintype S] [DecidableEq S]
    [Fintype I] [DecidableEq I]
    {k : ℕ}
    (ν : PMF Λ) (draw : Λ → Fin k → I)
    (μ : PMF Ω) (absent : I → Ω → Prop)
    [∀ i s, DecidablePred fun sample => im05_listPrefixOmits i s (draw sample)]
    [∀ ω, DecidablePred fun i => absent i ω]
    [∀ i, DecidablePred fun ω => absent i ω]
    (prob : I → ℝ) (Q : ℝ)
    (tail : Finset I) (witnessTail : I → Finset I)
    (state : I → ℕ → Λ → S)
    (previous : I → ℕ → S → Finset I)
    (prevMass : I → ℕ → S → ℝ)
    (rank : I → ℕ) (g n : ℕ)
    (hk_pos : 0 < k)
    (hQ_pos : 0 < 1 - Q)
    (hg : 0 < g)
    (hcard : (g : ℝ) / 2 ≤ (tail.card : ℝ))
    (hhalf : ∀ i ∈ tail, (g : ℝ) / 2 ≤ (rank i : ℝ))
    (htwo_k : ∀ i ∈ tail, 2 * k < rank i)
    (hprob_nonneg : ∀ u, 0 ≤ prob u)
    (hprob_sum : ∑ u : I, prob u = 1)
    (hwitness_card : ∀ i ∈ tail, (witnessTail i).card = rank i - k)
    (hmass_tail_le : ∀ i ∈ tail,
      (∑ u ∈ witnessTail i, prob u) ≤ 1 - Q)
    (hpopular : ∀ i ∈ tail, ∀ u ∈ witnessTail i, prob i ≤ prob u)
    (hprefix_pos : ∀ i ∈ tail, ∀ r, r < k →
      0 < EconCSLib.pmfProb ν
        (fun sample => im05_listPrefixOmits i r (draw sample)))
    (hprevMass : ∀ i ∈ tail, ∀ r s,
      prevMass i r s = ∑ u ∈ previous i r s, prob u)
    (havailable_pos : ∀ i ∈ tail, ∀ r, r < k → ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits i r (draw sample) ∧
            state i r sample = s) →
      0 < EconCSLib.finiteAvailableWeight prob (previous i r s))
    (hw_not_previous : ∀ i ∈ tail, ∀ r, r < k → ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits i r (draw sample) ∧
            state i r sample = s) →
      i ∉ previous i r s)
    (hprev_le_Q : ∀ i ∈ tail, ∀ r, r < k → ∀ s : S,
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits i r (draw sample) ∧
            state i r sample = s) →
      prevMass i r s ≤ Q)
    (hcond_eq : ∀ (i : I) (hi : i ∈ tail), ∀ r, (hr : r < k) → ∀ s : S, (hspos :
      0 < EconCSLib.pmfProb ν
        (fun sample =>
          im05_listPrefixOmits i r (draw sample) ∧
            state i r sample = s)) →
      EconCSLib.pmfConditionalProb ν
          (fun sample =>
            im05_listPrefixOmits i r (draw sample) ∧
              state i r sample = s)
          (fun sample => draw sample ⟨r, hr⟩ = i) =
        (EconCSLib.finiteWeightedPMFExcluding
          prob (previous i r s) hprob_nonneg (havailable_pos i hi r hr s hspos)
          i).toReal)
    (hall : ∀ i ∈ tail,
      EconCSLib.pmfProb μ (fun ω => absent i ω) =
        (EconCSLib.pmfProb ν
          (fun sample => im05_listPrefixOmits i k (draw sample))) ^ n) :
    (g : ℝ) / 2 *
        Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤
      EconCSLib.pmfExp μ
        (fun ω =>
          (((Finset.univ : Finset I).filter fun i => absent i ω).card : ℝ)) := by
  classical
  refine
    paper_im05_lemma4_3_expected_absent_count_lower_bound_from_rank_tail
      μ absent tail rank g n k hg hcard ?_ hhalf ?_
  · intro i hi
    have h := htwo_k i hi
    omega
  · intro i hi
    have hk_rank_i : k < rank i := by
      have h := htwo_k i hi
      omega
    exact
      paper_im05_lemma4_3_absence_probability_ge_exp_rank_from_rank_power
        (rank i) k n hk_pos (htwo_k i hi)
        (paper_im05_lemma4_3_absence_probability_ge_rank_power_from_algorithm4_2_prefix_states
          ν draw i μ (fun ω => absent i ω)
          (state i) (witnessTail i) prob (previous i) (prevMass i)
          Q (rank i) n hk_rank_i
          (hprefix_pos i hi) hprob_nonneg hprob_sum
          (hprevMass i hi) (havailable_pos i hi) (hw_not_previous i hi)
          (hprev_le_Q i hi) hQ_pos (hwitness_card i hi)
          (hmass_tail_le i hi) (hpopular i hi) (hcond_eq i hi) (hall i hi))

