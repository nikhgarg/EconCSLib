theorem im05_SourceFinalNoninitialStableHusbandTargetBlocks_of_final_target_removed
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hfinalRemoved :
      ∀ m : M,
        m ∈ im05_stableHusbands val_m val_w g →
          im05_algorithm41InitialHusband val_m val_w g ≠ some m →
            g ∉
              (im05_algorithm41SourceDivorceTargetFinalState
                val_m val_w g).m_proposals m) :
    im05_SourceFinalNoninitialStableHusbandTargetBlocks val_m val_w g := by
  classical
  intro m hm hnotInitial
  let final := im05_algorithm41SourceDivorceTargetFinalState val_m val_w g
  cases hmatch : final.m_match m with
  | none =>
      simpa [valM, final, hmatch] using hacceptable.1 m g
  | some wcur =>
      have horder :
          im05_ManCurrentMatchOrderInvariant val_m final := by
        simpa [final, im05_algorithm41SourceDivorceTargetFinalState] using
          im05_algorithm41SourceDivorceTargetStateAfterSteps_currentMatchOrder_of_allPairsAcceptable
            val_m val_w g (Fintype.card M * Fintype.card W)
            hstrictW hacceptable
      have hle : val_m m wcur ≤ val_m m g :=
        horder m g wcur
          (by simpa [final] using hfinalRemoved m hm hnotInitial)
          hmatch
      have hne_wcur_g : wcur ≠ g := by
        intro hw
        subst wcur
        have hwmatch : final.w_match g = some m := (final.consistent m g).1 hmatch
        have hnone :
            final.w_match g = none := by
          simpa [final] using
            im05_algorithm41SourceDivorceTargetFinalState_w_match_target_none
              val_m val_w g
        cases hnone.symm.trans hwmatch
      have hneq : val_m m wcur ≠ val_m m g := by
        intro heq
        exact hne_wcur_g (hstrictM m wcur g heq)
      exact lt_of_le_of_ne hle hneq

