theorem paper_im05_lemma4_1_from_variance_and_lemma4_3
    {Ω : Type*} [Fintype Ω] [DecidableEq Ω]
    (μ : PMF Ω) (X Y : Ω → ℕ)
    (g n k : ℕ) (hg : 0 < g) (EY : ℝ)
    (hEY_lower :
      (g : ℝ) / 2 *
          Real.exp (-(8 * (n : ℝ) * (k : ℝ) / (g : ℝ))) ≤ EY)
    (hEY :
      EconCSLib.pmfExp μ (fun ω => (Y ω : ℝ)) = EY)
    (hvar :
      EconCSLib.pmfVariance μ (fun ω => (Y ω : ℝ)) ≤ EY)
    (hXY : ∀ ω, Y ω ≤ X ω) :
    im05_reciprocalCountExpectation μ X ≤
      12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ)) / (g : ℝ) := by
  let a : ℝ := 8 * (n : ℝ) * (k : ℝ) / (g : ℝ)
  have hg_pos : 0 < (g : ℝ) := by exact_mod_cast hg
  have hEY_pos : 0 < EY := by
    have hL_pos : 0 < (g : ℝ) / 2 * Real.exp (-a) := by positivity
    exact lt_of_lt_of_le hL_pos (by simpa [a] using hEY_lower)
  have hreciprocal :
      im05_reciprocalCountExpectation μ X ≤ 6 / EY :=
    paper_im05_lemma4_1_reciprocal_bound_from_variance
      μ X Y EY hEY hEY_pos hvar hXY
  exact
    paper_im05_lemma4_1_algebra_from_lemma4_3
      g n k hg EY (im05_reciprocalCountExpectation μ X)
      hEY_lower hreciprocal

/--
Constant-factor Lemma 4.1 bridge.  This variant is useful for corrected proof
