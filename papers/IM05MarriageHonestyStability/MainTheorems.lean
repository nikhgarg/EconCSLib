-/
theorem im05_algorithm41FinalState_target_holder_mem_stableHusbands_of_no_target_block
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (g : W) {m : M}
    (hmatch : (im05_algorithm41FinalState val_m val_w g).w_match g = some m)
    (hno_target_block : ∀ r : M,
      valM val_m r ((im05_algorithm41FinalState val_m val_w g).m_match r) <
          val_m r g →
        valW val_w g ((im05_algorithm41FinalState val_m val_w g).w_match g) <
          val_w g r → False) :
    m ∈ im05_stableHusbands val_m val_w g := by
  classical
  let finalAssignment : Assignment M W :=
    ⟨(im05_algorithm41FinalState val_m val_w g).m_match,
      (im05_algorithm41FinalState val_m val_w g).w_match,
      (im05_algorithm41FinalState val_m val_w g).consistent⟩
  have hstable_except :
      IsStableExceptWoman val_m val_w finalAssignment g := by
    simpa [finalAssignment] using
      im05_algorithm41FinalState_stable_except_target val_m val_w g
  have hstable : IsStable val_m val_w finalAssignment :=
    stable_of_stableExceptWoman_and_no_target_block
      val_m val_w finalAssignment g hstable_except
      (by
        intro r hm hg
        exact hno_target_block r (by simpa [finalAssignment] using hm)
          (by simpa [finalAssignment] using hg))
  simp [im05_stableHusbands]
  exact ⟨finalAssignment, hstable, by simpa [finalAssignment] using hmatch⟩

