        (im05_algorithm41SourceStep val_m val_w s) :=
    im05_algorithm41SourceStep_preserves_manProposalOrderInvariant
      val_m val_w s hproposalOrder
  by_cases hactive : ∃ a, IsActiveMan val_m s a
  · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · by_cases htarget : daStepChosenWoman val_m s hactive = target
      · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc,
          htarget, divorceWomanState] using hsource
      · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc,
          htarget] using hsource
    · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc]
        using hsource
  · simpa [im05_algorithm41SourceStepDivorceTarget, hactive] using
      hproposalOrder

theorem im05_algorithm41SourceDivorceTargetStateAfterStepsFrom_preserves_manProposalOrderInvariant
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (start : DAState M W) (steps : ℕ)
    (hproposalOrder : ManProposalOrderInvariant val_m start) :
    ManProposalOrderInvariant val_m
      (im05_algorithm41SourceDivorceTargetStateAfterStepsFrom
        val_m val_w target start steps) := by
  unfold im05_algorithm41SourceDivorceTargetStateAfterStepsFrom
  induction List.range steps generalizing start with
  | nil =>
      simpa using hproposalOrder
  | cons _ rest ih =>
      simp [List.foldl_cons]
      exact ih (im05_algorithm41SourceStepDivorceTarget val_m val_w target start)
        (im05_algorithm41SourceStepDivorceTarget_preserves_manProposalOrderInvariant
          val_m val_w start target hproposalOrder)

theorem im05_algorithm41SourceStepDivorceTarget_preserves_currentMatchOrder
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s) :
    im05_ManCurrentMatchOrderInvariant val_m
      (im05_algorithm41SourceStepDivorceTarget val_m val_w target s) := by
  classical
  have hsource :
      im05_ManCurrentMatchOrderInvariant val_m
        (im05_algorithm41SourceStep val_m val_w s) :=
    im05_algorithm41SourceStep_preserves_currentMatchOrder
      val_m val_w s hproposalOrder hmatchOrder
  by_cases hactive : ∃ a, IsActiveMan val_m s a
  · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · by_cases htarget : daStepChosenWoman val_m s hactive = target
      · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc,
          htarget] using
          im05_divorceWomanState_preserves_currentMatchOrder
            val_m (im05_algorithm41SourceStep val_m val_w s) target hsource
      · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc,
          htarget] using hsource
    · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc]
        using hsource
  · simpa [im05_algorithm41SourceStepDivorceTarget, hactive] using hmatchOrder

theorem im05_algorithm41SourceDivorceTargetStateAfterStepsFrom_preserves_currentMatchOrder
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (start : DAState M W) (steps : ℕ)
    (hproposalOrder : ManProposalOrderInvariant val_m start)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m start) :
    im05_ManCurrentMatchOrderInvariant val_m
      (im05_algorithm41SourceDivorceTargetStateAfterStepsFrom
        val_m val_w target start steps) := by
  unfold im05_algorithm41SourceDivorceTargetStateAfterStepsFrom
  induction List.range steps generalizing start with
  | nil =>
      simpa using hmatchOrder
  | cons _ rest ih =>
      simp [List.foldl_cons]
      exact ih (im05_algorithm41SourceStepDivorceTarget val_m val_w target start)
        (im05_algorithm41SourceStepDivorceTarget_preserves_manProposalOrderInvariant
          val_m val_w start target hproposalOrder)
        (im05_algorithm41SourceStepDivorceTarget_preserves_currentMatchOrder
          val_m val_w start target hproposalOrder hmatchOrder)

/--
If `r` has previously proposed to the target, then in any stable matching that
matches the target to a strictly worse man, `r` must strictly prefer the target
to his own stable partner.  Removed non-current pairs are ruled out by
Roth-style rejected-pair impossibility; remaining pairs and the current match
are ruled out by proposal-order invariants.
-/
theorem im05_prior_proposer_prefers_target_in_stable_match
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejected : DARejectedPairImpossibleInvariant val_m val_w s)
    {b r : M} {mu : Assignment M W}
    (hstable : im05_stable_matching val_m val_w mu)
    (hmu_target : mu.w_match target = some b)
    (hr_proposed : im05_algorithm41HasProposedTo s r target)
    (htarget_prefers_r : val_w target b < val_w target r) :
    valM val_m r (mu.m_match r) < val_m r target := by
  classical
  cases hmu_r : mu.m_match r with
  | none =>
      simpa [valM, hmu_r] using hacceptable.1 r target
  | some wmu =>
      have hr_ne_b : r ≠ b := by
        intro h
        subst r
        exact (lt_irrefl (val_w target b)) htarget_prefers_r
      have hwmu_ne_target : wmu ≠ target := by
        intro hw
        subst wmu
        have htarget_r : mu.w_match target = some r :=
          (mu.consistent_m r target).1 hmu_r
        exact hr_ne_b (Option.some.inj (htarget_r.symm.trans hmu_target))
      have hle : val_m r wmu ≤ val_m r target := by
        by_cases hremaining : wmu ∈ s.m_proposals r
        · exact hproposalOrder r target wmu hr_proposed hremaining
            (le_of_lt (hacceptable.1 r wmu))
        · by_cases hcurrent : s.m_match r = some wmu
          · exact hmatchOrder r target wmu hr_proposed hcurrent
          · exact False.elim (hrejected mu hstable r wmu hremaining hcurrent hmu_r)
      have hneq : val_m r wmu ≠ val_m r target := by
        intro heq
        exact hwmu_ne_target (hstrictM r wmu target heq)
      exact (lt_of_le_of_ne hle hneq)

/--
Target-exception version of
`im05_prior_proposer_prefers_target_in_stable_match`, suitable after Algorithm
4.1 has already removed accepted target pairs.
-/
theorem im05_prior_proposer_prefers_target_in_stable_match_except_target
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s target)
    {b r : M} {mu : Assignment M W}
    (hstable : im05_stable_matching val_m val_w mu)
    (hmu_target : mu.w_match target = some b)
    (hr_proposed : im05_algorithm41HasProposedTo s r target)
    (htarget_prefers_r : val_w target b < val_w target r) :
    valM val_m r (mu.m_match r) < val_m r target := by
  classical
  cases hmu_r : mu.m_match r with
  | none =>
      simpa [valM, hmu_r] using hacceptable.1 r target
  | some wmu =>
      have hr_ne_b : r ≠ b := by
        intro h
        subst r
        exact (lt_irrefl (val_w target b)) htarget_prefers_r
      have hwmu_ne_target : wmu ≠ target := by
        intro hw
        subst wmu
        have htarget_r : mu.w_match target = some r :=
          (mu.consistent_m r target).1 hmu_r
        exact hr_ne_b (Option.some.inj (htarget_r.symm.trans hmu_target))
      have hle : val_m r wmu ≤ val_m r target := by
        by_cases hremaining : wmu ∈ s.m_proposals r
        · exact hproposalOrder r target wmu hr_proposed hremaining
            (le_of_lt (hacceptable.1 r wmu))
        · by_cases hcurrent : s.m_match r = some wmu
          · exact hmatchOrder r target wmu hr_proposed hcurrent
          · exact False.elim
              (hrejected mu hstable r wmu hwmu_ne_target hremaining hcurrent hmu_r)
      have hneq : val_m r wmu ≠ val_m r target := by
        intro heq
        exact hwmu_ne_target (hstrictM r wmu target heq)
      exact (lt_of_le_of_ne hle hneq)

/--
Non-target version of the prior-proposer blocking bridge.  The target-exception
rejected-pair invariant is enough as long as the prior proposer is not matched
to the exceptional target in the stable matching being ruled out.
-/
theorem im05_prior_proposer_prefers_woman_in_stable_match_except_exception
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (exception w : W)
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hproposalOrder : ManProposalOrderInvariant val_m s)
    (hmatchOrder : im05_ManCurrentMatchOrderInvariant val_m s)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s exception)
    {b r : M} {mu : Assignment M W}
    (hstable : im05_stable_matching val_m val_w mu)
    (hmu_w : mu.w_match w = some b)
    (hw_ne_exception : w ≠ exception)
    (hr_proposed : im05_algorithm41HasProposedTo s r w)
    (hw_prefers_r : val_w w b < val_w w r)
    (hr_not_exception : mu.m_match r ≠ some exception) :
    valM val_m r (mu.m_match r) < val_m r w := by
  classical
  cases hmu_r : mu.m_match r with
  | none =>
      simpa [valM, hmu_r] using hacceptable.1 r w
  | some wmu =>
      have hr_ne_b : r ≠ b := by
        intro h
        subst r
        exact (lt_irrefl (val_w w b)) hw_prefers_r
      have hwmu_ne_w : wmu ≠ w := by
        intro hw
        subst wmu
        have hw_r : mu.w_match w = some r :=
          (mu.consistent_m r w).1 hmu_r
        exact hr_ne_b (Option.some.inj (hw_r.symm.trans hmu_w))
      have hwmu_ne_exception : wmu ≠ exception := by
        intro hw
        subst wmu
        exact hr_not_exception hmu_r
      have hle : val_m r wmu ≤ val_m r w := by
        by_cases hremaining : wmu ∈ s.m_proposals r
        · exact hproposalOrder r w wmu hr_proposed hremaining
            (le_of_lt (hacceptable.1 r wmu))
        · by_cases hcurrent : s.m_match r = some wmu
          · exact hmatchOrder r w wmu hr_proposed hcurrent
          · exact False.elim
              (hrejected mu hstable r wmu hwmu_ne_exception hremaining hcurrent hmu_r)
      have hneq : val_m r wmu ≠ val_m r w := by
        intro heq
        exact hwmu_ne_w (hstrictM r wmu w heq)
      exact lt_of_le_of_ne hle hneq

/--
Active-proposer preference bridge for a non-target Algorithm 4.1 step.  If the
chosen proposer is not matched to the exceptional target and is also not
matched to the chosen woman in the stable matching under consideration, then
the chosen proposal would be a strict improvement for him.  This is the
man-side half of the accepted-displacement blocking-pair argument.
-/
theorem im05_active_proposer_prefers_chosen_in_stable_match_except_exception
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (exception : W) {a : M} {w : W}
    {mu : Assignment M W}
    (hstrictM : MenStrictPreferenceProfile val_m)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hrejected :
      im05_DARejectedPairImpossibleExceptWoman val_m val_w s exception)
    (hstable : im05_stable_matching val_m val_w mu)
    (hact : IsActiveMan val_m s a)
    (hwbest : BestRemainingWoman val_m s a w)
    (ha_not_exception : mu.m_match a ≠ some exception)
    (ha_not_w : mu.m_match a ≠ some w) :
    valM val_m a (mu.m_match a) < val_m a w := by
  classical
  cases ha_mu : mu.m_match a with
  | none =>
      simpa [valM, ha_mu] using hacceptable.1 a w
  | some wmu =>
      have hwmu_ne_w : wmu ≠ w := by
        intro hw
        subst wmu
        exact ha_not_w ha_mu
      by_cases hle : val_m a wmu ≤ val_m a w
      · have hneq : val_m a wmu ≠ val_m a w := by
          intro heq
          exact hwmu_ne_w (hstrictM a wmu w heq)
        exact lt_of_le_of_ne hle hneq
      · have hbetter : val_m a w < val_m a wmu := lt_of_not_ge hle
        have hnotRemaining : wmu ∉ s.m_proposals a :=
          better_than_best_not_remaining val_m s hacceptable.1 hwbest
            wmu hbetter
        have hnotCurrent : s.m_match a ≠ some wmu := by
          intro hmatch
          rw [hact.1] at hmatch
          cases hmatch
        have hwmu_ne_exception : wmu ≠ exception := by
          intro hw
          subst wmu
          exact ha_not_exception ha_mu
        exact False.elim
          (hrejected mu hstable a wmu hwmu_ne_exception hnotRemaining
            hnotCurrent ha_mu)

theorem im05_mem_stableHusbands_iff_exists_stable_exception_match
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) {r : M} :
    r ∈ im05_stableHusbands val_m val_w g ↔
      ∃ mu : Assignment M W,
        im05_stable_matching val_m val_w mu ∧
          mu.m_match r = some g := by
  constructor
  · intro hr
    rcases (by simpa [im05_stableHusbands] using hr) with
      ⟨mu, hstable, hw⟩
    exact ⟨mu, hstable, (mu.consistent_m r g).2 hw⟩
  · rintro ⟨mu, hstable, hm⟩
    have hw : mu.w_match g = some r := (mu.consistent_m r g).1 hm
    exact (by
      simpa [im05_stableHusbands] using ⟨mu, hstable, hw⟩)

theorem im05_not_exception_match_of_not_mem_stableHusbands
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) {r : M} {mu : Assignment M W}
    (hstable : im05_stable_matching val_m val_w mu)
    (hnotStableHusband : r ∉ im05_stableHusbands val_m val_w g) :
    mu.m_match r ≠ some g := by
  intro hmatch
  have hw : mu.w_match g = some r := (mu.consistent_m r g).1 hmatch
  exact hnotStableHusband (by
    simpa [im05_stableHusbands] using ⟨mu, hstable, hw⟩)

theorem im05_not_mem_stableHusbands_of_forall_stable_not_exception_match
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) {r : M}
    (hnotMatch :
      ∀ mu : Assignment M W,
        im05_stable_matching val_m val_w mu →
          mu.m_match r ≠ some g) :
    r ∉ im05_stableHusbands val_m val_w g := by
  intro hr
  rcases (by simpa [im05_stableHusbands] using hr) with
    ⟨mu, hstable, hw⟩
  exact hnotMatch mu hstable ((mu.consistent_m r g).2 hw)

theorem im05_not_mem_stableHusbands_iff_forall_stable_not_exception_match
    {M W : Type*} [Fintype M] [DecidableEq M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) {r : M} :
    r ∉ im05_stableHusbands val_m val_w g ↔
      ∀ mu : Assignment M W,
        im05_stable_matching val_m val_w mu →
          mu.m_match r ≠ some g := by
  constructor
  · intro hnot mu hstable
    exact
      im05_not_exception_match_of_not_mem_stableHusbands
        val_m val_w g hstable hnot
  · exact
      im05_not_mem_stableHusbands_of_forall_stable_not_exception_match
        val_m val_w g

/--
Readable trace condition for the corrected Algorithm 4.1 run: every non-target
blocking proposer used in the exception-partner argument is outside the stable
husband set of the target woman `g`.
-/
def im05_SourceStepNonTargetBlockersNotStableHusbands
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (g : W) : Prop :=
  ∀ hactive : ∃ a, IsActiveMan val_m s a,
    daStepChosenWoman val_m s hactive ≠ g →
      (¬ im05_algorithm41SourceStepAccepts val_m val_w s hactive →
        ∀ (mu : Assignment M W),
          im05_stable_matching val_m val_w mu →
            mu.w_match (daStepChosenWoman val_m s hactive) =
              some (daStepChosenMan val_m s hactive) →
              ∀ r : M,
                im05_algorithm41HasProposedTo s r
                  (daStepChosenWoman val_m s hactive) →
                  val_w (daStepChosenWoman val_m s hactive)
                      (daStepChosenMan val_m s hactive) <
                    val_w (daStepChosenWoman val_m s hactive) r →
                    r ∉ im05_stableHusbands val_m val_w g) ∧
      (im05_algorithm41SourceStepAccepts val_m val_w s hactive →
        ∀ cur,
          s.w_match (daStepChosenWoman val_m s hactive) = some cur →
            daStepChosenMan val_m s hactive ∉
              im05_stableHusbands val_m val_w g)

/--
Stronger local form of the non-target blocker obligation: instead of proving
stable-husband non-membership directly, rule out matching to the exceptional
target in every stable matching.
-/
def im05_SourceStepNonTargetStableMatchExclusions
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (g : W) : Prop :=
  ∀ hactive : ∃ a, IsActiveMan val_m s a,
    daStepChosenWoman val_m s hactive ≠ g →
      (¬ im05_algorithm41SourceStepAccepts val_m val_w s hactive →
        ∀ r : M,
          im05_algorithm41HasProposedTo s r
            (daStepChosenWoman val_m s hactive) →
            val_w (daStepChosenWoman val_m s hactive)
                (daStepChosenMan val_m s hactive) <
              val_w (daStepChosenWoman val_m s hactive) r →
              ∀ mu : Assignment M W,
                im05_stable_matching val_m val_w mu →
                  mu.m_match r ≠ some g) ∧
      (im05_algorithm41SourceStepAccepts val_m val_w s hactive →
        ∀ cur,
          s.w_match (daStepChosenWoman val_m s hactive) = some cur →
            ∀ mu : Assignment M W,
              im05_stable_matching val_m val_w mu →
                mu.m_match (daStepChosenMan val_m s hactive) ≠ some g)

theorem im05_SourceStepNonTargetBlockersNotStableHusbands_of_stableMatchExclusions
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (g : W)
    (hexcl :
      im05_SourceStepNonTargetStableMatchExclusions val_m val_w s g) :
    im05_SourceStepNonTargetBlockersNotStableHusbands val_m val_w s g := by
  intro hactive hnonTarget
  constructor
  · intro hreject _mu _hstable _hmu_w r hr hbetter
    exact
      im05_not_mem_stableHusbands_of_forall_stable_not_exception_match
        val_m val_w g
        ((hexcl hactive hnonTarget).1 hreject r hr hbetter)
  · intro haccept cur hcur
    exact
      im05_not_mem_stableHusbands_of_forall_stable_not_exception_match
        val_m val_w g
        ((hexcl hactive hnonTarget).2 haccept cur hcur)

def im05_SourceTraceNonTargetBlockersNotStableHusbands
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) (steps : ℕ) : Prop :=
  (∀ t : ℕ,
    t < steps →
      ∀ hactive :
        ∃ a, IsActiveMan val_m
          (im05_algorithm41SourceDivorceTargetStateAfterSteps
            val_m val_w g t) a,
        daStepChosenWoman val_m
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) hactive ≠ g →
          ¬ im05_algorithm41SourceStepAccepts val_m val_w
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) hactive →
            ∀ (mu : Assignment M W),
              im05_stable_matching val_m val_w mu →
                mu.w_match
                    (daStepChosenWoman val_m
                      (im05_algorithm41SourceDivorceTargetStateAfterSteps
                        val_m val_w g t) hactive) =
                  some
                    (daStepChosenMan val_m
                      (im05_algorithm41SourceDivorceTargetStateAfterSteps
                        val_m val_w g t) hactive) →
                  ∀ r : M,
                    im05_algorithm41HasProposedTo
                      (im05_algorithm41SourceDivorceTargetStateAfterSteps
                        val_m val_w g t) r
                      (daStepChosenWoman val_m
                        (im05_algorithm41SourceDivorceTargetStateAfterSteps
                          val_m val_w g t) hactive) →
                      val_w
                          (daStepChosenWoman val_m
                            (im05_algorithm41SourceDivorceTargetStateAfterSteps
                              val_m val_w g t) hactive)
                          (daStepChosenMan val_m
                            (im05_algorithm41SourceDivorceTargetStateAfterSteps
                              val_m val_w g t) hactive) <
                        val_w
                          (daStepChosenWoman val_m
                            (im05_algorithm41SourceDivorceTargetStateAfterSteps
                              val_m val_w g t) hactive) r →
                        r ∉ im05_stableHusbands val_m val_w g) ∧
  (∀ t : ℕ,
    t < steps →
      ∀ hactive :
        ∃ a, IsActiveMan val_m
          (im05_algorithm41SourceDivorceTargetStateAfterSteps
            val_m val_w g t) a,
        daStepChosenWoman val_m
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) hactive ≠ g →
          im05_algorithm41SourceStepAccepts val_m val_w
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) hactive →
            ∀ cur,
              (im05_algorithm41SourceDivorceTargetStateAfterSteps
                val_m val_w g t).w_match
                  (daStepChosenWoman val_m
                    (im05_algorithm41SourceDivorceTargetStateAfterSteps
                      val_m val_w g t) hactive) = some cur →
                daStepChosenMan val_m
                    (im05_algorithm41SourceDivorceTargetStateAfterSteps
                      val_m val_w g t) hactive ∉
          im05_stableHusbands val_m val_w g)

def im05_SourceTraceNonTargetStableMatchExclusions
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) (steps : ℕ) : Prop :=
  ∀ t : ℕ,
    t < steps →
      im05_SourceStepNonTargetStableMatchExclusions val_m val_w
        (im05_algorithm41SourceDivorceTargetStateAfterSteps
          val_m val_w g t) g

theorem im05_SourceStepNonTargetStableMatchExclusions_of_target_chosen
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (g : W)
    (htarget :
      ∀ hactive : ∃ a, IsActiveMan val_m s a,
        daStepChosenWoman val_m s hactive = g) :
    im05_SourceStepNonTargetStableMatchExclusions val_m val_w s g := by
  intro hactive hnonTarget
  exact False.elim (hnonTarget (htarget hactive))

theorem im05_SourceTraceNonTargetStableMatchExclusions_of_target_chosen_prefix
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) (steps : ℕ)
    (htargetPrefix :
      ∀ t : ℕ,
        t < steps →
          ∀ hactive :
            ∃ a, IsActiveMan val_m
              (im05_algorithm41SourceDivorceTargetStateAfterSteps
                val_m val_w g t) a,
            daStepChosenWoman val_m
              (im05_algorithm41SourceDivorceTargetStateAfterSteps
                val_m val_w g t) hactive = g) :
    im05_SourceTraceNonTargetStableMatchExclusions val_m val_w g steps := by
  intro t ht
  exact
    im05_SourceStepNonTargetStableMatchExclusions_of_target_chosen
      val_m val_w
      (im05_algorithm41SourceDivorceTargetStateAfterSteps
        val_m val_w g t) g
      (htargetPrefix t ht)

theorem im05_SourceTraceNonTargetBlockersNotStableHusbands_of_stepBlockers
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) (steps : ℕ)
    (hstep :
      ∀ t : ℕ,
        t < steps →
          im05_SourceStepNonTargetBlockersNotStableHusbands val_m val_w
            (im05_algorithm41SourceDivorceTargetStateAfterSteps
              val_m val_w g t) g) :
    im05_SourceTraceNonTargetBlockersNotStableHusbands
      val_m val_w g steps := by
  constructor
  · intro t ht hactive hnonTarget hreject mu hstable hmu_w r hr hbetter
    exact (hstep t ht hactive hnonTarget).1
      hreject mu hstable hmu_w r hr hbetter
  · intro t ht hactive hnonTarget haccept cur hcur
    exact (hstep t ht hactive hnonTarget).2 haccept cur hcur

theorem im05_SourceTraceNonTargetBlockersNotStableHusbands_of_stableMatchExclusions
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) (steps : ℕ)
    (hexcl :
      im05_SourceTraceNonTargetStableMatchExclusions
        val_m val_w g steps) :
    im05_SourceTraceNonTargetBlockersNotStableHusbands
      val_m val_w g steps := by
  exact
    im05_SourceTraceNonTargetBlockersNotStableHusbands_of_stepBlockers
      val_m val_w g steps
      (fun t ht =>
        im05_SourceStepNonTargetBlockersNotStableHusbands_of_stableMatchExclusions
          val_m val_w
          (im05_algorithm41SourceDivorceTargetStateAfterSteps
            val_m val_w g t) g
          (hexcl t ht))

theorem im05_SourceTraceNonTargetBlockersNotStableHusbands_iff_stepBlockers
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (g : W) (steps : ℕ) :
    im05_SourceTraceNonTargetBlockersNotStableHusbands
        val_m val_w g steps ↔
