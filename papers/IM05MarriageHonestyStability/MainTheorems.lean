/--
Stable husbands are invariant under relabeling the women side of the market.
This is the deterministic event-invariance core needed for uniform
exchangeability arguments.
-/
theorem im05_stableHusbands_relabelWomen
    {M W W' : Type*} [Fintype M] [DecidableEq M]
    (e : W ≃ W') (val_m : M → W → ℝ) (val_w : W → M → ℝ) (w : W) :
    im05_stableHusbands
        (fun m w' => val_m m (e.symm w'))
        (fun w' m => val_w (e.symm w') m) (e w) =
      im05_stableHusbands val_m val_w w := by
  classical
  ext m
  constructor
  · intro hm
    simp [im05_stableHusbands] at hm ⊢
    rcases hm with ⟨mu', hstable, hmatch⟩
    let mu : Assignment M W := mu'.relabelWomen e.symm
    have hstable_rel :
        IsStable
          (fun m w' => val_m m (e.symm w'))
          (fun w' m => val_w (e.symm w') m)
          (mu.relabelWomen e) := by
      simpa [mu] using hstable
    have hstable_orig : IsStable val_m val_w mu :=
      (isStable_relabelWomen_iff e val_m val_w mu).1 hstable_rel
    have hmatch_orig : mu.w_match w = some m := by
      simpa [mu] using hmatch
    exact ⟨mu, hstable_orig, hmatch_orig⟩
  · intro hm
    simp [im05_stableHusbands] at hm ⊢
    rcases hm with ⟨mu, hstable, hmatch⟩
    refine ⟨mu.relabelWomen e, ?_, ?_⟩
    · exact (isStable_relabelWomen_iff e val_m val_w mu).2 hstable
    · simpa using hmatch

/-- The multi-stable-husband event is invariant under relabeling women. -/
theorem im05_hasMoreThanOneStableHusband_relabelWomen
    {M W W' : Type*} [Fintype M] [DecidableEq M]
    (e : W ≃ W') (val_m : M → W → ℝ) (val_w : W → M → ℝ) (w : W) :
    im05_hasMoreThanOneStableHusband
        (fun m w' => val_m m (e.symm w'))
        (fun w' m => val_w (e.symm w') m) (e w) ↔
      im05_hasMoreThanOneStableHusband val_m val_w w := by
  unfold im05_hasMoreThanOneStableHusband
  rw [im05_stableHusbands_relabelWomen e val_m val_w w]

/--
Pointwise sample-profile version of woman relabeling: if a transformed sample
has exactly the women-relabelled valuation profile, then its fixed-woman
multi-stable event is the original event for the preimage woman.
-/
theorem paper_im05_hasMoreThanOneStableHusband_of_woman_relabeling
    {M W : Type*} [Fintype M] [DecidableEq M]
    (e : W ≃ W) (val_m val_m' : M → W → ℝ)
    (val_w val_w' : W → M → ℝ) (w w' : W)
    (hw : e w = w')
    (hm_relabel : ∀ m x, val_m' m x = val_m m (e.symm x))
    (hw_relabel : ∀ x m, val_w' x m = val_w (e.symm x) m) :
    im05_hasMoreThanOneStableHusband val_m' val_w' w' ↔
      im05_hasMoreThanOneStableHusband val_m val_w w := by
  have hm_fun :
      val_m' = fun m x => val_m m (e.symm x) := by
    funext m x
    exact hm_relabel m x
  have hw_fun :
      val_w' = fun x m => val_w (e.symm x) m := by
    funext x m
    exact hw_relabel x m
  subst w'
  simpa [hm_fun, hw_fun] using
    im05_hasMoreThanOneStableHusband_relabelWomen e val_m val_w w

/-- Count of women with more than one stable husband in a finite market. -/
noncomputable def im05_multiStableHusbandCount {M W : Type*}
    [Fintype M] [Fintype W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) : ℕ := by
  classical
  exact ((Finset.univ : Finset W).filter fun w =>
    im05_hasMoreThanOneStableHusband val_m val_w w).card

/-- Count of men with more than one stable wife in a finite market. -/
noncomputable def im05_multiStableWifeCount {M W : Type*}
    [Fintype M] [Fintype W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) : ℕ := by
  classical
  exact ((Finset.univ : Finset M).filter fun m =>
    im05_hasMoreThanOneStableWife val_m val_w m).card

/--
Theorem 3.1 proof line: by linearity of expectation, the expected number of
women with more than one stable husband is the sum, over women, of the
probability that the woman has more than one stable husband.
-/
theorem paper_im05_ck_linearity_expected_multiStableHusbandCount
    {Ω M W : Type*} [Fintype Ω] [DecidableEq Ω]
    [Fintype M] [Fintype W] [DecidableEq W]
    (μ : PMF Ω)
    (val_m : Ω → M → W → ℝ) (val_w : Ω → W → M → ℝ) :
    EconCSLib.pmfExp μ
        (fun ω => (im05_multiStableHusbandCount (val_m ω) (val_w ω) : ℝ)) =
      ∑ w : W,
        @EconCSLib.pmfProb Ω _ _ μ
          (fun ω =>
            im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w)
          (Classical.decPred _) := by
  classical
  unfold im05_multiStableHusbandCount
  simpa using
    (EconCSLib.pmfExp_card_filter_eq_sum_pmfProb μ
      (fun ω w =>
        im05_hasMoreThanOneStableHusband (val_m ω) (val_w ω) w))

/--
Symmetric linearity proof line for the expected number of men with more than
