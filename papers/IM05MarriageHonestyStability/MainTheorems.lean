    EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 (by
            simpa using Fintype.card_pos_iff.mpr ⟨i⟩))
        (fun sample =>
          im05_listPrefixOmits i 1
              (im05_algorithm42FreshListDraw sample) ∧
            im05_listPrefixOmits j 1
              (im05_algorithm42FreshListDraw sample)) ≤
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 (by
            simpa using Fintype.card_pos_iff.mpr ⟨i⟩))
        (fun sample =>
          im05_listPrefixOmits i 1
            (im05_algorithm42FreshListDraw sample)) *
      EconCSLib.pmfProb
        (im05_algorithm42FreshListPMF
          (im05_countWeight count) (im05_countWeight_nonneg count)
          hcount_available 1 (by
            simpa using Fintype.card_pos_iff.mpr ⟨i⟩))
        (fun sample =>
          im05_listPrefixOmits j 1
            (im05_algorithm42FreshListDraw sample)) := by
  classical
  let μ :=
    im05_algorithm42FreshListPMF
      (im05_countWeight count) (im05_countWeight_nonneg count)
      hcount_available 1 (by
        simpa using Fintype.card_pos_iff.mpr ⟨i⟩)
  let event : I → im05_algorithm42FreshListSample I 1 → Prop :=
    fun u sample =>
      im05_listPrefixOmits u 1 (im05_algorithm42FreshListDraw sample)
  have hcard_two : 2 ≤ Fintype.card I := by
    have hsubset : ({i, j} : Finset I) ⊆ (Finset.univ : Finset I) := by
      intro u _hu
      simp
    have hcard_pair : ({i, j} : Finset I).card = 2 := by
      simp [hij]
    have hle := Finset.card_le_card hsubset
    simpa [hcard_pair] using hle
  have hposj : 0 < EconCSLib.pmfProb μ (event j) := by
    have hcount_pos :
        ∀ u : I, 0 < im05_countWeight count u := by
      intro u
      dsimp [im05_countWeight]
      exact_mod_cast
        im05_count_pos_of_countWeight_available count hcount_available u
    simpa [μ, event] using
      (paper_im05_algorithm4_2_freshList_omit_pos_of_full_support
        (im05_countWeight count) (im05_countWeight_nonneg count)
        hcount_pos hcount_available
        (k := 1)
        (by simpa using Fintype.card_pos_iff.mpr ⟨i⟩)
        (by omega) j)
  have hcond :
      EconCSLib.pmfConditionalProb μ (event j) (event i) ≤
        EconCSLib.pmfProb μ (event i) := by
    simpa [μ, event] using
      (paper_im05_lemma4_4_freshList_conditional_comparison_from_integerMultiset_finite_law_one_of_available
        count hcount_available i j hij)
  simpa [μ, event] using
    (EconCSLib.pmfProb_inter_le_mul_of_conditionalProb_le
      μ (event i) (event j) hposj hcond)

