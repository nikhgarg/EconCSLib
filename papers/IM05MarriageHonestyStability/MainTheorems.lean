/-- Source-shaped runs preserve men's individual rationality. -/
theorem im05_foldl_sourceStep_preserves_manIRInvariant
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (steps : List ℕ) (s : DAState M W)
