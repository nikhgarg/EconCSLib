/-!
# Paper-Facing Theorems: Immorlica-Mahdian 2005

This file begins the formalization of Immorlica and Mahdian's
*Marriage, Honesty, and Stability*.  The first closed seams expose the paper's
stable-partner counting notation, the deterministic set-inclusion core behind
Lemma 4.2, and the asymptotic bridge saying that a uniform constant bound on the
expected number of multi-stable-partner agents implies a vanishing fraction.
-/

namespace IM05MarriageHonestyStability

open EconCSLib.Matching

/-! ## Paper-facing definitions -/

/-- Paper-facing stable matching predicate. -/
def im05_stable_matching {M W : Type*}
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (mu : Assignment M W) : Prop :=
  IsStable val_m val_w mu

/-- The stable husbands of woman `w`: men matched to `w` in some stable matching. -/
noncomputable def im05_stableHusbands {M W : Type*}
    [Fintype M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (w : W) : Finset M := by
  classical
  exact (Finset.univ : Finset M).filter fun m =>
    ∃ mu : Assignment M W, im05_stable_matching val_m val_w mu ∧
      mu.w_match w = some m

/-- The stable wives of man `m`: women matched to `m` in some stable matching. -/
noncomputable def im05_stableWives {M W : Type*}
    [Fintype W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (m : M) : Finset W := by
  classical
  exact (Finset.univ : Finset W).filter fun w =>
    ∃ mu : Assignment M W, im05_stable_matching val_m val_w mu ∧
      mu.m_match m = some w

/-- Woman `w` has more than one stable husband. -/
def im05_hasMoreThanOneStableHusband {M W : Type*}
    [Fintype M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (w : W) : Prop :=
  1 < (im05_stableHusbands val_m val_w w).card

/-- Man `m` has more than one stable wife. -/
def im05_hasMoreThanOneStableWife {M W : Type*}
    [Fintype W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (m : M) : Prop :=
  1 < (im05_stableWives val_m val_w m).card

/--
`w` has more than one stable husband exactly when two stable matchings witness
two distinct husbands for `w`.
-/
theorem im05_hasMoreThanOneStableHusband_iff_exists_distinct
    {M W : Type*} [Fintype M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (w : W) :
    im05_hasMoreThanOneStableHusband val_m val_w w ↔
      ∃ m₁ m₂ : M, m₁ ≠ m₂ ∧
        (∃ mu : Assignment M W,
          im05_stable_matching val_m val_w mu ∧ mu.w_match w = some m₁) ∧
        (∃ nu : Assignment M W,
          im05_stable_matching val_m val_w nu ∧ nu.w_match w = some m₂) := by
  classical
  unfold im05_hasMoreThanOneStableHusband
  rw [Finset.one_lt_card_iff]
  constructor
  · rintro ⟨m₁, m₂, hm₁, hm₂, hne⟩
    simp [im05_stableHusbands] at hm₁ hm₂
    exact ⟨m₁, m₂, hne, hm₁, hm₂⟩
  · rintro ⟨m₁, m₂, hne, hm₁, hm₂⟩
    refine ⟨m₁, m₂, ?_, ?_, hne⟩
    · simp [im05_stableHusbands, hm₁]
    · simp [im05_stableHusbands, hm₂]

/--
`m` has more than one stable wife exactly when two stable matchings witness two
distinct wives for `m`.
-/
theorem im05_hasMoreThanOneStableWife_iff_exists_distinct
    {M W : Type*} [Fintype W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (m : M) :
    im05_hasMoreThanOneStableWife val_m val_w m ↔
      ∃ w₁ w₂ : W, w₁ ≠ w₂ ∧
        (∃ mu : Assignment M W,
          im05_stable_matching val_m val_w mu ∧ mu.m_match m = some w₁) ∧
        (∃ nu : Assignment M W,
          im05_stable_matching val_m val_w nu ∧ nu.m_match m = some w₂) := by
  classical
  unfold im05_hasMoreThanOneStableWife
  rw [Finset.one_lt_card_iff]
  constructor
  · rintro ⟨w₁, w₂, hw₁, hw₂, hne⟩
    simp [im05_stableWives] at hw₁ hw₂
    exact ⟨w₁, w₂, hne, hw₁, hw₂⟩
  · rintro ⟨w₁, w₂, hne, hw₁, hw₂⟩
    refine ⟨w₁, w₂, ?_, ?_, hne⟩
    · simp [im05_stableWives, hw₁]
    · simp [im05_stableWives, hw₂]

/--
If woman `w` does not have more than one stable husband, then any two stable
matchings that match her must match her to the same man.
-/
theorem im05_not_multiStableHusband_eq_of_stable_matches
    {M W : Type*} [Fintype M]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (w : W)
    (hnot : ¬ im05_hasMoreThanOneStableHusband val_m val_w w)
    (mu nu : Assignment M W)
    (hmu : im05_stable_matching val_m val_w mu)
    (hnu : im05_stable_matching val_m val_w nu)
    {m₁ m₂ : M}
    (hm₁ : mu.w_match w = some m₁)
    (hm₂ : nu.w_match w = some m₂) :
    m₁ = m₂ := by
  by_contra hne
  exact hnot
    ((im05_hasMoreThanOneStableHusband_iff_exists_distinct
      val_m val_w w).2
      ⟨m₁, m₂, hne, ⟨mu, hmu, hm₁⟩, ⟨nu, hnu, hm₂⟩⟩)

/--
If man `m` does not have more than one stable wife, then any two stable
matchings that match him must match him to the same woman.
-/
theorem im05_not_multiStableWife_eq_of_stable_matches
    {M W : Type*} [Fintype W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (m : M)
    (hnot : ¬ im05_hasMoreThanOneStableWife val_m val_w m)
    (mu nu : Assignment M W)
    (hmu : im05_stable_matching val_m val_w mu)
    (hnu : im05_stable_matching val_m val_w nu)
    {w₁ w₂ : W}
    (hw₁ : mu.m_match m = some w₁)
    (hw₂ : nu.m_match m = some w₂) :
    w₁ = w₂ := by
  by_contra hne
  exact hnot
    ((im05_hasMoreThanOneStableWife_iff_exists_distinct
      val_m val_w m).2
      ⟨w₁, w₂, hne, ⟨mu, hmu, hw₁⟩, ⟨nu, hnu, hw₂⟩⟩)

/-- A list of men is weakly ordered from worst to best for woman `g`. -/
def im05_worstToBestForWoman {M W : Type*}
    (val_w : W → M → ℝ) (g : W) (output : List M) : Prop :=
  output.Pairwise fun m₁ m₂ => val_w g m₁ ≤ val_w g m₂

/--
The source-specific acceptance standard used by Algorithm 4.1 for the target
woman after a divorce.  `none` means no remembered proposer yet; `some best`
means the target only accepts men she strictly prefers to `best`.
-/
def im05_algorithm41TargetAccepts
    {M W : Type*} (val_w : W → M → ℝ) (g : W)
    (standard : Option M) (m : M) : Prop :=
  match standard with
  | none => 0 ≤ val_w g m
  | some best => val_w g best < val_w g m

/-- Updating the Algorithm 4.1 target standard after `g` accepts a proposer. -/
def im05_algorithm41TargetStandardAfterAccept {M : Type*}
    (_standard : Option M) (m : M) : Option M :=
  some m

/-- Accepting a proposer weakly improves the target's remembered standard. -/
theorem im05_algorithm41TargetStandard_value_mono_of_accepts
    {M W : Type*} (val_w : W → M → ℝ) (g : W)
    (standard : Option M) (m : M)
    (haccept : im05_algorithm41TargetAccepts val_w g standard m) :
    valW val_w g standard ≤
      valW val_w g (im05_algorithm41TargetStandardAfterAccept standard m) := by
  cases standard with
  | none =>
      simpa [im05_algorithm41TargetAccepts,
        im05_algorithm41TargetStandardAfterAccept, valW] using haccept
  | some best =>
      exact le_of_lt (by
        simpa [im05_algorithm41TargetAccepts,
          im05_algorithm41TargetStandardAfterAccept, valW] using haccept)

/-- The updated target standard is exactly the accepted proposer. -/
@[simp] theorem im05_algorithm41TargetStandardAfterAccept_eq_some
    {M : Type*} (standard : Option M) (m : M) :
    im05_algorithm41TargetStandardAfterAccept standard m = some m := rfl

/--
In the source Algorithm 4.1, a woman compares a suitor to the best man who has
proposed to her so far.  The `DAState` proposal set stores remaining proposal
opportunities, so absence from that set means the proposal has already occurred.
-/
def im05_algorithm41HasProposedTo
    {M W : Type*} (s : DAState M W) (m : M) (w : W) : Prop :=
  w ∉ s.m_proposals m

/-- Source Step 4(a): no previously seen proposer is strictly better than `b`. -/
def im05_algorithm41HistoryAccepts
    {M W : Type*} (val_w : W → M → ℝ) (s : DAState M W)
    (w : W) (b : M) : Prop :=
  ∀ r : M, im05_algorithm41HasProposedTo s r w →
    ¬ val_w w b < val_w w r

/-- `best` is a best-so-far proposer for `w` according to the proposal history. -/
def im05_algorithm41BestProposedSoFar
    {M W : Type*} (val_w : W → M → ℝ) (s : DAState M W)
    (w : W) (best : M) : Prop :=
  im05_algorithm41HasProposedTo s best w ∧
    ∀ r : M, im05_algorithm41HasProposedTo s r w →
      val_w w r ≤ val_w w best

/-- Removing proposal opportunity `(b,w)` records that `b` has proposed to `w`. -/
theorem im05_algorithm41HasProposedTo_removeProposal_self
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (s : DAState M W) (b : M) (w : W) :
    im05_algorithm41HasProposedTo
      {s with m_proposals := removeProposal s b w} b w := by
  simp [im05_algorithm41HasProposedTo, removeProposal]

/--
Proposal-history update law for one removed proposal opportunity.  A proposal
has occurred after removing `(b,w)` iff it had already occurred, or it is the
newly recorded proposal `(b,w)`.
-/
theorem im05_algorithm41HasProposedTo_removeProposal_iff
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (s : DAState M W) (b m : M) (w w' : W) :
    im05_algorithm41HasProposedTo
        {s with m_proposals := removeProposal s b w} m w' ↔
      im05_algorithm41HasProposedTo s m w' ∨ (m = b ∧ w' = w) := by
  classical
  by_cases hmb : m = b
  · subst m
    by_cases hww : w' = w
    · subst w'
      simp [im05_algorithm41HasProposedTo, removeProposal]
    · simp [im05_algorithm41HasProposedTo, removeProposal, hww]
  · simp [im05_algorithm41HasProposedTo, removeProposal, hmb]

/--
If Step 4(a)'s history-based accept predicate holds for proposal `(b,w)`, then
after recording that proposal, `b` is a best-so-far proposer for `w`.
-/
theorem im05_algorithm41BestProposedSoFar_after_history_accept
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_w : W → M → ℝ) (s : DAState M W) (w : W) (b : M)
    (haccept : im05_algorithm41HistoryAccepts val_w s w b) :
    im05_algorithm41BestProposedSoFar val_w
      {s with m_proposals := removeProposal s b w} w b := by
  classical
  constructor
  · exact im05_algorithm41HasProposedTo_removeProposal_self s b w
  · intro r hr
    have hcases :=
      (im05_algorithm41HasProposedTo_removeProposal_iff s b r w w).1 hr
    rcases hcases with hprior | hnew
    · exact not_lt.mp (haccept r hprior)
    · rcases hnew with ⟨hrb, _⟩
      subst r
      exact le_rfl

/--
Removing a proposal to another woman leaves the target woman's best-so-far
proposal history unchanged.
-/
theorem im05_algorithm41BestProposedSoFar_removeProposal_of_ne
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_w : W → M → ℝ) (s : DAState M W)
    {target w : W} {best b : M}
    (hne : w ≠ target)
    (hbest : im05_algorithm41BestProposedSoFar val_w s target best) :
    im05_algorithm41BestProposedSoFar val_w
      {s with m_proposals := removeProposal s b w} target best := by
  classical
  constructor
  · have hcases :=
      (im05_algorithm41HasProposedTo_removeProposal_iff s b best w target).2
        (Or.inl hbest.1)
    exact hcases
  · intro r hr
    have hcases :=
      (im05_algorithm41HasProposedTo_removeProposal_iff s b r w target).1 hr
    rcases hcases with hprior | hnew
    · exact hbest.2 r hprior
    · rcases hnew with ⟨_hrb, htarget_w⟩
      exact False.elim (hne htarget_w.symm)

/--
If the target woman rejects a new suitor under the source history rule, her
previous best-so-far proposer remains best after the rejected proposal is
recorded.
-/
theorem im05_algorithm41BestProposedSoFar_after_target_reject
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_w : W → M → ℝ) (s : DAState M W)
    (target : W) (best b : M)
    (hbest : im05_algorithm41BestProposedSoFar val_w s target best)
    (hreject : ¬ im05_algorithm41HistoryAccepts val_w s target b) :
    im05_algorithm41BestProposedSoFar val_w
      {s with m_proposals := removeProposal s b target} target best := by
  classical
  have hb_le_best : val_w target b ≤ val_w target best := by
    have hnot : ¬ ∀ r : M,
        im05_algorithm41HasProposedTo s r target →
          ¬ val_w target b < val_w target r := by
      simpa [im05_algorithm41HistoryAccepts] using hreject
    push Not at hnot
    rcases hnot with ⟨r, hr, hbr⟩
    have hr_best := hbest.2 r hr
    linarith
  constructor
  · exact
      (im05_algorithm41HasProposedTo_removeProposal_iff s b best target target).2
        (Or.inl hbest.1)
  · intro r hr
    have hcases :=
      (im05_algorithm41HasProposedTo_removeProposal_iff s b r target target).1 hr
    rcases hcases with hprior | hnew
    · exact hbest.2 r hprior
    · rcases hnew with ⟨hrb, _⟩
      subst r
      exact hb_le_best

/--
For a non-target woman, failure of the source history-acceptance test gives a
current holder who is weakly preferred to the rejected suitor, assuming the
usual target-exception rejection invariant and all-pairs acceptability.
-/
theorem im05_current_holder_ge_of_not_historyAccepts_of_invariantsExcept
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) {target w : W} {b : M}
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hreject : WomanRejectionInvariantExcept val_w s target)
    (hne : w ≠ target)
    (hnotAccept : ¬ im05_algorithm41HistoryAccepts val_w s w b) :
    ∃ current : M, s.w_match w = some current ∧
      val_w w b ≤ val_w w current := by
  classical
  have hnot : ¬ ∀ r : M,
      im05_algorithm41HasProposedTo s r w →
        ¬ val_w w b < val_w w r := by
    simpa [im05_algorithm41HistoryAccepts] using hnotAccept
  push Not at hnot
  rcases hnot with ⟨r, hr, hbr⟩
  by_cases hrmatch : s.m_match r = some w
  · exact ⟨r, (s.consistent r w).1 hrmatch, le_of_lt hbr⟩
  · rcases hreject w hne r hr hrmatch with hneg | ⟨current, hcurrent, hle⟩
    · have hbpos : 0 < val_w w b := hacceptable.2 w b
      linarith
    · exact ⟨current, hcurrent, le_trans (le_of_lt hbr) hle⟩

/--
If `best` was already best-so-far and the target-standard test accepts `b`
against `best`, then the source history test also accepts `b`.
-/
theorem im05_algorithm41HistoryAccepts_of_bestProposedSoFar_of_targetAccepts
    {M W : Type*} (val_w : W → M → ℝ) (s : DAState M W)
    (w : W) (best b : M)
    (hbest : im05_algorithm41BestProposedSoFar val_w s w best)
    (haccept : im05_algorithm41TargetAccepts val_w w (some best) b) :
    im05_algorithm41HistoryAccepts val_w s w b := by
  intro r hr hbetter
  have hr_best : val_w w r ≤ val_w w best := hbest.2 r hr
  have hbest_b : val_w w best < val_w w b := by
    simpa [im05_algorithm41TargetAccepts] using haccept
  linarith

/--
For an ordinary non-exceptional DA state, a matched woman who prefers the new
suitor to her current holder also passes the source history test.  This is the
formal reason Step 4(a)'s history comparison agrees with current-match
comparison away from the target woman.
-/
theorem im05_algorithm41HistoryAccepts_of_womanRejectionInvariant_current_lt
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_w : W → M → ℝ) (s : DAState M W)
    (w : W) (current b : M)
    (hreject : WomanRejectionInvariant val_w s)
    (hcurrent : s.w_match w = some current)
    (hb_nonneg : 0 ≤ val_w w b)
    (hcurrent_lt : val_w w current < val_w w b) :
    im05_algorithm41HistoryAccepts val_w s w b := by
  intro r hproposed hbetter
  by_cases hmatch : s.m_match r = some w
  · have hw_match : s.w_match w = some r := (s.consistent r w).1 hmatch
    have hrcurrent : r = current := by
      exact Option.some.inj (hw_match.symm.trans hcurrent)
    subst r
    linarith
  · have hrej := hreject w r hproposed hmatch
    rcases hrej with hneg | ⟨mcur, hmcur, hr_le⟩
    · linarith
    · have hmcur_current : mcur = current := by
        exact Option.some.inj (hmcur.symm.trans hcurrent)
      subst mcur
      linarith

/--
The same current-match/history bridge under the target-exception invariant,
for any woman other than the exceptional target.
-/
theorem im05_algorithm41HistoryAccepts_of_womanRejectionInvariantExcept_current_lt
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_w : W → M → ℝ) (s : DAState M W)
    (target w : W) (current b : M)
    (hne : w ≠ target)
    (hreject : WomanRejectionInvariantExcept val_w s target)
    (hcurrent : s.w_match w = some current)
    (hb_nonneg : 0 ≤ val_w w b)
    (hcurrent_lt : val_w w current < val_w w b) :
    im05_algorithm41HistoryAccepts val_w s w b := by
  intro r hproposed hbetter
  by_cases hmatch : s.m_match r = some w
  · have hw_match : s.w_match w = some r := (s.consistent r w).1 hmatch
    have hrcurrent : r = current := by
      exact Option.some.inj (hw_match.symm.trans hcurrent)
    subst r
    linarith
  · have hrej := hreject w hne r hproposed hmatch
    rcases hrej with hneg | ⟨mcur, hmcur, hr_le⟩
    · linarith
    · have hmcur_current : mcur = current := by
        exact Option.some.inj (hmcur.symm.trans hcurrent)
      subst mcur
      linarith

/--
Source Step 4(a) acceptance test for the proposal selected by the current
active-state choice functions.  This is intentionally history-based; ordinary
`daStepChosenAccepts` is only a convenient implementation shortcut when the
history invariant makes it equivalent.
-/
noncomputable def im05_algorithm41SourceStepAccepts
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (hactive : ∃ m, IsActiveMan val_m s m) : Prop :=
  im05_algorithm41HistoryAccepts val_w s
    (daStepChosenWoman val_m s hactive)
    (daStepChosenMan val_m s hactive)

/-- The target-standard predicate supplies the source chosen-step accept test. -/
theorem im05_algorithm41SourceStepAccepts_of_bestProposedSoFar_of_targetAccepts
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (hactive : ∃ m, IsActiveMan val_m s m)
    (best : M)
    (hbest :
      im05_algorithm41BestProposedSoFar val_w s
        (daStepChosenWoman val_m s hactive) best)
    (haccept :
      im05_algorithm41TargetAccepts val_w
        (daStepChosenWoman val_m s hactive) (some best)
        (daStepChosenMan val_m s hactive)) :
    im05_algorithm41SourceStepAccepts val_m val_w s hactive := by
  exact
    im05_algorithm41HistoryAccepts_of_bestProposedSoFar_of_targetAccepts
      val_w s (daStepChosenWoman val_m s hactive) best
      (daStepChosenMan val_m s hactive) hbest haccept

/--
For a non-target chosen woman, the target-exception rejection invariant lets the
ordinary current-match comparison imply the source chosen-step history test.
-/
theorem im05_algorithm41SourceStepAccepts_of_nonTarget_current_lt
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hactive : ∃ m, IsActiveMan val_m s m)
    (current : M)
    (hne : daStepChosenWoman val_m s hactive ≠ target)
    (hreject : WomanRejectionInvariantExcept val_w s target)
    (hcurrent :
      s.w_match (daStepChosenWoman val_m s hactive) = some current)
    (hb_nonneg :
      0 ≤ val_w (daStepChosenWoman val_m s hactive)
        (daStepChosenMan val_m s hactive))
    (hcurrent_lt :
      val_w (daStepChosenWoman val_m s hactive) current <
        val_w (daStepChosenWoman val_m s hactive)
          (daStepChosenMan val_m s hactive)) :
    im05_algorithm41SourceStepAccepts val_m val_w s hactive := by
  exact
    im05_algorithm41HistoryAccepts_of_womanRejectionInvariantExcept_current_lt
      val_w s target (daStepChosenWoman val_m s hactive) current
      (daStepChosenMan val_m s hactive) hne hreject hcurrent
      hb_nonneg hcurrent_lt

theorem im05_algorithm41SourceStepAccepts_iff_daStepChosenAccepts_of_invariants
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinv : DAInvariants val_m val_w s)
    (hactive : ∃ m, IsActiveMan val_m s m) :
    im05_algorithm41SourceStepAccepts val_m val_w s hactive ↔
      daStepChosenAccepts val_m val_w s hactive := by
  classical
  let b := daStepChosenMan val_m s hactive
  let w := daStepChosenWoman val_m s hactive
  have hb_active : IsActiveMan val_m s b := by
    simpa [b, daStepChosenMan] using Classical.choose_spec hactive
  rcases hinv with ⟨_hmanIR, _hwomanIR, hmatched, hwomanReject,
    _hproposalOrder⟩
  constructor
  · intro hhistory
    cases hcur : s.w_match w with
    | none =>
        simpa [daStepChosenAccepts, b, w, hcur] using
          le_of_lt (hacceptable.2 w b)
    | some cur =>
        have hcur_match : s.m_match cur = some w := (s.consistent cur w).2 hcur
        have hcur_proposed : im05_algorithm41HasProposedTo s cur w :=
          hmatched cur w hcur_match
        have hnot : ¬ val_w w b < val_w w cur :=
          hhistory cur hcur_proposed
        have hle : val_w w cur ≤ val_w w b := le_of_not_gt hnot
        have hne : cur ≠ b := by
          intro h
          subst cur
          rw [hb_active.1] at hcur_match
          cases hcur_match
        have hneq : val_w w cur ≠ val_w w b := by
          intro heq
          exact hne (hstrictW w cur b heq)
        exact by
          simpa [daStepChosenAccepts, b, w, hcur] using lt_of_le_of_ne hle hneq
  · intro hda
    cases hcur : s.w_match w with
    | none =>
        have hb_nonneg : 0 ≤ val_w w b := by
          simpa [daStepChosenAccepts, b, w, hcur] using hda
        intro r hr hbetter
        by_cases hmatch : s.m_match r = some w
        · have hw_match : s.w_match w = some r := (s.consistent r w).1 hmatch
          rw [hcur] at hw_match
          cases hw_match
        · rcases hwomanReject w r hr hmatch with hneg | ⟨cur, hcur', _hle⟩
          · linarith
          · rw [hcur] at hcur'
            cases hcur'
    | some cur =>
        have hcur_lt : val_w w cur < val_w w b := by
          simpa [daStepChosenAccepts, b, w, hcur] using hda
        exact
          im05_algorithm41HistoryAccepts_of_womanRejectionInvariant_current_lt
            val_w s w cur b hwomanReject hcur
            (le_of_lt (hacceptable.2 w b)) hcur_lt

theorem im05_algorithm41SourceStepAccepts_iff_daStepChosenAccepts_of_invariantsExceptWoman_nonTarget
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinv : DAInvariantsExceptWoman val_m val_w s target)
    (hactive : ∃ m, IsActiveMan val_m s m)
    (hnonTarget : daStepChosenWoman val_m s hactive ≠ target) :
    im05_algorithm41SourceStepAccepts val_m val_w s hactive ↔
      daStepChosenAccepts val_m val_w s hactive := by
  classical
  let b := daStepChosenMan val_m s hactive
  let w := daStepChosenWoman val_m s hactive
  have hb_active : IsActiveMan val_m s b := by
    simpa [b, daStepChosenMan] using Classical.choose_spec hactive
  have hw_ne_target : w ≠ target := by
    simpa [w] using hnonTarget
  rcases hinv with ⟨_hmanIR, _hwomanIR, hmatched, hwomanRejectExcept,
    _hproposalOrder⟩
  constructor
  · intro hhistory
    cases hcur : s.w_match w with
    | none =>
        simpa [daStepChosenAccepts, b, w, hcur] using
          le_of_lt (hacceptable.2 w b)
    | some cur =>
        have hcur_match : s.m_match cur = some w := (s.consistent cur w).2 hcur
        have hcur_proposed : im05_algorithm41HasProposedTo s cur w :=
          hmatched cur w hcur_match
        have hnot : ¬ val_w w b < val_w w cur :=
          hhistory cur hcur_proposed
        have hle : val_w w cur ≤ val_w w b := le_of_not_gt hnot
        have hne : cur ≠ b := by
          intro h
          subst cur
          rw [hb_active.1] at hcur_match
          cases hcur_match
        have hneq : val_w w cur ≠ val_w w b := by
          intro heq
          exact hne (hstrictW w cur b heq)
        exact by
          simpa [daStepChosenAccepts, b, w, hcur] using lt_of_le_of_ne hle hneq
  · intro hda
    cases hcur : s.w_match w with
    | none =>
        have hb_nonneg : 0 ≤ val_w w b := by
          simpa [daStepChosenAccepts, b, w, hcur] using hda
        intro r hr hbetter
        by_cases hmatch : s.m_match r = some w
        · have hw_match : s.w_match w = some r := (s.consistent r w).1 hmatch
          rw [hcur] at hw_match
          cases hw_match
        · rcases hwomanRejectExcept w hw_ne_target r hr hmatch with
            hneg | ⟨cur, hcur', _hle⟩
          · linarith
          · rw [hcur] at hcur'
            cases hcur'
    | some cur =>
        have hcur_lt : val_w w cur < val_w w b := by
          simpa [daStepChosenAccepts, b, w, hcur] using hda
        exact
          im05_algorithm41HistoryAccepts_of_womanRejectionInvariantExcept_current_lt
            val_w s target w cur b hw_ne_target hwomanRejectExcept hcur
            (le_of_lt (hacceptable.2 w b)) hcur_lt

/--
One source-shaped Algorithm 4.1 proposal step.  It uses the same proposer and
courted-woman selection as `daStep`, but the accept/reject branch is governed
by the paper's proposal-history comparison rather than by the woman's current
match alone.
-/
noncomputable def im05_algorithm41SourceStep
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) : DAState M W :=
  have _ : Decidable (∃ m, IsActiveMan val_m s m) := Classical.propDecidable _
  if hactive : ∃ m, IsActiveMan val_m s m then
    let m := daStepChosenMan val_m s hactive
    let hact : IsActiveMan val_m s m := by
      simpa [m, daStepChosenMan] using Classical.choose_spec hactive
    let w := daStepChosenWoman val_m s hactive
    let new_proposals := removeProposal s m w
    let m_current := s.w_match w
    have _ : Decidable (im05_algorithm41SourceStepAccepts val_m val_w s hactive) :=
      Classical.propDecidable _
    if hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive then
      let new_w_match := Function.update s.w_match w (some m)
      let new_m_match := fun m'' =>
        if m'' = m then some w
        else if m_current = some m'' then none
        else s.m_match m''
      { m_match := new_m_match
        w_match := new_w_match
        m_proposals := new_proposals
        consistent := by
          simpa [new_m_match, new_w_match, m_current] using
            acceptMatch_consistent s hact.1 }
    else
      { s with m_proposals := new_proposals }
  else
    s

/-- If no man is active, the source-shaped Algorithm 4.1 step is idle. -/
theorem im05_algorithm41SourceStep_of_not_active
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W)
    (hnot : ¬ ∃ m, IsActiveMan val_m s m) :
    im05_algorithm41SourceStep val_m val_w s = s := by
  simp [im05_algorithm41SourceStep, hnot]

theorem im05_algorithm41SourceStep_eq_daStep_of_invariants
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinv : DAInvariants val_m val_w s) :
    im05_algorithm41SourceStep val_m val_w s = daStep val_m val_w s := by
  classical
  by_cases hactive : ∃ m, IsActiveMan val_m s m
  · have hiff :=
      im05_algorithm41SourceStepAccepts_iff_daStepChosenAccepts_of_invariants
        val_m val_w s hstrictW hacceptable hinv hactive
    by_cases hsource : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · have hda : daStepChosenAccepts val_m val_w s hactive := hiff.1 hsource
      simp [daStepChosenAccepts, daStepChosenMan, daStepChosenWoman] at hda
      simp [im05_algorithm41SourceStep, daStep, hactive, hsource,
        daStepChosenMan, daStepChosenWoman, hda]
      funext m''
      rfl
    · have hda : ¬ daStepChosenAccepts val_m val_w s hactive :=
        fun h => hsource (hiff.2 h)
      simp [daStepChosenAccepts, daStepChosenMan, daStepChosenWoman] at hda
      simp [im05_algorithm41SourceStep, daStep, hactive, hsource,
        daStepChosenMan, daStepChosenWoman, hda]
  · simp [im05_algorithm41SourceStep, daStep, hactive]

theorem im05_algorithm41SourceStep_eq_daStep_of_invariantsExceptWoman_nonTarget
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (target : W)
    (hstrictW : WomenStrictPreferenceProfile val_w)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinv : DAInvariantsExceptWoman val_m val_w s target)
    (hactive : ∃ m, IsActiveMan val_m s m)
    (hnonTarget : daStepChosenWoman val_m s hactive ≠ target) :
    im05_algorithm41SourceStep val_m val_w s = daStep val_m val_w s := by
  classical
  have hiff :=
    im05_algorithm41SourceStepAccepts_iff_daStepChosenAccepts_of_invariantsExceptWoman_nonTarget
      val_m val_w s target hstrictW hacceptable hinv hactive hnonTarget
  by_cases hsource : im05_algorithm41SourceStepAccepts val_m val_w s hactive
  · have hda : daStepChosenAccepts val_m val_w s hactive := hiff.1 hsource
    simp [daStepChosenAccepts, daStepChosenMan, daStepChosenWoman] at hda
    simp [im05_algorithm41SourceStep, daStep, hactive, hsource,
      daStepChosenMan, daStepChosenWoman, hda]
    funext m''
    rfl
  · have hda : ¬ daStepChosenAccepts val_m val_w s hactive :=
      fun h => hsource (hiff.2 h)
    simp [daStepChosenAccepts, daStepChosenMan, daStepChosenWoman] at hda
    simp [im05_algorithm41SourceStep, daStep, hactive, hsource,
      daStepChosenMan, daStepChosenWoman, hda]

/-- A source-shaped active step removes the selected proposal opportunity. -/
theorem im05_algorithm41SourceStep_m_proposals_chosen
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (hactive : ∃ m, IsActiveMan val_m s m) :
    (im05_algorithm41SourceStep val_m val_w s).m_proposals
        (daStepChosenMan val_m s hactive) =
      s.m_proposals (daStepChosenMan val_m s hactive) \
        {daStepChosenWoman val_m s hactive} := by
  classical
  by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
  · simp [im05_algorithm41SourceStep, hactive, hacc, removeProposal,
      daStepChosenMan, daStepChosenWoman]
  · simp [im05_algorithm41SourceStep, hactive, hacc, removeProposal,
      daStepChosenMan, daStepChosenWoman]

/-- After a source-shaped active step, the selected proposal is in the history. -/
theorem im05_algorithm41SourceStep_records_chosen_proposal
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (hactive : ∃ m, IsActiveMan val_m s m) :
    im05_algorithm41HasProposedTo
      (im05_algorithm41SourceStep val_m val_w s)
      (daStepChosenMan val_m s hactive)
      (daStepChosenWoman val_m s hactive) := by
  rw [im05_algorithm41HasProposedTo,
    im05_algorithm41SourceStep_m_proposals_chosen]
  simp

/--
A source-shaped step only removes proposal opportunities; it never restores a
previously removed proposal.
-/
theorem im05_algorithm41SourceStep_m_proposals_subset
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (m : M) :
    (im05_algorithm41SourceStep val_m val_w s).m_proposals m ⊆
      s.m_proposals m := by
  classical
  intro w hmem
  by_cases hactive : ∃ a, IsActiveMan val_m s a
  · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · exact
        ((mem_removeProposal_iff s
          (daStepChosenMan val_m s hactive) m
          (daStepChosenWoman val_m s hactive) w).1
          (by simpa [im05_algorithm41SourceStep, hactive, hacc] using hmem)).1
    · exact
        ((mem_removeProposal_iff s
          (daStepChosenMan val_m s hactive) m
          (daStepChosenWoman val_m s hactive) w).1
          (by simpa [im05_algorithm41SourceStep, hactive, hacc] using hmem)).1
  · simpa [im05_algorithm41SourceStep, hactive] using hmem

/-- At most one man is active in a one-suitor continued-proposal trace. -/
def im05_atMostOneActiveMan
    {M W : Type*} (val_m : M → W → ℝ) (s : DAState M W) : Prop :=
  ∀ m₁ m₂ : M, IsActiveMan val_m s m₁ → IsActiveMan val_m s m₂ → m₁ = m₂

theorem im05_atMostOneActiveMan_of_not_active
    {M W : Type*} (val_m : M → W → ℝ) (s : DAState M W)
    (hnot : ¬ ∃ m, IsActiveMan val_m s m) :
    im05_atMostOneActiveMan val_m s := by
  intro m₁ _ hm₁ _
  exact False.elim (hnot ⟨m₁, hm₁⟩)

theorem im05_algorithm41SourceStep_preserves_atMostOneActiveMan
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W)
    (hatMost : im05_atMostOneActiveMan val_m s) :
    im05_atMostOneActiveMan val_m
      (im05_algorithm41SourceStep val_m val_w s) := by
  classical
  intro r₁ r₂ hr₁ hr₂
  by_cases hactive : ∃ a, IsActiveMan val_m s a
  · let chosen := daStepChosenMan val_m s hactive
    have hchosen : IsActiveMan val_m s chosen := by
      simpa [chosen, daStepChosenMan] using Classical.choose_spec hactive
    by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · let chosenW := daStepChosenWoman val_m s hactive
      have active_new_current :
          ∀ r : M,
            IsActiveMan val_m (im05_algorithm41SourceStep val_m val_w s) r →
              s.w_match chosenW = some r := by
        intro r hr
        by_cases hrchosen : r = chosen
        · subst r
          have hnone := hr.1
          simp [im05_algorithm41SourceStep, hactive, hacc, chosen] at hnone
        · by_cases hcur : s.w_match chosenW = some r
          · exact hcur
          · have hmatch_old : s.m_match r = none := by
              simpa [im05_algorithm41SourceStep, hactive, hacc, chosen,
                chosenW, hrchosen, hcur] using hr.1
            have hproposal_old :
                ∃ w ∈ s.m_proposals r, 0 ≤ val_m r w := by
              rcases hr.2 with ⟨w, hwmem, hw_nonneg⟩
              exact ⟨w,
                im05_algorithm41SourceStep_m_proposals_subset
                  val_m val_w s r hwmem,
                hw_nonneg⟩
            have hrold : IsActiveMan val_m s r :=
              ⟨hmatch_old, hproposal_old⟩
            have hrequal : r = chosen := hatMost r chosen hrold hchosen
            exact False.elim (hrchosen hrequal)
      have hcur₁ := active_new_current r₁ hr₁
      have hcur₂ := active_new_current r₂ hr₂
      exact Option.some.inj (hcur₁.symm.trans hcur₂)
    · have active_new_old :
          ∀ r : M,
            IsActiveMan val_m (im05_algorithm41SourceStep val_m val_w s) r →
              IsActiveMan val_m s r := by
        intro r hr
        refine ⟨?_, ?_⟩
        · simpa [im05_algorithm41SourceStep, hactive, hacc] using hr.1
        · rcases hr.2 with ⟨w, hwmem, hw_nonneg⟩
          exact ⟨w,
            im05_algorithm41SourceStep_m_proposals_subset
              val_m val_w s r hwmem,
            hw_nonneg⟩
      exact hatMost r₁ r₂ (active_new_old r₁ hr₁) (active_new_old r₂ hr₂)
  · have hr₁_old : IsActiveMan val_m s r₁ := by
      simpa [im05_algorithm41SourceStep, hactive] using hr₁
    have hr₂_old : IsActiveMan val_m s r₂ := by
      simpa [im05_algorithm41SourceStep, hactive] using hr₂
    exact hatMost r₁ r₂ hr₁_old hr₂_old

theorem im05_no_active_sourceStep_of_target_accept_of_atMostOneActive
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W)
    (hactive : ∃ a, IsActiveMan val_m s a)
    (hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive)
    (htarget : daStepChosenWoman val_m s hactive = target)
    (hunmatched : s.w_match target = none)
    (hatMost : im05_atMostOneActiveMan val_m s) :
    ¬ ∃ r, IsActiveMan val_m (im05_algorithm41SourceStep val_m val_w s) r := by
  classical
  intro hnew
  rcases hnew with ⟨r, hr⟩
  let chosen := daStepChosenMan val_m s hactive
  have hchosen : IsActiveMan val_m s chosen := by
    simpa [chosen, daStepChosenMan] using Classical.choose_spec hactive
  by_cases hrchosen : r = chosen
  · subst r
    have hnone := hr.1
    simp [im05_algorithm41SourceStep, hactive, hacc, htarget, chosen] at hnone
  · have hmatch_old : s.m_match r = none := by
      simpa [im05_algorithm41SourceStep, hactive, hacc, htarget,
        chosen, hrchosen, hunmatched] using hr.1
    have hproposal_old :
        ∃ w ∈ s.m_proposals r, 0 ≤ val_m r w := by
      rcases hr.2 with ⟨w, hwmem, hw_nonneg⟩
      exact ⟨w,
        im05_algorithm41SourceStep_m_proposals_subset val_m val_w s r hwmem,
        hw_nonneg⟩
    have hrold : IsActiveMan val_m s r := ⟨hmatch_old, hproposal_old⟩
    exact hrchosen (hatMost r chosen hrold hchosen)

/--
The Algorithm 4.1 source event emitted by one step: a target acceptance outputs
the accepted man before the target immediately divorces him and the proposal
process continues.
-/
noncomputable def im05_algorithm41SourceStepTargetAccepted
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W) : Option M :=
  have _ : Decidable (∃ m, IsActiveMan val_m s m) := Classical.propDecidable _
  if hactive : ∃ m, IsActiveMan val_m s m then
    have _ : Decidable (im05_algorithm41SourceStepAccepts val_m val_w s hactive) :=
      Classical.propDecidable _
    if im05_algorithm41SourceStepAccepts val_m val_w s hactive then
      if daStepChosenWoman val_m s hactive = target then
        some (daStepChosenMan val_m s hactive)
      else
        none
    else
      none
  else
    none

/--
Source-shaped Algorithm 4.1 step with the target woman's immediate divorce
after every accepted target proposal.  This wraps `im05_algorithm41SourceStep`,
which records the accepted match, and then applies the paper's Step 2 divorce
when the accepted woman is the target.
-/
noncomputable def im05_algorithm41SourceStepDivorceTarget
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W) : DAState M W :=
  have _ : Decidable (∃ m, IsActiveMan val_m s m) := Classical.propDecidable _
  if hactive : ∃ m, IsActiveMan val_m s m then
    have _ : Decidable (im05_algorithm41SourceStepAccepts val_m val_w s hactive) :=
      Classical.propDecidable _
    if im05_algorithm41SourceStepAccepts val_m val_w s hactive then
      if daStepChosenWoman val_m s hactive = target then
        divorceWomanState (im05_algorithm41SourceStep val_m val_w s) target
      else
        im05_algorithm41SourceStep val_m val_w s
    else
      im05_algorithm41SourceStep val_m val_w s
  else
    s

/--
The corrected target-divorcing source step also only removes proposal
opportunities.  The target divorce changes matches but leaves proposal
histories unchanged.
-/
theorem im05_algorithm41SourceStepDivorceTarget_m_proposals_subset
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W) (m : M) :
    (im05_algorithm41SourceStepDivorceTarget val_m val_w target s).m_proposals m ⊆
      s.m_proposals m := by
  classical
  have hsource :=
    im05_algorithm41SourceStep_m_proposals_subset val_m val_w s m
  by_cases hactive : ∃ a, IsActiveMan val_m s a
  · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · by_cases htarget : daStepChosenWoman val_m s hactive = target
      · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc,
          htarget] using hsource
      · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc,
          htarget] using hsource
    · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc]
        using hsource
  · intro w hmem
    simpa [im05_algorithm41SourceStepDivorceTarget, hactive] using hmem

theorem im05_algorithm41SourceStepDivorceTarget_removed_proposal_eq_chosen
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W) {m : M} {w : W}
    (hmem : w ∈ s.m_proposals m)
    (hnot :
      w ∉ (im05_algorithm41SourceStepDivorceTarget val_m val_w target s).m_proposals m) :
    ∃ hactive : ∃ a, IsActiveMan val_m s a,
      daStepChosenMan val_m s hactive = m ∧
        daStepChosenWoman val_m s hactive = w := by
  classical
  by_cases hactive : ∃ a, IsActiveMan val_m s a
  · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · by_cases htarget : daStepChosenWoman val_m s hactive = target
      · have hnotRemove :
            w ∉
              removeProposal s (daStepChosenMan val_m s hactive)
                (daStepChosenWoman val_m s hactive) m := by
          simpa [im05_algorithm41SourceStepDivorceTarget,
            im05_algorithm41SourceStep, hactive, hacc, htarget,
            divorceWomanState] using hnot
        rcases not_mem_of_not_mem_removeProposal s hnotRemove with
          hnotOld | hnew
        · exact False.elim (hnotOld hmem)
        · exact ⟨hactive, hnew.1.symm, hnew.2.symm⟩
      · have hnotRemove :
            w ∉
              removeProposal s (daStepChosenMan val_m s hactive)
                (daStepChosenWoman val_m s hactive) m := by
          simpa [im05_algorithm41SourceStepDivorceTarget,
            im05_algorithm41SourceStep, hactive, hacc, htarget] using hnot
        rcases not_mem_of_not_mem_removeProposal s hnotRemove with
          hnotOld | hnew
        · exact False.elim (hnotOld hmem)
        · exact ⟨hactive, hnew.1.symm, hnew.2.symm⟩
    · have hnotRemove :
          w ∉
            removeProposal s (daStepChosenMan val_m s hactive)
              (daStepChosenWoman val_m s hactive) m := by
        simpa [im05_algorithm41SourceStepDivorceTarget,
          im05_algorithm41SourceStep, hactive, hacc] using hnot
      rcases not_mem_of_not_mem_removeProposal s hnotRemove with
        hnotOld | hnew
      · exact False.elim (hnotOld hmem)
      · exact ⟨hactive, hnew.1.symm, hnew.2.symm⟩
  · exact False.elim (hnot (by
      simpa [im05_algorithm41SourceStepDivorceTarget, hactive] using hmem))

theorem im05_divorceWomanState_atMostOneActiveMan_of_not_active
    {M W : Type*} [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (s : DAState M W) (target : W)
    (hnot : ¬ ∃ m, IsActiveMan val_m s m) :
    im05_atMostOneActiveMan val_m (divorceWomanState s target) := by
  intro m₁ m₂ hm₁ hm₂
  have htarget₁ : s.w_match target = some m₁ := by
    by_contra hne
    have hmatch_old : s.m_match m₁ = none := by
      simpa [divorceWomanState, hne] using hm₁.1
    have hproposal_old : ∃ w ∈ s.m_proposals m₁, 0 ≤ val_m m₁ w := by
      simpa [divorceWomanState] using hm₁.2
    exact hnot ⟨m₁, hmatch_old, hproposal_old⟩
  have htarget₂ : s.w_match target = some m₂ := by
    by_contra hne
    have hmatch_old : s.m_match m₂ = none := by
      simpa [divorceWomanState, hne] using hm₂.1
    have hproposal_old : ∃ w ∈ s.m_proposals m₂, 0 ≤ val_m m₂ w := by
      simpa [divorceWomanState] using hm₂.2
    exact hnot ⟨m₂, hmatch_old, hproposal_old⟩
  exact Option.some.inj (htarget₁.symm.trans htarget₂)

theorem im05_algorithm41SourceStepDivorceTarget_preserves_atMostOneActiveMan_of_target_unmatched
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W)
    (hunmatched : s.w_match target = none)
    (hatMost : im05_atMostOneActiveMan val_m s) :
    im05_atMostOneActiveMan val_m
      (im05_algorithm41SourceStepDivorceTarget val_m val_w target s) := by
  classical
  by_cases hactive : ∃ a, IsActiveMan val_m s a
  · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · by_cases htarget : daStepChosenWoman val_m s hactive = target
      · have hno_source :
            ¬ ∃ r, IsActiveMan val_m
              (im05_algorithm41SourceStep val_m val_w s) r :=
          im05_no_active_sourceStep_of_target_accept_of_atMostOneActive
            val_m val_w target s hactive hacc htarget hunmatched hatMost
        simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc, htarget]
          using
            im05_divorceWomanState_atMostOneActiveMan_of_not_active
              val_m (im05_algorithm41SourceStep val_m val_w s) target
              hno_source
      · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc, htarget]
          using
            im05_algorithm41SourceStep_preserves_atMostOneActiveMan
              val_m val_w s hatMost
    · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc]
        using
          im05_algorithm41SourceStep_preserves_atMostOneActiveMan
            val_m val_w s hatMost
  · simpa [im05_algorithm41SourceStepDivorceTarget, hactive] using hatMost

/--
Unpack a corrected Algorithm 4.1 target-acceptance output event into the active
proposal and source-history acceptance facts that produced it.
-/
theorem im05_algorithm41SourceStepTargetAccepted_eq_some_imp
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W) {m : M}
    (h :
      im05_algorithm41SourceStepTargetAccepted val_m val_w target s = some m) :
    ∃ hactive : ∃ a, IsActiveMan val_m s a,
      im05_algorithm41SourceStepAccepts val_m val_w s hactive ∧
        daStepChosenWoman val_m s hactive = target ∧
          daStepChosenMan val_m s hactive = m := by
  classical
  unfold im05_algorithm41SourceStepTargetAccepted at h
  by_cases hactive : ∃ a, IsActiveMan val_m s a
  · simp [hactive] at h
    by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · simp [hacc] at h
      by_cases htarget : daStepChosenWoman val_m s hactive = target
      · simp [htarget] at h
        exact ⟨hactive, hacc, htarget, h⟩
      · simp [htarget] at h
    · simp [hacc] at h
  · simp [hactive] at h

/-- A target-acceptance output event satisfies the source history accept test. -/
theorem im05_algorithm41SourceStepTargetAccepted_historyAccepts
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W) {m : M}
    (h :
      im05_algorithm41SourceStepTargetAccepted val_m val_w target s = some m) :
    im05_algorithm41HistoryAccepts val_w s target m := by
  rcases im05_algorithm41SourceStepTargetAccepted_eq_some_imp
      val_m val_w target s h with
    ⟨hactive, hacc, htarget, hm⟩
  subst m
  simpa [im05_algorithm41SourceStepAccepts, htarget] using hacc

/-- A target-acceptance output event used an available proposal to the target. -/
theorem im05_algorithm41SourceStepTargetAccepted_target_mem_proposals
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W) {m : M}
    (h :
      im05_algorithm41SourceStepTargetAccepted val_m val_w target s = some m) :
    target ∈ s.m_proposals m := by
  rcases im05_algorithm41SourceStepTargetAccepted_eq_some_imp
      val_m val_w target s h with
    ⟨hactive, _hacc, htarget, hm⟩
  subst m
  let chosenM := daStepChosenMan val_m s hactive
  have hact : IsActiveMan val_m s chosenM := by
    simpa [chosenM, daStepChosenMan] using Classical.choose_spec hactive
  have hwbest :
      BestRemainingWoman val_m s chosenM
        (daStepChosenWoman val_m s hactive) := by
    simpa [chosenM, daStepChosenWoman, daStepChosenMan, hact] using
      Classical.choose_spec (exists_best_woman val_m s chosenM hact)
  simpa [chosenM, htarget] using hwbest.1

/--
Immediately after a target-acceptance output event, the accepted man no longer
has the target available in his proposal set.
-/
theorem im05_algorithm41SourceStepTargetAccepted_target_not_mem_after_step
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W) {m : M}
    (h :
      im05_algorithm41SourceStepTargetAccepted val_m val_w target s = some m) :
    target ∉
      (im05_algorithm41SourceStepDivorceTarget val_m val_w target s).m_proposals m := by
  rcases im05_algorithm41SourceStepTargetAccepted_eq_some_imp
      val_m val_w target s h with
    ⟨hactive, hacc, htarget, hm⟩
  subst m
  simp [im05_algorithm41SourceStepDivorceTarget, im05_algorithm41SourceStep,
    hactive, hacc, htarget, removeProposal]

/-- Divorcing a woman does not change the remaining proposal count. -/
theorem remainingProposalCount_divorceWomanState
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (s : DAState M W) (target : W) :
    remainingProposalCount (divorceWomanState s target) =
      remainingProposalCount s := by
  simp [remainingProposalCount, divorceWomanState]

/-- If no man is active, the target-divorcing source step is idle. -/
theorem im05_algorithm41SourceStepDivorceTarget_of_not_active
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W)
    (hnot : ¬ ∃ m, IsActiveMan val_m s m) :
    im05_algorithm41SourceStepDivorceTarget val_m val_w target s = s := by
  simp [im05_algorithm41SourceStepDivorceTarget, hnot]

/--
After a corrected source step, the target remains unmatched if she was
unmatched before the step.  Target acceptances are immediately followed by the
paper's Step 2 divorce; non-target acceptances do not update the target match.
-/
theorem im05_algorithm41SourceStepDivorceTarget_w_match_target_none_of_none
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W)
    (hunmatched : s.w_match target = none) :
    (im05_algorithm41SourceStepDivorceTarget val_m val_w target s).w_match
      target = none := by
  classical
  by_cases hactive : ∃ m, IsActiveMan val_m s m
  · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · by_cases htarget : daStepChosenWoman val_m s hactive = target
      · simp [im05_algorithm41SourceStepDivorceTarget, hactive, hacc, htarget]
      · have htarget' : target ≠ daStepChosenWoman val_m s hactive := by
          intro h
          exact htarget h.symm
        simp [im05_algorithm41SourceStepDivorceTarget, im05_algorithm41SourceStep,
          hactive, hacc, htarget, htarget', Function.update, hunmatched]
    · simp [im05_algorithm41SourceStepDivorceTarget, im05_algorithm41SourceStep,
        hactive, hacc, hunmatched]
  · simp [im05_algorithm41SourceStepDivorceTarget, hactive, hunmatched]

/-- A source-shaped active step consumes exactly one proposal opportunity. -/
theorem im05_remainingProposalCount_sourceStep_add_one_of_active
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (s : DAState M W) (hactive : ∃ m, IsActiveMan val_m s m) :
    remainingProposalCount (im05_algorithm41SourceStep val_m val_w s) + 1 =
      remainingProposalCount s := by
  classical
  let m := daStepChosenMan val_m s hactive
  have hact : IsActiveMan val_m s m := by
    simpa [m, daStepChosenMan] using Classical.choose_spec hactive
  have hwbest :
      BestRemainingWoman val_m s m (daStepChosenWoman val_m s hactive) := by
    simpa [daStepChosenWoman, daStepChosenMan, m, hact] using
      Classical.choose_spec (exists_best_woman val_m s m hact)
  have hremove := remainingProposalCount_removeProposal_add_one
    (s := s) (m := m) (w := daStepChosenWoman val_m s hactive) hwbest.1
  by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
  · simpa [im05_algorithm41SourceStep, hactive, hacc, remainingProposalCount,
      daStepChosenMan, m] using hremove
  · simpa [im05_algorithm41SourceStep, hactive, hacc, remainingProposalCount,
      daStepChosenMan, m] using hremove

/--
An active target-divorcing source step consumes exactly one proposal
opportunity; the immediate target divorce does not affect proposal histories.
-/
theorem im05_remainingProposalCount_sourceStepDivorceTarget_add_one_of_active
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (s : DAState M W)
    (hactive : ∃ m, IsActiveMan val_m s m) :
    remainingProposalCount
        (im05_algorithm41SourceStepDivorceTarget val_m val_w target s) + 1 =
      remainingProposalCount s := by
  classical
  have hsource :=
    im05_remainingProposalCount_sourceStep_add_one_of_active
      val_m val_w s hactive
  by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
  · by_cases htarget : daStepChosenWoman val_m s hactive = target
    · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc, htarget,
        remainingProposalCount_divorceWomanState] using hsource
    · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc, htarget]
        using hsource
  · simpa [im05_algorithm41SourceStepDivorceTarget, hactive, hacc] using hsource

/-- Run the source-shaped Algorithm 4.1 step from an arbitrary starting state. -/
noncomputable def im05_algorithm41SourceStateAfterStepsFrom
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (start : DAState M W) (steps : ℕ) : DAState M W :=
  (List.range steps).foldl
    (fun s _ => im05_algorithm41SourceStep val_m val_w s) start

/--
Run the target-divorcing source-shaped Algorithm 4.1 step from an arbitrary
starting state.
-/
noncomputable def im05_algorithm41SourceDivorceTargetStateAfterStepsFrom
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (start : DAState M W) (steps : ℕ) : DAState M W :=
  (List.range steps).foldl
    (fun s _ => im05_algorithm41SourceStepDivorceTarget val_m val_w target s)
    start

/-- Once no man is active, further source-shaped steps leave the state fixed. -/
theorem im05_foldl_sourceStep_eq_self_of_not_active
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (steps : List ℕ) (s : DAState M W)
    (hnot : ¬ ∃ m, IsActiveMan val_m s m) :
    steps.foldl (fun s _ => im05_algorithm41SourceStep val_m val_w s) s = s := by
  induction steps generalizing s with
  | nil =>
      rfl
  | cons _ steps ih =>
      rw [List.foldl_cons,
        im05_algorithm41SourceStep_of_not_active val_m val_w s hnot]
      exact ih s hnot

/--
Once no man is active, further target-divorcing source-shaped steps leave the
state fixed.
-/
theorem im05_foldl_sourceStepDivorceTarget_eq_self_of_not_active
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (steps : List ℕ) (s : DAState M W)
    (hnot : ¬ ∃ m, IsActiveMan val_m s m) :
    steps.foldl
        (fun s _ => im05_algorithm41SourceStepDivorceTarget val_m val_w target s)
        s = s := by
  induction steps generalizing s with
  | nil =>
      rfl
  | cons _ steps ih =>
      rw [List.foldl_cons,
        im05_algorithm41SourceStepDivorceTarget_of_not_active
          val_m val_w target s hnot]
      exact ih s hnot

/--
If the number of remaining proposal opportunities is bounded by the number of
source-shaped steps left, then after those steps no man is active.
-/
theorem im05_no_active_after_sourceSteps_of_count_le_length
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (steps : List ℕ) (s : DAState M W)
    (hcount : remainingProposalCount s ≤ steps.length) :
    ¬ ∃ m, IsActiveMan val_m
      (steps.foldl
        (fun s _ => im05_algorithm41SourceStep val_m val_w s) s) m := by
  induction steps generalizing s with
  | nil =>
      intro hactive
      have hpos := remainingProposalCount_pos_of_active val_m s hactive
      simp at hcount
      linarith
  | cons _ steps ih =>
      by_cases hactive : ∃ m, IsActiveMan val_m s m
      · have hstep_count :=
          im05_remainingProposalCount_sourceStep_add_one_of_active
            val_m val_w s hactive
        have hcount_step :
            remainingProposalCount
                (im05_algorithm41SourceStep val_m val_w s) ≤
              steps.length := by
          have hsucc :
              remainingProposalCount
                    (im05_algorithm41SourceStep val_m val_w s) + 1 ≤
                steps.length + 1 := by
            simpa [hstep_count] using hcount
          exact Nat.succ_le_succ_iff.mp hsucc
        simpa [List.foldl_cons] using
          ih (im05_algorithm41SourceStep val_m val_w s) hcount_step
      · rw [List.foldl_cons,
          im05_algorithm41SourceStep_of_not_active val_m val_w s hactive]
        simpa [im05_foldl_sourceStep_eq_self_of_not_active
          val_m val_w steps s hactive] using hactive

/--
If the number of remaining proposal opportunities is bounded by the number of
target-divorcing source-shaped steps left, then after those steps no man is
active.
-/
theorem im05_no_active_after_sourceDivorceTargetSteps_of_count_le_length
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (steps : List ℕ) (s : DAState M W)
    (hcount : remainingProposalCount s ≤ steps.length) :
    ¬ ∃ m, IsActiveMan val_m
      (steps.foldl
        (fun s _ => im05_algorithm41SourceStepDivorceTarget val_m val_w target s)
        s) m := by
  induction steps generalizing s with
  | nil =>
      intro hactive
      have hpos := remainingProposalCount_pos_of_active val_m s hactive
      simp at hcount
      linarith
  | cons _ steps ih =>
      by_cases hactive : ∃ m, IsActiveMan val_m s m
      · have hstep_count :=
          im05_remainingProposalCount_sourceStepDivorceTarget_add_one_of_active
            val_m val_w target s hactive
        have hcount_step :
            remainingProposalCount
                (im05_algorithm41SourceStepDivorceTarget val_m val_w target s) ≤
              steps.length := by
          have hsucc :
              remainingProposalCount
                    (im05_algorithm41SourceStepDivorceTarget val_m val_w target s) + 1 ≤
                steps.length + 1 := by
            simpa [hstep_count] using hcount
          exact Nat.succ_le_succ_iff.mp hsucc
        simpa [List.foldl_cons] using
          ih (im05_algorithm41SourceStepDivorceTarget val_m val_w target s)
            hcount_step
      · rw [List.foldl_cons,
          im05_algorithm41SourceStepDivorceTarget_of_not_active
            val_m val_w target s hactive]
        simpa [im05_foldl_sourceStepDivorceTarget_eq_self_of_not_active
          val_m val_w target steps s hactive] using hactive

/-- Source-shaped runs terminate within the remaining-proposal-count bound. -/
theorem im05_no_active_sourceStateAfterStepsFrom_of_remainingProposalCount_le
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (start : DAState M W) {steps : ℕ}
    (hcount : remainingProposalCount start ≤ steps) :
    ¬ ∃ m, IsActiveMan val_m
      (im05_algorithm41SourceStateAfterStepsFrom val_m val_w start steps) m := by
  unfold im05_algorithm41SourceStateAfterStepsFrom
  exact im05_no_active_after_sourceSteps_of_count_le_length
    val_m val_w (List.range steps) start (by simpa using hcount)

/--
Target-divorcing source-shaped runs terminate within the remaining-proposal-count
bound.
-/
theorem im05_no_active_sourceDivorceTargetStateAfterStepsFrom_of_remainingProposalCount_le
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (start : DAState M W) {steps : ℕ}
    (hcount : remainingProposalCount start ≤ steps) :
    ¬ ∃ m, IsActiveMan val_m
      (im05_algorithm41SourceDivorceTargetStateAfterStepsFrom
        val_m val_w target start steps) m := by
  unfold im05_algorithm41SourceDivorceTargetStateAfterStepsFrom
  exact im05_no_active_after_sourceDivorceTargetSteps_of_count_le_length
    val_m val_w target (List.range steps) start (by simpa using hcount)

/-- Source-shaped runs terminate within `#men * #women` proposal steps. -/
theorem im05_no_active_sourceStateAfterStepsFrom_card_mul
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (start : DAState M W) :
    ¬ ∃ m, IsActiveMan val_m
      (im05_algorithm41SourceStateAfterStepsFrom val_m val_w start
        (Fintype.card M * Fintype.card W)) m :=
  im05_no_active_sourceStateAfterStepsFrom_of_remainingProposalCount_le
    val_m val_w start (remainingProposalCount_le_card_mul start)

/--
Target-divorcing source-shaped runs terminate within `#men * #women` proposal
steps.
-/
theorem im05_no_active_sourceDivorceTargetStateAfterStepsFrom_card_mul
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ)
    (target : W) (start : DAState M W) :
    ¬ ∃ m, IsActiveMan val_m
      (im05_algorithm41SourceDivorceTargetStateAfterStepsFrom
        val_m val_w target start (Fintype.card M * Fintype.card W)) m :=
  im05_no_active_sourceDivorceTargetStateAfterStepsFrom_of_remainingProposalCount_le
    val_m val_w target start (remainingProposalCount_le_card_mul start)

/-- A source-shaped step preserves men's individual rationality. -/
theorem im05_algorithm41SourceStep_preserves_manIRInvariant
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (s : DAState M W)
    (hinv : ManIRInvariant val_m s) :
    ManIRInvariant val_m (im05_algorithm41SourceStep val_m val_w s) := by
  classical
  by_cases hactive : ∃ m, IsActiveMan val_m s m
  · let m := daStepChosenMan val_m s hactive
    have hact : IsActiveMan val_m s m := by
      simpa [m, daStepChosenMan] using Classical.choose_spec hactive
    have hwbest :
        BestRemainingWoman val_m s (daStepChosenMan val_m s hactive)
          (daStepChosenWoman val_m s hactive) := by
      simpa [daStepChosenWoman, daStepChosenMan, m, hact] using
        Classical.choose_spec (exists_best_woman val_m s m hact)
    by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · intro m0 w0 hmatch
      by_cases hm0 : m0 = daStepChosenMan val_m s hactive
      · subst m0
        simp [im05_algorithm41SourceStep, hactive, hacc] at hmatch
        subst w0
        exact hwbest.2.1
      · by_cases hcur :
          s.w_match (daStepChosenWoman val_m s hactive) = some m0
        · simp [im05_algorithm41SourceStep, hactive, hacc, hm0, hcur] at hmatch
        · have hold : s.m_match m0 = some w0 := by
            simpa [im05_algorithm41SourceStep, hactive, hacc, hm0, hcur] using
              hmatch
          exact hinv m0 w0 hold
    · intro m0 w0 hmatch
      exact hinv m0 w0
        (by simpa [im05_algorithm41SourceStep, hactive, hacc] using hmatch)
  · simpa [im05_algorithm41SourceStep, hactive] using hinv

/--
On an all-acceptable marriage domain, a source-shaped step preserves women's
individual rationality.
-/
theorem im05_algorithm41SourceStep_preserves_womanIRInvariant_of_allPairsAcceptable
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (s : DAState M W)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinv : WomanIRInvariant val_w s) :
    WomanIRInvariant val_w (im05_algorithm41SourceStep val_m val_w s) := by
  classical
  by_cases hactive : ∃ m, IsActiveMan val_m s m
  · by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · intro w0 m0 hmatch
      by_cases hw0 : w0 = daStepChosenWoman val_m s hactive
      · subst w0
        simp [im05_algorithm41SourceStep, hactive, hacc] at hmatch
        subst m0
        exact le_of_lt (hacceptable.2
          (daStepChosenWoman val_m s hactive)
          (daStepChosenMan val_m s hactive))
      · have hold : s.w_match w0 = some m0 := by
          simpa [im05_algorithm41SourceStep, hactive, hacc, Function.update,
            hw0] using hmatch
        exact hinv w0 m0 hold
    · intro w0 m0 hmatch
      exact hinv w0 m0
        (by simpa [im05_algorithm41SourceStep, hactive, hacc] using hmatch)
  · simpa [im05_algorithm41SourceStep, hactive] using hinv

/--
On an all-acceptable marriage domain, a source-shaped step preserves the
non-target woman rejection invariant.  This is the main deterministic
compatibility fact between the paper's target-history rule and the ordinary DA
invariant package away from the target woman.
-/
theorem im05_algorithm41SourceStep_preserves_womanRejectionInvariantExcept_of_allPairsAcceptable
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (s : DAState M W)
    (target : W)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hmatched : MatchedProposedInvariant s)
    (hrejectInv : WomanRejectionInvariantExcept val_w s target) :
    WomanRejectionInvariantExcept val_w
      (im05_algorithm41SourceStep val_m val_w s) target := by
  classical
  by_cases hactive : ∃ m, IsActiveMan val_m s m
  · let chosenM := daStepChosenMan val_m s hactive
    let chosenW := daStepChosenWoman val_m s hactive
    have hact : IsActiveMan val_m s chosenM := by
      simpa [chosenM, daStepChosenMan] using Classical.choose_spec hactive
    by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · have hhistory :
          im05_algorithm41HistoryAccepts val_w s chosenW chosenM := by
        simpa [im05_algorithm41SourceStepAccepts, chosenM, chosenW] using hacc
      intro w0 hw0_ne_target m0 hnotNew hnotMatchedNew
      have hnotRemove : w0 ∉ removeProposal s chosenM chosenW m0 := by
        simpa [im05_algorithm41SourceStep, hactive, hacc, chosenM, chosenW] using
          hnotNew
      rcases not_mem_of_not_mem_removeProposal s hnotRemove with hnotOld | hnew
      · by_cases holdMatch : s.m_match m0 = some w0
        · have hm0_ne_chosen : m0 ≠ chosenM := by
            intro hm0
            subst m0
            rw [hact.1] at holdMatch
            cases holdMatch
          by_cases hcur : s.w_match chosenW = some m0
          · have holdW : s.m_match m0 = some chosenW :=
              (s.consistent m0 chosenW).2 hcur
            have hw0_eq : w0 = chosenW :=
              Option.some.inj (holdMatch.symm.trans holdW)
            subst w0
            by_cases hchosen_target : chosenW = target
            · exact False.elim (hw0_ne_target hchosen_target)
            · right
              refine ⟨chosenM, ?_, ?_⟩
              · simp [im05_algorithm41SourceStep, hactive, hacc, chosenM, chosenW]
              · have hcurrent_proposed :
                    im05_algorithm41HasProposedTo s m0 chosenW :=
                  hmatched m0 chosenW holdW
                exact not_lt.mp (hhistory m0 hcurrent_proposed)
          · exfalso
            exact hnotMatchedNew (by
              simpa [im05_algorithm41SourceStep, hactive, hacc, chosenM,
                chosenW, hm0_ne_chosen, hcur] using holdMatch)
        · rcases hrejectInv w0 hw0_ne_target m0 hnotOld holdMatch with
            hneg | ⟨oldcur, hwold, hleOld⟩
          · exact Or.inl hneg
          · by_cases hw0_chosen : w0 = chosenW
            · subst w0
              by_cases hchosen_target : chosenW = target
              · exact False.elim (hw0_ne_target hchosen_target)
              · right
                refine ⟨chosenM, ?_, ?_⟩
                · simp [im05_algorithm41SourceStep, hactive, hacc, chosenM, chosenW]
                · have holdcur : s.m_match oldcur = some chosenW :=
                    (s.consistent oldcur chosenW).2 hwold
                  have hcurrent_proposed :
                      im05_algorithm41HasProposedTo s oldcur chosenW :=
                    hmatched oldcur chosenW holdcur
                  have hcur_le_new :=
                    not_lt.mp (hhistory oldcur hcurrent_proposed)
                  exact le_trans hleOld hcur_le_new
            · right
              refine ⟨oldcur, ?_, hleOld⟩
              simpa [im05_algorithm41SourceStep, hactive, hacc, Function.update,
                chosenM, chosenW, hw0_chosen] using hwold
      · rcases hnew with ⟨hm0, hw0⟩
        subst m0
        subst w0
        exfalso
        exact hnotMatchedNew (by
          simp [im05_algorithm41SourceStep, hactive, hacc, chosenM, chosenW])
    · intro w0 hw0_ne_target m0 hnotNew hnotMatchedNew
      have hnotRemove : w0 ∉ removeProposal s chosenM chosenW m0 := by
        simpa [im05_algorithm41SourceStep, hactive, hacc, chosenM, chosenW] using
          hnotNew
      rcases not_mem_of_not_mem_removeProposal s hnotRemove with hnotOld | hnew
      · have hnotMatchedOld : s.m_match m0 ≠ some w0 := by
          intro hold
          exact hnotMatchedNew (by
            simpa [im05_algorithm41SourceStep, hactive, hacc, chosenM, chosenW]
              using hold)
        rcases hrejectInv w0 hw0_ne_target m0 hnotOld hnotMatchedOld with
          hneg | ⟨current, hcurrent, hle⟩
        · exact Or.inl hneg
        · right
          refine ⟨current, ?_, hle⟩
          simpa [im05_algorithm41SourceStep, hactive, hacc, chosenM, chosenW]
            using hcurrent
      · rcases hnew with ⟨hm0, hw0⟩
        subst m0
        subst w0
        by_cases hchosen_target : chosenW = target
        · exact False.elim (hw0_ne_target hchosen_target)
        · have hnotAccept :
              ¬ im05_algorithm41HistoryAccepts val_w s chosenW chosenM := by
            simpa [im05_algorithm41SourceStepAccepts, chosenM, chosenW] using hacc
          rcases
              im05_current_holder_ge_of_not_historyAccepts_of_invariantsExcept
                val_m val_w s (target := target) (w := chosenW)
                (b := chosenM) hacceptable hrejectInv hchosen_target hnotAccept with
            ⟨current, hcurrent, hle⟩
          right
          refine ⟨current, ?_, hle⟩
          simpa [im05_algorithm41SourceStep, hactive, hacc, chosenM, chosenW]
            using hcurrent
  · simpa [im05_algorithm41SourceStep, hactive] using hrejectInv

/-- A source-shaped step preserves the fact that matched men have proposed. -/
theorem im05_algorithm41SourceStep_preserves_matchedProposedInvariant
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (s : DAState M W)
    (hinv : MatchedProposedInvariant s) :
    MatchedProposedInvariant (im05_algorithm41SourceStep val_m val_w s) := by
  classical
  by_cases hactive : ∃ m, IsActiveMan val_m s m
  · let m := daStepChosenMan val_m s hactive
    have hact : IsActiveMan val_m s m := by
      simpa [m, daStepChosenMan] using Classical.choose_spec hactive
    by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · intro m0 w0 hmatch
      by_cases hm0 : m0 = daStepChosenMan val_m s hactive
      · subst m0
        simp [im05_algorithm41SourceStep, hactive, hacc] at hmatch
        subst w0
        simp [im05_algorithm41SourceStep, hactive, hacc, removeProposal]
      · by_cases hcur :
          s.w_match (daStepChosenWoman val_m s hactive) = some m0
        · simp [im05_algorithm41SourceStep, hactive, hacc, hm0, hcur] at hmatch
        · have hold : s.m_match m0 = some w0 := by
            simpa [im05_algorithm41SourceStep, hactive, hacc, hm0, hcur] using
              hmatch
          simpa [im05_algorithm41SourceStep, hactive, hacc, removeProposal, hm0]
            using hinv m0 w0 hold
    · intro m0 w0 hmatch
      by_cases hm0 : m0 = daStepChosenMan val_m s hactive
      · subst m0
        have hold :
            s.m_match (daStepChosenMan val_m s hactive) = some w0 := by
          simpa [im05_algorithm41SourceStep, hactive, hacc] using hmatch
        rw [hact.1] at hold
        cases hold
      · have hold : s.m_match m0 = some w0 := by
          simpa [im05_algorithm41SourceStep, hactive, hacc] using hmatch
        simpa [im05_algorithm41SourceStep, hactive, hacc, removeProposal, hm0]
          using hinv m0 w0 hold
  · simpa [im05_algorithm41SourceStep, hactive] using hinv

/-- A source-shaped step preserves men's proposal-order invariant. -/
theorem im05_algorithm41SourceStep_preserves_manProposalOrderInvariant
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (s : DAState M W)
    (hinv : ManProposalOrderInvariant val_m s) :
    ManProposalOrderInvariant val_m
      (im05_algorithm41SourceStep val_m val_w s) := by
  classical
  by_cases hactive : ∃ m, IsActiveMan val_m s m
  · let m := daStepChosenMan val_m s hactive
    have hact : IsActiveMan val_m s m := by
      simpa [m, daStepChosenMan] using Classical.choose_spec hactive
    have hwbest :
        BestRemainingWoman val_m s (daStepChosenMan val_m s hactive)
          (daStepChosenWoman val_m s hactive) := by
      simpa [daStepChosenWoman, daStepChosenMan, m, hact] using
        Classical.choose_spec (exists_best_woman val_m s m hact)
    have hremove :
        ManProposalOrderInvariant val_m
          {s with
            m_proposals := removeProposal s
              (daStepChosenMan val_m s hactive)
              (daStepChosenWoman val_m s hactive)} :=
      manProposalOrder_removeProposal val_m s hwbest hinv
    by_cases hacc : im05_algorithm41SourceStepAccepts val_m val_w s hactive
    · simpa [im05_algorithm41SourceStep, hactive, hacc] using hremove
    · simpa [im05_algorithm41SourceStep, hactive, hacc] using hremove
  · simpa [im05_algorithm41SourceStep, hactive] using hinv

/--
On an all-acceptable marriage domain, one source-shaped Algorithm 4.1 step
preserves the full target-exception DA invariant package.
-/
theorem im05_algorithm41SourceStep_preserves_invariantsExceptWoman_of_allPairsAcceptable
    {M W : Type*} [Fintype M] [Fintype W] [DecidableEq M] [DecidableEq W]
    (val_m : M → W → ℝ) (val_w : W → M → ℝ) (s : DAState M W)
    (target : W)
    (hacceptable : AllPairsAcceptable val_m val_w)
    (hinv : DAInvariantsExceptWoman val_m val_w s target) :
    DAInvariantsExceptWoman val_m val_w
      (im05_algorithm41SourceStep val_m val_w s) target := by
  rcases hinv with ⟨hmanIR, hwomanIR, hmatched, hwomanReject, hproposalOrder⟩
  exact
    ⟨im05_algorithm41SourceStep_preserves_manIRInvariant
        val_m val_w s hmanIR,
      im05_algorithm41SourceStep_preserves_womanIRInvariant_of_allPairsAcceptable
        val_m val_w s hacceptable hwomanIR,
      im05_algorithm41SourceStep_preserves_matchedProposedInvariant
        val_m val_w s hmatched,
      im05_algorithm41SourceStep_preserves_womanRejectionInvariantExcept_of_allPairsAcceptable
        val_m val_w s target hacceptable hmatched hwomanReject,
      im05_algorithm41SourceStep_preserves_manProposalOrderInvariant
        val_m val_w s hproposalOrder⟩

