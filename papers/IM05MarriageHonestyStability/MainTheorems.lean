        EconCSLib.pmfExp μ
          (fun ω =>
            (((Finset.univ : Finset I).filter fun i => event i ω).card : ℝ)))
    (hXY : ∀ ω,
      ((Finset.univ : Finset I).filter fun i => event i ω).card ≤ X ω)
    (hneg : ∀ i j : I, i ≠ j →
      EconCSLib.pmfProb μ (fun ω => event i ω ∧ event j ω) ≤
        EconCSLib.pmfProb μ (fun ω => event i ω) *
          EconCSLib.pmfProb μ (fun ω => event j ω)) :
    im05_reciprocalCountExpectation μ X ≤
      12 * Real.exp (8 * (n : ℝ) * (k : ℝ) / (g : ℝ)) / (g : ℝ) := by
  classical
