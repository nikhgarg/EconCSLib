      simpa [one_mul] using
        mul_le_mul_of_nonneg_right hcoef_ge_one hoptMax
    have hdiv_nonneg : 0 ≤ L / (56 / epsilon) := by
      positivity
    nlinarith
  have hmin :
      optMin - L / (56 / epsilon) ≤ optMin := by
    have hdiv_nonneg : 0 ≤ L / (56 / epsilon) := by
      positivity
    nlinarith
  simpa [optMin, optMax, optLoad] using
    paper_lmms_theorem_3_3_value_pair_forward_ratio_transfer_epsilon
      (SourceAgent := SourceAgent) (SourceItem := SourceItem)
      (L := L) (epsilon := epsilon)
      (p := (optMin, optMax)) (optimal := optimal)
