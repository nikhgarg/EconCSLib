      _ ≤
          (paper_lmms_theorem_3_3_capCountForAverage
              L (L + extraAverage) lambda + 1 : ℝ) *
            (L / (lambda : ℝ)) := hcap_upper
  intro indexOf combinedSupply hindex hsupply _htop_zero _hsupply_average
  rcases allocationProvider indexOf hindex with ⟨A, hA_alloc, hA_window⟩
  let typedValue :
      paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
        (L := L) (lambda := lambda) highGoods lowGoods v → ℝ :=
    paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue
      (L := L) (lambda := lambda)
      (highGoods := highGoods) (lowGoods := lowGoods)
      (sourceValue := v) indexOf
  let p : ℝ × ℝ :=
    (Theorem34.minCommonLoad typedValue A,
      Theorem34.maxCommonLoad typedValue A)
  let typedCert :=
    paper_lmms_theorem_3_3_concrete_ip_certificate_with_cap_of_exact_bounded_typed_combined_high_low_allocation
      (L := L) (LR := LR) (lambda := lambda)
      (maxCount :=
        paper_lmms_theorem_3_3_capCountForAverage
          L (L + extraAverage) lambda)
      (SourceAgent := SourceAgent)
      highGoods lowGoods v indexOf A hA_alloc hlambda hL hcap
      (by
        intro i
        simpa [typedValue] using hA_window i)
  refine ⟨p, ⟨?_⟩⟩
  exact
    { pair_mem := by
        simpa [p, typedValue] using typedCert.pair_mem
      typeMultiplicity := typedCert.typeMultiplicity
      zeroOutsideWindow := by
        intro t ht
        exact typedCert.zeroOutsideWindow t (by
          simpa [p, typedValue] using ht)
      allPlayersAssigned := by
        simpa [p, typedValue] using typedCert.allPlayersAssigned
      allGoodsAssigned := by
        intro k
        rw [hsupply k]
        simpa [p, typedValue] using typedCert.allGoodsAssigned k }

/--
The source high/low split gives the paper's aggregate rounding-error budget:
high goods contribute at most one `L / lambda^2` unit each, and each high good
has source value at least `L / lambda`; the artificial low-good construction
contributes one additional `L / lambda` unit.
-/
theorem paper_lmms_theorem_3_3_rounding_error_budget_le_source_slack
    {L : ℝ} {lambda : ℕ} {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    (highGoods lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g)
    (hlow :
      ∀ g : SourceItem, g ∈ lowGoods →
        0 ≤ v g)
    (hsource_average :
      highGoods.sum v + lowGoods.sum v =
        (Fintype.card SourceAgent : ℝ) * L) :
    (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
        L / (lambda : ℝ) ≤
      ((Fintype.card SourceAgent : ℝ) + 1) * (L / (lambda : ℝ)) := by
  classical
  have hlambda_real_pos : 0 < (lambda : ℝ) := by
    exact_mod_cast hlambda
  have hhigh_unit_le :
      (highGoods.card : ℝ) * (L / (lambda : ℝ)) ≤ highGoods.sum v := by
    calc
      (highGoods.card : ℝ) * (L / (lambda : ℝ)) =
          highGoods.sum (fun _g => L / (lambda : ℝ)) := by
            simp [Finset.sum_const, nsmul_eq_mul]
      _ ≤ highGoods.sum v := by
            exact Finset.sum_le_sum fun g hg => le_of_lt (hhigh g hg)
  have hlow_nonneg : 0 ≤ lowGoods.sum v :=
    Finset.sum_nonneg fun g hg => hlow g hg
  have hhigh_unit_le_total :
      (highGoods.card : ℝ) * (L / (lambda : ℝ)) ≤
        (Fintype.card SourceAgent : ℝ) * L := by
    calc
      (highGoods.card : ℝ) * (L / (lambda : ℝ)) ≤
          highGoods.sum v := hhigh_unit_le
      _ ≤ highGoods.sum v + lowGoods.sum v := by linarith
      _ = (Fintype.card SourceAgent : ℝ) * L := hsource_average
  have hhigh_error_le :
      (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) ≤
        (Fintype.card SourceAgent : ℝ) * (L / (lambda : ℝ)) := by
    have hdiv :=
      div_le_div_of_nonneg_right hhigh_unit_le_total
        (le_of_lt hlambda_real_pos)
    calc
      (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) =
          ((highGoods.card : ℝ) * (L / (lambda : ℝ))) / (lambda : ℝ) := by
            field_simp [ne_of_gt hlambda_real_pos]
      _ ≤ ((Fintype.card SourceAgent : ℝ) * L) / (lambda : ℝ) := hdiv
      _ = (Fintype.card SourceAgent : ℝ) * (L / (lambda : ℝ)) := by
            ring
  calc
    (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
        L / (lambda : ℝ)
        ≤ (Fintype.card SourceAgent : ℝ) * (L / (lambda : ℝ)) +
          L / (lambda : ℝ) := by
          simpa [add_comm, add_left_comm, add_assoc] using
            add_le_add_right hhigh_error_le (L / (lambda : ℝ))
    _ = ((Fintype.card SourceAgent : ℝ) + 1) * (L / (lambda : ℝ)) := by
          ring

/--
The per-agent slack used by the source-average auto-cap is at most two grid
units.  The only input is that the source agent set is nonempty.
-/
theorem paper_lmms_theorem_3_3_source_auto_cap_extra_average_le_two_units
    {L : ℝ} {lambda : ℕ} {SourceAgent : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    (hlambda : 0 < lambda) (hL : 0 < L) :
    ((((Fintype.card SourceAgent : ℝ) + 1) *
        (L / (lambda : ℝ))) /
      (Fintype.card SourceAgent : ℝ)) ≤
      2 * (L / (lambda : ℝ)) := by
  have hcard_nat_pos : 0 < Fintype.card SourceAgent :=
    Fintype.card_pos
  have hcard_pos : 0 < (Fintype.card SourceAgent : ℝ) := by
    exact_mod_cast hcard_nat_pos
  have hcard_one_le : (1 : ℝ) ≤ (Fintype.card SourceAgent : ℝ) := by
    exact_mod_cast hcard_nat_pos
  have hlambda_real_pos : 0 < (lambda : ℝ) := by
    exact_mod_cast hlambda
  have hunit_nonneg : 0 ≤ L / (lambda : ℝ) :=
    (div_pos hL hlambda_real_pos).le
  have hfactor :
      (((Fintype.card SourceAgent : ℝ) + 1) /
        (Fintype.card SourceAgent : ℝ)) ≤ 2 := by
    field_simp [ne_of_gt hcard_pos]
    linarith
  calc
    ((((Fintype.card SourceAgent : ℝ) + 1) *
        (L / (lambda : ℝ))) /
      (Fintype.card SourceAgent : ℝ))
        =
          (((Fintype.card SourceAgent : ℝ) + 1) /
            (Fintype.card SourceAgent : ℝ)) *
              (L / (lambda : ℝ)) := by
          ring
    _ ≤ 2 * (L / (lambda : ℝ)) :=
          mul_le_mul_of_nonneg_right hfactor hunit_nonneg

/--
The source-average auto-cap average is bounded by the paper's simple
`L * (1 + 2 / lambda)` scale.
-/
theorem paper_lmms_theorem_3_3_source_auto_cap_average_le_one_plus_two_over_lambda
    {L : ℝ} {lambda : ℕ} {SourceAgent : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    (hlambda : 0 < lambda) (hL : 0 < L) :
    L +
        ((((Fintype.card SourceAgent : ℝ) + 1) *
            (L / (lambda : ℝ))) /
          (Fintype.card SourceAgent : ℝ)) ≤
      L * (1 + 2 / (lambda : ℝ)) := by
  calc
    L +
        ((((Fintype.card SourceAgent : ℝ) + 1) *
            (L / (lambda : ℝ))) /
          (Fintype.card SourceAgent : ℝ))
        ≤ L + 2 * (L / (lambda : ℝ)) := by
          simpa [add_comm, add_left_comm, add_assoc] using
            add_le_add_left
              (paper_lmms_theorem_3_3_source_auto_cap_extra_average_le_two_units
                (SourceAgent := SourceAgent) hlambda hL)
              L
    _ = L * (1 + 2 / (lambda : ℝ)) := by
          ring

/--
The source-average auto-cap count is bounded by an explicit linear function of
`lambda`.  This is the finite-search-size version of the
`L * (1 + 2 / lambda)` cap-average bound.
-/
theorem paper_lmms_theorem_3_3_source_auto_cap_count_le
    {L : ℝ} {lambda : ℕ} {SourceAgent : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    (hlambda : 0 < lambda) (hL : 0 < L) :
    paper_lmms_theorem_3_3_capCountForAverage
      L
        (L +
          ((((Fintype.card SourceAgent : ℝ) + 1) *
              (L / (lambda : ℝ))) /
            (Fintype.card SourceAgent : ℝ)))
      lambda ≤ 2 * lambda + 4 := by
  let capAverage : ℝ :=
    L +
      ((((Fintype.card SourceAgent : ℝ) + 1) *
          (L / (lambda : ℝ))) /
        (Fintype.card SourceAgent : ℝ))
  have hcapAverage_le :
      capAverage ≤ L * (1 + 2 / (lambda : ℝ)) := by
    simpa [capAverage] using
      paper_lmms_theorem_3_3_source_auto_cap_average_le_one_plus_two_over_lambda
        (SourceAgent := SourceAgent) hlambda hL
  have hlambda_real_pos : 0 < (lambda : ℝ) := by
    exact_mod_cast hlambda
  have hunit_pos : 0 < L / (lambda : ℝ) :=
    div_pos hL hlambda_real_pos
  have htwocap_le :
      2 * capAverage ≤ 2 * (L * (1 + 2 / (lambda : ℝ))) :=
    mul_le_mul_of_nonneg_left hcapAverage_le (by norm_num)
  have hquot_le :
      2 * capAverage / (L / (lambda : ℝ)) ≤
        (2 * lambda + 4 : ℕ) := by
    calc
      2 * capAverage / (L / (lambda : ℝ))
          ≤
            2 * (L * (1 + 2 / (lambda : ℝ))) /
              (L / (lambda : ℝ)) :=
            div_le_div_of_nonneg_right htwocap_le hunit_pos.le
      _ = (2 * lambda + 4 : ℕ) := by
            field_simp [ne_of_gt hL, ne_of_gt hlambda_real_pos]
            norm_num [Nat.cast_add, Nat.cast_mul]
            ring
  have hceil :
      Nat.ceil (2 * capAverage / (L / (lambda : ℝ))) ≤
        2 * lambda + 4 :=
    Nat.ceil_le.mpr hquot_le
  simpa [paper_lmms_theorem_3_3_capCountForAverage, capAverage] using hceil

/--
The source-average auto-capped value-pair search surface has an explicit
cardinality bound depending only on `lambda`.
-/
theorem paper_lmms_theorem_3_3_source_auto_cap_value_pair_set_card_le
    {L LR : ℝ} {lambda : ℕ} {SourceAgent : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    (hlambda : 0 < lambda) (hL : 0 < L) :
    let extraAverage : ℝ :=
      (((Fintype.card SourceAgent : ℝ) + 1) * (L / (lambda : ℝ))) /
        (Fintype.card SourceAgent : ℝ)
    let maxCount : ℕ :=
      paper_lmms_theorem_3_3_capCountForAverage
        L (L + extraAverage) lambda
    (Theorem33.roundedAdmissibleValuePairSetWithCap
        L LR lambda maxCount).card ≤
      ((2 * lambda + 5) ^
        Fintype.card (Theorem33.RoundedValueIndex lambda)) ^ 2 := by
  classical
  dsimp
  let maxCount : ℕ :=
    paper_lmms_theorem_3_3_capCountForAverage
      L
        (L +
          ((((Fintype.card SourceAgent : ℝ) + 1) *
              (L / (lambda : ℝ))) /
            (Fintype.card SourceAgent : ℝ)))
      lambda
  have hcount : maxCount ≤ 2 * lambda + 4 := by
    simpa [maxCount] using
      paper_lmms_theorem_3_3_source_auto_cap_count_le
        (SourceAgent := SourceAgent) hlambda hL
  have hbase : maxCount + 1 ≤ 2 * lambda + 5 := by
    omega
  have hraw :
      (Theorem33.roundedAdmissibleValuePairSetWithCap
          L LR lambda maxCount).card ≤
        ((maxCount + 1) ^
          Fintype.card (Theorem33.RoundedValueIndex lambda)) ^ 2 :=
    Theorem33.roundedAdmissibleValuePairSetWithCap_card_le
      L LR lambda maxCount
  have hinner :
      (maxCount + 1) ^
          Fintype.card (Theorem33.RoundedValueIndex lambda) ≤
        (2 * lambda + 5) ^
          Fintype.card (Theorem33.RoundedValueIndex lambda) :=
    pow_le_pow_left₀ (Nat.zero_le _) hbase _
  have houter :
      ((maxCount + 1) ^
          Fintype.card (Theorem33.RoundedValueIndex lambda)) ^ 2 ≤
        ((2 * lambda + 5) ^
          Fintype.card (Theorem33.RoundedValueIndex lambda)) ^ 2 :=
    pow_le_pow_left₀ (Nat.zero_le _) hinner 2
  exact le_trans hraw houter

