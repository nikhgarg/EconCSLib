/--
Theorem 3.3/Lemma 3.5 additive-transfer endpoint: the raw additive
rounded-to-source and source-to-rounded inequalities compose, for
`lambda = 56 / epsilon`, into the paper's `(1 + epsilon)` ratio guarantee.
-/
theorem paper_lmms_theorem_3_3_ratio_transfer_certificate_epsilon_of_additive
    {epsilon L optMin optMax roundedMin roundedMax outMin outMax : ℝ}
    (hepsilon_pos : 0 < epsilon) (hepsilon_le_one : epsilon ≤ 1)
    (houtMin : 0 < outMin)
    (hroundedMin : 0 < roundedMin)
    (hoptMin : 0 < optMin) (hoptMax : 0 ≤ optMax)
    (hroundedMax_nonneg : 0 ≤ roundedMax)
    (hroundedMin_half : L ≤ 2 * roundedMin)
    (hroundedMax_half : L ≤ 2 * roundedMax)
    (hoptMin_half : L ≤ 2 * optMin)
    (hoptMax_half : L ≤ 2 * optMax)
    (hbackward_max :
      outMax ≤ roundedMax + L / (56 / epsilon))
    (hbackward_min :
      ((56 / epsilon) / ((56 / epsilon) + 1)) * roundedMin -
          (2 / (56 / epsilon)) * L ≤ outMin)
    (hforward_max :
      roundedMax ≤ (((56 / epsilon) + 1) / (56 / epsilon)) * optMax +
        L / (56 / epsilon))
    (hforward_min :
      optMin - L / (56 / epsilon) ≤ roundedMin) :
    Theorem35.ratio outMin outMax ≤
      Theorem35.ratio optMin optMax * (1 + epsilon) := by
  exact
    Theorem35.theorem33_ratio_transfer_certificate_epsilon_of_additive
      hepsilon_pos hepsilon_le_one houtMin hroundedMin hoptMin hoptMax
      hroundedMax_nonneg hroundedMin_half hroundedMax_half hoptMin_half
      hoptMax_half hbackward_max hbackward_min hforward_max hforward_min

/--
Theorem 3.3/Lemma 3.5 additive-transfer endpoint over per-agent load
functions.  This lets later construction layers compare source, rounded, and
output allocations with different item types as long as the three load
functions share the same finite agent index.
-/
theorem paper_lmms_theorem_3_3_ratio_transfer_certificate_epsilon_of_agentwise_additive_loads
    {SourceAgent : Type*} [Fintype SourceAgent] [Nonempty SourceAgent]
    {epsilon L : ℝ}
    {optLoad roundedLoad outLoad : SourceAgent → ℝ}
    (hepsilon_pos : 0 < epsilon) (hepsilon_le_one : epsilon ≤ 1)
    (houtMin :
      0 < (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty outLoad)
    (hroundedMin :
      0 < (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty roundedLoad)
    (hoptMin :
      0 < (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty optLoad)
    (hoptMax :
      0 ≤ (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty optLoad)
    (hroundedMax_nonneg :
      0 ≤ (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty roundedLoad)
    (hroundedMin_half :
      L ≤ 2 * (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty roundedLoad)
    (hroundedMax_half :
      L ≤ 2 * (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty roundedLoad)
    (hoptMin_half :
      L ≤ 2 * (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty optLoad)
    (hoptMax_half :
      L ≤ 2 * (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty optLoad)
    (hbackward_max_agent :
      ∀ i : SourceAgent, outLoad i ≤ roundedLoad i + L / (56 / epsilon))
    (hbackward_min_agent :
      ∀ i : SourceAgent,
        ((56 / epsilon) / ((56 / epsilon) + 1)) * roundedLoad i -
          (2 / (56 / epsilon)) * L ≤ outLoad i)
    (hforward_max_agent :
      ∀ i : SourceAgent,
        roundedLoad i ≤ (((56 / epsilon) + 1) / (56 / epsilon)) *
            optLoad i + L / (56 / epsilon))
    (hforward_min_agent :
      ∀ i : SourceAgent, optLoad i - L / (56 / epsilon) ≤
        roundedLoad i) :
    Theorem35.ratio
        ((Finset.univ : Finset SourceAgent).inf'
          Finset.univ_nonempty outLoad)
        ((Finset.univ : Finset SourceAgent).sup'
          Finset.univ_nonempty outLoad) ≤
      Theorem35.ratio
          ((Finset.univ : Finset SourceAgent).inf'
            Finset.univ_nonempty optLoad)
          ((Finset.univ : Finset SourceAgent).sup'
            Finset.univ_nonempty optLoad) *
        (1 + epsilon) := by
  exact
    Theorem35.theorem33_ratio_transfer_certificate_epsilon_of_agentwise_additive_loads
      hepsilon_pos hepsilon_le_one houtMin hroundedMin hoptMin hoptMax
      hroundedMax_nonneg hroundedMin_half hroundedMax_half hoptMin_half
      hoptMax_half hbackward_max_agent hbackward_min_agent
      hforward_max_agent hforward_min_agent

/-! ## 8) Truthfulness support -/

/-- Paper direct fair-division mechanism without monetary transfers. -/
abbrev paper_direct_mechanism (Agent Item : Type*) :=
  DirectFairDivisionMechanism Agent Item

/-- Paper randomized direct fair-division mechanism without monetary transfers. -/
abbrev paper_randomized_direct_mechanism (Agent Item : Type*) :=
  RandomizedDirectFairDivisionMechanism Agent Item

/-- Paper dominant-strategy truthfulness predicate for fair-division mechanisms. -/
def paper_fair_division_truthful [DecidableEq Agent]
    (M : paper_direct_mechanism Agent Item) : Prop :=
  M.Truthful

/-- Paper expected-utility truthfulness predicate for randomized mechanisms. -/
def paper_randomized_fair_division_truthful
    [Fintype (Allocation Agent Item)] [DecidableEq (Allocation Agent Item)]
    [DecidableEq Agent]
    (M : paper_randomized_direct_mechanism Agent Item) : Prop :=
  M.Truthful

/--
Theorem 4.1 support: a concrete profitable deviation refutes
dominant-strategy truthfulness.
-/
theorem paper_lmms_theorem_4_1_not_truthful_of_profitable_deviation
    [DecidableEq Agent] (M : paper_direct_mechanism Agent Item)
    (w : M.ProfitableDeviation) :
    ¬ paper_fair_division_truthful M := by
  exact DirectFairDivisionMechanism.not_truthful_of_profitableDeviation M w

/--
Theorem 4.1 certificate form: if the source two-player construction supplies
an envy-free manipulation certificate, then any mechanism that always allocates
the goods and returns an envy-free allocation whenever one exists is not
truthful.
-/
theorem paper_lmms_theorem_4_1_not_truthful_of_envy_free_certificate
    [DecidableEq Agent] (M : paper_direct_mechanism Agent Item)
    (goods : Finset Item)
    (halloc : ReturnsAllocationOf M goods)
    (hef : ReturnsEnvyFreeWheneverExists M goods)
    (cert : EnvyFreeManipulationCertificate (Agent := Agent) (Item := Item) goods) :
    ¬ paper_fair_division_truthful M := by
  exact
    not_truthful_of_envyFreeManipulationCertificate
      M halloc hef cert

/--
Theorem 4.1 minimum-envy form: a minimum-envy mechanism returns an envy-free
allocation whenever one exists, so the same manipulation certificate refutes
truthfulness for minimum-envy mechanisms.
-/
theorem paper_lmms_theorem_4_1_minimum_envy_not_truthful_of_certificate
    [DecidableEq Agent] (M : paper_direct_mechanism Agent Item)
    (goods : Finset Item)
    (hmin : ReturnsMinimumReportEnvy M goods)
    (cert : EnvyFreeManipulationCertificate (Agent := Agent) (Item := Item) goods) :
    ¬ paper_fair_division_truthful M := by
  exact
    not_truthful_of_envyFreeManipulationCertificate
      M
      (returnsAllocationOf_of_returnsMinimumReportEnvy M hmin)
      (returnsEnvyFreeWheneverExists_of_returnsMinimumReportEnvy M hmin)
      cert

/--
Theorem 4.1 source-model support: in the finite two-player/eight-egg source
model, a source counterexample certificate gives a profitable deviation and
therefore refutes truthfulness.
-/
theorem paper_lmms_theorem_4_1_not_truthful_of_source_counterexample_certificate
    (M : Theorem41.LMMS41Mechanism)
    (C : Theorem41.LMMS41SourceCounterexampleCertificate M) :
    ¬ M.Truthful := by
  exact Theorem41.lmms41_not_truthful_of_sourceCounterexampleCertificate M C

/--
Theorem 4.1 source-case assembly: once the truthful and shifted finite
source profiles are known to have exact envy-free allocations, any mechanism
that always allocates the source goods and returns an envy-free allocation
whenever one exists is not truthful.
-/
theorem paper_lmms_theorem_4_1_not_truthful_of_shifted_exists
    (M : Theorem41.LMMS41Mechanism)
    (halloc : ReturnsAllocationOf M Theorem41.lmms41Goods)
    (hef : ReturnsEnvyFreeWheneverExists M Theorem41.lmms41Goods)
    (htrue_exists : Theorem41.LMMS41TruthfulExists)
    (hcase1_exists :
      ∀ T : ℕ, T ≤ 4 → Theorem41.LMMS41Player1ShiftedExistsFor T)
    (hcase2_exists :
      ∀ U : ℕ, U ≤ 3 → Theorem41.LMMS41Player2ShiftedExistsFor U) :
    ¬ M.Truthful := by
  exact
    Theorem41.lmms41_not_truthful_of_shifted_exists
      M halloc hef htrue_exists hcase1_exists hcase2_exists

/--
Theorem 4.1 source-model theorem: no mechanism that always allocates the
finite source goods and returns an envy-free allocation whenever one exists is
truthful.
-/
theorem paper_lmms_theorem_4_1_source_not_truthful_envy_free_whenever_exists
    (M : Theorem41.LMMS41Mechanism)
    (halloc : ReturnsAllocationOf M Theorem41.lmms41Goods)
    (hef : ReturnsEnvyFreeWheneverExists M Theorem41.lmms41Goods) :
    ¬ M.Truthful := by
  exact
    Theorem41.lmms41_not_truthful_of_returnsEnvyFreeWheneverExists
      M halloc hef

/--
Theorem 4.1 source-model minimum-envy form: a mechanism that always chooses a
minimum reported-envy allocation of the finite source goods is not truthful.
-/
theorem paper_lmms_theorem_4_1_source_minimum_envy_not_truthful
    (M : Theorem41.LMMS41Mechanism)
    (hmin : ReturnsMinimumReportEnvy M Theorem41.lmms41Goods) :
    ¬ M.Truthful := by
  exact
    Theorem41.lmms41_not_truthful_of_returnsEnvyFreeWheneverExists
      M
      (returnsAllocationOf_of_returnsMinimumReportEnvy M hmin)
      (returnsEnvyFreeWheneverExists_of_returnsMinimumReportEnvy M hmin)

/--
Theorem 4.2 truthfulness support: any no-transfer allocation rule independent
of reported utilities is truthful.
-/
theorem paper_lmms_theorem_4_2_report_independent_truthful
    [DecidableEq Agent] (M : paper_direct_mechanism Agent Item)
    (hind : M.ReportIndependent) :
    paper_fair_division_truthful M := by
  exact DirectFairDivisionMechanism.truthful_of_reportIndependent M hind

/--
Theorem 4.2 truthfulness support for the source randomized algorithm: any
report-independent no-transfer randomized allocation rule is truthful in
expected utility.
-/
theorem paper_lmms_theorem_4_2_randomized_report_independent_truthful
    [Fintype (Allocation Agent Item)] [DecidableEq (Allocation Agent Item)]
    [DecidableEq Agent]
    (M : paper_randomized_direct_mechanism Agent Item)
    (hind : M.ReportIndependent) :
    paper_randomized_fair_division_truthful M := by
  exact
    RandomizedDirectFairDivisionMechanism.truthful_of_reportIndependent M hind

/--
Theorem 4.2 source randomized mechanism: independent uniform allocation of
goods is truthful in expected utility.
-/
theorem paper_lmms_theorem_4_2_uniform_random_mechanism_truthful
    [Fintype (Allocation Agent Item)] [DecidableEq (Allocation Agent Item)]
    [DecidableEq Agent]
    [Nonempty Agent] :
    paper_randomized_fair_division_truthful
      (Theorem42.lmms42UniformRandomMechanism Agent Item) := by
  exact Theorem42.lmms42UniformRandomMechanism_truthful Agent Item

/--
Theorem 4.2 concentration bound: for additive valuations normalized to total
value one per player and with every item worth at most `alpha`, independent
uniform random allocation has maximum envy at most `t` with the explicit
Chebyshev/union-bound probability from the source proof.
-/
theorem paper_lmms_theorem_4_2_uniform_random_max_envy_probability_bound
    (w : Theorem42.LMMS42ItemWeights Agent Item) {alpha t : ℝ}
    (halpha : 0 ≤ alpha) (ht : 0 < t)
    (hnonneg : ∀ p : Agent, ∀ g : Item, 0 ≤ w p g)
    (hsum : ∀ p : Agent, ∑ g : Item, w p g = 1)
    (hbound : ∀ p : Agent, ∀ g : Item, w p g ≤ alpha) :
    1 - 2 * alpha * (Fintype.card Agent : ℝ) / t ^ 2 ≤
      EconCSLib.pmfProb (Theorem42.lmms42UniformAssignmentLaw Agent Item)
        (fun assign : Item → Agent =>
          maxReportEnvy (Theorem42.lmms42AdditiveReport w)
            (Theorem42.lmms42AllocationOfAssignment assign) ≤ t) := by
  exact
    Theorem42.lmms42_uniformAssignment_maxReportEnvy_prob_ge_of_weights
      w halpha ht hnonneg hsum hbound

end LMMS04FairDivision
