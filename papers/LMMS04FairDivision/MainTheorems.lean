/--
The load of the rounded bundle type induced by a source bundle equals the
direct sum of the corresponding rounded values of that bundle's goods.
-/
theorem paper_lmms_theorem_3_3_roundedBundleTypeOfBundle_load_eq_sum
    {SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (bundle : Finset SourceItem) :
    Theorem33.roundedBundleTypeLoad L
        (paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf bundle) =
      bundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) := by
  classical
  calc
    Theorem33.roundedBundleTypeLoad L
        (paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf bundle)
        =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        ∑ g ∈ bundle with indexOf g = k,
          Theorem33.roundedValue L lambda k := by
        apply Finset.sum_congr rfl
        intro k _hk
        simp [paper_lmms_theorem_3_3_roundedBundleTypeOfBundle, nsmul_eq_mul,
          mul_comm]
    _ = bundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) := by
        simpa using
          (Finset.sum_fiberwise_of_maps_to'
            (s := bundle)
            (t := (Finset.univ : Finset (Theorem33.RoundedValueIndex lambda)))
            (g := indexOf)
            (f := fun k : Theorem33.RoundedValueIndex lambda =>
              Theorem33.roundedValue L lambda k)
            (fun g _hg => Finset.mem_univ (indexOf g)))

/--
