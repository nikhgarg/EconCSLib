/--
Theorem 3.3/Lemma 3.5 forward scalar transfer for a value pair.  If a
comparison pair satisfies the additive source-to-rounded max/min estimates
against a bounded source optimum, its rounded value-pair ratio is within the
forward transfer factor of the source optimum's ratio.
-/
theorem paper_lmms_theorem_3_3_value_pair_forward_ratio_transfer_epsilon
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {L epsilon : ℝ} {p : ℝ × ℝ}
    {optimal : Allocation SourceAgent SourceItem}
    (sourceValue : SourceItem → ℝ)
    (hepsilon_pos : 0 < epsilon) (hepsilon_le_one : epsilon ≤ 1)
    (hL : 0 < L)
    (hopt_window :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem34.commonLoad sourceValue (optimal i)))
    (hp_min : 0 < p.1)
    (hforward_max_pair :
      p.2 ≤ (((56 / epsilon) + 1) / (56 / epsilon)) *
          ((Finset.univ : Finset SourceAgent).sup'
            Finset.univ_nonempty
            (fun i => Theorem34.commonLoad sourceValue (optimal i))) +
        L / (56 / epsilon))
    (hforward_min_pair :
      ((Finset.univ : Finset SourceAgent).inf'
          Finset.univ_nonempty
          (fun i => Theorem34.commonLoad sourceValue (optimal i))) -
        L / (56 / epsilon) ≤ p.1) :
    Theorem33.roundedValuePairRatio p ≤
      Theorem35.ratio
          ((Finset.univ : Finset SourceAgent).inf'
            Finset.univ_nonempty
            (fun i => Theorem34.commonLoad sourceValue (optimal i)))
          ((Finset.univ : Finset SourceAgent).sup'
            Finset.univ_nonempty
            (fun i => Theorem34.commonLoad sourceValue (optimal i))) *
        Theorem35.forwardTransferFactor (56 / epsilon) := by
  classical
  let optLoad : SourceAgent → ℝ :=
    fun i => Theorem34.commonLoad sourceValue (optimal i)
  have hlambda_pos : 0 < 56 / epsilon := by
    positivity
  have hlambda_ge : 56 ≤ 56 / epsilon := by
    rw [le_div_iff₀ hepsilon_pos]
    nlinarith
  have hlower : 0 < 1 - 2 / (56 / epsilon) := by
    have htwo_lt : (2 : ℝ) < 56 / epsilon := by
      nlinarith
    rw [sub_pos]
    rw [div_lt_one hlambda_pos]
    exact htwo_lt
  have hupper_nonneg :
      0 ≤ (((56 / epsilon) + 1) / (56 / epsilon)) +
          2 / (56 / epsilon) := by
    positivity
  have hoptMin :
      0 < (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty optLoad := by
    rw [Finset.lt_inf'_iff]
    intro i _hi
    have hi := (hopt_window i).1
    dsimp [optLoad]
    nlinarith [hL, hi]
  have hoptMax :
      0 ≤ (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty optLoad := by
    let i0 : SourceAgent := Classical.choice (inferInstance : Nonempty SourceAgent)
    have hload_nonneg : 0 ≤ optLoad i0 := by
      have hi := (hopt_window i0).1
      dsimp [optLoad]
      nlinarith [hL, hi]
    exact
      le_trans hload_nonneg
        (Finset.le_sup'
          (s := (Finset.univ : Finset SourceAgent))
          (f := optLoad)
          (by simp [i0] : i0 ∈ (Finset.univ : Finset SourceAgent)))
  have hoptMin_half :
      L ≤ 2 * (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty optLoad := by
    have hhalf :
        L / 2 ≤ (Finset.univ : Finset SourceAgent).inf'
          Finset.univ_nonempty optLoad := by
      apply Finset.le_inf'
      intro i _hi
      have hi := (hopt_window i).1
      dsimp [optLoad]
      linarith
    nlinarith
  have hoptMax_half :
      L ≤ 2 * (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty optLoad := by
    let i0 : SourceAgent := Classical.choice (inferInstance : Nonempty SourceAgent)
    have hi := (hopt_window i0).1
    have hle :
        optLoad i0 ≤
          (Finset.univ : Finset SourceAgent).sup'
            Finset.univ_nonempty optLoad :=
      Finset.le_sup'
        (s := (Finset.univ : Finset SourceAgent))
        (f := optLoad)
        (by simp [i0] : i0 ∈ (Finset.univ : Finset SourceAgent))
    dsimp [optLoad] at hle
    nlinarith
  have hforward :=
    Theorem35.forward_ratio_transfer_of_additive
      (lambda := 56 / epsilon) (L := L)
      (sourceMin := (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty optLoad)
      (sourceMax := (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty optLoad)
      (roundedMin := p.1) (roundedMax := p.2)
      hlambda_pos hp_min hoptMin hlower hupper_nonneg hoptMax
      hoptMin_half hoptMax_half
      (by simpa [optLoad] using hforward_max_pair)
      (by simpa [optLoad] using hforward_min_pair)
  simpa [Theorem33.roundedValuePairRatio, Theorem35.ratio, optLoad] using
    hforward

