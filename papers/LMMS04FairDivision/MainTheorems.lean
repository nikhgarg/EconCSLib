      (Theorem33.roundedTypesInValueWindowWithCap
          L LR lambda maxCount lower upper).card ≤
        (Theorem33.roundedAdmissibleTypeSetWithCap
          L LR lambda maxCount).card := by
    refine Finset.card_le_card ?_
    intro t ht
    exact
      ((Theorem33.mem_roundedTypesInValueWindowWithCap_iff t).mp ht).1
  exact
    le_trans hsubset
      (Theorem33.roundedAdmissibleTypeSetWithCap_card_le
        L LR lambda maxCount)

