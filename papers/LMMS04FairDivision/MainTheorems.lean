/-! ## 1) Paper-Facing Definitions -/

noncomputable def paper_envy (v : Valuation Agent Item) (A : Allocation Agent Item) (i j : Agent) : ℝ :=
  max 0 (v.value i (A j) - v.value i (A i))

theorem paper_envy_eq_envy (v : Valuation Agent Item) (A : Allocation Agent Item) (i j : Agent) :
    paper_envy v A i j = envy v A i j := by
  rfl

def paper_envy_free (v : Valuation Agent Item) (A : Allocation Agent Item) : Prop :=
  ∀ i j, v.value i (A j) ≤ v.value i (A i)

theorem paper_envy_free_eq (v : Valuation Agent Item) (A : Allocation Agent Item) :
    paper_envy_free v A ↔ EnvyFree v A := by
  rfl

def paper_envy_bounded_by (v : Valuation Agent Item) (A : Allocation Agent Item) (α : ℝ) : Prop :=
  ∀ i j, envy v A i j ≤ α

theorem paper_envy_bounded_by_eq (v : Valuation Agent Item) (A : Allocation Agent Item) (α : ℝ) :
    paper_envy_bounded_by v A α ↔ EnvyBoundedBy v A α := by
  rfl

/-- Definition 2.1: max marginal value of an item. -/
noncomputable def paper_max_marginal (v : Valuation Agent Item) : ℝ :=
  maxMarginal v

theorem paper_max_marginal_eq (v : Valuation Agent Item) :
    paper_max_marginal v = maxMarginal v := by rfl

/-- Paper Definition: Allocation of a set of goods. -/
def paper_is_allocation_of (A : Allocation Agent Item) (goods : Finset Item) : Prop :=
  IsAllocationOf A goods

theorem paper_is_allocation_of_eq (A : Allocation Agent Item) (goods : Finset Item) :
  paper_is_allocation_of A goods ↔ IsAllocationOf A goods := by rfl

/-! ## 2) Main Theorems -/

/--
Lemma 2.2: by repeatedly eliminating envy cycles, a finite partial allocation
can be transformed into an allocation of the same goods with the same envy
bound and an acyclic envy graph.
-/
theorem paper_lmms_lemma_2_2_acyclic_reduction
    (v : Valuation Agent Item) {α : ℝ} (goods : Finset Item)
    (A : Allocation Agent Item)
    (halloc : paper_is_allocation_of A goods)
    (hbound : paper_envy_bounded_by v A α) :
    ∃ B : Allocation Agent Item,
      paper_is_allocation_of B goods ∧
        paper_envy_bounded_by v B α ∧
          AcyclicEnvyGraph v B := by
  classical
  have halloc' : IsAllocationOf A goods :=
    (paper_is_allocation_of_eq A goods).mp halloc
  have hbound' : EnvyBoundedBy v A α :=
    (paper_envy_bounded_by_eq v A α).mp hbound
  have hreduce : HasAcyclicReduction v α :=
    hasAcyclicReduction_of_envyCycleListExtraction v
      (hasEnvyCycleListExtraction_of_finite v)
  obtain ⟨B, hBalloc, hBbound, hBacyclic⟩ :=
    hreduce goods A halloc' hbound'
  exact
    ⟨B, (paper_is_allocation_of_eq B goods).mpr hBalloc,
      (paper_envy_bounded_by_eq v B α).mpr hBbound, hBacyclic⟩

/-- Theorem 2.1 (Existence): There exists an allocation with envy bounded by max marginal. -/
theorem paper_lmms_theorem_2_1_existence
    (v : Valuation Agent Item) (goods : Finset Item) :
    ∃ A, paper_is_allocation_of A goods ∧
         paper_envy_bounded_by v A (paper_max_marginal v) := by
  rcases lmms_theorem_2_1_finite_maxMarginal v goods with ⟨A, h1, h2⟩
  use A
  rw [paper_is_allocation_of_eq, paper_envy_bounded_by_eq, paper_max_marginal_eq]
  exact ⟨h1, h2⟩

/-- Theorem 2.1 (Existence with alpha): There exists an allocation with envy bounded by alpha. -/
theorem paper_lmms_theorem_2_1_existence_alpha
    (v : Valuation Agent Item) {α : ℝ} (hαnonneg : 0 ≤ α) (hbound : MarginalBound v α) (goods : Finset Item) :
    ∃ A, paper_is_allocation_of A goods ∧
         paper_envy_bounded_by v A α := by
  rcases lmms_theorem_2_1_finite v hαnonneg hbound goods with ⟨A, h1, h2⟩
  use A
  rw [paper_is_allocation_of_eq, paper_envy_bounded_by_eq]
  exact ⟨h1, h2⟩

/-- Theorem 2.1 (Algorithm): The LMMS algorithm produces a bounded-envy allocation. -/
noncomputable def paper_lmms_algorithm
    (v : Valuation Agent Item) {α : ℝ} (hαnonneg : 0 ≤ α) (hbound : MarginalBound v α) (goodsList : List Item) :
    Allocation Agent Item :=
  (lmmsAlgorithm v hαnonneg hbound goodsList).2.val

theorem paper_lmms_algorithm_correct
    (v : Valuation Agent Item) {α : ℝ} (hαnonneg : 0 ≤ α) (hbound : MarginalBound v α) (goodsList : List Item) (hnodup : goodsList.Nodup) :
    paper_is_allocation_of (paper_lmms_algorithm v hαnonneg hbound goodsList) (lmmsAlgorithm v hαnonneg hbound goodsList).1 ∧
    paper_envy_bounded_by v (paper_lmms_algorithm v hαnonneg hbound goodsList) α := by
  rw [paper_is_allocation_of_eq, paper_envy_bounded_by_eq]
  exact (lmmsAlgorithm v hαnonneg hbound goodsList).2.property

/--
Theorem 2.1 (Algorithm, source-facing goods set): the LMMS algorithm produces a
bounded-envy allocation of exactly the input list's goods when the list has no
duplicates.
-/
theorem paper_lmms_algorithm_correct_list_toFinset
    (v : Valuation Agent Item) {α : ℝ} (hαnonneg : 0 ≤ α)
    (hbound : MarginalBound v α) (goodsList : List Item)
    (hnodup : goodsList.Nodup) :
    paper_is_allocation_of
        (paper_lmms_algorithm v hαnonneg hbound goodsList)
        goodsList.toFinset ∧
      paper_envy_bounded_by v
        (paper_lmms_algorithm v hαnonneg hbound goodsList) α := by
  rw [paper_is_allocation_of_eq, paper_envy_bounded_by_eq]
  exact
    lmmsAlgorithm_isAllocationOf_list_toFinset_and_envyBoundedBy
      v hαnonneg hbound goodsList hnodup

/-! ## 3) Measure-valued utility reduction -/

/--
Theorem 2.3 reduction seam: after the measurable space has been partitioned
into finitely many pieces whose one-piece marginal values are bounded by
`alpha`, Theorem 2.1 produces an allocation of those pieces with envy at most
`alpha`.

The separate measure-theoretic Lemma 2.4 is the source step that constructs
such a finite partition for probability measures on `[0,1]` with atoms bounded
by `alpha`.
-/
theorem paper_lmms_theorem_2_3_finite_partition_reduction
    {Piece : Type*} [Fintype Piece] [DecidableEq Piece]
    (v : Valuation Agent Piece) {alpha : ℝ}
    (halpha_nonneg : 0 ≤ alpha) (hbound : MarginalBound v alpha)
    (pieces : Finset Piece) :
    ∃ A : Allocation Agent Piece,
      IsAllocationOf A pieces ∧ EnvyBoundedBy v A alpha := by
  exact lmms_theorem_2_1_finite v halpha_nonneg hbound pieces

/--
Theorem 2.3 measure-partition bridge: if Lemma 2.4 has supplied a finite
measurable partition certificate, the induced finite-good instance has an
allocation of all partition pieces with envy at most `alpha`.
-/
theorem paper_lmms_theorem_2_3_from_measure_partition_certificate
    {Ω Piece : Type*} [MeasurableSpace Ω] [Fintype Piece] [DecidableEq Piece]
    {mu : Agent → Measure Ω} {alpha : ℝ}
    (halpha_nonneg : 0 ≤ alpha)
    (C : Lemma24.PaperMeasurePartitionCertificate mu alpha Piece) :
    ∃ A : Allocation Agent Piece,
      IsAllocationOf A (Finset.univ : Finset Piece) ∧
        EnvyBoundedBy C.valuation A alpha := by
  exact
    Lemma24.theorem2_3_from_measure_partition_certificate_univ
      halpha_nonneg C

/--
Theorem 2.3 aggregate-measure bridge: it is enough to construct a finite
partition whose pieces are small for the aggregate measure over all players.
Domination by the aggregate measure converts this into a Lemma 2.4-style
player-wise partition certificate, and then Theorem 2.1 allocates the pieces.
-/
theorem paper_lmms_theorem_2_3_from_aggregate_partition
    {Ω Piece : Type*} [MeasurableSpace Ω] [Fintype Piece] [DecidableEq Piece]
    {mu : Agent → Measure Ω} [∀ agent, IsFiniteMeasure (mu agent)]
    {alpha : ℝ} (halpha_nonneg : 0 ≤ alpha)
    (pieceSet : Piece → Set Ω)
    (hmeas : ∀ piece, MeasurableSet (pieceSet piece))
    (hdisjoint : Set.PairwiseDisjoint Set.univ pieceSet)
    (hcover : Set.iUnion pieceSet = Set.univ)
    (haggregate :
      ∀ piece, (aggregateMeasure mu).real (pieceSet piece) ≤ alpha) :
    ∃ A : Allocation Agent Piece,
      IsAllocationOf A (Finset.univ : Finset Piece) ∧
        EnvyBoundedBy
          (measurePartitionCertificateOfAggregateBound mu pieceSet hmeas hdisjoint hcover
            haggregate).valuation A alpha := by
  exact
    Lemma24.theorem2_3_from_aggregate_partition halpha_nonneg
      pieceSet hmeas hdisjoint hcover haggregate

/--
Theorem 2.3 high-atom split bridge: after finitely many point masses are made
singleton pieces, a residual aggregate-small partition is enough to allocate all
pieces with envy at most `alpha`.
-/
theorem paper_lmms_theorem_2_3_from_finite_singletons_and_residual_aggregate_partition
    {Ω Residual : Type*} [MeasurableSpace Ω] [MeasurableSingletonClass Ω]
    [DecidableEq Ω] [Fintype Residual] [DecidableEq Residual]
    {mu : Agent → Measure Ω} [∀ agent, IsFiniteMeasure (mu agent)]
    {alpha : ℝ} (halpha_nonneg : 0 ≤ alpha)
    (H : Finset Ω) (residualSet : Residual → Set Ω)
    (hmeas_residual : ∀ piece, MeasurableSet (residualSet piece))
    (hdisjoint_residual : Set.PairwiseDisjoint Set.univ residualSet)
    (hcover_residual : Set.iUnion residualSet = (H : Set Ω)ᶜ)
    (hsingleton : ∀ agent x, x ∈ H → (mu agent).real ({x} : Set Ω) ≤ alpha)
    (haggregate_residual :
      ∀ piece, (aggregateMeasure mu).real (residualSet piece) ≤ alpha) :
    ∃ A : Allocation Agent ({x : Ω // x ∈ H} ⊕ Residual),
      IsAllocationOf A (Finset.univ : Finset ({x : Ω // x ∈ H} ⊕ Residual)) ∧
        EnvyBoundedBy
          (measurePartitionCertificateOfFiniteSingletonsAndResidualAggregate
            mu H residualSet hmeas_residual hdisjoint_residual hcover_residual
            hsingleton haggregate_residual).valuation A alpha := by
  exact
    Lemma24.theorem2_3_from_finite_singletons_and_residual_aggregate_partition
      halpha_nonneg H residualSet hmeas_residual hdisjoint_residual
      hcover_residual hsingleton haggregate_residual

/--
Theorem 2.3 high-atom split bridge, deriving singleton-piece bounds from the
paper atom hypothesis.  The remaining proof obligation is only the
aggregate-small residual partition.
-/
theorem paper_lmms_theorem_2_3_from_residual_aggregate_partition_atom_bound
    {Ω Residual : Type*} [MeasurableSpace Ω] [MeasurableSingletonClass Ω]
    [DecidableEq Ω] [Fintype Residual] [DecidableEq Residual]
    {mu : Agent → Measure Ω} [∀ agent, IsFiniteMeasure (mu agent)]
    {alpha : ℝ} (halpha_nonneg : 0 ≤ alpha)
    (hatoms : ∀ agent, Lemma24.PaperAtomsBoundedBy (mu agent) alpha)
    (H : Finset Ω) (residualSet : Residual → Set Ω)
    (hmeas_residual : ∀ piece, MeasurableSet (residualSet piece))
    (hdisjoint_residual : Set.PairwiseDisjoint Set.univ residualSet)
    (hcover_residual : Set.iUnion residualSet = (H : Set Ω)ᶜ)
    (haggregate_residual :
      ∀ piece, (aggregateMeasure mu).real (residualSet piece) ≤ alpha) :
    ∃ A : Allocation Agent ({x : Ω // x ∈ H} ⊕ Residual),
      IsAllocationOf A (Finset.univ : Finset ({x : Ω // x ∈ H} ⊕ Residual)) ∧
        EnvyBoundedBy
          (measurePartitionCertificateOfFiniteSingletonsAndResidualAggregate
            mu H residualSet hmeas_residual hdisjoint_residual hcover_residual
            (fun agent x _ => Lemma24.paper_atom_bound_implies_point_mass_bound
              (mu agent) halpha_nonneg (hatoms agent) x)
            haggregate_residual).valuation A alpha := by
  exact
    Lemma24.theorem2_3_from_finite_singletons_and_residual_aggregate_partition_atom_bound
      halpha_nonneg hatoms H residualSet hmeas_residual hdisjoint_residual
      hcover_residual haggregate_residual

/--
Theorem 2.3, real-supported construction: for finite player measures supported
on a real interval and with paper-bounded atoms, split aggregate point masses
above `alpha / 2`, partition the residual aggregate measure into finite
low-mass pieces, and allocate the resulting finite goods with envy at most
`alpha`.
-/
theorem paper_lmms_theorem_2_3_real_interval_supported_atom_bound
    {mu : Agent → Measure ℝ} [∀ agent, IsFiniteMeasure (mu agent)]
    {alpha a b : ℝ} (halpha_pos : 0 < alpha)
    (hatoms : ∀ agent, Lemma24.PaperAtomsBoundedBy (mu agent) alpha)
    (haggregate_support :
      (aggregateMeasure mu).real ((Set.Ioc a b)ᶜ) = 0) :
    ∃ H : Finset ℝ,
      ∃ P : EconCSLib.Probability.RealIntervalPartition
        ((aggregateMeasure mu).restrict (H : Set ℝ)ᶜ) alpha a b,
        letI := P.instFintype
        letI := P.instDecidableEq
        ∃ A : Allocation Agent ({x : ℝ // x ∈ H} ⊕ Option P.Piece),
          IsAllocationOf A
              (Finset.univ : Finset ({x : ℝ // x ∈ H} ⊕ Option P.Piece)) ∧
            EnvyBoundedBy
              (measurePartitionCertificateOfFiniteSingletonsAndResidualAggregate
                mu H (Lemma24.realIntervalResidualSet H P)
                (Lemma24.realIntervalResidualSet_measurable H P)
                (Lemma24.realIntervalResidualSet_pairwiseDisjoint H P)
                (Lemma24.realIntervalResidualSet_cover H P)
                (fun agent x _ => Lemma24.paper_atom_bound_implies_point_mass_bound
                  (mu agent) (le_of_lt halpha_pos) (hatoms agent) x)
                (Lemma24.realIntervalResidualSet_aggregate_le
                  (Agent := Agent) (le_of_lt halpha_pos) H P
                  haggregate_support)).valuation A alpha := by
  exact
    Lemma24.theorem2_3_real_interval_supported_atom_bound
      halpha_pos hatoms haggregate_support

/-! ## 4) Query lower-bound support -/

/--
Theorem 3.1 source-proof core: if a deterministic query algorithm has fewer
possible transcripts than hard instances, and indistinguishable distinct hard
instances have no common optimal output, then the algorithm cannot be correct
on all hard instances.
-/
theorem paper_lmms_theorem_3_1_query_lower_bound_from_transcript_certificate
    {Instance Transcript Output : Type*}
    [Fintype Instance] [Fintype Transcript]
    (transcript : Instance → Transcript)
    (output : Transcript → Output)
    (Optimal : Instance → Output → Prop)
    (hcard : Fintype.card Transcript < Fintype.card Instance)
    (hnoCommon :
      ∀ i j : Instance, i ≠ j → transcript i = transcript j →
        ∀ out : Output, ¬ (Optimal i out ∧ Optimal j out)) :
    ¬ ∀ i : Instance, Optimal i (output (transcript i)) := by
  exact
    Theorem31.lmms31_query_lower_bound_from_transcript_certificate
      transcript output Optimal hcard hnoCommon

/--
Theorem 3.1 swapped-instance source-proof step: if the hard-family counting
argument supplies two utility functions `u` and `v` such that the two-player
instances `(u,v)` and `(v,u)` have the same deterministic transcript, and no
single output is optimal for both instances, then the algorithm is not correct
on all hard instances.
-/
theorem paper_lmms_theorem_3_1_query_lower_bound_from_swapped_pair_certificate
    {Valuation Transcript Output : Type*}
    (transcript : Valuation × Valuation → Transcript)
    (output : Transcript → Output)
    (Optimal : Valuation × Valuation → Output → Prop)
    (u v : Valuation)
    (htranscript : transcript (u, v) = transcript (v, u))
    (hnoCommon :
      ∀ out : Output, ¬ (Optimal (u, v) out ∧ Optimal (v, u) out)) :
    ¬ ∀ inst : Valuation × Valuation,
      Optimal inst (output (transcript inst)) := by
  exact
    Theorem31.lmms31_query_lower_bound_from_swapped_pair_certificate
      transcript output Optimal u v htranscript hnoCommon

/--
Theorem 3.1 hard-family certificate: if the paper hard-family construction has
more instances than deterministic transcripts, every hard instance has an
envy-free allocation, and collided transcripts have no common envy-free
allocation, then no deterministic algorithm can return an optimal output on
all hard instances whenever optimality implies envy-freeness for this family.
-/
theorem paper_lmms_theorem_3_1_hard_family_query_lower_bound
    {Agent Item Instance Transcript : Type*}
    [Fintype Instance] [Fintype Transcript] [DecidableEq Item]
    (C : Theorem31.LMMS31HardFamilyCertificate
      Agent Item Instance Transcript)
    (output : Transcript → Allocation Agent Item)
    (Optimal : Instance → Allocation Agent Item → Prop)
    (hOptimal_envyFree :
      ∀ i A, Optimal i A →
        IsAllocationOf A C.goods ∧ ReportEnvyFree (C.report i) A)
    (hcard : Fintype.card Transcript < Fintype.card Instance) :
    ¬ ∀ i, Optimal i (output (C.transcript i)) := by
  exact
    Theorem31.lmms31_query_lower_bound_of_hard_family_certificate
      C output Optimal hOptimal_envyFree hcard

/--
Theorem 3.1 minimum-envy hard-family specialization: the source hard-family
certificate rules out deterministic algorithms that always return a
minimum-envy allocation on the hard family.
-/
theorem paper_lmms_theorem_3_1_minimum_envy_query_lower_bound
    {Agent Item Instance Transcript : Type*}
    [Fintype Agent] [Nonempty Agent]
    [Fintype Instance] [Fintype Transcript] [DecidableEq Item]
    (C : Theorem31.LMMS31HardFamilyCertificate
      Agent Item Instance Transcript)
    (output : Transcript → Allocation Agent Item)
    (hcard : Fintype.card Transcript < Fintype.card Instance) :
    ¬ ∀ i,
      MinimumReportEnvyAllocation
        (C.report i) C.goods (output (C.transcript i)) := by
  exact
    Theorem31.lmms31_minimum_envy_query_lower_bound_of_hard_family_certificate
      C output hcard

/--
Theorem 3.1 minimum-envy-ratio hard-family specialization: using the
multiplicative ratio objective, the source hard-family certificate rules out
deterministic algorithms that always return a minimum-ratio allocation.
-/
theorem paper_lmms_theorem_3_1_minimum_envy_ratio_query_lower_bound
    {Agent Item Instance Transcript : Type*}
    [Fintype Instance] [Fintype Transcript] [DecidableEq Item]
    (C : Theorem31.LMMS31HardFamilyCertificate
      Agent Item Instance Transcript)
    (output : Transcript → Allocation Agent Item)
    (hcard : Fintype.card Transcript < Fintype.card Instance) :
    ¬ ∀ i,
      Theorem31.MinimumReportEnvyRatioAllocation
        (C.report i) C.goods (output (C.transcript i)) := by
  exact
    Theorem31.lmms31_minimum_envy_ratio_query_lower_bound_of_hard_family_certificate
      C output hcard

/--
Theorem 3.1 source swapped-pair minimum-envy obstruction: for the explicit
two-player hard functions from the paper, if the crossed profiles `(u,v)` and
`(v,u)` have the same deterministic transcript, the same output cannot be a
minimum-envy allocation for both profiles.
-/
theorem paper_lmms_theorem_3_1_minimum_envy_swapped_cross_pair
    {Item Transcript : Type*} [Fintype Item] [DecidableEq Item] {k : ℕ}
    (hcard_items : Fintype.card Item = 2 * k)
    (u v : Theorem31.LMMS31HardFunction Item k)
    (hdisagree :
      ∃ S : Finset Item, S.card = k ∧ u.val S = 1 ∧ v.val S = 0)
    (transcript : Theorem31.LMMS31Agent → Transcript)
    (output : Transcript → Allocation Theorem31.LMMS31Agent Item)
    (htranscript :
      transcript (0 : Theorem31.LMMS31Agent) =
        transcript (1 : Theorem31.LMMS31Agent)) :
    ¬ ∀ inst : Theorem31.LMMS31Agent,
      MinimumReportEnvyAllocation
        (Theorem31.lmms31SwappedCrossReport u v inst)
        (Finset.univ : Finset Item)
        (output (transcript inst)) := by
  exact
    Theorem31.lmms31_minimum_envy_query_lower_bound_of_swapped_cross_pair
      hcard_items u v hdisagree transcript output htranscript

/--
Theorem 3.1 source swapped-pair minimum-envy-ratio obstruction: the explicit
two-player hard profiles `(u,v)` and `(v,u)` cannot both receive a
minimum-ratio allocation from the same deterministic transcript output.
-/
theorem paper_lmms_theorem_3_1_minimum_envy_ratio_swapped_cross_pair
    {Item Transcript : Type*} [Fintype Item] [DecidableEq Item] {k : ℕ}
    (hcard_items : Fintype.card Item = 2 * k)
    (u v : Theorem31.LMMS31HardFunction Item k)
    (hdisagree :
      ∃ S : Finset Item, S.card = k ∧ u.val S = 1 ∧ v.val S = 0)
    (transcript : Theorem31.LMMS31Agent → Transcript)
    (output : Transcript → Allocation Theorem31.LMMS31Agent Item)
    (htranscript :
      transcript (0 : Theorem31.LMMS31Agent) =
        transcript (1 : Theorem31.LMMS31Agent)) :
    ¬ ∀ inst : Theorem31.LMMS31Agent,
      Theorem31.MinimumReportEnvyRatioAllocation
        (Theorem31.lmms31SwappedCrossReport u v inst)
        (Finset.univ : Finset Item)
        (output (transcript inst)) := by
  exact
    Theorem31.lmms31_minimum_envy_ratio_query_lower_bound_of_swapped_cross_pair
      hcard_items u v hdisagree transcript output htranscript

/--
Theorem 3.1 counting support: a complement-pair presentation of the middle
layer generates exactly `2 ^ #pairs` distinct source hard utility functions.
-/
theorem paper_lmms_theorem_3_1_hard_function_family_card
    {Item : Type*} [Fintype Item] [DecidableEq Item] {k : ℕ}
    (C : Theorem31.LMMS31MiddleComplementPairs Item k) :
    (Theorem31.LMMS31MiddleComplementPairs.hardFunctionFamily C).card =
      2 ^ Fintype.card C.Pair := by
  exact
    Theorem31.LMMS31MiddleComplementPairs.hardFunctionFamily_card C

/--
Theorem 3.1 counting support: the source transcript-count comparison reduces
to the finite combinatorial inequality that the transcript space is smaller
than `2 ^ #pairs`.
-/
theorem paper_lmms_theorem_3_1_transcript_card_lt_hard_family_card
    {Item Transcript : Type*} [Fintype Item] [DecidableEq Item]
    [Fintype Transcript] {k : ℕ}
    (C : Theorem31.LMMS31MiddleComplementPairs Item k)
    (hlt : Fintype.card Transcript < 2 ^ Fintype.card C.Pair) :
    Fintype.card Transcript <
      (Theorem31.LMMS31MiddleComplementPairs.hardFunctionFamily C).card := by
  exact
    Theorem31.LMMS31MiddleComplementPairs.transcript_card_lt_hardFunctionFamily_card_iff
      C hlt

/--
Theorem 3.1 middle-pair counting assembly: if identical hard profiles have
fewer deterministic transcripts than middle-layer orientations, and identical
profile transcript collisions force equal crossed-profile transcripts, then no
deterministic output can be a minimum-envy allocation for every crossed hard
profile.
-/
theorem paper_lmms_theorem_3_1_minimum_envy_lower_bound_from_middle_pair_count
    {Item Transcript : Type*} [Fintype Item] [DecidableEq Item]
    [Fintype Transcript] {k : ℕ}
    (C : Theorem31.LMMS31MiddleComplementPairs Item k)
    (hcard_items : Fintype.card Item = 2 * k)
    (identicalTranscript : (C.Pair → Bool) → Transcript)
    (crossTranscript : (C.Pair → Bool) → (C.Pair → Bool) → Transcript)
    (output : Transcript → Allocation Theorem31.LMMS31Agent Item)
    (htranscript_bound : Fintype.card Transcript < 2 ^ Fintype.card C.Pair)
    (hcross_same :
      ∀ choice₁ choice₂,
        identicalTranscript choice₁ = identicalTranscript choice₂ →
          crossTranscript choice₁ choice₂ =
            crossTranscript choice₂ choice₁) :
    ¬ ∀ choice₁ choice₂,
      MinimumReportEnvyAllocation
        (Theorem31.lmms31CrossReport
          (C.hardFunctionOfMiddleChoice choice₁)
          (C.hardFunctionOfMiddleChoice choice₂))
