    fun i => Theorem34.commonLoad sourceValue (optimal i)
  let optMin : ℝ :=
    (Finset.univ : Finset SourceAgent).inf' Finset.univ_nonempty optLoad
  let optMax : ℝ :=
    (Finset.univ : Finset SourceAgent).sup' Finset.univ_nonempty optLoad
