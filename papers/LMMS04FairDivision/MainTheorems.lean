            Theorem34.loadRatio
              (Theorem34.minCommonLoad v C)
              (Theorem34.maxCommonLoad v C)) A →
          (¬ ∀ i : SourceAgent,
            Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (A i))) →
          ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i ∧ 0 < v g)
    (hgoods_nonneg : ∀ g : SourceItem, g ∈ goods → 0 ≤ v g)
    (hgoods_lt : ∀ g : SourceItem, g ∈ goods → v g < L) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        Theorem34.Claim34Certificate v L
          (fun A : Allocation SourceAgent SourceItem =>
            Theorem34.loadRatio
              (Theorem34.minCommonLoad v A)
              (Theorem34.maxCommonLoad v A))
          (fun A i => A i) B := by
  exact
    paper_lmms_claim_3_4_bounded_optimal_of_exact_allocations
      A₀ hA₀ hopt_alloc hL hgoods_load
      (by
        intro A hA hnot_bounded
        have halloc : IsAllocationOf A goods := hopt_alloc A hA
        exact
          Theorem34.minCommonLoad_pos_of_each_bundle_has_pos_good
            (v := v) (bundle := A)
            (hpositive_bundles A hA hnot_bounded)
            (by
              intro i g hg
              exact hgoods_nonneg g (isAllocationOf_mem_goods halloc hg)))
      hgoods_nonneg hgoods_lt

/--
Claim 3.4 exact-allocation assembly with positive goods and nonempty relevant
bundles: this replaces the raw positive-minimum premise by the source-shaped
obligation that every unbounded optimal allocation gives each agent at least
one good.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_of_exact_allocations_with_nonempty_positive_goods
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Fintype SourceItem] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ} {L : ℝ}
    (A₀ : Allocation SourceAgent SourceItem)
    (hA₀ :
      Theorem34.IsOptimalRatio
        (fun A : Allocation SourceAgent SourceItem =>
          Theorem34.loadRatio
            (Theorem34.minCommonLoad v A)
            (Theorem34.maxCommonLoad v A)) A₀)
    (hopt_alloc :
      ∀ A : Allocation SourceAgent SourceItem,
        Theorem34.IsOptimalRatio
          (fun C : Allocation SourceAgent SourceItem =>
            Theorem34.loadRatio
              (Theorem34.minCommonLoad v C)
              (Theorem34.maxCommonLoad v C)) A →
          IsAllocationOf A goods)
    (hL : 0 < L)
    (hgoods_load :
      Theorem34.commonLoad v goods = (Fintype.card SourceAgent : ℝ) * L)
    (hopt_owns :
      ∀ A : Allocation SourceAgent SourceItem,
        Theorem34.IsOptimalRatio
          (fun C : Allocation SourceAgent SourceItem =>
            Theorem34.loadRatio
              (Theorem34.minCommonLoad v C)
              (Theorem34.maxCommonLoad v C)) A →
          (¬ ∀ i : SourceAgent,
            Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (A i))) →
          ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i)
    (hgoods_pos : ∀ g : SourceItem, g ∈ goods → 0 < v g)
    (hgoods_lt : ∀ g : SourceItem, g ∈ goods → v g < L) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        Theorem34.Claim34Certificate v L
          (fun A : Allocation SourceAgent SourceItem =>
            Theorem34.loadRatio
              (Theorem34.minCommonLoad v A)
              (Theorem34.maxCommonLoad v A))
          (fun A i => A i) B := by
  exact
    paper_lmms_claim_3_4_bounded_optimal_of_exact_allocations_with_positive_bundles
      A₀ hA₀ hopt_alloc hL hgoods_load
      (by
        intro A hA hnot_bounded i
        rcases hopt_owns A hA hnot_bounded i with ⟨g, hg⟩
        exact
          ⟨g, hg, hgoods_pos g
            (isAllocationOf_mem_goods (hopt_alloc A hA) hg)⟩)
      (fun g hg => le_of_lt (hgoods_pos g hg))
      hgoods_lt

/--
Identical-utilities bridge: the model-level finite minimum load is the same as
the concrete Claim 3.4 minimum common load.
-/
theorem paper_lmms_theorem_3_3_minAllocationLoad_eq_minCommonLoad
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    (M : Theorem33.IdenticalUtilitiesModel SourceAgent SourceItem Alloc)
    (A : Alloc) :
    Theorem33.minAllocationLoad M A =
      Theorem34.minCommonLoad M.commonValue (M.bundleOf A) := by
  apply le_antisymm
  · rcases
      Theorem34.exists_commonLoad_eq_minCommonLoad
        (v := M.commonValue) (bundle := M.bundleOf A) with
      ⟨i, hi⟩
    have h := Theorem33.minAllocationLoad_le_load M A i
    simpa [Theorem33.allocationLoad, Theorem33.bundleLoad, hi] using h
  · unfold Theorem33.minAllocationLoad
    exact
      Finset.le_inf'
        (s := (Finset.univ : Finset SourceAgent))
        (f := Theorem33.allocationLoad M A)
        Finset.univ_nonempty
        (by
          intro i _hi
          simpa [Theorem33.allocationLoad, Theorem33.bundleLoad] using
            Theorem34.minCommonLoad_le
              (v := M.commonValue) (bundle := M.bundleOf A) i)

/--
Identical-utilities bridge: the model-level finite maximum load is the same as
the concrete Claim 3.4 maximum common load.
-/
theorem paper_lmms_theorem_3_3_maxAllocationLoad_eq_maxCommonLoad
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    (M : Theorem33.IdenticalUtilitiesModel SourceAgent SourceItem Alloc)
    (A : Alloc) :
    Theorem33.maxAllocationLoad M A =
      Theorem34.maxCommonLoad M.commonValue (M.bundleOf A) := by
  apply le_antisymm
  · unfold Theorem33.maxAllocationLoad
    exact
      Finset.sup'_le
        Finset.univ_nonempty
        (Theorem33.allocationLoad M A)
        (by
          intro i _hi
          simpa [Theorem33.allocationLoad, Theorem33.bundleLoad] using
            Theorem34.commonLoad_le_maxCommonLoad
              (v := M.commonValue) (bundle := M.bundleOf A) i)
  · rcases
      Theorem34.exists_commonLoad_eq_maxCommonLoad
        (v := M.commonValue) (bundle := M.bundleOf A) with
      ⟨i, hi⟩
    have h := Theorem33.load_le_maxAllocationLoad M A i
    simpa [Theorem33.allocationLoad, Theorem33.bundleLoad, hi] using h

/--
Model-level Claim-3.4 window projection: per-agent allocation-load windows
imply the corresponding finite min/max allocation-load windows.
-/
theorem paper_lmms_theorem_3_3_min_max_windows_of_allocation_load_windows
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    (M : Theorem33.IdenticalUtilitiesModel SourceAgent SourceItem Alloc)
    {L : ℝ} {A : Alloc}
    (hwindow :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem33.allocationLoad M A i)) :
    Theorem34.boundedAroundAverage L (Theorem33.minAllocationLoad M A) ∧
      Theorem34.boundedAroundAverage L (Theorem33.maxAllocationLoad M A) := by
  have hmin_window :
      Theorem34.boundedAroundAverage L (Theorem33.minAllocationLoad M A) := by
    rcases
        Theorem34.exists_commonLoad_eq_minCommonLoad
          (v := M.commonValue) (bundle := M.bundleOf A) with
      ⟨i, hi⟩
    have hi_window := hwindow i
    simpa [paper_lmms_theorem_3_3_minAllocationLoad_eq_minCommonLoad M A,
      Theorem33.allocationLoad, Theorem33.bundleLoad, ← hi] using hi_window
  have hmax_window :
      Theorem34.boundedAroundAverage L (Theorem33.maxAllocationLoad M A) := by
    rcases
        Theorem34.exists_commonLoad_eq_maxCommonLoad
          (v := M.commonValue) (bundle := M.bundleOf A) with
      ⟨i, hi⟩
    have hi_window := hwindow i
    simpa [paper_lmms_theorem_3_3_maxAllocationLoad_eq_maxCommonLoad M A,
      Theorem33.allocationLoad, Theorem33.bundleLoad, ← hi] using hi_window
  exact ⟨hmin_window, hmax_window⟩

/--
Theorem 3.3 rounded-instance search-certificate assembly from agentwise
additive transfer bounds and per-agent Claim-3.4 windows for the rounded and
optimal allocations.  The per-agent windows are projected to the min/max
windows required by the transfer algebra.
-/
theorem paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_agentwise_additive_transfer_with_allocation_windows
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {M : Theorem33.IdenticalUtilitiesModel SourceAgent SourceItem Alloc}
    {L epsilon : ℝ} {lambda : ℕ} {optimal rounded output : Alloc}
    (hepsilon_pos : 0 < epsilon) (hepsilon_le_one : epsilon ≤ 1)
    (hL : 0 < L)
    (pairSearch : Theorem33.RoundedValuePairSearchCertificate L lambda SourceAgent)
    (houtput_min : 0 < Theorem33.minAllocationLoad M output)
    (hrounded_window :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem33.allocationLoad M rounded i))
    (hopt_window :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem33.allocationLoad M optimal i))
    (hbackward_max_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M output i ≤
          Theorem33.allocationLoad M rounded i + L / (56 / epsilon))
    (hbackward_min_agent :
      ∀ i : SourceAgent,
        ((56 / epsilon) / ((56 / epsilon) + 1)) *
            Theorem33.allocationLoad M rounded i -
          (2 / (56 / epsilon)) * L ≤
            Theorem33.allocationLoad M output i)
    (hforward_max_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M rounded i ≤
          (((56 / epsilon) + 1) / (56 / epsilon)) *
              Theorem33.allocationLoad M optimal i +
            L / (56 / epsilon))
    (hforward_min_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M optimal i - L / (56 / epsilon) ≤
          Theorem33.allocationLoad M rounded i) :
    ∃ cert : Theorem33.RoundedInstanceSearchCertificate
        M L epsilon lambda optimal,
      cert.rounded = rounded ∧
        cert.output = output ∧
          cert.pairSearch = pairSearch ∧
            Theorem33.allocationLoadRatio M cert.output ≤
              Theorem33.allocationLoadRatio M optimal * (1 + epsilon) := by
  have hrounded_minmax :=
    paper_lmms_theorem_3_3_min_max_windows_of_allocation_load_windows
      M hrounded_window
  have hopt_minmax :=
    paper_lmms_theorem_3_3_min_max_windows_of_allocation_load_windows
      M hopt_window
  exact
    paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_agentwise_additive_transfer_with_bounded_min_max
      (M := M) (L := L) (epsilon := epsilon) (lambda := lambda)
      (optimal := optimal) (rounded := rounded) (output := output)
      hepsilon_pos hepsilon_le_one hL pairSearch houtput_min
      hrounded_minmax.1 hrounded_minmax.2 hopt_minmax.1 hopt_minmax.2
      hbackward_max_agent hbackward_min_agent hforward_max_agent
      hforward_min_agent

/--
Theorem 3.3 rounded-instance search-certificate assembly from agentwise
additive transfer bounds and per-agent Claim-3.4 windows, deriving the output
allocation's positive minimum load from the backward minimum transfer bound.
This removes a separate positivity premise from the transfer boundary.
-/
theorem paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_agentwise_additive_transfer_with_allocation_windows_of_backward_min
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {M : Theorem33.IdenticalUtilitiesModel SourceAgent SourceItem Alloc}
    {L epsilon : ℝ} {lambda : ℕ} {optimal rounded output : Alloc}
    (hepsilon_pos : 0 < epsilon) (hepsilon_le_one : epsilon ≤ 1)
    (hL : 0 < L)
    (pairSearch : Theorem33.RoundedValuePairSearchCertificate L lambda SourceAgent)
    (hrounded_window :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem33.allocationLoad M rounded i))
    (hopt_window :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem33.allocationLoad M optimal i))
    (hbackward_max_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M output i ≤
          Theorem33.allocationLoad M rounded i + L / (56 / epsilon))
    (hbackward_min_agent :
      ∀ i : SourceAgent,
        ((56 / epsilon) / ((56 / epsilon) + 1)) *
            Theorem33.allocationLoad M rounded i -
          (2 / (56 / epsilon)) * L ≤
            Theorem33.allocationLoad M output i)
    (hforward_max_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M rounded i ≤
          (((56 / epsilon) + 1) / (56 / epsilon)) *
              Theorem33.allocationLoad M optimal i +
            L / (56 / epsilon))
    (hforward_min_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M optimal i - L / (56 / epsilon) ≤
          Theorem33.allocationLoad M rounded i) :
    ∃ cert : Theorem33.RoundedInstanceSearchCertificate
        M L epsilon lambda optimal,
      cert.rounded = rounded ∧
        cert.output = output ∧
          cert.pairSearch = pairSearch ∧
            Theorem33.allocationLoadRatio M cert.output ≤
              Theorem33.allocationLoadRatio M optimal * (1 + epsilon) := by
  let transferLambda : ℝ := 56 / epsilon
  have hlambda_pos : 0 < transferLambda := by
    dsimp [transferLambda]
    positivity
  have hlambda_ge : 56 ≤ transferLambda := by
    dsimp [transferLambda]
    rw [le_div_iff₀ hepsilon_pos]
    nlinarith
  have hlower_pos :
      0 < transferLambda / (transferLambda + 1) - 4 / transferLambda :=
    Theorem35.backwardLowerFactor_pos_of_ge_56 hlambda_ge
  have houtput_load_pos :
      ∀ i : SourceAgent, 0 < Theorem33.allocationLoad M output i := by
    intro i
    have hrounded_pos : 0 < Theorem33.allocationLoad M rounded i := by
      have hi := (hrounded_window i).1
      nlinarith [hL, hi]
    have hrounded_half :
        L ≤ 2 * Theorem33.allocationLoad M rounded i := by
      have hi := (hrounded_window i).1
      nlinarith
    have hmin_transfer :
        Theorem33.allocationLoad M rounded i *
            (transferLambda / (transferLambda + 1) -
              4 / transferLambda) ≤
          Theorem33.allocationLoad M output i := by
      exact
        Theorem35.backward_min_transfer
          (lambda := transferLambda) (L := L)
          hlambda_pos hrounded_half
          (by
            simpa [transferLambda] using hbackward_min_agent i)
    exact
      lt_of_lt_of_le
        (mul_pos hrounded_pos hlower_pos) hmin_transfer
  have houtput_min : 0 < Theorem33.minAllocationLoad M output :=
    Theorem33.minAllocationLoad_pos_of_loads_pos
      M output houtput_load_pos
  exact
    paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_agentwise_additive_transfer_with_allocation_windows
      (M := M) (L := L) (epsilon := epsilon) (lambda := lambda)
      (optimal := optimal) (rounded := rounded) (output := output)
      hepsilon_pos hepsilon_le_one hL pairSearch houtput_min
      hrounded_window hopt_window hbackward_max_agent hbackward_min_agent
      hforward_max_agent hforward_min_agent

/--
Theorem 3.3 rounded-instance search-certificate assembly from Claim-3.4
certificates and agentwise additive transfer bounds.  The Claim-3.4
certificates provide the rounded and optimal per-agent load windows, while the
backward minimum transfer estimate supplies output positive minimum load.
-/
theorem paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_agentwise_additive_transfer_with_claim34_certificates_of_backward_min
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {M : Theorem33.IdenticalUtilitiesModel SourceAgent SourceItem Alloc}
    {L epsilon : ℝ} {lambda : ℕ} {optimal rounded output : Alloc}
    (hepsilon_pos : 0 < epsilon) (hepsilon_le_one : epsilon ≤ 1)
    (hL : 0 < L)
    (pairSearch : Theorem33.RoundedValuePairSearchCertificate L lambda SourceAgent)
    (hrounded_cert :
      Theorem34.Claim34Certificate M.commonValue L
        (Theorem33.allocationLoadRatio M) M.bundleOf rounded)
    (hopt_cert :
      Theorem34.Claim34Certificate M.commonValue L
        (Theorem33.allocationLoadRatio M) M.bundleOf optimal)
    (hbackward_max_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M output i ≤
          Theorem33.allocationLoad M rounded i + L / (56 / epsilon))
    (hbackward_min_agent :
      ∀ i : SourceAgent,
        ((56 / epsilon) / ((56 / epsilon) + 1)) *
            Theorem33.allocationLoad M rounded i -
          (2 / (56 / epsilon)) * L ≤
            Theorem33.allocationLoad M output i)
    (hforward_max_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M rounded i ≤
          (((56 / epsilon) + 1) / (56 / epsilon)) *
              Theorem33.allocationLoad M optimal i +
            L / (56 / epsilon))
    (hforward_min_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M optimal i - L / (56 / epsilon) ≤
          Theorem33.allocationLoad M rounded i) :
    ∃ cert : Theorem33.RoundedInstanceSearchCertificate
        M L epsilon lambda optimal,
      cert.rounded = rounded ∧
        cert.output = output ∧
          cert.pairSearch = pairSearch ∧
            Theorem33.allocationLoadRatio M cert.output ≤
              Theorem33.allocationLoadRatio M optimal * (1 + epsilon) := by
  exact
    paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_agentwise_additive_transfer_with_allocation_windows_of_backward_min
      (M := M) (L := L) (epsilon := epsilon) (lambda := lambda)
      (optimal := optimal) (rounded := rounded) (output := output)
      hepsilon_pos hepsilon_le_one hL pairSearch
      (by
        intro i
        simpa [Theorem33.allocationLoad, Theorem33.bundleLoad] using
          hrounded_cert.2 i)
      (by
        intro i
        simpa [Theorem33.allocationLoad, Theorem33.bundleLoad] using
          hopt_cert.2 i)
      hbackward_max_agent hbackward_min_agent hforward_max_agent
      hforward_min_agent

/--
Theorem 3.3 source/rounded load-function transfer: if a source output
allocation, a source optimum, and a rounded allocation have per-agent additive
transfer bounds, then the source output ratio is within `(1 + epsilon)` of the
source optimum ratio.  The source and rounded allocations may use different
item types; only their load functions share the same finite agent set.
-/
theorem paper_lmms_theorem_3_3_source_output_ratio_transfer_of_rounded_allocation
    {SourceAgent SourceItem RoundedItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent] [DecidableEq SourceItem]
    {L epsilon : ℝ}
    (sourceValue : SourceItem → ℝ) (roundedValue : RoundedItem → ℝ)
    {sourceGoods : Finset SourceItem}
    {optimal output : Allocation SourceAgent SourceItem}
    {rounded : Allocation SourceAgent RoundedItem}
    (hepsilon_pos : 0 < epsilon) (hepsilon_le_one : epsilon ≤ 1)
    (hL : 0 < L)
    (houtput_alloc : IsAllocationOf output sourceGoods)
    (houtput_min :
      0 < (Finset.univ : Finset SourceAgent).inf' Finset.univ_nonempty
        (fun i => Theorem34.commonLoad sourceValue (output i)))
    (hrounded_window :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem34.commonLoad roundedValue (rounded i)))
    (hopt_window :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem34.commonLoad sourceValue (optimal i)))
    (hbackward_max_agent :
      ∀ i : SourceAgent,
        Theorem34.commonLoad sourceValue (output i) ≤
          Theorem34.commonLoad roundedValue (rounded i) +
            L / (56 / epsilon))
    (hbackward_min_agent :
      ∀ i : SourceAgent,
        ((56 / epsilon) / ((56 / epsilon) + 1)) *
            Theorem34.commonLoad roundedValue (rounded i) -
          (2 / (56 / epsilon)) * L ≤
            Theorem34.commonLoad sourceValue (output i))
    (hforward_max_agent :
      ∀ i : SourceAgent,
        Theorem34.commonLoad roundedValue (rounded i) ≤
          (((56 / epsilon) + 1) / (56 / epsilon)) *
              Theorem34.commonLoad sourceValue (optimal i) +
            L / (56 / epsilon))
    (hforward_min_agent :
      ∀ i : SourceAgent,
        Theorem34.commonLoad sourceValue (optimal i) -
            L / (56 / epsilon) ≤
          Theorem34.commonLoad roundedValue (rounded i)) :
    IsAllocationOf output sourceGoods ∧
      Theorem35.ratio
          ((Finset.univ : Finset SourceAgent).inf'
            Finset.univ_nonempty
            (fun i => Theorem34.commonLoad sourceValue (output i)))
          ((Finset.univ : Finset SourceAgent).sup'
            Finset.univ_nonempty
            (fun i => Theorem34.commonLoad sourceValue (output i))) ≤
        Theorem35.ratio
            ((Finset.univ : Finset SourceAgent).inf'
              Finset.univ_nonempty
              (fun i => Theorem34.commonLoad sourceValue (optimal i)))
            ((Finset.univ : Finset SourceAgent).sup'
              Finset.univ_nonempty
              (fun i => Theorem34.commonLoad sourceValue (optimal i))) *
          (1 + epsilon) := by
  classical
  let optLoad : SourceAgent → ℝ :=
    fun i => Theorem34.commonLoad sourceValue (optimal i)
  let roundedLoad : SourceAgent → ℝ :=
    fun i => Theorem34.commonLoad roundedValue (rounded i)
  let outLoad : SourceAgent → ℝ :=
    fun i => Theorem34.commonLoad sourceValue (output i)
  have hroundedMin :
      0 < (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty roundedLoad := by
    rw [Finset.lt_inf'_iff]
    intro i _hi
    have hi := (hrounded_window i).1
    dsimp [roundedLoad]
    nlinarith [hL, hi]
  have hoptMin :
      0 < (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty optLoad := by
    rw [Finset.lt_inf'_iff]
    intro i _hi
    have hi := (hopt_window i).1
    dsimp [optLoad]
    nlinarith [hL, hi]
  have hoptMax :
      0 ≤ (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty optLoad := by
    let i0 : SourceAgent := Classical.choice (inferInstance : Nonempty SourceAgent)
    have hload_nonneg : 0 ≤ optLoad i0 := by
      have hi := (hopt_window i0).1
      dsimp [optLoad]
      nlinarith [hL, hi]
    exact
      le_trans hload_nonneg
        (Finset.le_sup'
          (s := (Finset.univ : Finset SourceAgent))
          (f := optLoad)
          (by simp [i0] : i0 ∈ (Finset.univ : Finset SourceAgent)))
  have hroundedMax_nonneg :
      0 ≤ (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty roundedLoad := by
    let i0 : SourceAgent := Classical.choice (inferInstance : Nonempty SourceAgent)
    have hload_nonneg : 0 ≤ roundedLoad i0 := by
      have hi := (hrounded_window i0).1
      dsimp [roundedLoad]
      nlinarith [hL, hi]
    exact
      le_trans hload_nonneg
        (Finset.le_sup'
          (s := (Finset.univ : Finset SourceAgent))
          (f := roundedLoad)
          (by simp [i0] : i0 ∈ (Finset.univ : Finset SourceAgent)))
  have hroundedMin_half :
      L ≤ 2 * (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty roundedLoad := by
    have hhalf :
        L / 2 ≤ (Finset.univ : Finset SourceAgent).inf'
          Finset.univ_nonempty roundedLoad := by
      apply Finset.le_inf'
      intro i _hi
      have hi := (hrounded_window i).1
      dsimp [roundedLoad]
      linarith
    nlinarith
  have hroundedMax_half :
      L ≤ 2 * (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty roundedLoad := by
    let i0 : SourceAgent := Classical.choice (inferInstance : Nonempty SourceAgent)
    have hi := (hrounded_window i0).1
    have hle :
        roundedLoad i0 ≤
          (Finset.univ : Finset SourceAgent).sup'
            Finset.univ_nonempty roundedLoad :=
      Finset.le_sup'
        (s := (Finset.univ : Finset SourceAgent))
        (f := roundedLoad)
        (by simp [i0] : i0 ∈ (Finset.univ : Finset SourceAgent))
    dsimp [roundedLoad] at hle
    nlinarith
  have hoptMin_half :
      L ≤ 2 * (Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty optLoad := by
    have hhalf :
        L / 2 ≤ (Finset.univ : Finset SourceAgent).inf'
          Finset.univ_nonempty optLoad := by
      apply Finset.le_inf'
      intro i _hi
      have hi := (hopt_window i).1
      dsimp [optLoad]
      linarith
    nlinarith
  have hoptMax_half :
      L ≤ 2 * (Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty optLoad := by
    let i0 : SourceAgent := Classical.choice (inferInstance : Nonempty SourceAgent)
    have hi := (hopt_window i0).1
    have hle :
        optLoad i0 ≤
