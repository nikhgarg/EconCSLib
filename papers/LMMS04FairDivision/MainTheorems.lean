/--
Claim 3.4 with exact finite allocations: `IsAllocationOf` supplies the
ownership, item-domain, average-load, and canonical `moveBundle` plumbing
required by the concrete min/max source-data assembly.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_of_exact_allocations
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Fintype SourceItem] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ} {L : ℝ}
    (A₀ : Allocation SourceAgent SourceItem)
    (hA₀ :
      Theorem34.IsOptimalRatio
        (fun A : Allocation SourceAgent SourceItem =>
          Theorem34.loadRatio
            (Theorem34.minCommonLoad v A)
            (Theorem34.maxCommonLoad v A)) A₀)
    (hopt_alloc :
      ∀ A : Allocation SourceAgent SourceItem,
        Theorem34.IsOptimalRatio
          (fun C : Allocation SourceAgent SourceItem =>
            Theorem34.loadRatio
              (Theorem34.minCommonLoad v C)
              (Theorem34.maxCommonLoad v C)) A →
          IsAllocationOf A goods)
    (hL : 0 < L)
    (hgoods_load :
      Theorem34.commonLoad v goods = (Fintype.card SourceAgent : ℝ) * L)
    (hmin_pos :
      ∀ A : Allocation SourceAgent SourceItem,
        Theorem34.IsOptimalRatio
          (fun C : Allocation SourceAgent SourceItem =>
            Theorem34.loadRatio
              (Theorem34.minCommonLoad v C)
              (Theorem34.maxCommonLoad v C)) A →
          (¬ ∀ i : SourceAgent,
            Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (A i))) →
          0 < Theorem34.minCommonLoad v A)
    (hgoods_nonneg : ∀ g : SourceItem, g ∈ goods → 0 ≤ v g)
    (hgoods_lt : ∀ g : SourceItem, g ∈ goods → v g < L) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        Theorem34.Claim34Certificate v L
          (fun A : Allocation SourceAgent SourceItem =>
            Theorem34.loadRatio
              (Theorem34.minCommonLoad v A)
              (Theorem34.maxCommonLoad v A))
          (fun A i => A i) B := by
  classical
  let ratioOf : Allocation SourceAgent SourceItem → ℝ :=
    fun A =>
      Theorem34.loadRatio
        (Theorem34.minCommonLoad v A)
        (Theorem34.maxCommonLoad v A)
  rcases
    Theorem34.claim34_certificate_of_branching_potential_descent
      (v := v) (L := L) (ratioOf := ratioOf)
      (bundleOf := fun A : Allocation SourceAgent SourceItem => A)
      (fun A : Allocation SourceAgent SourceItem => Theorem34.minCommonLoad v A)
      A₀ hA₀
      (by
        intro A hA hnot_bounded
        have halloc : IsAllocationOf A goods := hopt_alloc A hA
        have havg :
            (∑ i : SourceAgent, Theorem34.commonLoad v (A i)) =
              (Fintype.card SourceAgent : ℝ) * L := by
          rw [← hgoods_load]
          simpa [Theorem34.commonLoad] using
            paper_lmms_isAllocationOf_sum_bundle_values_eq_sum_goods
              (A := A) (goods := goods) (v := v) halloc
        exact
          Theorem34.claim34_branch_step_of_minmax_source_trichotomy
            (v := v) (L := L) (ratioOf := ratioOf)
            (bundleOf := fun A : Allocation SourceAgent SourceItem => A)
            (minOf := fun A : Allocation SourceAgent SourceItem =>
              Theorem34.minCommonLoad v A)
            (maxOf := fun A : Allocation SourceAgent SourceItem =>
              Theorem34.maxCommonLoad v A)
            (fun A source target g => Theorem34.moveBundle A source target g)
            (A := A)
            (minLoad := Theorem34.minCommonLoad v A)
            (maxLoad := Theorem34.maxCommonLoad v A)
            hL havg
            (fun C i => Theorem34.minCommonLoad_le (v := v) (bundle := C) i)
            (fun C => Theorem34.exists_commonLoad_eq_minCommonLoad (v := v) (bundle := C))
            (fun C i => Theorem34.commonLoad_le_maxCommonLoad (v := v) (bundle := C) i)
            (fun C => Theorem34.exists_commonLoad_eq_maxCommonLoad (v := v) (bundle := C))
            rfl rfl (hmin_pos A hA hnot_bounded) hnot_bounded
            (by
              intro i g hg
              exact hgoods_nonneg g (isAllocationOf_mem_goods halloc hg))
            (by
              intro i g hg
              exact hgoods_lt g (isAllocationOf_mem_goods halloc hg))
            (by
              intro i j g hi hj
              have hgoods : g ∈ goods := isAllocationOf_mem_goods halloc hi
              exact isAllocationOf_owner_unique halloc hgoods hi hj)
            (by intro C; rfl)
            (by intro source target g; rfl)) with
    ⟨B, hcert⟩
  exact ⟨B, hopt_alloc B hcert.1, hcert⟩

