theorem paper_lmms_theorem_3_3_rounded_types_in_value_window_with_cap_card_le
    {L LR : ℝ} {lambda maxCount : ℕ} (lower upper : ℝ) :
    (Theorem33.roundedTypesInValueWindowWithCap
        L LR lambda maxCount lower upper).card ≤
      (maxCount + 1) ^
        Fintype.card (Theorem33.RoundedValueIndex lambda) := by
