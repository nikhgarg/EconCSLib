/--
Low-owner estimates from an exact allocation of the materialized aggregated
low artificial goods.  This removes the external low-rounded total premise by
deriving it from exact allocation of the artificial supply.
-/
theorem paper_lmms_exists_low_goods_owner_load_estimates_of_exact_aggregated_low_supply_allocation
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ)
    (lowRounded :
      Allocation SourceAgent
        (paper_lmms_theorem_3_3_roundedSupplyItem
          (Theorem33.lowGoodsAggregatedSupply L lambda
            (lowGoods.sum sourceValue))))
    (hlowRounded_alloc :
      IsAllocationOf lowRounded
        (Finset.univ :
          Finset
            (paper_lmms_theorem_3_3_roundedSupplyItem
              (Theorem33.lowGoodsAggregatedSupply L lambda
                (lowGoods.sum sourceValue)))))
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hlow_nonneg :
      ∀ g : SourceItem, g ∈ lowGoods → 0 ≤ sourceValue g)
    (hlow_item_lt :
      ∀ g : SourceItem, g ∈ lowGoods →
        sourceValue g < L / (lambda : ℝ)) :
    ∃ owner : SourceItem → SourceAgent,
      (∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i).sum sourceValue ≤
          Theorem34.commonLoad
              (paper_lmms_theorem_3_3_roundedSupplyValue L lambda)
              (lowRounded i) +
            L / (lambda : ℝ)) ∧
        ∀ i : SourceAgent,
          Theorem34.commonLoad
              (paper_lmms_theorem_3_3_roundedSupplyValue L lambda)
              (lowRounded i) -
              L / (lambda : ℝ) ≤
            (lowGoods.filter fun g => owner g = i).sum sourceValue := by
  classical
  let lowRoundedLoad : SourceAgent → ℝ :=
    fun i =>
      Theorem34.commonLoad
        (paper_lmms_theorem_3_3_roundedSupplyValue L lambda) (lowRounded i)
  have hlowRounded_nonneg : ∀ i : SourceAgent, 0 ≤ lowRoundedLoad i := by
    intro i
    exact
      Finset.sum_nonneg
        (fun item _hitem =>
          le_of_lt
            (paper_lmms_theorem_3_3_roundedSupplyValue_pos
              (L := L) (lambda := lambda)
              (supply :=
                Theorem33.lowGoodsAggregatedSupply L lambda
                  (lowGoods.sum sourceValue))
              hlambda hL item))
  have hlowRounded_total :
      (∑ i : SourceAgent, lowRoundedLoad i) =
        ∑ k : Theorem33.RoundedValueIndex lambda,
          (Theorem33.lowGoodsAggregatedSupply L lambda
              (lowGoods.sum sourceValue) k : ℝ) *
            Theorem33.roundedValue L lambda k := by
    simpa [lowRoundedLoad] using
      paper_lmms_theorem_3_3_lowGoodsAggregatedSupplyAllocation_total_load_eq_weighted_supply
        (L := L) (lambda := lambda)
        lowGoods sourceValue lowRounded hlowRounded_alloc
  simpa [lowRoundedLoad] using
    paper_lmms_exists_low_goods_owner_load_estimates_of_aggregated_lowRoundedLoad
      lowGoods sourceValue lowRoundedLoad hlambda hL hlow_nonneg
      hlow_item_lt hlowRounded_nonneg hlowRounded_total

/--
Provenance-carrying materialization of the paper's combined high/low rounded
supply.  Left items are original high source goods, while right items are the
artificial low goods generated by `lowGoodsAggregatedSupply`.
-/
noncomputable abbrev paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
    {SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ) :=
  Sum {g : SourceItem // g ∈ highGoods}
    (paper_lmms_theorem_3_3_roundedSupplyItem
      (Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum sourceValue)))

/-- Rounded index of a provenance-carrying combined high/low supply item. -/
noncomputable def paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf
    {SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    {highGoods lowGoods : Finset SourceItem} {sourceValue : SourceItem → ℝ}
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (item :
      paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
        (L := L) (lambda := lambda) highGoods lowGoods sourceValue) :
    Theorem33.RoundedValueIndex lambda :=
  match item with
  | Sum.inl g => indexOf g.1
  | Sum.inr lowItem =>
      paper_lmms_theorem_3_3_roundedSupplyIndexOf
        (supply :=
          Theorem33.lowGoodsAggregatedSupply L lambda
            (lowGoods.sum sourceValue))
        lowItem

/-- Rounded value of a provenance-carrying combined high/low supply item. -/
noncomputable def paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue
    {SourceItem : Type*} (L : ℝ) {lambda : ℕ}
    {highGoods lowGoods : Finset SourceItem} {sourceValue : SourceItem → ℝ}
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (item :
      paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
        (L := L) (lambda := lambda) highGoods lowGoods sourceValue) : ℝ :=
  Theorem33.roundedValue L lambda
    (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf
      (L := L) (lambda := lambda)
      (highGoods := highGoods) (lowGoods := lowGoods)
      (sourceValue := sourceValue) indexOf item)

/--
The provenance-carrying combined materialization has exactly the paper's
combined high-source plus low-artificial rounded supply vector.
-/
theorem paper_lmms_theorem_3_3_typedCombinedHighLowSupply_goodsSupply_eq
    {SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (k : Theorem33.RoundedValueIndex lambda) :
    paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf
          (L := L) (lambda := lambda)
          (highGoods := highGoods) (lowGoods := lowGoods)
          (sourceValue := sourceValue) indexOf)
        (Finset.univ :
          Finset
            (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
              (L := L) (lambda := lambda)
              highGoods lowGoods sourceValue)) k =
      paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods k +
        Theorem33.lowGoodsAggregatedSupply L lambda
          (lowGoods.sum sourceValue) k := by
  classical
  let lowSupply : Theorem33.RoundedValueIndex lambda → ℕ :=
    Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum sourceValue)
  let Combined :=
    paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
      (L := L) (lambda := lambda) highGoods lowGoods sourceValue
  let typedIndex : Combined → Theorem33.RoundedValueIndex lambda :=
    paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf
      (L := L) (lambda := lambda)
      (highGoods := highGoods) (lowGoods := lowGoods)
      (sourceValue := sourceValue) indexOf
  let lowIndex :
      paper_lmms_theorem_3_3_roundedSupplyItem lowSupply →
        Theorem33.RoundedValueIndex lambda :=
    paper_lmms_theorem_3_3_roundedSupplyIndexOf (supply := lowSupply)
  let e :
      {item : Combined // typedIndex item = k} ≃
        Sum
          {g : {g : SourceItem // g ∈ highGoods} // indexOf g.1 = k}
          {item : paper_lmms_theorem_3_3_roundedSupplyItem lowSupply //
            lowIndex item = k} :=
    {
    toFun item := by
      rcases item with ⟨item, hitem⟩
      cases item with
      | inl g =>
          exact Sum.inl ⟨g, by simpa [typedIndex,
            paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf]
            using hitem⟩
      | inr lowItem =>
          exact Sum.inr ⟨lowItem, by simpa [typedIndex, lowIndex,
            paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf]
            using hitem⟩
    invFun item := by
      cases item with
      | inl g =>
          exact ⟨Sum.inl g.1, by simpa [typedIndex,
            paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf]
            using g.2⟩
      | inr lowItem =>
          exact ⟨Sum.inr lowItem.1, by simpa [typedIndex, lowIndex,
            paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf]
            using lowItem.2⟩
    left_inv item := by
      rcases item with ⟨item, hitem⟩
      cases item <;> rfl
    right_inv item := by
      cases item <;> rfl
    }
  have hsplit :
      Fintype.card {item : Combined // typedIndex item = k} =
        Fintype.card
            {g : {g : SourceItem // g ∈ highGoods} // indexOf g.1 = k} +
          Fintype.card
            {item : paper_lmms_theorem_3_3_roundedSupplyItem lowSupply //
              lowIndex item = k} := by
    simpa using Fintype.card_congr e
  have hhigh_card :
      Fintype.card
          {g : {g : SourceItem // g ∈ highGoods} // indexOf g.1 = k} =
        (highGoods.filter fun g => indexOf g = k).card := by
    rw [Fintype.card_subtype]
    refine Finset.card_bij (fun x _ => x.1) ?_ ?_ ?_
    · intro x hx
      rw [Finset.mem_filter] at hx ⊢
      exact ⟨x.2, hx.2⟩
    · intro x _ y _ hxy
      exact Subtype.ext hxy
    · intro y hy
      rw [Finset.mem_filter] at hy
      refine ⟨⟨y, hy.1⟩, ?_, rfl⟩
      rw [Finset.mem_filter]
      exact ⟨Finset.mem_univ _, hy.2⟩
  have hlow_card :
      Fintype.card
          {item : paper_lmms_theorem_3_3_roundedSupplyItem lowSupply //
            lowIndex item = k} =
        lowSupply k := by
    have hfilter :
        ((Finset.univ :
            Finset (paper_lmms_theorem_3_3_roundedSupplyItem lowSupply)).filter
            (fun item => lowIndex item = k)).card =
          lowSupply k := by
      simpa [lowSupply, lowIndex] using
        paper_lmms_theorem_3_3_roundedGoodsSupplyOfSupply_eq
          (Theorem33.lowGoodsAggregatedSupply L lambda
            (lowGoods.sum sourceValue)) k
    exact (Fintype.card_subtype (fun item :
      paper_lmms_theorem_3_3_roundedSupplyItem lowSupply =>
        lowIndex item = k)).trans hfilter
  rw [paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods]
  change
    ((Finset.univ : Finset Combined).filter fun item => typedIndex item = k).card =
      (highGoods.filter fun g => indexOf g = k).card + lowSupply k
  rw [← Fintype.card_subtype (fun item : Combined => typedIndex item = k)]
  rw [hsplit, hhigh_card, hlow_card]

/--
Total rounded value of the provenance-carrying combined materialization splits
into the high source rounded value plus the aggregated low artificial value.
-/
theorem paper_lmms_theorem_3_3_typedCombinedHighLowSupply_value_sum_eq_high_low_weighted_sum
    {SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda) :
    (∑ item :
        paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue,
        paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue
          (L := L) (lambda := lambda)
          (highGoods := highGoods) (lowGoods := lowGoods)
          (sourceValue := sourceValue) indexOf item) =
      highGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
        ∑ k : Theorem33.RoundedValueIndex lambda,
          (Theorem33.lowGoodsAggregatedSupply L lambda
              (lowGoods.sum sourceValue) k : ℝ) *
            Theorem33.roundedValue L lambda k := by
  classical
  let lowSupply : Theorem33.RoundedValueIndex lambda → ℕ :=
    Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum sourceValue)
  let Combined :=
    paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
      (L := L) (lambda := lambda) highGoods lowGoods sourceValue
  let typedIndex : Combined → Theorem33.RoundedValueIndex lambda :=
    paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf
      (L := L) (lambda := lambda)
      (highGoods := highGoods) (lowGoods := lowGoods)
      (sourceValue := sourceValue) indexOf
  have htyped_weighted :
      (∑ k : Theorem33.RoundedValueIndex lambda,
          (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods typedIndex
              (Finset.univ : Finset Combined) k : ℝ) *
            Theorem33.roundedValue L lambda k) =
        (Finset.univ : Finset Combined).sum
          (fun item => Theorem33.roundedValue L lambda (typedIndex item)) :=
    paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_weighted_sum_eq_sum_goods
      (L := L) typedIndex (Finset.univ : Finset Combined)
  have hhigh_weighted :
      (∑ k : Theorem33.RoundedValueIndex lambda,
          (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods k : ℝ) *
            Theorem33.roundedValue L lambda k) =
        highGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) :=
    paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_weighted_sum_eq_sum_goods
      (L := L) indexOf highGoods
  calc
    (∑ item : Combined,
        paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue
          (L := L) (lambda := lambda)
          (highGoods := highGoods) (lowGoods := lowGoods)
          (sourceValue := sourceValue) indexOf item)
        =
      (Finset.univ : Finset Combined).sum
        (fun item => Theorem33.roundedValue L lambda (typedIndex item)) := by
          simp [paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue,
            typedIndex]
    _ =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods typedIndex
            (Finset.univ : Finset Combined) k : ℝ) *
          Theorem33.roundedValue L lambda k := htyped_weighted.symm
    _ =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        ((paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods k +
            lowSupply k : ℕ) : ℝ) *
          Theorem33.roundedValue L lambda k := by
          apply Finset.sum_congr rfl
          intro k _hk
          rw [paper_lmms_theorem_3_3_typedCombinedHighLowSupply_goodsSupply_eq
            (L := L) (lambda := lambda) highGoods lowGoods sourceValue indexOf k]
    _ =
        (∑ k : Theorem33.RoundedValueIndex lambda,
          (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods k : ℝ) *
            Theorem33.roundedValue L lambda k) +
        (∑ k : Theorem33.RoundedValueIndex lambda,
          (lowSupply k : ℝ) * Theorem33.roundedValue L lambda k) := by
          simp [Nat.cast_add, add_mul, Finset.sum_add_distrib]
    _ =
      highGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
        ∑ k : Theorem33.RoundedValueIndex lambda,
          (Theorem33.lowGoodsAggregatedSupply L lambda
              (lowGoods.sum sourceValue) k : ℝ) *
            Theorem33.roundedValue L lambda k := by
          rw [hhigh_weighted]

/--
The provenance-carrying combined materialization satisfies the same total
rounded-value bounds as the paper's anonymous combined supply vector.
-/
theorem paper_lmms_theorem_3_3_typedCombinedHighLowSupply_value_bounds
    {SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        sourceValue g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            sourceValue g + L / ((lambda : ℝ) ^ 2))
    (hlow_nonneg :
      ∀ g : SourceItem, g ∈ lowGoods → 0 ≤ sourceValue g) :
    highGoods.sum sourceValue + lowGoods.sum sourceValue ≤
        ∑ item :
          paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
            (L := L) (lambda := lambda) highGoods lowGoods sourceValue,
          paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue
            (L := L) (lambda := lambda)
            (highGoods := highGoods) (lowGoods := lowGoods)
            (sourceValue := sourceValue) indexOf item ∧
      (∑ item :
          paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
            (L := L) (lambda := lambda) highGoods lowGoods sourceValue,
          paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue
            (L := L) (lambda := lambda)
            (highGoods := highGoods) (lowGoods := lowGoods)
            (sourceValue := sourceValue) indexOf item) <
        highGoods.sum sourceValue + lowGoods.sum sourceValue +
          (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
            L / (lambda : ℝ) := by
  classical
  have hsum_split :=
    paper_lmms_theorem_3_3_typedCombinedHighLowSupply_value_sum_eq_high_low_weighted_sum
      (L := L) (lambda := lambda) highGoods lowGoods sourceValue indexOf
  have hlowS_nonneg : 0 ≤ lowGoods.sum sourceValue :=
    Finset.sum_nonneg fun g hg => hlow_nonneg g hg
  have hlow_bounds :=
    Theorem33.lowGoodsAggregatedSupply_weighted_sum_bounds
      (L := L) (S := lowGoods.sum sourceValue) hlambda hL hlowS_nonneg
  have hhigh_lower :
      highGoods.sum sourceValue ≤
        highGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) :=
    Finset.sum_le_sum fun g hg => (hindex g hg).1
  have hhigh_upper :
      highGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) ≤
        highGoods.sum sourceValue +
          (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) := by
    calc
      highGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g))
          ≤ highGoods.sum
              (fun g => sourceValue g + L / ((lambda : ℝ) ^ 2)) := by
            exact Finset.sum_le_sum fun g hg => le_of_lt (hindex g hg).2
      _ =
          highGoods.sum sourceValue +
            (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) := by
            simp [Finset.sum_add_distrib, nsmul_eq_mul]
  constructor
  · rw [hsum_split]
    exact add_le_add hhigh_lower hlow_bounds.1
  · rw [hsum_split]
    have hsum_lt :
        highGoods.sum
              (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
            (∑ k : Theorem33.RoundedValueIndex lambda,
              (Theorem33.lowGoodsAggregatedSupply L lambda
                  (lowGoods.sum sourceValue) k : ℝ) *
                Theorem33.roundedValue L lambda k) <
          (highGoods.sum sourceValue +
              (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2))) +
            (lowGoods.sum sourceValue + L / (lambda : ℝ)) := by
      exact add_lt_add_of_le_of_lt hhigh_upper hlow_bounds.2
    linarith

/--
Project an allocation of provenance-carrying combined high/low items to the
source high goods owned by each agent.
-/
noncomputable def paper_lmms_theorem_3_3_typedCombinedHighPart
    {SourceAgent SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ)
    (A :
      Allocation SourceAgent
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue)) :
    Allocation SourceAgent SourceItem :=
  fun i =>
    highGoods.filter fun g =>
      if hg : g ∈ highGoods then
        Sum.inl (⟨g, hg⟩ : {g : SourceItem // g ∈ highGoods}) ∈ A i
      else
        False

/--
An exact allocation of the provenance-carrying combined materialization
projects to an exact allocation of the original high source goods.
-/
theorem paper_lmms_theorem_3_3_typedCombinedHighPart_isAllocationOf
    {SourceAgent SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ)
    (A :
      Allocation SourceAgent
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue))
    (halloc :
      IsAllocationOf A
        (Finset.univ :
          Finset
            (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
              (L := L) (lambda := lambda) highGoods lowGoods sourceValue))) :
    IsAllocationOf
      (paper_lmms_theorem_3_3_typedCombinedHighPart
        (L := L) (lambda := lambda) highGoods lowGoods sourceValue A)
      highGoods := by
  classical
  constructor
  · intro i g hg
    exact (Finset.mem_filter.mp hg).1
  · intro g hg
    let highItem :
        paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue :=
      Sum.inl (⟨g, hg⟩ : {g : SourceItem // g ∈ highGoods})
    rcases halloc.2 highItem (Finset.mem_univ highItem) with
      ⟨owner, howner, hunique⟩
    refine ⟨owner, ?_, ?_⟩
    · simp [paper_lmms_theorem_3_3_typedCombinedHighPart, highItem, hg,
        howner]
    · intro j hj
      have hitem : highItem ∈ A j := by
        have hjmem := (Finset.mem_filter.mp hj).2
        simpa [paper_lmms_theorem_3_3_typedCombinedHighPart, highItem, hg]
          using hjmem
      exact hunique j hitem

/--
Per-agent low rounded load carried by the artificial-low side of an allocation
of provenance-carrying combined high/low items.
-/
noncomputable def paper_lmms_theorem_3_3_typedCombinedLowRoundedLoad
    {SourceAgent SourceItem : Type*}
    {L : ℝ} {lambda : ℕ}
    {highGoods lowGoods : Finset SourceItem} {sourceValue : SourceItem → ℝ}
    (A :
      Allocation SourceAgent
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue))
    (i : SourceAgent) : ℝ :=
  (A i).sum fun item =>
    match item with
    | Sum.inl _ => 0
    | Sum.inr lowItem =>
        paper_lmms_theorem_3_3_roundedSupplyValue
          (L := L) (lambda := lambda)
          (supply :=
            Theorem33.lowGoodsAggregatedSupply L lambda
              (lowGoods.sum sourceValue))
          lowItem

/-- The artificial-low load extracted from typed combined items is nonnegative. -/
theorem paper_lmms_theorem_3_3_typedCombinedLowRoundedLoad_nonneg
    {SourceAgent SourceItem : Type*}
    {L : ℝ} {lambda : ℕ}
    {highGoods lowGoods : Finset SourceItem} {sourceValue : SourceItem → ℝ}
    (A :
      Allocation SourceAgent
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue))
    (hlambda : 0 < lambda) (hL : 0 < L) :
    ∀ i : SourceAgent,
      0 ≤ paper_lmms_theorem_3_3_typedCombinedLowRoundedLoad
        (L := L) (lambda := lambda)
        (highGoods := highGoods) (lowGoods := lowGoods)
        (sourceValue := sourceValue) A i := by
  classical
  intro i
  apply Finset.sum_nonneg
  intro item _hitem
  cases item with
  | inl g =>
      simp
  | inr lowItem =>
      exact
        le_of_lt
          (paper_lmms_theorem_3_3_roundedSupplyValue_pos
            (L := L) (lambda := lambda)
            (supply :=
              Theorem33.lowGoodsAggregatedSupply L lambda
                (lowGoods.sum sourceValue))
            hlambda hL lowItem)

/--
The total artificial-low load extracted from an exact typed combined allocation
is the weighted value of the low aggregated supply.
-/
theorem paper_lmms_theorem_3_3_typedCombinedLowRoundedLoad_total_eq_weighted_supply
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ)
    (A :
      Allocation SourceAgent
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue))
    (halloc :
      IsAllocationOf A
        (Finset.univ :
          Finset
            (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
              (L := L) (lambda := lambda) highGoods lowGoods sourceValue))) :
    (∑ i : SourceAgent,
        paper_lmms_theorem_3_3_typedCombinedLowRoundedLoad
          (L := L) (lambda := lambda)
          (highGoods := highGoods) (lowGoods := lowGoods)
          (sourceValue := sourceValue) A i) =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        (Theorem33.lowGoodsAggregatedSupply L lambda
            (lowGoods.sum sourceValue) k : ℝ) *
          Theorem33.roundedValue L lambda k := by
  classical
  let lowSupply : Theorem33.RoundedValueIndex lambda → ℕ :=
    Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum sourceValue)
  let Combined :=
    paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
      (L := L) (lambda := lambda) highGoods lowGoods sourceValue
  let lowOnlyValue : Combined → ℝ :=
    fun item =>
      match item with
      | Sum.inl _ => 0
      | Sum.inr lowItem =>
          paper_lmms_theorem_3_3_roundedSupplyValue
            (L := L) (lambda := lambda) (supply := lowSupply) lowItem
  have hsum :=
    paper_lmms_isAllocationOf_sum_bundle_values_eq_sum_goods
      (A := A)
      (goods := (Finset.univ : Finset Combined))
      (v := lowOnlyValue)
      halloc
  have huniv_sum :
      (Finset.univ : Finset Combined).sum lowOnlyValue =
      ∑ item : paper_lmms_theorem_3_3_roundedSupplyItem lowSupply,
          paper_lmms_theorem_3_3_roundedSupplyValue
            (L := L) (lambda := lambda) (supply := lowSupply) item := by
    simp [Combined, lowOnlyValue, lowSupply,
      paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem]
  calc
    (∑ i : SourceAgent,
        paper_lmms_theorem_3_3_typedCombinedLowRoundedLoad
          (L := L) (lambda := lambda)
          (highGoods := highGoods) (lowGoods := lowGoods)
          (sourceValue := sourceValue) A i)
        =
      ∑ i : SourceAgent, (A i).sum lowOnlyValue := by
        apply Finset.sum_congr rfl
        intro i _hi
        rfl
    _ = (Finset.univ : Finset Combined).sum lowOnlyValue := hsum
    _ =
      ∑ item : paper_lmms_theorem_3_3_roundedSupplyItem lowSupply,
        paper_lmms_theorem_3_3_roundedSupplyValue
          (L := L) (lambda := lambda) (supply := lowSupply) item := huniv_sum
    _ =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        (Theorem33.lowGoodsAggregatedSupply L lambda
            (lowGoods.sum sourceValue) k : ℝ) *
          Theorem33.roundedValue L lambda k := by
        simpa [lowSupply] using
          paper_lmms_theorem_3_3_roundedSupplyValue_sum_eq_weighted_supply
            (L := L) (lambda := lambda)
            (Theorem33.lowGoodsAggregatedSupply L lambda
              (lowGoods.sum sourceValue))

/--
The projected high source bundle has the same rounded value as the high side of
the typed combined bundle.
-/
theorem paper_lmms_theorem_3_3_typedCombinedHighPart_sum_eq_highSide_sum
    {SourceAgent SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (A :
      Allocation SourceAgent
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue))
    (i : SourceAgent) :
    (paper_lmms_theorem_3_3_typedCombinedHighPart
        (L := L) (lambda := lambda) highGoods lowGoods sourceValue A i).sum
        (fun g => Theorem33.roundedValue L lambda (indexOf g)) =
      (A i).sum
        (fun item =>
          match item with
          | Sum.inl g => Theorem33.roundedValue L lambda (indexOf g.1)
          | Sum.inr _ => 0) := by
  classical
  let highOnlyValue :
      paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
        (L := L) (lambda := lambda) highGoods lowGoods sourceValue → ℝ :=
    fun item =>
      match item with
      | Sum.inl g => Theorem33.roundedValue L lambda (indexOf g.1)
      | Sum.inr _ => 0
  let highSide :
      Finset
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue) :=
    (A i).filter fun item =>
      match item with
      | Sum.inl _ => True
      | Sum.inr _ => False
  have hsum_filter :
      highSide.sum highOnlyValue = (A i).sum highOnlyValue := by
    dsimp [highSide]
    rw [Finset.sum_filter]
    apply Finset.sum_congr rfl
    intro item _hitem
    cases item <;> simp [highOnlyValue]
  have hsum_bij :
      (paper_lmms_theorem_3_3_typedCombinedHighPart
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue A i).sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) =
        highSide.sum highOnlyValue := by
    refine Finset.sum_bij
      (s :=
        paper_lmms_theorem_3_3_typedCombinedHighPart
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue A i)
      (t := highSide)
      (i := fun g hg =>
        Sum.inl (⟨g, (Finset.mem_filter.mp hg).1⟩ :
          {g : SourceItem // g ∈ highGoods}))
      ?hi ?hinj ?hsurj ?hweight
    · intro g hg
      rw [Finset.mem_filter]
      constructor
      · have hpred := (Finset.mem_filter.mp hg).2
        simpa [paper_lmms_theorem_3_3_typedCombinedHighPart,
          (Finset.mem_filter.mp hg).1] using hpred
      · simp
    · intro g₁ hg₁ g₂ hg₂ hmap
      cases hmap
      rfl
    · intro item hitem
      rw [Finset.mem_filter] at hitem
      cases item with
      | inl g =>
          refine ⟨g.1, ?_, ?_⟩
          · simp [paper_lmms_theorem_3_3_typedCombinedHighPart, g.2,
              hitem.1]
          · rfl
      | inr lowItem =>
          simp at hitem
    · intro g hg
      simp
  rw [hsum_bij, hsum_filter]

/--
For a typed combined allocation, rounded common load decomposes into the
projected high-source rounded load plus the extracted low artificial load.
-/
theorem paper_lmms_theorem_3_3_typedCombined_commonLoad_eq_highPart_add_lowRoundedLoad
    {SourceAgent SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (A :
      Allocation SourceAgent
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue))
    (i : SourceAgent) :
    Theorem34.commonLoad
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue
          (L := L) (lambda := lambda)
          (highGoods := highGoods) (lowGoods := lowGoods)
          (sourceValue := sourceValue) indexOf)
        (A i) =
      (paper_lmms_theorem_3_3_typedCombinedHighPart
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue A i).sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
        paper_lmms_theorem_3_3_typedCombinedLowRoundedLoad
          (L := L) (lambda := lambda)
          (highGoods := highGoods) (lowGoods := lowGoods)
          (sourceValue := sourceValue) A i := by
  classical
  let highOnlyValue :
      paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
        (L := L) (lambda := lambda) highGoods lowGoods sourceValue → ℝ :=
    fun item =>
      match item with
      | Sum.inl g => Theorem33.roundedValue L lambda (indexOf g.1)
      | Sum.inr _ => 0
  let lowOnlyValue :
      paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
        (L := L) (lambda := lambda) highGoods lowGoods sourceValue → ℝ :=
    fun item =>
      match item with
      | Sum.inl _ => 0
      | Sum.inr lowItem =>
          paper_lmms_theorem_3_3_roundedSupplyValue
            (L := L) (lambda := lambda)
            (supply :=
              Theorem33.lowGoodsAggregatedSupply L lambda
                (lowGoods.sum sourceValue))
            lowItem
  have hpoint :
      ∀ item :
        paper_lmms_theorem_3_3_typedCombinedHighLowSupplyItem
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue,
        paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue
            (L := L) (lambda := lambda)
            (highGoods := highGoods) (lowGoods := lowGoods)
            (sourceValue := sourceValue) indexOf item =
          highOnlyValue item + lowOnlyValue item := by
    intro item
    cases item <;>
      simp [paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue,
        paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf,
        paper_lmms_theorem_3_3_roundedSupplyValue, highOnlyValue,
        lowOnlyValue]
  calc
    Theorem34.commonLoad
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue
          (L := L) (lambda := lambda)
          (highGoods := highGoods) (lowGoods := lowGoods)
          (sourceValue := sourceValue) indexOf)
        (A i)
        =
      (A i).sum
        (paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue
          (L := L) (lambda := lambda)
          (highGoods := highGoods) (lowGoods := lowGoods)
          (sourceValue := sourceValue) indexOf) := rfl
    _ = (A i).sum (fun item => highOnlyValue item + lowOnlyValue item) := by
          apply Finset.sum_congr rfl
          intro item _hitem
          exact hpoint item
    _ = (A i).sum highOnlyValue + (A i).sum lowOnlyValue := by
          simp [Finset.sum_add_distrib]
    _ =
      (paper_lmms_theorem_3_3_typedCombinedHighPart
          (L := L) (lambda := lambda) highGoods lowGoods sourceValue A i).sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
        paper_lmms_theorem_3_3_typedCombinedLowRoundedLoad
          (L := L) (lambda := lambda)
          (highGoods := highGoods) (lowGoods := lowGoods)
          (sourceValue := sourceValue) A i := by
          rw [← paper_lmms_theorem_3_3_typedCombinedHighPart_sum_eq_highSide_sum
            (L := L) (lambda := lambda) highGoods lowGoods sourceValue indexOf A i]
          rfl

/-- Max-over-min load ratio for an allocation of a materialized rounded supply. -/
noncomputable def paper_lmms_theorem_3_3_roundedSupplyAllocationRatio
    (L : ℝ) (lambda : ℕ) {SourceAgent : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {supply : Theorem33.RoundedValueIndex lambda → ℕ}
    (A : Allocation SourceAgent
      (paper_lmms_theorem_3_3_roundedSupplyItem supply)) : ℝ :=
  Theorem34.loadRatio
    (Theorem34.minCommonLoad
      (paper_lmms_theorem_3_3_roundedSupplyValue L lambda) A)
    (Theorem34.maxCommonLoad
      (paper_lmms_theorem_3_3_roundedSupplyValue L lambda) A)

/--
Theorem 3.3 low-good aggregation seam: if `S` is the total value of the low
goods, choose `ceil (S / (L / λ))` artificial goods, each with rounded value
`L / λ`.  The resulting rounded goods-supply vector is supported at the
low-good index `k = λ`, has exact count `lowCount` there, and has total rounded
value in `[S, S + L / λ)`.
-/
theorem paper_lmms_theorem_3_3_exists_low_goods_artificial_supply
    {SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hvalues :
      ∀ g : SourceItem, g ∈ lowGoods →
        0 ≤ v g ∧ v g < L / (lambda : ℝ)) :
    ∃ lowCount : ℕ,
      let artificialGoods : Finset (Fin lowCount) := Finset.univ
      let indexOf : Fin lowCount → Theorem33.RoundedValueIndex lambda :=
        fun _ => Theorem33.lowGoodRoundedValueIndex lambda
      lowGoods.sum v ≤
          ∑ k : Theorem33.RoundedValueIndex lambda,
            (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf
                artificialGoods k : ℝ) *
              Theorem33.roundedValue L lambda k ∧
        (∑ k : Theorem33.RoundedValueIndex lambda,
            (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf
                artificialGoods k : ℝ) *
              Theorem33.roundedValue L lambda k) <
            lowGoods.sum v + L / (lambda : ℝ) ∧
          paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf artificialGoods
              (Theorem33.lowGoodRoundedValueIndex lambda) =
            lowCount ∧
            ∀ k : Theorem33.RoundedValueIndex lambda,
              k ≠ Theorem33.lowGoodRoundedValueIndex lambda →
                paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf
                    artificialGoods k =
                  0 := by
  classical
  have hS_nonneg : 0 ≤ lowGoods.sum v :=
    Finset.sum_nonneg fun g hg => (hvalues g hg).1
  let lowCount : ℕ :=
    Theorem33.roundedLowGoodsCount L lambda (lowGoods.sum v)
  refine ⟨lowCount, ?_⟩
  let artificialGoods : Finset (Fin lowCount) := Finset.univ
  let indexOf : Fin lowCount → Theorem33.RoundedValueIndex lambda :=
    fun _ => Theorem33.lowGoodRoundedValueIndex lambda
  have hweighted :
      (∑ k : Theorem33.RoundedValueIndex lambda,
          (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf
              artificialGoods k : ℝ) *
            Theorem33.roundedValue L lambda k) =
        (lowCount : ℝ) * (L / (lambda : ℝ)) := by
    calc
      (∑ k : Theorem33.RoundedValueIndex lambda,
          (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf
              artificialGoods k : ℝ) *
            Theorem33.roundedValue L lambda k)
          =
        artificialGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) := by
            exact
              paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_weighted_sum_eq_sum_goods
                (L := L) indexOf artificialGoods
      _ = (lowCount : ℝ) * (L / (lambda : ℝ)) := by
            simp [artificialGoods, indexOf,
              Theorem33.roundedValue_lowGoodRoundedValueIndex_eq hlambda,
              nsmul_eq_mul]
  constructor
  · rw [hweighted]
    exact
      Theorem33.lowGoods_total_le_roundedLowGoodsCount_value
        (L := L) (S := lowGoods.sum v) hlambda hL
  · constructor
    · rw [hweighted]
      exact
        Theorem33.roundedLowGoodsCount_value_lt_total_add_unit
          (L := L) (S := lowGoods.sum v) hlambda hL hS_nonneg
    · constructor
      · simp [paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods]
      · intro k hk
        have hne : Theorem33.lowGoodRoundedValueIndex lambda ≠ k := by
          exact fun h => hk h.symm
        simp [paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods,
          hne]

/--
Combined high/low rounded-supply weighted-value bounds for any supplied
rounding map and supply vector satisfying the paper high/low equations.  This
is the reusable arithmetic core behind the existential combined-supply
constructor.
-/
theorem paper_lmms_theorem_3_3_combined_high_low_rounded_goods_supply_weighted_value_bounds
    {SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (combinedSupply : Theorem33.RoundedValueIndex lambda → ℕ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hlow_nonneg :
      ∀ g : SourceItem, g ∈ lowGoods → 0 ≤ v g)
    (hsupply :
      ∀ k : Theorem33.RoundedValueIndex lambda,
        combinedSupply k =
          paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods k +
            Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v) k) :
    highGoods.sum v + lowGoods.sum v ≤
        ∑ k : Theorem33.RoundedValueIndex lambda,
          (combinedSupply k : ℝ) * Theorem33.roundedValue L lambda k ∧
      (∑ k : Theorem33.RoundedValueIndex lambda,
        (combinedSupply k : ℝ) * Theorem33.roundedValue L lambda k) <
        highGoods.sum v + lowGoods.sum v +
          (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
            L / (lambda : ℝ) := by
  classical
  let highSupply : Theorem33.RoundedValueIndex lambda → ℕ :=
    paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods
  let lowSupply : Theorem33.RoundedValueIndex lambda → ℕ :=
    Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v)
  have hcombined_split :
      (∑ k : Theorem33.RoundedValueIndex lambda,
          (combinedSupply k : ℝ) * Theorem33.roundedValue L lambda k) =
        (∑ k : Theorem33.RoundedValueIndex lambda,
          (highSupply k : ℝ) * Theorem33.roundedValue L lambda k) +
        (∑ k : Theorem33.RoundedValueIndex lambda,
          (lowSupply k : ℝ) * Theorem33.roundedValue L lambda k) := by
    calc
      (∑ k : Theorem33.RoundedValueIndex lambda,
          (combinedSupply k : ℝ) * Theorem33.roundedValue L lambda k)
          =
        ∑ k : Theorem33.RoundedValueIndex lambda,
          ((highSupply k + lowSupply k : ℕ) : ℝ) *
            Theorem33.roundedValue L lambda k := by
            apply Finset.sum_congr rfl
            intro k _hk
            rw [hsupply k]
      _ =
        (∑ k : Theorem33.RoundedValueIndex lambda,
          (highSupply k : ℝ) * Theorem33.roundedValue L lambda k) +
        (∑ k : Theorem33.RoundedValueIndex lambda,
          (lowSupply k : ℝ) * Theorem33.roundedValue L lambda k) := by
            simp [Nat.cast_add, add_mul, Finset.sum_add_distrib]
  have hhigh_weighted :
      (∑ k : Theorem33.RoundedValueIndex lambda,
          (highSupply k : ℝ) * Theorem33.roundedValue L lambda k) =
        highGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) := by
    simpa [highSupply] using
      paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_weighted_sum_eq_sum_goods
        (L := L) indexOf highGoods
  have hlowS_nonneg : 0 ≤ lowGoods.sum v :=
    Finset.sum_nonneg fun g hg => hlow_nonneg g hg
  have hlow_bounds :=
    Theorem33.lowGoodsAggregatedSupply_weighted_sum_bounds
      (L := L) (S := lowGoods.sum v) hlambda hL hlowS_nonneg
  have hhigh_lower :
      highGoods.sum v ≤
        highGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) :=
    Finset.sum_le_sum fun g hg => (hindex g hg).1
  have hhigh_upper :
      highGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) ≤
        highGoods.sum v +
          (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) := by
    calc
      highGoods.sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g))
          ≤ highGoods.sum (fun g => v g + L / ((lambda : ℝ) ^ 2)) := by
            exact Finset.sum_le_sum fun g hg => le_of_lt (hindex g hg).2
      _ =
          highGoods.sum v +
            (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) := by
            simp [Finset.sum_add_distrib, nsmul_eq_mul]
  constructor
  · rw [hcombined_split, hhigh_weighted]
    exact
      add_le_add hhigh_lower (by simpa [lowSupply] using hlow_bounds.1)
  · rw [hcombined_split, hhigh_weighted]
    have hsum_lt :
        highGoods.sum
              (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
            (∑ k : Theorem33.RoundedValueIndex lambda,
              (lowSupply k : ℝ) * Theorem33.roundedValue L lambda k) <
          (highGoods.sum v +
              (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2))) +
            (lowGoods.sum v + L / (lambda : ℝ)) := by
      exact
        add_lt_add_of_le_of_lt hhigh_upper
          (by simpa [lowSupply] using hlow_bounds.2)
    linarith

/--
Theorem 3.3 combined rounded goods-supply seam: combine the high-good
source-value rounding map with the low-good artificial supply into one
per-rounded-value goods vector.  Its total rounded value is at least the source
high-plus-low value and is below that source value plus the paper's high-good
rounding error budget and one low-good unit.
-/
theorem paper_lmms_theorem_3_3_exists_combined_high_low_rounded_goods_supply
    {SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g ∧ v g < L)
    (hlow :
      ∀ g : SourceItem, g ∈ lowGoods →
        0 ≤ v g ∧ v g < L / (lambda : ℝ)) :
    ∃ indexOf : SourceItem → Theorem33.RoundedValueIndex lambda,
      ∃ combinedSupply : Theorem33.RoundedValueIndex lambda → ℕ,
        (∀ g : SourceItem, g ∈ highGoods →
          v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
            Theorem33.roundedValue L lambda (indexOf g) <
              v g + L / ((lambda : ℝ) ^ 2)) ∧
          (∀ k : Theorem33.RoundedValueIndex lambda,
            combinedSupply k =
              paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods k +
                Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v) k) ∧
            highGoods.sum v + lowGoods.sum v ≤
              ∑ k : Theorem33.RoundedValueIndex lambda,
                (combinedSupply k : ℝ) *
                  Theorem33.roundedValue L lambda k ∧
              (∑ k : Theorem33.RoundedValueIndex lambda,
                (combinedSupply k : ℝ) *
                  Theorem33.roundedValue L lambda k) <
                highGoods.sum v + lowGoods.sum v +
                  (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
                    L / (lambda : ℝ) := by
  classical
  rcases
      paper_lmms_theorem_3_3_exists_high_good_indexOf
        highGoods v hlambda hL hhigh with
    ⟨indexOf, hindex⟩
  let highSupply : Theorem33.RoundedValueIndex lambda → ℕ :=
    paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods
  let lowSupply : Theorem33.RoundedValueIndex lambda → ℕ :=
    Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v)
  let combinedSupply : Theorem33.RoundedValueIndex lambda → ℕ :=
    fun k => highSupply k + lowSupply k
  refine ⟨indexOf, combinedSupply, hindex, ?_, ?_, ?_⟩
  · intro k
    rfl
  · have hhigh_weighted :
        (∑ k : Theorem33.RoundedValueIndex lambda,
            (highSupply k : ℝ) * Theorem33.roundedValue L lambda k) =
          highGoods.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) := by
      simpa [highSupply] using
        paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_weighted_sum_eq_sum_goods
          (L := L) indexOf highGoods
    have hlowS_nonneg : 0 ≤ lowGoods.sum v :=
      Finset.sum_nonneg fun g hg => (hlow g hg).1
    have hlow_bounds :=
      Theorem33.lowGoodsAggregatedSupply_weighted_sum_bounds
        (L := L) (S := lowGoods.sum v) hlambda hL hlowS_nonneg
    have hcombined_split :
        (∑ k : Theorem33.RoundedValueIndex lambda,
            (combinedSupply k : ℝ) * Theorem33.roundedValue L lambda k) =
          (∑ k : Theorem33.RoundedValueIndex lambda,
            (highSupply k : ℝ) * Theorem33.roundedValue L lambda k) +
          (∑ k : Theorem33.RoundedValueIndex lambda,
            (lowSupply k : ℝ) * Theorem33.roundedValue L lambda k) := by
      simp [combinedSupply, Nat.cast_add, add_mul, Finset.sum_add_distrib]
    rw [hcombined_split]
    exact
      add_le_add
        (by
          rw [hhigh_weighted]
          exact Finset.sum_le_sum fun g hg => (hindex g hg).1)
        (by
          simpa [lowSupply] using hlow_bounds.1)
  · have hhigh_weighted :
        (∑ k : Theorem33.RoundedValueIndex lambda,
            (highSupply k : ℝ) * Theorem33.roundedValue L lambda k) =
          highGoods.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) := by
      simpa [highSupply] using
        paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_weighted_sum_eq_sum_goods
          (L := L) indexOf highGoods
    have hhigh_upper :
        highGoods.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) ≤
          highGoods.sum v + (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) := by
      calc
        highGoods.sum (fun g => Theorem33.roundedValue L lambda (indexOf g))
            ≤ highGoods.sum (fun g => v g + L / ((lambda : ℝ) ^ 2)) := by
              exact Finset.sum_le_sum fun g hg => le_of_lt (hindex g hg).2
        _ = highGoods.sum v +
              (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) := by
              simp [Finset.sum_add_distrib, nsmul_eq_mul]
    have hlowS_nonneg : 0 ≤ lowGoods.sum v :=
      Finset.sum_nonneg fun g hg => (hlow g hg).1
    have hlow_bounds :=
      Theorem33.lowGoodsAggregatedSupply_weighted_sum_bounds
        (L := L) (S := lowGoods.sum v) hlambda hL hlowS_nonneg
    have hcombined_split :
        (∑ k : Theorem33.RoundedValueIndex lambda,
            (combinedSupply k : ℝ) * Theorem33.roundedValue L lambda k) =
          (∑ k : Theorem33.RoundedValueIndex lambda,
            (highSupply k : ℝ) * Theorem33.roundedValue L lambda k) +
          (∑ k : Theorem33.RoundedValueIndex lambda,
            (lowSupply k : ℝ) * Theorem33.roundedValue L lambda k) := by
      simp [combinedSupply, Nat.cast_add, add_mul, Finset.sum_add_distrib]
    rw [hcombined_split, hhigh_weighted]
    have hsum_lt :
        highGoods.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
            (∑ k : Theorem33.RoundedValueIndex lambda,
              (lowSupply k : ℝ) * Theorem33.roundedValue L lambda k) <
          (highGoods.sum v +
              (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2))) +
            (lowGoods.sum v + L / (lambda : ℝ)) := by
      exact
        add_lt_add_of_le_of_lt hhigh_upper
          (by simpa [lowSupply] using hlow_bounds.2)
    linarith

/--
Combined high/low supply has no top-index goods when the high-good rounding map
avoids the top index and `lambda > 1` makes the artificial low-good index
different from the top index.
-/
theorem paper_lmms_theorem_3_3_combined_high_low_supply_top_eq_zero
    {SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (combinedSupply : Theorem33.RoundedValueIndex lambda → ℕ)
    (hlambda : 1 < lambda)
    (hsupply :
      ∀ k : Theorem33.RoundedValueIndex lambda,
        combinedSupply k =
          paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods k +
            Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v) k)
    (hhigh_no_top :
      ∀ g : SourceItem, g ∈ highGoods →
        indexOf g ≠ paper_lmms_theorem_3_3_topRoundedValueIndex lambda) :
    combinedSupply (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) = 0 := by
  classical
  have hhigh_zero :
      paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods
          (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) = 0 :=
    paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_eq_zero_of_index_ne
      indexOf highGoods (paper_lmms_theorem_3_3_topRoundedValueIndex lambda)
      hhigh_no_top
  have hlow_zero :
      Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v)
          (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) = 0 :=
    paper_lmms_theorem_3_3_lowGoodsAggregatedSupply_top_eq_zero
      (L := L) (S := lowGoods.sum v) hlambda
  rw [hsupply (paper_lmms_theorem_3_3_topRoundedValueIndex lambda)]
  simp [hhigh_zero, hlow_zero]

/--
Combined high/low supply with no top-index support under the explicit
high-good rounding margin `v g + L / lambda^2 ≤ L`. This is the faithful
source-shaped strengthening needed by no-top Claim 3.4 bridges.
-/
theorem paper_lmms_theorem_3_3_exists_combined_high_low_rounded_goods_supply_no_top_of_margin
    {SourceItem : Type*} [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (hlambda : 1 < lambda) (hL : 0 < L)
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g ∧ v g < L)
    (hlow :
      ∀ g : SourceItem, g ∈ lowGoods →
        0 ≤ v g ∧ v g < L / (lambda : ℝ))
    (hmargin :
      ∀ g : SourceItem, g ∈ highGoods →
        v g + L / ((lambda : ℝ) ^ 2) ≤ L) :
    ∃ indexOf : SourceItem → Theorem33.RoundedValueIndex lambda,
      ∃ combinedSupply : Theorem33.RoundedValueIndex lambda → ℕ,
        (∀ g : SourceItem, g ∈ highGoods →
          v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
            Theorem33.roundedValue L lambda (indexOf g) <
              v g + L / ((lambda : ℝ) ^ 2)) ∧
          (∀ k : Theorem33.RoundedValueIndex lambda,
            combinedSupply k =
              paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods k +
                Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v) k) ∧
            combinedSupply (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) = 0 ∧
              highGoods.sum v + lowGoods.sum v ≤
                ∑ k : Theorem33.RoundedValueIndex lambda,
                  (combinedSupply k : ℝ) *
                    Theorem33.roundedValue L lambda k ∧
                (∑ k : Theorem33.RoundedValueIndex lambda,
                  (combinedSupply k : ℝ) *
                    Theorem33.roundedValue L lambda k) <
                  highGoods.sum v + lowGoods.sum v +
                    (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
                      L / (lambda : ℝ) := by
  classical
  have hlambda_pos : 0 < lambda := Nat.zero_lt_of_lt hlambda
  rcases
      paper_lmms_theorem_3_3_exists_combined_high_low_rounded_goods_supply
        highGoods lowGoods v hlambda_pos hL hhigh hlow with
    ⟨indexOf, combinedSupply, hindex, hsupply, hlower, hupper⟩
  have hhigh_no_top :
      ∀ g : SourceItem, g ∈ highGoods →
        indexOf g ≠ paper_lmms_theorem_3_3_topRoundedValueIndex lambda :=
    paper_lmms_theorem_3_3_high_indexOf_ne_top_of_rounding_margin
      indexOf hlambda_pos hindex hmargin
  have htop_zero :
      combinedSupply (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) = 0 :=
    paper_lmms_theorem_3_3_combined_high_low_supply_top_eq_zero
      highGoods lowGoods v indexOf combinedSupply hlambda hsupply hhigh_no_top
  exact ⟨indexOf, combinedSupply, hindex, hsupply, htop_zero, hlower, hupper⟩

/--
Theorem 3.3 materialized combined-supply seam: after combining high source
