/--
Claim 3.4 concrete min/max source-data assembly: using the canonical finite
minimum and maximum bundle loads removes the need for separate min/max accessor
proofs. The remaining source obligations are average-load preservation,
positive minima on the unbounded optimal path, small nonnegative goods, unique
ownership, and the concrete move update law.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_of_concrete_minmax_source_trichotomy
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Fintype Alloc] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {bundleOf : Alloc → SourceAgent → Finset SourceItem}
    {v : SourceItem → ℝ} {L : ℝ} {ratioOf : Alloc → ℝ}
    (moveAlloc : Alloc → SourceAgent → SourceAgent → SourceItem → Alloc)
    (A₀ : Alloc) (hA₀ : Theorem34.IsOptimalRatio ratioOf A₀)
    (hL : 0 < L)
    (havg :
      ∀ A : Alloc,
        Theorem34.IsOptimalRatio ratioOf A →
          (∑ i : SourceAgent, Theorem34.commonLoad v (bundleOf A i)) =
            (Fintype.card SourceAgent : ℝ) * L)
    (hmin_pos :
      ∀ A : Alloc,
        Theorem34.IsOptimalRatio ratioOf A →
          (¬ ∀ i : SourceAgent,
            Theorem34.boundedAroundAverage L
              (Theorem34.commonLoad v (bundleOf A i))) →
            0 < Theorem34.minCommonLoad v (bundleOf A))
    (hitem_nonneg :
      ∀ A : Alloc, ∀ i : SourceAgent, ∀ g : SourceItem,
        g ∈ bundleOf A i → 0 ≤ v g)
    (hitem_lt :
      ∀ A : Alloc, ∀ i : SourceAgent, ∀ g : SourceItem,
        g ∈ bundleOf A i → v g < L)
    (hunique :
      ∀ A : Alloc, ∀ {i j : SourceAgent} {g : SourceItem},
        g ∈ bundleOf A i → g ∈ bundleOf A j → i = j)
    (hratio :
      ∀ C : Alloc,
        ratioOf C =
          Theorem34.loadRatio (Theorem34.minCommonLoad v (bundleOf C))
            (Theorem34.maxCommonLoad v (bundleOf C)))
    (hbundle_move :
      ∀ A source target g,
        bundleOf (moveAlloc A source target g) =
          Theorem34.moveBundle (bundleOf A) source target g) :
    ∃ B : Alloc, Theorem34.Claim34Certificate v L ratioOf bundleOf B := by
  exact
    Theorem34.claim34_certificate_of_concrete_minmax_source_trichotomy
      (v := v) (L := L) (ratioOf := ratioOf) (bundleOf := bundleOf)
      moveAlloc A₀ hA₀ hL havg hmin_pos hitem_nonneg hitem_lt
      hunique hratio hbundle_move

/--
Owner-filter allocation helper: assigning each good to its owner and filtering
the source goods by that owner gives an exact allocation of the source goods.
-/
theorem paper_lmms_isAllocationOf_filter_owner
    {SourceAgent SourceItem : Type*}
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    (goods : Finset SourceItem) (owner : SourceItem → SourceAgent) :
    IsAllocationOf
      (fun i : SourceAgent => goods.filter fun g => owner g = i) goods := by
  classical
  constructor
  · intro i g hg
    exact (Finset.mem_filter.mp hg).1
  · intro g hg
    refine ⟨owner g, ?_, ?_⟩
    · simp [hg]
    · intro i hi
      exact (Finset.mem_filter.mp hi).2.symm

/--
Exact allocation to owner-map helper: every exact allocation induces an owner
map whose owner-filter bundles recover the original allocation on the
allocated goods.
-/
theorem paper_lmms_exists_owner_filter_eq_of_isAllocationOf
    {SourceAgent SourceItem : Type*}
    [Nonempty SourceAgent] [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {A : Allocation SourceAgent SourceItem}
    (halloc : IsAllocationOf A goods) :
    ∃ owner : SourceItem → SourceAgent,
      ∀ i : SourceAgent, (goods.filter fun g => owner g = i) = A i := by
  classical
  let fallback : SourceAgent := Classical.choice inferInstance
  let owner : SourceItem → SourceAgent :=
    fun g =>
      if hg : g ∈ goods then
        Classical.choose ((halloc.2 g hg).exists)
      else
        fallback
  refine ⟨owner, ?_⟩
  intro i
  ext g
  constructor
  · intro hgfilter
    rcases Finset.mem_filter.mp hgfilter with ⟨hgoods, howner⟩
    have hchosen_mem :
        g ∈ A (Classical.choose ((halloc.2 g hgoods).exists)) :=
      Classical.choose_spec ((halloc.2 g hgoods).exists)
    have hchosen_eq : Classical.choose ((halloc.2 g hgoods).exists) = i := by
      simpa [owner, hgoods] using howner
    simpa [hchosen_eq] using hchosen_mem
  · intro hgA
    have hgoods : g ∈ goods := halloc.1 i g hgA
    have hchosen_mem :
        g ∈ A (Classical.choose ((halloc.2 g hgoods).exists)) :=
      Classical.choose_spec ((halloc.2 g hgoods).exists)
    have hchosen_eq :
        Classical.choose ((halloc.2 g hgoods).exists) = i :=
      (halloc.2 g hgoods).unique hchosen_mem hgA
    exact Finset.mem_filter.mpr
      ⟨hgoods, by simp [owner, hgoods, hchosen_eq]⟩

/--
Weighted-prefix support for the low-good construction.  In any fixed ordering of
small goods, if a target is below the total prefixable mass plus one item-size
`delta`, the maximal prefix not exceeding the target is within `delta` of it
from below.  This is the crossing lemma used by the remaining weighted-prefix
partition proof.
-/
noncomputable def paper_lmms_prefixWeight
    {SourceItem : Type*} (goods : List SourceItem) (v : SourceItem → ℝ)
    (n : ℕ) : ℝ :=
  ((goods.take n).map v).sum

/--
The full prefix weight of a finset's nodup list is the finset's total value.
-/
theorem paper_lmms_prefixWeight_toList_length_eq_sum
    {SourceItem : Type*} [DecidableEq SourceItem]
    (goods : Finset SourceItem) (v : SourceItem → ℝ) :
    paper_lmms_prefixWeight goods.toList v goods.toList.length =
      goods.sum v := by
  calc
    paper_lmms_prefixWeight goods.toList v goods.toList.length =
        ((goods.toList).map v).sum := by
      unfold paper_lmms_prefixWeight
      rw [List.map_take]
      rw [show goods.toList.length = (goods.toList.map v).length by simp]
      rw [List.take_length]
    _ = goods.sum v := by
      have hsum := List.sum_toFinset v (Finset.nodup_toList goods)
      simpa using hsum.symm

/--
Cardinality-indexed form of the full-prefix finset sum identity.
-/
theorem paper_lmms_prefixWeight_toList_card_eq_sum
    {SourceItem : Type*} [DecidableEq SourceItem]
    (goods : Finset SourceItem) (v : SourceItem → ℝ) :
    paper_lmms_prefixWeight goods.toList v goods.card =
      goods.sum v := by
  simpa using paper_lmms_prefixWeight_toList_length_eq_sum goods v

/--
Existence of a maximal weighted prefix below a target.  The last conjunct states
maximality among all prefixes whose weight is at most the target.
-/
theorem paper_lmms_exists_prefixWeight_floor
    {SourceItem : Type*} {delta target : ℝ}
    (goods : List SourceItem) (v : SourceItem → ℝ)
    (htarget_nonneg : 0 ≤ target)
    (hitem_lt : ∀ g : SourceItem, g ∈ goods → v g < delta)
    (hupper : target < paper_lmms_prefixWeight goods v goods.length + delta) :
    ∃ n : ℕ, n ≤ goods.length ∧
      paper_lmms_prefixWeight goods v n ≤ target ∧
      target < paper_lmms_prefixWeight goods v n + delta ∧
      ∀ m : ℕ, m ≤ goods.length →
        paper_lmms_prefixWeight goods v m ≤ target → m ≤ n := by
  classical
  let candidates : Finset ℕ :=
    (Finset.range (goods.length + 1)).filter fun n =>
      paper_lmms_prefixWeight goods v n ≤ target
  have hnonempty : candidates.Nonempty := by
    refine ⟨0, ?_⟩
    simp [candidates, paper_lmms_prefixWeight, htarget_nonneg]
  rcases Finset.exists_max_image candidates (fun n : ℕ => n) hnonempty with
    ⟨n, hnmem, hmax⟩
  have hn_range : n ∈ Finset.range (goods.length + 1) :=
    (Finset.mem_filter.mp hnmem).1
  have hn_prefix_le : paper_lmms_prefixWeight goods v n ≤ target :=
    (Finset.mem_filter.mp hnmem).2
  have hn_lt_succ : n < goods.length + 1 := by
    simpa using hn_range
  have hn_le_len : n ≤ goods.length := by omega
  have hmax_index :
      ∀ m : ℕ, m ≤ goods.length →
        paper_lmms_prefixWeight goods v m ≤ target → m ≤ n := by
    intro m hm hmw
    have hm_range : m ∈ Finset.range (goods.length + 1) := by
      simp [hm]
    have hmmem : m ∈ candidates :=
      Finset.mem_filter.mpr ⟨hm_range, hmw⟩
    exact hmax m hmmem
  have htarget_lt :
      target < paper_lmms_prefixWeight goods v n + delta := by
    by_cases hlast : n = goods.length
    · simpa [hlast] using hupper
    · have hnlt : n < goods.length := lt_of_le_of_ne hn_le_len hlast
      have hn1_le_len : n + 1 ≤ goods.length := Nat.succ_le_of_lt hnlt
      have hn1_range : n + 1 ∈ Finset.range (goods.length + 1) := by
        simp [hn1_le_len]
      have hnot_prefix :
          ¬ paper_lmms_prefixWeight goods v (n + 1) ≤ target := by
        intro hle
        have hn1mem : n + 1 ∈ candidates :=
          Finset.mem_filter.mpr ⟨hn1_range, hle⟩
        have hle_n : n + 1 ≤ n := hmax (n + 1) hn1mem
        omega
      have htarget_lt_succ :
          target < paper_lmms_prefixWeight goods v (n + 1) :=
        not_le.mp hnot_prefix
      have hsucc :
          paper_lmms_prefixWeight goods v (n + 1) =
            paper_lmms_prefixWeight goods v n + v goods[n] := by
        have hsum :=
          List.sum_take_succ (goods.map v) n (by simpa using hnlt)
        simpa [paper_lmms_prefixWeight] using hsum
      have hitem : v goods[n] < delta :=
        hitem_lt goods[n] (List.getElem_mem hnlt)
      nlinarith
  exact ⟨n, hn_le_len, hn_prefix_le, htarget_lt, hmax_index⟩

/--
The prefix-floor index is monotone in the target: any prefix below the smaller
target is also below the larger target, hence lies before the larger target's
maximal prefix.
-/
theorem paper_lmms_prefixWeight_floor_index_le_of_target_le
    {SourceItem : Type*} {target₁ target₂ : ℝ}
    {goods : List SourceItem} {v : SourceItem → ℝ} {n₁ n₂ : ℕ}
    (htarget : target₁ ≤ target₂)
    (hn₁_len : n₁ ≤ goods.length)
    (hn₁_weight : paper_lmms_prefixWeight goods v n₁ ≤ target₁)
    (hn₂_max :
      ∀ m : ℕ, m ≤ goods.length →
        paper_lmms_prefixWeight goods v m ≤ target₂ → m ≤ n₂) :
    n₁ ≤ n₂ :=
  hn₂_max n₁ hn₁_len (le_trans hn₁_weight htarget)

/--
The maximal prefix below a target has nonnegative error strictly less than
`delta`.
-/
theorem paper_lmms_prefixWeight_floor_error_bounds
    {SourceItem : Type*} {delta target : ℝ}
    {goods : List SourceItem} {v : SourceItem → ℝ} {n : ℕ}
    (hn_weight : paper_lmms_prefixWeight goods v n ≤ target)
    (htarget_lt : target < paper_lmms_prefixWeight goods v n + delta) :
    0 ≤ target - paper_lmms_prefixWeight goods v n ∧
      target - paper_lmms_prefixWeight goods v n < delta := by
  constructor <;> linarith

/--
Monotone weighted-prefix cuts for cumulative low-good targets.  This packages
the previous floor lemma for every cumulative target and fixes the final cut at
the full list length.  It is the finite cut skeleton for the remaining
low-good weighted-prefix partition theorem.
-/
theorem paper_lmms_exists_monotone_prefixWeight_cuts
    {SourceItem : Type*} {delta : ℝ} {N : ℕ}
    (goods : List SourceItem) (v : SourceItem → ℝ)
    (targetPrefix : ℕ → ℝ)
    (hNpos : 0 < N)
    (hdelta : 0 < delta)
    (hzero : targetPrefix 0 = 0)
    (hprefix_nonneg : ∀ k : ℕ, k < N → 0 ≤ targetPrefix k)
    (hprefix_mono :
      ∀ k l : ℕ, k ≤ l → l ≤ N → targetPrefix k ≤ targetPrefix l)
    (hitem_lt : ∀ g : SourceItem, g ∈ goods → v g < delta)
    (htotal_lower :
      paper_lmms_prefixWeight goods v goods.length ≤ targetPrefix N)
    (htotal_upper :
      targetPrefix N < paper_lmms_prefixWeight goods v goods.length + delta) :
    ∃ cut : ℕ → ℕ,
      cut 0 = 0 ∧
        cut N = goods.length ∧
        (∀ k : ℕ, k ≤ N → cut k ≤ goods.length) ∧
        (∀ k l : ℕ, k ≤ l → l ≤ N → cut k ≤ cut l) ∧
        ∀ k : ℕ, k ≤ N →
          paper_lmms_prefixWeight goods v (cut k) ≤ targetPrefix k ∧
            targetPrefix k <
              paper_lmms_prefixWeight goods v (cut k) + delta := by
  classical
  have hfloor :
      ∀ k : ℕ, k < N →
        ∃ n : ℕ, n ≤ goods.length ∧
          paper_lmms_prefixWeight goods v n ≤ targetPrefix k ∧
          targetPrefix k < paper_lmms_prefixWeight goods v n + delta ∧
          ∀ m : ℕ, m ≤ goods.length →
            paper_lmms_prefixWeight goods v m ≤ targetPrefix k → m ≤ n := by
    intro k hk
    exact
      paper_lmms_exists_prefixWeight_floor goods v
        (hprefix_nonneg k hk) hitem_lt
        (lt_of_le_of_lt (hprefix_mono k N (Nat.le_of_lt hk) le_rfl)
          htotal_upper)
  let floorCut : (k : ℕ) → k < N → ℕ :=
    fun k hk => Classical.choose (hfloor k hk)
  let cut : ℕ → ℕ :=
    fun k =>
      if k = 0 then 0
      else if hN : k = N then goods.length
      else if hk : k < N then floorCut k hk
      else goods.length
  have hcut_zero : cut 0 = 0 := by
    simp [cut]
  have hcut_N : cut N = goods.length := by
    have hN0 : ¬ N = 0 := Nat.ne_of_gt hNpos
    simp [cut, hN0]
  have hcut_len : ∀ k : ℕ, k ≤ N → cut k ≤ goods.length := by
    intro k hkN
    by_cases hk0 : k = 0
    · simp [cut, hk0]
    · by_cases hkEqN : k = N
      · subst k
        simpa [hcut_N]
      · have hklt : k < N := lt_of_le_of_ne hkN hkEqN
        have hchoose := Classical.choose_spec (hfloor k hklt)
        simpa [cut, hk0, hkEqN, hklt, floorCut] using hchoose.1
  have hcut_weight :
      ∀ k : ℕ, k ≤ N →
        paper_lmms_prefixWeight goods v (cut k) ≤ targetPrefix k ∧
          targetPrefix k <
            paper_lmms_prefixWeight goods v (cut k) + delta := by
    intro k hkN
    by_cases hk0 : k = 0
    · subst k
      constructor
      · simp [cut, paper_lmms_prefixWeight, hzero]
      · simp [cut, paper_lmms_prefixWeight, hzero, hdelta]
    · by_cases hkEqN : k = N
      · subst k
        constructor
        · simpa [cut, hk0] using htotal_lower
        · simpa [cut, hk0] using htotal_upper
      · have hklt : k < N := lt_of_le_of_ne hkN hkEqN
        have hchoose := Classical.choose_spec (hfloor k hklt)
        exact
          ⟨by
            simpa [cut, hk0, hkEqN, hklt, floorCut] using hchoose.2.1,
          by
            simpa [cut, hk0, hkEqN, hklt, floorCut] using hchoose.2.2.1⟩
  have hcut_mono :
      ∀ k l : ℕ, k ≤ l → l ≤ N → cut k ≤ cut l := by
    intro k l hkl hlN
    by_cases hk0 : k = 0
    · subst k
      simp [hcut_zero]
    · by_cases hlEqN : l = N
      · subst l
        simpa [hcut_N] using hcut_len k hkl
      · have hkN : k ≤ N := le_trans hkl hlN
        have hkNeN : k ≠ N := by
          intro hkEqN
          have : l = N := le_antisymm hlN (by simpa [hkEqN] using hkl)
          exact hlEqN this
        have hklt : k < N := lt_of_le_of_ne hkN hkNeN
        have hllt : l < N := lt_of_le_of_ne hlN hlEqN
        by_cases hl0 : l = 0
        · subst l
          have : k = 0 := le_antisymm hkl (Nat.zero_le k)
          exact (hk0 this).elim
        · have hk_weight := (Classical.choose_spec (hfloor k hklt)).2.1
          have hl_max := (Classical.choose_spec (hfloor l hllt)).2.2.2
          have htarget_kl := hprefix_mono k l hkl hlN
          have hle :=
            paper_lmms_prefixWeight_floor_index_le_of_target_le
              (goods := goods) (v := v) htarget_kl
              (Classical.choose_spec (hfloor k hklt)).1
              hk_weight hl_max
          simpa [cut, hk0, hkNeN, hl0, hlEqN, hklt, hllt, floorCut] using hle
  exact ⟨cut, hcut_zero, hcut_N, hcut_len, hcut_mono, hcut_weight⟩

/--
Weight of the interval between two consecutive prefix cuts.
-/
noncomputable def paper_lmms_prefixSliceWeight
    {SourceItem : Type*} (goods : List SourceItem) (v : SourceItem → ℝ)
    (cut : ℕ → ℕ) (k : ℕ) : ℝ :=
  paper_lmms_prefixWeight goods v (cut (k + 1)) -
    paper_lmms_prefixWeight goods v (cut k)

/--
The concrete sublist between two consecutive prefix cuts.
-/
noncomputable def paper_lmms_prefixSliceList
    {SourceItem : Type*} (goods : List SourceItem) (cut : ℕ → ℕ)
    (k : ℕ) : List SourceItem :=
  (goods.drop (cut k)).take (cut (k + 1) - cut k)

/--
The concrete slice list has weight equal to the difference of consecutive
prefix weights.
-/
theorem paper_lmms_prefixSliceWeight_eq_sum_prefixSliceList
    {SourceItem : Type*} (goods : List SourceItem) (v : SourceItem → ℝ)
    (cut : ℕ → ℕ) (k : ℕ)
    (hmono : cut k ≤ cut (k + 1)) :
    ((paper_lmms_prefixSliceList goods cut k).map v).sum =
      paper_lmms_prefixSliceWeight goods v cut k := by
  let xs := goods.map v
  let a := cut k
  let b := cut (k + 1)
  have hab : a ≤ b := hmono
  have hdecomp : xs.take b = xs.take a ++ (xs.drop a).take (b - a) := by
    calc
      xs.take b = (xs.take b).take a ++ (xs.take b).drop a := by
        rw [List.take_append_drop]
      _ = xs.take a ++ (xs.drop a).take (b - a) := by
        rw [List.take_take, List.drop_take]
        simp [Nat.min_eq_left hab]
  have hsum := congrArg List.sum hdecomp
  have hslice :
      ((paper_lmms_prefixSliceList goods cut k).map v).sum =
        ((xs.drop a).take (b - a)).sum := by
    simp [paper_lmms_prefixSliceList, xs, a, b, List.map_take, List.map_drop]
  unfold paper_lmms_prefixSliceWeight paper_lmms_prefixWeight
  simp [xs, a, b] at hsum hslice ⊢
  linarith

/--
For a nodup ordered list, a contiguous drop/take slice is exactly the subset of
the list's finset whose original list index lies in the corresponding interval.
-/
theorem paper_lmms_list_drop_take_toFinset_eq_filter_idxOf
    {SourceItem : Type*} [DecidableEq SourceItem]
    (goods : List SourceItem) (hnodup : goods.Nodup)
    {a b : ℕ}
    (hab : a ≤ b) (hb : b ≤ goods.length) :
    ((goods.drop a).take (b - a)).toFinset =
      goods.toFinset.filter fun g => a ≤ goods.idxOf g ∧ goods.idxOf g < b := by
  ext g
  constructor
  · intro hg
    have hgList : g ∈ (goods.drop a).take (b - a) := by
      simpa [List.mem_toFinset] using hg
    rcases (List.mem_take_iff_getElem.mp hgList) with ⟨j, hj, hgj⟩
    have hjb : j < b - a := lt_of_lt_of_le hj (Nat.min_le_left _ _)
    have hjdrop : j < (goods.drop a).length :=
      lt_of_lt_of_le hj (Nat.min_le_right _ _)
    have hdrop_get :
        (goods.drop a)[j] = goods[a + j] :=
      List.getElem_drop (xs := goods) (i := a) (j := j) (h := hjdrop)
    have haj_len : a + j < goods.length := by
      have hlen_drop : (goods.drop a).length = goods.length - a := by
        simp
      omega
    have hgood_at : goods[a + j] = g := by
      rw [← hdrop_get]
      exact hgj
    have hidx_at : goods.idxOf goods[a + j] = a + j :=
      hnodup.idxOf_getElem (a + j) haj_len
    have hidx_g : goods.idxOf g = a + j := by
      simpa [hgood_at] using hidx_at
    have hmem_goods : g ∈ goods := by
      simpa [← hgood_at] using List.getElem_mem haj_len
    exact Finset.mem_filter.mpr
      ⟨by simpa [List.mem_toFinset] using hmem_goods,
        by omega, by omega⟩
  · intro hg
    rcases Finset.mem_filter.mp hg with ⟨hmemFin, hge, hlt⟩
    have hmem_goods : g ∈ goods := by
      simpa [List.mem_toFinset] using hmemFin
    have hidx_lt_len : goods.idxOf g < goods.length :=
      List.idxOf_lt_length_iff.2 hmem_goods
    let j := goods.idxOf g - a
    have haj : a + j = goods.idxOf g := by
      dsimp [j]
      omega
    have hjb : j < b - a := by
      dsimp [j]
      omega
    have hjdrop : j < (goods.drop a).length := by
      have hlen_drop : (goods.drop a).length = goods.length - a := by
        simp
      dsimp [j]
      omega
    have hjmin : j < min (b - a) (goods.drop a).length :=
      lt_min hjb hjdrop
    have hdrop_get :
        (goods.drop a)[j] = goods[a + j] :=
      List.getElem_drop (xs := goods) (i := a) (j := j) (h := hjdrop)
    have hidx_get : goods[goods.idxOf g] = g :=
      List.getElem_idxOf hidx_lt_len
    have hidx_get_aj : goods[a + j] = g := by
      simpa [haj] using hidx_get
    have hslice_get : (goods.drop a)[j] = g :=
      hdrop_get.trans hidx_get_aj
    have hgList : g ∈ (goods.drop a).take (b - a) :=
      List.mem_take_iff_getElem.mpr ⟨j, hjmin, hslice_get⟩
    simpa [List.mem_toFinset] using hgList

/--
For a nodup ordered goods list, the concrete prefix slice is exactly the subset
of the list's finset whose original list index lies between the two consecutive
cut indices.
-/
theorem paper_lmms_prefixSliceList_toFinset_eq_filter_idxOf
    {SourceItem : Type*} [DecidableEq SourceItem]
    {goods : List SourceItem} (hnodup : goods.Nodup)
    {cut : ℕ → ℕ} {k : ℕ}
    (hmono : cut k ≤ cut (k + 1))
    (hcut_next_len : cut (k + 1) ≤ goods.length) :
    (paper_lmms_prefixSliceList goods cut k).toFinset =
      goods.toFinset.filter fun g =>
        cut k ≤ goods.idxOf g ∧ goods.idxOf g < cut (k + 1) := by
  simpa [paper_lmms_prefixSliceList] using
    paper_lmms_list_drop_take_toFinset_eq_filter_idxOf
      goods hnodup hmono hcut_next_len

/--
If the final cut reaches the list length, every valid list index lies in some
consecutive cut interval.  This isolates the finite crossing argument used when
constructing an owner map from ordered prefix slices.
-/
theorem paper_lmms_exists_cut_interval_of_final
    {cut : ℕ → ℕ} {N len idx : ℕ}
    (hcut0 : cut 0 = 0)
    (hcutN : cut N = len)
    (hidx : idx < len) :
    ∃ k : ℕ, k < N ∧ cut k ≤ idx ∧ idx < cut (k + 1) := by
  classical
  have hex : ∃ m : ℕ, idx < cut m := by
    exact ⟨N, by simpa [hcutN] using hidx⟩
  let m := Nat.find hex
  have hm : idx < cut m := Nat.find_spec hex
  have hm_le_N : m ≤ N :=
    Nat.find_min' hex (by simpa [hcutN] using hidx)
  have hm_pos : 0 < m := by
    by_contra hnot
    have hm0 : m = 0 := Nat.eq_zero_of_not_pos hnot
    have : idx < 0 := by simpa [hm0, hcut0] using hm
    omega
  refine ⟨m - 1, ?_, ?_, ?_⟩
  · omega
  · have hpred_lt : m - 1 < m := Nat.sub_one_lt (Nat.ne_of_gt hm_pos)
    have hnot_pred : ¬ idx < cut (m - 1) :=
      Nat.find_min hex hpred_lt
    omega
  · have hm_succ : m - 1 + 1 = m := by omega
    simpa [hm_succ] using hm

/--
Construct an owner map whose filtered bundles are exactly the consecutive
prefix slices of `lowGoods.toList` in the canonical finite-agent order.
-/
theorem paper_lmms_exists_owner_filter_eq_prefixSliceList_toFinset_of_monotone_cuts
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    (lowGoods : Finset SourceItem) (cut : ℕ → ℕ)
    (hcut0 : cut 0 = 0)
    (hcut_card : cut (Fintype.card SourceAgent) = lowGoods.toList.length)
    (hcut_len :
      ∀ k : ℕ, k ≤ Fintype.card SourceAgent → cut k ≤ lowGoods.toList.length)
    (hcut_mono :
      ∀ k l : ℕ, k ≤ l → l ≤ Fintype.card SourceAgent → cut k ≤ cut l) :
    ∃ owner : SourceItem → SourceAgent,
      ∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i) =
          (paper_lmms_prefixSliceList lowGoods.toList cut
            ((Fintype.equivFin SourceAgent) i).1).toFinset := by
  classical
  let N := Fintype.card SourceAgent
  let goods := lowGoods.toList
  let e : SourceAgent ≃ Fin N := Fintype.equivFin SourceAgent
  have hinterval :
      ∀ g : SourceItem, g ∈ lowGoods →
        ∃ k : ℕ, k < N ∧ cut k ≤ goods.idxOf g ∧
          goods.idxOf g < cut (k + 1) := by
    intro g hg
    have hg_goods : g ∈ goods := by
      simpa [goods] using Finset.mem_toList.mpr hg
    have hidx : goods.idxOf g < goods.length :=
      List.idxOf_lt_length_iff.2 hg_goods
    exact
      paper_lmms_exists_cut_interval_of_final
        (cut := cut) (N := N) (len := goods.length)
        hcut0 (by simpa [N, goods] using hcut_card) hidx
  let fallback : SourceAgent := Classical.choice inferInstance
  let owner : SourceItem → SourceAgent :=
    fun g =>
      if hg : g ∈ lowGoods then
        e.symm ⟨Classical.choose (hinterval g hg),
          (Classical.choose_spec (hinterval g hg)).1⟩
      else fallback
  refine ⟨owner, ?_⟩
  intro i
  let idx := (e i).1
  have hidx_lt : idx < N := (e i).2
  have hidx_succ : idx + 1 ≤ N := Nat.succ_le_of_lt hidx_lt
  have hslice_eq :
      (paper_lmms_prefixSliceList goods cut idx).toFinset =
        goods.toFinset.filter fun g =>
          cut idx ≤ goods.idxOf g ∧ goods.idxOf g < cut (idx + 1) := by
    exact
      paper_lmms_prefixSliceList_toFinset_eq_filter_idxOf
        (goods := goods) (cut := cut) (k := idx)
        (Finset.nodup_toList lowGoods)
        (hcut_mono idx (idx + 1) (Nat.le_succ idx) hidx_succ)
        (by simpa [N, goods] using hcut_len (idx + 1) hidx_succ)
  have htarget :
      (paper_lmms_prefixSliceList lowGoods.toList cut
            ((Fintype.equivFin SourceAgent) i).1).toFinset =
        goods.toFinset.filter fun g =>
          cut idx ≤ goods.idxOf g ∧ goods.idxOf g < cut (idx + 1) := by
    simpa [goods, e, idx] using hslice_eq
  ext g
  constructor
  · intro hgfilter
    rcases Finset.mem_filter.mp hgfilter with ⟨hglow, howner_eq⟩
    let k := Classical.choose (hinterval g hglow)
    have hk_spec := Classical.choose_spec (hinterval g hglow)
    have hk_fin_eq : (⟨k, hk_spec.1⟩ : Fin N) = e i := by
      have hcong := congrArg e howner_eq
      simpa [owner, hglow, e, k] using hcong
    have hk_eq_idx : k = idx := by
      exact congrArg Fin.val hk_fin_eq
    have hk_spec_k :
        k < N ∧ cut k ≤ goods.idxOf g ∧ goods.idxOf g < cut (k + 1) := by
      simpa [k] using hk_spec
    have hmem_goods : g ∈ goods.toFinset := by
      simpa [goods] using hglow
    have hmem_interval :
        cut idx ≤ goods.idxOf g ∧ goods.idxOf g < cut (idx + 1) := by
      simpa [hk_eq_idx, idx] using hk_spec_k.2
    have hmem_filter :
        g ∈ goods.toFinset.filter fun g =>
          cut idx ≤ goods.idxOf g ∧ goods.idxOf g < cut (idx + 1) :=
      Finset.mem_filter.mpr ⟨hmem_goods, hmem_interval⟩
    simpa [htarget] using hmem_filter
  · intro hgslice
    have hmem_filter :
        g ∈ goods.toFinset.filter fun g =>
          cut idx ≤ goods.idxOf g ∧ goods.idxOf g < cut (idx + 1) := by
      simpa [htarget] using hgslice
    rcases Finset.mem_filter.mp hmem_filter with ⟨hg_goods_fin, hidx_interval⟩
    have hglow : g ∈ lowGoods := by
      simpa [goods] using hg_goods_fin
    let k := Classical.choose (hinterval g hglow)
    have hk_spec := Classical.choose_spec (hinterval g hglow)
    have hk_spec_k :
        k < N ∧ cut k ≤ goods.idxOf g ∧ goods.idxOf g < cut (k + 1) := by
      simpa [k] using hk_spec
    have hk_eq_idx : k = idx := by
      have hk_le_N : k ≤ N := Nat.le_of_lt hk_spec_k.1
      by_cases hk_le_idx : k ≤ idx
      · by_cases hkeq : k = idx
        · exact hkeq
        · have hk_lt_idx : k < idx := lt_of_le_of_ne hk_le_idx hkeq
          have hk_succ_le_idx : k + 1 ≤ idx := Nat.succ_le_of_lt hk_lt_idx
          have hcut_le :
              cut (k + 1) ≤ cut idx :=
            hcut_mono (k + 1) idx hk_succ_le_idx (Nat.le_of_lt hidx_lt)
          omega
      · have hidx_lt_k : idx < k := lt_of_not_ge hk_le_idx
        have hidx_succ_le_k : idx + 1 ≤ k := Nat.succ_le_of_lt hidx_lt_k
        have hcut_le :
            cut (idx + 1) ≤ cut k :=
          hcut_mono (idx + 1) k hidx_succ_le_k hk_le_N
        omega
    have howner_eq : owner g = i := by
      have hk_fin_eq : (⟨k, hk_spec.1⟩ : Fin N) = e i := by
        apply Fin.ext
        exact hk_eq_idx
      have hsymm_eq : e.symm (⟨k, hk_spec.1⟩ : Fin N) = i := by
        exact e.symm_apply_eq.mpr hk_fin_eq
      simpa [owner, hglow, e, k] using hsymm_eq
    exact Finset.mem_filter.mpr ⟨hglow, howner_eq⟩

/--
Owner-filter sum version of the prefix-slice construction.  It is the direct
input required by the low-good owner-estimate bridge.
-/
theorem paper_lmms_exists_owner_slice_sum_eq_of_monotone_cuts
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ) (cut : ℕ → ℕ)
    (hcut0 : cut 0 = 0)
    (hcut_card : cut (Fintype.card SourceAgent) = lowGoods.toList.length)
    (hcut_len :
      ∀ k : ℕ, k ≤ Fintype.card SourceAgent → cut k ≤ lowGoods.toList.length)
    (hcut_mono :
      ∀ k l : ℕ, k ≤ l → l ≤ Fintype.card SourceAgent → cut k ≤ cut l) :
    ∃ owner : SourceItem → SourceAgent,
      ∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i).sum v =
          ((paper_lmms_prefixSliceList lowGoods.toList cut
            ((Fintype.equivFin SourceAgent) i).1).map v).sum := by
  rcases
      paper_lmms_exists_owner_filter_eq_prefixSliceList_toFinset_of_monotone_cuts
        lowGoods cut hcut0 hcut_card hcut_len hcut_mono with
    ⟨owner, howner⟩
  refine ⟨owner, ?_⟩
  intro i
  rw [howner i]
  exact
    List.sum_toFinset v
      ((List.take_sublist _ _).nodup
        ((List.drop_sublist _ _).nodup (Finset.nodup_toList lowGoods)))

/--
The target mass assigned to the interval between consecutive cumulative
targets.
-/
noncomputable def paper_lmms_targetIncrement
    (targetPrefix : ℕ → ℝ) (k : ℕ) : ℝ :=
  targetPrefix (k + 1) - targetPrefix k

/--
Cumulative target load for the first `k` agents in the canonical `Fin N` order.
-/
noncomputable def paper_lmms_finPrefixTarget
    {N : ℕ} (target : Fin N → ℝ) (k : ℕ) : ℝ :=
  (Finset.range k).sum fun r =>
    if h : r < N then target ⟨r, h⟩ else 0

/-- The empty finite-agent prefix has target load zero. -/
theorem paper_lmms_finPrefixTarget_zero
    {N : ℕ} (target : Fin N → ℝ) :
    paper_lmms_finPrefixTarget target 0 = 0 := by
  simp [paper_lmms_finPrefixTarget]

/-- The full finite-agent prefix is the total target load. -/
theorem paper_lmms_finPrefixTarget_total
    {N : ℕ} (target : Fin N → ℝ) :
    paper_lmms_finPrefixTarget target N = ∑ i : Fin N, target i := by
  simpa [paper_lmms_finPrefixTarget] using
    (Finset.sum_fin_eq_sum_range target).symm

/-- Finite-agent cumulative target loads are nonnegative under nonnegative targets. -/
theorem paper_lmms_finPrefixTarget_nonneg
    {N : ℕ} (target : Fin N → ℝ)
    (htarget_nonneg : ∀ i : Fin N, 0 ≤ target i)
    (k : ℕ) :
    0 ≤ paper_lmms_finPrefixTarget target k := by
  unfold paper_lmms_finPrefixTarget
  exact Finset.sum_nonneg fun r _hr => by
    by_cases hrN : r < N
    · simpa [hrN] using htarget_nonneg ⟨r, hrN⟩
    · simp [hrN]

/-- Finite-agent cumulative target loads are monotone under nonnegative targets. -/
theorem paper_lmms_finPrefixTarget_mono
    {N : ℕ} (target : Fin N → ℝ)
    (htarget_nonneg : ∀ i : Fin N, 0 ≤ target i)
    {k l : ℕ} (hkl : k ≤ l) :
    paper_lmms_finPrefixTarget target k ≤
      paper_lmms_finPrefixTarget target l := by
  unfold paper_lmms_finPrefixTarget
  refine Finset.sum_le_sum_of_subset_of_nonneg ?hsubset ?hnonneg
  · intro r hr
    exact Finset.mem_range.mpr (lt_of_lt_of_le (Finset.mem_range.mp hr) hkl)
  · intro r _hrl _hrk
    by_cases hrN : r < N
    · simpa [hrN] using htarget_nonneg ⟨r, hrN⟩
    · simp [hrN]

/--
The increment of finite-agent cumulative targets is exactly the next agent's
target.
-/
theorem paper_lmms_targetIncrement_finPrefixTarget
    {N : ℕ} (target : Fin N → ℝ) {k : ℕ} (hk : k + 1 ≤ N) :
    paper_lmms_targetIncrement (paper_lmms_finPrefixTarget target) k =
      target ⟨k, Nat.lt_of_succ_le hk⟩ := by
  have hklt : k < N := Nat.lt_of_succ_le hk
  unfold paper_lmms_targetIncrement paper_lmms_finPrefixTarget
  rw [Finset.sum_range_succ]
  simp [hklt]

/--
Finite-agent version of the ordered low-good prefix skeleton: nonnegative target
loads with total mass within one item-size of the ordered goods have monotone
cuts whose concrete slice loads approximate each agent target within `delta`.
-/
theorem paper_lmms_exists_prefixSliceList_estimates_for_fin_targets
    {SourceItem : Type*} {delta : ℝ} {N : ℕ}
    (goods : List SourceItem) (v : SourceItem → ℝ)
    (target : Fin N → ℝ)
    (hNpos : 0 < N)
    (hdelta : 0 < delta)
    (htarget_nonneg : ∀ i : Fin N, 0 ≤ target i)
    (hitem_lt : ∀ g : SourceItem, g ∈ goods → v g < delta)
    (htotal_lower :
      paper_lmms_prefixWeight goods v goods.length ≤
        paper_lmms_finPrefixTarget target N)
    (htotal_upper :
      paper_lmms_finPrefixTarget target N <
        paper_lmms_prefixWeight goods v goods.length + delta) :
    ∃ cut : ℕ → ℕ,
      cut 0 = 0 ∧
        cut N = goods.length ∧
        (∀ k : ℕ, k ≤ N → cut k ≤ goods.length) ∧
        (∀ k l : ℕ, k ≤ l → l ≤ N → cut k ≤ cut l) ∧
        ∀ i : Fin N,
          target i - delta ≤
              ((paper_lmms_prefixSliceList goods cut i.1).map v).sum ∧
            ((paper_lmms_prefixSliceList goods cut i.1).map v).sum ≤
              target i + delta := by
  rcases
      paper_lmms_exists_monotone_prefixWeight_cuts
        goods v (paper_lmms_finPrefixTarget target) hNpos hdelta
        (paper_lmms_finPrefixTarget_zero target)
        (fun k _hk => paper_lmms_finPrefixTarget_nonneg target htarget_nonneg k)
        (fun k l hkl _hlN =>
          paper_lmms_finPrefixTarget_mono target htarget_nonneg hkl)
        hitem_lt htotal_lower htotal_upper with
    ⟨cut, hcut0, hcutN, hcut_len, hcut_mono, hcut_weight⟩
  refine ⟨cut, hcut0, hcutN, hcut_len, hcut_mono, ?_⟩
  intro i
  have hi_succ : i.1 + 1 ≤ N := Nat.succ_le_of_lt i.2
  have hi_le : i.1 ≤ N := Nat.le_trans (Nat.le_succ i.1) hi_succ
  have hcurr := hcut_weight i.1 hi_le
  have hnext := hcut_weight (i.1 + 1) hi_succ
  have hsum :=
    paper_lmms_prefixSliceWeight_eq_sum_prefixSliceList goods v cut i.1
      (hcut_mono i.1 (i.1 + 1) (Nat.le_succ i.1) hi_succ)
  have hincr :
      paper_lmms_targetIncrement (paper_lmms_finPrefixTarget target) i.1 =
        target i := by
    simpa using paper_lmms_targetIncrement_finPrefixTarget target hi_succ
  constructor
  · rw [hsum, ← hincr]
    unfold paper_lmms_prefixSliceWeight paper_lmms_targetIncrement
    linarith
  · rw [hsum, ← hincr]
    unfold paper_lmms_prefixSliceWeight paper_lmms_targetIncrement
    linarith

/--
Finite-agent ordered low-good prefix skeleton for an arbitrary finite agent type.
The canonical `Fintype.equivFin` order supplies the slice index for each agent.
-/
theorem paper_lmms_exists_prefixSliceList_estimates_for_finite_targets
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {delta : ℝ}
    (goods : List SourceItem) (v : SourceItem → ℝ)
    (target : SourceAgent → ℝ)
    (hdelta : 0 < delta)
    (htarget_nonneg : ∀ i : SourceAgent, 0 ≤ target i)
    (hitem_lt : ∀ g : SourceItem, g ∈ goods → v g < delta)
    (htotal_lower :
      paper_lmms_prefixWeight goods v goods.length ≤
        ∑ i : SourceAgent, target i)
    (htotal_upper :
      (∑ i : SourceAgent, target i) <
        paper_lmms_prefixWeight goods v goods.length + delta) :
    ∃ cut : ℕ → ℕ,
      cut 0 = 0 ∧
        cut (Fintype.card SourceAgent) = goods.length ∧
        (∀ k : ℕ, k ≤ Fintype.card SourceAgent → cut k ≤ goods.length) ∧
        (∀ k l : ℕ, k ≤ l → l ≤ Fintype.card SourceAgent →
          cut k ≤ cut l) ∧
        ∀ i : SourceAgent,
          target i - delta ≤
              ((paper_lmms_prefixSliceList goods cut
                ((Fintype.equivFin SourceAgent) i).1).map v).sum ∧
            ((paper_lmms_prefixSliceList goods cut
                ((Fintype.equivFin SourceAgent) i).1).map v).sum ≤
              target i + delta := by
  classical
  let e : SourceAgent ≃ Fin (Fintype.card SourceAgent) :=
    Fintype.equivFin SourceAgent
  let targetFin : Fin (Fintype.card SourceAgent) → ℝ :=
    fun j => target (e.symm j)
  have hNpos : 0 < Fintype.card SourceAgent :=
    Fintype.card_pos_iff.mpr inferInstance
  have htargetFin_nonneg :
      ∀ j : Fin (Fintype.card SourceAgent), 0 ≤ targetFin j := by
    intro j
    exact htarget_nonneg (e.symm j)
  have hsum_eq :
      (∑ j : Fin (Fintype.card SourceAgent), targetFin j) =
        ∑ i : SourceAgent, target i := by
    symm
    calc
      (∑ i : SourceAgent, target i) =
          ∑ i : SourceAgent, targetFin (e i) := by
            simp [targetFin, e]
      _ = ∑ j : Fin (Fintype.card SourceAgent), targetFin j :=
            Equiv.sum_comp e targetFin
  have htotal_lower_fin :
      paper_lmms_prefixWeight goods v goods.length ≤
        paper_lmms_finPrefixTarget targetFin (Fintype.card SourceAgent) := by
    rwa [paper_lmms_finPrefixTarget_total targetFin, hsum_eq]
  have htotal_upper_fin :
      paper_lmms_finPrefixTarget targetFin (Fintype.card SourceAgent) <
        paper_lmms_prefixWeight goods v goods.length + delta := by
    rwa [paper_lmms_finPrefixTarget_total targetFin, hsum_eq]
  rcases
      paper_lmms_exists_prefixSliceList_estimates_for_fin_targets
        goods v targetFin hNpos hdelta htargetFin_nonneg hitem_lt
        htotal_lower_fin htotal_upper_fin with
    ⟨cut, hcut0, hcutN, hcut_len, hcut_mono, hslice⟩
  refine ⟨cut, hcut0, hcutN, hcut_len, hcut_mono, ?_⟩
  intro i
  have hi := hslice (e i)
  simpa [targetFin, e] using hi

/--
If two consecutive cumulative prefixes are each within `delta` from below of
their cumulative targets, then the slice between those cuts is within `delta`
of the corresponding target increment.
-/
theorem paper_lmms_prefixSliceWeight_estimates_of_cumulative_bounds
    {SourceItem : Type*} {delta : ℝ}
    {goods : List SourceItem} {v : SourceItem → ℝ}
    {targetPrefix : ℕ → ℝ} {cut : ℕ → ℕ} {k : ℕ}
    (hcurr :
      paper_lmms_prefixWeight goods v (cut k) ≤ targetPrefix k ∧
        targetPrefix k <
          paper_lmms_prefixWeight goods v (cut k) + delta)
    (hnext :
      paper_lmms_prefixWeight goods v (cut (k + 1)) ≤
          targetPrefix (k + 1) ∧
        targetPrefix (k + 1) <
          paper_lmms_prefixWeight goods v (cut (k + 1)) + delta) :
    paper_lmms_targetIncrement targetPrefix k - delta ≤
        paper_lmms_prefixSliceWeight goods v cut k ∧
      paper_lmms_prefixSliceWeight goods v cut k ≤
        paper_lmms_targetIncrement targetPrefix k + delta := by
  unfold paper_lmms_prefixSliceWeight paper_lmms_targetIncrement
  constructor <;> linarith

/--
Per-slice estimates from a monotone cut sequence whose cumulative prefixes are
within `delta` of the cumulative targets.
-/
theorem paper_lmms_prefixSliceWeight_estimates_of_monotone_cuts
    {SourceItem : Type*} {delta : ℝ} {N : ℕ}
    {goods : List SourceItem} {v : SourceItem → ℝ}
    {targetPrefix : ℕ → ℝ} {cut : ℕ → ℕ}
    (hcut_weight :
      ∀ k : ℕ, k ≤ N →
        paper_lmms_prefixWeight goods v (cut k) ≤ targetPrefix k ∧
          targetPrefix k <
            paper_lmms_prefixWeight goods v (cut k) + delta)
    (k : ℕ) (hk : k + 1 ≤ N) :
    paper_lmms_targetIncrement targetPrefix k - delta ≤
        paper_lmms_prefixSliceWeight goods v cut k ∧
      paper_lmms_prefixSliceWeight goods v cut k ≤
        paper_lmms_targetIncrement targetPrefix k + delta :=
  paper_lmms_prefixSliceWeight_estimates_of_cumulative_bounds
    (hcut_weight k (Nat.le_trans (Nat.le_succ k) hk))
    (hcut_weight (k + 1) hk)

/--
Concrete list-slice estimates from a monotone cut sequence.  This is the
list-level form used before converting slices to owner-filter bundles.
-/
theorem paper_lmms_prefixSliceList_sum_estimates_of_monotone_cuts
    {SourceItem : Type*} {delta : ℝ} {N : ℕ}
    {goods : List SourceItem} {v : SourceItem → ℝ}
    {targetPrefix : ℕ → ℝ} {cut : ℕ → ℕ}
    (hcut_mono :
      ∀ k l : ℕ, k ≤ l → l ≤ N → cut k ≤ cut l)
    (hcut_weight :
      ∀ k : ℕ, k ≤ N →
        paper_lmms_prefixWeight goods v (cut k) ≤ targetPrefix k ∧
          targetPrefix k <
            paper_lmms_prefixWeight goods v (cut k) + delta)
    (k : ℕ) (hk : k + 1 ≤ N) :
    paper_lmms_targetIncrement targetPrefix k - delta ≤
        ((paper_lmms_prefixSliceList goods cut k).map v).sum ∧
      ((paper_lmms_prefixSliceList goods cut k).map v).sum ≤
        paper_lmms_targetIncrement targetPrefix k + delta := by
  have hslice :=
    paper_lmms_prefixSliceWeight_estimates_of_monotone_cuts
      (goods := goods) (v := v) (targetPrefix := targetPrefix)
      (cut := cut) hcut_weight k hk
  have hsum :=
    paper_lmms_prefixSliceWeight_eq_sum_prefixSliceList goods v cut k
      (hcut_mono k (k + 1) (Nat.le_succ k) hk)
  simpa [hsum] using hslice

/--
Adapter from ordered prefix-slice load estimates to the owner-filter estimates
used by the low-good partition boundary.  The remaining combinatorial step is
to construct an owner map whose filters have the stated slice sums.
-/
theorem paper_lmms_low_goods_owner_load_estimates_of_prefix_sliceList_estimates
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {delta : ℝ}
    (lowGoods : Finset SourceItem) (goods : List SourceItem)
    (v : SourceItem → ℝ) (owner : SourceItem → SourceAgent)
    (target : SourceAgent → ℝ) (cut : ℕ → ℕ)
    (hslice_lower :
      ∀ i : SourceAgent,
        target i - delta ≤
          ((paper_lmms_prefixSliceList goods cut
            ((Fintype.equivFin SourceAgent) i).1).map v).sum)
    (hslice_upper :
      ∀ i : SourceAgent,
        ((paper_lmms_prefixSliceList goods cut
          ((Fintype.equivFin SourceAgent) i).1).map v).sum ≤
          target i + delta)
    (howner_slice :
      ∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i).sum v =
          ((paper_lmms_prefixSliceList goods cut
            ((Fintype.equivFin SourceAgent) i).1).map v).sum) :
    (∀ i : SourceAgent,
      (lowGoods.filter fun g => owner g = i).sum v ≤ target i + delta) ∧
      ∀ i : SourceAgent,
        target i - delta ≤ (lowGoods.filter fun g => owner g = i).sum v := by
  constructor
  · intro i
    rw [howner_slice i]
    exact hslice_upper i
  · intro i
    rw [howner_slice i]
    exact hslice_lower i

/--
Finite-target ordered low-good construction: if the ordered low goods have
total value within one `delta` of the target total, and every low good is
smaller than `delta`, then the prefix-slice construction yields an owner map
whose filtered low-good bundles satisfy the per-agent target estimates.
-/
theorem paper_lmms_exists_low_goods_owner_load_estimates_of_finite_prefix_targets
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {delta : ℝ}
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (target : SourceAgent → ℝ)
    (hdelta : 0 < delta)
    (htarget_nonneg : ∀ i : SourceAgent, 0 ≤ target i)
    (hitem_lt : ∀ g : SourceItem, g ∈ lowGoods → v g < delta)
    (htotal_lower :
      paper_lmms_prefixWeight lowGoods.toList v lowGoods.toList.length ≤
        ∑ i : SourceAgent, target i)
    (htotal_upper :
      (∑ i : SourceAgent, target i) <
        paper_lmms_prefixWeight lowGoods.toList v lowGoods.toList.length +
          delta) :
    ∃ owner : SourceItem → SourceAgent,
      (∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i).sum v ≤ target i + delta) ∧
        ∀ i : SourceAgent,
          target i - delta ≤ (lowGoods.filter fun g => owner g = i).sum v := by
  rcases
      paper_lmms_exists_prefixSliceList_estimates_for_finite_targets
        lowGoods.toList v target hdelta htarget_nonneg
        (fun g hg => hitem_lt g (by simpa using Finset.mem_toList.mp hg))
        htotal_lower htotal_upper with
    ⟨cut, hcut0, hcut_card, hcut_len, hcut_mono, hslice⟩
  rcases
      paper_lmms_exists_owner_slice_sum_eq_of_monotone_cuts
        lowGoods v cut hcut0 hcut_card hcut_len hcut_mono with
    ⟨owner, howner_slice⟩
  refine ⟨owner, ?_⟩
  exact
    paper_lmms_low_goods_owner_load_estimates_of_prefix_sliceList_estimates
      lowGoods lowGoods.toList v owner target cut
      (fun i => (hslice i).1) (fun i => (hslice i).2) howner_slice

/--
Finite-target low-good construction with the total-value premise stated as a
finset sum rather than a full-prefix list weight.
-/
theorem paper_lmms_exists_low_goods_owner_load_estimates_of_finite_prefix_targets_of_total_sum
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {delta : ℝ}
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (target : SourceAgent → ℝ)
    (hdelta : 0 < delta)
    (htarget_nonneg : ∀ i : SourceAgent, 0 ≤ target i)
    (hitem_lt : ∀ g : SourceItem, g ∈ lowGoods → v g < delta)
    (htotal_lower :
      lowGoods.sum v ≤ ∑ i : SourceAgent, target i)
    (htotal_upper :
      (∑ i : SourceAgent, target i) < lowGoods.sum v + delta) :
    ∃ owner : SourceItem → SourceAgent,
      (∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i).sum v ≤ target i + delta) ∧
        ∀ i : SourceAgent,
          target i - delta ≤ (lowGoods.filter fun g => owner g = i).sum v := by
  exact
    paper_lmms_exists_low_goods_owner_load_estimates_of_finite_prefix_targets
      lowGoods v target hdelta htarget_nonneg hitem_lt
      (by
        simpa [paper_lmms_prefixWeight_toList_card_eq_sum lowGoods v]
          using htotal_lower)
      (by
        simpa [paper_lmms_prefixWeight_toList_card_eq_sum lowGoods v]
          using htotal_upper)

/--
The low artificial supply total provides exactly the one-unit total bounds
needed by the ordered low-good prefix construction.
-/
theorem paper_lmms_low_goods_aggregated_supply_total_bounds
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (lowRoundedLoad : SourceAgent → ℝ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hlow_nonneg : ∀ g : SourceItem, g ∈ lowGoods → 0 ≤ v g)
    (hlowRounded_total :
      (∑ i : SourceAgent, lowRoundedLoad i) =
        ∑ k : Theorem33.RoundedValueIndex lambda,
          (Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v) k : ℝ) *
            Theorem33.roundedValue L lambda k) :
    lowGoods.sum v ≤ ∑ i : SourceAgent, lowRoundedLoad i ∧
      (∑ i : SourceAgent, lowRoundedLoad i) <
        lowGoods.sum v + L / (lambda : ℝ) := by
  have hS_nonneg : 0 ≤ lowGoods.sum v :=
    Finset.sum_nonneg fun g hg => hlow_nonneg g hg
  have hbounds :=
    Theorem33.lowGoodsAggregatedSupply_weighted_sum_bounds
      (L := L) (lambda := lambda) (S := lowGoods.sum v)
      hlambda hL hS_nonneg
  constructor
  · rw [hlowRounded_total]
    exact hbounds.1
  · rw [hlowRounded_total]
    exact hbounds.2

/--
Low-owner estimates from the actual aggregated low artificial-supply total.
This is the low-good prefix construction specialized to the paper's rounded
low-good aggregation.
-/
theorem paper_lmms_exists_low_goods_owner_load_estimates_of_aggregated_lowRoundedLoad
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (lowRoundedLoad : SourceAgent → ℝ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hlow_nonneg : ∀ g : SourceItem, g ∈ lowGoods → 0 ≤ v g)
    (hlow_item_lt :
      ∀ g : SourceItem, g ∈ lowGoods → v g < L / (lambda : ℝ))
    (hlowRounded_nonneg : ∀ i : SourceAgent, 0 ≤ lowRoundedLoad i)
    (hlowRounded_total :
      (∑ i : SourceAgent, lowRoundedLoad i) =
        ∑ k : Theorem33.RoundedValueIndex lambda,
          (Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v) k : ℝ) *
            Theorem33.roundedValue L lambda k) :
    ∃ owner : SourceItem → SourceAgent,
      (∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i).sum v ≤
          lowRoundedLoad i + L / (lambda : ℝ)) ∧
        ∀ i : SourceAgent,
          lowRoundedLoad i - L / (lambda : ℝ) ≤
            (lowGoods.filter fun g => owner g = i).sum v := by
  have hlambda_real : 0 < (lambda : ℝ) := by
    exact_mod_cast hlambda
  have hdelta : 0 < L / (lambda : ℝ) :=
    div_pos hL hlambda_real
  have hbounds :=
    paper_lmms_low_goods_aggregated_supply_total_bounds
      lowGoods v lowRoundedLoad hlambda hL hlow_nonneg hlowRounded_total
  exact
    paper_lmms_exists_low_goods_owner_load_estimates_of_finite_prefix_targets_of_total_sum
      lowGoods v lowRoundedLoad hdelta hlowRounded_nonneg hlow_item_lt
      hbounds.1 hbounds.2

/--
Theorem 3.3 low-good partition boundary: an owner map whose filtered low-good
bundles satisfy the desired per-agent load estimates yields an exact low-good
allocation carrying those same estimates.
-/
theorem paper_lmms_theorem_3_3_exists_low_goods_partition_of_owner_load_estimates
    {SourceAgent SourceItem : Type*}
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (owner : SourceItem → SourceAgent)
    (lowRoundedLoad : SourceAgent → ℝ)
    (hupper :
      ∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i).sum v ≤
          lowRoundedLoad i + L / (lambda : ℝ))
    (hlower :
      ∀ i : SourceAgent,
        lowRoundedLoad i - L / (lambda : ℝ) ≤
          (lowGoods.filter fun g => owner g = i).sum v) :
    ∃ lowPart : Allocation SourceAgent SourceItem,
      IsAllocationOf lowPart lowGoods ∧
        ∀ i : SourceAgent,
          (lowPart i).sum v ≤ lowRoundedLoad i + L / (lambda : ℝ) ∧
            lowRoundedLoad i - L / (lambda : ℝ) ≤ (lowPart i).sum v := by
  classical
  let lowPart : Allocation SourceAgent SourceItem :=
    fun i => lowGoods.filter fun g => owner g = i
  refine
    ⟨lowPart, paper_lmms_isAllocationOf_filter_owner lowGoods owner, ?_⟩
  intro i
  exact ⟨by simpa [lowPart] using hupper i,
    by simpa [lowPart] using hlower i⟩

/--
Theorem 3.3 low-good ordered-prefix construction: finite prefix targets produce
an exact low-good allocation whose bundle loads are within one `delta` of each
target.
-/
theorem paper_lmms_theorem_3_3_exists_low_goods_partition_of_finite_prefix_targets
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {delta : ℝ}
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (target : SourceAgent → ℝ)
    (hdelta : 0 < delta)
    (htarget_nonneg : ∀ i : SourceAgent, 0 ≤ target i)
    (hitem_lt : ∀ g : SourceItem, g ∈ lowGoods → v g < delta)
    (htotal_lower :
      paper_lmms_prefixWeight lowGoods.toList v lowGoods.toList.length ≤
        ∑ i : SourceAgent, target i)
    (htotal_upper :
      (∑ i : SourceAgent, target i) <
        paper_lmms_prefixWeight lowGoods.toList v lowGoods.toList.length +
          delta) :
    ∃ lowPart : Allocation SourceAgent SourceItem,
      IsAllocationOf lowPart lowGoods ∧
        ∀ i : SourceAgent,
          (lowPart i).sum v ≤ target i + delta ∧
            target i - delta ≤ (lowPart i).sum v := by
  rcases
      paper_lmms_exists_low_goods_owner_load_estimates_of_finite_prefix_targets
        lowGoods v target hdelta htarget_nonneg hitem_lt
        htotal_lower htotal_upper with
    ⟨owner, hupper, hlower⟩
  rcases
      paper_lmms_theorem_3_3_exists_low_goods_partition_of_owner_load_estimates
        (L := delta) (lambda := 1) lowGoods v owner target
        (by
          intro i
          simpa using hupper i)
        (by
          intro i
          simpa using hlower i) with
    ⟨lowPart, halloc, hestimates⟩
  refine ⟨lowPart, halloc, ?_⟩
  intro i
  simpa using hestimates i

/--
Theorem 3.3 low-good ordered-prefix construction with the low-good total stated
as a finset sum.
-/
theorem paper_lmms_theorem_3_3_exists_low_goods_partition_of_finite_prefix_targets_of_total_sum
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {delta : ℝ}
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (target : SourceAgent → ℝ)
    (hdelta : 0 < delta)
    (htarget_nonneg : ∀ i : SourceAgent, 0 ≤ target i)
    (hitem_lt : ∀ g : SourceItem, g ∈ lowGoods → v g < delta)
    (htotal_lower :
      lowGoods.sum v ≤ ∑ i : SourceAgent, target i)
    (htotal_upper :
      (∑ i : SourceAgent, target i) < lowGoods.sum v + delta) :
    ∃ lowPart : Allocation SourceAgent SourceItem,
      IsAllocationOf lowPart lowGoods ∧
        ∀ i : SourceAgent,
          (lowPart i).sum v ≤ target i + delta ∧
            target i - delta ≤ (lowPart i).sum v := by
  exact
    paper_lmms_theorem_3_3_exists_low_goods_partition_of_finite_prefix_targets
      lowGoods v target hdelta htarget_nonneg hitem_lt
      (by
        simpa [paper_lmms_prefixWeight_toList_card_eq_sum lowGoods v]
          using htotal_lower)
      (by
        simpa [paper_lmms_prefixWeight_toList_card_eq_sum lowGoods v]
          using htotal_upper)

/--
Exact low-partition to owner-load boundary: an already constructed exact
low-good allocation satisfying the per-agent one-unit estimates induces an
owner map satisfying the equivalent filtered low-good estimates.
-/
theorem paper_lmms_exists_low_goods_owner_load_estimates_of_exact_low_partition
    {SourceAgent SourceItem : Type*}
    [Nonempty SourceAgent] [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (lowPart : Allocation SourceAgent SourceItem)
    (lowRoundedLoad : SourceAgent → ℝ)
    (halloc : IsAllocationOf lowPart lowGoods)
    (hupper :
      ∀ i : SourceAgent,
        (lowPart i).sum v ≤ lowRoundedLoad i + L / (lambda : ℝ))
    (hlower :
      ∀ i : SourceAgent,
        lowRoundedLoad i - L / (lambda : ℝ) ≤ (lowPart i).sum v) :
    ∃ owner : SourceItem → SourceAgent,
      (∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i).sum v ≤
          lowRoundedLoad i + L / (lambda : ℝ)) ∧
        ∀ i : SourceAgent,
          lowRoundedLoad i - L / (lambda : ℝ) ≤
            (lowGoods.filter fun g => owner g = i).sum v := by
  rcases paper_lmms_exists_owner_filter_eq_of_isAllocationOf halloc with
    ⟨owner, howner_eq⟩
  refine ⟨owner, ?_, ?_⟩
  · intro i
    simpa [howner_eq i] using hupper i
  · intro i
    simpa [howner_eq i] using hlower i

/--
Low-good owner estimates and exact low partitions are equivalent formulations:
an owner map gives the exact partition by filtering, and any exact partition
induces an owner map whose filters recover that partition.
-/
theorem paper_lmms_exists_low_goods_owner_load_estimates_iff_exists_exact_low_partition
    {SourceAgent SourceItem : Type*}
    [Nonempty SourceAgent] [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (lowRoundedLoad : SourceAgent → ℝ) :
    (∃ owner : SourceItem → SourceAgent,
      (∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i).sum v ≤
          lowRoundedLoad i + L / (lambda : ℝ)) ∧
        ∀ i : SourceAgent,
          lowRoundedLoad i - L / (lambda : ℝ) ≤
            (lowGoods.filter fun g => owner g = i).sum v) ↔
      ∃ lowPart : Allocation SourceAgent SourceItem,
        IsAllocationOf lowPart lowGoods ∧
          ∀ i : SourceAgent,
            (lowPart i).sum v ≤ lowRoundedLoad i + L / (lambda : ℝ) ∧
              lowRoundedLoad i - L / (lambda : ℝ) ≤ (lowPart i).sum v := by
  constructor
  · intro howner_estimates
    rcases howner_estimates with ⟨owner, hupper, hlower⟩
    exact
      paper_lmms_theorem_3_3_exists_low_goods_partition_of_owner_load_estimates
        lowGoods v owner lowRoundedLoad hupper hlower
  · intro hpartition
    rcases hpartition with ⟨lowPart, halloc, hestimates⟩
    exact
      paper_lmms_exists_low_goods_owner_load_estimates_of_exact_low_partition
        lowGoods v lowPart lowRoundedLoad halloc
        (fun i => (hestimates i).1)
        (fun i => (hestimates i).2)

/--
Union of two exact allocations over disjoint goods: if `highPart` exactly
allocates `highGoods` and `lowPart` exactly allocates `lowGoods`, and the two
goods sets are disjoint, then the pointwise union exactly allocates the union
of the goods.
-/
theorem paper_lmms_isAllocationOf_union_of_disjoint_allocations
    {SourceAgent SourceItem : Type*}
    [DecidableEq SourceItem]
    {highPart lowPart : Allocation SourceAgent SourceItem}
    {highGoods lowGoods : Finset SourceItem}
    (hhigh_alloc : IsAllocationOf highPart highGoods)
    (hlow_alloc : IsAllocationOf lowPart lowGoods)
    (hdisjoint : Disjoint highGoods lowGoods) :
    IsAllocationOf
      (fun i : SourceAgent => highPart i ∪ lowPart i)
      (highGoods ∪ lowGoods) := by
  classical
  constructor
  · intro i g hg
    rcases Finset.mem_union.mp hg with hhigh | hlow
    · exact Finset.mem_union.mpr (Or.inl (hhigh_alloc.1 i g hhigh))
    · exact Finset.mem_union.mpr (Or.inr (hlow_alloc.1 i g hlow))
  · intro g hg
    rcases Finset.mem_union.mp hg with hghigh | hglow
    · rcases hhigh_alloc.2 g hghigh with ⟨owner, howner, hunique⟩
      refine ⟨owner, Finset.mem_union.mpr (Or.inl howner), ?_⟩
      intro j hj
      rcases Finset.mem_union.mp hj with hjhigh | hjlow
      · exact hunique j hjhigh
      · have hlow_goods : g ∈ lowGoods := hlow_alloc.1 j g hjlow
        exact (Finset.disjoint_left.mp hdisjoint hghigh hlow_goods).elim
    · rcases hlow_alloc.2 g hglow with ⟨owner, howner, hunique⟩
      refine ⟨owner, Finset.mem_union.mpr (Or.inr howner), ?_⟩
      intro j hj
      rcases Finset.mem_union.mp hj with hjhigh | hjlow
      · have hhigh_goods : g ∈ highGoods := hhigh_alloc.1 j g hjhigh
        exact (Finset.disjoint_left.mp hdisjoint hhigh_goods hglow).elim
      · exact hunique j hjlow

/--
Finite-sum union helper for high/low bundles: subsets of disjoint high and low
goods are themselves disjoint, so the value of their union is the sum of their
values.
-/
theorem paper_lmms_finset_sum_union_of_subsets_of_disjoint
    {SourceItem : Type*} [DecidableEq SourceItem]
    {highBundle lowBundle highGoods lowGoods : Finset SourceItem}
    (v : SourceItem → ℝ)
    (hhigh_subset : highBundle ⊆ highGoods)
    (hlow_subset : lowBundle ⊆ lowGoods)
    (hdisjoint : Disjoint highGoods lowGoods) :
    (highBundle ∪ lowBundle).sum v =
      highBundle.sum v + lowBundle.sum v := by
  classical
  have hbundle_disjoint : Disjoint highBundle lowBundle := by
    rw [Finset.disjoint_left]
    intro g hghigh hglow
    exact Finset.disjoint_left.mp hdisjoint (hhigh_subset hghigh)
      (hlow_subset hglow)
  exact Finset.sum_union hbundle_disjoint

/-- Common-load form of `Finset.sum_union` for disjoint source bundles. -/
theorem paper_lmms_commonLoad_union_eq_add_of_disjoint
    {SourceItem : Type*} [DecidableEq SourceItem]
    (v : SourceItem → ℝ) {S T : Finset SourceItem}
    (hdisjoint : Disjoint S T) :
    Theorem34.commonLoad v (S ∪ T) =
      Theorem34.commonLoad v S + Theorem34.commonLoad v T := by
  simpa [Theorem34.commonLoad] using Finset.sum_union hdisjoint

/--
Combined high/low source allocation: exact high and low allocations over
disjoint goods assemble into one exact source allocation, and every combined
bundle load is the sum of its high and low bundle loads.
-/
theorem paper_lmms_exists_combined_allocation_of_disjoint_exact_allocations
    {SourceAgent SourceItem : Type*}
    [DecidableEq SourceItem]
    {highPart lowPart : Allocation SourceAgent SourceItem}
    {highGoods lowGoods : Finset SourceItem}
    (v : SourceItem → ℝ)
    (hhigh_alloc : IsAllocationOf highPart highGoods)
    (hlow_alloc : IsAllocationOf lowPart lowGoods)
    (hdisjoint : Disjoint highGoods lowGoods) :
    ∃ combined : Allocation SourceAgent SourceItem,
      IsAllocationOf combined (highGoods ∪ lowGoods) ∧
        (∀ i : SourceAgent, combined i = highPart i ∪ lowPart i) ∧
          ∀ i : SourceAgent,
            (combined i).sum v =
              (highPart i).sum v + (lowPart i).sum v := by
  classical
  let combined : Allocation SourceAgent SourceItem :=
    fun i => highPart i ∪ lowPart i
  refine
    ⟨combined,
      paper_lmms_isAllocationOf_union_of_disjoint_allocations
        hhigh_alloc hlow_alloc hdisjoint,
      ?_, ?_⟩
  · intro i
    rfl
  · intro i
    simpa [combined] using
      paper_lmms_finset_sum_union_of_subsets_of_disjoint
        (v := v)
        (hhigh_subset := fun g hg => hhigh_alloc.1 i g hg)
        (hlow_subset := fun g hg => hlow_alloc.1 i g hg)
        hdisjoint

/--
Common-load version of the high/low output assembly: the pointwise union of
exact high and low allocations is exact, and its common load is the sum of the
high and low common loads.
-/
theorem paper_lmms_exact_high_low_output_assembly
    {SourceAgent SourceItem : Type*}
    [DecidableEq SourceItem]
    {highPart lowPart : Allocation SourceAgent SourceItem}
    {highGoods lowGoods : Finset SourceItem}
    (v : SourceItem → ℝ)
    (hhigh_alloc : IsAllocationOf highPart highGoods)
    (hlow_alloc : IsAllocationOf lowPart lowGoods)
    (hdisjoint : Disjoint highGoods lowGoods) :
    IsAllocationOf
        (fun i : SourceAgent => highPart i ∪ lowPart i)
        (highGoods ∪ lowGoods) ∧
      ∀ i : SourceAgent,
        Theorem34.commonLoad v (highPart i ∪ lowPart i) =
          Theorem34.commonLoad v (highPart i) +
            Theorem34.commonLoad v (lowPart i) := by
  refine
    ⟨paper_lmms_isAllocationOf_union_of_disjoint_allocations
        hhigh_alloc hlow_alloc hdisjoint,
      ?_⟩
  intro i
  have hbundle_disjoint : Disjoint (highPart i) (lowPart i) := by
    rw [Finset.disjoint_left]
    intro g hghigh hglow
    exact Finset.disjoint_left.mp hdisjoint
      (hhigh_alloc.1 i g hghigh) (hlow_alloc.1 i g hglow)
  exact paper_lmms_commonLoad_union_eq_add_of_disjoint v hbundle_disjoint

/--
Concrete exact allocation constructor: if a proposed owner map gives every
agent at least one source good, filtering the goods by owner yields an exact
allocation of the goods and every bundle is nonempty.
-/
theorem paper_lmms_exists_nonempty_exact_allocation_of_surjective_owner
    {SourceAgent SourceItem : Type*}
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    (goods : Finset SourceItem) (owner : SourceItem → SourceAgent)
    (howner : ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ goods ∧ owner g = i) :
    ∃ A : Allocation SourceAgent SourceItem,
      IsAllocationOf A goods ∧
        ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i := by
  classical
  let A : Allocation SourceAgent SourceItem :=
    fun i => goods.filter fun g => owner g = i
  refine
    ⟨A, paper_lmms_isAllocationOf_filter_owner goods owner, ?_⟩
  intro i
  rcases howner i with ⟨g, hg, hgi⟩
  exact ⟨g, by simp [A, hg, hgi]⟩

/--
If total positive item value is exactly `#agents * L` and every item is
strictly smaller than `L`, then there are enough items to give each agent one
owned item.  This is the source-identification bridge needed by the
paper-shaped Claim 3.4 selector.
-/
theorem paper_lmms_exists_surjective_owner_of_total_strictly_small_positive_values
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Fintype SourceItem] [Nonempty SourceAgent]
    {v : SourceItem → ℝ} {L : ℝ}
    (hL : 0 < L)
    (_hpos : ∀ g : SourceItem, 0 < v g)
    (hlt : ∀ g : SourceItem, v g < L)
    (htotal : (∑ g : SourceItem, v g) =
      (Fintype.card SourceAgent : ℝ) * L) :
    ∃ owner : SourceItem → SourceAgent,
      ∀ i : SourceAgent, ∃ g : SourceItem, owner g = i := by
  classical
  have hcard : Fintype.card SourceAgent ≤ Fintype.card SourceItem := by
    by_contra hnot
    have hlt_card : Fintype.card SourceItem < Fintype.card SourceAgent :=
      Nat.lt_of_not_ge hnot
    have hagent_pos : 0 < Fintype.card SourceAgent := Fintype.card_pos
    by_cases hitem_zero : Fintype.card SourceItem = 0
    · haveI : IsEmpty SourceItem := Fintype.card_eq_zero_iff.mp hitem_zero
      have hzero :
          (0 : ℝ) = (Fintype.card SourceAgent : ℝ) * L := by
        simpa using htotal
      have hpositive : 0 < (Fintype.card SourceAgent : ℝ) * L :=
        mul_pos (Nat.cast_pos.mpr hagent_pos) hL
      linarith
    · have hitem_pos : 0 < Fintype.card SourceItem := Nat.pos_of_ne_zero hitem_zero
      have huniv_nonempty : (Finset.univ : Finset SourceItem).Nonempty := by
        exact Finset.card_pos.mp (by simpa using hitem_pos)
      have hsum_lt_item_card :
          (∑ g : SourceItem, v g) < (Fintype.card SourceItem : ℝ) * L := by
        calc
          (∑ g : SourceItem, v g)
              < ∑ _g : SourceItem, L := by
                exact Finset.sum_lt_sum_of_nonempty huniv_nonempty
                  (fun g _hg => hlt g)
          _ = (Fintype.card SourceItem : ℝ) * L := by
                simp [nsmul_eq_mul]
      have hitem_card_lt_agent_card :
          (Fintype.card SourceItem : ℝ) * L <
            (Fintype.card SourceAgent : ℝ) * L :=
        mul_lt_mul_of_pos_right (Nat.cast_lt.mpr hlt_card) hL
      have htotal_lt :
          (∑ g : SourceItem, v g) <
            (Fintype.card SourceAgent : ℝ) * L :=
        hsum_lt_item_card.trans hitem_card_lt_agent_card
      rw [htotal] at htotal_lt
      exact (lt_irrefl _ htotal_lt).elim
  rcases Function.Embedding.nonempty_of_card_le hcard with ⟨e⟩
  let owner : SourceItem → SourceAgent := Function.invFun e
  refine ⟨owner, ?_⟩
  intro i
  refine ⟨e i, ?_⟩
  exact Function.leftInverse_invFun e.injective i

/--
For an exact finite allocation, summing identical item values over all bundles
is the same as summing them once over the allocated goods.
-/
theorem paper_lmms_isAllocationOf_sum_bundle_values_eq_sum_goods
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [DecidableEq SourceItem]
    {A : Allocation SourceAgent SourceItem} {goods : Finset SourceItem}
    {v : SourceItem → ℝ}
    (halloc : IsAllocationOf A goods) :
    (∑ i : SourceAgent, (A i).sum v) = goods.sum v := by
  classical
  have hbundle :
      ∀ i : SourceAgent,
        (A i).sum v =
          goods.sum fun g => if g ∈ A i then v g else 0 := by
    intro i
    calc
      (A i).sum v =
          (A i).sum (fun g => if g ∈ A i then v g else 0) := by
            apply Finset.sum_congr rfl
            intro g hg
            simp [hg]
      _ = goods.sum (fun g => if g ∈ A i then v g else 0) := by
            exact
              Finset.sum_subset
                (by
                  intro g hg
                  exact isAllocationOf_mem_goods halloc hg)
                (by
                  intro g _hgoods hnot_mem
                  simp [hnot_mem])
  calc
    (∑ i : SourceAgent, (A i).sum v) =
        ∑ i : SourceAgent, goods.sum fun g => if g ∈ A i then v g else 0 := by
          apply Finset.sum_congr rfl
          intro i _hi
          exact hbundle i
    _ = goods.sum (fun g => ∑ i : SourceAgent, if g ∈ A i then v g else 0) := by
          rw [Finset.sum_comm]
    _ = goods.sum v := by
          apply Finset.sum_congr rfl
          intro g hg
          rcases halloc.2 g hg with ⟨owner, howner, hunique_owner⟩
          rw [Finset.sum_eq_single owner]
          · simp [howner]
          · intro i _hi hne
            have hnot_mem : g ∉ A i := by
              intro hi
              exact hne (hunique_owner i hi)
            simp [hnot_mem]
          · intro howner_not_mem
            simp at howner_not_mem

/--
Exact-allocation counting helper: for any finite index map, the total number
of allocated goods of one index across all bundles equals the number of goods
of that index in the source goods set.
-/
theorem paper_lmms_isAllocationOf_sum_bundle_index_counts_eq_goods_count
    {SourceAgent SourceItem K : Type*}
    [Fintype SourceAgent] [DecidableEq SourceItem] [DecidableEq K]
    {A : Allocation SourceAgent SourceItem} {goods : Finset SourceItem}
    (halloc : IsAllocationOf A goods) (indexOf : SourceItem → K) (k : K) :
    (∑ i : SourceAgent, ((A i).filter fun g => indexOf g = k).card) =
      (goods.filter fun g => indexOf g = k).card := by
  classical
  let v : SourceItem → ℝ := fun g => if indexOf g = k then 1 else 0
  have hsum :=
    paper_lmms_isAllocationOf_sum_bundle_values_eq_sum_goods
      (A := A) (goods := goods) (v := v) halloc
  have hfilter_sum :
      ∀ S : Finset SourceItem,
        S.sum v = (((S.filter fun g => indexOf g = k).card : ℕ) : ℝ) := by
    intro S
    rw [← Finset.sum_filter]
    simp
  have hcast :
      (((∑ i : SourceAgent, ((A i).filter fun g => indexOf g = k).card) : ℕ) : ℝ) =
        (((goods.filter fun g => indexOf g = k).card : ℕ) : ℝ) := by
    simpa [hfilter_sum] using hsum
  exact_mod_cast hcast

/--
Theorem 3.3 high-good rounding seam: for source goods whose values already
lie in the high-good interval `(L / λ, L)`, choose a rounded value index whose
rounded value is an upward approximation within additive `L / λ^2`.

The paper's full rounded-instance construction also aggregates low goods into
new artificial goods of value `L / λ`; this theorem intentionally covers only
the original high goods where a source-item-to-index map is faithful.
-/
theorem paper_lmms_theorem_3_3_exists_high_good_indexOf
    {SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    (goods : Finset SourceItem) (v : SourceItem → ℝ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hvalues :
      ∀ g : SourceItem, g ∈ goods →
        L / (lambda : ℝ) < v g ∧ v g < L) :
    ∃ indexOf : SourceItem → Theorem33.RoundedValueIndex lambda,
      ∀ g : SourceItem, g ∈ goods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2) := by
  classical
  let fallback : Theorem33.RoundedValueIndex lambda :=
    ⟨⟨lambda ^ 2, Nat.lt_succ_self _⟩,
      Nat.le_self_pow (by norm_num : (2 : ℕ) ≠ 0) lambda⟩
  let pick :
      ∀ g : SourceItem, g ∈ goods → Theorem33.RoundedValueIndex lambda :=
    fun g hg =>
      Classical.choose
        (Theorem33.exists_roundedValueIndex_of_high_good
          (L := L) (x := v g) hlambda hL (hvalues g hg).1
          (hvalues g hg).2)
  let indexOf : SourceItem → Theorem33.RoundedValueIndex lambda :=
    fun g => if hg : g ∈ goods then pick g hg else fallback
  refine ⟨indexOf, ?_⟩
  intro g hg
  have hchosen :=
    Classical.choose_spec
      (Theorem33.exists_roundedValueIndex_of_high_good
        (L := L) (x := v g) hlambda hL (hvalues g hg).1
        (hvalues g hg).2)
  simpa [indexOf, pick, hg] using hchosen

/--
The rounded identical-utilities model induced by assigning each source good to
a rounded value index.
-/
noncomputable def paper_lmms_theorem_3_3_roundedModelOfIndex
    {SourceAgent SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda) :
    Theorem33.IdenticalUtilitiesModel SourceAgent SourceItem
      (Allocation SourceAgent SourceItem) where
  commonValue := fun g => Theorem33.roundedValue L lambda (indexOf g)
  bundleOf := fun A i => A i

/--
High-good source-to-rounded load transfer for one bundle: if every item in a
bundle is a high good and `indexOf` rounds each high good upward by less than
`L / lambda^2`, then the rounded bundle load is at most the source bundle load
scaled by `(lambda + 1) / lambda`.
-/
theorem paper_lmms_theorem_3_3_high_bundle_rounded_load_le_scaled_source_load
    {SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    (bundle highGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (hlambda : 0 < lambda)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g)
    (hsubset : bundle ⊆ highGoods) :
    bundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) ≤
      (((lambda : ℝ) + 1) / (lambda : ℝ)) * bundle.sum v := by
  classical
  have hlambda_real_pos : 0 < (lambda : ℝ) := by exact_mod_cast hlambda
  have hitem :
      ∀ g : SourceItem, g ∈ bundle →
        Theorem33.roundedValue L lambda (indexOf g) ≤
          (((lambda : ℝ) + 1) / (lambda : ℝ)) * v g := by
    intro g hg
    have hghigh : g ∈ highGoods := hsubset hg
    have hround_le :
        Theorem33.roundedValue L lambda (indexOf g) ≤
          v g + L / ((lambda : ℝ) ^ 2) :=
      le_of_lt ((hindex g hghigh).2)
    have herror_le :
        L / ((lambda : ℝ) ^ 2) ≤ v g / (lambda : ℝ) := by
      have hdiv :
          (L / (lambda : ℝ)) / (lambda : ℝ) <
            v g / (lambda : ℝ) :=
        div_lt_div_of_pos_right (hhigh g hghigh) hlambda_real_pos
      have hrewrite :
          (L / (lambda : ℝ)) / (lambda : ℝ) =
            L / ((lambda : ℝ) ^ 2) := by
        field_simp [ne_of_gt hlambda_real_pos]
      linarith
    have hscaled :
        v g + L / ((lambda : ℝ) ^ 2) ≤
          (((lambda : ℝ) + 1) / (lambda : ℝ)) * v g := by
      calc
        v g + L / ((lambda : ℝ) ^ 2)
            ≤ v g + v g / (lambda : ℝ) := by linarith
        _ = (((lambda : ℝ) + 1) / (lambda : ℝ)) * v g := by
            field_simp [ne_of_gt hlambda_real_pos]
    exact le_trans hround_le hscaled
  calc
    bundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g))
        ≤ bundle.sum (fun g =>
            (((lambda : ℝ) + 1) / (lambda : ℝ)) * v g) := by
          exact Finset.sum_le_sum hitem
    _ = (((lambda : ℝ) + 1) / (lambda : ℝ)) * bundle.sum v := by
          simp [Finset.mul_sum]

/--
High/low one-bundle source-to-rounded transfer: the high-good rounding bound,
plus a per-bundle low artificial-load estimate, gives the forward Lemma 3.5
additive upper bound for that bundle.  This isolates the algebra left after
the low-good partition construction supplies the low estimate.
-/
theorem paper_lmms_theorem_3_3_high_low_bundle_rounded_load_le_forward_transfer
    {SourceItem : Type*} {L lowRoundedLoad : ℝ} {lambda : ℕ}
    (highBundle lowBundle highGoods : Finset SourceItem)
    (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (hlambda : 0 < lambda)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g)
    (hhigh_subset : highBundle ⊆ highGoods)
    (hlow_nonneg : ∀ g : SourceItem, g ∈ lowBundle → 0 ≤ v g)
    (hlow_transfer :
      lowRoundedLoad ≤ lowBundle.sum v + L / (lambda : ℝ)) :
    highBundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
        lowRoundedLoad ≤
      (((lambda : ℝ) + 1) / (lambda : ℝ)) *
          (highBundle.sum v + lowBundle.sum v) +
        L / (lambda : ℝ) := by
  classical
  let coeff : ℝ := ((lambda : ℝ) + 1) / (lambda : ℝ)
  have hhigh_transfer :
      highBundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) ≤
        coeff * highBundle.sum v := by
    simpa [coeff] using
      paper_lmms_theorem_3_3_high_bundle_rounded_load_le_scaled_source_load
        highBundle highGoods v indexOf hlambda hindex hhigh hhigh_subset
  have hlambda_real_pos : 0 < (lambda : ℝ) := by exact_mod_cast hlambda
  have hcoeff_ge_one : 1 ≤ coeff := by
    dsimp [coeff]
    rw [le_div_iff₀ hlambda_real_pos]
    linarith
  have hlow_sum_nonneg : 0 ≤ lowBundle.sum v :=
    Finset.sum_nonneg hlow_nonneg
  have hlow_scaled : lowBundle.sum v ≤ coeff * lowBundle.sum v := by
    have hmul := mul_le_mul_of_nonneg_right hcoeff_ge_one hlow_sum_nonneg
    simpa using hmul
  calc
    highBundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
        lowRoundedLoad
        ≤ coeff * highBundle.sum v +
            (lowBundle.sum v + L / (lambda : ℝ)) := by
          exact add_le_add hhigh_transfer hlow_transfer
    _ ≤ coeff * highBundle.sum v +
            (coeff * lowBundle.sum v + L / (lambda : ℝ)) := by
          linarith
    _ = coeff * (highBundle.sum v + lowBundle.sum v) +
            L / (lambda : ℝ) := by
          ring

/--
Agentwise source-to-rounded high/low transfer wrapper: if every agent has a
high source bundle, a low source bundle, and a rounded low load no larger than
the low source load plus one low unit, then the forward Lemma 3.5 additive
inequality holds agentwise.
-/
theorem paper_lmms_theorem_3_3_forward_agentwise_transfer_of_high_low_bundle_estimates
    {SourceAgent SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    (highBundle lowBundle : SourceAgent → Finset SourceItem)
    (highGoods : Finset SourceItem)
    (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (lowRoundedLoad : SourceAgent → ℝ)
    (hlambda : 0 < lambda)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g)
    (hhigh_subset :
      ∀ i : SourceAgent, highBundle i ⊆ highGoods)
    (hlow_nonneg :
      ∀ i : SourceAgent, ∀ g : SourceItem, g ∈ lowBundle i → 0 ≤ v g)
    (hlow_transfer :
      ∀ i : SourceAgent,
        lowRoundedLoad i ≤ (lowBundle i).sum v + L / (lambda : ℝ)) :
    ∀ i : SourceAgent,
      (highBundle i).sum
          (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
        lowRoundedLoad i ≤
      (((lambda : ℝ) + 1) / (lambda : ℝ)) *
          ((highBundle i).sum v + (lowBundle i).sum v) +
        L / (lambda : ℝ) := by
  intro i
  exact
    paper_lmms_theorem_3_3_high_low_bundle_rounded_load_le_forward_transfer
      (highBundle i) (lowBundle i) highGoods v indexOf hlambda
      hindex hhigh (hhigh_subset i) (hlow_nonneg i) (hlow_transfer i)

/--
High-good rounded-to-source upper transfer for one bundle: high source value is
bounded by the corresponding rounded high load because high goods are rounded
upward.
-/
theorem paper_lmms_theorem_3_3_high_bundle_source_load_le_rounded_load
    {SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    (bundle highGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hsubset : bundle ⊆ highGoods) :
    bundle.sum v ≤
      bundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) := by
  exact
    Finset.sum_le_sum
      (by
        intro g hg
        exact (hindex g (hsubset hg)).1)

/--
High-good rounded-to-source lower transfer for one bundle: a high source load
is at least `lambda / (lambda + 1)` times the corresponding rounded high load.
-/
theorem paper_lmms_theorem_3_3_high_bundle_source_load_ge_scaled_rounded_load
    {SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    (bundle highGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (hlambda : 0 < lambda)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g)
    (hsubset : bundle ⊆ highGoods) :
    ((lambda : ℝ) / ((lambda : ℝ) + 1)) *
        bundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) ≤
      bundle.sum v := by
  classical
  let forwardCoeff : ℝ := ((lambda : ℝ) + 1) / (lambda : ℝ)
  let backwardCoeff : ℝ := (lambda : ℝ) / ((lambda : ℝ) + 1)
  have hforward :
      bundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) ≤
        forwardCoeff * bundle.sum v := by
    simpa [forwardCoeff] using
      paper_lmms_theorem_3_3_high_bundle_rounded_load_le_scaled_source_load
        bundle highGoods v indexOf hlambda hindex hhigh hsubset
  have hlambda_real_pos : 0 < (lambda : ℝ) := by exact_mod_cast hlambda
  have hlambda_plus_pos : 0 < (lambda : ℝ) + 1 := by linarith
  have hbackward_nonneg : 0 ≤ backwardCoeff := by
    dsimp [backwardCoeff]
    positivity
  have hscaled :=
    mul_le_mul_of_nonneg_left hforward hbackward_nonneg
  have hcoeff :
      backwardCoeff * (forwardCoeff * bundle.sum v) = bundle.sum v := by
    dsimp [backwardCoeff, forwardCoeff]
    field_simp [ne_of_gt hlambda_real_pos, ne_of_gt hlambda_plus_pos]
  simpa [backwardCoeff, hcoeff, mul_assoc] using hscaled

/--
High/low one-bundle rounded-to-source maximum transfer: high goods are rounded
upward, and a supplied low-load upper estimate gives the backward Lemma 3.5
additive max inequality for that bundle.
-/
theorem paper_lmms_theorem_3_3_high_low_bundle_source_load_le_backward_transfer
    {SourceItem : Type*} {L lowSourceLoad lowRoundedLoad : ℝ} {lambda : ℕ}
    (highBundle highGoods : Finset SourceItem)
    (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hhigh_subset : highBundle ⊆ highGoods)
    (hlow_transfer :
      lowSourceLoad ≤ lowRoundedLoad + L / (lambda : ℝ)) :
    highBundle.sum v + lowSourceLoad ≤
      highBundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
        lowRoundedLoad + L / (lambda : ℝ) := by
  have hhigh_transfer :
      highBundle.sum v ≤
        highBundle.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) :=
    paper_lmms_theorem_3_3_high_bundle_source_load_le_rounded_load
      highBundle highGoods v indexOf hindex hhigh_subset
  linarith

/--
High/low one-bundle rounded-to-source minimum transfer: the high-good scaling
bound, plus a supplied low-load lower estimate, gives the backward Lemma 3.5
additive min inequality for that bundle.
-/
theorem paper_lmms_theorem_3_3_high_low_bundle_source_load_ge_backward_transfer
    {SourceItem : Type*} {L lowSourceLoad lowRoundedLoad : ℝ} {lambda : ℕ}
    (highBundle highGoods : Finset SourceItem)
    (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g)
    (hhigh_subset : highBundle ⊆ highGoods)
    (hlowRounded_nonneg : 0 ≤ lowRoundedLoad)
    (hlow_transfer :
      lowRoundedLoad - L / (lambda : ℝ) ≤ lowSourceLoad) :
    ((lambda : ℝ) / ((lambda : ℝ) + 1)) *
          (highBundle.sum
              (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
            lowRoundedLoad) -
        (2 / (lambda : ℝ)) * L ≤
      highBundle.sum v + lowSourceLoad := by
  classical
  let coeff : ℝ := (lambda : ℝ) / ((lambda : ℝ) + 1)
  have hhigh_transfer :
      coeff *
          highBundle.sum
            (fun g => Theorem33.roundedValue L lambda (indexOf g)) ≤
        highBundle.sum v := by
    simpa [coeff] using
      paper_lmms_theorem_3_3_high_bundle_source_load_ge_scaled_rounded_load
        highBundle highGoods v indexOf hlambda hindex hhigh hhigh_subset
  have hlambda_real_pos : 0 < (lambda : ℝ) := by exact_mod_cast hlambda
  have hlambda_plus_pos : 0 < (lambda : ℝ) + 1 := by linarith
  have hcoeff_le_one : coeff ≤ 1 := by
    dsimp [coeff]
    rw [div_le_one₀ hlambda_plus_pos]
    linarith
  have hcoeff_nonneg : 0 ≤ coeff := by
    dsimp [coeff]
    positivity
  have hlow_coeff_le : coeff * lowRoundedLoad ≤ lowRoundedLoad := by
    have hmul := mul_le_mul_of_nonneg_right hcoeff_le_one hlowRounded_nonneg
    simpa using hmul
  have hunit_nonneg : 0 ≤ L / (lambda : ℝ) := by positivity
  have hlow_transfer' :
      coeff * lowRoundedLoad - (2 / (lambda : ℝ)) * L ≤ lowSourceLoad := by
    have htwounit :
        (2 / (lambda : ℝ)) * L = 2 * (L / (lambda : ℝ)) := by
      field_simp [ne_of_gt hlambda_real_pos]
    rw [htwounit]
    nlinarith
  linarith

/--
Agentwise rounded-to-source high/low transfer wrapper: if every agent has a
high source bundle, a source low load, and a rounded low load satisfying the
per-agent low upper/lower estimates, then the two backward Lemma 3.5 additive
inequalities hold agentwise.
-/
theorem paper_lmms_theorem_3_3_backward_agentwise_transfer_of_high_low_bundle_estimates
    {SourceAgent SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    (highBundle : SourceAgent → Finset SourceItem)
    (highGoods : Finset SourceItem)
    (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (lowSourceLoad lowRoundedLoad : SourceAgent → ℝ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g)
    (hhigh_subset :
      ∀ i : SourceAgent, highBundle i ⊆ highGoods)
    (hlowRounded_nonneg : ∀ i : SourceAgent, 0 ≤ lowRoundedLoad i)
    (hlow_upper :
      ∀ i : SourceAgent,
        lowSourceLoad i ≤ lowRoundedLoad i + L / (lambda : ℝ))
    (hlow_lower :
      ∀ i : SourceAgent,
        lowRoundedLoad i - L / (lambda : ℝ) ≤ lowSourceLoad i) :
    (∀ i : SourceAgent,
      (highBundle i).sum v + lowSourceLoad i ≤
        (highBundle i).sum
            (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
          lowRoundedLoad i + L / (lambda : ℝ)) ∧
      ∀ i : SourceAgent,
        ((lambda : ℝ) / ((lambda : ℝ) + 1)) *
              ((highBundle i).sum
                  (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
                lowRoundedLoad i) -
            (2 / (lambda : ℝ)) * L ≤
          (highBundle i).sum v + lowSourceLoad i := by
  refine ⟨?_, ?_⟩
  · intro i
    exact
      paper_lmms_theorem_3_3_high_low_bundle_source_load_le_backward_transfer
        (highBundle i) highGoods v indexOf hindex (hhigh_subset i)
        (hlow_upper i)
  · intro i
    exact
      paper_lmms_theorem_3_3_high_low_bundle_source_load_ge_backward_transfer
        (highBundle i) highGoods v indexOf hlambda hL hindex hhigh
        (hhigh_subset i) (hlowRounded_nonneg i) (hlow_lower i)

/--
Exact low-partition transfer premises: if an exact low-good partition is
already available and satisfies the per-agent one-unit low-load estimates,
then the combined high/low loads satisfy the four additive transfer premises
used by the final Theorem 3.5 ratio-transfer endpoint.
-/
theorem paper_lmms_theorem_3_3_low_partition_agentwise_additive_transfer_premises_epsilon
    {SourceAgent SourceItem : Type*}
    [DecidableEq SourceItem]
    {L epsilon : ℝ} {lambda : ℕ}
    (highBundle lowPart : SourceAgent → Finset SourceItem)
    (highGoods lowGoods : Finset SourceItem)
    (v : SourceItem → ℝ)
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (lowRoundedLoad : SourceAgent → ℝ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hlambda_eq : (lambda : ℝ) = 56 / epsilon)
    (hindex :
