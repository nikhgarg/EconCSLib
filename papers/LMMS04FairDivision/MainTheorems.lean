theorem paper_lmms_theorem_3_3_exists_value_pair_search_certificate_with_ratio_guarantee_of_value_pair_ip
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
