/--
Theorem 3.3 value-pair IP summary.  A feasible value-pair IP certificate
places the selected pair in the finite search set, keeps it in the Claim 3.4
load window, and exposes the selected type window and player-count equation.
-/
theorem paper_lmms_theorem_3_3_value_pair_ip_certificate_summary
    {L : ℝ} {lambda : ℕ} {SourceAgent : Type*} [Fintype SourceAgent]
    {p : ℝ × ℝ}
    (pairIP : Theorem33.RoundedValuePairIPCertificate L lambda SourceAgent p) :
    p ∈ Theorem33.roundedAdmissibleValuePairSet L lambda ∧
      L / 2 < p.1 ∧ p.1 < 2 * L ∧
      L / 2 < p.2 ∧ p.2 < 2 * L ∧
      pairIP.ip.admissibleTypes =
        Theorem33.roundedTypesInValueWindow L lambda p.1 p.2 ∧
      pairIP.ip.admissibleTypes.card ≤
        (2 * lambda + 1) ^
          Fintype.card (Theorem33.RoundedValueIndex lambda) ∧
      pairIP.ip.admissibleTypes.sum pairIP.ip.typeMultiplicity =
        Fintype.card SourceAgent := by
  have hb := Theorem33.RoundedValuePairIPCertificate.pair_bounds pairIP
  exact
    ⟨pairIP.pair_mem, hb.1, hb.2.1, hb.2.2.1, hb.2.2.2,
      Theorem33.RoundedValuePairIPCertificate.admissibleTypes_eq_window pairIP,
      Theorem33.RoundedValuePairIPCertificate.admissibleTypes_card_le pairIP,
      pairIP.ip.allPlayersAssigned⟩

/--
Theorem 3.3 finite-search seam: a rounded value-pair search certificate
chooses a pair from the source finite set `V(U) × V(U)`, keeps both chosen
values in the Claim 3.4 window, and uses at most the source type-box number of
IP variables.
-/
theorem paper_lmms_theorem_3_3_value_pair_search_certificate_size_bound
    {L : ℝ} {lambda : ℕ} {SourceAgent : Type*} [Fintype SourceAgent]
    (cert : Theorem33.RoundedValuePairSearchCertificate L lambda SourceAgent) :
    (Theorem33.roundedAdmissibleValuePairSet L lambda).card ≤
        ((2 * lambda + 1) ^
          Fintype.card (Theorem33.RoundedValueIndex lambda)) ^ 2 ∧
      cert.chosenPair ∈ Theorem33.roundedAdmissibleValuePairSet L lambda ∧
      L / 2 < cert.chosenPair.1 ∧ cert.chosenPair.1 < 2 * L ∧
      L / 2 < cert.chosenPair.2 ∧ cert.chosenPair.2 < 2 * L ∧
      cert.chosenIP.ip.admissibleTypes.card ≤
        (2 * lambda + 1) ^
          Fintype.card (Theorem33.RoundedValueIndex lambda) := by
  have hb := Theorem33.RoundedValuePairSearchCertificate.chosenPair_bounds cert
  exact
    ⟨Theorem33.roundedAdmissibleValuePairSet_card_le L lambda,
      Theorem33.RoundedValuePairSearchCertificate.chosenPair_mem cert,
      hb.1, hb.2.1, hb.2.2.1, hb.2.2.2,
      Theorem33.RoundedValuePairIPCertificate.admissibleTypes_card_le
        cert.chosenIP⟩

