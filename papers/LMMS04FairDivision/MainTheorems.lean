/--
The bounded source optimum's finite min/max loads form a capped value pair
once rounded type witnesses realize those two loads and the count cap covers
the Claim-3.4 average window.
-/
theorem paper_lmms_theorem_3_3_source_min_max_pair_mem_roundedAdmissibleValuePairSetWithCap_of_types
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {L : ℝ} {lambda maxCount : ℕ}
    (sourceValue : SourceItem → ℝ)
    (optimal : Allocation SourceAgent SourceItem)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hcap : 2 * L ≤ (maxCount + 1 : ℝ) * (L / (lambda : ℝ)))
    (hopt_window :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem34.commonLoad sourceValue (optimal i)))
    (minType maxType : Theorem33.RoundedBundleType lambda)
    (hminType :
      Theorem33.roundedBundleTypeLoad L minType =
        (Finset.univ : Finset SourceAgent).inf'
          Finset.univ_nonempty
          (fun i => Theorem34.commonLoad sourceValue (optimal i)))
    (hmaxType :
      Theorem33.roundedBundleTypeLoad L maxType =
        (Finset.univ : Finset SourceAgent).sup'
          Finset.univ_nonempty
          (fun i => Theorem34.commonLoad sourceValue (optimal i))) :
    (((Finset.univ : Finset SourceAgent).inf'
        Finset.univ_nonempty
        (fun i => Theorem34.commonLoad sourceValue (optimal i))),
      ((Finset.univ : Finset SourceAgent).sup'
        Finset.univ_nonempty
        (fun i => Theorem34.commonLoad sourceValue (optimal i)))) ∈
      Theorem33.roundedAdmissibleValuePairSetWithCap
        L L lambda maxCount := by
  classical
  let sourceLoad : SourceAgent → ℝ :=
    fun i => Theorem34.commonLoad sourceValue (optimal i)
  let sourceMin : ℝ :=
    (Finset.univ : Finset SourceAgent).inf' Finset.univ_nonempty sourceLoad
  let sourceMax : ℝ :=
    (Finset.univ : Finset SourceAgent).sup' Finset.univ_nonempty sourceLoad
  have hmin_lower : L / 2 < sourceMin := by
    dsimp [sourceMin, sourceLoad]
    rw [Finset.lt_inf'_iff]
    intro i _hi
    exact (hopt_window i).1
  have hmin_upper : sourceMin < 2 * L := by
    let i0 : SourceAgent := Classical.choice (inferInstance : Nonempty SourceAgent)
    have hle :
        sourceMin ≤ sourceLoad i0 :=
      Finset.inf'_le
        (s := (Finset.univ : Finset SourceAgent))
        (f := sourceLoad)
        (by simp [i0] : i0 ∈ (Finset.univ : Finset SourceAgent))
    exact lt_of_le_of_lt hle (by simpa [sourceLoad] using (hopt_window i0).2)
  have hmax_lower : L / 2 < sourceMax := by
    let i0 : SourceAgent := Classical.choice (inferInstance : Nonempty SourceAgent)
    have hle :
        sourceLoad i0 ≤ sourceMax :=
      Finset.le_sup'
        (s := (Finset.univ : Finset SourceAgent))
        (f := sourceLoad)
        (by simp [i0] : i0 ∈ (Finset.univ : Finset SourceAgent))
    exact lt_of_lt_of_le (by simpa [sourceLoad] using (hopt_window i0).1) hle
  have hmax_upper : sourceMax < 2 * L := by
    dsimp [sourceMax, sourceLoad]
    rw [Finset.sup'_lt_iff]
    intro i _hi
    exact (hopt_window i).2
  have hpair :
      (Theorem33.roundedBundleTypeLoad L minType,
          Theorem33.roundedBundleTypeLoad L maxType) ∈
        Theorem33.roundedAdmissibleValuePairSetWithCap
          L L lambda maxCount :=
    Theorem33.roundedBundleTypeLoad_pair_mem_roundedAdmissibleValuePairSetWithCap_of_load_window
      hlambda hL hcap minType maxType
      (by simpa [sourceMin, sourceLoad, hminType] using hmin_lower)
      (by simpa [sourceMin, sourceLoad, hminType] using hmin_upper)
      (by simpa [sourceMax, sourceLoad, hmaxType] using hmax_lower)
      (by simpa [sourceMax, sourceLoad, hmaxType] using hmax_upper)
  simpa [sourceMin, sourceMax, sourceLoad, hminType, hmaxType] using hpair

