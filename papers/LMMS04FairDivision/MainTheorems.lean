/--
Theorem 3.3 rounding-transfer certificate: once Lemma 3.5 has supplied the
rounded-to-source and source-to-rounded ratio-transfer inequalities, and the
rounded allocation is optimal in the rounded instance, the two transfers
compose into the paper's multiplicative approximation factor.
-/
theorem paper_lmms_theorem_3_3_ratio_transfer_certificate
    {lambda optMin optMax roundedMin roundedMax outMin outMax : ℝ}
    (hout :
      Theorem35.ratio outMin outMax ≤
        Theorem35.ratio roundedMin roundedMax *
          Theorem35.backwardTransferFactor lambda)
    (hrounded_opt :
      Theorem35.ratio roundedMin roundedMax ≤
        Theorem35.ratio optMin optMax *
          Theorem35.forwardTransferFactor lambda)
    (hbackward_nonneg : 0 ≤ Theorem35.backwardTransferFactor lambda) :
    Theorem35.ratio outMin outMax ≤
      Theorem35.ratio optMin optMax *
        (Theorem35.backwardTransferFactor lambda *
          Theorem35.forwardTransferFactor lambda) := by
  exact
    Theorem35.theorem33_ratio_transfer_certificate
      hout hrounded_opt hbackward_nonneg

/--
Theorem 3.3 displayed-factor algebra: the product of the two Lemma 3.5
transfer factors is the rational approximation factor printed in the source
proof.
-/
theorem paper_lmms_theorem_3_3_transfer_factor_eq_source_fraction
    {lambda : ℝ}
    (hlambda : lambda ≠ 0)
    (hlambda_ne_neg_one : lambda + 1 ≠ 0)
    (hlambda_ne_two : lambda - 2 ≠ 0) :
    Theorem35.backwardTransferFactor lambda *
        Theorem35.forwardTransferFactor lambda =
      Theorem35.theorem33TransferFactor lambda := by
  exact
    Theorem35.transfer_factor_eq_source_fraction
      hlambda hlambda_ne_neg_one hlambda_ne_two

