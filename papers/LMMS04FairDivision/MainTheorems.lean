/--
Theorem 3.3 exact rounded-allocation min/max pair: if every rounded bundle load
lies in the Claim 3.4 window, then the exact rounded allocation's minimum and
maximum rounded loads form a source value pair in `V(U) × V(U)`.
-/
theorem paper_lmms_theorem_3_3_exact_rounded_allocation_min_max_pair_mem
    {L : ℝ} {lambda : ℕ} {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent] [DecidableEq SourceItem]
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (A : Allocation SourceAgent SourceItem)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hwindow :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem34.commonLoad
            (fun g : SourceItem => Theorem33.roundedValue L lambda (indexOf g))
            (A i))) :
    (Theorem34.minCommonLoad
        (fun g : SourceItem => Theorem33.roundedValue L lambda (indexOf g)) A,
      Theorem34.maxCommonLoad
        (fun g : SourceItem => Theorem33.roundedValue L lambda (indexOf g)) A) ∈
      Theorem33.roundedAdmissibleValuePairSet L lambda := by
  classical
  let roundedV : SourceItem → ℝ :=
    fun g => Theorem33.roundedValue L lambda (indexOf g)
  rcases
      Theorem34.exists_commonLoad_eq_minCommonLoad
        (v := roundedV) (bundle := A) with
    ⟨imin, himin⟩
  rcases
      Theorem34.exists_commonLoad_eq_maxCommonLoad
        (v := roundedV) (bundle := A) with
    ⟨imax, himax⟩
  let minType :=
    paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf (A imin)
  let maxType :=
    paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf (A imax)
  have hmin_load_common :
      Theorem33.roundedBundleTypeLoad L minType =
        Theorem34.commonLoad roundedV (A imin) := by
    simpa [minType, roundedV, Theorem34.commonLoad] using
      paper_lmms_theorem_3_3_roundedBundleTypeOfBundle_load_eq_sum
        (L := L) indexOf (A imin)
  have hmax_load_common :
      Theorem33.roundedBundleTypeLoad L maxType =
        Theorem34.commonLoad roundedV (A imax) := by
    simpa [maxType, roundedV, Theorem34.commonLoad] using
      paper_lmms_theorem_3_3_roundedBundleTypeOfBundle_load_eq_sum
        (L := L) indexOf (A imax)
  have hmin_load :
      Theorem33.roundedBundleTypeLoad L minType =
        Theorem34.minCommonLoad roundedV A := by
    simpa [himin] using hmin_load_common
  have hmax_load :
      Theorem33.roundedBundleTypeLoad L maxType =
        Theorem34.maxCommonLoad roundedV A := by
    simpa [himax] using hmax_load_common
  have hpair :
      (Theorem33.roundedBundleTypeLoad L minType,
          Theorem33.roundedBundleTypeLoad L maxType) ∈
        Theorem33.roundedAdmissibleValuePairSet L lambda :=
    Theorem33.roundedBundleTypeLoad_pair_mem_roundedAdmissibleValuePairSet_of_load_window
      hlambda hL minType maxType
      (by simpa [roundedV, hmin_load_common] using (hwindow imin).1)
      (by simpa [roundedV, hmin_load_common] using (hwindow imin).2)
      (by simpa [roundedV, hmax_load_common] using (hwindow imax).1)
      (by simpa [roundedV, hmax_load_common] using (hwindow imax).2)
  simpa [roundedV, hmin_load, hmax_load] using hpair

/--
Theorem 3.3 exact rounded-allocation window bridge: if every rounded bundle
load lies in the Claim 3.4 window, then each induced rounded bundle type lies
in the selected min/max IP window for that allocation.
-/
theorem paper_lmms_theorem_3_3_exact_rounded_allocation_types_in_min_max_window
    {L : ℝ} {lambda : ℕ} {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent] [DecidableEq SourceItem]
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (A : Allocation SourceAgent SourceItem)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hwindow :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem34.commonLoad
            (fun g : SourceItem => Theorem33.roundedValue L lambda (indexOf g))
            (A i))) :
    ∀ i : SourceAgent,
      paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf (A i) ∈
        Theorem33.roundedTypesInValueWindow L lambda
          (Theorem34.minCommonLoad
            (fun g : SourceItem => Theorem33.roundedValue L lambda (indexOf g)) A)
          (Theorem34.maxCommonLoad
            (fun g : SourceItem => Theorem33.roundedValue L lambda (indexOf g)) A) := by
  classical
  let roundedV : SourceItem → ℝ :=
    fun g => Theorem33.roundedValue L lambda (indexOf g)
  intro i
  let typeOfI :=
    paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf (A i)
  have hload_common :
      Theorem33.roundedBundleTypeLoad L typeOfI =
        Theorem34.commonLoad roundedV (A i) := by
    simpa [typeOfI, roundedV, Theorem34.commonLoad] using
      paper_lmms_theorem_3_3_roundedBundleTypeOfBundle_load_eq_sum
        (L := L) indexOf (A i)
  have hadmissible :
      typeOfI ∈ Theorem33.roundedAdmissibleTypeSet L lambda :=
    Theorem33.roundedBundleType_mem_roundedAdmissibleTypeSet_of_load_window
      hlambda hL typeOfI
      (by simpa [roundedV, hload_common] using (hwindow i).1)
      (by simpa [roundedV, hload_common] using (hwindow i).2)
  have hmin_le :
      Theorem34.minCommonLoad roundedV A ≤
        Theorem33.roundedBundleTypeLoad L typeOfI := by
    simpa [← hload_common] using
      Theorem34.minCommonLoad_le (v := roundedV) (bundle := A) i
  have hle_max :
      Theorem33.roundedBundleTypeLoad L typeOfI ≤
        Theorem34.maxCommonLoad roundedV A := by
    simpa [← hload_common] using
      Theorem34.commonLoad_le_maxCommonLoad (v := roundedV) (bundle := A) i
  exact
    (Theorem33.mem_roundedTypesInValueWindow_iff
      (L := L) (lambda := lambda)
      (lower := Theorem34.minCommonLoad roundedV A)
      (upper := Theorem34.maxCommonLoad roundedV A) typeOfI).mpr
      ⟨hadmissible, hmin_le, hle_max⟩

