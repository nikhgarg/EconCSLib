      (L := L) (lambda := lambda) highGoods lowGoods sourceValue
  let typedIndex : typedItem → Theorem33.RoundedValueIndex lambda :=
    paper_lmms_theorem_3_3_typedCombinedHighLowSupplyIndexOf
      (L := L) (lambda := lambda)
      (highGoods := highGoods) (lowGoods := lowGoods)
      (sourceValue := sourceValue) indexOf
  let cert :=
    paper_lmms_theorem_3_3_concrete_ip_certificate_with_cap_of_exact_bounded_rounded_allocation
      (L := L) (LR := LR) (lambda := lambda) (maxCount := maxCount)
      (SourceAgent := SourceAgent) (SourceItem := typedItem)
      (goods := (Finset.univ : Finset typedItem))
      typedIndex A halloc hlambda hL hcap
      (by
        intro i
        simpa [typedItem, typedIndex,
          paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue]
          using hwindow i)
  exact
    { pair_mem := by
        simpa [typedItem, typedIndex,
          paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue] using
          cert.pair_mem
      typeMultiplicity := cert.typeMultiplicity
      zeroOutsideWindow := by
        intro t ht
        exact cert.zeroOutsideWindow t (by
          simpa [typedItem, typedIndex,
            paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue] using ht)
      allPlayersAssigned := by
        simpa [typedItem, typedIndex,
          paper_lmms_theorem_3_3_typedCombinedHighLowSupplyValue] using
          cert.allPlayersAssigned
      allGoodsAssigned := by
        intro k
        exact
          (cert.allGoodsAssigned k).trans
            (paper_lmms_theorem_3_3_typedCombinedHighLowSupply_goodsSupply_eq
              (L := L) (lambda := lambda) highGoods lowGoods sourceValue
              indexOf k) }

/--
Load-window consequence of realizing a capped concrete IP by agent types.  Once
the IP multiplicities are the fibers of a concrete type assignment and an exact
allocation has those per-agent rounded type loads, every realized bundle lies
inside the Claim-3.4 window around the rounded average.
-/
theorem paper_lmms_theorem_3_3_exact_bounded_allocation_window_of_capped_ip_type_realization
    {L LR : ℝ} {lambda maxCount : ℕ} {SourceAgent Item : Type*}
    [Fintype SourceAgent]
    {supply : Theorem33.RoundedValueIndex lambda → ℕ} {p : ℝ × ℝ}
    (ip :
      Theorem33.RoundedConcreteIPCertificateWithCap
        L LR lambda maxCount SourceAgent p supply)
    (itemValue : Item → ℝ) (A : Allocation SourceAgent Item)
    (typeOf : SourceAgent → Theorem33.RoundedBundleType lambda)
    (hmultiplicity :
      ∀ t : Theorem33.RoundedBundleType lambda,
        Theorem33.roundedTypeMultiplicityOfAssignment typeOf t =
          ip.typeMultiplicity t)
    (hload_eq :
      ∀ i : SourceAgent,
        Theorem34.commonLoad itemValue (A i) =
          Theorem33.roundedBundleTypeLoad L (typeOf i)) :
    ∀ i : SourceAgent,
      Theorem34.boundedAroundAverage LR
        (Theorem34.commonLoad itemValue (A i)) := by
  classical
  intro i
  have hpos_assignment :
      0 < Theorem33.roundedTypeMultiplicityOfAssignment typeOf (typeOf i) := by
    unfold Theorem33.roundedTypeMultiplicityOfAssignment
    exact Finset.card_pos.mpr ⟨i, by simp⟩
  have hpos_ip : 0 < ip.typeMultiplicity (typeOf i) := by
    simpa [hmultiplicity (typeOf i)] using hpos_assignment
  have htype_window :
      typeOf i ∈
        Theorem33.roundedTypesInValueWindowWithCap
          L LR lambda maxCount p.1 p.2 :=
    ip.used_type_mem_window hpos_ip
  have htype_admissible :
      typeOf i ∈
        Theorem33.roundedAdmissibleTypeSetWithCap
          L LR lambda maxCount :=
    ((Theorem33.mem_roundedTypesInValueWindowWithCap_iff
      (valueScale := L) (averageScale := LR) (lambda := lambda)
      (maxCount := maxCount) (lower := p.1) (upper := p.2)
      (typeOf i)).mp htype_window).1
  have hbounds :
      LR / 2 < Theorem33.roundedBundleTypeLoad L (typeOf i) ∧
        Theorem33.roundedBundleTypeLoad L (typeOf i) < 2 * LR :=
    ((Theorem33.mem_roundedAdmissibleTypeSetWithCap_iff
      (valueScale := L) (averageScale := LR) (lambda := lambda)
      (maxCount := maxCount) (typeOf i)).mp htype_admissible).2
  simpa [Theorem34.boundedAroundAverage, hload_eq i] using hbounds

/--
Rounded-index count realization gives the exact rounded bundle-load identity.
This isolates the finite bookkeeping target: once every agent receives exactly
the coordinate counts of its realized rounded type, the analytic load equality
used by the capped-IP bridge is automatic.
-/
theorem paper_lmms_theorem_3_3_commonLoad_eq_roundedBundleTypeLoad_of_bundle_index_counts
    {L : ℝ} {lambda : ℕ} {Item : Type*}
    (indexOf : Item → Theorem33.RoundedValueIndex lambda)
    (bundle : Finset Item) (t : Theorem33.RoundedBundleType lambda)
    (hcounts :
      ∀ k : Theorem33.RoundedValueIndex lambda,
        (bundle.filter fun item => indexOf item = k).card = t.count k) :
    Theorem34.commonLoad
        (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
        bundle =
      Theorem33.roundedBundleTypeLoad L t := by
  classical
  have htype :
      paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf bundle = t := by
    cases t
    simp [paper_lmms_theorem_3_3_roundedBundleTypeOfBundle, hcounts]
  calc
    Theorem34.commonLoad
        (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
        bundle =
        bundle.sum
          (fun item : Item => Theorem33.roundedValue L lambda (indexOf item)) := rfl
    _ =
        Theorem33.roundedBundleTypeLoad L
          (paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf bundle) :=
          (paper_lmms_theorem_3_3_roundedBundleTypeOfBundle_load_eq_sum
            (L := L) indexOf bundle).symm
    _ = Theorem33.roundedBundleTypeLoad L t := by
          rw [htype]

/--
Count-realization form of the capped-IP bounded-window bridge.  The remaining
finite construction only has to build an exact allocation whose rounded-index
fiber counts match each realized IP type; load boundedness then follows from
the IP type window.
-/
theorem paper_lmms_theorem_3_3_exact_bounded_allocation_window_of_capped_ip_count_realization
    {L LR : ℝ} {lambda maxCount : ℕ} {SourceAgent Item : Type*}
    [Fintype SourceAgent]
    {supply : Theorem33.RoundedValueIndex lambda → ℕ} {p : ℝ × ℝ}
    (ip :
      Theorem33.RoundedConcreteIPCertificateWithCap
        L LR lambda maxCount SourceAgent p supply)
    (indexOf : Item → Theorem33.RoundedValueIndex lambda)
    (A : Allocation SourceAgent Item)
    (typeOf : SourceAgent → Theorem33.RoundedBundleType lambda)
    (hmultiplicity :
      ∀ t : Theorem33.RoundedBundleType lambda,
        Theorem33.roundedTypeMultiplicityOfAssignment typeOf t =
          ip.typeMultiplicity t)
    (hcounts :
      ∀ i : SourceAgent,
        ∀ k : Theorem33.RoundedValueIndex lambda,
          ((A i).filter fun item => indexOf item = k).card =
            (typeOf i).count k) :
    ∀ i : SourceAgent,
      Theorem34.boundedAroundAverage LR
        (Theorem34.commonLoad
          (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
          (A i)) := by
  exact
    paper_lmms_theorem_3_3_exact_bounded_allocation_window_of_capped_ip_type_realization
      (L := L) (LR := LR) (lambda := lambda) (maxCount := maxCount)
      ip (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
      A typeOf hmultiplicity
      (fun i =>
        paper_lmms_theorem_3_3_commonLoad_eq_roundedBundleTypeLoad_of_bundle_index_counts
          (L := L) indexOf (A i) (typeOf i) (hcounts i))

/--
Window-plus-count form of the capped-IP boundedness bridge.  This is the
smallest analytic target for the finite realization layer: if each realized
agent type lies in the chosen capped IP window and the allocation has the
matching rounded-index counts, every bundle is bounded around `LR`.
-/
theorem paper_lmms_theorem_3_3_exact_bounded_allocation_window_of_capped_ip_window_count_realization
    {L LR : ℝ} {lambda maxCount : ℕ} {SourceAgent Item : Type*}
    [Fintype SourceAgent]
    {supply : Theorem33.RoundedValueIndex lambda → ℕ} {p : ℝ × ℝ}
    (_ip :
      Theorem33.RoundedConcreteIPCertificateWithCap
        L LR lambda maxCount SourceAgent p supply)
    (indexOf : Item → Theorem33.RoundedValueIndex lambda)
    (A : Allocation SourceAgent Item)
    (typeOf : SourceAgent → Theorem33.RoundedBundleType lambda)
    (htypes :
      ∀ i : SourceAgent,
        typeOf i ∈
          Theorem33.roundedTypesInValueWindowWithCap
            L LR lambda maxCount p.1 p.2)
    (hcounts :
      ∀ i : SourceAgent,
        ∀ k : Theorem33.RoundedValueIndex lambda,
          ((A i).filter fun item => indexOf item = k).card =
            (typeOf i).count k) :
    ∀ i : SourceAgent,
      Theorem34.boundedAroundAverage LR
        (Theorem34.commonLoad
          (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
          (A i)) := by
  intro i
  have htype_admissible :
      typeOf i ∈
        Theorem33.roundedAdmissibleTypeSetWithCap
          L LR lambda maxCount :=
    ((Theorem33.mem_roundedTypesInValueWindowWithCap_iff
      (valueScale := L) (averageScale := LR) (lambda := lambda)
      (maxCount := maxCount) (lower := p.1) (upper := p.2)
      (typeOf i)).mp (htypes i)).1
  have hbounds :
      LR / 2 < Theorem33.roundedBundleTypeLoad L (typeOf i) ∧
        Theorem33.roundedBundleTypeLoad L (typeOf i) < 2 * LR :=
    ((Theorem33.mem_roundedAdmissibleTypeSetWithCap_iff
      (valueScale := L) (averageScale := LR) (lambda := lambda)
      (maxCount := maxCount) (typeOf i)).mp htype_admissible).2
  have hload :
      Theorem34.commonLoad
          (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
          (A i) =
        Theorem33.roundedBundleTypeLoad L (typeOf i) :=
    paper_lmms_theorem_3_3_commonLoad_eq_roundedBundleTypeLoad_of_bundle_index_counts
      (L := L) indexOf (A i) (typeOf i) (hcounts i)
  simpa [Theorem34.boundedAroundAverage, hload] using hbounds

/--
Value-window count realization bounds the realized rounded allocation ratio by
the selected value-pair ratio.  This is the scalar counterpart to the bounded
window bridge: exact per-index counts identify each actual rounded load with
its assigned rounded type load, and the selected value window bounds the finite
infimum and supremum of those loads.
-/
theorem paper_lmms_theorem_3_3_rounded_allocation_ratio_le_value_pair_of_window_count_realization
    {L LR : ℝ} {lambda maxCount : ℕ} {SourceAgent Item : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {p : ℝ × ℝ}
    (indexOf : Item → Theorem33.RoundedValueIndex lambda)
    (A : Allocation SourceAgent Item)
    (typeOf : SourceAgent → Theorem33.RoundedBundleType lambda)
    (htypes :
      ∀ i : SourceAgent,
        typeOf i ∈
          Theorem33.roundedTypesInValueWindowWithCap
            L LR lambda maxCount p.1 p.2)
    (hcounts :
      ∀ i : SourceAgent,
        ∀ k : Theorem33.RoundedValueIndex lambda,
          ((A i).filter fun item => indexOf item = k).card =
            (typeOf i).count k)
    (hp_pos : 0 < p.1) :
    Theorem35.ratio
        ((Finset.univ : Finset SourceAgent).inf'
          Finset.univ_nonempty
          (fun i =>
            Theorem34.commonLoad
              (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
              (A i)))
        ((Finset.univ : Finset SourceAgent).sup'
          Finset.univ_nonempty
          (fun i =>
            Theorem34.commonLoad
              (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
              (A i))) ≤
      Theorem33.roundedValuePairRatio p := by
  classical
  let load : SourceAgent → ℝ :=
    fun i =>
      Theorem34.commonLoad
        (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
        (A i)
  have hload_eq :
      ∀ i : SourceAgent,
        load i = Theorem33.roundedBundleTypeLoad L (typeOf i) := by
    intro i
    exact
      paper_lmms_theorem_3_3_commonLoad_eq_roundedBundleTypeLoad_of_bundle_index_counts
        (L := L) indexOf (A i) (typeOf i) (hcounts i)
  have hlower : ∀ i : SourceAgent, p.1 ≤ load i := by
    intro i
    have hi :=
      ((Theorem33.mem_roundedTypesInValueWindowWithCap_iff
        (valueScale := L) (averageScale := LR) (lambda := lambda)
        (maxCount := maxCount) (lower := p.1) (upper := p.2)
        (typeOf i)).mp (htypes i)).2.1
    simpa [hload_eq i] using hi
  have hupper : ∀ i : SourceAgent, load i ≤ p.2 := by
    intro i
    have hi :=
      ((Theorem33.mem_roundedTypesInValueWindowWithCap_iff
        (valueScale := L) (averageScale := LR) (lambda := lambda)
        (maxCount := maxCount) (lower := p.1) (upper := p.2)
        (typeOf i)).mp (htypes i)).2.2
    simpa [hload_eq i] using hi
  have hinf_ge :
      p.1 ≤ (Finset.univ : Finset SourceAgent).inf'
          Finset.univ_nonempty load := by
    apply Finset.le_inf'
    intro i _hi
    exact hlower i
  have hsup_le :
      (Finset.univ : Finset SourceAgent).sup'
          Finset.univ_nonempty load ≤ p.2 := by
    apply Finset.sup'_le
    intro i _hi
    exact hupper i
  have hinf_pos :
      0 < (Finset.univ : Finset SourceAgent).inf'
          Finset.univ_nonempty load :=
    lt_of_lt_of_le hp_pos hinf_ge
  have hp_upper_nonneg : 0 ≤ p.2 := by
    let i0 : SourceAgent := Classical.choice (inferInstance : Nonempty SourceAgent)
    exact le_trans hp_pos.le (le_trans (hlower i0) (hupper i0))
  have hratio :
      ((Finset.univ : Finset SourceAgent).sup'
          Finset.univ_nonempty load) /
          ((Finset.univ : Finset SourceAgent).inf'
            Finset.univ_nonempty load) ≤
        p.2 / p.1 := by
    calc
      ((Finset.univ : Finset SourceAgent).sup'
          Finset.univ_nonempty load) /
          ((Finset.univ : Finset SourceAgent).inf'
            Finset.univ_nonempty load) ≤
          p.2 /
            ((Finset.univ : Finset SourceAgent).inf'
              Finset.univ_nonempty load) :=
            div_le_div_of_nonneg_right hsup_le hinf_pos.le
      _ ≤ p.2 / p.1 := by
            rw [div_le_div_iff₀ hinf_pos hp_pos]
            exact mul_le_mul_of_nonneg_left hinf_ge hp_upper_nonneg
  simpa [Theorem35.ratio, Theorem33.roundedValuePairRatio, load] using hratio

/--
Capped-search specialization of the value-window ratio bound: the realized
allocation coming from the selected capped value pair has rounded min/max ratio
no larger than that chosen pair's ratio.
-/
theorem paper_lmms_theorem_3_3_realized_capped_search_allocation_ratio_le_chosen_pair
    {L LR : ℝ} {lambda maxCount : ℕ} {SourceAgent Item : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {supply : Theorem33.RoundedValueIndex lambda → ℕ}
    (search :
      Theorem33.RoundedValuePairSearchCertificateWithCap
        L LR lambda maxCount SourceAgent supply)
    (hLR : 0 < LR)
    (indexOf : Item → Theorem33.RoundedValueIndex lambda)
    (A : Allocation SourceAgent Item)
    (typeOf : SourceAgent → Theorem33.RoundedBundleType lambda)
    (htypes :
      ∀ i : SourceAgent,
        typeOf i ∈
          Theorem33.roundedTypesInValueWindowWithCap
            L LR lambda maxCount search.chosenPair.1 search.chosenPair.2)
    (hcounts :
      ∀ i : SourceAgent,
        ∀ k : Theorem33.RoundedValueIndex lambda,
          ((A i).filter fun item => indexOf item = k).card =
            (typeOf i).count k) :
    Theorem35.ratio
        ((Finset.univ : Finset SourceAgent).inf'
          Finset.univ_nonempty
          (fun i =>
            Theorem34.commonLoad
              (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
              (A i)))
        ((Finset.univ : Finset SourceAgent).sup'
          Finset.univ_nonempty
          (fun i =>
            Theorem34.commonLoad
              (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
              (A i))) ≤
      Theorem33.roundedValuePairRatio search.chosenPair := by
  classical
  have hpair_mem :=
    Theorem33.RoundedValuePairSearchCertificateWithCap.chosenPair_mem search
  have hvalue_mem :
      search.chosenPair.1 ∈
        Theorem33.roundedAdmissibleValueSetWithCap
          L LR lambda maxCount :=
    ((Theorem33.mem_roundedAdmissibleValuePairSetWithCap_iff
      (valueScale := L) (averageScale := LR) (lambda := lambda)
      (maxCount := maxCount) search.chosenPair).mp hpair_mem).1
  rcases
      (Theorem33.mem_roundedAdmissibleValueSetWithCap_iff
        (valueScale := L) (averageScale := LR) (lambda := lambda)
        (maxCount := maxCount) search.chosenPair.1).mp hvalue_mem with
    ⟨t, ht, htload⟩
  have ht_bounds :
      LR / 2 < Theorem33.roundedBundleTypeLoad L t ∧
        Theorem33.roundedBundleTypeLoad L t < 2 * LR :=
    ((Theorem33.mem_roundedAdmissibleTypeSetWithCap_iff
      (valueScale := L) (averageScale := LR) (lambda := lambda)
      (maxCount := maxCount) t).mp ht).2
  have hp_pos : 0 < search.chosenPair.1 := by
    have : LR / 2 < search.chosenPair.1 := by
      simpa [← htload] using ht_bounds.1
    nlinarith
  exact
    paper_lmms_theorem_3_3_rounded_allocation_ratio_le_value_pair_of_window_count_realization
      (L := L) (LR := LR) (lambda := lambda) (maxCount := maxCount)
      (p := search.chosenPair) indexOf A typeOf htypes hcounts hp_pos

/--
Finite type-slot realization of a capped concrete IP: the IP multiplicities can
be materialized as fibers of a concrete agent-to-rounded-type assignment.  This
is the first half of the reverse finite realization theorem.
-/
theorem paper_lmms_theorem_3_3_exists_type_assignment_realizing_capped_ip
    {L LR : ℝ} {lambda maxCount : ℕ} {SourceAgent : Type*}
    [Fintype SourceAgent]
    {supply : Theorem33.RoundedValueIndex lambda → ℕ} {p : ℝ × ℝ}
    (ip :
      Theorem33.RoundedConcreteIPCertificateWithCap
        L LR lambda maxCount SourceAgent p supply) :
    ∃ typeOf : SourceAgent → Theorem33.RoundedBundleType lambda,
      (∀ i : SourceAgent,
        typeOf i ∈
          Theorem33.roundedTypesInValueWindowWithCap
            L LR lambda maxCount p.1 p.2) ∧
        ∀ t : Theorem33.RoundedBundleType lambda,
          Theorem33.roundedTypeMultiplicityOfAssignment typeOf t =
            ip.typeMultiplicity t := by
  classical
  let window : Finset (Theorem33.RoundedBundleType lambda) :=
    Theorem33.roundedTypesInValueWindowWithCap
      L LR lambda maxCount p.1 p.2
  let TypeSlot := Sigma
    (fun tw : {t : Theorem33.RoundedBundleType lambda // t ∈ window} =>
      Fin (ip.typeMultiplicity tw.1))
  have hslot_card : Fintype.card TypeSlot = Fintype.card SourceAgent := by
    calc
      Fintype.card TypeSlot =
          ∑ tw : {t : Theorem33.RoundedBundleType lambda // t ∈ window},
            ip.typeMultiplicity tw.1 := by
        simp [TypeSlot, Fintype.card_sigma]
      _ = window.sum ip.typeMultiplicity := by
        rw [Finset.sum_coe_sort]
      _ = Fintype.card SourceAgent := by
        simpa [window] using ip.allPlayersAssigned
  let agentSlot : SourceAgent ≃ TypeSlot :=
    Fintype.equivOfCardEq hslot_card.symm
  let typeOf : SourceAgent → Theorem33.RoundedBundleType lambda :=
    fun i => (agentSlot i).1.1
  have htypes : ∀ i : SourceAgent, typeOf i ∈ window := by
    intro i
    exact (agentSlot i).1.2
  refine ⟨typeOf, ?_, ?_⟩
  · intro i
    simpa [window] using htypes i
  · intro t
    by_cases ht : t ∈ window
    · let tw : {t : Theorem33.RoundedBundleType lambda // t ∈ window} :=
        ⟨t, ht⟩
      let eBase :
          {i : SourceAgent // typeOf i = t} ≃
            {i : SourceAgent // (agentSlot i).1 = tw} :=
        Equiv.subtypeEquivRight fun i => by
          constructor
          · intro h
            apply Subtype.ext
            simpa [typeOf, tw] using h
          · intro h
            simpa [typeOf, tw] using congrArg Subtype.val h
      let eMap :
          {i : SourceAgent // (agentSlot i).1 = tw} ≃
            {s : TypeSlot // s.1 = tw} :=
        agentSlot.subtypeEquiv (fun _ => Iff.rfl)
      let eFiber :
          {s : TypeSlot // s.1 = tw} ≃
            Fin (ip.typeMultiplicity t) := by
        simpa [TypeSlot, tw] using
          (@Equiv.sigmaSubtype
            {t : Theorem33.RoundedBundleType lambda // t ∈ window}
            (fun tw => Fin (ip.typeMultiplicity tw.1)) tw)
      have hfiber_card :
          Fintype.card {i : SourceAgent // typeOf i = t} =
            ip.typeMultiplicity t := by
        simpa using Fintype.card_congr (eBase.trans (eMap.trans eFiber))
      unfold Theorem33.roundedTypeMultiplicityOfAssignment
      rw [← Fintype.card_subtype
        (fun i : SourceAgent => typeOf i = t)]
      exact hfiber_card
    · have hzero_assign :
          Theorem33.roundedTypeMultiplicityOfAssignment typeOf t = 0 :=
        Theorem33.roundedTypeMultiplicityOfAssignment_eq_zero_of_not_mem
          typeOf htypes ht
      have hzero_ip : ip.typeMultiplicity t = 0 :=
        ip.zeroOutsideWindow t (by simpa [window] using ht)
      rw [hzero_assign, hzero_ip]

/--
Finite item-slot realization for a capped concrete IP after a type assignment
has been chosen.  For any finite materialization whose rounded-index fibers
have the supply prescribed by the IP, this constructs an exact allocation whose
per-agent rounded-index counts are exactly the assigned rounded bundle type.
-/
theorem paper_lmms_theorem_3_3_exists_exact_allocation_realizing_capped_ip_type_assignment
    {L LR : ℝ} {lambda maxCount : ℕ} {SourceAgent Item : Type*}
    [Fintype SourceAgent] [DecidableEq SourceAgent]
    [Fintype Item] [DecidableEq Item]
    {supply : Theorem33.RoundedValueIndex lambda → ℕ} {p : ℝ × ℝ}
    (ip :
      Theorem33.RoundedConcreteIPCertificateWithCap
        L LR lambda maxCount SourceAgent p supply)
    (indexOf : Item → Theorem33.RoundedValueIndex lambda)
    (hSupply :
      ∀ k : Theorem33.RoundedValueIndex lambda,
        ((Finset.univ : Finset Item).filter fun item => indexOf item = k).card =
          supply k)
    (typeOf : SourceAgent → Theorem33.RoundedBundleType lambda)
    (htypes :
      ∀ i : SourceAgent,
        typeOf i ∈
          Theorem33.roundedTypesInValueWindowWithCap
            L LR lambda maxCount p.1 p.2)
    (hmultiplicity :
      ∀ t : Theorem33.RoundedBundleType lambda,
        Theorem33.roundedTypeMultiplicityOfAssignment typeOf t =
          ip.typeMultiplicity t) :
    ∃ A : Allocation SourceAgent Item,
      IsAllocationOf A (Finset.univ : Finset Item) ∧
        ∀ i : SourceAgent,
          ∀ k : Theorem33.RoundedValueIndex lambda,
            ((A i).filter fun item => indexOf item = k).card =
              (typeOf i).count k := by
  classical
  let window : Finset (Theorem33.RoundedBundleType lambda) :=
    Theorem33.roundedTypesInValueWindowWithCap
      L LR lambda maxCount p.1 p.2
  let DemandSlot := fun k : Theorem33.RoundedValueIndex lambda =>
    Sigma fun i : SourceAgent => Fin ((typeOf i).count k)
  let ItemSlot := fun k : Theorem33.RoundedValueIndex lambda =>
    {item : Item // indexOf item = k}
  have hdemand_card :
      ∀ k : Theorem33.RoundedValueIndex lambda,
        Fintype.card (DemandSlot k) = supply k := by
    intro k
    calc
      Fintype.card (DemandSlot k) =
          ∑ i : SourceAgent, (typeOf i).count k := by
        simp [DemandSlot, Fintype.card_sigma]
      _ =
          window.sum (fun t => ip.typeMultiplicity t * t.count k) := by
        rw [← Theorem33.roundedTypeMultiplicityOfAssignment_goods_count_eq_sum_agents
          (types := window) typeOf (by simpa [window] using htypes) k]
        apply Finset.sum_congr rfl
        intro t _ht
        rw [hmultiplicity t]
      _ = supply k := by
        simpa [window] using ip.allGoodsAssigned k
  have hitem_card :
      ∀ k : Theorem33.RoundedValueIndex lambda,
        Fintype.card (ItemSlot k) = supply k := by
    intro k
    calc
      Fintype.card (ItemSlot k) =
          ((Finset.univ : Finset Item).filter fun item => indexOf item = k).card := by
        rw [Fintype.card_subtype]
      _ = supply k := hSupply k
  let itemToDemand :
      ∀ k : Theorem33.RoundedValueIndex lambda,
        ItemSlot k ≃ DemandSlot k :=
    fun k => Fintype.equivOfCardEq
      ((hitem_card k).trans (hdemand_card k).symm)
  let TotalItemSlot := Sigma ItemSlot
  let TotalDemandSlot := Sigma DemandSlot
  let itemTotal : Item ≃ TotalItemSlot :=
    {
      toFun := fun item => ⟨indexOf item, ⟨item, rfl⟩⟩
      invFun := fun s => s.2.1
      left_inv := fun _item => rfl
      right_inv := fun s => by
        rcases s with ⟨_k, item, hidx⟩
        cases hidx
        rfl
    }
  let itemToDemandTotal : TotalItemSlot ≃ TotalDemandSlot :=
    Equiv.sigmaCongrRight itemToDemand
  let owner : Item → SourceAgent :=
    fun item => (itemToDemandTotal (itemTotal item)).2.1
  let A : Allocation SourceAgent Item :=
    Theorem42.lmms42AllocationOfAssignment owner
  have halloc : IsAllocationOf A (Finset.univ : Finset Item) := by
    simpa [A] using Theorem42.lmms42AllocationOfAssignment_isAllocationOf owner
  refine ⟨A, halloc, ?_⟩
  intro i k
  let eItemToTotal :
      {item : Item // owner item = i ∧ indexOf item = k} ≃
        {s : TotalItemSlot //
          (itemToDemandTotal s).2.1 = i ∧ s.1 = k} :=
    itemTotal.subtypeEquiv (fun item => by
      constructor
      · intro h
        simpa [owner, itemTotal, itemToDemandTotal] using h
      · intro h
        simpa [owner, itemTotal, itemToDemandTotal] using h)
  let eTotalToDemand :
      {s : TotalItemSlot //
        (itemToDemandTotal s).2.1 = i ∧ s.1 = k} ≃
        {d : TotalDemandSlot // d.2.1 = i ∧ d.1 = k} :=
    itemToDemandTotal.subtypeEquiv (fun s => by
      constructor
      · intro h
        simpa [itemToDemandTotal] using h
      · intro h
        simpa [itemToDemandTotal] using h)
  let eItem :
      {item : Item // owner item = i ∧ indexOf item = k} ≃
        {d : TotalDemandSlot // d.2.1 = i ∧ d.1 = k} :=
    eItemToTotal.trans eTotalToDemand
  let eTotalFiber :
      {d : TotalDemandSlot // d.2.1 = i ∧ d.1 = k} ≃
        {d : DemandSlot k // d.1 = i} :=
    {
      toFun := fun d => by
        rcases d with ⟨⟨_k, demand⟩, howner, hk⟩
        cases hk
        exact ⟨demand, howner⟩
      invFun := fun d => ⟨⟨k, d.1⟩, d.2, rfl⟩
      left_inv := fun d => by
        rcases d with ⟨⟨_k, demand⟩, howner, hk⟩
        cases hk
        rfl
      right_inv := fun _d => by
        rfl
    }
  let eFiber :
      {d : DemandSlot k // d.1 = i} ≃ Fin ((typeOf i).count k) := by
    simpa [DemandSlot] using
      (@Equiv.sigmaSubtype SourceAgent
        (fun i => Fin ((typeOf i).count k)) i)
  have hsub_card :
      Fintype.card {item : Item // owner item = i ∧ indexOf item = k} =
        (typeOf i).count k := by
    simpa using Fintype.card_congr (eItem.trans (eTotalFiber.trans eFiber))
  calc
    ((A i).filter fun item => indexOf item = k).card =
        ((Finset.univ : Finset Item).filter
          (fun item => owner item = i ∧ indexOf item = k)).card := by
      simp [A, Theorem42.lmms42AllocationOfAssignment, Finset.filter_filter]
    _ = Fintype.card {item : Item // owner item = i ∧ indexOf item = k} := by
      rw [Fintype.card_subtype]
    _ = (typeOf i).count k := hsub_card

/--
Full finite realization of a capped concrete IP over an indexed finite item
materialization.  The IP multiplicities are first realized as agent types, then
items of each rounded index are matched to the corresponding demand slots,
producing an exact allocation whose bundles are bounded around `LR`.
-/
theorem paper_lmms_theorem_3_3_exists_exact_bounded_allocation_of_indexed_concrete_ip_with_cap
    {L LR : ℝ} {lambda maxCount : ℕ} {SourceAgent Item : Type*}
    [Fintype SourceAgent] [DecidableEq SourceAgent]
    [Fintype Item] [DecidableEq Item]
    {supply : Theorem33.RoundedValueIndex lambda → ℕ} {p : ℝ × ℝ}
    (ip :
      Theorem33.RoundedConcreteIPCertificateWithCap
        L LR lambda maxCount SourceAgent p supply)
    (indexOf : Item → Theorem33.RoundedValueIndex lambda)
    (hSupply :
      ∀ k : Theorem33.RoundedValueIndex lambda,
        ((Finset.univ : Finset Item).filter fun item => indexOf item = k).card =
          supply k) :
    ∃ typeOf : SourceAgent → Theorem33.RoundedBundleType lambda,
      ∃ A : Allocation SourceAgent Item,
        IsAllocationOf A (Finset.univ : Finset Item) ∧
          (∀ i : SourceAgent,
            typeOf i ∈
              Theorem33.roundedTypesInValueWindowWithCap
                L LR lambda maxCount p.1 p.2) ∧
          (∀ t : Theorem33.RoundedBundleType lambda,
            Theorem33.roundedTypeMultiplicityOfAssignment typeOf t =
              ip.typeMultiplicity t) ∧
          (∀ i : SourceAgent,
            ∀ k : Theorem33.RoundedValueIndex lambda,
              ((A i).filter fun item => indexOf item = k).card =
                (typeOf i).count k) ∧
          ∀ i : SourceAgent,
            Theorem34.boundedAroundAverage LR
              (Theorem34.commonLoad
                (fun item : Item => Theorem33.roundedValue L lambda (indexOf item))
                (A i)) := by
  classical
  rcases
      paper_lmms_theorem_3_3_exists_type_assignment_realizing_capped_ip
        (L := L) (LR := LR) (lambda := lambda) (maxCount := maxCount)
        ip with
    ⟨typeOf, htypes, hmultiplicity⟩
  rcases
      paper_lmms_theorem_3_3_exists_exact_allocation_realizing_capped_ip_type_assignment
        (L := L) (LR := LR) (lambda := lambda) (maxCount := maxCount)
        ip indexOf hSupply typeOf htypes hmultiplicity with
    ⟨A, halloc, hcounts⟩
  exact
    ⟨typeOf, A, halloc, htypes, hmultiplicity, hcounts,
      paper_lmms_theorem_3_3_exact_bounded_allocation_window_of_capped_ip_window_count_realization
        (L := L) (LR := LR) (lambda := lambda) (maxCount := maxCount)
        ip indexOf A typeOf htypes hcounts⟩

