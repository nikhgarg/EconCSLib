/--
Theorem 3.3 combined-supply finite-search seam: after the high source goods
and low artificial goods are combined into the paper's rounded supply vector,
a solver certificate that assigns one admissible rounded bundle type to each
agent and exactly uses that supply is enough to construct the finite
value-pair search certificate.  This isolates the remaining IP/solver
obligation without adding the Lenstra/runtime proof.
-/
theorem paper_lmms_theorem_3_3_exists_value_pair_search_certificate_of_combined_high_low_type_assignment
    {SourceAgent SourceItem : Type*} [Fintype SourceAgent]
    [DecidableEq SourceItem]
    {L : ℝ} {lambda : ℕ}
    (highGoods lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g ∧ v g < L)
    (hlow :
      ∀ g : SourceItem, g ∈ lowGoods →
        0 ≤ v g ∧ v g < L / (lambda : ℝ))
    (solver :
      ∀ (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
        (combinedSupply : Theorem33.RoundedValueIndex lambda → ℕ),
        (∀ g : SourceItem, g ∈ highGoods →
          v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
            Theorem33.roundedValue L lambda (indexOf g) <
              v g + L / ((lambda : ℝ) ^ 2)) →
        (∀ k : Theorem33.RoundedValueIndex lambda,
          combinedSupply k =
            paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods k +
              Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v) k) →
        ∃ p : ℝ × ℝ,
          p ∈ Theorem33.roundedAdmissibleValuePairSet L lambda ∧
            ∃ typeOf : SourceAgent → Theorem33.RoundedBundleType lambda,
              (∀ i : SourceAgent,
                typeOf i ∈
                  Theorem33.roundedTypesInValueWindow L lambda p.1 p.2) ∧
                ∀ k : Theorem33.RoundedValueIndex lambda,
                  (∑ i : SourceAgent, (typeOf i).count k) =
                    combinedSupply k) :
    ∃ indexOf : SourceItem → Theorem33.RoundedValueIndex lambda,
      ∃ combinedSupply : Theorem33.RoundedValueIndex lambda → ℕ,
        ∃ p : ℝ × ℝ,
          ∃ typeOf : SourceAgent → Theorem33.RoundedBundleType lambda,
            ∃ search : Theorem33.RoundedValuePairSearchCertificate L lambda SourceAgent,
              (∀ g : SourceItem, g ∈ highGoods →
                v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
                  Theorem33.roundedValue L lambda (indexOf g) <
                    v g + L / ((lambda : ℝ) ^ 2)) ∧
                (∀ k : Theorem33.RoundedValueIndex lambda,
                  combinedSupply k =
                    paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods
                        indexOf highGoods k +
                      Theorem33.lowGoodsAggregatedSupply L lambda
                        (lowGoods.sum v) k) ∧
                  p ∈ Theorem33.roundedAdmissibleValuePairSet L lambda ∧
                    (∀ i : SourceAgent,
                      typeOf i ∈
                        Theorem33.roundedTypesInValueWindow L lambda p.1 p.2) ∧
                      (∀ k : Theorem33.RoundedValueIndex lambda,
                        (∑ i : SourceAgent, (typeOf i).count k) =
                          combinedSupply k) ∧
                        Theorem33.roundedValuePairRatio search.chosenPair ≤
                          Theorem33.roundedValuePairRatio p := by
  classical
  rcases
      paper_lmms_theorem_3_3_exists_combined_high_low_rounded_goods_supply
        highGoods lowGoods v hlambda hL hhigh hlow with
    ⟨indexOf, combinedSupply, hindex, hsupply, _hlower, _hupper⟩
  rcases solver indexOf combinedSupply hindex hsupply with
    ⟨p, hpair, typeOf, htypes, hcounts⟩
  obtain ⟨search, hsearch⟩ :=
    paper_lmms_theorem_3_3_exists_value_pair_search_certificate_of_supply_type_assignment
      (L := L) (lambda := lambda) (SourceAgent := SourceAgent)
      (supply := combinedSupply) hpair typeOf htypes hcounts
  exact
    ⟨indexOf, combinedSupply, p, typeOf, search, hindex, hsupply, hpair,
      htypes, hcounts, hsearch⟩

