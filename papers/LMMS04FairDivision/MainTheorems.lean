    (hopt_max : 0 ≤ Theorem33.maxAllocationLoad M optimal)
    (hrounded_max_nonneg : 0 ≤ Theorem33.maxAllocationLoad M rounded)
    (hrounded_min_half :
      L ≤ 2 * Theorem33.minAllocationLoad M rounded)
    (hrounded_max_half :
      L ≤ 2 * Theorem33.maxAllocationLoad M rounded)
    (hopt_min_half :
      L ≤ 2 * Theorem33.minAllocationLoad M optimal)
    (hopt_max_half :
      L ≤ 2 * Theorem33.maxAllocationLoad M optimal)
    (hbackward_max :
      Theorem33.maxAllocationLoad M output ≤
        Theorem33.maxAllocationLoad M rounded + L / (56 / epsilon))
    (hbackward_min :
      ((56 / epsilon) / ((56 / epsilon) + 1)) *
          Theorem33.minAllocationLoad M rounded -
        (2 / (56 / epsilon)) * L ≤
          Theorem33.minAllocationLoad M output)
    (hforward_max :
      Theorem33.maxAllocationLoad M rounded ≤
        (((56 / epsilon) + 1) / (56 / epsilon)) *
            Theorem33.maxAllocationLoad M optimal +
          L / (56 / epsilon))
    (hforward_min :
      Theorem33.minAllocationLoad M optimal - L / (56 / epsilon) ≤
        Theorem33.minAllocationLoad M rounded) :
    ∃ cert : Theorem33.RoundedInstanceSearchCertificate
        M L epsilon lambda optimal,
      cert.rounded = rounded ∧
        cert.output = output ∧
          cert.pairSearch = pairSearch ∧
            Theorem33.allocationLoadRatio M cert.output ≤
              Theorem33.allocationLoadRatio M optimal * (1 + epsilon) := by
  let transferLambda : ℝ := 56 / epsilon
  have hlambda_pos : 0 < transferLambda := by
    dsimp [transferLambda]
    positivity
  have hlambda_ge : 56 ≤ transferLambda := by
    dsimp [transferLambda]
    rw [le_div_iff₀ hepsilon_pos]
    nlinarith
  have hbackward_lower :
      0 < transferLambda / (transferLambda + 1) - 4 / transferLambda :=
    Theorem35.backwardLowerFactor_pos_of_ge_56 hlambda_ge
  have hforward_lower : 0 < 1 - 2 / transferLambda :=
    Theorem35.forwardLowerFactor_pos_of_ge_56 hlambda_ge
  have hbackward_upper_nonneg : 0 ≤ 1 + 2 / transferLambda := by
    positivity
  have hforward_upper_nonneg :
      0 ≤ ((transferLambda + 1) / transferLambda) +
        2 / transferLambda := by
    positivity
  have hrounded_to_source_ratio :
      Theorem35.ratio
          (Theorem33.minAllocationLoad M output)
          (Theorem33.maxAllocationLoad M output) ≤
        Theorem35.ratio
            (Theorem33.minAllocationLoad M rounded)
            (Theorem33.maxAllocationLoad M rounded) *
          Theorem35.backwardTransferFactor transferLambda := by
    exact
      Theorem35.backward_ratio_transfer_of_additive
        (lambda := transferLambda) (L := L)
        hlambda_pos houtput_min hrounded_min hbackward_lower
        hbackward_upper_nonneg hrounded_max_nonneg
        hrounded_min_half hrounded_max_half
        (by simpa [transferLambda] using hbackward_max)
        (by simpa [transferLambda] using hbackward_min)
  have hsource_to_rounded_ratio :
      Theorem35.ratio
          (Theorem33.minAllocationLoad M rounded)
          (Theorem33.maxAllocationLoad M rounded) ≤
        Theorem35.ratio
            (Theorem33.minAllocationLoad M optimal)
            (Theorem33.maxAllocationLoad M optimal) *
          Theorem35.forwardTransferFactor transferLambda := by
    exact
      Theorem35.forward_ratio_transfer_of_additive
        (lambda := transferLambda) (L := L)
        hlambda_pos hrounded_min hopt_min hforward_lower
        hforward_upper_nonneg hopt_max hopt_min_half hopt_max_half
        (by simpa [transferLambda] using hforward_max)
        (by simpa [transferLambda] using hforward_min)
  have hrounded_to_source :
      Theorem33.allocationLoadRatio M output ≤
        Theorem33.allocationLoadRatio M rounded *
          Theorem35.backwardTransferFactor (56 / epsilon) := by
    rw [paper_lmms_theorem_3_3_allocation_load_ratio_eq_transfer_ratio
          M output,
        paper_lmms_theorem_3_3_allocation_load_ratio_eq_transfer_ratio
          M rounded]
    simpa [transferLambda] using hrounded_to_source_ratio
  have hsource_to_rounded :
      Theorem33.allocationLoadRatio M rounded ≤
        Theorem33.allocationLoadRatio M optimal *
          Theorem35.forwardTransferFactor (56 / epsilon) := by
    rw [paper_lmms_theorem_3_3_allocation_load_ratio_eq_transfer_ratio
          M rounded,
        paper_lmms_theorem_3_3_allocation_load_ratio_eq_transfer_ratio
          M optimal]
    simpa [transferLambda] using hsource_to_rounded_ratio
  exact
    paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_transfer
      hepsilon_pos hepsilon_le_one pairSearch hopt_min hopt_max
      hrounded_to_source hsource_to_rounded

/--
Theorem 3.3 rounded-instance search-certificate assembly from agentwise
additive transfer bounds.  Bundlewise Lemma 3.5 estimates naturally arise per
agent; this wrapper globalizes those estimates to the min/max premises used by
`..._of_additive_transfer`.
-/
theorem paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_agentwise_additive_transfer
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {M : Theorem33.IdenticalUtilitiesModel SourceAgent SourceItem Alloc}
    {L epsilon : ℝ} {lambda : ℕ} {optimal rounded output : Alloc}
    (hepsilon_pos : 0 < epsilon) (hepsilon_le_one : epsilon ≤ 1)
    (pairSearch : Theorem33.RoundedValuePairSearchCertificate L lambda SourceAgent)
    (houtput_min : 0 < Theorem33.minAllocationLoad M output)
    (hrounded_min : 0 < Theorem33.minAllocationLoad M rounded)
    (hopt_min : 0 < Theorem33.minAllocationLoad M optimal)
    (hopt_max : 0 ≤ Theorem33.maxAllocationLoad M optimal)
    (hrounded_max_nonneg : 0 ≤ Theorem33.maxAllocationLoad M rounded)
    (hrounded_min_half :
      L ≤ 2 * Theorem33.minAllocationLoad M rounded)
    (hrounded_max_half :
      L ≤ 2 * Theorem33.maxAllocationLoad M rounded)
    (hopt_min_half :
      L ≤ 2 * Theorem33.minAllocationLoad M optimal)
    (hopt_max_half :
      L ≤ 2 * Theorem33.maxAllocationLoad M optimal)
    (hbackward_max_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M output i ≤
          Theorem33.allocationLoad M rounded i + L / (56 / epsilon))
    (hbackward_min_agent :
      ∀ i : SourceAgent,
        ((56 / epsilon) / ((56 / epsilon) + 1)) *
            Theorem33.allocationLoad M rounded i -
          (2 / (56 / epsilon)) * L ≤
            Theorem33.allocationLoad M output i)
    (hforward_max_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M rounded i ≤
          (((56 / epsilon) + 1) / (56 / epsilon)) *
              Theorem33.allocationLoad M optimal i +
            L / (56 / epsilon))
    (hforward_min_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M optimal i - L / (56 / epsilon) ≤
          Theorem33.allocationLoad M rounded i) :
    ∃ cert : Theorem33.RoundedInstanceSearchCertificate
        M L epsilon lambda optimal,
      cert.rounded = rounded ∧
        cert.output = output ∧
          cert.pairSearch = pairSearch ∧
            Theorem33.allocationLoadRatio M cert.output ≤
              Theorem33.allocationLoadRatio M optimal * (1 + epsilon) := by
  have hbackward_max :
      Theorem33.maxAllocationLoad M output ≤
        Theorem33.maxAllocationLoad M rounded + L / (56 / epsilon) := by
    unfold Theorem33.maxAllocationLoad
    apply Finset.sup'_le
    intro i _hi
    have hi := hbackward_max_agent i
    have hrounded_le :=
      Theorem33.load_le_maxAllocationLoad M rounded i
    exact
      le_trans hi
        (by
          simpa [Theorem33.maxAllocationLoad] using
            add_le_add_right hrounded_le (L / (56 / epsilon)))
  have hbackward_min :
      ((56 / epsilon) / ((56 / epsilon) + 1)) *
          Theorem33.minAllocationLoad M rounded -
        (2 / (56 / epsilon)) * L ≤
          Theorem33.minAllocationLoad M output := by
    have hcoef_nonneg :
        0 ≤ (56 / epsilon) / ((56 / epsilon) + 1) := by
      positivity
    unfold Theorem33.minAllocationLoad
    apply Finset.le_inf'
    intro i _hi
    have hmin_le :=
      Theorem33.minAllocationLoad_le_load M rounded i
    have hscaled :
        ((56 / epsilon) / ((56 / epsilon) + 1)) *
            Theorem33.minAllocationLoad M rounded ≤
          ((56 / epsilon) / ((56 / epsilon) + 1)) *
            Theorem33.allocationLoad M rounded i :=
      mul_le_mul_of_nonneg_left hmin_le hcoef_nonneg
    have hi := hbackward_min_agent i
    exact
      le_trans
        (by
          simpa [Theorem33.minAllocationLoad] using
            sub_le_sub_right hscaled ((2 / (56 / epsilon)) * L))
        hi
  have hforward_max :
      Theorem33.maxAllocationLoad M rounded ≤
        (((56 / epsilon) + 1) / (56 / epsilon)) *
            Theorem33.maxAllocationLoad M optimal +
          L / (56 / epsilon) := by
    have hcoef_nonneg :
        0 ≤ (((56 / epsilon) + 1) / (56 / epsilon)) := by
      positivity
    unfold Theorem33.maxAllocationLoad
    apply Finset.sup'_le
    intro i _hi
    have hopt_le :=
      Theorem33.load_le_maxAllocationLoad M optimal i
    have hscaled :
        (((56 / epsilon) + 1) / (56 / epsilon)) *
            Theorem33.allocationLoad M optimal i ≤
          (((56 / epsilon) + 1) / (56 / epsilon)) *
            Theorem33.maxAllocationLoad M optimal :=
      mul_le_mul_of_nonneg_left hopt_le hcoef_nonneg
    have hi := hforward_max_agent i
    exact
      le_trans hi
        (by
          simpa [Theorem33.maxAllocationLoad] using
            add_le_add_right hscaled (L / (56 / epsilon)))
  have hforward_min :
      Theorem33.minAllocationLoad M optimal - L / (56 / epsilon) ≤
        Theorem33.minAllocationLoad M rounded := by
    unfold Theorem33.minAllocationLoad
    apply Finset.le_inf'
    intro i _hi
    have hopt_min_le :=
      Theorem33.minAllocationLoad_le_load M optimal i
    have hi := hforward_min_agent i
    exact
      le_trans
        (by
          simpa [Theorem33.minAllocationLoad] using
            sub_le_sub_right hopt_min_le (L / (56 / epsilon)))
        hi
  exact
    paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_additive_transfer
      hepsilon_pos hepsilon_le_one pairSearch houtput_min hrounded_min
      hopt_min hopt_max hrounded_max_nonneg hrounded_min_half
      hrounded_max_half hopt_min_half hopt_max_half hbackward_max
      hbackward_min hforward_max hforward_min

/--
Theorem 3.3 rounded-instance search-certificate assembly from agentwise
additive transfer bounds and Claim-3.4-style min/max windows.  The
`boundedAroundAverage` hypotheses discharge the positivity, nonnegativity, and
half-average side conditions required by the algebraic transfer wrapper.
-/
theorem paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_agentwise_additive_transfer_with_bounded_min_max
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {M : Theorem33.IdenticalUtilitiesModel SourceAgent SourceItem Alloc}
    {L epsilon : ℝ} {lambda : ℕ} {optimal rounded output : Alloc}
    (hepsilon_pos : 0 < epsilon) (hepsilon_le_one : epsilon ≤ 1)
    (hL : 0 < L)
    (pairSearch : Theorem33.RoundedValuePairSearchCertificate L lambda SourceAgent)
    (houtput_min : 0 < Theorem33.minAllocationLoad M output)
    (hrounded_min_window :
      Theorem34.boundedAroundAverage L
        (Theorem33.minAllocationLoad M rounded))
    (hrounded_max_window :
      Theorem34.boundedAroundAverage L
        (Theorem33.maxAllocationLoad M rounded))
    (hopt_min_window :
      Theorem34.boundedAroundAverage L
        (Theorem33.minAllocationLoad M optimal))
    (hopt_max_window :
      Theorem34.boundedAroundAverage L
        (Theorem33.maxAllocationLoad M optimal))
    (hbackward_max_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M output i ≤
          Theorem33.allocationLoad M rounded i + L / (56 / epsilon))
    (hbackward_min_agent :
      ∀ i : SourceAgent,
        ((56 / epsilon) / ((56 / epsilon) + 1)) *
            Theorem33.allocationLoad M rounded i -
          (2 / (56 / epsilon)) * L ≤
            Theorem33.allocationLoad M output i)
    (hforward_max_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M rounded i ≤
          (((56 / epsilon) + 1) / (56 / epsilon)) *
              Theorem33.allocationLoad M optimal i +
            L / (56 / epsilon))
    (hforward_min_agent :
      ∀ i : SourceAgent,
        Theorem33.allocationLoad M optimal i - L / (56 / epsilon) ≤
          Theorem33.allocationLoad M rounded i) :
    ∃ cert : Theorem33.RoundedInstanceSearchCertificate
        M L epsilon lambda optimal,
      cert.rounded = rounded ∧
        cert.output = output ∧
          cert.pairSearch = pairSearch ∧
            Theorem33.allocationLoadRatio M cert.output ≤
              Theorem33.allocationLoadRatio M optimal * (1 + epsilon) := by
  have hrounded_min : 0 < Theorem33.minAllocationLoad M rounded := by
    nlinarith [hL, hrounded_min_window.1]
  have hopt_min : 0 < Theorem33.minAllocationLoad M optimal := by
    nlinarith [hL, hopt_min_window.1]
  have hopt_max : 0 ≤ Theorem33.maxAllocationLoad M optimal := by
    nlinarith [hL, hopt_max_window.1]
  have hrounded_max_nonneg :
      0 ≤ Theorem33.maxAllocationLoad M rounded := by
    nlinarith [hL, hrounded_max_window.1]
  have hrounded_min_half :
      L ≤ 2 * Theorem33.minAllocationLoad M rounded := by
    nlinarith [hrounded_min_window.1]
  have hrounded_max_half :
      L ≤ 2 * Theorem33.maxAllocationLoad M rounded := by
    nlinarith [hrounded_max_window.1]
  have hopt_min_half :
      L ≤ 2 * Theorem33.minAllocationLoad M optimal := by
    nlinarith [hopt_min_window.1]
  have hopt_max_half :
      L ≤ 2 * Theorem33.maxAllocationLoad M optimal := by
    nlinarith [hopt_max_window.1]
  exact
    paper_lmms_theorem_3_3_exists_rounded_instance_search_certificate_of_agentwise_additive_transfer
      hepsilon_pos hepsilon_le_one pairSearch houtput_min hrounded_min
      hopt_min hopt_max hrounded_max_nonneg hrounded_min_half
      hrounded_max_half hopt_min_half hopt_max_half hbackward_max_agent
      hbackward_min_agent hforward_max_agent hforward_min_agent

