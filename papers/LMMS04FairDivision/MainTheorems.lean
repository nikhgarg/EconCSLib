            (SourceAgent := SourceAgent) (SourceItem := SourceItem)
            (L := L) (lambda := lambda) indexOf))
        (fun B i => B i)
        A) :
    ∀ i : SourceAgent,
      paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf (A i) ∈
        Theorem33.roundedTypesInValueWindow L lambda
          (Theorem33.minAllocationLoad
            (paper_lmms_theorem_3_3_roundedModelOfIndex
              (SourceAgent := SourceAgent) (SourceItem := SourceItem)
              (L := L) (lambda := lambda) indexOf) A)
          (Theorem33.maxAllocationLoad
            (paper_lmms_theorem_3_3_roundedModelOfIndex
              (SourceAgent := SourceAgent) (SourceItem := SourceItem)
              (L := L) (lambda := lambda) indexOf) A) := by
  classical
  let M :=
    paper_lmms_theorem_3_3_roundedModelOfIndex
      (SourceAgent := SourceAgent) (SourceItem := SourceItem)
      (L := L) (lambda := lambda) indexOf
  intro i
  let typeOfI :=
    paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf (A i)
  have hload_common :
      Theorem33.roundedBundleTypeLoad L typeOfI =
        Theorem33.allocationLoad M A i := by
    simpa [typeOfI, M, paper_lmms_theorem_3_3_roundedModelOfIndex,
      Theorem33.allocationLoad, Theorem33.bundleLoad, Theorem34.commonLoad] using
      paper_lmms_theorem_3_3_roundedBundleTypeOfBundle_load_eq_sum
        (L := L) indexOf (A i)
  have hadmissible :
      typeOfI ∈ Theorem33.roundedAdmissibleTypeSet L lambda :=
    Theorem33.roundedBundleType_mem_roundedAdmissibleTypeSet_of_load_window
      hlambda hL typeOfI
      (by simpa [M, paper_lmms_theorem_3_3_roundedModelOfIndex, hload_common]
        using (cert.2 i).1)
      (by simpa [M, paper_lmms_theorem_3_3_roundedModelOfIndex, hload_common]
        using (cert.2 i).2)
  have hmin_le :
      Theorem33.minAllocationLoad M A ≤
        Theorem33.roundedBundleTypeLoad L typeOfI := by
    simpa [← hload_common] using
      Theorem33.minAllocationLoad_le_load M A i
  have hle_max :
      Theorem33.roundedBundleTypeLoad L typeOfI ≤
        Theorem33.maxAllocationLoad M A := by
    simpa [← hload_common] using
      Theorem33.load_le_maxAllocationLoad M A i
  exact
    (Theorem33.mem_roundedTypesInValueWindow_iff
      (L := L) (lambda := lambda)
      (lower := Theorem33.minAllocationLoad M A)
      (upper := Theorem33.maxAllocationLoad M A) typeOfI).mpr
      ⟨hadmissible, hmin_le, hle_max⟩

/--
Exact-allocation source-domain helper for Claim 3.4: moving an owned good from
one agent to a different target preserves exact allocation of the same goods.
-/
theorem paper_lmms_isAllocationOf_moveBundle
    {SourceAgent SourceItem : Type*}
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {A : Allocation SourceAgent SourceItem} {goods : Finset SourceItem}
    {source target : SourceAgent} {g : SourceItem}
    (halloc : IsAllocationOf A goods)
    (hsource_ne_target : source ≠ target)
    (hg_source : g ∈ A source) :
    IsAllocationOf (Theorem34.moveBundle A source target g) goods := by
  classical
  have htarget_ne_source : target ≠ source := hsource_ne_target.symm
  constructor
  · intro i x hx
    by_cases hi_source : i = source
    · have hxA : x ∈ A source := by
        have hx_erase : x ∈ (A source).erase g := by
          simpa [Theorem34.moveBundle, hi_source] using hx
        exact Finset.mem_of_mem_erase hx_erase
      exact isAllocationOf_mem_goods halloc hxA
    · by_cases hi_target : i = target
      · have hx_insert : x ∈ insert g (A target) := by
          simpa [Theorem34.moveBundle, hi_target, htarget_ne_source] using hx
        rcases Finset.mem_insert.mp hx_insert with hx_eq | hxA
        · rw [hx_eq]
          exact isAllocationOf_mem_goods halloc hg_source
        · exact isAllocationOf_mem_goods halloc hxA
      · have hxA : x ∈ A i := by
          simpa [Theorem34.moveBundle, hi_source, hi_target] using hx
        exact isAllocationOf_mem_goods halloc hxA
  · intro x hx_goods
    by_cases hxg : x = g
    · subst x
      refine ⟨target, ?_, ?_⟩
      · simp [Theorem34.moveBundle, hsource_ne_target.symm]
      · intro j hj
        by_cases hj_source : j = source
        · have hbad : g ∈ (A source).erase g := by
            simpa [Theorem34.moveBundle, hj_source] using hj
          exact False.elim (by simpa using hbad)
        · by_cases hj_target : j = target
          · exact hj_target
          · have hjA : g ∈ A j := by
              simpa [Theorem34.moveBundle, hj_source, hj_target] using hj
            have hjs : j = source :=
              isAllocationOf_owner_unique halloc hx_goods hjA hg_source
            exact False.elim (hj_source hjs)
    · rcases halloc.2 x hx_goods with ⟨owner, howner, hunique_owner⟩
      refine ⟨owner, ?_, ?_⟩
      · by_cases howner_source : owner = source
        · have hx_ne_g : x ≠ g := hxg
          simpa [Theorem34.moveBundle, howner_source, hx_ne_g] using howner
        · by_cases howner_target : owner = target
          · have howner_target_mem : x ∈ A target := by
              simpa [howner_target] using howner
            simp [Theorem34.moveBundle, howner_target, htarget_ne_source,
              howner_target_mem]
          · simpa [Theorem34.moveBundle, howner_source, howner_target] using howner
      · intro j hj
        have hjA : x ∈ A j := by
          by_cases hj_source : j = source
          · have hj_erase : x ∈ (A source).erase g := by
              simpa [Theorem34.moveBundle, hj_source] using hj
            simpa [hj_source] using Finset.mem_of_mem_erase hj_erase
          · by_cases hj_target : j = target
            · have hj_insert : x ∈ insert g (A target) := by
                simpa [Theorem34.moveBundle, hj_target, htarget_ne_source] using hj
              rcases Finset.mem_insert.mp hj_insert with hx_eq | hxA
              · exact False.elim (hxg hx_eq)
              · simpa [hj_target] using hxA
            · simpa [Theorem34.moveBundle, hj_source, hj_target] using hj
        exact hunique_owner j hjA

/--
Exact-allocation source-domain helper for Claim 3.4: if the moved good is not
the donor's whole load, moving it to a distinct target preserves nonemptiness
of every agent bundle.
-/
theorem paper_lmms_moveBundle_nonempty_of_source_load_gt_item
    {SourceAgent SourceItem : Type*}
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {A : Allocation SourceAgent SourceItem} {v : SourceItem → ℝ}
    {source target : SourceAgent} {g : SourceItem}
    (hsource_ne_target : source ≠ target)
    (hg_source : g ∈ A source)
    (hA_nonempty :
      ∀ i : SourceAgent, ∃ x : SourceItem, x ∈ A i)
    (hg_lt_source_load : v g < Theorem34.commonLoad v (A source)) :
    ∀ i : SourceAgent,
      ∃ x : SourceItem,
        x ∈ Theorem34.moveBundle A source target g i := by
  classical
  intro i
  by_cases hi_source : i = source
  · subst i
    have herase_pos :
        0 < Theorem34.commonLoad v ((A source).erase g) := by
      rw [Theorem34.commonLoad_erase (v := v) (S := A source) (g := g) hg_source]
      linarith
    rcases
        Theorem34.exists_mem_of_commonLoad_pos
          (v := v) (S := (A source).erase g) herase_pos with
      ⟨x, hx⟩
    exact ⟨x, by simpa [Theorem34.moveBundle] using hx⟩
  · by_cases hi_target : i = target
    · refine ⟨g, ?_⟩
      subst i
      simp [Theorem34.moveBundle, hsource_ne_target.symm]
    · rcases hA_nonempty i with ⟨x, hx⟩
      exact ⟨x, by simpa [Theorem34.moveBundle, hi_source, hi_target] using hx⟩

/--
Gap-shaped version of `paper_lmms_moveBundle_nonempty_of_source_load_gt_item`:
the low-only and boundary Claim 3.4 moves choose a good with value strictly
below `maxLoad - minLoad`, so a positive minimum load leaves another donor
item after the move.
-/
theorem paper_lmms_moveBundle_nonempty_of_gap
    {SourceAgent SourceItem : Type*}
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {A : Allocation SourceAgent SourceItem} {v : SourceItem → ℝ}
    {source target : SourceAgent} {g : SourceItem} {minLoad maxLoad : ℝ}
    (hsource_ne_target : source ≠ target)
    (hg_source : g ∈ A source)
    (hA_nonempty :
      ∀ i : SourceAgent, ∃ x : SourceItem, x ∈ A i)
    (hsource_max : Theorem34.commonLoad v (A source) = maxLoad)
    (hmin_pos : 0 < minLoad)
    (hg_gap : v g < maxLoad - minLoad) :
    ∀ i : SourceAgent,
      ∃ x : SourceItem,
        x ∈ Theorem34.moveBundle A source target g i := by
  apply
    paper_lmms_moveBundle_nonempty_of_source_load_gt_item
      (A := A) (v := v) hsource_ne_target hg_source hA_nonempty
  rw [hsource_max]
  nlinarith

/--
Claim 3.4 obstruction lemma: under exact allocation of nonnegative goods, an
empty bundle forces the concrete minimum common load to be zero.  Thus the
positive-minimum premise cannot be derived from exact allocation or positive
total load alone.
-/
theorem paper_lmms_claim_3_4_minCommonLoad_eq_zero_of_exact_allocation_empty_bundle
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ}
    {A : Allocation SourceAgent SourceItem}
    (halloc : IsAllocationOf A goods)
    (hempty : ∃ i : SourceAgent, A i = ∅)
    (hgoods_nonneg : ∀ g : SourceItem, g ∈ goods → 0 ≤ v g) :
    Theorem34.minCommonLoad v A = 0 := by
  classical
  have hloads_nonneg :
      ∀ i : SourceAgent, 0 ≤ Theorem34.commonLoad v (A i) := by
    intro i
    unfold Theorem34.commonLoad
    exact
      Finset.sum_nonneg (by
        intro g hg
        exact hgoods_nonneg g (isAllocationOf_mem_goods halloc hg))
  have hmin_nonneg : 0 ≤ Theorem34.minCommonLoad v A := by
    rcases
        Theorem34.exists_commonLoad_eq_minCommonLoad
          (v := v) (bundle := A) with
      ⟨i, hi⟩
    rw [← hi]
    exact hloads_nonneg i
  rcases hempty with ⟨i, hi_empty⟩
  have hmin_le_zero : Theorem34.minCommonLoad v A ≤ 0 := by
    have hle := Theorem34.minCommonLoad_le (v := v) (bundle := A) i
    simpa [Theorem34.commonLoad, hi_empty] using hle
  exact le_antisymm hmin_le_zero hmin_nonneg

/--
Exact-allocation positivity helper for Claim 3.4: if every agent owns at least
one good and every allocated good has positive common value, then the concrete
minimum common load is positive.
-/
theorem paper_lmms_claim_3_4_minCommonLoad_pos_of_exact_allocation_each_agent_nonempty
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ}
    {A : Allocation SourceAgent SourceItem}
    (halloc : IsAllocationOf A goods)
    (howns : ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i)
    (hgoods_pos : ∀ g : SourceItem, g ∈ goods → 0 < v g) :
    0 < Theorem34.minCommonLoad v A := by
  exact
    Theorem34.minCommonLoad_pos_of_each_bundle_has_pos_good
      (v := v) (bundle := A)
      (fun i =>
        let ⟨g, hg⟩ := howns i
        ⟨g, hg, hgoods_pos g (isAllocationOf_mem_goods halloc hg)⟩)
      (fun i g hg =>
        le_of_lt (hgoods_pos g (isAllocationOf_mem_goods halloc hg)))

/--
Claim 3.4 positive-minimum helper: if the concrete minimum common load is
positive, then no bundle is empty.
-/
theorem paper_lmms_claim_3_4_each_agent_nonempty_of_minCommonLoad_pos
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {v : SourceItem → ℝ} {A : Allocation SourceAgent SourceItem}
    (hmin_pos : 0 < Theorem34.minCommonLoad v A) :
    ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i := by
  intro i
  exact
    Theorem34.exists_mem_of_commonLoad_pos
      (v := v) (S := A i)
      (lt_of_lt_of_le hmin_pos
        (Theorem34.minCommonLoad_le (v := v) (bundle := A) i))

/--
Claim 3.4 exact nonempty branch step: for exact allocations of positive goods
whose values are all strictly below `L`, the min/max source trichotomy supplies
the concrete descent step while preserving exactness and nonempty bundles.
-/
theorem paper_lmms_claim_3_4_branch_step_of_exact_nonempty_positive_goods
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Fintype SourceItem] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ} {L : ℝ}
    (hL : 0 < L)
    (hgoods_load :
      Theorem34.commonLoad v goods = (Fintype.card SourceAgent : ℝ) * L)
    (hgoods_pos : ∀ g : SourceItem, g ∈ goods → 0 < v g)
    (hgoods_lt : ∀ g : SourceItem, g ∈ goods → v g < L)
    (A : Allocation SourceAgent SourceItem)
    (hA_alloc : IsAllocationOf A goods)
    (hA_nonempty : ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i)
    (_hA_opt :
      ∀ C : Allocation SourceAgent SourceItem,
        IsAllocationOf C goods →
          (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
            Theorem34.loadRatio (Theorem34.minCommonLoad v A)
                (Theorem34.maxCommonLoad v A) ≤
              Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                (Theorem34.maxCommonLoad v C))
    (hnot_bounded :
      ¬ ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (A i))) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ B i) ∧
          Theorem34.loadRatio (Theorem34.minCommonLoad v B)
              (Theorem34.maxCommonLoad v B) ≤
            Theorem34.loadRatio (Theorem34.minCommonLoad v A)
              (Theorem34.maxCommonLoad v A) ∧
            (Theorem34.overfullBundleCardPotential v L B <
                Theorem34.overfullBundleCardPotential v L A ∨
              (Theorem34.overfullBundleCardPotential v L B =
                  Theorem34.overfullBundleCardPotential v L A ∧
                Theorem34.minLoadTiePotential v
                  (fun A : Allocation SourceAgent SourceItem => A)
                  (fun A => Theorem34.minCommonLoad v A) B <
                Theorem34.minLoadTiePotential v
                  (fun A : Allocation SourceAgent SourceItem => A)
                  (fun A => Theorem34.minCommonLoad v A) A)) := by
  classical
  let minLoad : ℝ := Theorem34.minCommonLoad v A
  let maxLoad : ℝ := Theorem34.maxCommonLoad v A
  have hminA : Theorem34.minCommonLoad v A = minLoad := rfl
  have hmaxA : Theorem34.maxCommonLoad v A = maxLoad := rfl
  have havg :
      (∑ i : SourceAgent, Theorem34.commonLoad v (A i)) =
        (Fintype.card SourceAgent : ℝ) * L := by
    rw [← hgoods_load]
    simpa [Theorem34.commonLoad] using
      paper_lmms_isAllocationOf_sum_bundle_values_eq_sum_goods
        (A := A) (goods := goods) (v := v) hA_alloc
  have hmin_pos : 0 < minLoad := by
    simpa [minLoad] using
      paper_lmms_claim_3_4_minCommonLoad_pos_of_exact_allocation_each_agent_nonempty
        (A := A) (goods := goods) (v := v) hA_alloc hA_nonempty hgoods_pos
  have hmin_le : ∀ i : SourceAgent, minLoad ≤ Theorem34.commonLoad v (A i) := by
    intro i
    rw [← hminA]
    exact Theorem34.minCommonLoad_le (v := v) (bundle := A) i
  have hle_max : ∀ i : SourceAgent, Theorem34.commonLoad v (A i) ≤ maxLoad := by
    intro i
    rw [← hmaxA]
    exact Theorem34.commonLoad_le_maxCommonLoad (v := v) (bundle := A) i
  have hwithin :
      ∀ i : SourceAgent,
        minLoad ≤ Theorem34.commonLoad v (A i) ∧
          Theorem34.commonLoad v (A i) ≤ maxLoad := by
    intro i
    exact ⟨hmin_le i, hle_max i⟩
  have hmax_nonneg : 0 ≤ maxLoad := by
    rcases
        Theorem34.exists_commonLoad_eq_maxCommonLoad
          (v := v) (bundle := A) with
      ⟨source, hsource⟩
    have hmin_le_max : minLoad ≤ maxLoad := by
      simpa [hsource] using hmin_le source
    exact le_trans hmin_pos.le hmin_le_max
  rcases
      Theorem34.exists_commonLoad_eq_maxCommonLoad
        (v := v) (bundle := A) with
    ⟨source, hsource_max_raw⟩
  rcases
      Theorem34.exists_commonLoad_eq_minCommonLoad
        (v := v) (bundle := A) with
    ⟨target, htarget_min_raw⟩
  have hsource_max : Theorem34.commonLoad v (A source) = maxLoad := by
    rw [hsource_max_raw, hmaxA]
  have htarget_min : Theorem34.commonLoad v (A target) = minLoad := by
    rw [htarget_min_raw, hminA]
  have hitem_nonneg_source :
      ∀ g : SourceItem, g ∈ A source → 0 ≤ v g := by
    intro g hg
    exact le_of_lt (hgoods_pos g (isAllocationOf_mem_goods hA_alloc hg))
  have hitem_lt_source :
      ∀ g : SourceItem, g ∈ A source → v g < L := by
    intro g hg
    exact hgoods_lt g (isAllocationOf_mem_goods hA_alloc hg)
  have hunique :
      ∀ {i j : SourceAgent} {g : SourceItem}, g ∈ A i → g ∈ A j → i = j := by
    intro i j g hi hj
    exact
      isAllocationOf_owner_unique hA_alloc
        (isAllocationOf_mem_goods hA_alloc hi) hi hj
  by_cases hmax_high : 2 * L < maxLoad
  · have hsource_high_load : 2 * L < Theorem34.commonLoad v (A source) := by
      rw [hsource_max]
      exact hmax_high
    rcases
        Theorem34.exists_target_good_of_high_source_average
          (bundle := A) (v := v) hL havg hsource_high_load
          hitem_nonneg_source hitem_lt_source hunique with
      ⟨target', g, hsource_ne_target, hg_source, hg_target,
        htarget_le, hg_nonneg, hg_lt⟩
    let B : Allocation SourceAgent SourceItem :=
      Theorem34.moveBundle A source target' g
    have hB_alloc : IsAllocationOf B goods := by
      simpa [B] using
        paper_lmms_isAllocationOf_moveBundle
          (A := A) (goods := goods) hA_alloc hsource_ne_target hg_source
    have hB_nonempty : ∀ i : SourceAgent, ∃ x : SourceItem, x ∈ B i := by
      have hg_lt_source_load : v g < Theorem34.commonLoad v (A source) := by
        nlinarith
      simpa [B] using
        paper_lmms_moveBundle_nonempty_of_source_load_gt_item
          (A := A) (v := v) hsource_ne_target hg_source hA_nonempty
          hg_lt_source_load
    have hratio_load :
        Theorem34.loadRatio (Theorem34.minCommonLoad v B)
            (Theorem34.maxCommonLoad v B) ≤
          Theorem34.loadRatio minLoad maxLoad := by
      exact
        (Theorem34.local_reallocation_certificate_of_le_average_target_high_source
          (bundle := A) (v := v)
          (source := source) (target := target') (g := g)
          (oldMin := minLoad) (oldMax := maxLoad)
          (newMin := Theorem34.minCommonLoad v B)
          (newMax := Theorem34.maxCommonLoad v B)
          hsource_ne_target hg_source hg_target hL hmin_pos hmax_nonneg
          hwithin htarget_le hsource_high_load hg_nonneg hg_lt
          (by
            intro i
            simpa [B] using
              Theorem34.minCommonLoad_le (v := v) (bundle := B) i)
          (by
            rcases
                Theorem34.exists_commonLoad_eq_minCommonLoad
                  (v := v) (bundle := B) with
              ⟨i, hi⟩
            exact ⟨i, by simpa [B] using hi⟩)
          (by
            intro i
            simpa [B] using
              Theorem34.commonLoad_le_maxCommonLoad (v := v) (bundle := B) i)
          (by
            rcases
                Theorem34.exists_commonLoad_eq_maxCommonLoad
                  (v := v) (bundle := B) with
              ⟨i, hi⟩
            exact ⟨i, by simpa [B] using hi⟩)).1
    have hratio_BA :
        Theorem34.loadRatio (Theorem34.minCommonLoad v B)
            (Theorem34.maxCommonLoad v B) ≤
          Theorem34.loadRatio (Theorem34.minCommonLoad v A)
            (Theorem34.maxCommonLoad v A) := by
      simpa [minLoad, maxLoad] using hratio_load
    have hpotential :
        Theorem34.overfullBundleCardPotential v L B <
          Theorem34.overfullBundleCardPotential v L A := by
      simpa [B] using
        Theorem34.overfullBundleCardPotential_decreases_of_moveBundle_le_average_target_high_source
          hsource_ne_target hg_source hg_target hL htarget_le
          hsource_high_load hg_lt
    exact ⟨B, hB_alloc, hB_nonempty, hratio_BA, Or.inl hpotential⟩
  · have hmax_le : maxLoad ≤ 2 * L := le_of_not_gt hmax_high
    by_cases hmin_low : minLoad ≤ L / 2
    · rcases
          Theorem34.exists_low_min_max_source_move_ratio_nonincreasing
            (bundle := A) (v := v) hL havg htarget_min hsource_max
            hmin_pos hmin_low hmin_le hle_max hitem_nonneg_source
            hitem_lt_source hunique with
        ⟨g, hg_source, hg_target, hg_pos, hg_gap, hratio_move⟩
      let B : Allocation SourceAgent SourceItem :=
        Theorem34.moveBundle A source target g
      have hsource_ne_target : source ≠ target := by
        intro hsource_target
        exact hg_target (by simpa [hsource_target] using hg_source)
      have hB_alloc : IsAllocationOf B goods := by
        simpa [B] using
          paper_lmms_isAllocationOf_moveBundle
            (A := A) (goods := goods) hA_alloc hsource_ne_target hg_source
      have hB_nonempty : ∀ i : SourceAgent, ∃ x : SourceItem, x ∈ B i := by
        simpa [B] using
          paper_lmms_moveBundle_nonempty_of_gap
            (A := A) (v := v) (minLoad := minLoad) (maxLoad := maxLoad)
            hsource_ne_target hg_source hA_nonempty hsource_max hmin_pos hg_gap
      have hratio_load :
          Theorem34.loadRatio (Theorem34.minCommonLoad v B)
              (Theorem34.maxCommonLoad v B) ≤
            Theorem34.loadRatio minLoad maxLoad := by
        refine hratio_move ?_ ?_ ?_ ?_
        · intro i
          simpa [B] using
            Theorem34.minCommonLoad_le (v := v) (bundle := B) i
        · rcases
              Theorem34.exists_commonLoad_eq_minCommonLoad
                (v := v) (bundle := B) with
            ⟨i, hi⟩
          exact ⟨i, by simpa [B] using hi⟩
        · intro i
          simpa [B] using
            Theorem34.commonLoad_le_maxCommonLoad (v := v) (bundle := B) i
        · rcases
              Theorem34.exists_commonLoad_eq_maxCommonLoad
                (v := v) (bundle := B) with
            ⟨i, hi⟩
          exact ⟨i, by simpa [B] using hi⟩
      have hratio_BA :
          Theorem34.loadRatio (Theorem34.minCommonLoad v B)
              (Theorem34.maxCommonLoad v B) ≤
            Theorem34.loadRatio (Theorem34.minCommonLoad v A)
              (Theorem34.maxCommonLoad v A) := by
        simpa [minLoad, maxLoad] using hratio_load
      have hbranch :=
        Theorem34.claim34_low_only_branch_step_of_move_certificate
          (v := v) (L := L)
          (ratioOf := fun A : Allocation SourceAgent SourceItem =>
            Theorem34.loadRatio (Theorem34.minCommonLoad v A)
              (Theorem34.maxCommonLoad v A))
          (bundleOf := fun A : Allocation SourceAgent SourceItem => A)
          (minOf := fun A => Theorem34.minCommonLoad v A)
          (A := A) (B := B) (source := source) (target := target)
          (g := g) (minLoad := minLoad) (maxLoad := maxLoad)
          (fun C i => Theorem34.minCommonLoad_le (v := v) (bundle := C) i)
          (fun C => Theorem34.exists_commonLoad_eq_minCommonLoad (v := v) (bundle := C))
          hminA htarget_min hsource_max hsource_ne_target hg_source
          hg_target hg_pos hg_gap hmax_le hle_max (by rfl) hratio_BA
      exact ⟨B, hB_alloc, hB_nonempty, hratio_BA, Or.inr hbranch.2⟩
    · have hmin_gt : L / 2 < minLoad := lt_of_not_ge hmin_low
      have hmax_ge : 2 * L ≤ maxLoad := by
        by_contra hnot_ge
        have hmax_lt : maxLoad < 2 * L := lt_of_not_ge hnot_ge
        exact hnot_bounded (by
          intro i
          exact
            ⟨lt_of_lt_of_le hmin_gt (hmin_le i),
              lt_of_le_of_lt (hle_max i) hmax_lt⟩)
      have hmax_eq_twoL : maxLoad = 2 * L := le_antisymm hmax_le hmax_ge
      rcases
          Theorem34.exists_boundary_min_max_source_move_ratio_nonincreasing
            (bundle := A) (v := v) hL havg htarget_min hsource_max
            hmin_pos hmax_eq_twoL hmin_le hle_max hitem_nonneg_source
            hitem_lt_source hunique with
        ⟨g, hg_source, hg_target, hg_pos, hg_gap, hratio_move⟩
      let B : Allocation SourceAgent SourceItem :=
        Theorem34.moveBundle A source target g
      have hsource_ne_target : source ≠ target := by
        intro hsource_target
        exact hg_target (by simpa [hsource_target] using hg_source)
      have hB_alloc : IsAllocationOf B goods := by
        simpa [B] using
          paper_lmms_isAllocationOf_moveBundle
            (A := A) (goods := goods) hA_alloc hsource_ne_target hg_source
      have hB_nonempty : ∀ i : SourceAgent, ∃ x : SourceItem, x ∈ B i := by
        simpa [B] using
          paper_lmms_moveBundle_nonempty_of_gap
            (A := A) (v := v) (minLoad := minLoad) (maxLoad := maxLoad)
            hsource_ne_target hg_source hA_nonempty hsource_max hmin_pos hg_gap
      have hratio_load :
          Theorem34.loadRatio (Theorem34.minCommonLoad v B)
              (Theorem34.maxCommonLoad v B) ≤
            Theorem34.loadRatio minLoad maxLoad := by
        refine hratio_move ?_ ?_ ?_ ?_
        · intro i
          simpa [B] using
            Theorem34.minCommonLoad_le (v := v) (bundle := B) i
        · rcases
              Theorem34.exists_commonLoad_eq_minCommonLoad
                (v := v) (bundle := B) with
            ⟨i, hi⟩
          exact ⟨i, by simpa [B] using hi⟩
        · intro i
          simpa [B] using
            Theorem34.commonLoad_le_maxCommonLoad (v := v) (bundle := B) i
        · rcases
              Theorem34.exists_commonLoad_eq_maxCommonLoad
                (v := v) (bundle := B) with
            ⟨i, hi⟩
          exact ⟨i, by simpa [B] using hi⟩
      have hratio_BA :
          Theorem34.loadRatio (Theorem34.minCommonLoad v B)
              (Theorem34.maxCommonLoad v B) ≤
            Theorem34.loadRatio (Theorem34.minCommonLoad v A)
              (Theorem34.maxCommonLoad v A) := by
        simpa [minLoad, maxLoad] using hratio_load
      have hbranch :=
        Theorem34.claim34_low_only_branch_step_of_move_certificate
          (v := v) (L := L)
          (ratioOf := fun A : Allocation SourceAgent SourceItem =>
            Theorem34.loadRatio (Theorem34.minCommonLoad v A)
              (Theorem34.maxCommonLoad v A))
          (bundleOf := fun A : Allocation SourceAgent SourceItem => A)
          (minOf := fun A => Theorem34.minCommonLoad v A)
          (A := A) (B := B) (source := source) (target := target)
          (g := g) (minLoad := minLoad) (maxLoad := maxLoad)
          (fun C i => Theorem34.minCommonLoad_le (v := v) (bundle := C) i)
          (fun C => Theorem34.exists_commonLoad_eq_minCommonLoad (v := v) (bundle := C))
          hminA htarget_min hsource_max hsource_ne_target hg_source
          hg_target hg_pos hg_gap (by rw [hmax_eq_twoL]) hle_max
          (by rfl) hratio_BA
      exact ⟨B, hB_alloc, hB_nonempty, hratio_BA, Or.inr hbranch.2⟩

/--
Claim 3.4 source-domain descent over exact positive-minimum allocations.  This
is the feasible-domain replacement for unrestricted optimality over all
`Allocation` objects: the ratio comparison, secondary-potential bound, and
descent step only range over exact allocations of the source goods whose
minimum load is positive.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_on_exact_positive_min_allocations
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ} {L : ℝ}
    {ratioOf : Allocation SourceAgent SourceItem → ℝ}
    (primary secondary : Allocation SourceAgent SourceItem → ℕ)
    (secondaryBound : ℕ)
    (A₀ : Allocation SourceAgent SourceItem)
    (hA₀_alloc : IsAllocationOf A₀ goods)
    (hA₀_min_pos : 0 < Theorem34.minCommonLoad v A₀)
    (hA₀_opt :
      ∀ C : Allocation SourceAgent SourceItem,
        IsAllocationOf C goods →
          0 < Theorem34.minCommonLoad v C →
            ratioOf A₀ ≤ ratioOf C)
    (hsecondary_bound :
      ∀ A : Allocation SourceAgent SourceItem,
        IsAllocationOf A goods →
          0 < Theorem34.minCommonLoad v A →
            secondary A ≤ secondaryBound)
    (hstep :
      ∀ A : Allocation SourceAgent SourceItem,
        IsAllocationOf A goods →
          0 < Theorem34.minCommonLoad v A →
            (∀ C : Allocation SourceAgent SourceItem,
              IsAllocationOf C goods →
                0 < Theorem34.minCommonLoad v C →
                  ratioOf A ≤ ratioOf C) →
              (¬ ∀ i : SourceAgent,
                Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (A i))) →
                ∃ B : Allocation SourceAgent SourceItem,
                  IsAllocationOf B goods ∧
                    0 < Theorem34.minCommonLoad v B ∧
                      ratioOf B ≤ ratioOf A ∧
                        (primary B < primary A ∨
                          (primary B = primary A ∧ secondary B < secondary A))) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        0 < Theorem34.minCommonLoad v B ∧
          (∀ C : Allocation SourceAgent SourceItem,
            IsAllocationOf C goods →
              0 < Theorem34.minCommonLoad v C →
                ratioOf B ≤ ratioOf C) ∧
            ∀ i : SourceAgent,
              Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (B i)) := by
  classical
  let feasible : Allocation SourceAgent SourceItem → Prop :=
    fun A => IsAllocationOf A goods ∧ 0 < Theorem34.minCommonLoad v A
  rcases
      Theorem34.claim34_bounded_optimal_on_of_lexicographic_finite_descent
        (v := v) (L := L) (ratioOf := ratioOf)
        (bundleOf := fun A : Allocation SourceAgent SourceItem => A)
        feasible primary secondary secondaryBound A₀
        ⟨hA₀_alloc, hA₀_min_pos⟩
        (by
          intro C hC
          exact hA₀_opt C hC.1 hC.2)
        (by
          intro A hA
          exact hsecondary_bound A hA.1 hA.2)
        (by
          intro A hA hAopt hnot_bounded
          rcases
              hstep A hA.1 hA.2
                (by
                  intro C hC hCmin
                  exact hAopt C ⟨hC, hCmin⟩)
                hnot_bounded with
            ⟨B, hBalloc, hBmin, hBA, hdecrease⟩
          exact ⟨B, ⟨hBalloc, hBmin⟩, hBA, hdecrease⟩) with
    ⟨B, hBfeasible, hBopt, hBbounded⟩
  exact
    ⟨B, hBfeasible.1, hBfeasible.2,
      (by
        intro C hC hCmin
        exact hBopt C ⟨hC, hCmin⟩),
      hBbounded⟩

/--
Claim 3.4 source-domain descent with the concrete ratio and lexicographic
potentials used by the branching proof.  This is the exact positive-minimum
feasible-domain wrapper with the paper-local min/max ratio, high-bundle
primary potential, and low-only tie-breaker secondary potential already
specialized.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_on_exact_positive_min_allocations_branching_potentials
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Fintype SourceItem] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ} {L : ℝ}
    (A₀ : Allocation SourceAgent SourceItem)
    (hA₀_alloc : IsAllocationOf A₀ goods)
    (hA₀_min_pos : 0 < Theorem34.minCommonLoad v A₀)
    (hA₀_opt :
      ∀ C : Allocation SourceAgent SourceItem,
        IsAllocationOf C goods →
          0 < Theorem34.minCommonLoad v C →
            Theorem34.loadRatio (Theorem34.minCommonLoad v A₀)
                (Theorem34.maxCommonLoad v A₀) ≤
              Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                (Theorem34.maxCommonLoad v C))
    (hstep :
      ∀ A : Allocation SourceAgent SourceItem,
        IsAllocationOf A goods →
          0 < Theorem34.minCommonLoad v A →
            (∀ C : Allocation SourceAgent SourceItem,
              IsAllocationOf C goods →
                0 < Theorem34.minCommonLoad v C →
                  Theorem34.loadRatio (Theorem34.minCommonLoad v A)
                      (Theorem34.maxCommonLoad v A) ≤
                    Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                      (Theorem34.maxCommonLoad v C)) →
              (¬ ∀ i : SourceAgent,
                Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (A i))) →
                ∃ B : Allocation SourceAgent SourceItem,
                  IsAllocationOf B goods ∧
                    0 < Theorem34.minCommonLoad v B ∧
                      Theorem34.loadRatio (Theorem34.minCommonLoad v B)
                          (Theorem34.maxCommonLoad v B) ≤
                        Theorem34.loadRatio (Theorem34.minCommonLoad v A)
                          (Theorem34.maxCommonLoad v A) ∧
                        (Theorem34.overfullBundleCardPotential v L B <
                            Theorem34.overfullBundleCardPotential v L A ∨
                          (Theorem34.overfullBundleCardPotential v L B =
                              Theorem34.overfullBundleCardPotential v L A ∧
                            Theorem34.minLoadTiePotential v
                              (fun A : Allocation SourceAgent SourceItem => A)
                              (fun A => Theorem34.minCommonLoad v A) B <
                            Theorem34.minLoadTiePotential v
                              (fun A : Allocation SourceAgent SourceItem => A)
                              (fun A => Theorem34.minCommonLoad v A) A))) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        0 < Theorem34.minCommonLoad v B ∧
          (∀ C : Allocation SourceAgent SourceItem,
            IsAllocationOf C goods →
              0 < Theorem34.minCommonLoad v C →
                Theorem34.loadRatio (Theorem34.minCommonLoad v B)
                    (Theorem34.maxCommonLoad v B) ≤
                  Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                    (Theorem34.maxCommonLoad v C)) ∧
            ∀ i : SourceAgent,
              Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (B i)) := by
  classical
  let ratioOf : Allocation SourceAgent SourceItem → ℝ :=
    fun A =>
      Theorem34.loadRatio (Theorem34.minCommonLoad v A)
        (Theorem34.maxCommonLoad v A)
  let primary : Allocation SourceAgent SourceItem → ℕ :=
    fun A => Theorem34.overfullBundleCardPotential v L A
  let secondary : Allocation SourceAgent SourceItem → ℕ :=
    fun A =>
      Theorem34.minLoadTiePotential v
        (fun A : Allocation SourceAgent SourceItem => A)
        (fun A => Theorem34.minCommonLoad v A) A
  let secondaryBound : ℕ :=
    Fintype.card (Allocation SourceAgent SourceItem) *
        (Fintype.card SourceAgent + 1) +
      Fintype.card SourceAgent
  rcases
      paper_lmms_claim_3_4_bounded_optimal_on_exact_positive_min_allocations
        (v := v) (L := L) (ratioOf := ratioOf)
        primary secondary secondaryBound A₀
        hA₀_alloc hA₀_min_pos
        (by
          intro C hC_alloc hC_min_pos
          exact hA₀_opt C hC_alloc hC_min_pos)
        (by
          intro A _hA_alloc _hA_min_pos
          exact
            Theorem34.minLoadTiePotential_le_card_bound
              (v := v)
              (bundleOf := fun A : Allocation SourceAgent SourceItem => A)
              (minOf := fun A => Theorem34.minCommonLoad v A) A)
        (by
          intro A hA_alloc hA_min_pos hA_opt hnot_bounded
          exact
            hstep A hA_alloc hA_min_pos
              (by
                intro C hC_alloc hC_min_pos
                exact hA_opt C hC_alloc hC_min_pos)
              hnot_bounded) with
    ⟨B, hB_alloc, hB_min_pos, hB_opt, hB_bounded⟩
  exact ⟨B, hB_alloc, hB_min_pos, hB_opt, hB_bounded⟩

/--
Claim 3.4 source-domain descent over exact allocations with nonempty bundles
and positive source goods.  This packages the positive-minimum feasible-domain
descent in the paper's more concrete domain: exact allocations of the source
goods where each agent receives at least one good.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_on_exact_nonempty_positive_goods
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ} {L : ℝ}
    {ratioOf : Allocation SourceAgent SourceItem → ℝ}
    (primary secondary : Allocation SourceAgent SourceItem → ℕ)
    (secondaryBound : ℕ)
    (A₀ : Allocation SourceAgent SourceItem)
    (hA₀_alloc : IsAllocationOf A₀ goods)
    (hA₀_nonempty : ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A₀ i)
    (hgoods_pos : ∀ g : SourceItem, g ∈ goods → 0 < v g)
    (hA₀_opt :
      ∀ C : Allocation SourceAgent SourceItem,
        IsAllocationOf C goods →
          (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
            ratioOf A₀ ≤ ratioOf C)
    (hsecondary_bound :
      ∀ A : Allocation SourceAgent SourceItem,
        IsAllocationOf A goods →
          (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i) →
            secondary A ≤ secondaryBound)
    (hstep :
      ∀ A : Allocation SourceAgent SourceItem,
        IsAllocationOf A goods →
          (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i) →
            (∀ C : Allocation SourceAgent SourceItem,
              IsAllocationOf C goods →
                (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
                  ratioOf A ≤ ratioOf C) →
              (¬ ∀ i : SourceAgent,
                Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (A i))) →
                ∃ B : Allocation SourceAgent SourceItem,
                  IsAllocationOf B goods ∧
                    (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ B i) ∧
                      ratioOf B ≤ ratioOf A ∧
                        (primary B < primary A ∨
                          (primary B = primary A ∧ secondary B < secondary A))) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ B i) ∧
          (∀ C : Allocation SourceAgent SourceItem,
            IsAllocationOf C goods →
              (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
                ratioOf B ≤ ratioOf C) ∧
            ∀ i : SourceAgent,
              Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (B i)) := by
  classical
  have hA₀_min_pos :
      0 < Theorem34.minCommonLoad v A₀ :=
    paper_lmms_claim_3_4_minCommonLoad_pos_of_exact_allocation_each_agent_nonempty
      (goods := goods) hA₀_alloc hA₀_nonempty hgoods_pos
  rcases
      paper_lmms_claim_3_4_bounded_optimal_on_exact_positive_min_allocations
        (v := v) (L := L) (ratioOf := ratioOf)
        primary secondary secondaryBound A₀ hA₀_alloc hA₀_min_pos
        (by
          intro C hC_alloc hC_min_pos
          exact
            hA₀_opt C hC_alloc
              (paper_lmms_claim_3_4_each_agent_nonempty_of_minCommonLoad_pos
                (v := v) hC_min_pos))
        (by
          intro A hA_alloc hA_min_pos
          exact
            hsecondary_bound A hA_alloc
              (paper_lmms_claim_3_4_each_agent_nonempty_of_minCommonLoad_pos
                (v := v) hA_min_pos))
        (by
          intro A hA_alloc hA_min_pos hA_opt hnot_bounded
          let hA_nonempty :
              ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i :=
            paper_lmms_claim_3_4_each_agent_nonempty_of_minCommonLoad_pos
              (v := v) hA_min_pos
          rcases
              hstep A hA_alloc hA_nonempty
                (by
                  intro C hC_alloc hC_nonempty
                  exact
                    hA_opt C hC_alloc
                      (paper_lmms_claim_3_4_minCommonLoad_pos_of_exact_allocation_each_agent_nonempty
                        (goods := goods) hC_alloc hC_nonempty hgoods_pos))
                hnot_bounded with
            ⟨B, hB_alloc, hB_nonempty, hBA, hdecrease⟩
          exact
            ⟨B, hB_alloc,
              paper_lmms_claim_3_4_minCommonLoad_pos_of_exact_allocation_each_agent_nonempty
                (goods := goods) hB_alloc hB_nonempty hgoods_pos,
              hBA, hdecrease⟩) with
    ⟨B, hB_alloc, hB_min_pos, hB_opt, hB_bounded⟩
  exact
    ⟨B, hB_alloc,
      paper_lmms_claim_3_4_each_agent_nonempty_of_minCommonLoad_pos
        (v := v) hB_min_pos,
      (by
        intro C hC_alloc hC_nonempty
        exact
          hB_opt C hC_alloc
            (paper_lmms_claim_3_4_minCommonLoad_pos_of_exact_allocation_each_agent_nonempty
              (goods := goods) hC_alloc hC_nonempty hgoods_pos)),
      hB_bounded⟩

/--
Claim 3.4 source-domain descent with source-shaped nonempty feasibility and
the concrete ratio/potentials used by the branching proof.  This composes the
exact nonempty-positive-goods feasible domain with the paper-local min/max
ratio, high-bundle primary potential, and low-only tie-breaker potential.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_on_exact_nonempty_positive_goods_branching_potentials
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Fintype SourceItem] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ} {L : ℝ}
    (A₀ : Allocation SourceAgent SourceItem)
    (hA₀_alloc : IsAllocationOf A₀ goods)
    (hA₀_nonempty : ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A₀ i)
    (hgoods_pos : ∀ g : SourceItem, g ∈ goods → 0 < v g)
    (hA₀_opt :
      ∀ C : Allocation SourceAgent SourceItem,
        IsAllocationOf C goods →
          (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
            Theorem34.loadRatio (Theorem34.minCommonLoad v A₀)
                (Theorem34.maxCommonLoad v A₀) ≤
              Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                (Theorem34.maxCommonLoad v C))
    (hstep :
      ∀ A : Allocation SourceAgent SourceItem,
        IsAllocationOf A goods →
          (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i) →
            (∀ C : Allocation SourceAgent SourceItem,
              IsAllocationOf C goods →
                (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
                  Theorem34.loadRatio (Theorem34.minCommonLoad v A)
                      (Theorem34.maxCommonLoad v A) ≤
                    Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                      (Theorem34.maxCommonLoad v C)) →
              (¬ ∀ i : SourceAgent,
                Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (A i))) →
                ∃ B : Allocation SourceAgent SourceItem,
                  IsAllocationOf B goods ∧
                    (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ B i) ∧
                      Theorem34.loadRatio (Theorem34.minCommonLoad v B)
                          (Theorem34.maxCommonLoad v B) ≤
                        Theorem34.loadRatio (Theorem34.minCommonLoad v A)
                          (Theorem34.maxCommonLoad v A) ∧
                        (Theorem34.overfullBundleCardPotential v L B <
                            Theorem34.overfullBundleCardPotential v L A ∨
                          (Theorem34.overfullBundleCardPotential v L B =
                              Theorem34.overfullBundleCardPotential v L A ∧
                            Theorem34.minLoadTiePotential v
                              (fun A : Allocation SourceAgent SourceItem => A)
                              (fun A => Theorem34.minCommonLoad v A) B <
                            Theorem34.minLoadTiePotential v
                              (fun A : Allocation SourceAgent SourceItem => A)
                              (fun A => Theorem34.minCommonLoad v A) A))) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ B i) ∧
          (∀ C : Allocation SourceAgent SourceItem,
            IsAllocationOf C goods →
              (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
                Theorem34.loadRatio (Theorem34.minCommonLoad v B)
                    (Theorem34.maxCommonLoad v B) ≤
                  Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                    (Theorem34.maxCommonLoad v C)) ∧
            ∀ i : SourceAgent,
              Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (B i)) := by
  classical
  let ratioOf : Allocation SourceAgent SourceItem → ℝ :=
    fun A =>
      Theorem34.loadRatio (Theorem34.minCommonLoad v A)
        (Theorem34.maxCommonLoad v A)
  let primary : Allocation SourceAgent SourceItem → ℕ :=
    fun A => Theorem34.overfullBundleCardPotential v L A
  let secondary : Allocation SourceAgent SourceItem → ℕ :=
    fun A =>
      Theorem34.minLoadTiePotential v
        (fun A : Allocation SourceAgent SourceItem => A)
        (fun A => Theorem34.minCommonLoad v A) A
  let secondaryBound : ℕ :=
    Fintype.card (Allocation SourceAgent SourceItem) *
        (Fintype.card SourceAgent + 1) +
      Fintype.card SourceAgent
  rcases
      paper_lmms_claim_3_4_bounded_optimal_on_exact_nonempty_positive_goods
        (v := v) (L := L) (ratioOf := ratioOf)
        primary secondary secondaryBound A₀ hA₀_alloc hA₀_nonempty
        hgoods_pos
        (by
          intro C hC_alloc hC_nonempty
          exact hA₀_opt C hC_alloc hC_nonempty)
        (by
          intro A _hA_alloc _hA_nonempty
          exact
            Theorem34.minLoadTiePotential_le_card_bound
              (v := v)
              (bundleOf := fun A : Allocation SourceAgent SourceItem => A)
              (minOf := fun A => Theorem34.minCommonLoad v A) A)
        (by
          intro A hA_alloc hA_nonempty hA_opt hnot_bounded
          exact
            hstep A hA_alloc hA_nonempty
              (by
                intro C hC_alloc hC_nonempty
                exact hA_opt C hC_alloc hC_nonempty)
              hnot_bounded) with
    ⟨B, hB_alloc, hB_nonempty, hB_opt, hB_bounded⟩
  exact ⟨B, hB_alloc, hB_nonempty, hB_opt, hB_bounded⟩

/--
Claim 3.4 source-domain optimizer selector: if the exact nonempty allocation
domain is nonempty, finite search chooses a ratio-minimizing allocation in
that domain, and the already-proved nonempty-positive-goods descent turns it
into a bounded exact nonempty optimum.  This removes the need to pass an
explicit starting optimum through later source-facing Claim 3.4 wrappers.
-/
theorem paper_lmms_claim_3_4_exists_bounded_optimal_on_exact_nonempty_positive_goods
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Fintype SourceItem] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ} {L : ℝ}
    (hL : 0 < L)
    (hgoods_load :
      Theorem34.commonLoad v goods = (Fintype.card SourceAgent : ℝ) * L)
    (hgoods_pos : ∀ g : SourceItem, g ∈ goods → 0 < v g)
    (hgoods_lt : ∀ g : SourceItem, g ∈ goods → v g < L)
    (hfeasible :
      ∃ A : Allocation SourceAgent SourceItem,
        IsAllocationOf A goods ∧
          ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ B i) ∧
          (∀ C : Allocation SourceAgent SourceItem,
            IsAllocationOf C goods →
              (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
                Theorem34.loadRatio (Theorem34.minCommonLoad v B)
                    (Theorem34.maxCommonLoad v B) ≤
                  Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                    (Theorem34.maxCommonLoad v C)) ∧
            ∀ i : SourceAgent,
              Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (B i)) := by
  classical
  let feasible : Allocation SourceAgent SourceItem → Prop :=
    fun A =>
      IsAllocationOf A goods ∧
        ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i
  let ratioOf : Allocation SourceAgent SourceItem → ℝ :=
    fun A =>
      Theorem34.loadRatio (Theorem34.minCommonLoad v A)
        (Theorem34.maxCommonLoad v A)
  haveI : DecidablePred feasible := Classical.decPred feasible
  have hfeasible' : ∃ A : Allocation SourceAgent SourceItem, feasible A := by
    simpa [feasible] using hfeasible
  obtain ⟨A₀, hA₀_min⟩ :=
    EconCSLib.Optimization.exists_isMinimizerOn_of_finite
      feasible ratioOf hfeasible'
  rcases hA₀_min.1 with ⟨hA₀_alloc, hA₀_nonempty⟩
  exact
    paper_lmms_claim_3_4_bounded_optimal_on_exact_nonempty_positive_goods_branching_potentials
      (goods := goods) (v := v) (L := L)
      A₀ hA₀_alloc hA₀_nonempty hgoods_pos
      (by
        intro C hC_alloc hC_nonempty
        exact hA₀_min.2 C ⟨hC_alloc, hC_nonempty⟩)
      (by
        intro A hA_alloc hA_nonempty hA_opt hnot_bounded
        exact
          paper_lmms_claim_3_4_branch_step_of_exact_nonempty_positive_goods
            (goods := goods) (v := v) (L := L)
            hL hgoods_load hgoods_pos hgoods_lt
            A hA_alloc hA_nonempty hA_opt hnot_bounded)

/--
Claim 3.4 source-domain selection from an owner map: a source assignment that
gives every agent at least one good supplies the nonempty exact feasible point
needed by the finite-search optimizer selector.
-/
theorem paper_lmms_claim_3_4_exists_bounded_optimal_of_surjective_owner
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Fintype SourceItem] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ} {L : ℝ}
    (owner : SourceItem → SourceAgent)
    (howner : ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ goods ∧ owner g = i)
    (hL : 0 < L)
    (hgoods_load :
      Theorem34.commonLoad v goods = (Fintype.card SourceAgent : ℝ) * L)
    (hgoods_pos : ∀ g : SourceItem, g ∈ goods → 0 < v g)
    (hgoods_lt : ∀ g : SourceItem, g ∈ goods → v g < L) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ B i) ∧
          (∀ C : Allocation SourceAgent SourceItem,
            IsAllocationOf C goods →
              (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
                Theorem34.loadRatio (Theorem34.minCommonLoad v B)
                    (Theorem34.maxCommonLoad v B) ≤
                  Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                    (Theorem34.maxCommonLoad v C)) ∧
            ∀ i : SourceAgent,
              Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (B i)) := by
  classical
  rcases
      paper_lmms_exists_nonempty_exact_allocation_of_surjective_owner
        goods owner howner with
    ⟨A, hA_alloc, hA_nonempty⟩
  exact
    paper_lmms_claim_3_4_exists_bounded_optimal_on_exact_nonempty_positive_goods
      (goods := goods) (v := v) (L := L)
      hL hgoods_load hgoods_pos hgoods_lt
      ⟨A, hA_alloc, hA_nonempty⟩

/--
Claim 3.4 source-domain selector for the whole finite good set: exact total
load, positive values, and strict smallness supply a surjective owner map, so
finite search over exact nonempty allocations returns a bounded exact nonempty
optimum.
-/
theorem paper_lmms_claim_3_4_exists_bounded_optimal_of_total_strictly_small_positive_goods
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Fintype SourceItem] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {v : SourceItem → ℝ} {L : ℝ}
    (hL : 0 < L)
    (hgoods_pos : ∀ g : SourceItem, 0 < v g)
    (hgoods_lt : ∀ g : SourceItem, v g < L)
    (htotal :
      (∑ g : SourceItem, v g) = (Fintype.card SourceAgent : ℝ) * L) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B (Finset.univ : Finset SourceItem) ∧
        (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ B i) ∧
          (∀ C : Allocation SourceAgent SourceItem,
            IsAllocationOf C (Finset.univ : Finset SourceItem) →
              (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
                Theorem34.loadRatio (Theorem34.minCommonLoad v B)
                    (Theorem34.maxCommonLoad v B) ≤
                  Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                    (Theorem34.maxCommonLoad v C)) ∧
            ∀ i : SourceAgent,
              Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (B i)) := by
  classical
  rcases
      paper_lmms_exists_surjective_owner_of_total_strictly_small_positive_values
        (SourceAgent := SourceAgent) (SourceItem := SourceItem)
        (v := v) (L := L) hL hgoods_pos hgoods_lt htotal with
    ⟨owner, howner⟩
  have howner_univ :
      ∀ i : SourceAgent,
        ∃ g : SourceItem,
          g ∈ (Finset.univ : Finset SourceItem) ∧ owner g = i := by
    intro i
    rcases howner i with ⟨g, hg⟩
    exact ⟨g, Finset.mem_univ g, hg⟩
  have hgoods_load :
      Theorem34.commonLoad v (Finset.univ : Finset SourceItem) =
        (Fintype.card SourceAgent : ℝ) * L := by
    simpa [Theorem34.commonLoad] using htotal
  exact
    paper_lmms_claim_3_4_exists_bounded_optimal_of_surjective_owner
      (goods := (Finset.univ : Finset SourceItem)) (v := v) (L := L)
      owner howner_univ hL hgoods_load
      (by intro g _hg; exact hgoods_pos g)
      (by intro g _hg; exact hgoods_lt g)

/--
Claim 3.4 source-domain wrapper over exact allocations: if the starting
allocation is optimal among all exact allocations and is in the nonempty
positive-good domain, then the nonempty-positive finite-descent wrapper returns
a bounded exact allocation that is still optimal among all exact allocations.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_on_exact_allocations_from_nonempty_positive_goods_branching_potentials
    {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Fintype SourceItem] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {goods : Finset SourceItem} {v : SourceItem → ℝ} {L : ℝ}
    (A₀ : Allocation SourceAgent SourceItem)
    (hA₀_alloc : IsAllocationOf A₀ goods)
    (hA₀_nonempty : ∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A₀ i)
    (hgoods_pos : ∀ g : SourceItem, g ∈ goods → 0 < v g)
    (hA₀_opt_exact :
      ∀ C : Allocation SourceAgent SourceItem,
        IsAllocationOf C goods →
          Theorem34.loadRatio (Theorem34.minCommonLoad v A₀)
              (Theorem34.maxCommonLoad v A₀) ≤
            Theorem34.loadRatio (Theorem34.minCommonLoad v C)
              (Theorem34.maxCommonLoad v C))
    (hstep :
      ∀ A : Allocation SourceAgent SourceItem,
        IsAllocationOf A goods →
          (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ A i) →
            (∀ C : Allocation SourceAgent SourceItem,
              IsAllocationOf C goods →
                (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ C i) →
                  Theorem34.loadRatio (Theorem34.minCommonLoad v A)
                      (Theorem34.maxCommonLoad v A) ≤
                    Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                      (Theorem34.maxCommonLoad v C)) →
              (¬ ∀ i : SourceAgent,
                Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (A i))) →
                ∃ B : Allocation SourceAgent SourceItem,
                  IsAllocationOf B goods ∧
                    (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ B i) ∧
                      Theorem34.loadRatio (Theorem34.minCommonLoad v B)
                          (Theorem34.maxCommonLoad v B) ≤
                        Theorem34.loadRatio (Theorem34.minCommonLoad v A)
                          (Theorem34.maxCommonLoad v A) ∧
                        (Theorem34.overfullBundleCardPotential v L B <
                            Theorem34.overfullBundleCardPotential v L A ∨
                          (Theorem34.overfullBundleCardPotential v L B =
                              Theorem34.overfullBundleCardPotential v L A ∧
                            Theorem34.minLoadTiePotential v
                              (fun A : Allocation SourceAgent SourceItem => A)
                              (fun A => Theorem34.minCommonLoad v A) B <
                            Theorem34.minLoadTiePotential v
                              (fun A : Allocation SourceAgent SourceItem => A)
                              (fun A => Theorem34.minCommonLoad v A) A))) :
    ∃ B : Allocation SourceAgent SourceItem,
      IsAllocationOf B goods ∧
        (∀ i : SourceAgent, ∃ g : SourceItem, g ∈ B i) ∧
          (∀ C : Allocation SourceAgent SourceItem,
            IsAllocationOf C goods →
              Theorem34.loadRatio (Theorem34.minCommonLoad v B)
                  (Theorem34.maxCommonLoad v B) ≤
                Theorem34.loadRatio (Theorem34.minCommonLoad v C)
                  (Theorem34.maxCommonLoad v C)) ∧
            ∀ i : SourceAgent,
              Theorem34.boundedAroundAverage L (Theorem34.commonLoad v (B i)) := by
  classical
  rcases
      paper_lmms_claim_3_4_bounded_optimal_on_exact_nonempty_positive_goods_branching_potentials
        (goods := goods) (v := v) (L := L)
        A₀ hA₀_alloc hA₀_nonempty hgoods_pos
        (by
          intro C hC_alloc _hC_nonempty
          exact hA₀_opt_exact C hC_alloc)
        hstep with
    ⟨B, hB_alloc, hB_nonempty, hB_opt_nonempty, hB_bounded⟩
  have hB_le_A₀ :
      Theorem34.loadRatio (Theorem34.minCommonLoad v B)
          (Theorem34.maxCommonLoad v B) ≤
        Theorem34.loadRatio (Theorem34.minCommonLoad v A₀)
          (Theorem34.maxCommonLoad v A₀) :=
    hB_opt_nonempty A₀ hA₀_alloc hA₀_nonempty
  exact
    ⟨B, hB_alloc, hB_nonempty,
      (by
        intro C hC_alloc
        exact le_trans hB_le_A₀ (hA₀_opt_exact C hC_alloc)),
      hB_bounded⟩

