  have hbridge :=
    paper_lmms_theorem_3_3_exists_value_pair_type_assignment_with_cap_of_combined_high_low_rounded_supply_average_no_top_of_margin
      (L := L) (LR := LR) (lambda := lambda) (maxCount := maxCount)
      (SourceAgent := SourceAgent)
