/--
If two totals are normalized by the same nonempty agent count, an inequality
between the totals gives the same inequality between their average loads.
-/
theorem paper_lmms_theorem_3_3_average_le_of_scaled_totals
    {SourceAgent : Type*} [Fintype SourceAgent] [Nonempty SourceAgent]
    {L LR sourceTotal roundedTotal : ℝ}
    (hsource : sourceTotal = (Fintype.card SourceAgent : ℝ) * L)
    (hrounded : roundedTotal = (Fintype.card SourceAgent : ℝ) * LR)
    (hle : sourceTotal ≤ roundedTotal) :
    L ≤ LR := by
  have hcard_nat_pos : 0 < Fintype.card SourceAgent := Fintype.card_pos
  have hcard_pos : 0 < (Fintype.card SourceAgent : ℝ) := by
    exact_mod_cast hcard_nat_pos
  have hmul :
      (Fintype.card SourceAgent : ℝ) * L ≤
        (Fintype.card SourceAgent : ℝ) * LR := by
    calc
      (Fintype.card SourceAgent : ℝ) * L = sourceTotal := hsource.symm
      _ ≤ roundedTotal := hle
      _ = (Fintype.card SourceAgent : ℝ) * LR := hrounded
  exact le_of_mul_le_mul_left hmul hcard_pos

/-- A concrete count cap large enough to cover `2 * capAverage`. -/
noncomputable def paper_lmms_theorem_3_3_capCountForAverage
    (L capAverage : ℝ) (lambda : ℕ) : ℕ :=
  Nat.ceil (2 * capAverage / (L / (lambda : ℝ)))

/--
The concrete cap count covers the target average window whenever the value
unit `L / lambda` is positive.
-/
theorem paper_lmms_theorem_3_3_capCountForAverage_satisfies
    {L capAverage : ℝ} {lambda : ℕ}
    (hlambda : 0 < lambda) (hL : 0 < L) :
    2 * capAverage ≤
      (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda + 1 : ℝ) *
        (L / (lambda : ℝ)) := by
  let unit : ℝ := L / (lambda : ℝ)
  have hlambda_real_pos : 0 < (lambda : ℝ) := by
    exact_mod_cast hlambda
  have hunit_pos : 0 < unit := by
    dsimp [unit]
    exact div_pos hL hlambda_real_pos
  have hceil :
      2 * capAverage / unit ≤
        (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda : ℝ) := by
    simpa [paper_lmms_theorem_3_3_capCountForAverage, unit] using
      Nat.le_ceil (2 * capAverage / unit)
  have hmul :
      (2 * capAverage / unit) * unit ≤
        (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda : ℝ) *
          unit :=
    mul_le_mul_of_nonneg_right hceil hunit_pos.le
  have hsucc :
      (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda : ℝ) *
          unit ≤
        (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda + 1 : ℝ) *
          unit := by
    have hnat :
        (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda : ℝ) ≤
          (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda + 1 :
            ℝ) := by
      exact_mod_cast
        Nat.le_succ (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda)
    exact mul_le_mul_of_nonneg_right hnat hunit_pos.le
  have hunit_ne : unit ≠ 0 := ne_of_gt hunit_pos
  calc
    2 * capAverage = (2 * capAverage / unit) * unit := by
      field_simp [hunit_ne]
    _ ≤
        (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda : ℝ) *
          unit := hmul
    _ ≤
        (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda + 1 : ℝ) *
          unit := hsucc
    _ =
        (paper_lmms_theorem_3_3_capCountForAverage L capAverage lambda + 1 : ℝ) *
          (L / (lambda : ℝ)) := rfl

/--
The source auto-cap count also covers the base source average `L`.  This is
the cap used when a source-min/max witness is later consumed by the same
auto-cap search surface as the generated rounded instances.
-/
theorem paper_lmms_theorem_3_3_source_auto_cap_count_satisfies_base_average
    {SourceAgent : Type*} [Fintype SourceAgent] [Nonempty SourceAgent]
    {L : ℝ} {lambda : ℕ}
    (hlambda : 0 < lambda) (hL : 0 < L) :
    let extraAverage : ℝ :=
      (((Fintype.card SourceAgent : ℝ) + 1) * (L / (lambda : ℝ))) /
        (Fintype.card SourceAgent : ℝ)
    2 * L ≤
      (paper_lmms_theorem_3_3_capCountForAverage
          L (L + extraAverage) lambda + 1 : ℝ) *
        (L / (lambda : ℝ)) := by
  classical
  dsimp
  let extraAverage : ℝ :=
    (((Fintype.card SourceAgent : ℝ) + 1) * (L / (lambda : ℝ))) /
      (Fintype.card SourceAgent : ℝ)
  have hcard_nat_pos : 0 < Fintype.card SourceAgent := Fintype.card_pos
  have hcard_pos : 0 < (Fintype.card SourceAgent : ℝ) := by
    exact_mod_cast hcard_nat_pos
  have hlambda_real_pos : 0 < (lambda : ℝ) := by
    exact_mod_cast hlambda
  have hextra_nonneg : 0 ≤ extraAverage := by
    dsimp [extraAverage]
    positivity
  have hL_le_capAverage : L ≤ L + extraAverage := by
    linarith
  have hcap_upper :
      2 * (L + extraAverage) ≤
        (paper_lmms_theorem_3_3_capCountForAverage
            L (L + extraAverage) lambda + 1 : ℝ) *
          (L / (lambda : ℝ)) :=
    paper_lmms_theorem_3_3_capCountForAverage_satisfies
      (L := L) (capAverage := L + extraAverage) (lambda := lambda)
      hlambda hL
  calc
    2 * L ≤ 2 * (L + extraAverage) := by
      exact mul_le_mul_of_nonneg_left hL_le_capAverage (by norm_num)
    _ ≤
        (paper_lmms_theorem_3_3_capCountForAverage
            L (L + extraAverage) lambda + 1 : ℝ) *
          (L / (lambda : ℝ)) := hcap_upper

