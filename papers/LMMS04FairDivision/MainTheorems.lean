  have herror_budget :
      (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
          L / (lambda : ℝ) ≤
        (Fintype.card SourceAgent : ℝ) *
          ((((Fintype.card SourceAgent : ℝ) + 1) *
              (L / (lambda : ℝ))) /
            (Fintype.card SourceAgent : ℝ)) := by
    calc
      (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
          L / (lambda : ℝ)
          ≤
            ((Fintype.card SourceAgent : ℝ) + 1) *
              (L / (lambda : ℝ)) := hbudget_scalar
      _ =
          (Fintype.card SourceAgent : ℝ) *
            ((((Fintype.card SourceAgent : ℝ) + 1) *
                (L / (lambda : ℝ))) /
              (Fintype.card SourceAgent : ℝ)) := by
            field_simp [ne_of_gt hcard_pos]
  exact
