/--
The generated combined high/low rounded supply has rounded total at most the
source average plus the auto-cap slack derived from the source high/low split.
-/
theorem paper_lmms_theorem_3_3_exists_combined_high_low_rounded_goods_supply_source_auto_cap_upper_no_top_of_margin
    {L : ℝ} {lambda : ℕ} {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent] [DecidableEq SourceItem]
    (highGoods lowGoods : Finset SourceItem) (v : SourceItem → ℝ)
    (hlambda : 1 < lambda) (hL : 0 < L)
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g ∧ v g < L)
    (hlow :
      ∀ g : SourceItem, g ∈ lowGoods →
        0 ≤ v g ∧ v g < L / (lambda : ℝ))
    (hmargin :
      ∀ g : SourceItem, g ∈ highGoods →
        v g + L / ((lambda : ℝ) ^ 2) ≤ L)
    (hsource_average :
      highGoods.sum v + lowGoods.sum v =
        (Fintype.card SourceAgent : ℝ) * L) :
    ∃ indexOf : SourceItem → Theorem33.RoundedValueIndex lambda,
      ∃ combinedSupply : Theorem33.RoundedValueIndex lambda → ℕ,
        (∀ g : SourceItem, g ∈ highGoods →
          v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
            Theorem33.roundedValue L lambda (indexOf g) <
              v g + L / ((lambda : ℝ) ^ 2)) ∧
          (∀ k : Theorem33.RoundedValueIndex lambda,
            combinedSupply k =
              paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf highGoods k +
                Theorem33.lowGoodsAggregatedSupply L lambda (lowGoods.sum v) k) ∧
            combinedSupply (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) = 0 ∧
              highGoods.sum v + lowGoods.sum v ≤
                ∑ k : Theorem33.RoundedValueIndex lambda,
                  (combinedSupply k : ℝ) *
                    Theorem33.roundedValue L lambda k ∧
                (∑ k : Theorem33.RoundedValueIndex lambda,
                  (combinedSupply k : ℝ) *
                    Theorem33.roundedValue L lambda k) ≤
                  (Fintype.card SourceAgent : ℝ) *
                    (L +
                      ((((Fintype.card SourceAgent : ℝ) + 1) *
                          (L / (lambda : ℝ))) /
                        (Fintype.card SourceAgent : ℝ))) := by
  classical
  rcases
      paper_lmms_theorem_3_3_exists_combined_high_low_rounded_goods_supply_no_top_of_margin
        highGoods lowGoods v hlambda hL hhigh hlow hmargin with
    ⟨indexOf, combinedSupply, hindex, hsupply, htop_zero, hlower, hupper⟩
  have hcard_nat_pos : 0 < Fintype.card SourceAgent :=
    Fintype.card_pos
  have hcard_pos : 0 < (Fintype.card SourceAgent : ℝ) := by
    exact_mod_cast hcard_nat_pos
  have hbudget_scalar :
      (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
          L / (lambda : ℝ) ≤
        ((Fintype.card SourceAgent : ℝ) + 1) *
          (L / (lambda : ℝ)) :=
    paper_lmms_theorem_3_3_rounding_error_budget_le_source_slack
      (SourceAgent := SourceAgent)
      highGoods lowGoods v (Nat.zero_lt_of_lt hlambda) hL
      (fun g hg => (hhigh g hg).1)
      (fun g hg => (hlow g hg).1)
      hsource_average
  have herror_budget :
      (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
          L / (lambda : ℝ) ≤
        (Fintype.card SourceAgent : ℝ) *
