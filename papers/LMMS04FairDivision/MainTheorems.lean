          (fun t => search.chosenIP.typeMultiplicity t * t.count k) =
            supply k := by
  rcases
      paper_lmms_theorem_3_3_value_pair_search_certificate_with_cap_full_summary_of_count_bound
        hmaxCount search with
    ⟨hpair_card, hchosen_mem, hwindow_card, hzero, hplayers, hgoods⟩
  exact
    ⟨paper_lmms_theorem_3_3_rounded_instance_search_certificate_ratio_guarantee
        hepsilon_pos hepsilon_le_one cert,
      hpair_card, hchosen_mem, hwindow_card, hzero, hplayers, hgoods⟩

/--
Theorem 3.3 capped bundled search seam: a rounded-instance search certificate
gives the final ratio guarantee, while a capped finite value-pair search
certificate gives the two-scale comparison and full explicit capped-IP
constraints for both the comparison IP and the chosen search IP.
-/
theorem paper_lmms_theorem_3_3_rounded_instance_search_certificate_ratio_guarantee_and_capped_full_ip_summary
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {M : Theorem33.IdenticalUtilitiesModel SourceAgent SourceItem Alloc}
    {L LR epsilon : ℝ} {lambda maxCount : ℕ} {optimal : Alloc}
    (hepsilon_pos : 0 < epsilon) (hepsilon_le_one : epsilon ≤ 1)
    (cert : Theorem33.RoundedInstanceSearchCertificate M L epsilon lambda optimal)
    {supply : Theorem33.RoundedValueIndex lambda → ℕ}
    (hmaxCount : maxCount ≤ 2 * lambda + 4)
    (search :
      Theorem33.RoundedValuePairSearchCertificateWithCap
        L LR lambda maxCount SourceAgent supply)
    {p : ℝ × ℝ}
    (ip :
      Theorem33.RoundedConcreteIPCertificateWithCap
        L LR lambda maxCount SourceAgent p supply) :
    Theorem33.allocationLoadRatio M cert.output ≤
        Theorem33.allocationLoadRatio M optimal * (1 + epsilon) ∧
      Theorem33.roundedValuePairRatio search.chosenPair ≤
        Theorem33.roundedValuePairRatio p ∧
      p ∈ Theorem33.roundedAdmissibleValuePairSetWithCap
          L LR lambda maxCount ∧
        (Theorem33.roundedTypesInValueWindowWithCap
            L LR lambda maxCount p.1 p.2).card ≤
          (2 * lambda + 5) ^
            Fintype.card (Theorem33.RoundedValueIndex lambda) ∧
          (∀ t : Theorem33.RoundedBundleType lambda,
            t ∉
              Theorem33.roundedTypesInValueWindowWithCap
                L LR lambda maxCount p.1 p.2 →
            ip.typeMultiplicity t = 0) ∧
            (Theorem33.roundedTypesInValueWindowWithCap
                L LR lambda maxCount p.1 p.2).sum
              ip.typeMultiplicity =
                Fintype.card SourceAgent ∧
              (∀ k : Theorem33.RoundedValueIndex lambda,
                (Theorem33.roundedTypesInValueWindowWithCap
                    L LR lambda maxCount p.1 p.2).sum
                  (fun t => ip.typeMultiplicity t * t.count k) =
                    supply k) ∧
                (Theorem33.roundedAdmissibleValuePairSetWithCap
                    L LR lambda maxCount).card ≤
                  ((2 * lambda + 5) ^
                    Fintype.card
                      (Theorem33.RoundedValueIndex lambda)) ^ 2 ∧
                  search.chosenPair ∈
                    Theorem33.roundedAdmissibleValuePairSetWithCap
                      L LR lambda maxCount ∧
                    (Theorem33.roundedTypesInValueWindowWithCap
                        L LR lambda maxCount search.chosenPair.1
                          search.chosenPair.2).card ≤
                      (2 * lambda + 5) ^
                        Fintype.card
                          (Theorem33.RoundedValueIndex lambda) ∧
                      (∀ t : Theorem33.RoundedBundleType lambda,
                        t ∉
                          Theorem33.roundedTypesInValueWindowWithCap
                            L LR lambda maxCount search.chosenPair.1
                              search.chosenPair.2 →
                        search.chosenIP.typeMultiplicity t = 0) ∧
                        (Theorem33.roundedTypesInValueWindowWithCap
                            L LR lambda maxCount search.chosenPair.1
                              search.chosenPair.2).sum
                          search.chosenIP.typeMultiplicity =
                            Fintype.card SourceAgent ∧
                          ∀ k : Theorem33.RoundedValueIndex lambda,
                            (Theorem33.roundedTypesInValueWindowWithCap
                                L LR lambda maxCount search.chosenPair.1
                                  search.chosenPair.2).sum
                              (fun t =>
                                search.chosenIP.typeMultiplicity t *
                                  t.count k) =
                              supply k := by
  rcases
      paper_lmms_theorem_3_3_value_pair_search_with_cap_ratio_and_explicit_full_ip_summaries_of_count_bound
        hmaxCount search ip with
    ⟨hratio, hpair, hp_window_card, hp_zero, hp_players, hp_goods,
      hsearch_pair_card, hchosen_mem, hchosen_window_card, hchosen_zero,
      hchosen_players, hchosen_goods⟩
  exact
    ⟨paper_lmms_theorem_3_3_rounded_instance_search_certificate_ratio_guarantee
        hepsilon_pos hepsilon_le_one cert,
      hratio, hpair, hp_window_card, hp_zero, hp_players, hp_goods,
      hsearch_pair_card, hchosen_mem, hchosen_window_card, hchosen_zero,
      hchosen_players, hchosen_goods⟩

/-! ## 6) Claim 3.4 bounded-optimal support -/

/--
Claim 3.4 certificate: if a ratio-nonincreasing reallocation from an optimal
allocation reaches the paper's load window `L / 2 < load < 2L`, the resulting
allocation is itself an optimal allocation satisfying that window.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_certificate
    {SourceAgent SourceItem Alloc : Type*} {v : SourceItem → ℝ} {L : ℝ}
    {ratioOf : Alloc → ℝ}
    {bundleOf : Alloc → SourceAgent → Finset SourceItem}
    {A B : Alloc}
    (hA : Theorem34.IsOptimalRatio ratioOf A)
    (hBA : ratioOf B ≤ ratioOf A)
    (hbounded :
      ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem34.commonLoad v (bundleOf B i))) :
    Theorem34.Claim34Certificate v L ratioOf bundleOf B := by
  exact
    Theorem34.claim34_certificate_of_nonincreasing_bounded_reallocation
      hA hBA hbounded

/--
Claim 3.4 certificate projection summary: unpack a paper-shaped Claim 3.4
certificate into optimality, the per-agent load window, and the induced
min/max load windows.
-/
theorem paper_lmms_claim_3_4_certificate_projection_summary
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {v : SourceItem → ℝ} {L : ℝ} {ratioOf : Alloc → ℝ}
    {bundleOf : Alloc → SourceAgent → Finset SourceItem} {A : Alloc}
    (cert : Theorem34.Claim34Certificate v L ratioOf bundleOf A) :
    Theorem34.IsOptimalRatio ratioOf A ∧
      (∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem34.commonLoad v (bundleOf A i))) ∧
      Theorem34.boundedAroundAverage L
        (Theorem34.minCommonLoad v (bundleOf A)) ∧
      Theorem34.boundedAroundAverage L
        (Theorem34.maxCommonLoad v (bundleOf A)) := by
  rcases cert with ⟨hopt, hwindow⟩
  have hmin_window :
      Theorem34.boundedAroundAverage L
        (Theorem34.minCommonLoad v (bundleOf A)) := by
    rcases
        Theorem34.exists_commonLoad_eq_minCommonLoad
          (v := v) (bundle := bundleOf A) with
      ⟨i, hi⟩
    simpa [← hi] using hwindow i
  have hmax_window :
      Theorem34.boundedAroundAverage L
        (Theorem34.maxCommonLoad v (bundleOf A)) := by
    rcases
        Theorem34.exists_commonLoad_eq_maxCommonLoad
          (v := v) (bundle := bundleOf A) with
      ⟨i, hi⟩
    simpa [← hi] using hwindow i
  exact ⟨hopt, hwindow, hmin_window, hmax_window⟩

/--
Claim 3.4 certificate explicit-bounds summary: unpack a Claim 3.4 certificate
into optimality and the explicit lower/upper load-window inequalities for
every agent, the minimum load, and the maximum load.
-/
theorem paper_lmms_claim_3_4_certificate_explicit_bounds_summary
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Nonempty SourceAgent]
    {v : SourceItem → ℝ} {L : ℝ} {ratioOf : Alloc → ℝ}
    {bundleOf : Alloc → SourceAgent → Finset SourceItem} {A : Alloc}
    (cert : Theorem34.Claim34Certificate v L ratioOf bundleOf A) :
    Theorem34.IsOptimalRatio ratioOf A ∧
      (∀ i : SourceAgent,
        L / 2 < Theorem34.commonLoad v (bundleOf A i)) ∧
      (∀ i : SourceAgent,
        Theorem34.commonLoad v (bundleOf A i) < 2 * L) ∧
      L / 2 < Theorem34.minCommonLoad v (bundleOf A) ∧
      Theorem34.minCommonLoad v (bundleOf A) < 2 * L ∧
      L / 2 < Theorem34.maxCommonLoad v (bundleOf A) ∧
      Theorem34.maxCommonLoad v (bundleOf A) < 2 * L := by
  rcases paper_lmms_claim_3_4_certificate_projection_summary cert with
    ⟨hopt, hwindow, hmin_window, hmax_window⟩
  exact
    ⟨hopt, (fun i => (hwindow i).1), (fun i => (hwindow i).2),
      hmin_window.1, hmin_window.2, hmax_window.1, hmax_window.2⟩

/--
Claim 3.4 finite-descent assembly: a ratio-nonincreasing local improvement
that strictly decreases a natural-number potential at every unbounded optimal
allocation yields a bounded optimal allocation.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_of_finite_descent
    {SourceAgent SourceItem Alloc : Type*} {v : SourceItem → ℝ} {L : ℝ}
    {ratioOf : Alloc → ℝ}
    {bundleOf : Alloc → SourceAgent → Finset SourceItem}
    (potential : Alloc → ℕ) (A₀ : Alloc)
    (hA₀ : Theorem34.IsOptimalRatio ratioOf A₀)
    (hstep :
      ∀ A : Alloc,
        Theorem34.IsOptimalRatio ratioOf A →
          (¬ ∀ i : SourceAgent,
            Theorem34.boundedAroundAverage L
              (Theorem34.commonLoad v (bundleOf A i))) →
            ∃ B : Alloc, ratioOf B ≤ ratioOf A ∧ potential B < potential A) :
    ∃ B : Alloc, Theorem34.Claim34Certificate v L ratioOf bundleOf B := by
  exact
    Theorem34.claim34_certificate_of_finite_descent
      potential A₀ hA₀ hstep

/--
Claim 3.4 branching finite-descent assembly: high-source moves decrease the
overfull-bundle potential, while the complementary low-only moves keep that
primary potential fixed and decrease the finite min-load tie-breaker.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_of_branching_potential_descent
    {SourceAgent SourceItem Alloc : Type*} [Fintype SourceAgent]
    [Fintype Alloc]
    {v : SourceItem → ℝ} {L : ℝ}
    {ratioOf : Alloc → ℝ}
    {bundleOf : Alloc → SourceAgent → Finset SourceItem}
    (minOf : Alloc → ℝ) (A₀ : Alloc)
    (hA₀ : Theorem34.IsOptimalRatio ratioOf A₀)
    (hstep :
      ∀ A : Alloc,
        Theorem34.IsOptimalRatio ratioOf A →
          (¬ ∀ i : SourceAgent,
            Theorem34.boundedAroundAverage L
              (Theorem34.commonLoad v (bundleOf A i))) →
            ∃ B : Alloc,
              ratioOf B ≤ ratioOf A ∧
                (Theorem34.overfullBundleCardPotential v L (bundleOf B) <
                    Theorem34.overfullBundleCardPotential v L (bundleOf A) ∨
                  (Theorem34.overfullBundleCardPotential v L (bundleOf B) =
                      Theorem34.overfullBundleCardPotential v L (bundleOf A) ∧
                    Theorem34.minLoadTiePotential v bundleOf minOf B <
                      Theorem34.minLoadTiePotential v bundleOf minOf A))) :
    ∃ B : Alloc, Theorem34.Claim34Certificate v L ratioOf bundleOf B := by
  exact
    Theorem34.claim34_certificate_of_branching_potential_descent
      minOf A₀ hA₀ hstep

/--
Claim 3.4 one-step support: a source reallocation that keeps every moved load
inside the old min/max interval cannot increase the max-over-min load ratio.
-/
theorem paper_lmms_claim_3_4_load_ratio_nonincreasing_of_move
    {SourceAgent : Type*} [DecidableEq SourceAgent]
    {load : SourceAgent → ℝ} {source target : SourceAgent}
    {x oldMin oldMax newMin newMax : ℝ}
    (holdMin_pos : 0 < oldMin)
    (holdMax_nonneg : 0 ≤ oldMax)
    (hwithin : ∀ i : SourceAgent, oldMin ≤ load i ∧ load i ≤ oldMax)
    (hx_nonneg : 0 ≤ x)
    (hsource : oldMin ≤ load source - x)
    (htarget : load target + x ≤ oldMax)
    (hnewMin_lower :
      ∀ i : SourceAgent, newMin ≤
        Theorem34.moveLoad load source target x i)
    (hnewMin_attains :
      ∃ i : SourceAgent, Theorem34.moveLoad load source target x i = newMin)
    (hnewMax_upper :
      ∀ i : SourceAgent,
        Theorem34.moveLoad load source target x i ≤ newMax)
    (hnewMax_attains :
      ∃ i : SourceAgent, Theorem34.moveLoad load source target x i = newMax) :
    Theorem34.loadRatio newMin newMax ≤
      Theorem34.loadRatio oldMin oldMax := by
  exact
    Theorem34.loadRatio_nonincreasing_of_moveLoad_certificate
      holdMin_pos holdMax_nonneg hwithin hx_nonneg hsource htarget
      hnewMin_lower hnewMin_attains hnewMax_upper hnewMax_attains

/--
Claim 3.4 local reallocation step: moving a fresh good of value in `[0,L)`
from a bundle above `2L` to a bundle below `L / 2` is ratio-nonincreasing
and strictly decreases the donor-cardinality potential, once the moved
allocation's extrema are certified.
-/
theorem paper_lmms_claim_3_4_local_reallocation_certificate_of_low_target_high_source
    {SourceAgent SourceItem : Type*} [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {bundle : SourceAgent → Finset SourceItem} {v : SourceItem → ℝ}
    {source target : SourceAgent} {g : SourceItem}
    {oldMin oldMax newMin newMax L : ℝ}
    (hsource_ne_target : source ≠ target)
    (hg_source : g ∈ bundle source)
    (hg_target : g ∉ bundle target)
    (hL : 0 < L)
    (holdMin_pos : 0 < oldMin)
    (holdMax_nonneg : 0 ≤ oldMax)
    (hwithin :
      ∀ i : SourceAgent, oldMin ≤ Theorem34.commonLoad v (bundle i) ∧
        Theorem34.commonLoad v (bundle i) ≤ oldMax)
    (htarget_low : Theorem34.commonLoad v (bundle target) < L / 2)
    (hsource_high : 2 * L < Theorem34.commonLoad v (bundle source))
    (hg_nonneg : 0 ≤ v g)
    (hg_lt : v g < L)
    (hnewMin_lower :
      ∀ i : SourceAgent, newMin ≤
        Theorem34.commonLoad v (Theorem34.moveBundle bundle source target g i))
    (hnewMin_attains :
      ∃ i : SourceAgent,
        Theorem34.commonLoad v (Theorem34.moveBundle bundle source target g i) = newMin)
    (hnewMax_upper :
      ∀ i : SourceAgent,
        Theorem34.commonLoad v (Theorem34.moveBundle bundle source target g i) ≤ newMax)
    (hnewMax_attains :
      ∃ i : SourceAgent,
        Theorem34.commonLoad v (Theorem34.moveBundle bundle source target g i) = newMax) :
    Theorem34.loadRatio newMin newMax ≤ Theorem34.loadRatio oldMin oldMax ∧
      Theorem34.donorCardPotential (Theorem34.moveBundle bundle source target g) source <
        Theorem34.donorCardPotential bundle source := by
  exact
    Theorem34.local_reallocation_certificate_of_low_target_high_source
      hsource_ne_target hg_source hg_target hL holdMin_pos holdMax_nonneg
      hwithin htarget_low hsource_high hg_nonneg hg_lt
      hnewMin_lower hnewMin_attains hnewMax_upper hnewMax_attains

/--
Claim 3.4 local-reallocation finite-descent assembly: if every optimal
allocation outside the paper load window supplies the source high-bundle move
into a bundle of load at most `L`, then there exists an optimal allocation
whose every bundle load lies between `L / 2` and `2L`.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_of_local_reallocation_descent
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {v : SourceItem → ℝ} {L : ℝ} {ratioOf : Alloc → ℝ}
    {bundleOf : Alloc → SourceAgent → Finset SourceItem}
    (moveAlloc : Alloc → SourceAgent → SourceAgent → SourceItem → Alloc)
    (A₀ : Alloc) (hA₀ : Theorem34.IsOptimalRatio ratioOf A₀)
    (hL : 0 < L)
    (hlocal :
      ∀ A : Alloc,
        Theorem34.IsOptimalRatio ratioOf A →
          (¬ ∀ i : SourceAgent,
            Theorem34.boundedAroundAverage L
              (Theorem34.commonLoad v (bundleOf A i))) →
            ∃ source target : SourceAgent,
            ∃ g : SourceItem,
            ∃ oldMin oldMax newMin newMax : ℝ,
              source ≠ target ∧
              g ∈ bundleOf A source ∧
              g ∉ bundleOf A target ∧
              0 < oldMin ∧
              0 ≤ oldMax ∧
              (∀ i : SourceAgent,
                oldMin ≤ Theorem34.commonLoad v (bundleOf A i) ∧
                  Theorem34.commonLoad v (bundleOf A i) ≤ oldMax) ∧
              Theorem34.commonLoad v (bundleOf A target) ≤ L ∧
              2 * L < Theorem34.commonLoad v (bundleOf A source) ∧
              0 ≤ v g ∧
              v g < L ∧
              (∀ i : SourceAgent,
                newMin ≤
                  Theorem34.commonLoad v
                    (Theorem34.moveBundle (bundleOf A) source target g i)) ∧
              (∃ i : SourceAgent,
                Theorem34.commonLoad v
                  (Theorem34.moveBundle (bundleOf A) source target g i) = newMin) ∧
              (∀ i : SourceAgent,
                Theorem34.commonLoad v
                  (Theorem34.moveBundle (bundleOf A) source target g i) ≤ newMax) ∧
              (∃ i : SourceAgent,
                Theorem34.commonLoad v
                  (Theorem34.moveBundle (bundleOf A) source target g i) = newMax) ∧
              ratioOf (moveAlloc A source target g) =
                Theorem34.loadRatio newMin newMax ∧
              ratioOf A = Theorem34.loadRatio oldMin oldMax ∧
              bundleOf (moveAlloc A source target g) =
                Theorem34.moveBundle (bundleOf A) source target g) :
    ∃ B : Alloc, Theorem34.Claim34Certificate v L ratioOf bundleOf B := by
  exact
    Theorem34.claim34_certificate_of_high_source_reallocation_descent
      (v := v) (L := L) (ratioOf := ratioOf) (bundleOf := bundleOf)
      moveAlloc A₀ hA₀ hL hlocal

/--
Claim 3.4 source branch-step trichotomy: the min/max source move constructors
discharge the strict high-source, low-only, and strict upper-boundary cases,
so every unbounded min/max source state supplies the branch step required by
the finite lexicographic descent endpoint.
-/
theorem paper_lmms_claim_3_4_branch_step_of_minmax_source_trichotomy
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Fintype Alloc] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {bundleOf : Alloc → SourceAgent → Finset SourceItem}
    {v : SourceItem → ℝ} {L : ℝ} {ratioOf : Alloc → ℝ}
    {minOf maxOf : Alloc → ℝ}
    (moveAlloc : Alloc → SourceAgent → SourceAgent → SourceItem → Alloc)
    {A : Alloc} {minLoad maxLoad : ℝ}
    (hL : 0 < L)
    (havg :
      (∑ i : SourceAgent, Theorem34.commonLoad v (bundleOf A i)) =
        (Fintype.card SourceAgent : ℝ) * L)
    (hmin_lower :
      ∀ C : Alloc, ∀ i : SourceAgent,
        minOf C ≤ Theorem34.commonLoad v (bundleOf C i))
    (hmin_attains :
      ∀ C : Alloc, ∃ i : SourceAgent,
        Theorem34.commonLoad v (bundleOf C i) = minOf C)
    (hmax_upper :
      ∀ C : Alloc, ∀ i : SourceAgent,
        Theorem34.commonLoad v (bundleOf C i) ≤ maxOf C)
    (hmax_attains :
      ∀ C : Alloc, ∃ i : SourceAgent,
        Theorem34.commonLoad v (bundleOf C i) = maxOf C)
    (hminA : minOf A = minLoad)
    (hmaxA : maxOf A = maxLoad)
    (hmin_pos : 0 < minLoad)
    (hnot_bounded :
      ¬ ∀ i : SourceAgent,
        Theorem34.boundedAroundAverage L
          (Theorem34.commonLoad v (bundleOf A i)))
    (hitem_nonneg :
      ∀ i : SourceAgent, ∀ g : SourceItem, g ∈ bundleOf A i → 0 ≤ v g)
    (hitem_lt :
      ∀ i : SourceAgent, ∀ g : SourceItem, g ∈ bundleOf A i → v g < L)
    (hunique :
      ∀ {i j : SourceAgent} {g : SourceItem},
        g ∈ bundleOf A i → g ∈ bundleOf A j → i = j)
    (hratio : ∀ C : Alloc, ratioOf C = Theorem34.loadRatio (minOf C) (maxOf C))
    (hbundle_move :
      ∀ source target g,
        bundleOf (moveAlloc A source target g) =
          Theorem34.moveBundle (bundleOf A) source target g) :
    ∃ B : Alloc,
      ratioOf B ≤ ratioOf A ∧
        (Theorem34.overfullBundleCardPotential v L (bundleOf B) <
            Theorem34.overfullBundleCardPotential v L (bundleOf A) ∨
          (Theorem34.overfullBundleCardPotential v L (bundleOf B) =
              Theorem34.overfullBundleCardPotential v L (bundleOf A) ∧
            Theorem34.minLoadTiePotential v bundleOf minOf B <
              Theorem34.minLoadTiePotential v bundleOf minOf A)) := by
  exact
    Theorem34.claim34_branch_step_of_minmax_source_trichotomy
      (v := v) (L := L) (ratioOf := ratioOf)
      (bundleOf := bundleOf) (minOf := minOf) (maxOf := maxOf)
      moveAlloc hL havg hmin_lower hmin_attains hmax_upper hmax_attains
      hminA hmaxA hmin_pos hnot_bounded hitem_nonneg hitem_lt hunique
      hratio hbundle_move

/--
Claim 3.4 min/max source-data assembly: average-load preservation, honest
min/max accessors, positive minima on the unbounded optimal path, small
nonnegative goods, unique ownership, and the concrete move update law imply the
existence of a bounded optimal allocation.
-/
theorem paper_lmms_claim_3_4_bounded_optimal_of_minmax_source_trichotomy
    {SourceAgent SourceItem Alloc : Type*}
    [Fintype SourceAgent] [Fintype Alloc] [Nonempty SourceAgent]
    [DecidableEq SourceAgent] [DecidableEq SourceItem]
    {bundleOf : Alloc → SourceAgent → Finset SourceItem}
    {v : SourceItem → ℝ} {L : ℝ} {ratioOf : Alloc → ℝ}
    {minOf maxOf : Alloc → ℝ}
    (moveAlloc : Alloc → SourceAgent → SourceAgent → SourceItem → Alloc)
    (A₀ : Alloc) (hA₀ : Theorem34.IsOptimalRatio ratioOf A₀)
    (hL : 0 < L)
    (havg :
      ∀ A : Alloc,
        Theorem34.IsOptimalRatio ratioOf A →
          (∑ i : SourceAgent, Theorem34.commonLoad v (bundleOf A i)) =
            (Fintype.card SourceAgent : ℝ) * L)
    (hmin_lower :
      ∀ C : Alloc, ∀ i : SourceAgent,
        minOf C ≤ Theorem34.commonLoad v (bundleOf C i))
    (hmin_attains :
      ∀ C : Alloc, ∃ i : SourceAgent,
        Theorem34.commonLoad v (bundleOf C i) = minOf C)
    (hmax_upper :
      ∀ C : Alloc, ∀ i : SourceAgent,
        Theorem34.commonLoad v (bundleOf C i) ≤ maxOf C)
    (hmax_attains :
      ∀ C : Alloc, ∃ i : SourceAgent,
        Theorem34.commonLoad v (bundleOf C i) = maxOf C)
    (hmin_pos :
      ∀ A : Alloc,
        Theorem34.IsOptimalRatio ratioOf A →
          (¬ ∀ i : SourceAgent,
            Theorem34.boundedAroundAverage L
              (Theorem34.commonLoad v (bundleOf A i))) →
            0 < minOf A)
    (hitem_nonneg :
      ∀ A : Alloc, ∀ i : SourceAgent, ∀ g : SourceItem,
        g ∈ bundleOf A i → 0 ≤ v g)
    (hitem_lt :
      ∀ A : Alloc, ∀ i : SourceAgent, ∀ g : SourceItem,
        g ∈ bundleOf A i → v g < L)
    (hunique :
      ∀ A : Alloc, ∀ {i j : SourceAgent} {g : SourceItem},
        g ∈ bundleOf A i → g ∈ bundleOf A j → i = j)
    (hratio : ∀ C : Alloc, ratioOf C = Theorem34.loadRatio (minOf C) (maxOf C))
    (hbundle_move :
      ∀ A source target g,
        bundleOf (moveAlloc A source target g) =
