    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (owner : SourceItem → SourceAgent)
    (lowRoundedLoad : SourceAgent → ℝ)
    (hlambda : 0 < lambda) (hL : 0 < L)
    (hlambda_eq : (lambda : ℝ) = 56 / epsilon)
    (hindex :
      ∀ g : SourceItem, g ∈ highGoods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hhigh :
      ∀ g : SourceItem, g ∈ highGoods →
        L / (lambda : ℝ) < v g)
    (hhigh_alloc : IsAllocationOf highPart highGoods)
    (hgoods_disjoint : Disjoint highGoods lowGoods)
    (hlow_nonneg :
      ∀ g : SourceItem, g ∈ lowGoods → 0 ≤ v g)
    (hlowRounded_nonneg : ∀ i : SourceAgent, 0 ≤ lowRoundedLoad i)
    (hlow_upper :
      ∀ i : SourceAgent,
        (lowGoods.filter fun g => owner g = i).sum v ≤
          lowRoundedLoad i + L / (lambda : ℝ))
    (hlow_lower :
      ∀ i : SourceAgent,
        lowRoundedLoad i - L / (lambda : ℝ) ≤
          (lowGoods.filter fun g => owner g = i).sum v) :
    ∃ lowPart output : Allocation SourceAgent SourceItem,
      IsAllocationOf lowPart lowGoods ∧
        IsAllocationOf output (highGoods ∪ lowGoods) ∧
        (∀ i : SourceAgent, output i = highPart i ∪ lowPart i) ∧
        (∀ i : SourceAgent,
          Theorem34.commonLoad v (output i) =
            (highPart i).sum v + (lowPart i).sum v) ∧
        (∀ i : SourceAgent,
          Theorem34.commonLoad v (output i) ≤
            (highPart i).sum
                (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
              lowRoundedLoad i + L / (56 / epsilon)) ∧
        (∀ i : SourceAgent,
          ((56 / epsilon) / ((56 / epsilon) + 1)) *
                ((highPart i).sum
                    (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
                  lowRoundedLoad i) -
              (2 / (56 / epsilon)) * L ≤
            Theorem34.commonLoad v (output i)) ∧
        (∀ i : SourceAgent,
          (highPart i).sum
              (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
            lowRoundedLoad i ≤
          (((56 / epsilon) + 1) / (56 / epsilon)) *
              Theorem34.commonLoad v (output i) +
            L / (56 / epsilon)) ∧
          ∀ i : SourceAgent,
            Theorem34.commonLoad v (output i) - L / (56 / epsilon) ≤
              (highPart i).sum
                  (fun g => Theorem33.roundedValue L lambda (indexOf g)) +
                lowRoundedLoad i := by
  rcases
      paper_lmms_theorem_3_3_exists_low_goods_partition_of_owner_load_estimates
        lowGoods v owner lowRoundedLoad hlow_upper hlow_lower with
    ⟨lowPart, hlowPart_alloc, hlowPart_estimates⟩
  rcases
      paper_lmms_theorem_3_3_source_output_allocation_agentwise_additive_transfer_premises_of_exact_low_partition_epsilon
        highPart lowPart highGoods lowGoods v indexOf lowRoundedLoad
        hlambda hL hlambda_eq hindex hhigh hhigh_alloc hlowPart_alloc
        hgoods_disjoint hlow_nonneg hlowRounded_nonneg
        (fun i => (hlowPart_estimates i).1)
        (fun i => (hlowPart_estimates i).2) with
    ⟨output, houtput_alloc, houtput_eq, houtput_load, hbackward_max,
      hbackward_min, hforward_max, hforward_min⟩
  exact
    ⟨lowPart, output, hlowPart_alloc, houtput_alloc, houtput_eq,
      houtput_load, hbackward_max, hbackward_min, hforward_max,
      hforward_min⟩

/--
The rounded bundle type induced by a finite bundle of source goods and a
rounded value index assigned to each source good.
-/
noncomputable def paper_lmms_theorem_3_3_roundedBundleTypeOfBundle
    {SourceItem : Type*} {lambda : ℕ}
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (bundle : Finset SourceItem) :
    Theorem33.RoundedBundleType lambda := by
  classical
  exact
    { count := fun k => (bundle.filter fun g => indexOf g = k).card }

/-- The rounded goods-supply vector induced by a finite set of source goods. -/
noncomputable def paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods
    {SourceItem : Type*} {lambda : ℕ}
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (goods : Finset SourceItem) :
    Theorem33.RoundedValueIndex lambda → ℕ := by
  classical
  exact fun k => (goods.filter fun g => indexOf g = k).card

/-- If no source good maps to a rounded index, that index has zero goods supply. -/
theorem paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_eq_zero_of_index_ne
    {SourceItem : Type*} [DecidableEq SourceItem] {lambda : ℕ}
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (goods : Finset SourceItem) (k : Theorem33.RoundedValueIndex lambda)
    (hno :
      ∀ g : SourceItem, g ∈ goods → indexOf g ≠ k) :
    paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf goods k = 0 := by
  classical
  rw [paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods, Finset.card_eq_zero]
  ext g
  by_cases hg : g ∈ goods
  · have hne := hno g hg
    simp [hg, hne]
  · simp [hg]

/--
The concrete rounded item type induced by a rounded goods-supply vector: for
each rounded value index `k`, create exactly `supply k` distinguishable goods.
-/
abbrev paper_lmms_theorem_3_3_roundedSupplyItem
    {lambda : ℕ} (supply : Theorem33.RoundedValueIndex lambda → ℕ) :=
  Sigma fun k : Theorem33.RoundedValueIndex lambda => Fin (supply k)

/-- The rounded value index of a materialized supply item. -/
def paper_lmms_theorem_3_3_roundedSupplyIndexOf
    {lambda : ℕ} {supply : Theorem33.RoundedValueIndex lambda → ℕ}
    (item : paper_lmms_theorem_3_3_roundedSupplyItem supply) :
    Theorem33.RoundedValueIndex lambda :=
  item.1

/-- The top rounded value index `k = lambda^2`, whose rounded value is `L`. -/
def paper_lmms_theorem_3_3_topRoundedValueIndex
    (lambda : ℕ) : Theorem33.RoundedValueIndex lambda :=
  ⟨⟨lambda ^ 2, Nat.lt_succ_self _⟩,
    Nat.le_self_pow (by norm_num : (2 : ℕ) ≠ 0) lambda⟩

/-- The top rounded value index has natural value `lambda^2`. -/
theorem paper_lmms_theorem_3_3_topRoundedValueIndex_value
    (lambda : ℕ) :
    Theorem33.roundedValueIndexValue
      (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) =
      lambda ^ 2 := by
  rfl

/-- The rounded value of a materialized supply item. -/
noncomputable def paper_lmms_theorem_3_3_roundedSupplyValue
    (L : ℝ) (lambda : ℕ)
    {supply : Theorem33.RoundedValueIndex lambda → ℕ}
    (item : paper_lmms_theorem_3_3_roundedSupplyItem supply) : ℝ :=
  Theorem33.roundedValue L lambda
    (paper_lmms_theorem_3_3_roundedSupplyIndexOf item)

/-- Every materialized rounded-supply item has positive value when `L, λ > 0`. -/
theorem paper_lmms_theorem_3_3_roundedSupplyValue_pos
    {L : ℝ} {lambda : ℕ}
    {supply : Theorem33.RoundedValueIndex lambda → ℕ}
    (hlambda : 0 < lambda) (hL : 0 < L)
    (item : paper_lmms_theorem_3_3_roundedSupplyItem supply) :
    0 < paper_lmms_theorem_3_3_roundedSupplyValue L lambda item := by
  have hunit_pos : 0 < L / (lambda : ℝ) :=
    div_pos hL (by exact_mod_cast hlambda)
  exact
    lt_of_lt_of_le hunit_pos
      (Theorem33.roundedValue_ge_L_div_lambda
        (L := L) hlambda hL
        (paper_lmms_theorem_3_3_roundedSupplyIndexOf item))

/-- The top rounded value is exactly `L`. -/
theorem paper_lmms_theorem_3_3_roundedValue_topRoundedValueIndex_eq
    {L : ℝ} {lambda : ℕ} (hlambda : 0 < lambda) :
    Theorem33.roundedValue L lambda
      (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) = L := by
  have hlambda_real_pos : 0 < (lambda : ℝ) := by
    exact_mod_cast hlambda
  have hcast : ((lambda ^ 2 : ℕ) : ℝ) = (lambda : ℝ) ^ 2 := by
    norm_num
  unfold Theorem33.roundedValue
  rw [paper_lmms_theorem_3_3_topRoundedValueIndex_value]
  rw [hcast]
  field_simp [ne_of_gt (sq_pos_of_pos hlambda_real_pos)]

/--
High-good no-top support under an explicit rounding margin. If the chosen
rounded value for each high good is still strictly below `L`, then its rounded
index cannot be the top index. The margin
`v g + L / lambda^2 ≤ L` is a source-shaped sufficient condition for this.
-/
theorem paper_lmms_theorem_3_3_high_indexOf_ne_top_of_rounding_margin
    {SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    {goods : Finset SourceItem} {v : SourceItem → ℝ}
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (hlambda : 0 < lambda)
    (hindex :
      ∀ g : SourceItem, g ∈ goods →
        v g ≤ Theorem33.roundedValue L lambda (indexOf g) ∧
          Theorem33.roundedValue L lambda (indexOf g) <
            v g + L / ((lambda : ℝ) ^ 2))
    (hmargin :
      ∀ g : SourceItem, g ∈ goods →
        v g + L / ((lambda : ℝ) ^ 2) ≤ L) :
    ∀ g : SourceItem, g ∈ goods →
      indexOf g ≠ paper_lmms_theorem_3_3_topRoundedValueIndex lambda := by
  intro g hg htop
  have hrounded_lt_L :
      Theorem33.roundedValue L lambda (indexOf g) < L :=
    (hindex g hg).2.trans_le (hmargin g hg)
  rw [htop, paper_lmms_theorem_3_3_roundedValue_topRoundedValueIndex_eq
    (L := L) hlambda] at hrounded_lt_L
  exact lt_irrefl L hrounded_lt_L

/-- The low-good rounded index has natural value `lambda`. -/
theorem paper_lmms_theorem_3_3_lowGoodRoundedValueIndex_value
    (lambda : ℕ) :
    Theorem33.roundedValueIndexValue
      (Theorem33.lowGoodRoundedValueIndex lambda) = lambda := by
  rfl

/-- For `lambda > 1`, the artificial low-good index is not the top index. -/
theorem paper_lmms_theorem_3_3_lowGoodRoundedValueIndex_ne_topRoundedValueIndex
    {lambda : ℕ} (hlambda : 1 < lambda) :
    Theorem33.lowGoodRoundedValueIndex lambda ≠
      paper_lmms_theorem_3_3_topRoundedValueIndex lambda := by
  intro h
  have hval := congrArg Theorem33.roundedValueIndexValue h
  have hlt : lambda < lambda ^ 2 := by
    have hpos : 0 < lambda := Nat.zero_lt_of_lt hlambda
    have hmul : lambda * 1 < lambda * lambda :=
      Nat.mul_lt_mul_of_pos_left hlambda hpos
    simpa [pow_two] using hmul
  rw [paper_lmms_theorem_3_3_lowGoodRoundedValueIndex_value,
    paper_lmms_theorem_3_3_topRoundedValueIndex_value] at hval
  exact (Nat.ne_of_lt hlt) hval

/-- For `lambda > 1`, low-good aggregation contributes no top-index goods. -/
theorem paper_lmms_theorem_3_3_lowGoodsAggregatedSupply_top_eq_zero
    {L S : ℝ} {lambda : ℕ} (hlambda : 1 < lambda) :
    Theorem33.lowGoodsAggregatedSupply L lambda S
        (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) = 0 := by
  exact
    Theorem33.lowGoodsAggregatedSupply_eq_zero_of_ne
      (k := paper_lmms_theorem_3_3_topRoundedValueIndex lambda)
      (L := L) (S := S)
      (paper_lmms_theorem_3_3_lowGoodRoundedValueIndex_ne_topRoundedValueIndex
        hlambda).symm

/-- Every rounded value index has value at most the average-load scale `L`. -/
theorem paper_lmms_theorem_3_3_roundedValue_le_L
    {L : ℝ} {lambda : ℕ}
    (hlambda : 0 < lambda) (hL : 0 ≤ L)
    (k : Theorem33.RoundedValueIndex lambda) :
    Theorem33.roundedValue L lambda k ≤ L := by
  have hlambda_real_pos : 0 < (lambda : ℝ) := by
    exact_mod_cast hlambda
  have hlambda_sq_pos : 0 < (lambda : ℝ) ^ 2 :=
    sq_pos_of_pos hlambda_real_pos
  have hk_upper :
      (Theorem33.roundedValueIndexValue k : ℝ) ≤ (lambda : ℝ) ^ 2 := by
    have hk_nat := Theorem33.roundedValueIndexValue_upper k
    exact_mod_cast hk_nat
  calc
    Theorem33.roundedValue L lambda k =
        ((Theorem33.roundedValueIndexValue k : ℝ) /
          ((lambda : ℝ) ^ 2)) * L := by
          rw [Theorem33.roundedValue]
          ring
    _ ≤ (((lambda : ℝ) ^ 2) / ((lambda : ℝ) ^ 2)) * L := by
          gcongr
    _ = L := by
          field_simp [ne_of_gt hlambda_sq_pos]

/-- Materialized rounded-supply item values are bounded above by `L`. -/
theorem paper_lmms_theorem_3_3_roundedSupplyValue_le_L
    {L : ℝ} {lambda : ℕ}
    {supply : Theorem33.RoundedValueIndex lambda → ℕ}
    (hlambda : 0 < lambda) (hL : 0 ≤ L)
    (item : paper_lmms_theorem_3_3_roundedSupplyItem supply) :
    paper_lmms_theorem_3_3_roundedSupplyValue L lambda item ≤ L := by
  exact
    paper_lmms_theorem_3_3_roundedValue_le_L
      hlambda hL
      (paper_lmms_theorem_3_3_roundedSupplyIndexOf item)

/--
Rounded values are strictly below `L` whenever the rounded index is strictly
below the top index `lambda^2`.
-/
theorem paper_lmms_theorem_3_3_roundedValue_lt_L_of_index_lt_top
    {L : ℝ} {lambda : ℕ}
    (hlambda : 0 < lambda) (hL : 0 < L)
    (k : Theorem33.RoundedValueIndex lambda)
    (hk_top : Theorem33.roundedValueIndexValue k < lambda ^ 2) :
    Theorem33.roundedValue L lambda k < L := by
  have hlambda_real_pos : 0 < (lambda : ℝ) := by
    exact_mod_cast hlambda
  have hlambda_sq_pos : 0 < (lambda : ℝ) ^ 2 :=
    sq_pos_of_pos hlambda_real_pos
  have hk_top_real :
      (Theorem33.roundedValueIndexValue k : ℝ) < (lambda : ℝ) ^ 2 := by
    exact_mod_cast hk_top
  have hnum_lt :
      (Theorem33.roundedValueIndexValue k : ℝ) * L <
        ((lambda : ℝ) ^ 2) * L :=
    mul_lt_mul_of_pos_right hk_top_real hL
  have hdiv_lt :
      ((Theorem33.roundedValueIndexValue k : ℝ) * L) /
          ((lambda : ℝ) ^ 2) <
        (((lambda : ℝ) ^ 2) * L) / ((lambda : ℝ) ^ 2) :=
    div_lt_div_of_pos_right hnum_lt hlambda_sq_pos
  calc
    Theorem33.roundedValue L lambda k =
        ((Theorem33.roundedValueIndexValue k : ℝ) * L) /
          ((lambda : ℝ) ^ 2) := rfl
    _ < (((lambda : ℝ) ^ 2) * L) / ((lambda : ℝ) ^ 2) := hdiv_lt
    _ = L := by
          field_simp [ne_of_gt hlambda_sq_pos]

/--
Materialized rounded-supply item values are strictly below `L` when their
rounded value index is not the top `lambda^2` index.
-/
theorem paper_lmms_theorem_3_3_roundedSupplyValue_lt_L_of_index_lt_top
    {L : ℝ} {lambda : ℕ}
    {supply : Theorem33.RoundedValueIndex lambda → ℕ}
    (hlambda : 0 < lambda) (hL : 0 < L)
    (item : paper_lmms_theorem_3_3_roundedSupplyItem supply)
    (hitem_top :
      Theorem33.roundedValueIndexValue
          (paper_lmms_theorem_3_3_roundedSupplyIndexOf item) <
        lambda ^ 2) :
    paper_lmms_theorem_3_3_roundedSupplyValue L lambda item < L := by
  exact
    paper_lmms_theorem_3_3_roundedValue_lt_L_of_index_lt_top
      hlambda hL
      (paper_lmms_theorem_3_3_roundedSupplyIndexOf item)
      hitem_top

/--
If the rounded supply has no item at the top value index `lambda^2`, then
every materialized item's rounded index is strictly below the top index.
-/
theorem paper_lmms_theorem_3_3_roundedSupplyIndex_lt_top_of_top_supply_eq_zero
    {lambda : ℕ}
    {supply : Theorem33.RoundedValueIndex lambda → ℕ}
    (htop_zero :
      supply (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) = 0)
    (item : paper_lmms_theorem_3_3_roundedSupplyItem supply) :
    Theorem33.roundedValueIndexValue
        (paper_lmms_theorem_3_3_roundedSupplyIndexOf item) <
      lambda ^ 2 := by
  let idx := paper_lmms_theorem_3_3_roundedSupplyIndexOf item
  have hle : Theorem33.roundedValueIndexValue idx ≤ lambda ^ 2 :=
    Theorem33.roundedValueIndexValue_upper idx
  by_contra hnot
  have hge : lambda ^ 2 ≤ Theorem33.roundedValueIndexValue idx :=
    Nat.le_of_not_gt hnot
  have hval : Theorem33.roundedValueIndexValue idx = lambda ^ 2 :=
    le_antisymm hle hge
  have hidx :
      idx = paper_lmms_theorem_3_3_topRoundedValueIndex lambda := by
    apply Subtype.ext
    apply Fin.ext
    exact hval
  have hitem_fst :
      item.1 = paper_lmms_theorem_3_3_topRoundedValueIndex lambda := by
    simpa [idx, paper_lmms_theorem_3_3_roundedSupplyIndexOf] using hidx
  have hfin : Fin (supply (paper_lmms_theorem_3_3_topRoundedValueIndex lambda)) := by
    simpa [hitem_fst] using item.2
  rw [htop_zero] at hfin
  exact Fin.elim0 hfin

/--
If the rounded supply has no top-index goods, all materialized item values are
strictly below `L`.
-/
theorem paper_lmms_theorem_3_3_roundedSupplyValue_lt_L_of_top_supply_eq_zero
    {L : ℝ} {lambda : ℕ}
    {supply : Theorem33.RoundedValueIndex lambda → ℕ}
    (hlambda : 0 < lambda) (hL : 0 < L)
    (htop_zero :
      supply (paper_lmms_theorem_3_3_topRoundedValueIndex lambda) = 0)
    (item : paper_lmms_theorem_3_3_roundedSupplyItem supply) :
    paper_lmms_theorem_3_3_roundedSupplyValue L lambda item < L := by
  exact
    paper_lmms_theorem_3_3_roundedSupplyValue_lt_L_of_index_lt_top
      hlambda hL item
      (paper_lmms_theorem_3_3_roundedSupplyIndex_lt_top_of_top_supply_eq_zero
        htop_zero item)

/--
Materializing a rounded goods-supply vector as finite rounded items recovers
exactly that supply vector when goods are counted by rounded value index.
-/
theorem paper_lmms_theorem_3_3_roundedGoodsSupplyOfSupply_eq
    {lambda : ℕ} (supply : Theorem33.RoundedValueIndex lambda → ℕ)
    (k : Theorem33.RoundedValueIndex lambda) :
    paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods
        (paper_lmms_theorem_3_3_roundedSupplyIndexOf
          (supply := supply))
        (Finset.univ :
          Finset (paper_lmms_theorem_3_3_roundedSupplyItem supply)) k =
      supply k := by
  classical
  let e :
      {item : paper_lmms_theorem_3_3_roundedSupplyItem supply //
          item.1 = k} ≃ Fin (supply k) :=
    {
    toFun item := by
      rcases item with ⟨⟨k', n⟩, hk'⟩
      cases hk'
      exact n
    invFun n := ⟨⟨k, n⟩, rfl⟩
    left_inv item := by
      rcases item with ⟨⟨k', n⟩, hk'⟩
      cases hk'
      rfl
    right_inv n := rfl
    }
  have hcard :
      Fintype.card
          {item : paper_lmms_theorem_3_3_roundedSupplyItem supply //
            item.1 = k} =
        supply k := by
    simpa using (Fintype.card_congr e)
  dsimp [paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods,
    paper_lmms_theorem_3_3_roundedSupplyIndexOf,
    paper_lmms_theorem_3_3_roundedSupplyItem]
  exact
    ((Fintype.card_subtype
      (fun item : Sigma fun k : Theorem33.RoundedValueIndex lambda =>
        Fin (supply k) => item.1 = k)).symm.trans hcard)

/--
The rounded goods-supply vector preserves the total rounded value of the source
goods when weighted by the rounded value associated with each index.
-/
theorem paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_weighted_sum_eq_sum_goods
    {SourceItem : Type*} {L : ℝ} {lambda : ℕ}
    [DecidableEq SourceItem]
    (indexOf : SourceItem → Theorem33.RoundedValueIndex lambda)
    (goods : Finset SourceItem) :
    (∑ k : Theorem33.RoundedValueIndex lambda,
        (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf goods k : ℝ) *
          Theorem33.roundedValue L lambda k) =
      goods.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) := by
  classical
  calc
    (∑ k : Theorem33.RoundedValueIndex lambda,
        (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf goods k : ℝ) *
          Theorem33.roundedValue L lambda k)
        =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        ∑ g ∈ goods with indexOf g = k,
          Theorem33.roundedValue L lambda k := by
        apply Finset.sum_congr rfl
        intro k _hk
        simp [paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods, nsmul_eq_mul,
          mul_comm]
    _ = goods.sum (fun g => Theorem33.roundedValue L lambda (indexOf g)) := by
        simpa using
          (Finset.sum_fiberwise_of_maps_to'
            (s := goods)
            (t := (Finset.univ : Finset (Theorem33.RoundedValueIndex lambda)))
            (g := indexOf)
            (f := fun k : Theorem33.RoundedValueIndex lambda =>
              Theorem33.roundedValue L lambda k)
            (fun g _hg => Finset.mem_univ (indexOf g)))

/--
The total value of the materialized rounded-supply items is exactly the
weighted value of the original supply vector.
-/
theorem paper_lmms_theorem_3_3_roundedSupplyValue_sum_eq_weighted_supply
    {L : ℝ} {lambda : ℕ}
    (supply : Theorem33.RoundedValueIndex lambda → ℕ) :
    (∑ item : paper_lmms_theorem_3_3_roundedSupplyItem supply,
        paper_lmms_theorem_3_3_roundedSupplyValue L lambda item) =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        (supply k : ℝ) * Theorem33.roundedValue L lambda k := by
  classical
  let indexOf :
      paper_lmms_theorem_3_3_roundedSupplyItem supply →
        Theorem33.RoundedValueIndex lambda :=
    paper_lmms_theorem_3_3_roundedSupplyIndexOf
  have hweighted :
      (∑ k : Theorem33.RoundedValueIndex lambda,
          (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf
              (Finset.univ :
                Finset (paper_lmms_theorem_3_3_roundedSupplyItem supply)) k : ℝ) *
            Theorem33.roundedValue L lambda k) =
        (Finset.univ :
            Finset (paper_lmms_theorem_3_3_roundedSupplyItem supply)).sum
          (fun item => Theorem33.roundedValue L lambda (indexOf item)) :=
    paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_weighted_sum_eq_sum_goods
      (L := L) indexOf
      (Finset.univ :
        Finset (paper_lmms_theorem_3_3_roundedSupplyItem supply))
  calc
    (∑ item : paper_lmms_theorem_3_3_roundedSupplyItem supply,
        paper_lmms_theorem_3_3_roundedSupplyValue L lambda item)
        =
      (Finset.univ :
          Finset (paper_lmms_theorem_3_3_roundedSupplyItem supply)).sum
        (fun item => Theorem33.roundedValue L lambda (indexOf item)) := by
          simp [paper_lmms_theorem_3_3_roundedSupplyValue, indexOf]
    _ =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf
            (Finset.univ :
              Finset (paper_lmms_theorem_3_3_roundedSupplyItem supply)) k : ℝ) *
          Theorem33.roundedValue L lambda k := hweighted.symm
    _ =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        (supply k : ℝ) * Theorem33.roundedValue L lambda k := by
          apply Finset.sum_congr rfl
          intro k _hk
          rw [paper_lmms_theorem_3_3_roundedGoodsSupplyOfSupply_eq]

/--
For an exact allocation of a materialized rounded-supply vector, the sum of
agent rounded loads is exactly the weighted value of that supply vector.
-/
theorem paper_lmms_theorem_3_3_roundedSupplyAllocation_total_load_eq_weighted_supply
    {L : ℝ} {lambda : ℕ} {SourceAgent : Type*}
    [Fintype SourceAgent]
    (supply : Theorem33.RoundedValueIndex lambda → ℕ)
    (A :
      Allocation SourceAgent
        (paper_lmms_theorem_3_3_roundedSupplyItem supply))
    (halloc :
      IsAllocationOf A
        (Finset.univ :
          Finset (paper_lmms_theorem_3_3_roundedSupplyItem supply))) :
    (∑ i : SourceAgent,
        Theorem34.commonLoad
          (paper_lmms_theorem_3_3_roundedSupplyValue L lambda) (A i)) =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        (supply k : ℝ) * Theorem33.roundedValue L lambda k := by
  classical
  have hsum :=
    paper_lmms_isAllocationOf_sum_bundle_values_eq_sum_goods
      (A := A)
      (goods :=
        (Finset.univ :
          Finset (paper_lmms_theorem_3_3_roundedSupplyItem supply)))
      (v := paper_lmms_theorem_3_3_roundedSupplyValue L lambda)
      halloc
  exact
    (by
      simpa [Theorem34.commonLoad] using
        hsum.trans
          (paper_lmms_theorem_3_3_roundedSupplyValue_sum_eq_weighted_supply
            (L := L) (lambda := lambda) supply))

/--
Specialization of the exact rounded-supply total identity to the low artificial
goods generated by `lowGoodsAggregatedSupply`.
-/
theorem paper_lmms_theorem_3_3_lowGoodsAggregatedSupplyAllocation_total_load_eq_weighted_supply
    {L : ℝ} {lambda : ℕ} {SourceAgent SourceItem : Type*}
    [Fintype SourceAgent] [DecidableEq SourceItem]
    (lowGoods : Finset SourceItem) (sourceValue : SourceItem → ℝ)
