    (∑ i : SourceAgent,
        Theorem33.roundedBundleTypeLoad L
          (paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf (A i))) =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf goods k : ℝ) *
          Theorem33.roundedValue L lambda k := by
  classical
  let roundedV : SourceItem → ℝ :=
    fun g => Theorem33.roundedValue L lambda (indexOf g)
  have hload :
      ∀ i : SourceAgent,
        Theorem33.roundedBundleTypeLoad L
            (paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf (A i)) =
          (A i).sum roundedV := by
    intro i
    simpa [roundedV] using
      paper_lmms_theorem_3_3_roundedBundleTypeOfBundle_load_eq_sum
        (L := L) indexOf (A i)
  have halloc_sum :
      (∑ i : SourceAgent, (A i).sum roundedV) = goods.sum roundedV :=
    paper_lmms_isAllocationOf_sum_bundle_values_eq_sum_goods
      (A := A) (goods := goods) (v := roundedV) halloc
  have hgoods_supply :
      (∑ k : Theorem33.RoundedValueIndex lambda,
          (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf goods k : ℝ) *
            Theorem33.roundedValue L lambda k) =
        goods.sum roundedV := by
    simpa [roundedV] using
      paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods_weighted_sum_eq_sum_goods
        (L := L) indexOf goods
  calc
    (∑ i : SourceAgent,
        Theorem33.roundedBundleTypeLoad L
          (paper_lmms_theorem_3_3_roundedBundleTypeOfBundle indexOf (A i)))
        = ∑ i : SourceAgent, (A i).sum roundedV := by
          apply Finset.sum_congr rfl
          intro i _hi
          exact hload i
    _ = goods.sum roundedV := halloc_sum
    _ =
      ∑ k : Theorem33.RoundedValueIndex lambda,
        (paper_lmms_theorem_3_3_roundedGoodsSupplyOfGoods indexOf goods k : ℝ) *
          Theorem33.roundedValue L lambda k := hgoods_supply.symm

