                Theorem33.roundedTypesInValueWindowWithCap
                  L LR lambda
                    (paper_lmms_theorem_3_3_capCountForAverage
                      L
                        (L +
                          (((Fintype.card SourceAgent : ℝ) + 1) *
                              (L / (lambda : ℝ))) /
                            (Fintype.card SourceAgent : ℝ))
                      lambda)
                  p.1 p.2) ∧
            (∀ k : Theorem33.RoundedValueIndex lambda,
              (∑ i : SourceAgent, (typeOf i).count k) = combinedSupply k) ∧
            ∃ search :
              Theorem33.RoundedValuePairSearchCertificateWithCap
                L LR lambda
                  (paper_lmms_theorem_3_3_capCountForAverage
                    L
                      (L +
                        (((Fintype.card SourceAgent : ℝ) + 1) *
                            (L / (lambda : ℝ))) /
                          (Fintype.card SourceAgent : ℝ))
                    lambda)
                SourceAgent combinedSupply,
              Theorem33.roundedValuePairRatio search.chosenPair ≤
                Theorem33.roundedValuePairRatio p := by
  classical
  have hcard_nat_pos : 0 < Fintype.card SourceAgent :=
    Fintype.card_pos
  have hcard_pos : 0 < (Fintype.card SourceAgent : ℝ) := by
    exact_mod_cast hcard_nat_pos
  have hbudget_scalar :
      (highGoods.card : ℝ) * (L / ((lambda : ℝ) ^ 2)) +
          L / (lambda : ℝ) ≤
        ((Fintype.card SourceAgent : ℝ) + 1) *
          (L / (lambda : ℝ)) :=
    paper_lmms_theorem_3_3_rounding_error_budget_le_source_slack
      (SourceAgent := SourceAgent)
      highGoods lowGoods v (Nat.zero_lt_of_lt hlambda) hL
      (fun g hg => (hhigh g hg).1)
      (fun g hg => (hlow g hg).1)
