    ⟨_htop_zero_again, p, typeOf, hpair, htypes, hcounts, search, hsearch⟩
  exact
    ⟨indexOf, combinedSupply, p, typeOf, hindex, hsupply, htop_zero,
      hpair, htypes, hcounts, search, hsearch⟩

