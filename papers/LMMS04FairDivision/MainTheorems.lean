  exact
    Theorem34.claim34_certificate_of_minmax_source_trichotomy
      (v := v) (L := L) (ratioOf := ratioOf)
      (bundleOf := bundleOf) (minOf := minOf) (maxOf := maxOf)
      moveAlloc A₀ hA₀ hL havg hmin_lower hmin_attains hmax_upper
