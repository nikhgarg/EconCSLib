    (hdeficit_le :
      ∀ cut (w : ℝ → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ x : ℝ, x ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
          w x ≠ z ∧ q x (w x) < (Fintype.card Y : ℝ)⁻¹) →
        ∀ x, x ∈ S ∩ Ioc cut hi → 1 - q x z ≤ q x (w x)) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ a : Y, Measurable fun x : ℝ => qNext x a) ∧
        (∀ x : ℝ, x ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
          w x ≠ z ∧ q x (w x) < (Fintype.card Y : ℝ)⁻¹) ∧
        (∀ x : ℝ, x ∈ S ∩ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then 1
            else if a = w x then q x (w x) - (1 - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ S ∩ Ioc lo cut → ∀ a : Y,
