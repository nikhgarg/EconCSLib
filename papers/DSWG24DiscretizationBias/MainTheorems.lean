      (hscore y).aestronglyMeasurable (fun x => hnonneg x y)
      (fun x => hle_one x y))
    (integrable_continuousJointClassifierMAE_of_ae_bound
      μ q CMAE hmaeMeas hmaeBound)
    hargmax hsum hnonneg hle_one hscore
    (fun y => integrable_jointLabelIndicator_product_finite μ y)
    hcal

/--
Finite product-law conditional-kernel Theorem 1(iii) wrapper with the MAE
integrability obligations discharged from measurable, `[0,1]`-bounded score
coordinates.
-/
theorem paper_theorem1iii_continuous_joint_prior_bias_le_mae_of_condExpKernelCalibration_finite_scoreBounded
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSingletonClass Y] [StandardBorelSpace (X × Y)]
