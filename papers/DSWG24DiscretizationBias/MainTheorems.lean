      sourceSb_subset_interval_split_exists_measurable_feature_qNext_collapse_simplex_mae_delta_nonpos_uniform_simplex_finite
        (μ := μR) (q := qCoord) (z := z) (lo := lo) (hi := hi) (S := S)
