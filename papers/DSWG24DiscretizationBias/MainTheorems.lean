theorem continuousJointPrior_eq_jointAggregatePosterior_of_continuousCalibration
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (y : Y)
    (hcal : ContinuousCalibration μ q) :
    continuousJointPrior μ y = continuousJointAggregatePosterior μ q y := by
  have h := hcal y Set.univ MeasurableSet.univ
  simpa [ContinuousCalibration, continuousJointPrior, continuousJointAggregatePosterior] using h

theorem continuousJointPrior_eq_jointAggregatePosterior_of_aggregate_preserved
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (q qNext : X → Y → ℝ) (z : Y)
    (hpriorAggregate :
      continuousJointPrior μ z = continuousJointAggregatePosterior μ q z)
    (haggregate :
      continuousJointAggregatePosterior μ qNext z =
        continuousJointAggregatePosterior μ q z) :
    continuousJointPrior μ z = continuousJointAggregatePosterior μ qNext z := by
  rw [hpriorAggregate, haggregate]

theorem continuousJointAggregatePosterior_preserved_trans
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q₀ q₁ q₂ : X → Y → ℝ) (z : Y)
    (haggregate₀₁ :
      continuousJointAggregatePosterior μ q₁ z =
        continuousJointAggregatePosterior μ q₀ z)
    (haggregate₁₂ :
      continuousJointAggregatePosterior μ q₂ z =
        continuousJointAggregatePosterior μ q₁ z) :
    continuousJointAggregatePosterior μ q₂ z =
      continuousJointAggregatePosterior μ q₀ z := by
  rw [haggregate₁₂, haggregate₀₁]

/--
