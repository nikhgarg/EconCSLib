theorem noAtoms_map_of_injective
    {α β : Type*} [MeasurableSpace α] [MeasurableSpace β]
    [MeasurableSingletonClass β]
    (μ : Measure α) [NoAtoms μ] {f : α → β}
    (hf : Measurable f) (hinj : Function.Injective f) :
    NoAtoms (Measure.map f μ) := by
  refine ⟨?_⟩
  intro b
  rw [Measure.map_apply hf (measurableSet_singleton b)]
  by_cases hpre_nonempty : ∃ x : α, f x = b
  · rcases hpre_nonempty with ⟨x, hx⟩
    have hpre : f ⁻¹' ({b} : Set β) = {x} := by
      ext y
      constructor
      · intro hy
        have hfy : f y = b := by simpa using hy
        exact hinj (hfy.trans hx.symm)
      · intro hy
        rw [hy]
        simpa using hx
    rw [hpre]
    exact measure_singleton x
  · have hpre : f ⁻¹' ({b} : Set β) = ∅ := by
      ext x
      constructor
      · intro hx
        exact False.elim (hpre_nonempty ⟨x, by simpa using hx⟩)
      · intro hx
        exact False.elim hx
    rw [hpre, measure_empty]

theorem noAtoms_map_of_measurableEmbedding
    {α β : Type*} [MeasurableSpace α] [MeasurableSpace β]
    [MeasurableSingletonClass β]
    (μ : Measure α) [NoAtoms μ] {f : α → β}
    (hf : MeasurableEmbedding f) :
    NoAtoms (Measure.map f μ) :=
  noAtoms_map_of_injective μ hf.measurable hf.injective

/--
A measurable embedding coordinate carries nonatomicity of the feature marginal
to the pushed-forward real coordinate marginal.  This is the lightweight
bridge used by the coordinate-sweep formalization of the source
transformation.
-/
theorem noAtoms_featureCoordinate_map_of_measurableEmbedding
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) [NoAtoms (Measure.map Prod.fst μ)]
    {r : X → ℝ} (hr : MeasurableEmbedding r) :
    NoAtoms (Measure.map r (Measure.map Prod.fst μ)) :=
  noAtoms_map_of_measurableEmbedding (Measure.map Prod.fst μ) hr

/-- Finite product laws have finite mass on every measurable coordinate interval. -/
theorem featureCoordinate_map_Icc_lt_top
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] {r : X → ℝ}
    (hr : Measurable r) (lo hi : ℝ) :
    (Measure.map r (Measure.map Prod.fst μ)) (Icc lo hi) < ⊤ := by
  rw [Measure.map_apply hr measurableSet_Icc]
  exact measure_lt_top (μ := Measure.map Prod.fst μ) (r ⁻¹' Icc lo hi)

/--
Integral transfer for a swept coordinate set.

It rewrites an integral over a feature marginal on a coordinate preimage as the
corresponding integral over the pushed-forward coordinate law.  This is the
measure-theoretic bridge behind the explicit real-coordinate source sweep.
-/
theorem integral_coordinate_preimage_indicator_eq_map_integral
    {X β : Type*} [MeasurableSpace X] [MeasurableSpace β]
    (μ : Measure X) {r : X → β} (hr : Measurable r)
    (S : Set β) (w : β → ℝ)
    (hS : MeasurableSet S) (hw : Measurable w) :
    (∫ x, (r ⁻¹' S).indicator (fun x : X => w (r x)) x ∂μ) =
      ∫ t, S.indicator w t ∂(Measure.map r μ) := by
  have hpoint : ∀ x : X,
      (r ⁻¹' S).indicator (fun x : X => w (r x)) x =
        S.indicator w (r x) := by
    intro x
    by_cases hx : r x ∈ S <;> simp [Set.indicator, hx]
  have hmeas :
      AEStronglyMeasurable (fun t : β => S.indicator w t)
        (Measure.map r μ) :=
    (hw.indicator hS).aestronglyMeasurable
  calc
    (∫ x, (r ⁻¹' S).indicator (fun x : X => w (r x)) x ∂μ) =
        ∫ x, S.indicator w (r x) ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ = ∫ t, S.indicator w t ∂(Measure.map r μ) :=
        (integral_map hr.aemeasurable hmeas).symm

/-- The joint map that records a real feature coordinate and preserves the label. -/
def featureCoordinateJointMap {X Y : Type*} (r : X → ℝ) : X × Y → ℝ × Y :=
  fun xy => (r xy.1, xy.2)

/-- Measurability of the joint coordinate-label map. -/
theorem measurable_featureCoordinateJointMap
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y] {r : X → ℝ}
    (hr : Measurable r) :
    Measurable (featureCoordinateJointMap (Y := Y) r) :=
  (hr.comp measurable_fst).prodMk measurable_snd

/--
The feature marginal of the coordinate-label pushforward is the coordinate
pushforward of the original feature marginal.
-/
theorem featureCoordinateJointMap_fst_marginal
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) {r : X → ℝ} (hr : Measurable r) :
    Measure.map Prod.fst (Measure.map (featureCoordinateJointMap (Y := Y) r) μ) =
      Measure.map r (Measure.map Prod.fst μ) := by
  rw [Measure.map_map measurable_fst (measurable_featureCoordinateJointMap (Y := Y) hr)]
  rw [Measure.map_map hr measurable_fst]
  rfl

/-- If a feature posterior factors through a coordinate, its paper MAE does too. -/
theorem paperConditionalMAE_featureCoordinate_factor
    {X Y : Type*} [Fintype Y]
    (q : X → Y → ℝ) (qCoord : ℝ → Y → ℝ) {r : X → ℝ}
    (hfactor : ∀ x a, q x a = qCoord (r x) a) (x : X) :
    Finite.paperConditionalMAE q x = Finite.paperConditionalMAE qCoord (r x) := by
  classical
  unfold Finite.paperConditionalMAE
  refine Finset.sum_congr rfl ?_
  intro a _
  rw [hfactor x a]

/--
Aggregate-posterior pullback across the coordinate-label map, for posteriors
that factor through the coordinate.
-/
theorem continuousJointAggregatePosterior_featureCoordinate_pullback
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) {r : X → ℝ} (hr : Measurable r)
    (q : X → Y → ℝ) (qCoord : ℝ → Y → ℝ) (z : Y)
    (hqCoordz : Measurable fun t : ℝ => qCoord t z)
    (hfactor : ∀ x, q x z = qCoord (r x) z) :
    continuousJointAggregatePosterior μ q z =
      continuousJointAggregatePosterior
        (Measure.map (featureCoordinateJointMap (Y := Y) r) μ) qCoord z := by
  unfold continuousJointAggregatePosterior
  have hmeas :
      AEStronglyMeasurable
        (fun xy : ℝ × Y => qCoord xy.1 z)
        (Measure.map (featureCoordinateJointMap (Y := Y) r) μ) :=
    (hqCoordz.comp measurable_fst).aestronglyMeasurable
  calc
    (∫ xy : X × Y, q xy.1 z ∂μ) =
        ∫ xy : X × Y, qCoord (r xy.1) z ∂μ := by
          exact integral_congr_ae
            (Filter.Eventually.of_forall fun xy => hfactor xy.1)
    _ = ∫ xy : ℝ × Y, qCoord xy.1 z
          ∂(Measure.map (featureCoordinateJointMap (Y := Y) r) μ) :=
        (integral_map
          (measurable_featureCoordinateJointMap (Y := Y) hr).aemeasurable hmeas).symm

/--
Weighted feature-region mass pulls back across the coordinate-label joint map
when the weight factors through the coordinate.
-/
theorem jointFeatureSetWeightedMass_featureCoordinate_pullback
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) {r : X → ℝ} (hr : Measurable r)
    (A : Set ℝ) (w : X → ℝ) (wCoord : ℝ → ℝ)
    (hA : MeasurableSet A) (hwCoord : Measurable wCoord)
    (hfactor : ∀ x, w x = wCoord (r x)) :
    jointFeatureSetWeightedMass μ (r ⁻¹' A) w =
      jointFeatureSetWeightedMass
        (Measure.map (featureCoordinateJointMap (Y := Y) r) μ) A wCoord := by
  unfold jointFeatureSetWeightedMass
  have hmeas :
      AEStronglyMeasurable
        (fun xy : ℝ × Y => A.indicator wCoord xy.1)
        (Measure.map (featureCoordinateJointMap (Y := Y) r) μ) :=
    ((hwCoord.indicator hA).comp measurable_fst).aestronglyMeasurable
  have hpoint : ∀ xy : X × Y,
      (r ⁻¹' A).indicator w xy.1 =
        A.indicator wCoord (r xy.1) := by
    intro xy
    by_cases hx : r xy.1 ∈ A <;> simp [Set.indicator, hx, hfactor xy.1]
  calc
    (∫ xy : X × Y, (r ⁻¹' A).indicator w xy.1 ∂μ) =
        ∫ xy : X × Y, A.indicator wCoord (r xy.1) ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ = ∫ xy : ℝ × Y, A.indicator wCoord xy.1
          ∂(Measure.map (featureCoordinateJointMap (Y := Y) r) μ) :=
        (integral_map
          (measurable_featureCoordinateJointMap (Y := Y) hr).aemeasurable hmeas).symm

/-- Feature-set mass pulls back across the coordinate-label joint map. -/
theorem jointFeatureSetMass_featureCoordinate_pullback
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) {r : X → ℝ} (hr : Measurable r)
    (A : Set ℝ) (hA : MeasurableSet A) :
    jointFeatureSetMass μ (r ⁻¹' A) =
      jointFeatureSetMass
        (Measure.map (featureCoordinateJointMap (Y := Y) r) μ) A := by
  simpa [jointFeatureSetMass] using
    jointFeatureSetWeightedMass_featureCoordinate_pullback
      μ hr A (fun _ : X => (1 : ℝ)) (fun _ : ℝ => (1 : ℝ))
      hA measurable_const (fun _ => rfl)

/--
Focal score-mass pulls back across the coordinate-label joint map when the
focal score factors through the coordinate.
-/
theorem jointFeatureSetScoreMass_featureCoordinate_pullback
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) {r : X → ℝ} (hr : Measurable r)
    (A : Set ℝ) (q : X → Y → ℝ) (qCoord : ℝ → Y → ℝ) (z : Y)
    (hA : MeasurableSet A)
    (hqCoordz : Measurable fun t : ℝ => qCoord t z)
    (hfactor : ∀ x, q x z = qCoord (r x) z) :
    jointFeatureSetScoreMass μ q (r ⁻¹' A) z =
      jointFeatureSetScoreMass
        (Measure.map (featureCoordinateJointMap (Y := Y) r) μ) qCoord A z := by
  simpa [jointFeatureSetScoreMass] using
    jointFeatureSetWeightedMass_featureCoordinate_pullback
      μ hr A (fun x : X => q x z) (fun t : ℝ => qCoord t z)
      hA hqCoordz hfactor

/--
MAE-delta pullback across the coordinate-label map, for a pair of posteriors
that both factor through the coordinate.
-/
theorem integral_paperConditionalMAE_delta_featureCoordinate_pullback
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y] [Fintype Y]
    (μ : Measure (X × Y)) {r : X → ℝ} (hr : Measurable r)
    (q qNext : X → Y → ℝ) (qCoord qNextCoord : ℝ → Y → ℝ)
    (hqCoord : ∀ a : Y, Measurable fun t : ℝ => qCoord t a)
    (hqNextCoord : ∀ a : Y, Measurable fun t : ℝ => qNextCoord t a)
    (hfactor : ∀ x a, q x a = qCoord (r x) a)
    (hfactorNext : ∀ x a, qNext x a = qNextCoord (r x) a) :
    (∫ xy : X × Y,
        (Finite.paperConditionalMAE qNext xy.1 -
          Finite.paperConditionalMAE q xy.1) ∂μ) =
      ∫ xy : ℝ × Y,
        (Finite.paperConditionalMAE qNextCoord xy.1 -
          Finite.paperConditionalMAE qCoord xy.1)
        ∂(Measure.map (featureCoordinateJointMap (Y := Y) r) μ) := by
  classical
  let T : X × Y → ℝ × Y := featureCoordinateJointMap (Y := Y) r
  have hT : Measurable T := measurable_featureCoordinateJointMap (Y := Y) hr
  have hmeas :
      AEStronglyMeasurable
        (fun xy : ℝ × Y =>
          Finite.paperConditionalMAE qNextCoord xy.1 -
            Finite.paperConditionalMAE qCoord xy.1)
        (Measure.map T μ) := by
    have hnext :
        Measurable
          (fun xy : ℝ × Y => Finite.paperConditionalMAE qNextCoord xy.1) :=
      measurable_jointConditionalMAE_of_scores qNextCoord
        (fun a => (hqNextCoord a).comp measurable_fst)
    have hcur :
        Measurable
          (fun xy : ℝ × Y => Finite.paperConditionalMAE qCoord xy.1) :=
      measurable_jointConditionalMAE_of_scores qCoord
        (fun a => (hqCoord a).comp measurable_fst)
    exact (hnext.sub hcur).aestronglyMeasurable
  have hpoint : ∀ xy : X × Y,
      (Finite.paperConditionalMAE qNext xy.1 -
          Finite.paperConditionalMAE q xy.1) =
        (Finite.paperConditionalMAE qNextCoord (r xy.1) -
          Finite.paperConditionalMAE qCoord (r xy.1)) := by
    intro xy
    rw [paperConditionalMAE_featureCoordinate_factor qNext qNextCoord hfactorNext xy.1]
    rw [paperConditionalMAE_featureCoordinate_factor q qCoord hfactor xy.1]
  calc
    (∫ xy : X × Y,
        (Finite.paperConditionalMAE qNext xy.1 -
          Finite.paperConditionalMAE q xy.1) ∂μ) =
        ∫ xy : X × Y,
          (Finite.paperConditionalMAE qNextCoord (r xy.1) -
            Finite.paperConditionalMAE qCoord (r xy.1)) ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ = ∫ xy : ℝ × Y,
        (Finite.paperConditionalMAE qNextCoord xy.1 -
          Finite.paperConditionalMAE qCoord xy.1) ∂(Measure.map T μ) :=
        (integral_map hT.aemeasurable hmeas).symm

theorem intervalIntegral_indicator_eq_inter_indicator_integral
    {μ : Measure ℝ} {lo hi : ℝ} {S : Set ℝ} {f : ℝ → ℝ}
    (hlohi : lo ≤ hi) :
    (∫ x in lo..hi, S.indicator f x ∂μ) =
      ∫ x, (S ∩ Ioc lo hi).indicator f x ∂μ := by
  rw [intervalIntegral.integral_of_le hlohi]
  rw [← integral_indicator measurableSet_Ioc]
  refine integral_congr_ae (Filter.Eventually.of_forall ?_)
  intro x
  by_cases hxS : x ∈ S
  · by_cases hxI : x ∈ Ioc lo hi
    · simp [Set.indicator, hxS, hxI]
    · simp [Set.indicator, hxS, hxI]
  · by_cases hxI : x ∈ Ioc lo hi
    · simp [Set.indicator, hxS, hxI]
    · simp [Set.indicator, hxS, hxI]

/--
Coordinate-sweep `S_b` split.

This is the explicit easier source-route statement for a general feature space:
if the focal score factors through a real coordinate `r`, then the real subset
sweep can be pulled back to feature sets
`r ⁻¹' (S ∩ (cut, hi])` and `r ⁻¹' (S ∩ (lo, cut])`.
-/
theorem sourceSb_coordinate_subset_interval_split_preserves_focal_score_mass_simplex_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSingletonClass Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    {r : X → ℝ} (hr : Measurable r)
    [NoAtoms (Measure.map r (Measure.map Prod.fst μ))]
    (q : X → Y → ℝ) (qCoord : ℝ → Y → ℝ) (z : Y)
    {lo hi : ℝ} {S : Set ℝ}
    (hlohi : lo ≤ hi) (hS : MeasurableSet S)
    (hqz : Measurable fun x : X => q x z)
    (hqCoordz : Measurable fun t : ℝ => qCoord t z)
    (hcoord : ∀ x : X, q x z = qCoord (r x) z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hsumCoord : ∀ t, (∑ a : Y, qCoord t a) = 1)
    (hnonnegCoord : ∀ t y, 0 ≤ qCoord t y)
    (hregion :
      ∀ t, t ∈ S → t ∈ Icc lo hi →
        t ∈ sourceSbRegion qCoord z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      jointFeatureSetScoreMass μ q
          ((r ⁻¹' (S ∩ Ioc cut hi)) ∪ (r ⁻¹' (S ∩ Ioc lo cut))) z =
        jointFeatureSetMass μ (r ⁻¹' (S ∩ Ioc cut hi)) +
          (Fintype.card Y : ℝ)⁻¹ *
            jointFeatureSetMass μ (r ⁻¹' (S ∩ Ioc lo cut)) := by
  classical
  let νX : Measure X := Measure.map Prod.fst μ
  let νR : Measure ℝ := Measure.map r νX
  have hfinite : νR (Icc lo hi) < ⊤ := by
    simpa [νX, νR] using featureCoordinate_map_Icc_lt_top μ hr lo hi
  rcases exists_source_Sb_balancing_subset_interval_cut_of_region_subset_uniform_simplex
      (μ := νR) (lo := lo) (hi := hi) (S := S) (q := qCoord) (z := z)
      hlohi hfinite hS hqCoordz hsumCoord hnonnegCoord hregion with
    ⟨cut, hcut, hbalanceInterval⟩
  have hlocut : lo ≤ cut := hcut.1
  have hcut_hi : cut ≤ hi := hcut.2
  have hleftInter :
      (∫ t in lo..cut,
          S.indicator
            (fun t : ℝ => qCoord t z - (Fintype.card Y : ℝ)⁻¹) t ∂νR) =
        ∫ t, (S ∩ Ioc lo cut).indicator
          (fun t : ℝ => qCoord t z - (Fintype.card Y : ℝ)⁻¹) t ∂νR :=
    intervalIntegral_indicator_eq_inter_indicator_integral
      (μ := νR) (lo := lo) (hi := cut) (S := S)
      (f := fun t : ℝ => qCoord t z - (Fintype.card Y : ℝ)⁻¹) hlocut
  have hrightInter :
      (∫ t in cut..hi,
          S.indicator (fun t : ℝ => 1 - qCoord t z) t ∂νR) =
        ∫ t, (S ∩ Ioc cut hi).indicator
          (fun t : ℝ => 1 - qCoord t z) t ∂νR :=
    intervalIntegral_indicator_eq_inter_indicator_integral
      (μ := νR) (lo := cut) (hi := hi) (S := S)
      (f := fun t : ℝ => 1 - qCoord t z) hcut_hi
  have hleftMap :
      (∫ x, (r ⁻¹' (S ∩ Ioc lo cut)).indicator
            (fun x : X => q x z - (Fintype.card Y : ℝ)⁻¹) x ∂νX) =
        ∫ t, (S ∩ Ioc lo cut).indicator
          (fun t : ℝ => qCoord t z - (Fintype.card Y : ℝ)⁻¹) t ∂νR := by
    have hpoint : ∀ x : X,
        (r ⁻¹' (S ∩ Ioc lo cut)).indicator
            (fun x : X => q x z - (Fintype.card Y : ℝ)⁻¹) x =
          (r ⁻¹' (S ∩ Ioc lo cut)).indicator
            (fun x : X => qCoord (r x) z - (Fintype.card Y : ℝ)⁻¹) x := by
      intro x
      by_cases hx : x ∈ r ⁻¹' (S ∩ Ioc lo cut)
      · rw [Set.indicator_of_mem hx, Set.indicator_of_mem hx, hcoord x]
      · rw [Set.indicator_of_notMem hx, Set.indicator_of_notMem hx]
    calc
      (∫ x, (r ⁻¹' (S ∩ Ioc lo cut)).indicator
            (fun x : X => q x z - (Fintype.card Y : ℝ)⁻¹) x ∂νX) =
          ∫ x, (r ⁻¹' (S ∩ Ioc lo cut)).indicator
            (fun x : X => qCoord (r x) z - (Fintype.card Y : ℝ)⁻¹) x ∂νX := by
            exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
      _ = ∫ t, (S ∩ Ioc lo cut).indicator
          (fun t : ℝ => qCoord t z - (Fintype.card Y : ℝ)⁻¹) t ∂νR := by
            simpa [νR] using
              integral_coordinate_preimage_indicator_eq_map_integral
                (μ := νX) hr (S ∩ Ioc lo cut)
                (fun t : ℝ => qCoord t z - (Fintype.card Y : ℝ)⁻¹)
                (hS.inter measurableSet_Ioc) (hqCoordz.sub measurable_const)
  have hrightMap :
      (∫ x, (r ⁻¹' (S ∩ Ioc cut hi)).indicator
            (fun x : X => 1 - q x z) x ∂νX) =
        ∫ t, (S ∩ Ioc cut hi).indicator
          (fun t : ℝ => 1 - qCoord t z) t ∂νR := by
    have hpoint : ∀ x : X,
        (r ⁻¹' (S ∩ Ioc cut hi)).indicator
            (fun x : X => 1 - q x z) x =
          (r ⁻¹' (S ∩ Ioc cut hi)).indicator
            (fun x : X => 1 - qCoord (r x) z) x := by
      intro x
      by_cases hx : x ∈ r ⁻¹' (S ∩ Ioc cut hi)
      · rw [Set.indicator_of_mem hx, Set.indicator_of_mem hx, hcoord x]
      · rw [Set.indicator_of_notMem hx, Set.indicator_of_notMem hx]
    calc
      (∫ x, (r ⁻¹' (S ∩ Ioc cut hi)).indicator
            (fun x : X => 1 - q x z) x ∂νX) =
          ∫ x, (r ⁻¹' (S ∩ Ioc cut hi)).indicator
            (fun x : X => 1 - qCoord (r x) z) x ∂νX := by
            exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
      _ = ∫ t, (S ∩ Ioc cut hi).indicator
          (fun t : ℝ => 1 - qCoord t z) t ∂νR := by
            simpa [νR] using
              integral_coordinate_preimage_indicator_eq_map_integral
                (μ := νX) hr (S ∩ Ioc cut hi)
                (fun t : ℝ => 1 - qCoord t z)
                (hS.inter measurableSet_Ioc) (measurable_const.sub hqCoordz)
  have hbalance :
      (∫ x, (r ⁻¹' (S ∩ Ioc lo cut)).indicator
            (fun x : X => q x z - (Fintype.card Y : ℝ)⁻¹) x ∂νX) =
        ∫ x, (r ⁻¹' (S ∩ Ioc cut hi)).indicator
          (fun x : X => 1 - q x z) x ∂νX := by
    rw [hleftMap, hrightMap, ← hleftInter, ← hrightInter]
    exact hbalanceInterval
  have hupperMeas : MeasurableSet (r ⁻¹' (S ∩ Ioc cut hi)) :=
    (hS.inter measurableSet_Ioc).preimage hr
  have hlowerMeas : MeasurableSet (r ⁻¹' (S ∩ Ioc lo cut)) :=
    (hS.inter measurableSet_Ioc).preimage hr
  have hdisj :
      Disjoint (r ⁻¹' (S ∩ Ioc cut hi)) (r ⁻¹' (S ∩ Ioc lo cut)) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    change r x ∈ S ∩ Ioc cut hi at hx_hi
    change r x ∈ S ∩ Ioc lo cut at hx_lo
    exact (not_lt_of_ge hx_lo.2.2) hx_hi.2.1
  refine ⟨cut, hcut, ?_⟩
  exact
    sourceSb_featureMarginal_balance_preserves_focal_score_mass_simplex_finite
      μ q (r ⁻¹' (S ∩ Ioc cut hi)) (r ⁻¹' (S ∩ Ioc lo cut)) z
      (Fintype.card Y : ℝ)⁻¹ hupperMeas hlowerMeas hqz hsum hnonneg
      uniform_inverse_card_nonneg (uniform_inverse_card_le_one z)
      hdisj
      (by simpa [νX] using hbalance)

/--
