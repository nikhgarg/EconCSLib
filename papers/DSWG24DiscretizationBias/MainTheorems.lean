/-- The iid product PMF on finite samples `Fin N → X`. -/
noncomputable def iidSamplePMF {X : Type*} [Fintype X] [DecidableEq X]
    (μ : PMF X) (N : ℕ) : PMF (Fin N → X) :=
  PMF.ofFintype (fun sample : Fin N → X => ∏ i : Fin N, μ (sample i)) (by
    classical
    have hsum_mu : (∑ x : X, μ x) = 1 := by
      simpa [tsum_fintype] using (PMF.tsum_coe μ)
    have hprod :=
      Finset.prod_univ_sum
        (t := fun _ : Fin N => (Finset.univ : Finset X))
        (f := fun _ x => μ x)
    have hprod' :
        (∏ _i : Fin N, ∑ x : X, μ x) =
          ∑ sample : Fin N → X, ∏ i : Fin N, μ (sample i) := by
      simpa [Fintype.piFinset_univ] using hprod
    rw [← hprod']
    simp [hsum_mu])

/-- The constant sample used to witness the positive-probability iid event. -/
def constantSample {X : Type*} {N : ℕ} (x : X) : Fin N → X :=
  fun _ => x

theorem iidSamplePMF_constantSample_apply_toReal_pos
    {X : Type*} [Fintype X] [DecidableEq X]
    (μ : PMF X) (N : ℕ) (x : X)
    (hmass : 0 < (μ x).toReal) :
    0 < ((iidSamplePMF μ N) (constantSample (N := N) x)).toReal := by
  have hprod_pos : 0 < ∏ _i : Fin N, (μ x).toReal :=
    Finset.prod_pos (fun _ _ => hmass)
  simpa [iidSamplePMF, constantSample] using hprod_pos

theorem iidSamplePMF_coordinate_mass_pos_of_sample_mass_pos
    {X : Type*} [Fintype X] [DecidableEq X]
    (μ : PMF X) (N : ℕ) (sample : Fin N → X) (i : Fin N)
    (hmass : 0 < ((iidSamplePMF μ N) sample).toReal) :
    0 < (μ (sample i)).toReal := by
  classical
  have hprod_pos : 0 < ∏ j : Fin N, (μ (sample j)).toReal := by
    simpa [iidSamplePMF] using hmass
  have hcoord_ne : (μ (sample i)).toReal ≠ 0 := by
    intro hzero
    have hprod_zero : (∏ j : Fin N, (μ (sample j)).toReal) = 0 := by
      rw [Finset.prod_eq_zero_iff]
      exact ⟨i, Finset.mem_univ i, hzero⟩
    exact (ne_of_gt hprod_pos) hprod_zero
  have hcoord_nonneg : 0 ≤ (μ (sample i)).toReal := ENNReal.toReal_nonneg
  exact lt_of_le_of_ne hcoord_nonneg hcoord_ne.symm

theorem iidSamplePMF_allRowsEvent_pos_of_event_pos
    {X : Type*} [Fintype X] [DecidableEq X]
    (μ : PMF X) (N : ℕ) (event : X → Prop) [DecidablePred event]
    (hpos : 0 < EconCSLib.pmfProb μ event) :
    0 < EconCSLib.pmfProb (iidSamplePMF μ N)
      (fun sample : Fin N → X => ∀ i : Fin N, event (sample i)) := by
  classical
  rcases (EconCSLib.pmfProb_pos_iff_exists_pos_mass
    (μ := μ) (p := event)).mp hpos with
    ⟨x, hx, hmass⟩
  exact EconCSLib.pmfProb_pos_of_mass
    (iidSamplePMF μ N)
    (fun sample : Fin N → X => ∀ i : Fin N, event (sample i))
    (constantSample (N := N) x)
    (by intro i; exact hx)
    (iidSamplePMF_constantSample_apply_toReal_pos μ N x hmass)

theorem exists_positive_mass_allRowsEvent_sample_of_event_pos
    {X : Type*} [Fintype X] [DecidableEq X]
    (μ : PMF X) (N : ℕ) (event : X → Prop) [DecidablePred event]
    (hpos : 0 < EconCSLib.pmfProb μ event) :
    ∃ sample : Fin N → X,
      (∀ i : Fin N, event (sample i)) ∧
        0 < ((iidSamplePMF μ N) sample).toReal := by
  classical
  rcases (EconCSLib.pmfProb_pos_iff_exists_pos_mass
    (μ := μ) (p := event)).mp hpos with
    ⟨x, hx, hmass⟩
  exact ⟨constantSample (N := N) x, (by intro i; exact hx),
    iidSamplePMF_constantSample_apply_toReal_pos μ N x hmass⟩

theorem iidSamplePMF_sampledDecision_ne_eq_zero_of_rule_ne_eq_zero
    {X : Type*} [Fintype X] [DecidableEq X] {N K : ℕ}
    (μ : PMF X) (rule argmaxRule : X → Fin K)
    (hzero : EconCSLib.pmfProb μ (fun x : X => rule x ≠ argmaxRule x) = 0) :
    EconCSLib.pmfProb (iidSamplePMF μ N)
      (fun sample : Fin N → X =>
        sampledDecision rule sample ≠ sampledDecision argmaxRule sample) = 0 := by
  classical
  refine EconCSLib.pmfProb_eq_zero_of_no_mass
    (iidSamplePMF μ N)
    (fun sample : Fin N → X =>
      sampledDecision rule sample ≠ sampledDecision argmaxRule sample) ?_
  intro sample hne
  by_contra hmass_ne
  have hmass_ne' : ((iidSamplePMF μ N) sample).toReal ≠ 0 := hmass_ne
  have hmass_pos : 0 < ((iidSamplePMF μ N) sample).toReal :=
    lt_of_le_of_ne ENNReal.toReal_nonneg hmass_ne'.symm
  have hrow : ∃ i : Fin N, rule (sample i) ≠ argmaxRule (sample i) := by
    by_contra hno
    apply hne
    funext i
    by_contra hi
    exact hno ⟨i, hi⟩
  rcases hrow with ⟨i, hi⟩
  have hcoord : 0 < (μ (sample i)).toReal :=
    iidSamplePMF_coordinate_mass_pos_of_sample_mass_pos μ N sample i hmass_pos
  have hbase_pos : 0 < EconCSLib.pmfProb μ (fun x : X => rule x ≠ argmaxRule x) :=
    EconCSLib.pmfProb_pos_of_mass μ (fun x : X => rule x ≠ argmaxRule x)
      (sample i) hi hcoord
  rw [hzero] at hbase_pos
  exact (lt_irrefl (0 : ℝ)) hbase_pos

theorem paper_theorem2iii_expected_accuracy_eq_of_independent_rule_agrees_ae
    {X : Type*} [Fintype X] [DecidableEq X] {N K : ℕ}
    (μ : PMF X) (posterior : X → Fin K → ℝ)
    (rule argmaxRule : X → Fin K)
    (hzero : EconCSLib.pmfProb μ (fun x : X => rule x ≠ argmaxRule x) = 0) :
    expectedDatasetAccuracy (iidSamplePMF μ N)
        (fun sample => sampledPosterior posterior sample)
        (fun sample => sampledDecision rule sample) =
      expectedDatasetAccuracy (iidSamplePMF μ N)
        (fun sample => sampledPosterior posterior sample)
        (fun sample => sampledDecision argmaxRule sample) := by
  exact expectedDatasetAccuracy_eq_of_policy_eq_zero_prob
    (iidSamplePMF μ N) (fun sample => sampledPosterior posterior sample)
    (fun sample => sampledDecision rule sample)
    (fun sample => sampledDecision argmaxRule sample)
    (iidSamplePMF_sampledDecision_ne_eq_zero_of_rule_ne_eq_zero
      μ rule argmaxRule hzero)

theorem paper_theorem2iii_expected_fidelity_eq_of_independent_rule_agrees_ae
    {X : Type*} [Fintype X] [DecidableEq X] {N K : ℕ}
    (μ : PMF X) (pref : Fin K → ℝ)
    (rule argmaxRule : X → Fin K)
    (hzero : EconCSLib.pmfProb μ (fun x : X => rule x ≠ argmaxRule x) = 0) :
    expectedDatasetFidelity (iidSamplePMF μ N) pref
        (fun sample => sampledDecision rule sample) =
      expectedDatasetFidelity (iidSamplePMF μ N) pref
        (fun sample => sampledDecision argmaxRule sample) := by
  exact expectedDatasetFidelity_eq_of_policy_eq_zero_prob
    (iidSamplePMF μ N) pref
    (fun sample => sampledDecision rule sample)
    (fun sample => sampledDecision argmaxRule sample)
    (iidSamplePMF_sampledDecision_ne_eq_zero_of_rule_ne_eq_zero
      μ rule argmaxRule hzero)

theorem paper_theorem2iii_expected_weightedObjective_eq_of_independent_rule_agrees_ae
    {X : Type*} [Fintype X] [DecidableEq X] {N K : ℕ}
    (μ : PMF X) (posterior : X → Fin K → ℝ) (pref : Fin K → ℝ)
    (rule argmaxRule : X → Fin K) (γ : ℝ)
    (hzero : EconCSLib.pmfProb μ (fun x : X => rule x ≠ argmaxRule x) = 0) :
    Pareto.weightedObjective γ
        (expectedDatasetAccuracy (iidSamplePMF μ N)
          (fun sample => sampledPosterior posterior sample))
        (expectedDatasetFidelity (iidSamplePMF μ N) pref)
        (fun sample => sampledDecision rule sample) =
      Pareto.weightedObjective γ
        (expectedDatasetAccuracy (iidSamplePMF μ N)
          (fun sample => sampledPosterior posterior sample))
        (expectedDatasetFidelity (iidSamplePMF μ N) pref)
        (fun sample => sampledDecision argmaxRule sample) := by
  exact expectedDataset_weightedObjective_eq_of_policy_eq_zero_prob
    (iidSamplePMF μ N) (fun sample => sampledPosterior posterior sample) pref
    (fun sample => sampledDecision rule sample)
    (fun sample => sampledDecision argmaxRule sample) γ
    (iidSamplePMF_sampledDecision_ne_eq_zero_of_rule_ne_eq_zero
      μ rule argmaxRule hzero)

/-- Event that an independent rule disagrees with argmax toward a fixed target class. -/
def allDisagreementAtom {X : Type*} {K : ℕ}
    (rule argmaxRule : X → Fin K) (target : Fin K) (x : X) : Prop :=
  argmaxRule x = target ∧ rule x ≠ target

/-- Set form of `allDisagreementAtom`, used by measure-theoretic iid products. -/
def allDisagreementSet {X : Type*} {K : ℕ}
    (rule argmaxRule : X → Fin K) (target : Fin K) : Set X :=
  {x | allDisagreementAtom rule argmaxRule target x}

/--
All-disagreement event for an augmented realized-randomness space.  The rule may
depend on the augmented atom, while the argmax benchmark depends only on the
projected feature.
-/
def augmentedAllDisagreementSet {Z X : Type*} {K : ℕ}
    (feature : Z → X) (rule : Z → Fin K) (argmaxRule : X → Fin K)
    (target : Fin K) : Set Z :=
  allDisagreementSet rule (fun z => argmaxRule (feature z)) target

/--
Joint law of features and realized independent randomization generated by a
feature law and a Markov/randomization kernel.
-/
noncomputable def randomizedKernelAugmentedLaw
    {X R : Type*} [MeasurableSpace X] [MeasurableSpace R]
    (μ : Measure X) (κ : ProbabilityTheory.Kernel X R) : Measure (X × R) :=
  μ ⊗ₘ κ

instance instIsFiniteMeasure_randomizedKernelAugmentedLaw
    {X R : Type*} [MeasurableSpace X] [MeasurableSpace R]
    (μ : Measure X) (κ : ProbabilityTheory.Kernel X R)
    [IsFiniteMeasure μ] [ProbabilityTheory.IsFiniteKernel κ] :
    IsFiniteMeasure (randomizedKernelAugmentedLaw μ κ) := by
  unfold randomizedKernelAugmentedLaw
  infer_instance

instance instIsProbabilityMeasure_randomizedKernelAugmentedLaw
    {X R : Type*} [MeasurableSpace X] [MeasurableSpace R]
    (μ : Measure X) (κ : ProbabilityTheory.Kernel X R)
    [IsProbabilityMeasure μ] [ProbabilityTheory.IsMarkovKernel κ] :
    IsProbabilityMeasure (randomizedKernelAugmentedLaw μ κ) := by
  unfold randomizedKernelAugmentedLaw
  infer_instance

theorem randomizedKernelAugmentedLaw_univ_of_markov
    {X R : Type*} [MeasurableSpace X] [MeasurableSpace R]
    (μ : Measure X) [SFinite μ] (κ : ProbabilityTheory.Kernel X R)
    [ProbabilityTheory.IsMarkovKernel κ] :
    randomizedKernelAugmentedLaw μ κ univ = μ univ := by
  simp [randomizedKernelAugmentedLaw]

theorem randomizedKernelAugmentedLaw_univ_of_probability
    {X R : Type*} [MeasurableSpace X] [MeasurableSpace R]
    (μ : Measure X) [IsProbabilityMeasure μ] (κ : ProbabilityTheory.Kernel X R)
    [ProbabilityTheory.IsMarkovKernel κ] :
    randomizedKernelAugmentedLaw μ κ univ = 1 := by
  simp [randomizedKernelAugmentedLaw]

/--
All-disagreement event under a feature law plus realized-randomness kernel.
-/
def kernelAllDisagreementSet {X R : Type*} {K : ℕ}
    (rule : X × R → Fin K) (argmaxRule : X → Fin K) (target : Fin K) :
    Set (X × R) :=
  augmentedAllDisagreementSet Prod.fst rule argmaxRule target

theorem iidSampleMeasure_allDisagreement_pos_of_event_pos
    {X : Type*} [MeasurableSpace X] {N K : ℕ}
