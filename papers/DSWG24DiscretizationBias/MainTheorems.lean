instance instDecidablePredAllDisagreementAtom {X : Type*} {K : ℕ}
    (rule argmaxRule : X → Fin K) (target : Fin K) :
    DecidablePred (allDisagreementAtom rule argmaxRule target) := by
  intro x
  unfold allDisagreementAtom
  infer_instance

theorem iidSamplePMF_allDisagreement_pos_of_event_pos
    {X : Type*} [Fintype X] [DecidableEq X] {N K : ℕ}
    (μ : PMF X) (rule argmaxRule : X → Fin K) (target : Fin K)
    (hpos :
      0 < EconCSLib.pmfProb μ (allDisagreementAtom rule argmaxRule target)) :
    0 < EconCSLib.pmfProb (iidSamplePMF μ N)
      (fun sample : Fin N → X =>
        ∀ i : Fin N, allDisagreementAtom rule argmaxRule target (sample i)) := by
  classical
  exact iidSamplePMF_allRowsEvent_pos_of_event_pos
    μ N (allDisagreementAtom rule argmaxRule target) hpos

theorem exists_positive_mass_allDisagreement_sample_of_event_pos
    {X : Type*} [Fintype X] [DecidableEq X] {N K : ℕ}
    (μ : PMF X) (rule argmaxRule : X → Fin K) (target : Fin K)
    (hpos :
      0 < EconCSLib.pmfProb μ (allDisagreementAtom rule argmaxRule target)) :
    ∃ sample : Fin N → X,
      (∀ i : Fin N, allDisagreementAtom rule argmaxRule target (sample i)) ∧
        0 < ((iidSamplePMF μ N) sample).toReal := by
  classical
  exact exists_positive_mass_allRowsEvent_sample_of_event_pos
    μ N (allDisagreementAtom rule argmaxRule target) hpos

theorem exists_target_allDisagreement_event_pos_of_disagreement_event_pos
    {X : Type*} [Fintype X] [DecidableEq X] {K : ℕ}
    (μ : PMF X) (rule argmaxRule : X → Fin K)
    (hpos :
      0 < EconCSLib.pmfProb μ (fun x : X => rule x ≠ argmaxRule x)) :
    ∃ target : Fin K,
      0 < EconCSLib.pmfProb μ
        (allDisagreementAtom rule argmaxRule target) := by
  classical
  rcases (EconCSLib.pmfProb_pos_iff_exists_pos_mass
    (μ := μ) (p := fun x : X => rule x ≠ argmaxRule x)).mp hpos with
    ⟨x, hne, hmass⟩
  refine ⟨argmaxRule x, ?_⟩
  exact EconCSLib.pmfProb_pos_of_mass μ
    (allDisagreementAtom rule argmaxRule (argmaxRule x)) x
    ⟨rfl, hne⟩ hmass

/--
Theorem 2(iii), independent-rule bridge for a selected all-disagreement sample.

Once the source probability argument has selected a dataset whose every row has
the same argmax target and whose independent decisions avoid that target, the
deterministic missing-argmax-class theorem applies directly.
-/
theorem paper_theorem2iii_not_pareto_of_independent_all_disagreement_sample
    {X : Type*} {N K : ℕ}
    (posterior : X → Fin K → ℝ) (pref : Fin K → ℝ)
    (rule argmaxRule : X → Fin K) (sample : Fin N → X) (target : Fin K)
    (hNpos : 0 < N)
    (hall :
      ∀ i : Fin N, argmaxRule (sample i) = target ∧ rule (sample i) ≠ target)
    (hpref_nonneg : ∀ y, 0 ≤ pref y)
    (hpref_sum : (∑ y : Fin K, pref y) = 1)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target)
    (hweak_argmax : ∀ x y, posterior x y ≤ posterior x (argmaxRule x)) :
    ¬ Pareto.ParetoOptimal
      (datasetAccuracyScore (sampledPosterior posterior sample))
      (datasetFidelity pref) (sampledDecision rule sample) := by
  refine paper_theorem2iii_not_pareto_of_missing_argmax_class
    (sampledPosterior posterior sample) pref (sampledDecision rule sample)
    target hNpos ?_ hpref_nonneg hpref_sum hnontrivial ?_
  · intro i
    exact (hall i).2
  · intro i
    have htarget : argmaxRule (sample i) = target := (hall i).1
    simpa [sampledPosterior, sampledDecision, htarget] using
      hweak_argmax (sample i) (rule (sample i))

theorem exists_weak_accuracy_strict_fidelity_switch_of_independent_all_disagreement_sample
    {X : Type*} {N K : ℕ}
    (posterior : X → Fin K → ℝ) (pref : Fin K → ℝ)
    (rule argmaxRule : X → Fin K) (sample : Fin N → X) (target : Fin K)
    (hNpos : 0 < N)
    (hall :
      ∀ i : Fin N, argmaxRule (sample i) = target ∧ rule (sample i) ≠ target)
    (hpref_nonneg : ∀ y, 0 ≤ pref y)
    (hpref_sum : (∑ y : Fin K, pref y) = 1)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target)
    (hweak_argmax : ∀ x y, posterior x y ≤ posterior x (argmaxRule x)) :
    ∃ betterDecision : Fin N → Fin K,
      datasetAccuracyScore (sampledPosterior posterior sample)
          (sampledDecision rule sample) ≤
        datasetAccuracyScore (sampledPosterior posterior sample) betterDecision ∧
      datasetFidelity pref (sampledDecision rule sample) <
        datasetFidelity pref betterDecision := by
  let decision := sampledDecision rule sample
  let posteriorAt := sampledPosterior posterior sample
  have hnone : ∀ j : Fin N, decision j ≠ target := by
    intro j
    exact (hall j).2
  rcases exists_row_strictly_overallocated_of_missing_label
    pref decision target hNpos hnone hpref_nonneg hpref_sum hnontrivial with
    ⟨i, hover_pos⟩
  have hne : decision i ≠ target := hnone i
  have hunder : datasetLabelShare decision target + 1 / (N : ℝ) ≤ pref target := by
    rw [datasetLabelShare_eq_zero_of_forall_ne decision target hnone]
    simpa using hnontrivial
  have hacc_row : posteriorAt i (decision i) ≤ posteriorAt i target := by
    have htarget : argmaxRule (sample i) = target := (hall i).1
    simpa [posteriorAt, decision, sampledPosterior, sampledDecision, htarget] using
      hweak_argmax (sample i) (rule (sample i))
  refine ⟨switchDecision decision i target, ?_, ?_⟩
  · exact datasetAccuracyScore_le_of_switch_to_weakly_better_label
      posteriorAt decision i target hacc_row
  · exact datasetFidelity_lt_of_switch_under_pos_over
      pref decision i target hne hunder hover_pos

theorem exists_strict_accuracy_strict_fidelity_switch_of_independent_all_disagreement_sample
    {X : Type*} {N K : ℕ}
    (posterior : X → Fin K → ℝ) (pref : Fin K → ℝ)
    (rule argmaxRule : X → Fin K) (sample : Fin N → X) (target : Fin K)
    (hNpos : 0 < N)
    (hall :
      ∀ i : Fin N, argmaxRule (sample i) = target ∧ rule (sample i) ≠ target)
    (hpref_nonneg : ∀ y, 0 ≤ pref y)
    (hpref_sum : (∑ y : Fin K, pref y) = 1)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target)
    (hstrict_argmax :
      ∀ i : Fin N, posterior (sample i) (rule (sample i)) <
        posterior (sample i) target) :
    ∃ betterDecision : Fin N → Fin K,
      datasetAccuracyScore (sampledPosterior posterior sample)
          (sampledDecision rule sample) <
        datasetAccuracyScore (sampledPosterior posterior sample) betterDecision ∧
      datasetFidelity pref (sampledDecision rule sample) <
        datasetFidelity pref betterDecision := by
  let decision := sampledDecision rule sample
  let posteriorAt := sampledPosterior posterior sample
  have hnone : ∀ j : Fin N, decision j ≠ target := by
    intro j
    exact (hall j).2
  rcases exists_row_strictly_overallocated_of_missing_label
    pref decision target hNpos hnone hpref_nonneg hpref_sum hnontrivial with
    ⟨i, hover_pos⟩
  have hne : decision i ≠ target := hnone i
  have hunder : datasetLabelShare decision target + 1 / (N : ℝ) ≤ pref target := by
    rw [datasetLabelShare_eq_zero_of_forall_ne decision target hnone]
    simpa using hnontrivial
  have hacc_row : posteriorAt i (decision i) < posteriorAt i target := by
    simpa [posteriorAt, decision, sampledPosterior, sampledDecision] using
      hstrict_argmax i
  refine ⟨switchDecision decision i target, ?_, ?_⟩
  · exact datasetAccuracyScore_lt_of_switch_to_better_label
      posteriorAt decision i target hacc_row
  · exact datasetFidelity_lt_of_switch_under_pos_over
      pref decision i target hne hunder hover_pos

/--
Theorem 2(iii), expected-policy Pareto lift for a selected sample.

The policy-level joint rule copies the independent rule on every dataset except
the positive-mass all-disagreement sample, where it applies the verified
one-row switch.
-/
theorem paper_theorem2iii_not_expected_pareto_of_independent_all_disagreement_sample
    {X : Type*} [Fintype X] [DecidableEq X] {N K : ℕ}
    (sampleLaw : PMF (Fin N → X))
    (posterior : X → Fin K → ℝ) (pref : Fin K → ℝ)
    (rule argmaxRule : X → Fin K) (sample : Fin N → X) (target : Fin K)
    (hmass : 0 < (sampleLaw sample).toReal)
    (hNpos : 0 < N)
    (hall :
      ∀ i : Fin N, argmaxRule (sample i) = target ∧ rule (sample i) ≠ target)
    (hpref_nonneg : ∀ y, 0 ≤ pref y)
    (hpref_sum : (∑ y : Fin K, pref y) = 1)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target)
    (hweak_argmax : ∀ x y, posterior x y ≤ posterior x (argmaxRule x)) :
    ¬ Pareto.ParetoOptimal
      (expectedDatasetAccuracy sampleLaw
        (fun s => sampledPosterior posterior s))
      (expectedDatasetFidelity sampleLaw pref)
      (fun s => sampledDecision rule s) := by
  rcases exists_weak_accuracy_strict_fidelity_switch_of_independent_all_disagreement_sample
    posterior pref rule argmaxRule sample target hNpos hall hpref_nonneg
    hpref_sum hnontrivial hweak_argmax with
    ⟨betterDecision, hacc, hfid⟩
  exact not_expectedDataset_pareto_of_positive_mass_sample_dominated
    sampleLaw (fun s => sampledPosterior posterior s) pref
    (fun s => sampledDecision rule s) sample betterDecision hmass hacc hfid

/--
Theorem 2(iii), finite positive-probability iid disagreement bridge.

If the one-draw disagreement event for target class `target` has positive
probability, then iid sampling has a positive-mass dataset on which the
independent rule is not Pareto optimal for the realized dataset objective.
-/
theorem paper_theorem2iii_exists_positive_mass_sample_not_pareto_of_disagreement_event_pos
    {X : Type*} [Fintype X] [DecidableEq X] {N K : ℕ}
    (μ : PMF X) (posterior : X → Fin K → ℝ) (pref : Fin K → ℝ)
    (rule argmaxRule : X → Fin K) (target : Fin K)
    (hpos :
      0 < EconCSLib.pmfProb μ (allDisagreementAtom rule argmaxRule target))
    (hNpos : 0 < N)
    (hpref_nonneg : ∀ y, 0 ≤ pref y)
    (hpref_sum : (∑ y : Fin K, pref y) = 1)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target)
    (hweak_argmax : ∀ x y, posterior x y ≤ posterior x (argmaxRule x)) :
    ∃ sample : Fin N → X,
      0 < ((iidSamplePMF μ N) sample).toReal ∧
        ¬ Pareto.ParetoOptimal
          (datasetAccuracyScore (sampledPosterior posterior sample))
          (datasetFidelity pref) (sampledDecision rule sample) := by
  classical
  rcases exists_positive_mass_allDisagreement_sample_of_event_pos
    μ rule argmaxRule target hpos with
    ⟨sample, hall, hsample_pos⟩
  exact ⟨sample, hsample_pos,
    paper_theorem2iii_not_pareto_of_independent_all_disagreement_sample
      posterior pref rule argmaxRule sample target hNpos hall hpref_nonneg
      hpref_sum hnontrivial hweak_argmax⟩

/--
Theorem 2(iii), finite deterministic independent-rule form.

If an independent rule disagrees with the fixed argmax rule with positive
feature probability, then some positive-mass iid sample realizes a dataset on
which that independent rule is not Pareto optimal.
-/
