    (hshapeA :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ xy : ℝ × Y,
          xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
            w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) →
        ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc cut hi → ∀ a : Y,
          qNext xy.1 a =
            if a = z then 1
            else if a = w xy then q xy.1 (w xy) - (1 - q xy.1 z)
            else q xy.1 a)
    (hshapeB :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ xy : ℝ × Y,
          xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
            w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) →
        ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc lo cut → ∀ a : Y,
