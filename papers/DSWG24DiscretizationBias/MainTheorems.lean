      μ q y (hscore y) htrim
      (conditionalExpectationCalibration_of_condExpKernelCalibration
        μ q hscore hlabelInt hcal)

/--
Finite-score level-set calibration for one target label.

The source definition of calibration says that on each score level
`q(y, x) = c`, the fraction of true label-`y` mass is `c`.  This formalized
version represents the realized score levels by a finite index type `C`, with
`bin x y` selecting the score cell and `score y c` giving the cell score.
-/
def FiniteScoreCalibrationAt
    {X Y C : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y] [DecidableEq C]
    (μ : Measure (X × Y)) (score : Y → C → ℝ) (bin : X → Y → C) (y : Y) : Prop :=
  ∀ c : C,
    (∫ xy, (if bin xy.1 y = c then
        if xy.2 = y then (1 : ℝ) else 0
      else 0) ∂μ) =
      score y c * ∫ xy, (if bin xy.1 y = c then (1 : ℝ) else 0) ∂μ

/-- Finite-score level-set calibration for every label. -/
def FiniteScoreCalibration
    {X Y C : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y] [DecidableEq C]
    (μ : Measure (X × Y)) (score : Y → C → ℝ) (bin : X → Y → C) : Prop :=
  ∀ y : Y, FiniteScoreCalibrationAt μ score bin y

theorem continuousJointPrior_eq_jointAggregatePosterior_of_finiteScoreCalibrationAt
    {X Y C : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    [Fintype C] [DecidableEq C]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (score : Y → C → ℝ) (bin : X → Y → C) (y : Y)
    (hrepr : ∀ x y, q x y = score y (bin x y))
    (hlabelInt : ∀ c : C,
      Integrable
        (fun xy : X × Y => if bin xy.1 y = c then
          if xy.2 = y then (1 : ℝ) else 0
        else 0) μ)
    (hmassInt : ∀ c : C,
      Integrable
        (fun xy : X × Y => if bin xy.1 y = c then (1 : ℝ) else 0) μ)
    (hcal : FiniteScoreCalibrationAt μ score bin y) :
    continuousJointPrior μ y = continuousJointAggregatePosterior μ q y := by
  classical
  let labelFiber : C → X × Y → ℝ :=
    fun c xy => if bin xy.1 y = c then
      if xy.2 = y then (1 : ℝ) else 0
    else 0
  let massFiber : C → X × Y → ℝ :=
    fun c xy => if bin xy.1 y = c then (1 : ℝ) else 0
  have hlabel_sum :
      (fun xy : X × Y => if xy.2 = y then (1 : ℝ) else 0) =
        fun xy : X × Y => ∑ c : C, labelFiber c xy := by
    funext xy
    rw [Finset.sum_eq_single (bin xy.1 y)]
    · simp [labelFiber]
    · intro c _ hc
      simp [labelFiber, hc.symm]
    · intro hmem
      exact False.elim (hmem (Finset.mem_univ (bin xy.1 y)))
  have hscore_sum :
      (fun xy : X × Y => q xy.1 y) =
        fun xy : X × Y => ∑ c : C, score y c * massFiber c xy := by
    funext xy
    rw [Finset.sum_eq_single (bin xy.1 y)]
    · simp [massFiber, hrepr]
    · intro c _ hc
      simp [massFiber, hc.symm]
    · intro hmem
      exact False.elim (hmem (Finset.mem_univ (bin xy.1 y)))
  have hscoreInt : ∀ c : C,
      Integrable (fun xy : X × Y => score y c * massFiber c xy) μ := by
    intro c
    exact (hmassInt c).const_mul (score y c)
  calc
    continuousJointPrior μ y =
        ∫ xy, ∑ c : C, labelFiber c xy ∂μ := by
          unfold continuousJointPrior
          rw [hlabel_sum]
    _ = ∑ c : C, ∫ xy, labelFiber c xy ∂μ := by
          rw [integral_finset_sum]
          intro c _
          exact hlabelInt c
    _ = ∑ c : C, score y c * ∫ xy, massFiber c xy ∂μ := by
          refine Finset.sum_congr rfl ?_
          intro c _
          exact hcal c
    _ = ∑ c : C, ∫ xy, score y c * massFiber c xy ∂μ := by
          refine Finset.sum_congr rfl ?_
          intro c _
          rw [integral_const_mul]
    _ = ∫ xy, ∑ c : C, score y c * massFiber c xy ∂μ := by
          rw [integral_finset_sum]
          intro c _
          exact hscoreInt c
    _ = continuousJointAggregatePosterior μ q y := by
          unfold continuousJointAggregatePosterior
          rw [hscore_sum]

theorem continuousJointPrior_eq_jointAggregatePosterior_of_finiteScoreCalibration
    {X Y C : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    [Fintype C] [DecidableEq C]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (score : Y → C → ℝ) (bin : X → Y → C)
    (hrepr : ∀ x y, q x y = score y (bin x y))
    (hlabelInt : ∀ y c,
      Integrable
        (fun xy : X × Y => if bin xy.1 y = c then
          if xy.2 = y then (1 : ℝ) else 0
        else 0) μ)
    (hmassInt : ∀ y c,
      Integrable
        (fun xy : X × Y => if bin xy.1 y = c then (1 : ℝ) else 0) μ)
    (hcal : FiniteScoreCalibration μ score bin) :
    ∀ y : Y, continuousJointPrior μ y = continuousJointAggregatePosterior μ q y :=
  fun y =>
    continuousJointPrior_eq_jointAggregatePosterior_of_finiteScoreCalibrationAt
      μ q score bin y hrepr (hlabelInt y) (hmassInt y) (hcal y)

theorem continuousBias_eq_aggregateBias_of_pref_eq
    (μ : Measure X) (q : X → Y → ℝ) (rule : X → Y) (pref : Y → ℝ) (y : Y)
    (hpref : pref y = continuousAggregatePosterior μ q y) :
    continuousBias μ rule pref y = continuousAggregateBias μ q rule y := by
  unfold continuousBias continuousAggregateBias
  rw [hpref]

/--
Theorem 1(i), continuous no-information form for a supplied reference
distribution.

If the argmax rule assigns every feature value to the plurality class `z`, the
classwise bias has exactly the displayed source value.
-/
theorem paper_theorem1i_continuous_no_information_bias
    (μ : Measure X) [IsProbabilityMeasure μ] (pref : Y → ℝ) (z y : Y) :
    continuousBias μ (fun _ : X => z) pref y =
      if z = y then 1 - pref y else -pref y := by
  classical
  unfold continuousBias continuousMarginalLabelShare
  by_cases hzy : z = y <;> simp [hzy]

/--
Theorem 1(i), continuous no-information form for the aggregate-posterior
reference.
-/
theorem paper_theorem1i_continuous_no_information_aggregate_bias
    (μ : Measure X) [IsProbabilityMeasure μ]
    (q : X → Y → ℝ) (p : Y → ℝ) (z y : Y)
    (hconst : ∀ x a, q x a = p a) :
    continuousAggregateBias μ q (fun _ : X => z) y =
      if z = y then 1 - p y else -p y := by
  classical
  unfold continuousAggregateBias continuousMarginalLabelShare continuousAggregatePosterior
  have hqfun : (fun x : X => q x y) = fun _ : X => p y := by
    funext x
    exact hconst x y
  rw [hqfun]
  by_cases hzy : z = y <;> simp [hzy]

/--
Theorem 1(ii), continuous perfect-classifier form.

If the induced decision equals the true label on every joint outcome, the
prior-reference amplification bias is zero.
-/
theorem paper_theorem1ii_continuous_perfect_classifier_prior_bias_zero
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (rule : X → Y)
    (htruth : ∀ xy : X × Y, rule xy.1 = xy.2) (y : Y) :
    continuousJointPriorBias μ rule y = 0 := by
  unfold continuousJointPriorBias continuousJointDecisionShare continuousJointPrior
  have hfun :
      (fun xy : X × Y => if rule xy.1 = y then (1 : ℝ) else 0) =
        fun xy : X × Y => if xy.2 = y then (1 : ℝ) else 0 := by
    funext xy
    rw [htruth xy]
  rw [hfun]
  ring

theorem continuousAggregateBias_eq_integral_pointwise
    (μ : Measure X) (q : X → Y → ℝ) (rule : X → Y) (y : Y)
    (hind : Integrable (fun x => if rule x = y then (1 : ℝ) else 0) μ)
    (hq : Integrable (fun x => q x y) μ) :
    continuousAggregateBias μ q rule y =
      ∫ x, ((if rule x = y then (1 : ℝ) else 0) - q x y) ∂μ := by
  unfold continuousAggregateBias continuousMarginalLabelShare continuousAggregatePosterior
  rw [integral_sub hind hq]

/--
Continuous Theorem 1(iii) seam from a pointwise posterior-MAE inequality.

This is the measure-theoretic analogue of the finite PMF wrapper: if the
conditional amplification contribution is pointwise bounded by the conditional
MAE contribution, then integrating over the feature distribution gives the
paper's argmax-bias/MAE inequality.
-/
theorem paper_theorem1iii_continuous_argmax_bias_le_mae_of_pointwise
    (μ : Measure X) (q : X → Y → ℝ) (argmaxRule : X → Y) (y : Y)
    (hind : Integrable (fun x => if argmaxRule x = y then (1 : ℝ) else 0) μ)
    (hq : Integrable (fun x => q x y) μ)
    (hmae : Integrable (fun x => Finite.paperConditionalMAE q x) μ)
    (hpoint : ∀ x,
      (if argmaxRule x = y then (1 : ℝ) else 0) - q x y ≤
        Finite.paperConditionalMAE q x) :
    continuousAggregateBias μ q argmaxRule y ≤ continuousClassifierMAE μ q := by
  rw [continuousAggregateBias_eq_integral_pointwise μ q argmaxRule y hind hq]
  unfold continuousClassifierMAE
  exact integral_mono (hind.sub hq) hmae hpoint

/--
Theorem 1(iii), continuous aggregate-reference form.

For an arbitrary feature distribution, if `q x` is a probability vector at each
feature value and `argmaxRule` selects a posterior maximizer, then the
aggregate-posterior amplification bias of any class is bounded by predictive
MAE.
-/
theorem paper_theorem1iii_continuous_argmax_bias_le_mae
    (μ : Measure X) (q : X → Y → ℝ) (argmaxRule : X → Y) (y : Y)
    (hind : Integrable (fun x => if argmaxRule x = y then (1 : ℝ) else 0) μ)
    (hq : Integrable (fun x => q x y) μ)
    (hmae : Integrable (fun x => Finite.paperConditionalMAE q x) μ)
    (hargmax : ∀ x a, q x a ≤ q x (argmaxRule x))
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a)
    (hle_one : ∀ x a, q x a ≤ 1) :
    continuousAggregateBias μ q argmaxRule y ≤ continuousClassifierMAE μ q :=
  paper_theorem1iii_continuous_argmax_bias_le_mae_of_pointwise
    μ q argmaxRule y hind hq hmae
    (fun x => Finite.pointwise_argmax_bias_le_conditionalMAE
      q argmaxRule x y (hargmax x) (hsum x) (hnonneg x) (hle_one x))

/--
Theorem 1(iii), continuous prior/reference form under Bayesian consistency.

If the supplied reference distribution agrees with the aggregate posterior for
the class under inspection, the aggregate-reference MAE bound transfers to that
reference.  Instantiating `pref` as the prior and proving this equality is the
source paper's calibration/consistency bridge.
-/
theorem paper_theorem1iii_continuous_reference_bias_le_mae_of_consistency
    (μ : Measure X) (q : X → Y → ℝ) (argmaxRule : X → Y)
    (pref : Y → ℝ) (y : Y)
    (hind : Integrable (fun x => if argmaxRule x = y then (1 : ℝ) else 0) μ)
    (hq : Integrable (fun x => q x y) μ)
    (hmae : Integrable (fun x => Finite.paperConditionalMAE q x) μ)
    (hargmax : ∀ x a, q x a ≤ q x (argmaxRule x))
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a)
    (hle_one : ∀ x a, q x a ≤ 1)
    (hpref : pref y = continuousAggregatePosterior μ q y) :
    continuousBias μ argmaxRule pref y ≤ continuousClassifierMAE μ q := by
  rw [continuousBias_eq_aggregateBias_of_pref_eq μ q argmaxRule pref y hpref]
  exact paper_theorem1iii_continuous_argmax_bias_le_mae
    μ q argmaxRule y hind hq hmae hargmax hsum hnonneg hle_one

/--
Theorem 1(iii), source-facing continuous wrapper using named assumptions.

`PosteriorSimplex` records that `q(x)` is a probability vector,
`IsArgmaxRule` records the deterministic tie-broken argmax rule, and
`BayesianConsistent` is the calibration-to-prior bridge used when the reference
is the prior rather than the aggregate posterior.
-/
theorem paper_theorem1iii_continuous_reference_bias_le_mae
    (μ : Measure X) (q : X → Y → ℝ) (argmaxRule : X → Y)
    (pref : Y → ℝ) (y : Y)
    (hind : Integrable (fun x => if argmaxRule x = y then (1 : ℝ) else 0) μ)
    (hq : Integrable (fun x => q x y) μ)
    (hmae : Integrable (fun x => Finite.paperConditionalMAE q x) μ)
    (hargmax : IsArgmaxRule q argmaxRule)
    (hsimplex : PosteriorSimplex q)
    (hconsistent : BayesianConsistent μ q pref) :
    continuousBias μ argmaxRule pref y ≤ continuousClassifierMAE μ q :=
  paper_theorem1iii_continuous_reference_bias_le_mae_of_consistency
    μ q argmaxRule pref y hind hq hmae hargmax
    hsimplex.1 hsimplex.2.1 hsimplex.2.2 (hconsistent y)

