namespace Pareto

variable {Rule : Type*}

/-- Weighted accuracy/fidelity objective from Equation (3). -/
noncomputable def weightedObjective
    (γ : ℝ) (accuracy fidelity : Rule → ℝ) (rule : Rule) : ℝ :=
  γ * accuracy rule + (1 - γ) * fidelity rule

/-- A rule weakly improves both objectives and strictly improves at least one. -/
def ParetoDominates
    (accuracy fidelity : Rule → ℝ) (better worse : Rule) : Prop :=
  accuracy worse ≤ accuracy better ∧
    fidelity worse ≤ fidelity better ∧
      (accuracy worse < accuracy better ∨ fidelity worse < fidelity better)

/-- A rule strictly improves both accuracy and fidelity. -/
def StrictlyDominatesBoth
    (accuracy fidelity : Rule → ℝ) (better worse : Rule) : Prop :=
  accuracy worse < accuracy better ∧ fidelity worse < fidelity better

/-- Pareto optimality for the paper's two metrics. -/
def ParetoOptimal
    (accuracy fidelity : Rule → ℝ) (rule : Rule) : Prop :=
  ¬ ∃ better : Rule, ParetoDominates accuracy fidelity better rule

theorem paretoDominates_of_strictlyDominatesBoth
    (accuracy fidelity : Rule → ℝ) {better worse : Rule}
    (h : StrictlyDominatesBoth accuracy fidelity better worse) :
    ParetoDominates accuracy fidelity better worse :=
  ⟨le_of_lt h.1, le_of_lt h.2, Or.inl h.1⟩

theorem not_paretoOptimal_of_dominated
    (accuracy fidelity : Rule → ℝ) {rule better : Rule}
    (hdom : ParetoDominates accuracy fidelity better rule) :
    ¬ ParetoOptimal accuracy fidelity rule := by
  intro hopt
  exact hopt ⟨better, hdom⟩

theorem not_paretoOptimal_of_strictlyDominatesBoth
    (accuracy fidelity : Rule → ℝ) {rule better : Rule}
    (hdom : StrictlyDominatesBoth accuracy fidelity better rule) :
    ¬ ParetoOptimal accuracy fidelity rule :=
  not_paretoOptimal_of_dominated accuracy fidelity
    (paretoDominates_of_strictlyDominatesBoth accuracy fidelity hdom)

/--
If another rule strictly improves both components, the weighted objective is
strictly higher for every positive `γ ≤ 1`.
-/
theorem weightedObjective_lt_of_strictlyDominatesBoth
    (accuracy fidelity : Rule → ℝ) {better worse : Rule} {γ : ℝ}
    (hγpos : 0 < γ) (hγle : γ ≤ 1)
    (hdom : StrictlyDominatesBoth accuracy fidelity better worse) :
    weightedObjective γ accuracy fidelity worse <
      weightedObjective γ accuracy fidelity better := by
  unfold weightedObjective
  have hacc_nonneg : 0 ≤ γ := le_of_lt hγpos
  have hfid_nonneg : 0 ≤ 1 - γ := sub_nonneg.mpr hγle
  have hacc_strict : γ * accuracy worse < γ * accuracy better :=
    mul_lt_mul_of_pos_left hdom.1 hγpos
  have hfid_le : (1 - γ) * fidelity worse ≤ (1 - γ) * fidelity better :=
    mul_le_mul_of_nonneg_left (le_of_lt hdom.2) hfid_nonneg
  linarith

theorem not_weightedObjective_maximizer_of_strictlyDominatesBoth
    (accuracy fidelity : Rule → ℝ) {rule better : Rule} {γ : ℝ}
    (hγpos : 0 < γ) (hγle : γ ≤ 1)
    (hdom : StrictlyDominatesBoth accuracy fidelity better rule) :
    ¬ ∀ other : Rule,
        weightedObjective γ accuracy fidelity other ≤
          weightedObjective γ accuracy fidelity rule := by
  intro hmax
  have hlt := weightedObjective_lt_of_strictlyDominatesBoth
    accuracy fidelity hγpos hγle hdom
  exact not_lt_of_ge (hmax better) hlt

theorem paretoDominates_of_weakAccuracy_strictFidelity
    (accuracy fidelity : Rule → ℝ) {better worse : Rule}
    (hacc : accuracy worse ≤ accuracy better)
    (hfid : fidelity worse < fidelity better) :
    ParetoDominates accuracy fidelity better worse :=
  ⟨hacc, le_of_lt hfid, Or.inr hfid⟩

theorem weightedObjective_lt_of_weakAccuracy_strictFidelity
    (accuracy fidelity : Rule → ℝ) {better worse : Rule} {γ : ℝ}
    (hγnonneg : 0 ≤ γ) (hγlt : γ < 1)
    (hacc : accuracy worse ≤ accuracy better)
    (hfid : fidelity worse < fidelity better) :
    weightedObjective γ accuracy fidelity worse <
      weightedObjective γ accuracy fidelity better := by
  unfold weightedObjective
  have hfid_pos : 0 < 1 - γ := sub_pos.mpr hγlt
  have hacc_le : γ * accuracy worse ≤ γ * accuracy better :=
    mul_le_mul_of_nonneg_left hacc hγnonneg
  have hfid_strict : (1 - γ) * fidelity worse < (1 - γ) * fidelity better :=
    mul_lt_mul_of_pos_left hfid hfid_pos
  linarith

end Pareto

namespace Theorem2iii

/-- Per-dataset marginal share of a label among deterministic decisions. -/
noncomputable def datasetLabelShare {N K : ℕ}
    (decision : Fin N → Fin K) (y : Fin K) : ℝ :=
  (∑ i : Fin N, if decision i = y then (1 : ℝ) else 0) / (N : ℝ)

/-- Per-dataset distributional fidelity from the source paper. -/
noncomputable def datasetFidelity {N K : ℕ}
    (pref : Fin K → ℝ) (decision : Fin N → Fin K) : ℝ :=
  -∑ y : Fin K, |datasetLabelShare decision y - pref y|

/-- Per-dataset posterior-score accuracy term. -/
noncomputable def datasetAccuracyScore {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (decision : Fin N → Fin K) : ℝ :=
  EconCSLib.Decision.averageScore posterior decision

/-- Replace one row's decision by a new label. -/
def switchDecision {N K : ℕ}
    (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K) : Fin N → Fin K :=
  Function.update decision i newLabel

theorem sum_switchDecision_score_eq_sub_add {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (decision : Fin N → Fin K)
    (i : Fin N) (newLabel : Fin K) :
    (∑ j : Fin N, posterior j (switchDecision decision i newLabel j)) =
      (∑ j : Fin N, posterior j (decision j)) -
        posterior i (decision i) + posterior i newLabel := by
  classical
  let fnew : Fin N → ℝ := fun j => posterior j (switchDecision decision i newLabel j)
  let fold : Fin N → ℝ := fun j => posterior j (decision j)
  have hnew_split :
      (∑ j : Fin N, fnew j) =
        (∑ j ∈ (Finset.univ : Finset (Fin N)).erase i, fnew j) + fnew i := by
    exact ((Finset.univ : Finset (Fin N)).sum_erase_add fnew (Finset.mem_univ i)).symm
  have hold_split :
      (∑ j : Fin N, fold j) =
        (∑ j ∈ (Finset.univ : Finset (Fin N)).erase i, fold j) + fold i := by
    exact ((Finset.univ : Finset (Fin N)).sum_erase_add fold (Finset.mem_univ i)).symm
  have herase :
      (∑ j ∈ (Finset.univ : Finset (Fin N)).erase i, fnew j) =
        ∑ j ∈ (Finset.univ : Finset (Fin N)).erase i, fold j := by
    refine Finset.sum_congr rfl ?_
    intro j hj
    have hji : j ≠ i := (Finset.mem_erase.mp hj).1
    simp [fnew, fold, switchDecision, Function.update, hji]
  have hfnew_i : fnew i = posterior i newLabel := by
    simp [fnew, switchDecision, Function.update]
  have hfold_i : fold i = posterior i (decision i) := rfl
  calc
    (∑ j : Fin N, posterior j (switchDecision decision i newLabel j)) =
        ∑ j : Fin N, fnew j := rfl
    _ = (∑ j ∈ (Finset.univ : Finset (Fin N)).erase i, fnew j) + fnew i :=
        hnew_split
    _ = (∑ j ∈ (Finset.univ : Finset (Fin N)).erase i, fold j) +
        posterior i newLabel := by rw [herase, hfnew_i]
    _ = ((∑ j : Fin N, fold j) - fold i) + posterior i newLabel := by
        rw [hold_split]
        ring
    _ = (∑ j : Fin N, posterior j (decision j)) -
        posterior i (decision i) + posterior i newLabel := by
        rfl

theorem datasetAccuracyScore_lt_of_switch_to_better_label {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (decision : Fin N → Fin K)
    (i : Fin N) (newLabel : Fin K)
    (hbetter : posterior i (decision i) < posterior i newLabel) :
    datasetAccuracyScore posterior decision <
      datasetAccuracyScore posterior (switchDecision decision i newLabel) := by
  unfold datasetAccuracyScore EconCSLib.Decision.averageScore
  rw [sum_switchDecision_score_eq_sub_add]
  have hNpos : 0 < (Fintype.card (Fin N) : ℝ) := by
    exact_mod_cast Fintype.card_pos_iff.mpr ⟨i⟩
  have hnum :
      (∑ j : Fin N, posterior j (decision j)) <
        (∑ j : Fin N, posterior j (decision j)) -
          posterior i (decision i) + posterior i newLabel := by
    linarith
  exact div_lt_div_of_pos_right hnum hNpos

theorem datasetAccuracyScore_le_of_switch_to_weakly_better_label {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (decision : Fin N → Fin K)
    (i : Fin N) (newLabel : Fin K)
    (hbetter : posterior i (decision i) ≤ posterior i newLabel) :
    datasetAccuracyScore posterior decision ≤
      datasetAccuracyScore posterior (switchDecision decision i newLabel) := by
  unfold datasetAccuracyScore EconCSLib.Decision.averageScore
  rw [sum_switchDecision_score_eq_sub_add]
  have hNnonneg : 0 ≤ (Fintype.card (Fin N) : ℝ) :=
    Nat.cast_nonneg (Fintype.card (Fin N))
  have hnum :
      (∑ j : Fin N, posterior j (decision j)) ≤
        (∑ j : Fin N, posterior j (decision j)) -
          posterior i (decision i) + posterior i newLabel := by
    linarith
  exact div_le_div_of_nonneg_right hnum hNnonneg

theorem datasetLabelShare_switch_newLabel {N K : ℕ}
    (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K)
    (hne : decision i ≠ newLabel) :
    datasetLabelShare (switchDecision decision i newLabel) newLabel =
      datasetLabelShare decision newLabel + 1 / (N : ℝ) := by
  unfold datasetLabelShare
  rw [sum_switchDecision_score_eq_sub_add
    (fun j label => if label = newLabel then (1 : ℝ) else 0)]
  simp [hne]
  ring_nf

theorem datasetLabelShare_switch_oldLabel {N K : ℕ}
    (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K)
    (hne : decision i ≠ newLabel) :
    datasetLabelShare (switchDecision decision i newLabel) (decision i) =
      datasetLabelShare decision (decision i) - 1 / (N : ℝ) := by
  unfold datasetLabelShare
  rw [sum_switchDecision_score_eq_sub_add
    (fun j label => if label = decision i then (1 : ℝ) else 0)]
  simp [hne.symm]
  ring_nf

theorem datasetLabelShare_switch_otherLabel {N K : ℕ}
    (decision : Fin N → Fin K) (i : Fin N) (newLabel y : Fin K)
    (hynew : y ≠ newLabel) (hyold : y ≠ decision i) :
    datasetLabelShare (switchDecision decision i newLabel) y =
      datasetLabelShare decision y := by
  unfold datasetLabelShare
  rw [sum_switchDecision_score_eq_sub_add
    (fun j label => if label = y then (1 : ℝ) else 0)]
  simp [hynew.symm, hyold.symm]

theorem datasetLabelShare_eq_zero_of_forall_ne {N K : ℕ}
    (decision : Fin N → Fin K) (y : Fin K)
    (hnone : ∀ i, decision i ≠ y) :
    datasetLabelShare decision y = 0 := by
  unfold datasetLabelShare
  have hsum : (∑ i : Fin N, if decision i = y then (1 : ℝ) else 0) = 0 := by
    simp [hnone]
  rw [hsum]
  simp

theorem sum_datasetLabelShare_eq_one {N K : ℕ}
    (decision : Fin N → Fin K) (hNpos : 0 < N) :
    (∑ y : Fin K, datasetLabelShare decision y) = 1 := by
  classical
  unfold datasetLabelShare
  rw [← Finset.sum_div]
  rw [Finset.sum_comm]
  have hinner :
      ∀ i : Fin N, (∑ y : Fin K, if decision i = y then (1 : ℝ) else 0) = 1 := by
    intro i
    rw [Finset.sum_eq_single (decision i)]
    · simp
    · intro y _ hy
      exact if_neg (fun h => hy h.symm)
    · intro hmem
      exact False.elim (hmem (Finset.mem_univ (decision i)))
  simp [hinner, Fintype.card_fin]
  exact Nat.ne_of_gt hNpos

theorem datasetFidelity_lt_of_switch_under_over {N K : ℕ}
    (pref : Fin K → ℝ) (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K)
    (hne : decision i ≠ newLabel)
    (hunder : datasetLabelShare decision newLabel + 1 / (N : ℝ) ≤ pref newLabel)
    (hover : pref (decision i) + 1 / (N : ℝ) ≤ datasetLabelShare decision (decision i)) :
    datasetFidelity pref decision <
      datasetFidelity pref (switchDecision decision i newLabel) := by
  classical
  let step : ℝ := 1 / (N : ℝ)
  have hstep_pos : 0 < step := by
    dsimp [step]
    exact one_div_pos.mpr (by exact_mod_cast (Nat.zero_lt_of_lt i.2))
  let sw := switchDecision decision i newLabel
  let oldDist : ℝ := ∑ y : Fin K, |datasetLabelShare decision y - pref y|
  let newDist : ℝ := ∑ y : Fin K, |datasetLabelShare sw y - pref y|
  have hle_all : ∀ y ∈ (Finset.univ : Finset (Fin K)),
      |datasetLabelShare sw y - pref y| ≤
        |datasetLabelShare decision y - pref y| := by
    intro y _
    by_cases hynew : y = newLabel
    · subst y
      rw [datasetLabelShare_switch_newLabel decision i newLabel hne]
      have hnew_nonpos :
          datasetLabelShare decision newLabel + step - pref newLabel ≤ 0 := by
        dsimp [step] at hunder ⊢
        linarith
      have hold_nonpos : datasetLabelShare decision newLabel - pref newLabel ≤ 0 := by
        dsimp [step] at hunder hstep_pos ⊢
        linarith
      rw [abs_of_nonpos hnew_nonpos, abs_of_nonpos hold_nonpos]
      linarith
    · by_cases hyold : y = decision i
      · subst y
        rw [datasetLabelShare_switch_oldLabel decision i newLabel hne]
        have hnew_nonneg :
            0 ≤ datasetLabelShare decision (decision i) - step - pref (decision i) := by
          dsimp [step] at hover ⊢
          linarith
        have hold_nonneg :
            0 ≤ datasetLabelShare decision (decision i) - pref (decision i) := by
          dsimp [step] at hover hstep_pos ⊢
          linarith
        rw [abs_of_nonneg hnew_nonneg, abs_of_nonneg hold_nonneg]
        linarith
      · rw [datasetLabelShare_switch_otherLabel decision i newLabel y hynew hyold]
  have hlt_one :
      |datasetLabelShare sw newLabel - pref newLabel| <
        |datasetLabelShare decision newLabel - pref newLabel| := by
    rw [datasetLabelShare_switch_newLabel decision i newLabel hne]
    have hnew_nonpos :
        datasetLabelShare decision newLabel + step - pref newLabel ≤ 0 := by
      dsimp [step] at hunder ⊢
      linarith
    have hold_nonpos : datasetLabelShare decision newLabel - pref newLabel ≤ 0 := by
      dsimp [step] at hunder hstep_pos ⊢
      linarith
    rw [abs_of_nonpos hnew_nonpos, abs_of_nonpos hold_nonpos]
    linarith
  have hdist : newDist < oldDist := by
    dsimp [newDist, oldDist]
    exact Finset.sum_lt_sum hle_all
      ⟨newLabel, Finset.mem_univ newLabel, hlt_one⟩
  unfold datasetFidelity
  dsimp [newDist, oldDist] at hdist
  linarith

theorem abs_sub_lt_add_of_pos {a b : ℝ} (ha : 0 < a) (hb : 0 < b) :
    |a - b| < a + b := by
  rw [abs_lt]
  constructor <;> linarith

theorem datasetFidelity_lt_of_switch_under_pos_over {N K : ℕ}
    (pref : Fin K → ℝ) (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K)
    (hne : decision i ≠ newLabel)
    (hunder : datasetLabelShare decision newLabel + 1 / (N : ℝ) ≤ pref newLabel)
    (hover_pos : pref (decision i) < datasetLabelShare decision (decision i)) :
    datasetFidelity pref decision <
      datasetFidelity pref (switchDecision decision i newLabel) := by
  classical
  let step : ℝ := 1 / (N : ℝ)
  let oldLabel : Fin K := decision i
  let sw := switchDecision decision i newLabel
  let oldTerm : Fin K → ℝ :=
    fun y => |datasetLabelShare decision y - pref y|
  let newTerm : Fin K → ℝ :=
    fun y => |datasetLabelShare sw y - pref y|
  let adjust : Fin K → ℝ :=
    fun y => if y = newLabel then -step else if y = oldLabel then step else 0
  let bound : Fin K → ℝ := fun y => oldTerm y + adjust y
  have hstep_pos : 0 < step := by
    dsimp [step]
    exact one_div_pos.mpr (by exact_mod_cast (Nat.zero_lt_of_lt i.2))
  have hle_bound : ∀ y ∈ (Finset.univ : Finset (Fin K)), newTerm y ≤ bound y := by
    intro y _
    by_cases hynew : y = newLabel
    · subst y
      rw [show newTerm newLabel =
          |datasetLabelShare sw newLabel - pref newLabel| by rfl]
      rw [datasetLabelShare_switch_newLabel decision i newLabel hne]
      have hnew_nonpos :
          datasetLabelShare decision newLabel + step - pref newLabel ≤ 0 := by
        dsimp [step] at hunder ⊢
        linarith
      have hold_nonpos : datasetLabelShare decision newLabel - pref newLabel ≤ 0 := by
        dsimp [step] at hunder hstep_pos ⊢
        linarith
      apply le_of_eq
      calc
        |datasetLabelShare decision newLabel + step - pref newLabel| =
            |datasetLabelShare decision newLabel - pref newLabel| - step := by
          rw [abs_of_nonpos hnew_nonpos, abs_of_nonpos hold_nonpos]
          ring
        _ = bound newLabel := by
          simp [bound, oldTerm, adjust, oldLabel]
          ring
    · by_cases hyold : y = oldLabel
      · subst y
        rw [show newTerm oldLabel =
            |datasetLabelShare sw oldLabel - pref oldLabel| by rfl]
        rw [datasetLabelShare_switch_oldLabel decision i newLabel hne]
        have hold_pos : 0 < datasetLabelShare decision oldLabel - pref oldLabel := by
          dsimp [oldLabel] at hover_pos ⊢
          linarith
        have habs :
            |datasetLabelShare decision oldLabel - step - pref oldLabel| <
              |datasetLabelShare decision oldLabel - pref oldLabel| + step := by
          have hrewrite :
              datasetLabelShare decision oldLabel - step - pref oldLabel =
                (datasetLabelShare decision oldLabel - pref oldLabel) - step := by
            ring
          rw [hrewrite, abs_of_pos hold_pos]
          exact abs_sub_lt_add_of_pos hold_pos hstep_pos
        have hne_old_new : ¬ oldLabel = newLabel := by
          dsimp [oldLabel]
          exact hne
        exact le_of_lt (by
          simpa [bound, oldTerm, adjust, oldLabel, hne_old_new, step] using habs)
      · rw [show newTerm y = |datasetLabelShare sw y - pref y| by rfl]
        rw [datasetLabelShare_switch_otherLabel decision i newLabel y hynew hyold]
        simp [bound, oldTerm, adjust, hynew, hyold]
  have hlt_bound_old :
      newTerm oldLabel < bound oldLabel := by
    rw [show newTerm oldLabel =
        |datasetLabelShare sw oldLabel - pref oldLabel| by rfl]
    rw [datasetLabelShare_switch_oldLabel decision i newLabel hne]
    have hold_pos : 0 < datasetLabelShare decision oldLabel - pref oldLabel := by
      dsimp [oldLabel] at hover_pos ⊢
      linarith
    have hrewrite :
        datasetLabelShare decision oldLabel - step - pref oldLabel =
          (datasetLabelShare decision oldLabel - pref oldLabel) - step := by
      ring
    have hne_new_old : ¬ oldLabel = newLabel := by
      dsimp [oldLabel]
      exact hne
    rw [hrewrite]
    simpa [bound, oldTerm, adjust, hne_new_old, abs_of_pos hold_pos, step] using
      abs_sub_lt_add_of_pos hold_pos hstep_pos
  have hsum_new_lt_bound :
      (∑ y : Fin K, newTerm y) < ∑ y : Fin K, bound y := by
    exact Finset.sum_lt_sum hle_bound
      ⟨oldLabel, Finset.mem_univ oldLabel, hlt_bound_old⟩
  have hadjust_sum : (∑ y : Fin K, adjust y) = 0 := by
    have hsplit_new :
        (∑ y : Fin K, adjust y) =
          (∑ y ∈ (Finset.univ : Finset (Fin K)).erase newLabel, adjust y) +
            adjust newLabel :=
      ((Finset.univ : Finset (Fin K)).sum_erase_add adjust
        (Finset.mem_univ newLabel)).symm
    have hold_mem : oldLabel ∈ (Finset.univ : Finset (Fin K)).erase newLabel := by
      simp [oldLabel, hne]
    have hsplit_old :
        (∑ y ∈ (Finset.univ : Finset (Fin K)).erase newLabel, adjust y) =
          (∑ y ∈ ((Finset.univ : Finset (Fin K)).erase newLabel).erase oldLabel,
              adjust y) + adjust oldLabel :=
      (((Finset.univ : Finset (Fin K)).erase newLabel).sum_erase_add
        adjust hold_mem).symm
    have hrest :
        (∑ y ∈ ((Finset.univ : Finset (Fin K)).erase newLabel).erase oldLabel,
            adjust y) = 0 := by
      refine Finset.sum_eq_zero ?_
      intro y hy
      have hy_old : y ≠ oldLabel := (Finset.mem_erase.mp hy).1
      have hy_new : y ≠ newLabel := by
        exact (Finset.mem_erase.mp (Finset.mem_erase.mp hy).2).1
      simp [adjust, hy_new, hy_old]
    rw [hsplit_new, hsplit_old, hrest]
    simp [adjust, oldLabel, hne]
  have hbound_sum : (∑ y : Fin K, bound y) = ∑ y : Fin K, oldTerm y := by
    calc
      (∑ y : Fin K, bound y) =
          ∑ y : Fin K, (oldTerm y + adjust y) := rfl
      _ = (∑ y : Fin K, oldTerm y) + ∑ y : Fin K, adjust y := by
          rw [Finset.sum_add_distrib]
      _ = ∑ y : Fin K, oldTerm y := by
          rw [hadjust_sum, add_zero]
  have hdist : (∑ y : Fin K, newTerm y) < ∑ y : Fin K, oldTerm y := by
    rwa [hbound_sum] at hsum_new_lt_bound
  unfold datasetFidelity
  dsimp [newTerm, oldTerm, sw] at hdist
  linarith

theorem exists_row_strictly_overallocated_of_missing_label
    {N K : ℕ}
    (pref : Fin K → ℝ) (decision : Fin N → Fin K) (target : Fin K)
    (hNpos : 0 < N)
    (hnone : ∀ i, decision i ≠ target)
    (hpref_nonneg : ∀ y, 0 ≤ pref y)
    (hpref_sum : (∑ y : Fin K, pref y) = 1)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target) :
    ∃ i : Fin N, pref (decision i) < datasetLabelShare decision (decision i) := by
  classical
  by_contra hno
  have hrow_le :
      ∀ i : Fin N, datasetLabelShare decision (decision i) ≤ pref (decision i) := by
    intro i
    exact le_of_not_gt (fun hgt => hno ⟨i, hgt⟩)
  have hle_all : ∀ y ∈ (Finset.univ : Finset (Fin K)),
      datasetLabelShare decision y ≤ pref y := by
    intro y _
    by_cases hy : ∃ i : Fin N, decision i = y
    · rcases hy with ⟨i, hi⟩
      simpa [hi] using hrow_le i
    · have hnone_y : ∀ i : Fin N, decision i ≠ y := by
        intro i hi
        exact hy ⟨i, hi⟩
      rw [datasetLabelShare_eq_zero_of_forall_ne decision y hnone_y]
      exact hpref_nonneg y
  have htarget_zero : datasetLabelShare decision target = 0 :=
    datasetLabelShare_eq_zero_of_forall_ne decision target hnone
  have hstep_pos : 0 < 1 / (N : ℝ) :=
    one_div_pos.mpr (by exact_mod_cast hNpos)
  have htarget_strict : datasetLabelShare decision target < pref target := by
    rw [htarget_zero]
    exact lt_of_lt_of_le hstep_pos hnontrivial
  have hsum_lt :
      (∑ y : Fin K, datasetLabelShare decision y) < ∑ y : Fin K, pref y :=
    Finset.sum_lt_sum hle_all
      ⟨target, Finset.mem_univ target, htarget_strict⟩
  rw [sum_datasetLabelShare_eq_one decision hNpos, hpref_sum] at hsum_lt
  exact (lt_irrefl (1 : ℝ)) hsum_lt

/--
Theorem 2(iii), deterministic switch certificate.

If a one-row switch strictly improves posterior-score accuracy and also
strictly improves distributional fidelity, the original deterministic rule is
not Pareto optimal among deterministic joint rules.
-/
theorem paper_theorem2iii_not_pareto_of_switch_improves
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K)
    (hbetter : posterior i (decision i) < posterior i newLabel)
    (hfid :
      datasetFidelity pref decision <
        datasetFidelity pref (switchDecision decision i newLabel)) :
    ¬ Pareto.ParetoOptimal
      (datasetAccuracyScore posterior) (datasetFidelity pref) decision := by
  refine Pareto.not_paretoOptimal_of_strictlyDominatesBoth
    (datasetAccuracyScore posterior) (datasetFidelity pref)
    (better := switchDecision decision i newLabel) ?_
  exact ⟨datasetAccuracyScore_lt_of_switch_to_better_label
    posterior decision i newLabel hbetter, hfid⟩

/--
Theorem 2(iii), weighted-objective consequence of a deterministic switch.

Under the same switch certificate, the original deterministic rule cannot
maximize `O_N^γ` for any `0 < γ ≤ 1`.
-/
theorem paper_theorem2iii_not_weightedObjective_maximizer_of_switch_improves
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K)
    {γ : ℝ} (hγpos : 0 < γ) (hγle : γ ≤ 1)
    (hbetter : posterior i (decision i) < posterior i newLabel)
    (hfid :
      datasetFidelity pref decision <
        datasetFidelity pref (switchDecision decision i newLabel)) :
    ¬ ∀ other : Fin N → Fin K,
        Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) other ≤
          Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) decision := by
  refine Pareto.not_weightedObjective_maximizer_of_strictlyDominatesBoth
    (datasetAccuracyScore posterior) (datasetFidelity pref)
    (better := switchDecision decision i newLabel) hγpos hγle ?_
  exact ⟨datasetAccuracyScore_lt_of_switch_to_better_label
    posterior decision i newLabel hbetter, hfid⟩

/--
Theorem 2(iii), deterministic under/over-allocation switch.

This is the local conclusion used in the source proof after selecting a
positive-probability dataset where the independent rule disagrees with argmax:
switch one row to a strictly better posterior label that is under-allocated by
the reference distribution, away from a currently over-allocated label.
-/
theorem paper_theorem2iii_not_pareto_of_under_over_switch
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K)
    (hne : decision i ≠ newLabel)
    (hbetter : posterior i (decision i) < posterior i newLabel)
    (hunder : datasetLabelShare decision newLabel + 1 / (N : ℝ) ≤ pref newLabel)
    (hover : pref (decision i) + 1 / (N : ℝ) ≤ datasetLabelShare decision (decision i)) :
    ¬ Pareto.ParetoOptimal
      (datasetAccuracyScore posterior) (datasetFidelity pref) decision :=
  paper_theorem2iii_not_pareto_of_switch_improves
    posterior pref decision i newLabel hbetter
    (datasetFidelity_lt_of_switch_under_over
      pref decision i newLabel hne hunder hover)

theorem paper_theorem2iii_not_weightedObjective_maximizer_of_under_over_switch
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K)
    {γ : ℝ} (hγpos : 0 < γ) (hγle : γ ≤ 1)
    (hne : decision i ≠ newLabel)
    (hbetter : posterior i (decision i) < posterior i newLabel)
    (hunder : datasetLabelShare decision newLabel + 1 / (N : ℝ) ≤ pref newLabel)
    (hover : pref (decision i) + 1 / (N : ℝ) ≤ datasetLabelShare decision (decision i)) :
    ¬ ∀ other : Fin N → Fin K,
        Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) other ≤
          Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) decision :=
  paper_theorem2iii_not_weightedObjective_maximizer_of_switch_improves
    posterior pref decision i newLabel hγpos hγle hbetter
    (datasetFidelity_lt_of_switch_under_over
      pref decision i newLabel hne hunder hover)

theorem paper_theorem2iii_not_pareto_of_switch_weak_accuracy_improves_fidelity
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K)
    (hbetter : posterior i (decision i) ≤ posterior i newLabel)
    (hfid :
      datasetFidelity pref decision <
        datasetFidelity pref (switchDecision decision i newLabel)) :
    ¬ Pareto.ParetoOptimal
      (datasetAccuracyScore posterior) (datasetFidelity pref) decision := by
  refine Pareto.not_paretoOptimal_of_dominated
    (datasetAccuracyScore posterior) (datasetFidelity pref)
    (rule := decision) (better := switchDecision decision i newLabel) ?_
  exact Pareto.paretoDominates_of_weakAccuracy_strictFidelity
    (datasetAccuracyScore posterior) (datasetFidelity pref)
    (datasetAccuracyScore_le_of_switch_to_weakly_better_label
      posterior decision i newLabel hbetter)
    hfid

theorem paper_theorem2iii_not_weightedObjective_maximizer_of_switch_weak_accuracy_improves_fidelity
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (i : Fin N) (newLabel : Fin K)
    {γ : ℝ} (hγnonneg : 0 ≤ γ) (hγlt : γ < 1)
    (hbetter : posterior i (decision i) ≤ posterior i newLabel)
    (hfid :
      datasetFidelity pref decision <
        datasetFidelity pref (switchDecision decision i newLabel)) :
    ¬ ∀ other : Fin N → Fin K,
        Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) other ≤
          Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) decision := by
  intro hmax
  have hlt := Pareto.weightedObjective_lt_of_weakAccuracy_strictFidelity
    (datasetAccuracyScore posterior) (datasetFidelity pref)
    hγnonneg hγlt
    (datasetAccuracyScore_le_of_switch_to_weakly_better_label
      posterior decision i newLabel hbetter)
    hfid
  exact not_lt_of_ge (hmax (switchDecision decision i newLabel)) hlt

/--
Theorem 2(iii), source-style non-trivial-reference switch.

If the selected dataset never assigns the target argmax class, the
non-trivial-reference lower bound `1/N ≤ pref target` supplies the
under-allocation half of the fidelity-improvement argument.  The remaining
`hover` assumption is the source proof's choice of an over-allocated current
label to switch away from.
-/
theorem paper_theorem2iii_not_pareto_of_nontrivial_reference_switch
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (i : Fin N) (target : Fin K)
    (hnone : ∀ j, decision j ≠ target)
    (hbetter : posterior i (decision i) < posterior i target)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target)
    (hover : pref (decision i) + 1 / (N : ℝ) ≤ datasetLabelShare decision (decision i)) :
    ¬ Pareto.ParetoOptimal
      (datasetAccuracyScore posterior) (datasetFidelity pref) decision := by
  have hne : decision i ≠ target := hnone i
  have hunder : datasetLabelShare decision target + 1 / (N : ℝ) ≤ pref target := by
    rw [datasetLabelShare_eq_zero_of_forall_ne decision target hnone]
    simpa using hnontrivial
  exact paper_theorem2iii_not_pareto_of_under_over_switch
    posterior pref decision i target hne hbetter hunder hover

theorem paper_theorem2iii_not_weightedObjective_maximizer_of_nontrivial_reference_switch
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (i : Fin N) (target : Fin K)
    {γ : ℝ} (hγpos : 0 < γ) (hγle : γ ≤ 1)
    (hnone : ∀ j, decision j ≠ target)
    (hbetter : posterior i (decision i) < posterior i target)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target)
    (hover : pref (decision i) + 1 / (N : ℝ) ≤ datasetLabelShare decision (decision i)) :
    ¬ ∀ other : Fin N → Fin K,
        Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) other ≤
          Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) decision := by
  have hne : decision i ≠ target := hnone i
  have hunder : datasetLabelShare decision target + 1 / (N : ℝ) ≤ pref target := by
    rw [datasetLabelShare_eq_zero_of_forall_ne decision target hnone]
    simpa using hnontrivial
  exact paper_theorem2iii_not_weightedObjective_maximizer_of_under_over_switch
    posterior pref decision i target hγpos hγle hne hbetter hunder hover

/--
Theorem 2(iii), source-style missing-argmax-class bridge.

If every row in the selected dataset has the same argmax target class but the
independent rule assigns no row to that class, a non-trivial reference
distribution and total mass one force some current label to be over-allocated.
Switching one such row to the target weakly improves posterior-score accuracy
and strictly improves fidelity, so the independent rule is not Pareto optimal.
-/
theorem paper_theorem2iii_not_pareto_of_missing_argmax_class
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (target : Fin K)
    (hNpos : 0 < N)
    (hnone : ∀ j, decision j ≠ target)
    (hpref_nonneg : ∀ y, 0 ≤ pref y)
    (hpref_sum : (∑ y : Fin K, pref y) = 1)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target)
    (hweak_argmax : ∀ i, posterior i (decision i) ≤ posterior i target) :
    ¬ Pareto.ParetoOptimal
      (datasetAccuracyScore posterior) (datasetFidelity pref) decision := by
  rcases exists_row_strictly_overallocated_of_missing_label
    pref decision target hNpos hnone hpref_nonneg hpref_sum hnontrivial with
    ⟨i, hover_pos⟩
  have hne : decision i ≠ target := hnone i
  have hunder : datasetLabelShare decision target + 1 / (N : ℝ) ≤ pref target := by
    rw [datasetLabelShare_eq_zero_of_forall_ne decision target hnone]
    simpa using hnontrivial
  exact paper_theorem2iii_not_pareto_of_switch_weak_accuracy_improves_fidelity
    posterior pref decision i target (hweak_argmax i)
    (datasetFidelity_lt_of_switch_under_pos_over
      pref decision i target hne hunder hover_pos)

theorem paper_theorem2iii_not_weightedObjective_maximizer_of_missing_argmax_class
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (target : Fin K)
    {γ : ℝ} (hγnonneg : 0 ≤ γ) (hγlt : γ < 1)
    (hNpos : 0 < N)
    (hnone : ∀ j, decision j ≠ target)
    (hpref_nonneg : ∀ y, 0 ≤ pref y)
    (hpref_sum : (∑ y : Fin K, pref y) = 1)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target)
    (hweak_argmax : ∀ i, posterior i (decision i) ≤ posterior i target) :
    ¬ ∀ other : Fin N → Fin K,
        Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) other ≤
          Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) decision := by
  rcases exists_row_strictly_overallocated_of_missing_label
    pref decision target hNpos hnone hpref_nonneg hpref_sum hnontrivial with
    ⟨i, hover_pos⟩
  have hne : decision i ≠ target := hnone i
  have hunder : datasetLabelShare decision target + 1 / (N : ℝ) ≤ pref target := by
    rw [datasetLabelShare_eq_zero_of_forall_ne decision target hnone]
    simpa using hnontrivial
  exact
    paper_theorem2iii_not_weightedObjective_maximizer_of_switch_weak_accuracy_improves_fidelity
      posterior pref decision i target hγnonneg hγlt (hweak_argmax i)
      (datasetFidelity_lt_of_switch_under_pos_over
        pref decision i target hne hunder hover_pos)

theorem paper_theorem2iii_not_weightedObjective_maximizer_of_missing_strict_argmax_class
    {N K : ℕ}
    (posterior : Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (decision : Fin N → Fin K) (target : Fin K)
    {γ : ℝ} (hγpos : 0 < γ) (hγle : γ ≤ 1)
    (hNpos : 0 < N)
    (hnone : ∀ j, decision j ≠ target)
    (hpref_nonneg : ∀ y, 0 ≤ pref y)
    (hpref_sum : (∑ y : Fin K, pref y) = 1)
    (hnontrivial : 1 / (N : ℝ) ≤ pref target)
    (hstrict_argmax : ∀ i, posterior i (decision i) < posterior i target) :
    ¬ ∀ other : Fin N → Fin K,
        Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) other ≤
          Pareto.weightedObjective γ
            (datasetAccuracyScore posterior) (datasetFidelity pref) decision := by
  rcases exists_row_strictly_overallocated_of_missing_label
    pref decision target hNpos hnone hpref_nonneg hpref_sum hnontrivial with
    ⟨i, hover_pos⟩
  have hne : decision i ≠ target := hnone i
  have hunder : datasetLabelShare decision target + 1 / (N : ℝ) ≤ pref target := by
    rw [datasetLabelShare_eq_zero_of_forall_ne decision target hnone]
    simpa using hnontrivial
  exact paper_theorem2iii_not_weightedObjective_maximizer_of_switch_improves
    posterior pref decision i target hγpos hγle (hstrict_argmax i)
    (datasetFidelity_lt_of_switch_under_pos_over
      pref decision i target hne hunder hover_pos)

/-- Decisions induced on a sampled dataset by an independent rule. -/
def sampledDecision {X : Type*} {N K : ℕ}
    (rule : X → Fin K) (sample : Fin N → X) : Fin N → Fin K :=
  fun i => rule (sample i)

/-- Row posterior scores induced by a sampled dataset. -/
def sampledPosterior {X : Type*} {N K : ℕ}
    (posterior : X → Fin K → ℝ) (sample : Fin N → X) :
    Fin N → Fin K → ℝ :=
  fun i y => posterior (sample i) y

/-- Expected dataset accuracy of a dataset-to-decision policy. -/
noncomputable def expectedDatasetAccuracy {Sample : Type*} [Fintype Sample]
    [DecidableEq Sample] {N K : ℕ}
    (sampleLaw : PMF Sample) (posterior : Sample → Fin N → Fin K → ℝ)
    (policy : Sample → Fin N → Fin K) : ℝ :=
  EconCSLib.pmfExp sampleLaw
    (fun sample => datasetAccuracyScore (posterior sample) (policy sample))

/-- Expected distributional fidelity of a dataset-to-decision policy. -/
noncomputable def expectedDatasetFidelity {Sample : Type*} [Fintype Sample]
    [DecidableEq Sample] {N K : ℕ}
    (sampleLaw : PMF Sample) (pref : Fin K → ℝ)
    (policy : Sample → Fin N → Fin K) : ℝ :=
  EconCSLib.pmfExp sampleLaw
    (fun sample => datasetFidelity pref (policy sample))

/-- Measure-integral expected dataset accuracy for measurable sample spaces. -/
noncomputable def measureExpectedDatasetAccuracy {Sample : Type*} [MeasurableSpace Sample]
    {N K : ℕ} (sampleLaw : Measure Sample)
    (posterior : Sample → Fin N → Fin K → ℝ)
    (policy : Sample → Fin N → Fin K) : ℝ :=
  ∫ sample, datasetAccuracyScore (posterior sample) (policy sample) ∂sampleLaw

/-- Measure-integral expected dataset fidelity for measurable sample spaces. -/
noncomputable def measureExpectedDatasetFidelity {Sample : Type*} [MeasurableSpace Sample]
    {N K : ℕ} (sampleLaw : Measure Sample) (pref : Fin K → ℝ)
    (policy : Sample → Fin N → Fin K) : ℝ :=
  ∫ sample, datasetFidelity pref (policy sample) ∂sampleLaw

/-- Bounded measurable dataset-accuracy scores are integrable under finite sample laws. -/
theorem integrable_measureDatasetAccuracyScore_of_ae_bound
    {Sample : Type*} [MeasurableSpace Sample] {N K : ℕ}
    (sampleLaw : Measure Sample) [IsFiniteMeasure sampleLaw]
    (posterior : Sample → Fin N → Fin K → ℝ)
    (policy : Sample → Fin N → Fin K) (C : ℝ)
    (hmeas :
      AEStronglyMeasurable
        (fun sample => datasetAccuracyScore (posterior sample) (policy sample))
        sampleLaw)
    (hbound :
      ∀ᵐ sample ∂sampleLaw,
        ‖datasetAccuracyScore (posterior sample) (policy sample)‖ ≤ C) :
    Integrable
      (fun sample => datasetAccuracyScore (posterior sample) (policy sample))
      sampleLaw :=
  Integrable.of_bound hmeas C hbound

/-- Bounded measurable dataset-fidelity scores are integrable under finite sample laws. -/
theorem integrable_measureDatasetFidelity_of_ae_bound
    {Sample : Type*} [MeasurableSpace Sample] {N K : ℕ}
    (sampleLaw : Measure Sample) [IsFiniteMeasure sampleLaw] (pref : Fin K → ℝ)
    (policy : Sample → Fin N → Fin K) (C : ℝ)
    (hmeas :
      AEStronglyMeasurable
        (fun sample => datasetFidelity pref (policy sample)) sampleLaw)
    (hbound :
      ∀ᵐ sample ∂sampleLaw, ‖datasetFidelity pref (policy sample)‖ ≤ C) :
    Integrable (fun sample => datasetFidelity pref (policy sample)) sampleLaw :=
  Integrable.of_bound hmeas C hbound

/--
Strict improvement of an integrable real payoff on a positive-measure set
strictly improves its integral, assuming weak improvement almost everywhere.
-/
theorem integral_lt_integral_of_ae_le_of_measure_setOf_lt_pos
    {Sample : Type*} [MeasurableSpace Sample] (sampleLaw : Measure Sample)
    {f g : Sample → ℝ}
    (hf : Integrable f sampleLaw) (hg : Integrable g sampleLaw)
    (hle : f ≤ᵐ[sampleLaw] g)
    (hpos : 0 < sampleLaw {sample | f sample < g sample}) :
    (∫ sample, f sample ∂sampleLaw) < ∫ sample, g sample ∂sampleLaw := by
  have hnonneg : 0 ≤ᵐ[sampleLaw] fun sample => g sample - f sample :=
    hle.mono fun _ hfg => sub_nonneg.mpr hfg
  have hdiffInt : Integrable (fun sample => g sample - f sample) sampleLaw :=
    hg.sub hf
  have hsupp_pos :
      0 < sampleLaw (Function.support (fun sample => g sample - f sample)) := by
    refine lt_of_lt_of_le hpos (measure_mono ?_)
    intro sample hstrict
    exact (sub_pos.mpr hstrict).ne'
  have hdiff_pos : 0 < ∫ sample, g sample - f sample ∂sampleLaw :=
    (integral_pos_iff_support_of_nonneg_ae hnonneg hdiffInt).2 hsupp_pos
  rw [integral_sub hg hf] at hdiff_pos
  linarith

/--
Measure-integral expected-policy Pareto lift: if a candidate policy is weakly
better in accuracy a.e. and strictly better in fidelity on a positive-measure
event, then the original policy is not Pareto optimal.
-/
theorem not_measureExpectedDataset_pareto_of_positive_measure_event_dominated
    {Sample : Type*} [MeasurableSpace Sample] {N K : ℕ}
    (sampleLaw : Measure Sample)
    (posterior : Sample → Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (policy betterPolicy : Sample → Fin N → Fin K) (event : Set Sample)
    (hpos : 0 < sampleLaw event)
    (haccOldInt :
      Integrable
        (fun sample => datasetAccuracyScore (posterior sample) (policy sample))
        sampleLaw)
    (haccNewInt :
      Integrable
        (fun sample => datasetAccuracyScore (posterior sample) (betterPolicy sample))
        sampleLaw)
    (hfidOldInt :
      Integrable (fun sample => datasetFidelity pref (policy sample)) sampleLaw)
    (hfidNewInt :
      Integrable (fun sample => datasetFidelity pref (betterPolicy sample)) sampleLaw)
    (hacc :
      (fun sample => datasetAccuracyScore (posterior sample) (policy sample)) ≤ᵐ[sampleLaw]
        fun sample => datasetAccuracyScore (posterior sample) (betterPolicy sample))
    (hfid :
      (fun sample => datasetFidelity pref (policy sample)) ≤ᵐ[sampleLaw]
        fun sample => datasetFidelity pref (betterPolicy sample))
    (hfid_strict : ∀ sample, sample ∈ event →
      datasetFidelity pref (policy sample) <
        datasetFidelity pref (betterPolicy sample)) :
    ¬ Pareto.ParetoOptimal
      (measureExpectedDatasetAccuracy sampleLaw posterior)
      (measureExpectedDatasetFidelity sampleLaw pref) policy := by
  have haccExp :
      measureExpectedDatasetAccuracy sampleLaw posterior policy ≤
        measureExpectedDatasetAccuracy sampleLaw posterior betterPolicy := by
    unfold measureExpectedDatasetAccuracy
    exact integral_mono_ae haccOldInt haccNewInt hacc
  have hfidSetPos :
      0 < sampleLaw {sample |
        datasetFidelity pref (policy sample) <
          datasetFidelity pref (betterPolicy sample)} := by
    refine lt_of_lt_of_le hpos (measure_mono ?_)
    intro sample hsample
    exact hfid_strict sample hsample
  have hfidExp :
      measureExpectedDatasetFidelity sampleLaw pref policy <
        measureExpectedDatasetFidelity sampleLaw pref betterPolicy := by
    unfold measureExpectedDatasetFidelity
    exact integral_lt_integral_of_ae_le_of_measure_setOf_lt_pos
      sampleLaw hfidOldInt hfidNewInt hfid hfidSetPos
  refine Pareto.not_paretoOptimal_of_dominated
    (measureExpectedDatasetAccuracy sampleLaw posterior)
    (measureExpectedDatasetFidelity sampleLaw pref)
    (rule := policy) (better := betterPolicy) ?_
  exact Pareto.paretoDominates_of_weakAccuracy_strictFidelity
    (measureExpectedDatasetAccuracy sampleLaw posterior)
    (measureExpectedDatasetFidelity sampleLaw pref) haccExp hfidExp

/--
Measure-integral expected-policy weighted-objective lift for `γ < 1`: weak
accuracy improvement plus strict fidelity improvement on a positive-measure
event rules out weighted-objective maximality.
-/
theorem not_measureExpectedDataset_weightedObjective_maximizer_of_positive_measure_event_dominated
    {Sample : Type*} [MeasurableSpace Sample] {N K : ℕ}
    (sampleLaw : Measure Sample)
    (posterior : Sample → Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (policy betterPolicy : Sample → Fin N → Fin K) (event : Set Sample)
    {γ : ℝ} (hγnonneg : 0 ≤ γ) (hγlt : γ < 1)
    (hpos : 0 < sampleLaw event)
    (haccOldInt :
      Integrable
        (fun sample => datasetAccuracyScore (posterior sample) (policy sample))
        sampleLaw)
    (haccNewInt :
      Integrable
        (fun sample => datasetAccuracyScore (posterior sample) (betterPolicy sample))
        sampleLaw)
    (hfidOldInt :
      Integrable (fun sample => datasetFidelity pref (policy sample)) sampleLaw)
    (hfidNewInt :
      Integrable (fun sample => datasetFidelity pref (betterPolicy sample)) sampleLaw)
    (hacc :
      (fun sample => datasetAccuracyScore (posterior sample) (policy sample)) ≤ᵐ[sampleLaw]
        fun sample => datasetAccuracyScore (posterior sample) (betterPolicy sample))
    (hfid :
      (fun sample => datasetFidelity pref (policy sample)) ≤ᵐ[sampleLaw]
        fun sample => datasetFidelity pref (betterPolicy sample))
    (hfid_strict : ∀ sample, sample ∈ event →
      datasetFidelity pref (policy sample) <
        datasetFidelity pref (betterPolicy sample)) :
    ¬ ∀ other : Sample → Fin N → Fin K,
        Pareto.weightedObjective γ
            (measureExpectedDatasetAccuracy sampleLaw posterior)
            (measureExpectedDatasetFidelity sampleLaw pref) other ≤
          Pareto.weightedObjective γ
            (measureExpectedDatasetAccuracy sampleLaw posterior)
            (measureExpectedDatasetFidelity sampleLaw pref) policy := by
  have haccExp :
      measureExpectedDatasetAccuracy sampleLaw posterior policy ≤
        measureExpectedDatasetAccuracy sampleLaw posterior betterPolicy := by
    unfold measureExpectedDatasetAccuracy
    exact integral_mono_ae haccOldInt haccNewInt hacc
  have hfidSetPos :
      0 < sampleLaw {sample |
        datasetFidelity pref (policy sample) <
          datasetFidelity pref (betterPolicy sample)} := by
    refine lt_of_lt_of_le hpos (measure_mono ?_)
    intro sample hsample
    exact hfid_strict sample hsample
  have hfidExp :
      measureExpectedDatasetFidelity sampleLaw pref policy <
        measureExpectedDatasetFidelity sampleLaw pref betterPolicy := by
    unfold measureExpectedDatasetFidelity
    exact integral_lt_integral_of_ae_le_of_measure_setOf_lt_pos
      sampleLaw hfidOldInt hfidNewInt hfid hfidSetPos
  intro hmax
  have hlt := Pareto.weightedObjective_lt_of_weakAccuracy_strictFidelity
    (measureExpectedDatasetAccuracy sampleLaw posterior)
    (measureExpectedDatasetFidelity sampleLaw pref)
    hγnonneg hγlt haccExp hfidExp
  exact not_lt_of_ge (hmax betterPolicy) hlt

/--
Measure-integral weighted-objective lift for `0 < γ ≤ 1`: strict accuracy and
fidelity improvements on a positive-measure event rule out maximality.
-/
theorem not_measureExpectedDataset_weightedObjective_maximizer_of_positive_measure_event_strictly_dominated
    {Sample : Type*} [MeasurableSpace Sample] {N K : ℕ}
    (sampleLaw : Measure Sample)
    (posterior : Sample → Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (policy betterPolicy : Sample → Fin N → Fin K) (event : Set Sample)
    {γ : ℝ} (hγpos : 0 < γ) (hγle : γ ≤ 1)
    (hpos : 0 < sampleLaw event)
    (haccOldInt :
      Integrable
        (fun sample => datasetAccuracyScore (posterior sample) (policy sample))
        sampleLaw)
    (haccNewInt :
      Integrable
        (fun sample => datasetAccuracyScore (posterior sample) (betterPolicy sample))
        sampleLaw)
    (hfidOldInt :
      Integrable (fun sample => datasetFidelity pref (policy sample)) sampleLaw)
    (hfidNewInt :
      Integrable (fun sample => datasetFidelity pref (betterPolicy sample)) sampleLaw)
    (hacc :
      (fun sample => datasetAccuracyScore (posterior sample) (policy sample)) ≤ᵐ[sampleLaw]
        fun sample => datasetAccuracyScore (posterior sample) (betterPolicy sample))
    (hfid :
      (fun sample => datasetFidelity pref (policy sample)) ≤ᵐ[sampleLaw]
        fun sample => datasetFidelity pref (betterPolicy sample))
    (hacc_strict : ∀ sample, sample ∈ event →
      datasetAccuracyScore (posterior sample) (policy sample) <
        datasetAccuracyScore (posterior sample) (betterPolicy sample))
    (hfid_strict : ∀ sample, sample ∈ event →
      datasetFidelity pref (policy sample) <
        datasetFidelity pref (betterPolicy sample)) :
    ¬ ∀ other : Sample → Fin N → Fin K,
        Pareto.weightedObjective γ
            (measureExpectedDatasetAccuracy sampleLaw posterior)
            (measureExpectedDatasetFidelity sampleLaw pref) other ≤
          Pareto.weightedObjective γ
            (measureExpectedDatasetAccuracy sampleLaw posterior)
            (measureExpectedDatasetFidelity sampleLaw pref) policy := by
  have haccSetPos :
      0 < sampleLaw {sample |
        datasetAccuracyScore (posterior sample) (policy sample) <
          datasetAccuracyScore (posterior sample) (betterPolicy sample)} := by
    refine lt_of_lt_of_le hpos (measure_mono ?_)
    intro sample hsample
    exact hacc_strict sample hsample
  have hfidSetPos :
      0 < sampleLaw {sample |
        datasetFidelity pref (policy sample) <
          datasetFidelity pref (betterPolicy sample)} := by
    refine lt_of_lt_of_le hpos (measure_mono ?_)
    intro sample hsample
    exact hfid_strict sample hsample
  have haccExp :
      measureExpectedDatasetAccuracy sampleLaw posterior policy <
        measureExpectedDatasetAccuracy sampleLaw posterior betterPolicy := by
    unfold measureExpectedDatasetAccuracy
    exact integral_lt_integral_of_ae_le_of_measure_setOf_lt_pos
      sampleLaw haccOldInt haccNewInt hacc haccSetPos
