theorem sourceSd_interval_split_exists_measurable_nonfocal_twoCoordinate_delta_integral_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) (c : ℝ) {lo hi : ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
