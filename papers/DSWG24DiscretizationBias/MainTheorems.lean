    (hargmax : ∀ x a, q x a ≤ q x (argmaxRule x))
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a)
    (hle_one : ∀ x a, q x a ≤ 1)
