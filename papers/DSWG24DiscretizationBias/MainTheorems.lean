/--
Integrated MAE nonincrease for the multiclass-safe patched `S_b -> S_a` move.

On the selected region `S`, the transformed posterior collapses all mass to the
focal label `z`; outside `S`, it is unchanged.  This avoids the multiclass
single-coordinate feasibility issue of the informal parallel-transformation
sketch.
-/
theorem integral_paperConditionalMAE_delta_collapse_to_focal_one_region_nonpos
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q qNext : X → Y → ℝ)
    (S : Set X) (z : Y)
    (hInt :
      Integrable
        (fun xy : X × Y =>
          Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) μ)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x, ∀ a : Y, 0 ≤ q x a)
    (hshapeS :
      ∀ᵐ xy ∂μ, xy.1 ∈ S → ∀ a : Y,
        qNext xy.1 a = if a = z then (1 : ℝ) else 0)
    (hshapeOutside :
      ∀ᵐ xy ∂μ, xy.1 ∉ S → ∀ a : Y,
        qNext xy.1 a = q xy.1 a) :
    (∫ xy : X × Y,
        (Finite.paperConditionalMAE qNext xy.1 -
          Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  have hle_ae :
      (fun xy : X × Y =>
          Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) ≤ᵐ[μ]
        fun _ : X × Y => (0 : ℝ) := by
    filter_upwards [hshapeS, hshapeOutside] with xy hS hOutside
    by_cases hx : xy.1 ∈ S
    · have hle :
          Finite.paperConditionalMAE qNext xy.1 ≤
            Finite.paperConditionalMAE q xy.1 :=
        paperConditionalMAE_collapse_to_focal_one_le
          q qNext xy.1 xy.1 z (hsum xy.1) (hnonneg xy.1) (hS hx)
      linarith
    · have hsame :
          Finite.paperConditionalMAE qNext xy.1 =
            Finite.paperConditionalMAE q xy.1 := by
        unfold Finite.paperConditionalMAE
        refine Finset.sum_congr rfl ?_
        intro a _
        rw [hOutside hx a]
      linarith
  have hzeroInt : Integrable (fun _ : X × Y => (0 : ℝ)) μ := by
    simpa using (integrable_zero (α := X × Y) (ε' := ℝ) (μ := μ))
  have hle_int :
      (∫ xy : X × Y,
          (Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) ∂μ) ≤
        ∫ _ : X × Y, (0 : ℝ) ∂μ :=
    integral_mono_ae hInt hzeroInt hle_ae
  simpa using hle_int

