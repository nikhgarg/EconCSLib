  refine Pareto.not_weightedObjective_maximizer_of_strictlyDominatesBoth
    (measureExpectedDatasetAccuracy sampleLaw posterior)
    (measureExpectedDatasetFidelity sampleLaw pref)
    (rule := policy) (better := betterPolicy) hγpos hγle ?_
  exact ⟨haccExp, hfidExp⟩

/-- Change a dataset-to-decision policy at one realized dataset only. -/
def switchPolicyAtSample {Sample : Type*} [DecidableEq Sample] {N K : ℕ}
    (policy : Sample → Fin N → Fin K) (sample : Sample)
    (betterDecision : Fin N → Fin K) : Sample → Fin N → Fin K :=
  Function.update policy sample betterDecision

theorem pmfExp_lt_pmfExp_of_forall_le_exists_lt
    {α : Type*} [Fintype α] [DecidableEq α]
    (μ : PMF α) (f g : α → ℝ)
    (hle : ∀ a, f a ≤ g a)
    (hex : ∃ a, 0 < (μ a).toReal ∧ f a < g a) :
    EconCSLib.pmfExp μ f < EconCSLib.pmfExp μ g := by
  classical
  unfold EconCSLib.pmfExp
  refine Finset.sum_lt_sum ?_ ?_
  · intro a _
    exact mul_le_mul_of_nonneg_left (hle a) ENNReal.toReal_nonneg
  · rcases hex with ⟨a, hmass, hlt⟩
    exact ⟨a, Finset.mem_univ a, mul_lt_mul_of_pos_left hlt hmass⟩

theorem pmfExp_eq_of_forall_eq_of_pos_mass
    {α : Type*} [Fintype α] [DecidableEq α]
    (μ : PMF α) {f g : α → ℝ}
    (h : ∀ a, 0 < (μ a).toReal → f a = g a) :
    EconCSLib.pmfExp μ f = EconCSLib.pmfExp μ g := by
  classical
  unfold EconCSLib.pmfExp
  refine Finset.sum_congr rfl ?_
  intro a _
  by_cases hmass : 0 < (μ a).toReal
  · rw [h a hmass]
  · have hmass_zero : (μ a).toReal = 0 := by
      exact le_antisymm (le_of_not_gt hmass) ENNReal.toReal_nonneg
    simp [hmass_zero]

theorem pmfExp_eq_of_zero_prob_ne
    {α β : Type*} [Fintype α] [DecidableEq α] [DecidableEq β]
    (μ : PMF α) (f g : α → β) (score : α → β → ℝ)
    (hzero : EconCSLib.pmfProb μ (fun a => f a ≠ g a) = 0) :
    EconCSLib.pmfExp μ (fun a => score a (f a)) =
      EconCSLib.pmfExp μ (fun a => score a (g a)) := by
  classical
  refine pmfExp_eq_of_forall_eq_of_pos_mass μ ?_
  intro a hmass
  have hfg : f a = g a := by
    by_contra hne
    have hpos : 0 < EconCSLib.pmfProb μ (fun a => f a ≠ g a) :=
      EconCSLib.pmfProb_pos_of_mass μ (fun a => f a ≠ g a) a hne hmass
    rw [hzero] at hpos
    exact (lt_irrefl (0 : ℝ)) hpos
  rw [hfg]

theorem expectedDatasetAccuracy_eq_of_policy_eq_zero_prob
    {Sample : Type*} [Fintype Sample] [DecidableEq Sample] {N K : ℕ}
    (sampleLaw : PMF Sample) (posterior : Sample → Fin N → Fin K → ℝ)
    (policy benchmark : Sample → Fin N → Fin K)
    (hzero : EconCSLib.pmfProb sampleLaw (fun s => policy s ≠ benchmark s) = 0) :
    expectedDatasetAccuracy sampleLaw posterior policy =
      expectedDatasetAccuracy sampleLaw posterior benchmark := by
  classical
  unfold expectedDatasetAccuracy
  exact pmfExp_eq_of_zero_prob_ne sampleLaw policy benchmark
    (fun sample decision => datasetAccuracyScore (posterior sample) decision) hzero

theorem expectedDatasetFidelity_eq_of_policy_eq_zero_prob
    {Sample : Type*} [Fintype Sample] [DecidableEq Sample] {N K : ℕ}
    (sampleLaw : PMF Sample) (pref : Fin K → ℝ)
    (policy benchmark : Sample → Fin N → Fin K)
    (hzero : EconCSLib.pmfProb sampleLaw (fun s => policy s ≠ benchmark s) = 0) :
    expectedDatasetFidelity sampleLaw pref policy =
      expectedDatasetFidelity sampleLaw pref benchmark := by
  classical
  unfold expectedDatasetFidelity
  exact pmfExp_eq_of_zero_prob_ne sampleLaw policy benchmark
    (fun _ decision => datasetFidelity pref decision) hzero

theorem expectedDataset_weightedObjective_eq_of_policy_eq_zero_prob
    {Sample : Type*} [Fintype Sample] [DecidableEq Sample] {N K : ℕ}
    (sampleLaw : PMF Sample) (posterior : Sample → Fin N → Fin K → ℝ)
    (pref : Fin K → ℝ) (policy benchmark : Sample → Fin N → Fin K) (γ : ℝ)
    (hzero : EconCSLib.pmfProb sampleLaw (fun s => policy s ≠ benchmark s) = 0) :
    Pareto.weightedObjective γ
        (expectedDatasetAccuracy sampleLaw posterior)
        (expectedDatasetFidelity sampleLaw pref) policy =
      Pareto.weightedObjective γ
        (expectedDatasetAccuracy sampleLaw posterior)
        (expectedDatasetFidelity sampleLaw pref) benchmark := by
  unfold Pareto.weightedObjective
  rw [expectedDatasetAccuracy_eq_of_policy_eq_zero_prob
      sampleLaw posterior policy benchmark hzero]
  rw [expectedDatasetFidelity_eq_of_policy_eq_zero_prob
      sampleLaw pref policy benchmark hzero]

theorem not_expectedDataset_pareto_of_positive_mass_sample_dominated
    {Sample : Type*} [Fintype Sample] [DecidableEq Sample] {N K : ℕ}
    (sampleLaw : PMF Sample) (posterior : Sample → Fin N → Fin K → ℝ)
    (pref : Fin K → ℝ) (policy : Sample → Fin N → Fin K)
    (sample : Sample) (betterDecision : Fin N → Fin K)
    (hmass : 0 < (sampleLaw sample).toReal)
    (hacc :
      datasetAccuracyScore (posterior sample) (policy sample) ≤
        datasetAccuracyScore (posterior sample) betterDecision)
    (hfid :
      datasetFidelity pref (policy sample) <
        datasetFidelity pref betterDecision) :
    ¬ Pareto.ParetoOptimal
      (expectedDatasetAccuracy sampleLaw posterior)
      (expectedDatasetFidelity sampleLaw pref) policy := by
  classical
  let betterPolicy := switchPolicyAtSample policy sample betterDecision
  have haccExp :
      expectedDatasetAccuracy sampleLaw posterior policy ≤
        expectedDatasetAccuracy sampleLaw posterior betterPolicy := by
    unfold expectedDatasetAccuracy
    refine EconCSLib.pmfExp_le_pmfExp_of_forall_le sampleLaw _ _ ?_
    intro s
    by_cases hs : s = sample
    · subst s
      simpa [betterPolicy, switchPolicyAtSample] using hacc
    · simp [betterPolicy, switchPolicyAtSample, hs]
  have hfidExp :
      expectedDatasetFidelity sampleLaw pref policy <
        expectedDatasetFidelity sampleLaw pref betterPolicy := by
    unfold expectedDatasetFidelity
    refine pmfExp_lt_pmfExp_of_forall_le_exists_lt sampleLaw _ _ ?_ ?_
    · intro s
      by_cases hs : s = sample
      · subst s
        exact le_of_lt (by simpa [betterPolicy, switchPolicyAtSample] using hfid)
      · simp [betterPolicy, switchPolicyAtSample, hs]
    · exact ⟨sample, hmass, by
        simpa [betterPolicy, switchPolicyAtSample] using hfid⟩
  refine Pareto.not_paretoOptimal_of_dominated
    (expectedDatasetAccuracy sampleLaw posterior)
    (expectedDatasetFidelity sampleLaw pref)
    (rule := policy) (better := betterPolicy) ?_
  exact Pareto.paretoDominates_of_weakAccuracy_strictFidelity
    (expectedDatasetAccuracy sampleLaw posterior)
    (expectedDatasetFidelity sampleLaw pref) haccExp hfidExp

theorem not_expectedDataset_weightedObjective_maximizer_of_positive_mass_sample_dominated
    {Sample : Type*} [Fintype Sample] [DecidableEq Sample] {N K : ℕ}
    (sampleLaw : PMF Sample) (posterior : Sample → Fin N → Fin K → ℝ)
    (pref : Fin K → ℝ) (policy : Sample → Fin N → Fin K)
    (sample : Sample) (betterDecision : Fin N → Fin K)
