theorem continuousJointClassifierMAE_sourceSaScSe_eq
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace (X × Y)] [Fintype Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (z : Y) (uniformScore : ℝ)
    (hzero_lt_uniform : 0 < uniformScore) (huniform_lt_one : uniformScore < 1)
    (hcover :
      sourceSaRegion q z ∪
          (sourceScRegion q z uniformScore ∪ sourceSeRegion q z) =
        univ)
    (hmaeSa : ∀ x, x ∈ sourceSaRegion q z →
      Finite.paperConditionalMAE q x = 0)
    (hmaeSc : ∀ x, x ∈ sourceScRegion q z uniformScore →
      Finite.paperConditionalMAE q x = 1 - uniformScore)
    (hmaeSe : ∀ x, x ∈ sourceSeRegion q z →
      Finite.paperConditionalMAE q x = 0) :
    continuousJointClassifierMAE μ q =
      (1 - uniformScore) *
        jointFeatureSetMass μ (sourceScRegion q z uniformScore) := by
  classical
  let Sa : Set X := sourceSaRegion q z
  let Sc : Set X := sourceScRegion q z uniformScore
  let Se : Set X := sourceSeRegion q z
  have hSaSc : Disjoint Sa Sc :=
    sourceSaRegion_disjoint_sourceScRegion huniform_lt_one
  have hScSe : Disjoint Sc Se :=
    sourceScRegion_disjoint_sourceSeRegion hzero_lt_uniform
  have hpoint : ∀ xy : X × Y,
      Finite.paperConditionalMAE q xy.1 =
        (1 - uniformScore) *
          Sc.indicator (fun _ : X => (1 : ℝ)) xy.1 := by
    intro xy
    have hxcover : xy.1 ∈ Sa ∪ (Sc ∪ Se) := by
      rw [show Sa ∪ (Sc ∪ Se) = univ by simpa [Sa, Sc, Se] using hcover]
      trivial
    rcases hxcover with hSa | hrest
    · have hnotSc : xy.1 ∉ Sc := Set.disjoint_left.mp hSaSc hSa
      simp [Set.indicator, hnotSc, hmaeSa xy.1 hSa]
    rcases hrest with hSc | hSe
    · simp [Set.indicator, hSc, hmaeSc xy.1 hSc]
    · have hnotSc : xy.1 ∉ Sc := Set.disjoint_left.mp hScSe.symm hSe
      simp [Set.indicator, hnotSc, hmaeSe xy.1 hSe]
  unfold continuousJointClassifierMAE jointFeatureSetMass
  calc
    (∫ xy : X × Y, Finite.paperConditionalMAE q xy.1 ∂μ)
        = ∫ xy : X × Y,
            (1 - uniformScore) *
              Sc.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ =
        (1 - uniformScore) *
          (∫ xy : X × Y,
            Sc.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) := by
          rw [integral_const_mul]

