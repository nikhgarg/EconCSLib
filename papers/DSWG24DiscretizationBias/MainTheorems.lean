  refine integral_congr_ae ?_
  filter_upwards [hzw, hshape] with xy hneq hxy
  exact paperConditionalMAE_twoCoordinate_lower_focal_to_zero_delta
    q qNext xy.1 (TFeature xy) hneq hxy

