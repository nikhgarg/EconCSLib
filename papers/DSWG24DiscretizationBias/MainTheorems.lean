/--
Multiclass-safe constructive `S_d` subset interval source transformation.

The upper swept subset raises the focal coordinate to uniform by subtracting
from a selected above-uniform nonfocal coordinate, while the lower swept subset
collapses to that selected nonfocal label.  This is the subset-sweep analogue
of the multiclass-safe `S_d` collapse endpoint.
-/
theorem sourceSd_subset_interval_split_exists_measurable_feature_qNext_collapse_simplex_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ} {S : Set ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hS : MeasurableSet S)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ S → x ∈ Icc lo hi →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ a : Y, Measurable fun x : ℝ => qNext x a) ∧
        (∀ x : ℝ, x ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) ∧
        (∀ x : ℝ, x ∈ S ∩ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) - ((Fintype.card Y : ℝ)⁻¹ - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ S ∩ Ioc lo cut → ∀ a : Y,
          qNext x a = if a = w x then (1 : ℝ) else 0) ∧
        (∀ x : ℝ, x ∉ S ∩ Ioc cut hi → x ∉ S ∩ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∀ x : ℝ, (∑ a : Y, qNext x a) = 1) ∧
        (∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a) ∧
        jointFeatureSetScoreMass μ qNext ((S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut)) z =
          jointFeatureSetScoreMass μ q ((S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut)) z ∧
        continuousJointAggregatePosterior μ qNext z =
          continuousJointAggregatePosterior μ q z ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSd_subset_interval_split_exists_measurable_feature_nonfocal_selector_product_balance_simplex_finite
      μ q z hlohi hfinite hS hq hsum hnonneg hregion with
    ⟨cut, w, hcut, hw_meas, hsel, hbalance⟩
  let wProd : ℝ × Y → Y := fun xy => w xy.1
  let qNext : ℝ → Y → ℝ := fun x a =>
    if x ∈ S ∩ Ioc cut hi then
      if a = z then u
      else if a = w x then q x (w x) - (u - q x z)
      else q x a
    else if x ∈ S ∩ Ioc lo cut then
      if a = w x then 1 else 0
    else q x a
  have hle_one : ∀ x y, q x y ≤ 1 := fun x y =>
    posterior_coord_le_one_of_sum_nonneg q x y (hsum x) (hnonneg x)
  have hdisj : Disjoint (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    exact (not_lt_of_ge hx_lo.2.2) hx_hi.2.1
  have hselected_meas : Measurable fun x : ℝ => q x (w x) :=
    measurable_selectedScore q w hq hw_meas
  have hselProd :
      ∀ xy : ℝ × Y,
        xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
          wProd xy ≠ z ∧ u < q xy.1 (wProd xy) := by
    intro xy hxy
    simpa [wProd, u] using hsel xy.1 hxy
