    intro x hx
    simpa [u] using hregion x hx.1 ⟨hx.2.1.le, hx.2.2.trans hcut.2⟩
  have hqNextC :
      ∀ x : ℝ, x ∈ S ∩ Ioc cut hi → ∀ a : Y,
