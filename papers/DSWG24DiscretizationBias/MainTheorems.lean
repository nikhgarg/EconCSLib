-/
theorem paperConditionalMAE_twoCoordinate_raise_focal_to_one_delta
    {X Y : Type*} [Fintype Y] [DecidableEq Y]
    (q qNext : X → Y → ℝ) (x xNext : X) {z w : Y} (hzw : z ≠ w)
    (hshape : ∀ a : Y,
      qNext xNext a =
        if a = z then 1 else if a = w then q x w - (1 - q x z) else q x a) :
    Finite.paperConditionalMAE qNext xNext - Finite.paperConditionalMAE q x =
      -2 * (1 - q x w) * (1 - q x z) := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then 1 else if a = w then q x w - (1 - q x z) else q x a
  have hsum_next :
      (∑ a : Y, qNext xNext a * (1 - qNext xNext a)) =
        ∑ a : Y, q' a * (1 - q' a) := by
    refine Finset.sum_congr rfl ?_
    intro a _
    simp [q', hshape a]
  have hdelta :
      (∑ a : Y, q' a * (1 - q' a)) -
          ∑ a : Y, q x a * (1 - q x a) =
        -2 * (1 - q x w) * (1 - q x z) := by
    simpa [q'] using
      posteriorMAESum_twoCoordinate_raise_focal_to_one
        (fun a : Y => q x a) hzw
  unfold Finite.paperConditionalMAE
  rw [hsum_next]
  exact hdelta

