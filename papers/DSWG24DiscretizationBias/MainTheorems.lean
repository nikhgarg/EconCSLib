theorem sourceWorstCase_bias_eq_mae_of_reduced_source_regions
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (rule : X → Y) (z : Y) (uniformScore : ℝ)
    (hqz : Measurable fun x : X => q x z)
    (hpriorAggregate :
      continuousJointPrior μ z = continuousJointAggregatePosterior μ q z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hzero_lt_uniform : 0 < uniformScore) (huniform_lt_one : uniformScore < 1)
    (hSb_empty : sourceSbRegion q z uniformScore = ∅)
    (hSd_empty : sourceSdRegion q z uniformScore = ∅)
    (hdecision :
      ∀ x, rule x = z ↔
        x ∈ sourceSaRegion q z ∪ sourceScRegion q z uniformScore)
    (hmaeSa : ∀ x, x ∈ sourceSaRegion q z →
      Finite.paperConditionalMAE q x = 0)
    (hmaeSc : ∀ x, x ∈ sourceScRegion q z uniformScore →
      Finite.paperConditionalMAE q x = 1 - uniformScore)
    (hmaeSe : ∀ x, x ∈ sourceSeRegion q z →
      Finite.paperConditionalMAE q x = 0) :
    continuousJointPriorBias μ rule z = continuousJointClassifierMAE μ q :=
  sourceWorstCase_bias_eq_mae_of_certificate μ q rule z
    (sourceWorstCaseEqualityCertificate_of_reduced_source_regions
      μ q rule z uniformScore hqz hpriorAggregate hsum hnonneg
      hzero_lt_uniform huniform_lt_one hSb_empty hSd_empty hdecision
      hmaeSa hmaeSc hmaeSe)

theorem sourceWorstCase_bias_eq_mae_of_three_region_masses
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (rule : X → Y) (z : Y)
    (Sa Sc : Set X) (uniformScore : ℝ)
    (hdecision :
      continuousJointDecisionShare μ rule z =
        jointFeatureSetMass μ Sa + jointFeatureSetMass μ Sc)
    (hprior :
      continuousJointPrior μ z =
        jointFeatureSetMass μ Sa + uniformScore * jointFeatureSetMass μ Sc)
    (hmae :
      continuousJointClassifierMAE μ q =
        (1 - uniformScore) * jointFeatureSetMass μ Sc) :
    continuousJointPriorBias μ rule z = continuousJointClassifierMAE μ q :=
  sourceWorstCase_bias_eq_mae_of_certificate μ q rule z
    (sourceWorstCaseEqualityCertificate_of_three_region_masses
      μ q rule z Sa Sc uniformScore hdecision hprior hmae)

/--
Source transformation certificate for the continuous proof route of
Theorem 1(iii).

The source proof transforms an arbitrary calibrated classifier into a
worst-case classifier while preserving the focal prior, not decreasing the
mass assigned to the focal argmax class, and not increasing MAE.  These fields
are exactly the transformation obligations needed for the final inequality.
-/
structure SourceTransformationCertificate
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μWorst : Measure (X × Y)) (q qWorst : X → Y → ℝ)
    (rule ruleWorst : X → Y) (z : Y) where
  prior_preserved : continuousJointPrior μWorst z = continuousJointPrior μ z
  decision_share_mono :
    continuousJointDecisionShare μ rule z ≤
      continuousJointDecisionShare μWorst ruleWorst z
  transformed_mae_le :
    continuousJointClassifierMAE μWorst qWorst ≤ continuousJointClassifierMAE μ q
  transformed_bias_le_mae :
    continuousJointPriorBias μWorst ruleWorst z ≤
      continuousJointClassifierMAE μWorst qWorst

theorem sourceTransformation_prior_bias_le_mae
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μWorst : Measure (X × Y)) (q qWorst : X → Y → ℝ)
    (rule ruleWorst : X → Y) (z : Y)
    (hcert : SourceTransformationCertificate μ μWorst q qWorst rule ruleWorst z) :
    continuousJointPriorBias μ rule z ≤ continuousJointClassifierMAE μ q := by
  have hbias_le :
      continuousJointPriorBias μ rule z ≤
        continuousJointPriorBias μWorst ruleWorst z := by
    unfold continuousJointPriorBias
    rw [hcert.prior_preserved]
    linarith [hcert.decision_share_mono]
  exact hbias_le.trans
    (hcert.transformed_bias_le_mae.trans hcert.transformed_mae_le)

/--
Source transformation certificates compose, matching the paper's sequential
`S_b` then `S_d` reduction route.
-/
theorem sourceTransformationCertificate_trans
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ₀ μ₁ μ₂ : Measure (X × Y))
    (q₀ q₁ q₂ : X → Y → ℝ) (rule₀ rule₁ rule₂ : X → Y) (z : Y)
    (h₀₁ : SourceTransformationCertificate μ₀ μ₁ q₀ q₁ rule₀ rule₁ z)
    (h₁₂ : SourceTransformationCertificate μ₁ μ₂ q₁ q₂ rule₁ rule₂ z) :
    SourceTransformationCertificate μ₀ μ₂ q₀ q₂ rule₀ rule₂ z where
  prior_preserved := h₁₂.prior_preserved.trans h₀₁.prior_preserved
  decision_share_mono :=
    h₀₁.decision_share_mono.trans h₁₂.decision_share_mono
  transformed_mae_le :=
    h₁₂.transformed_mae_le.trans h₀₁.transformed_mae_le
  transformed_bias_le_mae := h₁₂.transformed_bias_le_mae

theorem sourceTransformationCertificate_of_target_bound
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μNext : Measure (X × Y)) (q qNext : X → Y → ℝ)
    (rule ruleNext : X → Y) (z : Y)
    (hprior :
      continuousJointPrior μNext z = continuousJointPrior μ z)
    (hdecision :
      continuousJointDecisionShare μ rule z ≤
        continuousJointDecisionShare μNext ruleNext z)
    (hmae :
      continuousJointClassifierMAE μNext qNext ≤ continuousJointClassifierMAE μ q)
    (htarget :
      continuousJointPriorBias μNext ruleNext z ≤
        continuousJointClassifierMAE μNext qNext) :
    SourceTransformationCertificate μ μNext q qNext rule ruleNext z where
  prior_preserved := hprior
  decision_share_mono := hdecision
  transformed_mae_le := hmae
  transformed_bias_le_mae := htarget

theorem sourceTransformationCertificate_of_worstCaseEquality
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μWorst : Measure (X × Y)) (q qWorst : X → Y → ℝ)
    (rule ruleWorst : X → Y) (z : Y)
    (hprior :
      continuousJointPrior μWorst z = continuousJointPrior μ z)
    (hdecision :
      continuousJointDecisionShare μ rule z ≤
        continuousJointDecisionShare μWorst ruleWorst z)
    (hmae :
      continuousJointClassifierMAE μWorst qWorst ≤ continuousJointClassifierMAE μ q)
    (hworst : SourceWorstCaseEqualityCertificate μWorst qWorst ruleWorst z) :
    SourceTransformationCertificate μ μWorst q qWorst rule ruleWorst z :=
  sourceTransformationCertificate_of_target_bound
    μ μWorst q qWorst rule ruleWorst z hprior hdecision hmae
    (le_of_eq (sourceWorstCase_bias_eq_mae_of_certificate
      μWorst qWorst ruleWorst z hworst))

/--
Pushforward transformations preserve the focal prior when they preserve labels.

This is the measure-map version of the source proof's "same true population"
obligation for transformed classifiers.
-/
theorem continuousJointPrior_eq_of_measurePreserving_label
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μWorst : Measure (X × Y)) (z : Y) (T : X × Y → X × Y)
    (hT : MeasurePreserving T μ μWorst)
    (hpriorMeas :
      AEStronglyMeasurable (fun xy : X × Y => if xy.2 = z then (1 : ℝ) else 0)
        μWorst)
    (hlabel : ∀ xy : X × Y, (T xy).2 = xy.2) :
    continuousJointPrior μWorst z = continuousJointPrior μ z := by
  have hpriorMeas_map :
      AEStronglyMeasurable (fun xy : X × Y => if xy.2 = z then (1 : ℝ) else 0)
        (Measure.map T μ) := by
    rw [hT.map_eq]
    exact hpriorMeas
  unfold continuousJointPrior
  rw [← hT.map_eq]
  rw [integral_map hT.aemeasurable hpriorMeas_map]
  refine integral_congr_ae (Filter.Eventually.of_forall ?_)
  intro xy
  simp [hlabel xy]

/--
Pushforward transformations preserve the focal decision share when transformed
decisions agree pointwise after applying the map.
-/
theorem continuousJointDecisionShare_eq_of_measurePreserving_rule
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μWorst : Measure (X × Y)) (rule ruleWorst : X → Y) (z : Y)
    (T : X × Y → X × Y)
    (hT : MeasurePreserving T μ μWorst)
    (hdecisionMeas :
      AEStronglyMeasurable
        (fun xy : X × Y => if ruleWorst xy.1 = z then (1 : ℝ) else 0) μWorst)
    (hdecision : ∀ xy : X × Y, ruleWorst (T xy).1 = rule xy.1) :
    continuousJointDecisionShare μWorst ruleWorst z =
      continuousJointDecisionShare μ rule z := by
  have hdecisionMeas_map :
      AEStronglyMeasurable
        (fun xy : X × Y => if ruleWorst xy.1 = z then (1 : ℝ) else 0)
        (Measure.map T μ) := by
    rw [hT.map_eq]
    exact hdecisionMeas
  unfold continuousJointDecisionShare
  rw [← hT.map_eq]
  rw [integral_map hT.aemeasurable hdecisionMeas_map]
  refine integral_congr_ae (Filter.Eventually.of_forall ?_)
  intro xy
  simp [hdecision xy]

/--
Pushforward transformations preserve continuous MAE when the transformed
conditional-MAE integrand agrees pointwise after applying the map.
-/
theorem continuousJointClassifierMAE_eq_of_measurePreserving
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μWorst : Measure (X × Y)) (q qWorst : X → Y → ℝ)
    (T : X × Y → X × Y)
    (hT : MeasurePreserving T μ μWorst)
    (hmaeMeas :
      AEStronglyMeasurable
        (fun xy : X × Y => Finite.paperConditionalMAE qWorst xy.1) μWorst)
    (hmae : ∀ xy : X × Y,
      Finite.paperConditionalMAE qWorst (T xy).1 =
        Finite.paperConditionalMAE q xy.1) :
    continuousJointClassifierMAE μWorst qWorst =
      continuousJointClassifierMAE μ q := by
  have hmaeMeas_map :
      AEStronglyMeasurable
        (fun xy : X × Y => Finite.paperConditionalMAE qWorst xy.1)
        (Measure.map T μ) := by
    rw [hT.map_eq]
    exact hmaeMeas
  unfold continuousJointClassifierMAE
  rw [← hT.map_eq]
  rw [integral_map hT.aemeasurable hmaeMeas_map]
  refine integral_congr_ae (Filter.Eventually.of_forall ?_)
  intro xy
  exact hmae xy

/--
Pushforward transformations preserve the focal prior when they preserve labels
almost everywhere.
-/
theorem continuousJointPrior_eq_of_measurePreserving_label_ae
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μWorst : Measure (X × Y)) (z : Y) (T : X × Y → X × Y)
    (hT : MeasurePreserving T μ μWorst)
    (hpriorMeas :
      AEStronglyMeasurable (fun xy : X × Y => if xy.2 = z then (1 : ℝ) else 0)
        μWorst)
    (hlabel : (fun xy : X × Y => (T xy).2) =ᵐ[μ] fun xy => xy.2) :
    continuousJointPrior μWorst z = continuousJointPrior μ z := by
  have hpriorMeas_map :
      AEStronglyMeasurable (fun xy : X × Y => if xy.2 = z then (1 : ℝ) else 0)
        (Measure.map T μ) := by
    rw [hT.map_eq]
    exact hpriorMeas
  unfold continuousJointPrior
  rw [← hT.map_eq]
  rw [integral_map hT.aemeasurable hpriorMeas_map]
  refine integral_congr_ae ?_
  filter_upwards [hlabel] with xy hxy
  simp [hxy]

/--
Pushforward transformations weakly increase the focal decision share when the
transformed rule's focal indicator dominates the original one almost
everywhere.
-/
theorem continuousJointDecisionShare_le_of_measurePreserving_rule_indicator_ae
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μWorst : Measure (X × Y)) (rule ruleWorst : X → Y) (z : Y)
    (T : X × Y → X × Y)
    (hT : MeasurePreserving T μ μWorst)
    (horigInt :
      Integrable (fun xy : X × Y => if rule xy.1 = z then (1 : ℝ) else 0) μ)
    (hworstInt :
      Integrable (fun xy : X × Y => if ruleWorst xy.1 = z then (1 : ℝ) else 0)
        μWorst)
    (hdecision_le :
      (fun xy : X × Y => if rule xy.1 = z then (1 : ℝ) else 0) ≤ᵐ[μ]
        fun xy : X × Y => if ruleWorst (T xy).1 = z then (1 : ℝ) else 0) :
    continuousJointDecisionShare μ rule z ≤
      continuousJointDecisionShare μWorst ruleWorst z := by
  have hworstMeas_map :
      AEStronglyMeasurable
        (fun xy : X × Y => if ruleWorst xy.1 = z then (1 : ℝ) else 0)
        (Measure.map T μ) := by
    rw [hT.map_eq]
    exact hworstInt.aestronglyMeasurable
  have hworstMapInt :
      Integrable
        (fun xy : X × Y => if ruleWorst (T xy).1 = z then (1 : ℝ) else 0) μ := by
    simpa [Function.comp_def] using
      (hT.integrable_comp_of_integrable hworstInt)
  unfold continuousJointDecisionShare
  rw [← hT.map_eq]
  rw [integral_map hT.aemeasurable hworstMeas_map]
  exact integral_mono_ae horigInt hworstMapInt hdecision_le

/--
Pushforward transformations weakly decrease continuous MAE when the transformed
conditional-MAE integrand is bounded above by the original one almost
everywhere.
-/
theorem continuousJointClassifierMAE_le_of_measurePreserving_ae
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μWorst : Measure (X × Y)) (q qWorst : X → Y → ℝ)
    (T : X × Y → X × Y)
    (hT : MeasurePreserving T μ μWorst)
    (horigInt :
      Integrable (fun xy : X × Y => Finite.paperConditionalMAE q xy.1) μ)
    (hworstInt :
      Integrable (fun xy : X × Y => Finite.paperConditionalMAE qWorst xy.1)
        μWorst)
    (hmae_le :
      (fun xy : X × Y => Finite.paperConditionalMAE qWorst (T xy).1) ≤ᵐ[μ]
        fun xy : X × Y => Finite.paperConditionalMAE q xy.1) :
    continuousJointClassifierMAE μWorst qWorst ≤
      continuousJointClassifierMAE μ q := by
  have hworstMeas_map :
      AEStronglyMeasurable
        (fun xy : X × Y => Finite.paperConditionalMAE qWorst xy.1)
        (Measure.map T μ) := by
    rw [hT.map_eq]
    exact hworstInt.aestronglyMeasurable
  have hworstMapInt :
      Integrable
        (fun xy : X × Y => Finite.paperConditionalMAE qWorst (T xy).1) μ := by
    simpa [Function.comp_def] using
      (hT.integrable_comp_of_integrable hworstInt)
  unfold continuousJointClassifierMAE
  rw [← hT.map_eq]
  rw [integral_map hT.aemeasurable hworstMeas_map]
  exact integral_mono_ae hworstMapInt horigInt hmae_le

/--
Pushforward transformations weakly decrease continuous MAE when the integrated
conditional-MAE delta after pulling the target integrand back along the map is
nonpositive.

This is the aggregate counterpart to
`continuousJointClassifierMAE_le_of_measurePreserving_ae`: it is useful for
source-transformations where some local moves increase MAE but the balanced
split has nonpositive total delta.
-/
theorem continuousJointClassifierMAE_le_of_measurePreserving_integral_delta
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μNext : Measure (X × Y)) (q qNext : X → Y → ℝ)
    (T : X × Y → X × Y)
    (hT : MeasurePreserving T μ μNext)
    (horigInt :
      Integrable (fun xy : X × Y => Finite.paperConditionalMAE q xy.1) μ)
    (hnextInt :
      Integrable (fun xy : X × Y => Finite.paperConditionalMAE qNext xy.1)
        μNext)
    (hdelta_nonpos :
      (∫ xy : X × Y,
          (Finite.paperConditionalMAE qNext (T xy).1 -
            Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0) :
    continuousJointClassifierMAE μNext qNext ≤ continuousJointClassifierMAE μ q := by
  have hnextMeas_map :
      AEStronglyMeasurable
        (fun xy : X × Y => Finite.paperConditionalMAE qNext xy.1)
        (Measure.map T μ) := by
    rw [hT.map_eq]
    exact hnextInt.aestronglyMeasurable
  have hnextMapInt :
      Integrable
        (fun xy : X × Y => Finite.paperConditionalMAE qNext (T xy).1) μ := by
    simpa [Function.comp_def] using
      (hT.integrable_comp_of_integrable hnextInt)
  have hmap_eq :
      continuousJointClassifierMAE μNext qNext =
        ∫ xy : X × Y, Finite.paperConditionalMAE qNext (T xy).1 ∂μ := by
    unfold continuousJointClassifierMAE
    rw [← hT.map_eq]
    rw [integral_map hT.aemeasurable hnextMeas_map]
  have hsub_nonpos :
      (∫ xy : X × Y, Finite.paperConditionalMAE qNext (T xy).1 ∂μ) -
          ∫ xy : X × Y, Finite.paperConditionalMAE q xy.1 ∂μ ≤ 0 := by
    rw [← integral_sub hnextMapInt horigInt]
    exact hdelta_nonpos
  calc
    continuousJointClassifierMAE μNext qNext =
        ∫ xy : X × Y, Finite.paperConditionalMAE qNext (T xy).1 ∂μ := hmap_eq
    _ ≤ ∫ xy : X × Y, Finite.paperConditionalMAE q xy.1 ∂μ := by
      linarith
    _ = continuousJointClassifierMAE μ q := rfl

/--
Sequential same-law posterior updates with nonpositive integrated conditional
MAE deltas have nonpositive total integrated MAE delta.
-/
theorem integral_paperConditionalMAE_delta_nonpos_trans
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q₀ q₁ q₂ : X → Y → ℝ)
    (hmae₀ :
      Integrable (fun xy : X × Y => Finite.paperConditionalMAE q₀ xy.1) μ)
    (hmae₁ :
      Integrable (fun xy : X × Y => Finite.paperConditionalMAE q₁ xy.1) μ)
    (hmae₂ :
      Integrable (fun xy : X × Y => Finite.paperConditionalMAE q₂ xy.1) μ)
    (hdelta₀₁ :
      (∫ xy : X × Y,
          (Finite.paperConditionalMAE q₁ xy.1 -
            Finite.paperConditionalMAE q₀ xy.1) ∂μ) ≤ 0)
    (hdelta₁₂ :
      (∫ xy : X × Y,
          (Finite.paperConditionalMAE q₂ xy.1 -
            Finite.paperConditionalMAE q₁ xy.1) ∂μ) ≤ 0) :
    (∫ xy : X × Y,
        (Finite.paperConditionalMAE q₂ xy.1 -
          Finite.paperConditionalMAE q₀ xy.1) ∂μ) ≤ 0 := by
  have h₂₁Int :
      Integrable
        (fun xy : X × Y =>
          Finite.paperConditionalMAE q₂ xy.1 -
            Finite.paperConditionalMAE q₁ xy.1) μ :=
    hmae₂.sub hmae₁
  have h₁₀Int :
      Integrable
        (fun xy : X × Y =>
          Finite.paperConditionalMAE q₁ xy.1 -
            Finite.paperConditionalMAE q₀ xy.1) μ :=
    hmae₁.sub hmae₀
  have hpoint : ∀ xy : X × Y,
      Finite.paperConditionalMAE q₂ xy.1 -
          Finite.paperConditionalMAE q₀ xy.1 =
        (Finite.paperConditionalMAE q₂ xy.1 -
            Finite.paperConditionalMAE q₁ xy.1) +
          (Finite.paperConditionalMAE q₁ xy.1 -
            Finite.paperConditionalMAE q₀ xy.1) := by
    intro xy
    ring
  calc
    (∫ xy : X × Y,
        (Finite.paperConditionalMAE q₂ xy.1 -
          Finite.paperConditionalMAE q₀ xy.1) ∂μ)
        =
      ∫ xy : X × Y,
        ((Finite.paperConditionalMAE q₂ xy.1 -
            Finite.paperConditionalMAE q₁ xy.1) +
          (Finite.paperConditionalMAE q₁ xy.1 -
            Finite.paperConditionalMAE q₀ xy.1)) ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ =
        (∫ xy : X × Y,
          (Finite.paperConditionalMAE q₂ xy.1 -
            Finite.paperConditionalMAE q₁ xy.1) ∂μ) +
        ∫ xy : X × Y,
          (Finite.paperConditionalMAE q₁ xy.1 -
            Finite.paperConditionalMAE q₀ xy.1) ∂μ := by
          exact integral_add h₂₁Int h₁₀Int
    _ ≤ 0 := by
      linarith

theorem integral_paperConditionalMAE_delta_nonpos_trans_simplex_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSingletonClass Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q₀ q₁ q₂ : X → Y → ℝ)
    (hscore₀ : ∀ y : Y, Measurable (fun xy : X × Y => q₀ xy.1 y))
    (hscore₁ : ∀ y : Y, Measurable (fun xy : X × Y => q₁ xy.1 y))
    (hscore₂ : ∀ y : Y, Measurable (fun xy : X × Y => q₂ xy.1 y))
    (hsum₀ : ∀ x, (∑ a : Y, q₀ x a) = 1)
    (hnonneg₀ : ∀ x y, 0 ≤ q₀ x y)
    (hsum₁ : ∀ x, (∑ a : Y, q₁ x a) = 1)
    (hnonneg₁ : ∀ x y, 0 ≤ q₁ x y)
    (hsum₂ : ∀ x, (∑ a : Y, q₂ x a) = 1)
    (hnonneg₂ : ∀ x y, 0 ≤ q₂ x y)
    (hdelta₀₁ :
      (∫ xy : X × Y,
          (Finite.paperConditionalMAE q₁ xy.1 -
            Finite.paperConditionalMAE q₀ xy.1) ∂μ) ≤ 0)
    (hdelta₁₂ :
      (∫ xy : X × Y,
          (Finite.paperConditionalMAE q₂ xy.1 -
            Finite.paperConditionalMAE q₁ xy.1) ∂μ) ≤ 0) :
    (∫ xy : X × Y,
        (Finite.paperConditionalMAE q₂ xy.1 -
          Finite.paperConditionalMAE q₀ xy.1) ∂μ) ≤ 0 :=
  integral_paperConditionalMAE_delta_nonpos_trans μ q₀ q₁ q₂
    (integrable_jointConditionalMAE_of_scores_simplex_finite
      μ q₀ hscore₀ hsum₀ hnonneg₀)
    (integrable_jointConditionalMAE_of_scores_simplex_finite
      μ q₁ hscore₁ hsum₁ hnonneg₁)
    (integrable_jointConditionalMAE_of_scores_simplex_finite
      μ q₂ hscore₂ hsum₂ hnonneg₂)
    hdelta₀₁ hdelta₁₂

/--
Build the source transformation certificate from a concrete measure-preserving
transformation into the worst-case classifier.
-/
theorem sourceTransformationCertificate_of_measurePreserving_worstCaseEquality
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ μWorst : Measure (X × Y)) (q qWorst : X → Y → ℝ)
    (rule ruleWorst : X → Y) (z : Y) (T : X × Y → X × Y)
    (hT : MeasurePreserving T μ μWorst)
    (hpriorMeas :
      AEStronglyMeasurable (fun xy : X × Y => if xy.2 = z then (1 : ℝ) else 0)
        μWorst)
    (hdecisionMeas :
      AEStronglyMeasurable
        (fun xy : X × Y => if ruleWorst xy.1 = z then (1 : ℝ) else 0) μWorst)
    (hmaeMeas :
      AEStronglyMeasurable
        (fun xy : X × Y => Finite.paperConditionalMAE qWorst xy.1) μWorst)
    (hlabel : ∀ xy : X × Y, (T xy).2 = xy.2)
    (hdecision : ∀ xy : X × Y, ruleWorst (T xy).1 = rule xy.1)
    (hmae : ∀ xy : X × Y,
      Finite.paperConditionalMAE qWorst (T xy).1 =
        Finite.paperConditionalMAE q xy.1)
    (hworst : SourceWorstCaseEqualityCertificate μWorst qWorst ruleWorst z) :
    SourceTransformationCertificate μ μWorst q qWorst rule ruleWorst z := by
  have hprior_eq :
      continuousJointPrior μWorst z = continuousJointPrior μ z :=
    continuousJointPrior_eq_of_measurePreserving_label
      μ μWorst z T hT hpriorMeas hlabel
  have hdecision_eq :
      continuousJointDecisionShare μWorst ruleWorst z =
        continuousJointDecisionShare μ rule z :=
    continuousJointDecisionShare_eq_of_measurePreserving_rule
      μ μWorst rule ruleWorst z T hT hdecisionMeas hdecision
  have hmae_eq :
      continuousJointClassifierMAE μWorst qWorst =
        continuousJointClassifierMAE μ q :=
    continuousJointClassifierMAE_eq_of_measurePreserving
      μ μWorst q qWorst T hT hmaeMeas hmae
  exact sourceTransformationCertificate_of_worstCaseEquality
    μ μWorst q qWorst rule ruleWorst z hprior_eq
    (le_of_eq hdecision_eq.symm) (le_of_eq hmae_eq) hworst

