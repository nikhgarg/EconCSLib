        ¬ Pareto.ParetoOptimal
          (datasetAccuracyScore (sampledPosterior posterior sample))
          (datasetFidelity pref) (sampledDecision rule sample) := by
  classical
  rcases exists_target_allDisagreement_event_pos_of_disagreement_event_pos
    μ rule argmaxRule hdisagree with
    ⟨target, htarget_pos⟩
  rcases
    paper_theorem2iii_exists_positive_mass_sample_not_pareto_of_disagreement_event_pos
      μ posterior pref rule argmaxRule target htarget_pos hNpos hpref_nonneg
      hpref_sum (hnontrivial target) hweak_argmax with
