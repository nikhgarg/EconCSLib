                (hS.inter measurableSet_Ioc) hqCoordz
  have hrightMap :
      (∫ x, (r ⁻¹' (S ∩ Ioc cut hi)).indicator
            (fun x : X => (Fintype.card Y : ℝ)⁻¹ - q x z) x ∂νX) =
        ∫ t, (S ∩ Ioc cut hi).indicator
          (fun t : ℝ => (Fintype.card Y : ℝ)⁻¹ - qCoord t z) t ∂νR := by
    have hpoint : ∀ x : X,
        (r ⁻¹' (S ∩ Ioc cut hi)).indicator
            (fun x : X => (Fintype.card Y : ℝ)⁻¹ - q x z) x =
          (r ⁻¹' (S ∩ Ioc cut hi)).indicator
