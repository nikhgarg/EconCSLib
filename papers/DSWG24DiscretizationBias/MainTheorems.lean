    (N := N) μ rule argmaxRule target htarget_pos with
    ⟨sample, hall, hsample_pos⟩
  exact
    paper_theorem2iii_not_expected_weightedObjective_maximizer_of_independent_all_disagreement_sample_strict_argmax
      (iidSamplePMF μ N) posterior pref rule argmaxRule sample target hγpos
      hγle hsample_pos hNpos hall hpref_nonneg hpref_sum
      (hnontrivial target)
      (by
        intro i
        have htarget : argmaxRule (sample i) = target := (hall i).1
        have hne : rule (sample i) ≠ argmaxRule (sample i) := by
          simpa [htarget] using (hall i).2
        simpa [htarget] using hstrict_argmax (sample i) hne)

/--
Theorem 2(iii), finite randomized-rule interface.

The atom type `Z` can package a feature together with realized randomness used
by an independent randomized rule.  The argmax rule and posterior depend only on
the projected feature, while the realized independent decision may depend on
all of `Z`.
-/
theorem paper_theorem2iii_exists_positive_mass_sample_not_pareto_of_augmented_rule_disagrees_pos
    {Z X : Type*} [Fintype Z] [DecidableEq Z] {N K : ℕ}
    (ν : PMF Z) (feature : Z → X)
    (posterior : X → Fin K → ℝ) (pref : Fin K → ℝ)
    (rule : Z → Fin K) (argmaxRule : X → Fin K)
    (hdisagree :
      0 < EconCSLib.pmfProb ν
        (fun z : Z => rule z ≠ argmaxRule (feature z)))
    (hNpos : 0 < N)
    (hpref_nonneg : ∀ y, 0 ≤ pref y)
    (hpref_sum : (∑ y : Fin K, pref y) = 1)
    (hnontrivial : ∀ y : Fin K, 1 / (N : ℝ) ≤ pref y)
    (hweak_argmax : ∀ x y, posterior x y ≤ posterior x (argmaxRule x)) :
    ∃ target : Fin K, ∃ sample : Fin N → Z,
      0 < ((iidSamplePMF ν N) sample).toReal ∧
        ¬ Pareto.ParetoOptimal
          (datasetAccuracyScore
            (sampledPosterior (fun z y => posterior (feature z) y) sample))
          (datasetFidelity pref) (sampledDecision rule sample) := by
  classical
  exact
    paper_theorem2iii_exists_positive_mass_sample_not_pareto_of_independent_rule_disagrees_pos
      ν (fun z y => posterior (feature z) y) pref rule
      (fun z => argmaxRule (feature z)) hdisagree hNpos hpref_nonneg
      hpref_sum hnontrivial
      (by
        intro z y
        exact hweak_argmax (feature z) y)

