theorem jointFeatureSetMass_union_of_disjoint
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (S T : Set X)
    (hdisj : Disjoint S T)
    (hSInt :
      Integrable (fun xy : X × Y => S.indicator (fun _ : X => (1 : ℝ)) xy.1) μ)
    (hTInt :
      Integrable (fun xy : X × Y => T.indicator (fun _ : X => (1 : ℝ)) xy.1) μ) :
    jointFeatureSetMass μ (S ∪ T) =
      jointFeatureSetMass μ S + jointFeatureSetMass μ T := by
  unfold jointFeatureSetMass
  have hpoint : ∀ xy : X × Y,
      (S ∪ T).indicator (fun _ : X => (1 : ℝ)) xy.1 =
        S.indicator (fun _ : X => (1 : ℝ)) xy.1 +
          T.indicator (fun _ : X => (1 : ℝ)) xy.1 := by
    intro xy
    by_cases hS : xy.1 ∈ S
    · have hnotT : xy.1 ∉ T := Set.disjoint_left.mp hdisj hS
      simp [hS, hnotT]
    · by_cases hT : xy.1 ∈ T
      · simp [hS, hT]
      · simp [hS, hT]
  calc
    (∫ xy : X × Y, (S ∪ T).indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ)
        = ∫ xy : X × Y,
            (S.indicator (fun _ : X => (1 : ℝ)) xy.1 +
              T.indicator (fun _ : X => (1 : ℝ)) xy.1) ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ = (∫ xy : X × Y, S.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
          ∫ xy : X × Y, T.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ := by
          rw [integral_add hSInt hTInt]

theorem jointFeatureSetMass_union_of_disjoint_finite
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] (S T : Set X)
    (hdisj : Disjoint S T)
    (hSMeas :
      AEStronglyMeasurable
        (fun xy : X × Y => S.indicator (fun _ : X => (1 : ℝ)) xy.1) μ)
    (hTMeas :
      AEStronglyMeasurable
        (fun xy : X × Y => T.indicator (fun _ : X => (1 : ℝ)) xy.1) μ) :
    jointFeatureSetMass μ (S ∪ T) =
      jointFeatureSetMass μ S + jointFeatureSetMass μ T :=
  jointFeatureSetMass_union_of_disjoint μ S T hdisj
    (integrable_jointFeatureSetIndicator_of_finite μ S hSMeas)
    (integrable_jointFeatureSetIndicator_of_finite μ T hTMeas)

theorem continuousJointDecisionShare_sourceSaSc_sum_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (rule : X → Y) (z : Y) (uniformScore : ℝ)
    (hqz : Measurable fun x : X => q x z)
    (huniform_lt_one : uniformScore < 1)
    (hdecision :
      ∀ x, rule x = z ↔
        x ∈ sourceSaRegion q z ∪ sourceScRegion q z uniformScore) :
    continuousJointDecisionShare μ rule z =
      jointFeatureSetMass μ (sourceSaRegion q z) +
        jointFeatureSetMass μ (sourceScRegion q z uniformScore) := by
  classical
  let Sa : Set X := sourceSaRegion q z
  let Sc : Set X := sourceScRegion q z uniformScore
  have hshare :
      continuousJointDecisionShare μ rule z = jointFeatureSetMass μ (Sa ∪ Sc) :=
    continuousJointDecisionShare_eq_jointFeatureSetMass_of_rule_iff
      μ rule z (Sa ∪ Sc) hdecision
  have hdisj : Disjoint Sa Sc :=
    sourceSaRegion_disjoint_sourceScRegion huniform_lt_one
  have hSaMeas : MeasurableSet Sa := measurableSet_sourceSaRegion hqz
  have hScMeas : MeasurableSet Sc := measurableSet_sourceScRegion hqz
  rw [hshare]
  exact jointFeatureSetMass_union_of_disjoint_finite
    μ Sa Sc hdisj
    (aestronglyMeasurable_jointFeatureSetIndicator_of_measurableSet μ hSaMeas)
    (aestronglyMeasurable_jointFeatureSetIndicator_of_measurableSet μ hScMeas)

theorem jointFeatureSetMass_five_union_of_pairwise_disjoint
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (S1 S2 S3 S4 S5 : Set X)
    (h12 : Disjoint S1 S2) (h13 : Disjoint S1 S3)
    (h14 : Disjoint S1 S4) (h15 : Disjoint S1 S5)
    (h23 : Disjoint S2 S3) (h24 : Disjoint S2 S4)
    (h25 : Disjoint S2 S5) (h34 : Disjoint S3 S4)
    (h35 : Disjoint S3 S5) (h45 : Disjoint S4 S5)
    (hS1Int :
      Integrable (fun xy : X × Y => S1.indicator (fun _ : X => (1 : ℝ)) xy.1) μ)
    (hS2Int :
      Integrable (fun xy : X × Y => S2.indicator (fun _ : X => (1 : ℝ)) xy.1) μ)
    (hS3Int :
      Integrable (fun xy : X × Y => S3.indicator (fun _ : X => (1 : ℝ)) xy.1) μ)
    (hS4Int :
      Integrable (fun xy : X × Y => S4.indicator (fun _ : X => (1 : ℝ)) xy.1) μ)
    (hS5Int :
      Integrable (fun xy : X × Y => S5.indicator (fun _ : X => (1 : ℝ)) xy.1) μ) :
    jointFeatureSetMass μ (S1 ∪ (S2 ∪ (S3 ∪ (S4 ∪ S5)))) =
      jointFeatureSetMass μ S1 + jointFeatureSetMass μ S2 +
        jointFeatureSetMass μ S3 + jointFeatureSetMass μ S4 +
          jointFeatureSetMass μ S5 := by
  have hpoint : ∀ xy : X × Y,
      (S1 ∪ (S2 ∪ (S3 ∪ (S4 ∪ S5)))).indicator
          (fun _ : X => (1 : ℝ)) xy.1 =
        S1.indicator (fun _ : X => (1 : ℝ)) xy.1 +
          (S2.indicator (fun _ : X => (1 : ℝ)) xy.1 +
            (S3.indicator (fun _ : X => (1 : ℝ)) xy.1 +
              (S4.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                S5.indicator (fun _ : X => (1 : ℝ)) xy.1))) := by
    intro xy
    by_cases h1 : xy.1 ∈ S1
    · have hnot2 : xy.1 ∉ S2 := Set.disjoint_left.mp h12 h1
      have hnot3 : xy.1 ∉ S3 := Set.disjoint_left.mp h13 h1
      have hnot4 : xy.1 ∉ S4 := Set.disjoint_left.mp h14 h1
      have hnot5 : xy.1 ∉ S5 := Set.disjoint_left.mp h15 h1
      simp [h1, hnot2, hnot3, hnot4, hnot5]
    · by_cases h2 : xy.1 ∈ S2
      · have hnot3 : xy.1 ∉ S3 := Set.disjoint_left.mp h23 h2
        have hnot4 : xy.1 ∉ S4 := Set.disjoint_left.mp h24 h2
        have hnot5 : xy.1 ∉ S5 := Set.disjoint_left.mp h25 h2
        simp [h1, h2, hnot3, hnot4, hnot5]
      · by_cases h3 : xy.1 ∈ S3
        · have hnot4 : xy.1 ∉ S4 := Set.disjoint_left.mp h34 h3
          have hnot5 : xy.1 ∉ S5 := Set.disjoint_left.mp h35 h3
          simp [h1, h2, h3, hnot4, hnot5]
        · by_cases h4 : xy.1 ∈ S4
          · have hnot5 : xy.1 ∉ S5 := Set.disjoint_left.mp h45 h4
            simp [h1, h2, h3, h4, hnot5]
          · by_cases h5 : xy.1 ∈ S5
            · simp [h1, h2, h3, h4, h5]
            · simp [h1, h2, h3, h4, h5]
  unfold jointFeatureSetMass
  calc
    (∫ xy : X × Y,
        (S1 ∪ (S2 ∪ (S3 ∪ (S4 ∪ S5)))).indicator
          (fun _ : X => (1 : ℝ)) xy.1 ∂μ)
        = ∫ xy : X × Y,
            S1.indicator (fun _ : X => (1 : ℝ)) xy.1 +
              (S2.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                (S3.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                  (S4.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                    S5.indicator (fun _ : X => (1 : ℝ)) xy.1))) ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ =
        (∫ xy : X × Y, S1.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
          ((∫ xy : X × Y, S2.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
            ((∫ xy : X × Y, S3.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
              ((∫ xy : X × Y, S4.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
                ∫ xy : X × Y, S5.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ))) := by
          have h1 :
              (∫ xy : X × Y,
                S1.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                  (S2.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                    (S3.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                      (S4.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                        S5.indicator (fun _ : X => (1 : ℝ)) xy.1))) ∂μ) =
                (∫ xy : X × Y,
                  S1.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
                  ∫ xy : X × Y,
                    S2.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                      (S3.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                        (S4.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                          S5.indicator (fun _ : X => (1 : ℝ)) xy.1)) ∂μ := by
            simpa only [Pi.add_apply] using
              (integral_add hS1Int (hS2Int.add (hS3Int.add (hS4Int.add hS5Int))))
          have h2 :
              (∫ xy : X × Y,
                S2.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                  (S3.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                    (S4.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                      S5.indicator (fun _ : X => (1 : ℝ)) xy.1)) ∂μ) =
                (∫ xy : X × Y,
                  S2.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
                  ∫ xy : X × Y,
                    S3.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                      (S4.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                        S5.indicator (fun _ : X => (1 : ℝ)) xy.1) ∂μ := by
            simpa only [Pi.add_apply] using
              (integral_add hS2Int (hS3Int.add (hS4Int.add hS5Int)))
          have h3 :
              (∫ xy : X × Y,
                S3.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                  (S4.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                    S5.indicator (fun _ : X => (1 : ℝ)) xy.1) ∂μ) =
                (∫ xy : X × Y,
                  S3.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
                  ∫ xy : X × Y,
                    S4.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                      S5.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ := by
            simpa only [Pi.add_apply] using
              (integral_add hS3Int (hS4Int.add hS5Int))
          have h4 :
              (∫ xy : X × Y,
                S4.indicator (fun _ : X => (1 : ℝ)) xy.1 +
                  S5.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) =
                (∫ xy : X × Y,
                  S4.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
                  ∫ xy : X × Y,
                    S5.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ := by
            simpa only [Pi.add_apply] using
              (integral_add hS4Int hS5Int)
          rw [h1, h2, h3, h4]
    _ =
        (∫ xy : X × Y, S1.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
          (∫ xy : X × Y, S2.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
            (∫ xy : X × Y, S3.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
              (∫ xy : X × Y, S4.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
                ∫ xy : X × Y, S5.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ := by
          ring

