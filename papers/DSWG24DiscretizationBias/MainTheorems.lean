          ∫ x, (S ∩ Ioc cut hi).indicator (fun x : ℝ => 1 - q x z) x
            ∂(Measure.map Prod.fst μ) :=
      integral_fst_preimage_indicator_eq_featureMarginal_integral
        μ (S ∩ Ioc cut hi) (fun x : ℝ => 1 - q x z)
        (hS.inter measurableSet_Ioc) (measurable_const.sub (hq z))
