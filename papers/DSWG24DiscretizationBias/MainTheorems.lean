      Integrable
        (fun xy : ℝ × Y =>
          (-2 * (1 - u)) *
            (Prod.fst ⁻¹' Ioc cut hi).indicator
              (fun xy : ℝ × Y => 1 - q xy.1 z) xy) μ := by
    simpa [smul_eq_mul] using hAUpperBase.const_mul (-2 * (1 - u))
  have hBUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc lo cut).indicator
            (fun xy : ℝ × Y => q xy.1 z - u) xy) μ :=
    integrable_fst_preimage_score_excess_indicator_finite
      μ q (Ioc lo cut) z u measurableSet_Ioc (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hBUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (2 * u) *
            (Prod.fst ⁻¹' Ioc lo cut).indicator
              (fun xy : ℝ × Y => q xy.1 z - u) xy) μ := by
    simpa [smul_eq_mul] using hBUpperBase.const_mul (2 * u)
  refine ⟨cut, w, hcut, hw_meas, hsel, ?_⟩
  simpa [u] using
    sourceSb_split_twoCoordinate_delta_integral_nonpos_of_balance_uniform_region
      μ q (Ioc cut hi) (Ioc lo cut) z w hcard_gt_one
      hAInt hBInt hAUpperInt hBUpperInt
      hSbaRegion hSbcRegion
      (Filter.Eventually.of_forall fun xy hxy => (hsel xy hxy).2.le)
      (Filter.Eventually.of_forall fun xy _ => hnonneg xy.1 (w xy))
      hbalance

/--
Source Step 1 interval split as an actual piecewise posterior transformation.

The interval machinery chooses a cut and a measurable below-uniform nonfocal
selector.  If `qNext` has the corresponding `S_b -> S_a` shape on `(cut, hi]`,
the `S_b -> S_c` shape on `(lo, cut]`, and is unchanged outside the two pieces,
then the integrated MAE delta of `qNext` is nonpositive.
-/
theorem sourceSb_interval_split_exists_measurable_nonfocal_twoRegion_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q qNext : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ}
    (hcard_gt_one : 1 < Fintype.card Y)
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hshapeA :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi → ∀ a : Y,
          qNext xy.1 a =
            if a = z then 1
            else if a = w xy then q xy.1 (w xy) - (1 - q xy.1 z)
            else q xy.1 a)
    (hshapeB :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc lo cut → ∀ a : Y,
          qNext xy.1 a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w xy then
              q xy.1 (w xy) + (q xy.1 z - (Fintype.card Y : ℝ)⁻¹)
            else q xy.1 a)
    (hshapeOutside :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) →
        ∀ᵐ xy ∂μ, xy.1 ∉ Ioc cut hi → xy.1 ∉ Ioc lo cut → ∀ a : Y,
          qNext xy.1 a = q xy.1 a) :
    ∃ cut : ℝ, ∃ w : ℝ × Y → Y,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSb_interval_split_exists_measurable_nonfocal_twoCoordinate_delta_integral_nonpos_uniform_simplex_finite
      μ q z hcard_gt_one hlohi hfinite hq hsum hnonneg hregion with
    ⟨cut, w, hcut, hw_meas, hsel, hformula_nonpos⟩
  have hdisj : Disjoint (Ioc cut hi) (Ioc lo cut) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    exact (not_lt_of_ge hx_lo.2) hx_hi.1
  have hzw :
      ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut → z ≠ w xy :=
    Filter.Eventually.of_forall fun xy hxy => (hsel xy hxy).1.symm
  refine ⟨cut, w, hcut, hw_meas, hsel, ?_⟩
  simpa [u] using
    integral_paperConditionalMAE_delta_sourceSb_twoRegion_nonpos
      μ q qNext (Ioc cut hi) (Ioc lo cut) z w u hdisj hzw
      (hshapeA cut w hcut hw_meas hsel)
      (by simpa [u] using hshapeB cut w hcut hw_meas hsel)
      (hshapeOutside cut w hcut hw_meas hsel)
      (by simpa [u] using hformula_nonpos)

/--
Constructive `S_b` interval source transformation.

This endpoint chooses the balancing cut, a measurable feature-level nonfocal
selector, and the piecewise transformed posterior `qNext`.  It proves the
resulting integrated classifier-MAE delta is nonpositive.
-/
theorem sourceSb_interval_split_exists_measurable_feature_qNext_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ}
    (hcard_gt_one : 1 < Fintype.card Y)
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ q x (w x) < (Fintype.card Y : ℝ)⁻¹) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then 1
            else if a = w x then q x (w x) - (1 - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) + (q x z - (Fintype.card Y : ℝ)⁻¹)
            else q x a) ∧
        (∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSb_interval_split_exists_measurable_feature_nonfocal_selector_product_balance_simplex_finite
      μ q z hlohi hfinite hq hsum hnonneg hregion with
    ⟨cut, w, hcut, hw_meas, hsel, hbalance⟩
