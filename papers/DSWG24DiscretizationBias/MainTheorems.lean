    intro xy hxy
    simpa [wProd, u] using hsel xy.1 hxy
  have hSbaRegion :
      ∀ x, x ∈ Ioc cut hi →
        x ∈ sourceSbRegion q z u := by
    intro x hx
    simpa [u] using hregion x ⟨hcut.1.trans hx.1.le, hx.2⟩
  have hSbcRegion :
      ∀ x, x ∈ Ioc lo cut →
        x ∈ sourceSbRegion q z u := by
    intro x hx
    simpa [u] using hregion x ⟨hx.1.le, hx.2.trans hcut.2⟩
  have hAInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc cut hi).indicator (fun xy : ℝ × Y =>
            -2 * (1 - q xy.1 (wProd xy)) * (1 - q xy.1 z)
          ) xy) μ :=
    integrable_fst_preimage_twoCoordinate_delta_toOne_indicator_finite
