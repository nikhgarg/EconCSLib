theorem not_expectedDataset_weightedObjective_maximizer_of_positive_mass_sample_strictly_dominated
    {Sample : Type*} [Fintype Sample] [DecidableEq Sample] {N K : ℕ}
    (sampleLaw : PMF Sample) (posterior : Sample → Fin N → Fin K → ℝ)
    (pref : Fin K → ℝ) (policy : Sample → Fin N → Fin K)
    (sample : Sample) (betterDecision : Fin N → Fin K)
    {γ : ℝ} (hγpos : 0 < γ) (hγle : γ ≤ 1)
    (hmass : 0 < (sampleLaw sample).toReal)
    (hacc :
      datasetAccuracyScore (posterior sample) (policy sample) <
        datasetAccuracyScore (posterior sample) betterDecision)
    (hfid :
      datasetFidelity pref (policy sample) <
        datasetFidelity pref betterDecision) :
    ¬ ∀ other : Sample → Fin N → Fin K,
        Pareto.weightedObjective γ
            (expectedDatasetAccuracy sampleLaw posterior)
            (expectedDatasetFidelity sampleLaw pref) other ≤
          Pareto.weightedObjective γ
            (expectedDatasetAccuracy sampleLaw posterior)
            (expectedDatasetFidelity sampleLaw pref) policy := by
  classical
  let betterPolicy := switchPolicyAtSample policy sample betterDecision
  have haccExp :
      expectedDatasetAccuracy sampleLaw posterior policy <
        expectedDatasetAccuracy sampleLaw posterior betterPolicy := by
    unfold expectedDatasetAccuracy
    refine pmfExp_lt_pmfExp_of_forall_le_exists_lt sampleLaw _ _ ?_ ?_
    · intro s
      by_cases hs : s = sample
      · subst s
        exact le_of_lt (by simpa [betterPolicy, switchPolicyAtSample] using hacc)
      · simp [betterPolicy, switchPolicyAtSample, hs]
    · exact ⟨sample, hmass, by
        simpa [betterPolicy, switchPolicyAtSample] using hacc⟩
  have hfidExp :
      expectedDatasetFidelity sampleLaw pref policy <
        expectedDatasetFidelity sampleLaw pref betterPolicy := by
    unfold expectedDatasetFidelity
    refine pmfExp_lt_pmfExp_of_forall_le_exists_lt sampleLaw _ _ ?_ ?_
    · intro s
      by_cases hs : s = sample
      · subst s
        exact le_of_lt (by simpa [betterPolicy, switchPolicyAtSample] using hfid)
      · simp [betterPolicy, switchPolicyAtSample, hs]
    · exact ⟨sample, hmass, by
        simpa [betterPolicy, switchPolicyAtSample] using hfid⟩
  refine Pareto.not_weightedObjective_maximizer_of_strictlyDominatesBoth
    (expectedDatasetAccuracy sampleLaw posterior)
    (expectedDatasetFidelity sampleLaw pref)
    (rule := policy) (better := betterPolicy) hγpos hγle ?_
  exact ⟨haccExp, hfidExp⟩

/-- The iid product measure on measurable samples `Fin N → X`. -/
noncomputable def iidSampleMeasure {X : Type*} [MeasurableSpace X]
    (μ : Measure X) (N : ℕ) : Measure (Fin N → X) :=
  Measure.pi (fun _ : Fin N => μ)

/-- The event that every row of a sampled dataset lies in a base event. -/
def allRowsSet {X : Type*} {N : ℕ} (event : Set X) : Set (Fin N → X) :=
  Set.pi Set.univ (fun _ : Fin N => event)

theorem iidSampleMeasure_allRowsSet_apply
    {X : Type*} [MeasurableSpace X] (μ : Measure X) [SigmaFinite μ]
    (N : ℕ) (event : Set X) :
    iidSampleMeasure μ N (allRowsSet (N := N) event) =
      ∏ _i : Fin N, μ event := by
  classical
  simp [iidSampleMeasure, allRowsSet, Measure.pi_pi]

theorem iidSampleMeasure_allRowsSet_pos_of_event_pos
    {X : Type*} [MeasurableSpace X] (μ : Measure X) [SigmaFinite μ]
    (N : ℕ) (event : Set X) (hpos : 0 < μ event) :
    0 < iidSampleMeasure μ N (allRowsSet (N := N) event) := by
  rw [iidSampleMeasure_allRowsSet_apply μ N event]
  rw [CanonicallyOrderedAdd.prod_pos]
  intro _ _
  exact hpos

/--
Iid-product specialization of bounded-measurable integrability for dataset
accuracy scores.
-/
theorem integrable_iidDatasetAccuracyScore_of_ae_bound
    {X : Type*} [MeasurableSpace X] (μ : Measure X) [IsFiniteMeasure μ] {N K : ℕ}
    (posterior : (Fin N → X) → Fin N → Fin K → ℝ)
    (policy : (Fin N → X) → Fin N → Fin K) (C : ℝ)
    (hmeas :
      AEStronglyMeasurable
        (fun sample => datasetAccuracyScore (posterior sample) (policy sample))
        (iidSampleMeasure μ N))
    (hbound :
      ∀ᵐ sample ∂iidSampleMeasure μ N,
        ‖datasetAccuracyScore (posterior sample) (policy sample)‖ ≤ C) :
    Integrable
      (fun sample => datasetAccuracyScore (posterior sample) (policy sample))
      (iidSampleMeasure μ N) :=
by
  haveI : IsFiniteMeasure (iidSampleMeasure μ N) := by
    unfold iidSampleMeasure
    infer_instance
  exact integrable_measureDatasetAccuracyScore_of_ae_bound
    (iidSampleMeasure μ N) posterior policy C hmeas hbound

/--
Iid-product specialization of bounded-measurable integrability for dataset
fidelity scores.
-/
theorem integrable_iidDatasetFidelity_of_ae_bound
    {X : Type*} [MeasurableSpace X] (μ : Measure X) [IsFiniteMeasure μ] {N K : ℕ}
    (pref : Fin K → ℝ)
    (policy : (Fin N → X) → Fin N → Fin K) (C : ℝ)
    (hmeas :
      AEStronglyMeasurable
        (fun sample => datasetFidelity pref (policy sample)) (iidSampleMeasure μ N))
    (hbound :
      ∀ᵐ sample ∂iidSampleMeasure μ N, ‖datasetFidelity pref (policy sample)‖ ≤ C) :
    Integrable (fun sample => datasetFidelity pref (policy sample)) (iidSampleMeasure μ N) :=
by
  haveI : IsFiniteMeasure (iidSampleMeasure μ N) := by
    unfold iidSampleMeasure
    infer_instance
  exact integrable_measureDatasetFidelity_of_ae_bound
    (iidSampleMeasure μ N) pref policy C hmeas hbound

/--
`Measure.pi` iid expected-policy Pareto lift from a positive base event: if the
better policy weakly improves accuracy a.e. and strictly improves fidelity on
all samples whose rows lie in the base event, then the original policy is not
Pareto optimal under the iid product measure.
-/
theorem not_measureExpectedDataset_pareto_of_iid_allRows_event_dominated
    {X : Type*} [MeasurableSpace X] (μ : Measure X) [SigmaFinite μ] {N K : ℕ}
    (baseEvent : Set X)
    (posterior : (Fin N → X) → Fin N → Fin K → ℝ) (pref : Fin K → ℝ)
    (policy betterPolicy : (Fin N → X) → Fin N → Fin K)
    (hbase : 0 < μ baseEvent)
    (haccOldInt :
      Integrable
        (fun sample => datasetAccuracyScore (posterior sample) (policy sample))
        (iidSampleMeasure μ N))
    (haccNewInt :
      Integrable
        (fun sample => datasetAccuracyScore (posterior sample) (betterPolicy sample))
        (iidSampleMeasure μ N))
    (hfidOldInt :
      Integrable
        (fun sample => datasetFidelity pref (policy sample)) (iidSampleMeasure μ N))
    (hfidNewInt :
      Integrable
        (fun sample => datasetFidelity pref (betterPolicy sample)) (iidSampleMeasure μ N))
    (hacc :
      (fun sample => datasetAccuracyScore (posterior sample) (policy sample)) ≤ᵐ[iidSampleMeasure μ N]
        fun sample => datasetAccuracyScore (posterior sample) (betterPolicy sample))
    (hfid :
      (fun sample => datasetFidelity pref (policy sample)) ≤ᵐ[iidSampleMeasure μ N]
        fun sample => datasetFidelity pref (betterPolicy sample))
    (hfid_strict : ∀ sample, sample ∈ allRowsSet (N := N) baseEvent →
      datasetFidelity pref (policy sample) <
        datasetFidelity pref (betterPolicy sample)) :
    ¬ Pareto.ParetoOptimal
      (measureExpectedDatasetAccuracy (iidSampleMeasure μ N) posterior)
      (measureExpectedDatasetFidelity (iidSampleMeasure μ N) pref) policy :=
  not_measureExpectedDataset_pareto_of_positive_measure_event_dominated
    (iidSampleMeasure μ N) posterior pref policy betterPolicy
    (allRowsSet (N := N) baseEvent)
    (iidSampleMeasure_allRowsSet_pos_of_event_pos μ N baseEvent hbase)
    haccOldInt haccNewInt hfidOldInt hfidNewInt hacc hfid hfid_strict

