subset sweep for the below-uniform source region.
-/
theorem sourceSd_coordinate_subset_interval_split_preserves_focal_score_mass_simplex_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSingletonClass Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
