      μ q qNext (Ioc cut hi) (Ioc lo cut) z wProd u hdisj hzw
      hshapeA hshapeB hshapeOutside hformula_nonpos
  refine ⟨cut, w, qNext, hcut, hw_meas, ?_, ?_, ?_, ?_, hmae_nonpos⟩
  · simpa [u] using hsel
  · intro x hx a
    simpa [u] using hqNextA x hx a
  · intro x hx a
    simpa [u] using hqNextB x hx a
  · exact hqNextOutside

/--
Constructive `S_b` interval source transformation as a genuine posterior,
under the single-coordinate feasibility condition for the `S_b -> S_a` piece.

The MAE accounting for the paper's single-coordinate `S_b` construction is
already unconditional.  To also make the constructed `qNext` a pointwise
posterior, the selected nonfocal coordinate on the `S_b -> S_a` side must have
enough mass to absorb the focal increase to one.
-/
theorem sourceSb_interval_split_exists_measurable_feature_qNext_simplex_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ}
    (hcard_gt_one : 1 < Fintype.card Y)
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hdeficit_le :
      ∀ cut (w : ℝ → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ q x (w x) < (Fintype.card Y : ℝ)⁻¹) →
        ∀ x : ℝ, x ∈ Ioc cut hi → 1 - q x z ≤ q x (w x)) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ a : Y, Measurable fun x : ℝ => qNext x a) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ q x (w x) < (Fintype.card Y : ℝ)⁻¹) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then 1
            else if a = w x then q x (w x) - (1 - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) + (q x z - (Fintype.card Y : ℝ)⁻¹)
            else q x a) ∧
        (∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∀ x : ℝ, (∑ a : Y, qNext x a) = 1) ∧
        (∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSb_interval_split_exists_measurable_feature_qNext_mae_delta_nonpos_uniform_simplex_finite
      μ q z hcard_gt_one hlohi hfinite hq hsum hnonneg hregion with
    ⟨cut, w, qNext, hcut, hw_meas, hsel, hshapeA, hshapeB, hshapeOutside,
      hmae_nonpos⟩
  have hselected_meas : Measurable fun x : ℝ => q x (w x) :=
    measurable_selectedScore q w hq hw_meas
  have hqNext_meas : ∀ a : Y, Measurable fun x : ℝ => qNext x a := by
    intro a
    have hAMeas :
        Measurable fun x : ℝ =>
          if a = z then 1
          else if a = w x then q x (w x) - (1 - q x z)
          else q x a := by
      by_cases haz : a = z
      · simpa [haz] using measurable_const
      · have hset : MeasurableSet {x : ℝ | a = w x} := by
          have hset' : MeasurableSet {x : ℝ | w x = a} := by
            rw [show {x : ℝ | w x = a} = w ⁻¹' {a} by
              ext x
              simp]
            exact hw_meas (measurableSet_singleton a)
          simpa [eq_comm] using hset'
        have hinner :
            Measurable fun x : ℝ =>
              if a = w x then q x (w x) - (1 - q x z) else q x a :=
          Measurable.ite hset
            (hselected_meas.sub (measurable_const.sub (hq z))) (hq a)
        simpa [haz] using hinner
    have hBMeas :
        Measurable fun x : ℝ =>
          if a = z then u
          else if a = w x then q x (w x) + (q x z - u)
          else q x a := by
      by_cases haz : a = z
      · simpa [haz] using measurable_const
      · have hset : MeasurableSet {x : ℝ | a = w x} := by
          have hset' : MeasurableSet {x : ℝ | w x = a} := by
            rw [show {x : ℝ | w x = a} = w ⁻¹' {a} by
              ext x
              simp]
            exact hw_meas (measurableSet_singleton a)
          simpa [eq_comm] using hset'
        have hinner :
            Measurable fun x : ℝ =>
              if a = w x then q x (w x) + (q x z - u) else q x a :=
          Measurable.ite hset
            (hselected_meas.add ((hq z).sub measurable_const)) (hq a)
        simpa [haz] using hinner
    have hpiece_meas :
        Measurable fun x : ℝ =>
          if x ∈ Ioc cut hi then
            if a = z then 1
            else if a = w x then q x (w x) - (1 - q x z)
            else q x a
          else if x ∈ Ioc lo cut then
            if a = z then u
            else if a = w x then q x (w x) + (q x z - u)
            else q x a
          else q x a :=
      Measurable.ite measurableSet_Ioc hAMeas
        (Measurable.ite measurableSet_Ioc hBMeas (hq a))
    have h_eq :
        (fun x : ℝ => qNext x a) =
          fun x : ℝ =>
            if x ∈ Ioc cut hi then
              if a = z then 1
              else if a = w x then q x (w x) - (1 - q x z)
              else q x a
            else if x ∈ Ioc lo cut then
              if a = z then u
              else if a = w x then q x (w x) + (q x z - u)
              else q x a
            else q x a := by
      funext x
      by_cases hxA : x ∈ Ioc cut hi
      · simp [hxA, hshapeA x hxA a]
      · by_cases hxB : x ∈ Ioc lo cut
        · simp [hxA, hxB, u, hshapeB x hxB a]
        · simp [hxA, hxB, hshapeOutside x hxA hxB a]
    rw [h_eq]
    exact hpiece_meas
  have hsumNext : ∀ x : ℝ, (∑ a : Y, qNext x a) = 1 := by
    intro x
    by_cases hxA : x ∈ Ioc cut hi
    · have hzw : z ≠ w x := (hsel x (Or.inl hxA)).1.symm
      calc
        (∑ a : Y, qNext x a) =
            ∑ a : Y,
              (if a = z then 1
              else if a = w x then q x (w x) - (1 - q x z)
              else q x a) := by
            refine Finset.sum_congr rfl ?_
            intro a _
            exact hshapeA x hxA a
        _ = 1 := by
            simpa using
              posteriorSum_twoCoordinate_raise_focal_to_one
                (fun a : Y => q x a) hzw (hsum x)
    · by_cases hxB : x ∈ Ioc lo cut
      · have hzw : z ≠ w x := (hsel x (Or.inr hxB)).1.symm
        calc
          (∑ a : Y, qNext x a) =
              ∑ a : Y,
                (if a = z then u
                else if a = w x then q x (w x) + (q x z - u)
                else q x a) := by
              refine Finset.sum_congr rfl ?_
              intro a _
              simpa [u] using hshapeB x hxB a
          _ = 1 := by
              simpa using
                posteriorSum_twoCoordinate_lower_focal_to_uniform
                  (fun a : Y => q x a) hzw u (hsum x)
      · calc
          (∑ a : Y, qNext x a) = ∑ a : Y, q x a := by
              refine Finset.sum_congr rfl ?_
              intro a _
              exact hshapeOutside x hxA hxB a
          _ = 1 := hsum x
  have hnonnegNext : ∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a := by
    intro x a
    by_cases hxA : x ∈ Ioc cut hi
    · have hzw : z ≠ w x := (hsel x (Or.inl hxA)).1.symm
      have hpoint :
          0 ≤
            (if a = z then 1
            else if a = w x then q x (w x) - (1 - q x z)
            else q x a) := by
        simpa using
          (posteriorNonneg_twoCoordinate_raise_focal_to_one
            (fun a : Y => q x a) hzw (hnonneg x)
            (hdeficit_le cut w hcut hw_meas hsel x hxA)) a
      rw [hshapeA x hxA a]
      exact hpoint
    · by_cases hxB : x ∈ Ioc lo cut
      · have hzw : z ≠ w x := (hsel x (Or.inr hxB)).1.symm
        have hu_nonneg : 0 ≤ u := by
          simpa [u] using uniform_inverse_card_nonneg (Y := Y)
        have hu_le_qz : u ≤ q x z := by
          have hxRegion : x ∈ sourceSbRegion q z u := by
            simpa [u] using hregion x ⟨hxB.1.le, hxB.2.trans hcut.2⟩
          exact hxRegion.1.le
        have hpoint :
            0 ≤
              (if a = z then u
              else if a = w x then q x (w x) + (q x z - u)
              else q x a) := by
          simpa using
            (posteriorNonneg_twoCoordinate_lower_focal_to_uniform
              (fun a : Y => q x a) hzw u hu_nonneg (hnonneg x) hu_le_qz) a
        rw [hshapeB x hxB a]
        simpa [u] using hpoint
      · rw [hshapeOutside x hxA hxB a]
        exact hnonneg x a
  refine ⟨cut, w, qNext, hcut, hw_meas, hqNext_meas, hsel, hshapeA,
    hshapeB, hshapeOutside, hsumNext, hnonnegNext, hmae_nonpos⟩

/--
Multiclass-safe constructive `S_b` interval source transformation.

The upper interval is sent to focal certainty by setting `qNext_z = 1` and all
nonfocal coordinates to zero; the lower interval performs the usual
lower-to-uniform two-coordinate update.  The collapse side is a valid posterior
in every finite label space, and the balanced aggregate accounting proves that
the integrated classifier-MAE delta is nonpositive.
-/
theorem sourceSb_interval_split_exists_measurable_feature_qNext_collapse_simplex_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ a : Y, Measurable fun x : ℝ => qNext x a) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ q x (w x) < (Fintype.card Y : ℝ)⁻¹) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
          qNext x a = if a = z then (1 : ℝ) else 0) ∧
        (∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) + (q x z - (Fintype.card Y : ℝ)⁻¹)
            else q x a) ∧
        (∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∀ x : ℝ, (∑ a : Y, qNext x a) = 1) ∧
        (∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a) ∧
        jointFeatureSetScoreMass μ qNext (Ioc cut hi ∪ Ioc lo cut) z =
          jointFeatureSetScoreMass μ q (Ioc cut hi ∪ Ioc lo cut) z ∧
        continuousJointAggregatePosterior μ qNext z =
          continuousJointAggregatePosterior μ q z ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSb_interval_split_exists_measurable_feature_nonfocal_selector_product_balance_simplex_finite
      μ q z hlohi hfinite hq hsum hnonneg hregion with
    ⟨cut, w, hcut, hw_meas, hsel, hbalance⟩
  let wProd : ℝ × Y → Y := fun xy => w xy.1
  let qNext : ℝ → Y → ℝ := fun x a =>
    if x ∈ Ioc cut hi then
      if a = z then 1 else 0
    else if x ∈ Ioc lo cut then
      if a = z then u
      else if a = w x then q x (w x) + (q x z - u)
      else q x a
    else q x a
  have hle_one : ∀ x y, q x y ≤ 1 := fun x y =>
    posterior_coord_le_one_of_sum_nonneg q x y (hsum x) (hnonneg x)
  have hdisj : Disjoint (Ioc cut hi) (Ioc lo cut) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    exact (not_lt_of_ge hx_lo.2) hx_hi.1
  have hwProd_meas : Measurable wProd := hw_meas.comp measurable_fst
  have hselected_meas : Measurable fun x : ℝ => q x (w x) :=
    measurable_selectedScore q w hq hw_meas
  have hselProd :
      ∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
        wProd xy ≠ z ∧ q xy.1 (wProd xy) < u := by
    intro xy hxy
    simpa [wProd, u] using hsel xy.1 hxy
  have hSbaRegion :
      ∀ x, x ∈ Ioc cut hi →
        x ∈ sourceSbRegion q z u := by
    intro x hx
    simpa [u] using hregion x ⟨hcut.1.trans hx.1.le, hx.2⟩
  have hSbcRegion :
      ∀ x, x ∈ Ioc lo cut →
        x ∈ sourceSbRegion q z u := by
    intro x hx
    simpa [u] using hregion x ⟨hx.1.le, hx.2.trans hcut.2⟩
  have hqNextA :
      ∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
        qNext x a = if a = z then (1 : ℝ) else 0 := by
    intro x hx a
    have hx' : cut < x ∧ x ≤ hi := hx
    simp [qNext, hx']
  have hqNextB :
      ∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
        qNext x a =
          if a = z then u
          else if a = w x then q x (w x) + (q x z - u)
          else q x a := by
    intro x hx a
    have hxA : x ∉ Ioc cut hi := by
      intro hxA
      exact (Set.disjoint_left.mp hdisj) hxA hx
    have hxA' : ¬ (cut < x ∧ x ≤ hi) := by
      simpa using hxA
    have hx' : lo < x ∧ x ≤ cut := hx
    simp [qNext, hxA', hx']
  have hqNextOutside :
      ∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
        qNext x a = q x a := by
    intro x hxA hxB a
    have hxA' : ¬ (cut < x ∧ x ≤ hi) := by
      simpa using hxA
    have hxB' : ¬ (lo < x ∧ x ≤ cut) := by
      simpa using hxB
    simp [qNext, hxA', hxB']
  have hqNext_meas : ∀ a : Y, Measurable fun x : ℝ => qNext x a := by
    intro a
    have hAMeas : Measurable fun _x : ℝ =>
        if a = z then (1 : ℝ) else 0 := by
      by_cases haz : a = z <;> simp [haz]
    have hBMeas :
        Measurable fun x : ℝ =>
          if a = z then u
          else if a = w x then q x (w x) + (q x z - u)
          else q x a := by
      by_cases haz : a = z
      · simpa [haz] using measurable_const
      · have hset : MeasurableSet {x : ℝ | a = w x} := by
          have hset' : MeasurableSet {x : ℝ | w x = a} := by
            rw [show {x : ℝ | w x = a} = w ⁻¹' {a} by
              ext x
              simp]
            exact hw_meas (measurableSet_singleton a)
          simpa [eq_comm] using hset'
        have hinner :
            Measurable fun x : ℝ =>
              if a = w x then q x (w x) + (q x z - u) else q x a :=
          Measurable.ite hset
            (hselected_meas.add ((hq z).sub measurable_const)) (hq a)
        simpa [haz] using hinner
    have hpiece_meas :
        Measurable fun x : ℝ =>
          if x ∈ Ioc cut hi then
            if a = z then (1 : ℝ) else 0
          else if x ∈ Ioc lo cut then
            if a = z then u
            else if a = w x then q x (w x) + (q x z - u)
            else q x a
          else q x a :=
      Measurable.ite measurableSet_Ioc hAMeas
        (Measurable.ite measurableSet_Ioc hBMeas (hq a))
    have h_eq :
        (fun x : ℝ => qNext x a) =
          fun x : ℝ =>
            if x ∈ Ioc cut hi then
              if a = z then (1 : ℝ) else 0
            else if x ∈ Ioc lo cut then
              if a = z then u
              else if a = w x then q x (w x) + (q x z - u)
              else q x a
            else q x a := by
      funext x
      by_cases hxA : x ∈ Ioc cut hi
      · simp [hxA, hqNextA x hxA a]
      · by_cases hxB : x ∈ Ioc lo cut
        · simp [hxA, hxB, u, hqNextB x hxB a]
        · simp [hxA, hxB, hqNextOutside x hxA hxB a]
    rw [h_eq]
    exact hpiece_meas
  have hsumNext : ∀ x : ℝ, (∑ a : Y, qNext x a) = 1 := by
    intro x
    by_cases hxA : x ∈ Ioc cut hi
    · calc
        (∑ a : Y, qNext x a) =
            ∑ a : Y, (if a = z then (1 : ℝ) else 0) := by
              refine Finset.sum_congr rfl ?_
              intro a _
              exact hqNextA x hxA a
        _ = 1 := posteriorSum_focal_one_else_zero z
    · by_cases hxB : x ∈ Ioc lo cut
      · have hzw : z ≠ w x := (hsel x (Or.inr hxB)).1.symm
        calc
          (∑ a : Y, qNext x a) =
              ∑ a : Y,
                (if a = z then u
                else if a = w x then q x (w x) + (q x z - u)
                else q x a) := by
              refine Finset.sum_congr rfl ?_
              intro a _
              exact hqNextB x hxB a
          _ = 1 := by
              simpa using
                posteriorSum_twoCoordinate_lower_focal_to_uniform
                  (fun a : Y => q x a) hzw u (hsum x)
      · calc
          (∑ a : Y, qNext x a) = ∑ a : Y, q x a := by
              refine Finset.sum_congr rfl ?_
              intro a _
              exact hqNextOutside x hxA hxB a
          _ = 1 := hsum x
  have hnonnegNext : ∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a := by
    intro x a
    by_cases hxA : x ∈ Ioc cut hi
    · rw [hqNextA x hxA a]
      exact posteriorNonneg_focal_one_else_zero z a
    · by_cases hxB : x ∈ Ioc lo cut
      · have hzw : z ≠ w x := (hsel x (Or.inr hxB)).1.symm
        have hu_nonneg : 0 ≤ u := by
          simpa [u] using uniform_inverse_card_nonneg (Y := Y)
        have hu_le_qz : u ≤ q x z := (hSbcRegion x hxB).1.le
        have hpoint :
            0 ≤
              (if a = z then u
              else if a = w x then q x (w x) + (q x z - u)
              else q x a) := by
          simpa using
            (posteriorNonneg_twoCoordinate_lower_focal_to_uniform
              (fun a : Y => q x a) hzw u hu_nonneg (hnonneg x) hu_le_qz) a
        rw [hqNextB x hxB a]
        exact hpoint
      · rw [hqNextOutside x hxA hxB a]
        exact hnonneg x a
  have hscoreNext :
      ∀ y : Y, Measurable (fun xy : ℝ × Y => qNext xy.1 y) :=
    fun y => (hqNext_meas y).comp measurable_fst
  have hscoreOrig :
      ∀ y : Y, Measurable (fun xy : ℝ × Y => q xy.1 y) :=
    fun y => (hq y).comp measurable_fst
  have hmaeNextInt :
      Integrable (fun xy : ℝ × Y => Finite.paperConditionalMAE qNext xy.1) μ :=
    integrable_jointConditionalMAE_of_scores_simplex_finite
      μ qNext hscoreNext hsumNext hnonnegNext
  have hmaeOrigInt :
      Integrable (fun xy : ℝ × Y => Finite.paperConditionalMAE q xy.1) μ :=
    integrable_jointConditionalMAE_of_scores_simplex_finite
      μ q hscoreOrig hsum hnonneg
  have hDeltaInt :
      Integrable
        (fun xy : ℝ × Y =>
          Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) μ :=
    hmaeNextInt.sub hmaeOrigInt
  have hAUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc cut hi).indicator
            (fun xy : ℝ × Y => 1 - q xy.1 z) xy) μ :=
    integrable_fst_preimage_score_deficitToOne_indicator_finite
      μ q (Ioc cut hi) z measurableSet_Ioc (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
  have hAUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (-2 * u) *
            (Prod.fst ⁻¹' Ioc cut hi).indicator
              (fun xy : ℝ × Y => 1 - q xy.1 z) xy) μ := by
    simpa [smul_eq_mul] using hAUpperBase.const_mul (-2 * u)
  have hBUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc lo cut).indicator
            (fun xy : ℝ × Y => q xy.1 z - u) xy) μ :=
    integrable_fst_preimage_score_excess_indicator_finite
      μ q (Ioc lo cut) z u measurableSet_Ioc (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hBUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (2 * u) *
            (Prod.fst ⁻¹' Ioc lo cut).indicator
