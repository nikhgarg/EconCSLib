    have hleft :
        (∫ xy : ℝ × Y,
            (Prod.fst ⁻¹' (S ∩ Ioc lo cut)).indicator
              (fun xy : ℝ × Y => q xy.1 z - u) xy ∂μ) =
          ∫ x, (S ∩ Ioc lo cut).indicator (fun x : ℝ => q x z - u) x
