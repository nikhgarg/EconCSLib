/--
Exact integrated MAE delta for a two-piece `S_b` source transformation.

On `Sba` the focal coordinate is raised to `1`; on `Sbc` it is lowered to the
uniform value `u`; outside both pieces the posterior is unchanged.  The theorem
turns those pointwise shape obligations into the sum of the two indicator
delta formulas used by the balanced aggregate accounting.
-/
theorem integral_paperConditionalMAE_delta_sourceSb_twoRegion
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q qNext : X → Y → ℝ)
    (Sba Sbc : Set X) (z : Y) (w : X × Y → Y) (u : ℝ)
    (hdisj : Disjoint Sba Sbc)
    (hzw :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sba ∪ Sbc → z ≠ w xy)
    (hshapeA :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sba → ∀ a : Y,
        qNext xy.1 a =
          if a = z then 1
          else if a = w xy then q xy.1 (w xy) - (1 - q xy.1 z)
          else q xy.1 a)
    (hshapeB :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sbc → ∀ a : Y,
        qNext xy.1 a =
          if a = z then u
          else if a = w xy then q xy.1 (w xy) + (q xy.1 z - u)
          else q xy.1 a)
    (hshapeOutside :
      ∀ᵐ xy ∂μ, xy.1 ∉ Sba → xy.1 ∉ Sbc → ∀ a : Y,
        qNext xy.1 a = q xy.1 a) :
    (∫ xy : X × Y,
        (Finite.paperConditionalMAE qNext xy.1 -
          Finite.paperConditionalMAE q xy.1) ∂μ) =
      ∫ xy : X × Y,
        (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
          -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
        ) xy +
        (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
          -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
        ) xy ∂μ := by
  refine integral_congr_ae ?_
  filter_upwards [hzw, hshapeA, hshapeB, hshapeOutside] with
    xy hneq hA hB hOutside
  by_cases hxA : xy.1 ∈ Sba
  · have hxBnot : xy.1 ∉ Sbc := by
      intro hxB
      exact (Set.disjoint_left.mp hdisj) hxA hxB
    have hdelta :
        Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1 =
          -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z) :=
      paperConditionalMAE_twoCoordinate_raise_focal_to_one_delta
        q qNext xy.1 xy.1 (hneq (Or.inl hxA)) (hA hxA)
    calc
      Finite.paperConditionalMAE qNext xy.1 -
          Finite.paperConditionalMAE q xy.1 =
          -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z) := hdelta
      _ =
          (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
            -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
          ) xy +
          (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
          ) xy := by
            simp [Set.indicator, hxA, hxBnot]
  · by_cases hxB : xy.1 ∈ Sbc
    · have hdelta :
          Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1 =
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) :=
        paperConditionalMAE_twoCoordinate_lower_focal_to_uniform_delta
          q qNext xy.1 xy.1 (hneq (Or.inr hxB)) u (hB hxB)
      calc
        Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1 =
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) := hdelta
        _ =
            (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
              -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
            ) xy +
            (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
              -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
            ) xy := by
              simp [Set.indicator, hxA, hxB]
    · have hsame :
          Finite.paperConditionalMAE qNext xy.1 =
            Finite.paperConditionalMAE q xy.1 := by
        unfold Finite.paperConditionalMAE
        refine Finset.sum_congr rfl ?_
        intro a _
        rw [hOutside hxA hxB a]
      calc
        Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1 = 0 := by
              linarith
        _ =
            (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
              -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
            ) xy +
            (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
              -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
            ) xy := by
              simp [Set.indicator, hxA, hxB]

/-- Nonpositive actual MAE delta for a two-piece `S_b` transformation. -/
