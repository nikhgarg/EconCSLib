      Integrable
        (fun sample => datasetAccuracyScore (posterior sample) (betterPolicy sample))
        (iidSampleMeasure μ N))
    (hfidOldInt :
      Integrable
        (fun sample => datasetFidelity pref (policy sample)) (iidSampleMeasure μ N))
    (hfidNewInt :
      Integrable
        (fun sample => datasetFidelity pref (betterPolicy sample)) (iidSampleMeasure μ N))
