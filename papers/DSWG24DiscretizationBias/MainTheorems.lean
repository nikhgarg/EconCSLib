/--
Source Step 1 interval split, exposed as the product-measure balance equation
needed by aggregate MAE-delta accounting.
-/
theorem sourceSb_interval_split_product_balance_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hqz : Measurable fun x : ℝ => q x z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      (∫ xy : ℝ × Y,
          (Prod.fst ⁻¹' Ioc lo cut).indicator
            (fun xy : ℝ × Y => q xy.1 z - (Fintype.card Y : ℝ)⁻¹) xy ∂μ) =
        ∫ xy : ℝ × Y,
          (Prod.fst ⁻¹' Ioc cut hi).indicator
            (fun xy : ℝ × Y => 1 - q xy.1 z) xy ∂μ := by
  classical
  let ν : Measure ℝ := Measure.map Prod.fst μ
  rcases exists_source_Sb_balancing_interval_cut_of_region_subset_measurable_simplex
      (μ := ν) (lo := lo) (hi := hi) (q := q) (z := z)
      (invK := (Fintype.card Y : ℝ)⁻¹)
      hlohi hfinite hqz hsum hnonneg hregion with
    ⟨cut, hcut, hbalanceInterval⟩
  have hlocut : lo ≤ cut := hcut.1
  have hcut_hi : cut ≤ hi := hcut.2
  have hbalanceFeature :
      (∫ x, (Ioc lo cut).indicator
            (fun x : ℝ => q x z - (Fintype.card Y : ℝ)⁻¹) x ∂ν) =
        ∫ x, (Ioc cut hi).indicator (fun x : ℝ => 1 - q x z) x ∂ν := by
    rw [integral_indicator measurableSet_Ioc, integral_indicator measurableSet_Ioc]
    rw [← intervalIntegral.integral_of_le hlocut,
      ← intervalIntegral.integral_of_le hcut_hi]
    exact hbalanceInterval
  have hleftMap :
      (∫ xy : ℝ × Y,
          (Prod.fst ⁻¹' Ioc lo cut).indicator
            (fun xy : ℝ × Y => q xy.1 z - (Fintype.card Y : ℝ)⁻¹) xy ∂μ) =
        ∫ x, (Ioc lo cut).indicator
          (fun x : ℝ => q x z - (Fintype.card Y : ℝ)⁻¹) x ∂ν :=
    integral_fst_preimage_indicator_eq_featureMarginal_integral
      μ (Ioc lo cut) (fun x : ℝ => q x z - (Fintype.card Y : ℝ)⁻¹)
      measurableSet_Ioc (hqz.sub measurable_const)
  have hrightMap :
      (∫ xy : ℝ × Y,
          (Prod.fst ⁻¹' Ioc cut hi).indicator
            (fun xy : ℝ × Y => 1 - q xy.1 z) xy ∂μ) =
        ∫ x, (Ioc cut hi).indicator (fun x : ℝ => 1 - q x z) x ∂ν :=
    integral_fst_preimage_indicator_eq_featureMarginal_integral
      μ (Ioc cut hi) (fun x : ℝ => 1 - q x z)
      measurableSet_Ioc (measurable_const.sub hqz)
  refine ⟨cut, hcut, ?_⟩
  rw [hleftMap, hrightMap]
  exact hbalanceFeature

