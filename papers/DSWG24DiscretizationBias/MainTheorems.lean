theorem sourceSb_interval_split_exists_measurable_feature_qNext_simplex_mae_delta_nonpos_binary_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ}
    (hcard_two : Fintype.card Y = 2)
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ a : Y, Measurable fun x : ℝ => qNext x a) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ q x (w x) < (Fintype.card Y : ℝ)⁻¹) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then 1
            else if a = w x then q x (w x) - (1 - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) + (q x z - (Fintype.card Y : ℝ)⁻¹)
            else q x a) ∧
        (∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∀ x : ℝ, (∑ a : Y, qNext x a) = 1) ∧
        (∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  have hcard_gt_one : 1 < Fintype.card Y := by
    omega
  refine
    sourceSb_interval_split_exists_measurable_feature_qNext_simplex_mae_delta_nonpos_uniform_simplex_finite
      μ q z hcard_gt_one hlohi hfinite hq hsum hnonneg hregion ?_
  intro cut w hcut hw_meas hsel x hx
  have hw_ne_z : w x ≠ z := (hsel x (Or.inl hx)).1
  have hcomp :
      q x (w x) = 1 - q x z :=
    posterior_nonfocal_eq_one_sub_focal_of_card_two
      (fun a : Y => q x a) hcard_two hw_ne_z (hsum x)
  linarith

/--
