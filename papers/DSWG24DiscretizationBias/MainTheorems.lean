-/
theorem sourceSb_subset_interval_split_exists_measurable_nonfocal_twoRegion_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q qNext : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ} {S : Set ℝ}
