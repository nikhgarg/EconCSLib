      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hEInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc lo cut).indicator (fun xy : ℝ × Y =>
            -2 * q xy.1 (w xy) * q xy.1 z
          ) xy) μ :=
    integrable_fst_preimage_twoCoordinate_delta_toZero_indicator_finite
