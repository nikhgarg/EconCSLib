-/
theorem exists_source_Sb_balancing_subset_interval_cut_of_region_subset
    {Y : Type*} {μ : Measure ℝ} [NoAtoms μ] {lo hi invK : ℝ}
    {S : Set ℝ} {q : ℝ → Y → ℝ} {z : Y}
    (hlohi : lo ≤ hi)
    (hleftInt :
      IntegrableOn (S.indicator (fun x => q x z - invK)) (Icc lo hi) μ)
    (hrightInt :
      IntegrableOn (S.indicator (fun x => 1 - q x z)) (Icc lo hi) μ)
    (hregion :
      ∀ x, x ∈ S → x ∈ Icc lo hi → x ∈ sourceSbRegion q z invK) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      (∫ x in lo..cut, S.indicator (fun x => q x z - invK) x ∂μ) =
        ∫ x in cut..hi, S.indicator (fun x => 1 - q x z) x ∂μ :=
  exists_source_balancing_subset_interval_cut
    (μ := μ) (lo := lo) (hi := hi) (S := S)
    (leftWeight := fun x => q x z - invK)
    (rightWeight := fun x => 1 - q x z)
    hlohi hleftInt hrightInt
    (fun x hxS hxI => sub_nonneg.mpr ((hregion x hxS hxI).1.le))
    (fun x hxS hxI => sub_nonneg.mpr ((hregion x hxS hxI).2.le))

theorem exists_source_Sb_balancing_subset_interval_cut_of_region_subset_measurable_bounded
    {Y : Type*} {μ : Measure ℝ} [NoAtoms μ] {lo hi invK : ℝ}
    {S : Set ℝ} {q : ℝ → Y → ℝ} {z : Y}
    (hlohi : lo ≤ hi)
    (hfinite : μ (Icc lo hi) < ⊤)
    (hS : MeasurableSet S)
    (hqz : Measurable fun x : ℝ => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z)
    (hle_one : ∀ x, q x z ≤ 1)
    (hinvK_nonneg : 0 ≤ invK) (hinvK_le_one : invK ≤ 1)
    (hregion :
      ∀ x, x ∈ S → x ∈ Icc lo hi → x ∈ sourceSbRegion q z invK) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      (∫ x in lo..cut, S.indicator (fun x => q x z - invK) x ∂μ) =
        ∫ x in cut..hi, S.indicator (fun x => 1 - q x z) x ∂μ := by
  have hleftMeas :
      Measurable (S.indicator (fun x : ℝ => q x z - invK)) :=
    (hqz.sub measurable_const).indicator hS
  have hrightMeas :
      Measurable (S.indicator (fun x : ℝ => 1 - q x z)) :=
    (measurable_const.sub hqz).indicator hS
  have hleftBound :
      ∀ x : ℝ, ‖S.indicator (fun x : ℝ => q x z - invK) x‖ ≤ 1 := by
    intro x
    by_cases hxS : x ∈ S
    · simp [Set.indicator, hxS]
      exact abs_le.mpr
        ⟨by linarith [hnonneg x, hinvK_le_one],
          by linarith [hle_one x, hinvK_nonneg]⟩
    · simp [Set.indicator, hxS]
  have hrightBound :
      ∀ x : ℝ, ‖S.indicator (fun x : ℝ => 1 - q x z) x‖ ≤ 1 := by
    intro x
    by_cases hxS : x ∈ S
    · simp [Set.indicator, hxS]
      have hnonneg_def : 0 ≤ 1 - q x z := sub_nonneg.mpr (hle_one x)
      rw [abs_of_nonneg hnonneg_def]
      linarith [hnonneg x]
    · simp [Set.indicator, hxS]
  exact
    exists_source_Sb_balancing_subset_interval_cut_of_region_subset
      (μ := μ) (lo := lo) (hi := hi) (invK := invK)
      (S := S) (q := q) (z := z) hlohi
      (integrableOn_of_measurable_norm_le hfinite hleftMeas
        (C := 1) hleftBound)
      (integrableOn_of_measurable_norm_le hfinite hrightMeas
        (C := 1) hrightBound)
      hregion

