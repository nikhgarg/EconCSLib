        (Finite.paperConditionalMAE qNext (TFeature xy) -
          Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  rw [integral_paperConditionalMAE_delta_twoCoordinate_raise_focal_to_uniform
    μ q qNext TFeature z w u hzw hshape]
  exact hformula_nonpos

/--
Integral form of the `S_d -> S_e` two-coordinate MAE delta, allowing the
affected nonfocal coordinate to vary with the source point.
-/
theorem integral_paperConditionalMAE_delta_twoCoordinate_lower_focal_to_zero
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q qNext : X → Y → ℝ)
    (TFeature : X × Y → X) (z : Y) (w : X × Y → Y)
