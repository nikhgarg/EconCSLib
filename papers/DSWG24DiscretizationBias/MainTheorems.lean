/--
Worst-case equality certificate for the source proof of Theorem 1(iii).

After the source transformations eliminate the `S_b` and `S_d` regions, the
paper's displayed worst-case shape has both the focal-class bias and the MAE
equal to `(1 - 1/K)` times the mass of the uniform-score region.  This
certificate records that algebraic endpoint without baking in a particular
representation of the transformed feature space.
-/
structure SourceWorstCaseEqualityCertificate
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (rule : X → Y) (z : Y) where
  middleMass : ℝ
  uniformScore : ℝ
  bias_eq : continuousJointPriorBias μ rule z = (1 - uniformScore) * middleMass
  mae_eq : continuousJointClassifierMAE μ q = (1 - uniformScore) * middleMass

theorem sourceWorstCase_bias_eq_mae_of_certificate
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (rule : X → Y) (z : Y)
    (hcert : SourceWorstCaseEqualityCertificate μ q rule z) :
    continuousJointPriorBias μ rule z = continuousJointClassifierMAE μ q := by
  rw [hcert.bias_eq, hcert.mae_eq]

/--
Build the source worst-case equality certificate from the paper's three mass
identities: the argmax rule assigns focal mass `a + c`, the focal prior is
`a + u c`, and MAE is `(1-u)c`, where `u = 1/K` in the paper.
-/
noncomputable def sourceWorstCaseEqualityCertificate_of_three_region_masses
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (rule : X → Y) (z : Y)
    (Sa Sc : Set X) (uniformScore : ℝ)
    (hdecision :
      continuousJointDecisionShare μ rule z =
        jointFeatureSetMass μ Sa + jointFeatureSetMass μ Sc)
    (hprior :
      continuousJointPrior μ z =
        jointFeatureSetMass μ Sa + uniformScore * jointFeatureSetMass μ Sc)
    (hmae :
      continuousJointClassifierMAE μ q =
        (1 - uniformScore) * jointFeatureSetMass μ Sc) :
    SourceWorstCaseEqualityCertificate μ q rule z where
  middleMass := jointFeatureSetMass μ Sc
  uniformScore := uniformScore
  bias_eq := by
    unfold continuousJointPriorBias
    rw [hdecision, hprior]
    ring
  mae_eq := hmae

/--
Build the source worst-case equality certificate directly from a reduced
three-region classifier: `S_b` and `S_d` are empty, the focal decision rule
chooses exactly `S_a ∪ S_c`, the prior equals the aggregate posterior, and the
pointwise MAE has the worst-case values `0`, `1-u`, and `0` on
`S_a`, `S_c`, and `S_e`.
-/
noncomputable def sourceWorstCaseEqualityCertificate_of_reduced_source_regions
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (rule : X → Y) (z : Y) (uniformScore : ℝ)
    (hqz : Measurable fun x : X => q x z)
    (hpriorAggregate :
      continuousJointPrior μ z = continuousJointAggregatePosterior μ q z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hzero_lt_uniform : 0 < uniformScore) (huniform_lt_one : uniformScore < 1)
    (hSb_empty : sourceSbRegion q z uniformScore = ∅)
    (hSd_empty : sourceSdRegion q z uniformScore = ∅)
    (hdecision :
      ∀ x, rule x = z ↔
        x ∈ sourceSaRegion q z ∪ sourceScRegion q z uniformScore)
    (hmaeSa : ∀ x, x ∈ sourceSaRegion q z →
      Finite.paperConditionalMAE q x = 0)
    (hmaeSc : ∀ x, x ∈ sourceScRegion q z uniformScore →
      Finite.paperConditionalMAE q x = 1 - uniformScore)
    (hmaeSe : ∀ x, x ∈ sourceSeRegion q z →
      Finite.paperConditionalMAE q x = 0) :
    SourceWorstCaseEqualityCertificate μ q rule z := by
  let Sa : Set X := sourceSaRegion q z
  let Sc : Set X := sourceScRegion q z uniformScore
  have hdecisionMass :
      continuousJointDecisionShare μ rule z =
        jointFeatureSetMass μ Sa + jointFeatureSetMass μ Sc :=
    continuousJointDecisionShare_sourceSaSc_sum_finite
      μ q rule z uniformScore hqz huniform_lt_one hdecision
  have haggregateMass :
      continuousJointAggregatePosterior μ q z =
        jointFeatureSetMass μ Sa + uniformScore * jointFeatureSetMass μ Sc :=
    continuousJointAggregatePosterior_sourceSaScSe_sum_of_no_sourceSbSd_simplex_finite
      μ q z uniformScore hqz hsum hnonneg hzero_lt_uniform huniform_lt_one
      hSb_empty hSd_empty
  have hpriorMass :
      continuousJointPrior μ z =
        jointFeatureSetMass μ Sa + uniformScore * jointFeatureSetMass μ Sc := by
    rw [hpriorAggregate, haggregateMass]
  have hmaeMass :
      continuousJointClassifierMAE μ q =
        (1 - uniformScore) * jointFeatureSetMass μ Sc :=
    continuousJointClassifierMAE_sourceSaScSe_eq_of_no_sourceSbSd_simplex
      μ q z uniformScore hsum hnonneg hzero_lt_uniform huniform_lt_one
      hSb_empty hSd_empty hmaeSa hmaeSc hmaeSe
  exact sourceWorstCaseEqualityCertificate_of_three_region_masses
    μ q rule z Sa Sc uniformScore hdecisionMass hpriorMass hmaeMass

/--
Reduced-region worst-case certificate for the paper's uniform score `1/K`,
with the pointwise MAE values derived from simplex and region-shape
assumptions.
-/
noncomputable def sourceWorstCaseEqualityCertificate_of_reduced_source_regions_uniformMiddle
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (rule : X → Y) (z : Y)
    (hqz : Measurable fun x : X => q x z)
    (hpriorAggregate :
      continuousJointPrior μ z = continuousJointAggregatePosterior μ q z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hcard_gt_one : 1 < Fintype.card Y)
    (hSb_empty :
      sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹ = ∅)
    (hSd_empty :
      sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹ = ∅)
    (hdecision :
      ∀ x, rule x = z ↔
        x ∈ sourceSaRegion q z ∪
          sourceScRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hmiddleUniform :
      ∀ x, x ∈ sourceScRegion q z (Fintype.card Y : ℝ)⁻¹ →
        ∀ a : Y, q x a = (Fintype.card Y : ℝ)⁻¹)
    (hSePerfect :
      ∀ x, x ∈ sourceSeRegion q z → ∃ a : Y, q x a = 1) :
    SourceWorstCaseEqualityCertificate μ q rule z := by
  have hzero_lt_uniform : 0 < (Fintype.card Y : ℝ)⁻¹ :=
    uniform_inverse_card_pos z
  have huniform_lt_one : (Fintype.card Y : ℝ)⁻¹ < 1 :=
    uniform_inverse_card_lt_one_of_one_lt_card hcard_gt_one
  exact
    sourceWorstCaseEqualityCertificate_of_reduced_source_regions
      μ q rule z (Fintype.card Y : ℝ)⁻¹ hqz hpriorAggregate
      hsum hnonneg hzero_lt_uniform huniform_lt_one hSb_empty hSd_empty
      hdecision
      (fun x hx =>
        paperConditionalMAE_eq_zero_of_coord_eq_one q x z
          (hsum x) (hnonneg x) hx)
      (fun x hx =>
        paperConditionalMAE_eq_one_sub_uniform_of_all_eq_uniform
          q x z (hmiddleUniform x hx))
      (fun x hx =>
        paperConditionalMAE_eq_zero_of_exists_coord_eq_one q x
          (hsum x) (hnonneg x) (hSePerfect x hx))

/--
Uniform-middle worst-case certificate with the final reduced shape supplied as
one pointwise trichotomy.
-/
noncomputable def sourceWorstCaseEqualityCertificate_of_reduced_source_regions_uniformMiddle_shape
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (rule : X → Y) (z : Y)
    (hqz : Measurable fun x : X => q x z)
    (hpriorAggregate :
      continuousJointPrior μ z = continuousJointAggregatePosterior μ q z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hcard_gt_one : 1 < Fintype.card Y)
    (hshape :
      SourceReducedUniformMiddleShape q z (Fintype.card Y : ℝ)⁻¹)
    (hdecision :
      ∀ x, rule x = z ↔
        x ∈ sourceSaRegion q z ∪
          sourceScRegion q z (Fintype.card Y : ℝ)⁻¹) :
    SourceWorstCaseEqualityCertificate μ q rule z := by
  rcases sourceReducedUniformMiddle_obligations_of_shape_uniform_simplex
      (q := q) (z := z) hcard_gt_one hshape with
    ⟨hSb_empty, hSd_empty, hmiddleUniform, hSePerfect⟩
  exact
    sourceWorstCaseEqualityCertificate_of_reduced_source_regions_uniformMiddle
      μ q rule z hqz hpriorAggregate hsum hnonneg hcard_gt_one
      hSb_empty hSd_empty hdecision hmiddleUniform hSePerfect

/--
Canonical-rule uniform-middle worst-case certificate from the pointwise final
shape.  The decision rule is the canonical `z` on `S_a ∪ S_c` rule.
-/
noncomputable def sourceWorstCaseEqualityCertificate_of_reduced_source_regions_uniformMiddle_shape_canonicalRule
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (z fallback : Y)
    (hqz : Measurable fun x : X => q x z)
    (hpriorAggregate :
      continuousJointPrior μ z = continuousJointAggregatePosterior μ q z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hcard_gt_one : 1 < Fintype.card Y)
    (hshape :
      SourceReducedUniformMiddleShape q z (Fintype.card Y : ℝ)⁻¹)
    (hfallback : fallback ≠ z) :
    SourceWorstCaseEqualityCertificate μ q
      (sourceReducedDecisionRule q z (Fintype.card Y : ℝ)⁻¹ fallback) z :=
  sourceWorstCaseEqualityCertificate_of_reduced_source_regions_uniformMiddle_shape
    μ q (sourceReducedDecisionRule q z (Fintype.card Y : ℝ)⁻¹ fallback) z
    hqz hpriorAggregate hsum hnonneg hcard_gt_one hshape
    (fun x =>
      sourceReducedDecisionRule_eq_z_iff q z fallback
        (Fintype.card Y : ℝ)⁻¹ hfallback x)

theorem sourceWorstCase_bias_eq_mae_of_reduced_source_regions_uniformMiddle
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (rule : X → Y) (z : Y)
    (hqz : Measurable fun x : X => q x z)
    (hpriorAggregate :
      continuousJointPrior μ z = continuousJointAggregatePosterior μ q z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hcard_gt_one : 1 < Fintype.card Y)
    (hSb_empty :
      sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹ = ∅)
    (hSd_empty :
      sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹ = ∅)
    (hdecision :
      ∀ x, rule x = z ↔
        x ∈ sourceSaRegion q z ∪
          sourceScRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hmiddleUniform :
      ∀ x, x ∈ sourceScRegion q z (Fintype.card Y : ℝ)⁻¹ →
        ∀ a : Y, q x a = (Fintype.card Y : ℝ)⁻¹)
    (hSePerfect :
      ∀ x, x ∈ sourceSeRegion q z → ∃ a : Y, q x a = 1) :
    continuousJointPriorBias μ rule z = continuousJointClassifierMAE μ q :=
  sourceWorstCase_bias_eq_mae_of_certificate μ q rule z
    (sourceWorstCaseEqualityCertificate_of_reduced_source_regions_uniformMiddle
      μ q rule z hqz hpriorAggregate hsum hnonneg hcard_gt_one
      hSb_empty hSd_empty hdecision hmiddleUniform hSePerfect)

theorem sourceWorstCase_bias_eq_mae_of_reduced_source_regions_uniformMiddle_shape
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
