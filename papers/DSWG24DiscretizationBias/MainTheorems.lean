        μ) :
    Integrable (fun x : X => if rule x = z then (1 : ℝ) else 0) μ := by
  refine Integrable.of_bound hmeas 1 ?_
  filter_upwards with x
  by_cases h : rule x = z <;> simp [h]

theorem aestronglyMeasurable_featureDecisionIndicator
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSingletonClass Y] [DecidableEq Y]
    (μ : Measure X) (rule : X → Y) (z : Y) (hrule : Measurable rule) :
    AEStronglyMeasurable
      (fun x : X => if rule x = z then (1 : ℝ) else 0) μ := by
  have hset : MeasurableSet {x : X | rule x = z} :=
    hrule (measurableSet_singleton z)
  have hmeas :
      Measurable
        (({x : X | rule x = z}).indicator (fun _ : X => (1 : ℝ))) :=
    measurable_const.indicator hset
  have hfun :
      ({x : X | rule x = z}).indicator (fun _ : X => (1 : ℝ)) =
        fun x : X => if rule x = z then (1 : ℝ) else 0 := by
    funext x
    by_cases h : rule x = z <;> simp [Set.indicator, h]
  rw [← hfun]
  exact hmeas.aestronglyMeasurable

