          u * jointFeatureSetMass μ (S ∩ Ioc lo cut) :=
    sourceSb_featureMarginal_balance_preserves_focal_score_mass_simplex_finite
      μ q (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) z u
      (hS.inter measurableSet_Ioc) (hS.inter measurableSet_Ioc)
