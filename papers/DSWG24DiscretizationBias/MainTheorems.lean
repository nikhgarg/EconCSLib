  let qNext : X → Y → ℝ := fun x a => qNextCoord (r x) a
  have hqNext : ∀ a : Y, Measurable fun x : X => qNext x a :=
    fun a => (hqNextCoord a).comp hr
  have hsumNext : ∀ x : X, (∑ a : Y, qNext x a) = 1 := by
    intro x
    simpa [qNext] using hsumNextCoord (r x)
  have hnonnegNext : ∀ x : X, ∀ a : Y, 0 ≤ qNext x a := by
    intro x a
    simpa [qNext] using hnonnegNextCoord (r x) a
  have hfactorNext : ∀ x : X, ∀ a : Y, qNext x a = qNextCoord (r x) a := by
    intro x a
    rfl
  let U : Set ℝ := (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut)
  have hU : MeasurableSet U :=
    (hS.inter measurableSet_Ioc).union (hS.inter measurableSet_Ioc)
  have hmass_next :
      jointFeatureSetScoreMass μ qNext (r ⁻¹' U) z =
        jointFeatureSetScoreMass μR qNextCoord U z := by
    simpa [μR, T, U, qNext] using
      jointFeatureSetScoreMass_featureCoordinate_pullback
        μ hr U qNext qNextCoord z hU (hqNextCoord z) (fun x => hfactorNext x z)
  have hmass_q :
      jointFeatureSetScoreMass μ q (r ⁻¹' U) z =
        jointFeatureSetScoreMass μR qCoord U z := by
    simpa [μR, T, U] using
      jointFeatureSetScoreMass_featureCoordinate_pullback
        μ hr U q qCoord z hU (hqCoord z) (fun x => hfactor x z)
  have hmass :
      jointFeatureSetScoreMass μ qNext (r ⁻¹' U) z =
        jointFeatureSetScoreMass μ q (r ⁻¹' U) z := by
    rw [hmass_next, hmass_q]
    exact hmassCoord
  have haggregate_q :
      continuousJointAggregatePosterior μ q z =
        continuousJointAggregatePosterior μR qCoord z := by
    simpa [μR, T] using
      continuousJointAggregatePosterior_featureCoordinate_pullback
        μ hr q qCoord z (hqCoord z) (fun x => hfactor x z)
  have haggregate_next :
      continuousJointAggregatePosterior μ qNext z =
        continuousJointAggregatePosterior μR qNextCoord z := by
    simpa [μR, T, qNext] using
      continuousJointAggregatePosterior_featureCoordinate_pullback
        μ hr qNext qNextCoord z (hqNextCoord z) (fun _ => rfl)
  have haggregate :
      continuousJointAggregatePosterior μ qNext z =
        continuousJointAggregatePosterior μ q z := by
    rw [haggregate_next, haggregate_q]
    exact haggregateCoord
  have hmae_pullback :
      (∫ xy : X × Y,
          (Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) ∂μ) =
        ∫ xy : ℝ × Y,
          (Finite.paperConditionalMAE qNextCoord xy.1 -
            Finite.paperConditionalMAE qCoord xy.1) ∂μR := by
    simpa [μR, T, qNext] using
      integral_paperConditionalMAE_delta_featureCoordinate_pullback
        μ hr q qNext qCoord qNextCoord hqCoord hqNextCoord hfactor hfactorNext
  have hmae :
      (∫ xy : X × Y,
          (Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
    rw [hmae_pullback]
    exact hmaeCoord
  refine ⟨cut, wCoord, qNextCoord, qNext, hcut, hwCoord, hqNextCoord, hqNext,
    hsumNext, hnonnegNext, hfactorNext, ?_, ?_, ?_, ?_, hmass, haggregate, hmae⟩
  · intro x hx
    simpa using hselCoord (r x) hx
  · intro x hx a
    simpa [qNext] using hupperCoord (r x) hx a
  · intro x hx a
    simpa [qNext] using hlowerCoord (r x) hx a
  · intro x hxUpper hxLower a
    calc
      qNext x a = qNextCoord (r x) a := rfl
      _ = qCoord (r x) a := houtsideCoord (r x) hxUpper hxLower a
      _ = q x a := (hfactor x a).symm

