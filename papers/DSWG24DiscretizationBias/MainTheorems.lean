    {X Y C : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSpace C] [MeasurableSingletonClass Y] [MeasurableSingletonClass C]
    [DecidableEq Y] [DecidableEq C]
    (μ : Measure (X × Y)) (bin : X → Y → C) (y : Y) (c : C)
    (hbin : Measurable (fun xy : X × Y => bin xy.1 y)) :
    AEStronglyMeasurable
      (fun xy : X × Y => if bin xy.1 y = c then
        if xy.2 = y then (1 : ℝ) else 0
      else 0) μ := by
  let S : Set (X × Y) := {xy | bin xy.1 y = c ∧ xy.2 = y}
  have hset : MeasurableSet S := by
    exact (hbin (measurableSet_singleton c)).inter
      (measurable_snd (measurableSet_singleton y))
  have hmeas :
      Measurable (S.indicator (fun _ : X × Y => (1 : ℝ))) :=
    measurable_const.indicator hset
  have hfun :
      S.indicator (fun _ : X × Y => (1 : ℝ)) =
        fun xy : X × Y => if bin xy.1 y = c then
          if xy.2 = y then (1 : ℝ) else 0
        else 0 := by
    funext xy
    by_cases hb : bin xy.1 y = c
    · by_cases hy : xy.2 = y <;> simp [S, Set.indicator, hb, hy]
    · simp [S, Set.indicator, hb]
  rw [← hfun]
  exact hmeas.aestronglyMeasurable

theorem integrable_finiteScoreLabelFiber_product_finite
    {X Y C : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSpace C] [MeasurableSingletonClass Y] [MeasurableSingletonClass C]
    [DecidableEq Y] [DecidableEq C]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (bin : X → Y → C) (y : Y) (c : C)
    (hbin : Measurable (fun xy : X × Y => bin xy.1 y)) :
    Integrable
      (fun xy : X × Y => if bin xy.1 y = c then
        if xy.2 = y then (1 : ℝ) else 0
      else 0) μ := by
  refine Integrable.of_bound
    (aestronglyMeasurable_finiteScoreLabelFiber_product μ bin y c hbin) 1 ?_
  filter_upwards with xy
  by_cases hb : bin xy.1 y = c
  · by_cases hy : xy.2 = y <;> simp [hb, hy]
  · simp [hb]

/--
Bounded measurable conditional-MAE integrands are integrable under finite joint
laws.
-/
theorem integrable_continuousJointClassifierMAE_of_ae_bound
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] (q : X → Y → ℝ) (C : ℝ)
    (hmeas :
      AEStronglyMeasurable
        (fun xy : X × Y => Finite.paperConditionalMAE q xy.1) μ)
    (hbound :
      ∀ᵐ xy ∂μ, ‖Finite.paperConditionalMAE q xy.1‖ ≤ C) :
    Integrable (fun xy : X × Y => Finite.paperConditionalMAE q xy.1) μ :=
  Integrable.of_bound hmeas C hbound

theorem integrable_continuousClassifierMAE_of_ae_bound
    {X Y : Type*} [MeasurableSpace X] [Fintype Y]
    (μ : Measure X) [IsFiniteMeasure μ] (q : X → Y → ℝ) (C : ℝ)
    (hmeas :
      AEStronglyMeasurable (fun x : X => Finite.paperConditionalMAE q x) μ)
    (hbound :
      ∀ᵐ x ∂μ, ‖Finite.paperConditionalMAE q x‖ ≤ C) :
    Integrable (fun x : X => Finite.paperConditionalMAE q x) μ :=
  Integrable.of_bound hmeas C hbound

theorem measurable_featureConditionalMAE_of_scores
    {X Y : Type*} [MeasurableSpace X] [Fintype Y]
    (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun x : X => q x y)) :
    Measurable (fun x : X => Finite.paperConditionalMAE q x) := by
  classical
  unfold Finite.paperConditionalMAE
  exact Finset.measurable_sum Finset.univ (fun y _ =>
    (hscore y).mul (measurable_const.sub (hscore y)))

theorem aestronglyMeasurable_featureConditionalMAE_of_scores
    {X Y : Type*} [MeasurableSpace X] [Fintype Y]
    (μ : Measure X) (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun x : X => q x y)) :
    AEStronglyMeasurable (fun x : X => Finite.paperConditionalMAE q x) μ :=
  (measurable_featureConditionalMAE_of_scores q hscore).aestronglyMeasurable

theorem measurable_jointConditionalMAE_of_scores
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y]
    (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun xy : X × Y => q xy.1 y)) :
    Measurable (fun xy : X × Y => Finite.paperConditionalMAE q xy.1) := by
  classical
  unfold Finite.paperConditionalMAE
  exact Finset.measurable_sum Finset.univ (fun y _ =>
    (hscore y).mul (measurable_const.sub (hscore y)))

theorem aestronglyMeasurable_jointConditionalMAE_of_scores
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun xy : X × Y => q xy.1 y)) :
    AEStronglyMeasurable
      (fun xy : X × Y => Finite.paperConditionalMAE q xy.1) μ :=
  (measurable_jointConditionalMAE_of_scores q hscore).aestronglyMeasurable

theorem norm_paperConditionalMAE_le_card_of_bounds
    {X Y : Type*} [Fintype Y] (q : X → Y → ℝ) (x : X)
    (hnonneg : ∀ y : Y, 0 ≤ q x y)
    (hle_one : ∀ y : Y, q x y ≤ 1) :
    ‖Finite.paperConditionalMAE q x‖ ≤ (Fintype.card Y : ℝ) := by
  classical
  have hnonneg_sum : 0 ≤ Finite.paperConditionalMAE q x := by
    unfold Finite.paperConditionalMAE
    refine Finset.sum_nonneg ?_
    intro y _
    exact mul_nonneg (hnonneg y) (sub_nonneg.mpr (hle_one y))
  rw [Real.norm_eq_abs, abs_of_nonneg hnonneg_sum]
  unfold Finite.paperConditionalMAE
  calc
    (∑ y : Y, q x y * (1 - q x y)) ≤ ∑ _y : Y, (1 : ℝ) := by
      refine Finset.sum_le_sum ?_
      intro y _
      have hsub_nonneg : 0 ≤ 1 - q x y := sub_nonneg.mpr (hle_one y)
      have hsub_le_one : 1 - q x y ≤ 1 := by linarith [hnonneg y]
      simpa using
        (mul_le_mul (hle_one y) hsub_le_one hsub_nonneg (by norm_num : (0 : ℝ) ≤ 1))
    _ = (Fintype.card Y : ℝ) := by simp

theorem eventually_norm_jointConditionalMAE_le_card_of_bounds
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hle_one : ∀ x y, q x y ≤ 1) :
    ∀ᵐ xy ∂μ, ‖Finite.paperConditionalMAE q xy.1‖ ≤ (Fintype.card Y : ℝ) :=
  Filter.Eventually.of_forall (fun xy =>
    norm_paperConditionalMAE_le_card_of_bounds q xy.1
      (fun y => hnonneg xy.1 y) (fun y => hle_one xy.1 y))

theorem eventually_norm_featureConditionalMAE_le_card_of_bounds
    {X Y : Type*} [MeasurableSpace X] [Fintype Y]
    (μ : Measure X) (q : X → Y → ℝ)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hle_one : ∀ x y, q x y ≤ 1) :
    ∀ᵐ x ∂μ, ‖Finite.paperConditionalMAE q x‖ ≤ (Fintype.card Y : ℝ) :=
  Filter.Eventually.of_forall (fun x =>
    norm_paperConditionalMAE_le_card_of_bounds q x
      (fun y => hnonneg x y) (fun y => hle_one x y))

theorem integrable_jointConditionalMAE_of_scores_finite
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun xy : X × Y => q xy.1 y))
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hle_one : ∀ x y, q x y ≤ 1) :
    Integrable (fun xy : X × Y => Finite.paperConditionalMAE q xy.1) μ :=
  integrable_continuousJointClassifierMAE_of_ae_bound
    μ q (Fintype.card Y : ℝ)
    (aestronglyMeasurable_jointConditionalMAE_of_scores μ q hscore)
    (eventually_norm_jointConditionalMAE_le_card_of_bounds μ q hnonneg hle_one)

theorem integrable_featureConditionalMAE_of_scores_finite
    {X Y : Type*} [MeasurableSpace X] [Fintype Y]
    (μ : Measure X) [IsFiniteMeasure μ] (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun x : X => q x y))
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hle_one : ∀ x y, q x y ≤ 1) :
    Integrable (fun x : X => Finite.paperConditionalMAE q x) μ :=
  integrable_continuousClassifierMAE_of_ae_bound
    μ q (Fintype.card Y : ℝ)
    (aestronglyMeasurable_featureConditionalMAE_of_scores μ q hscore)
    (eventually_norm_featureConditionalMAE_le_card_of_bounds μ q hnonneg hle_one)

theorem eventually_norm_jointConditionalMAE_le_one_of_sum_nonneg
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y) :
    ∀ᵐ xy ∂μ, ‖Finite.paperConditionalMAE q xy.1‖ ≤ 1 :=
  Filter.Eventually.of_forall (fun xy =>
    norm_paperConditionalMAE_le_one_of_sum_nonneg q xy.1
      (hsum xy.1) (hnonneg xy.1))

theorem eventually_norm_featureConditionalMAE_le_one_of_sum_nonneg
    {X Y : Type*} [MeasurableSpace X] [Fintype Y]
    (μ : Measure X) (q : X → Y → ℝ)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y) :
    ∀ᵐ x ∂μ, ‖Finite.paperConditionalMAE q x‖ ≤ 1 :=
  Filter.Eventually.of_forall (fun x =>
    norm_paperConditionalMAE_le_one_of_sum_nonneg q x
      (hsum x) (hnonneg x))

theorem integrable_jointConditionalMAE_of_scores_simplex_finite
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun xy : X × Y => q xy.1 y))
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y) :
    Integrable (fun xy : X × Y => Finite.paperConditionalMAE q xy.1) μ :=
  integrable_continuousJointClassifierMAE_of_ae_bound
    μ q 1
    (aestronglyMeasurable_jointConditionalMAE_of_scores μ q hscore)
    (eventually_norm_jointConditionalMAE_le_one_of_sum_nonneg μ q hsum hnonneg)

theorem integrable_featureConditionalMAE_of_scores_simplex_finite
    {X Y : Type*} [MeasurableSpace X] [Fintype Y]
    (μ : Measure X) [IsFiniteMeasure μ] (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun x : X => q x y))
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y) :
    Integrable (fun x : X => Finite.paperConditionalMAE q x) μ :=
  integrable_continuousClassifierMAE_of_ae_bound
    μ q 1
    (aestronglyMeasurable_featureConditionalMAE_of_scores μ q hscore)
    (eventually_norm_featureConditionalMAE_le_one_of_sum_nonneg μ q hsum hnonneg)

/-- Joint weighted mass of a feature-region under a feature-label distribution. -/
noncomputable def jointFeatureSetWeightedMass
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (S : Set X) (w : X → ℝ) : ℝ := by
  exact ∫ xy, S.indicator w xy.1 ∂μ

/-- Joint mass of a feature-region under a feature-label distribution. -/
noncomputable def jointFeatureSetMass
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (S : Set X) : ℝ := by
  exact ∫ xy, S.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ

/-- Weighted mass using the focal score `q_z`. -/
noncomputable def jointFeatureSetScoreMass
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y) : ℝ :=
  jointFeatureSetWeightedMass μ S (fun x => q x z)

/-- Weighted excess above a uniform score on a feature-region. -/
noncomputable def jointFeatureSetScoreExcess
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y)
    (uniformScore : ℝ) : ℝ :=
  jointFeatureSetWeightedMass μ S (fun x => q x z - uniformScore)

/-- Weighted deficit from score one on a feature-region. -/
noncomputable def jointFeatureSetScoreDeficitToOne
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y) : ℝ :=
  jointFeatureSetWeightedMass μ S (fun x => 1 - q x z)

/-- Weighted deficit from a uniform score on a feature-region. -/
noncomputable def jointFeatureSetScoreDeficitToUniform
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y)
    (uniformScore : ℝ) : ℝ :=
  jointFeatureSetWeightedMass μ S (fun x => uniformScore - q x z)

theorem jointFeatureSetWeightedMass_univ
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (w : X → ℝ) :
    jointFeatureSetWeightedMass μ (univ : Set X) w =
      ∫ xy : X × Y, w xy.1 ∂μ := by
  unfold jointFeatureSetWeightedMass
  simp

theorem jointFeatureSetScoreMass_univ_eq_jointAggregatePosterior
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (z : Y) :
    jointFeatureSetScoreMass μ q (univ : Set X) z =
      continuousJointAggregatePosterior μ q z := by
  simpa [jointFeatureSetScoreMass, continuousJointAggregatePosterior] using
    jointFeatureSetWeightedMass_univ μ (fun x : X => q x z)

theorem jointFeatureSetWeightedMass_eq_const_mul_mass_of_eq_on
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (S : Set X) (w : X → ℝ) (c : ℝ)
    (hconst : ∀ x, x ∈ S → w x = c) :
    jointFeatureSetWeightedMass μ S w = c * jointFeatureSetMass μ S := by
  have hpoint : ∀ xy : X × Y,
      S.indicator w xy.1 =
        c * S.indicator (fun _ : X => (1 : ℝ)) xy.1 := by
    intro xy
    by_cases hx : xy.1 ∈ S
    · simp [Set.indicator, hx, hconst xy.1 hx]
    · simp [Set.indicator, hx]
  unfold jointFeatureSetWeightedMass jointFeatureSetMass
  calc
    (∫ xy : X × Y, S.indicator w xy.1 ∂μ)
        = ∫ xy : X × Y,
            c * S.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ =
        c * (∫ xy : X × Y,
          S.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) := by
          rw [integral_const_mul]

theorem jointFeatureSetScoreMass_eq_const_mul_mass_of_eq_on
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y) (c : ℝ)
    (hconst : ∀ x, x ∈ S → q x z = c) :
    jointFeatureSetScoreMass μ q S z = c * jointFeatureSetMass μ S := by
  simpa [jointFeatureSetScoreMass] using
    jointFeatureSetWeightedMass_eq_const_mul_mass_of_eq_on
      μ S (fun x : X => q x z) c hconst

theorem jointFeatureSetScoreMass_eq_of_eq_on
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q qNext : X → Y → ℝ) (S : Set X) (z : Y)
    (heq : ∀ x, x ∈ S → qNext x z = q x z) :
    jointFeatureSetScoreMass μ qNext S z =
      jointFeatureSetScoreMass μ q S z := by
  unfold jointFeatureSetScoreMass jointFeatureSetWeightedMass
  refine integral_congr_ae (Filter.Eventually.of_forall ?_)
  intro xy
  by_cases hx : xy.1 ∈ S
  · simp [Set.indicator, hx, heq xy.1 hx]
  · simp [Set.indicator, hx]

theorem jointFeatureSetScoreMass_sourceSaRegion
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (z : Y) :
    jointFeatureSetScoreMass μ q (sourceSaRegion q z) z =
      jointFeatureSetMass μ (sourceSaRegion q z) := by
  simpa using
    jointFeatureSetScoreMass_eq_const_mul_mass_of_eq_on
      μ q (sourceSaRegion q z) z 1 (fun x hx => hx)

theorem jointFeatureSetScoreMass_sourceScRegion
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (z : Y) (uniformScore : ℝ) :
    jointFeatureSetScoreMass μ q (sourceScRegion q z uniformScore) z =
      uniformScore * jointFeatureSetMass μ (sourceScRegion q z uniformScore) := by
  exact jointFeatureSetScoreMass_eq_const_mul_mass_of_eq_on
    μ q (sourceScRegion q z uniformScore) z uniformScore (fun x hx => hx)

theorem jointFeatureSetScoreMass_sourceSeRegion
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (z : Y) :
    jointFeatureSetScoreMass μ q (sourceSeRegion q z) z = 0 := by
  simpa using
    jointFeatureSetScoreMass_eq_const_mul_mass_of_eq_on
      μ q (sourceSeRegion q z) z 0 (fun x hx => hx)

theorem continuousJointDecisionShare_eq_jointFeatureSetMass_of_rule_iff
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (rule : X → Y) (z : Y) (S : Set X)
    (hiff : ∀ x, rule x = z ↔ x ∈ S) :
    continuousJointDecisionShare μ rule z = jointFeatureSetMass μ S := by
  unfold continuousJointDecisionShare jointFeatureSetMass
  refine integral_congr_ae (Filter.Eventually.of_forall ?_)
  intro xy
  by_cases hrule : rule xy.1 = z
  · have hxS : xy.1 ∈ S := (hiff xy.1).mp hrule
    simp [Set.indicator, hrule, hxS]
  · have hxS : xy.1 ∉ S := by
      intro hxS
      exact hrule ((hiff xy.1).mpr hxS)
    simp [Set.indicator, hrule, hxS]

theorem jointFeatureSetMass_empty
    {X Y : Type*} [MeasurableSpace (X × Y)] (μ : Measure (X × Y)) :
    jointFeatureSetMass μ (∅ : Set X) = 0 := by
  unfold jointFeatureSetMass
  simp

theorem jointFeatureSetMass_univ
    {X Y : Type*} [MeasurableSpace (X × Y)] (μ : Measure (X × Y)) :
    jointFeatureSetMass μ (univ : Set X) =
      ∫ _ : X × Y, (1 : ℝ) ∂μ := by
  unfold jointFeatureSetMass
  simp

theorem jointFeatureSetMass_univ_of_probability
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) [IsProbabilityMeasure μ] :
    jointFeatureSetMass μ (univ : Set X) = 1 := by
  rw [jointFeatureSetMass_univ]
  simp

theorem jointFeatureSetMass_eq_featureMarginal_integral
    {X Z : Type*} [MeasurableSpace X] [MeasurableSpace Z]
    (μ : Measure (X × Z)) (S : Set X) (hS : MeasurableSet S) :
    jointFeatureSetMass μ S =
      ∫ x, S.indicator (fun _ : X => (1 : ℝ)) x ∂(Measure.map Prod.fst μ) := by
  unfold jointFeatureSetMass
  have hmeas :
      AEStronglyMeasurable
        (fun x : X => S.indicator (fun _ : X => (1 : ℝ)) x)
        (Measure.map Prod.fst μ) :=
    (measurable_const.indicator hS).aestronglyMeasurable
  exact (integral_map measurable_fst.aemeasurable hmeas).symm

theorem jointFeatureSetWeightedMass_eq_featureMarginal_integral
    {X Z : Type*} [MeasurableSpace X] [MeasurableSpace Z]
    (μ : Measure (X × Z)) (S : Set X) (w : X → ℝ)
    (hS : MeasurableSet S) (hw : Measurable w) :
    jointFeatureSetWeightedMass μ S w =
      ∫ x, S.indicator w x ∂(Measure.map Prod.fst μ) := by
  unfold jointFeatureSetWeightedMass
  have hmeas :
      AEStronglyMeasurable
        (fun x : X => S.indicator w x)
        (Measure.map Prod.fst μ) :=
    (hw.indicator hS).aestronglyMeasurable
  exact (integral_map measurable_fst.aemeasurable hmeas).symm

/--
Version of `jointFeatureSetWeightedMass_eq_featureMarginal_integral` for the
literal product-space preimage indicator.  This is the form needed by
pulled-back source transformations.
-/
theorem integral_fst_preimage_indicator_eq_featureMarginal_integral
    {X Z : Type*} [MeasurableSpace X] [MeasurableSpace Z]
    (μ : Measure (X × Z)) (S : Set X) (w : X → ℝ)
    (hS : MeasurableSet S) (hw : Measurable w) :
    (∫ xz : X × Z,
        (Prod.fst ⁻¹' S).indicator (fun xz : X × Z => w xz.1) xz ∂μ) =
      ∫ x, S.indicator w x ∂(Measure.map Prod.fst μ) := by
  have hpoint : ∀ xz : X × Z,
      (Prod.fst ⁻¹' S).indicator (fun xz : X × Z => w xz.1) xz =
        S.indicator w xz.1 := by
    intro xz
    by_cases hx : xz.1 ∈ S <;> simp [Set.indicator, hx]
  calc
    (∫ xz : X × Z,
        (Prod.fst ⁻¹' S).indicator (fun xz : X × Z => w xz.1) xz ∂μ) =
        ∫ xz : X × Z, S.indicator w xz.1 ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ = ∫ x, S.indicator w x ∂(Measure.map Prod.fst μ) :=
        jointFeatureSetWeightedMass_eq_featureMarginal_integral μ S w hS hw

/-- Nonnegativity of a product-space `fst`-preimage indicator integral. -/
theorem integral_fst_preimage_indicator_nonneg
    {X Z : Type*} [MeasurableSpace X] [MeasurableSpace Z]
    (μ : Measure (X × Z)) (S : Set X) (w : X → ℝ)
    (hw_nonneg : ∀ x, x ∈ S → 0 ≤ w x) :
    0 ≤ ∫ xz : X × Z,
      (Prod.fst ⁻¹' S).indicator (fun xz : X × Z => w xz.1) xz ∂μ := by
  refine integral_nonneg ?_
  intro xz
  by_cases hx : xz.1 ∈ S
  · simpa [Set.indicator, hx] using hw_nonneg xz.1 hx
  · simp [Set.indicator, hx]

/-- The `1 - q_z` mass is nonnegative on any `S_b` subregion. -/
theorem sourceSbRegion_deficitToOne_fst_preimage_integral_nonneg
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y) (u : ℝ)
    (hregion : ∀ x, x ∈ S → x ∈ sourceSbRegion q z u) :
    0 ≤ ∫ xy : X × Y,
      (Prod.fst ⁻¹' S).indicator (fun xy : X × Y => 1 - q xy.1 z) xy ∂μ :=
  integral_fst_preimage_indicator_nonneg μ S (fun x : X => 1 - q x z)
    (fun x hx => sub_nonneg.mpr (hregion x hx).2.le)

/-- The focal score mass is nonnegative on any `S_d` subregion. -/
theorem sourceSdRegion_score_fst_preimage_integral_nonneg
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y) (u : ℝ)
    (hregion : ∀ x, x ∈ S → x ∈ sourceSdRegion q z u) :
    0 ≤ ∫ xy : X × Y,
      (Prod.fst ⁻¹' S).indicator (fun xy : X × Y => q xy.1 z) xy ∂μ :=
  integral_fst_preimage_indicator_nonneg μ S (fun x : X => q x z)
    (fun x hx => (hregion x hx).1.le)

/-- The `u - q_z` mass is nonnegative on any `S_d` subregion. -/
theorem sourceSdRegion_deficitToUniform_fst_preimage_integral_nonneg
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y) (u : ℝ)
    (hregion : ∀ x, x ∈ S → x ∈ sourceSdRegion q z u) :
    0 ≤ ∫ xy : X × Y,
      (Prod.fst ⁻¹' S).indicator (fun xy : X × Y => u - q xy.1 z) xy ∂μ :=
  integral_fst_preimage_indicator_nonneg μ S (fun x : X => u - q x z)
    (fun x hx => sub_nonneg.mpr (hregion x hx).2.le)

/--
Region-subset version of the balanced `S_b` aggregate MAE accounting.  The
source-region hypotheses discharge the focal-score sign obligations and the
nonnegative deficit mass.
-/
theorem sourceSb_split_twoCoordinate_delta_integral_nonpos_of_balance_region
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (Sba Sbc : Set X) (z : Y) (w : X × Y → Y) (u : ℝ)
    (hAInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
            -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
          ) xy) μ)
    (hBInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
          ) xy) μ)
    (hAUpperInt :
      Integrable
        (fun xy : X × Y =>
          (-2 * (1 - u)) *
            (Prod.fst ⁻¹' Sba).indicator
              (fun xy : X × Y => 1 - q xy.1 z) xy) μ)
    (hBUpperInt :
      Integrable
        (fun xy : X × Y =>
          (2 * u) *
            (Prod.fst ⁻¹' Sbc).indicator
              (fun xy : X × Y => q xy.1 z - u) xy) μ)
    (hSbaRegion : ∀ x, x ∈ Sba → x ∈ sourceSbRegion q z u)
    (hSbcRegion : ∀ x, x ∈ Sbc → x ∈ sourceSbRegion q z u)
    (hqw_le_u :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sba ∪ Sbc → q xy.1 (w xy) ≤ u)
    (hqw_nonneg :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sbc → 0 ≤ q xy.1 (w xy))
    (hbalance :
      (∫ xy : X × Y,
          (Prod.fst ⁻¹' Sbc).indicator
            (fun xy : X × Y => q xy.1 z - u) xy ∂μ) =
        ∫ xy : X × Y,
          (Prod.fst ⁻¹' Sba).indicator
            (fun xy : X × Y => 1 - q xy.1 z) xy ∂μ)
    (hu_le_half : u ≤ (1 / 2 : ℝ)) :
    (∫ xy : X × Y,
        (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
          -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
        ) xy +
        (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
          -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
        ) xy ∂μ) ≤ 0 :=
  sourceSb_split_twoCoordinate_delta_integral_nonpos_of_balance
    μ q Sba Sbc z w u hAInt hBInt hAUpperInt hBUpperInt
    hqw_le_u hqw_nonneg
    (Filter.Eventually.of_forall fun xy hx => (hSbaRegion xy.1 hx).2.le)
    (Filter.Eventually.of_forall fun xy hx => (hSbcRegion xy.1 hx).1.le)
    hbalance
    (sourceSbRegion_deficitToOne_fst_preimage_integral_nonneg
      μ q Sba z u hSbaRegion)
    hu_le_half

/--
Uniform-score region-subset version of the balanced `S_b` aggregate MAE
accounting.
-/
theorem sourceSb_split_twoCoordinate_delta_integral_nonpos_of_balance_uniform_region
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (Sba Sbc : Set X) (z : Y) (w : X × Y → Y)
    (hcard_gt_one : 1 < Fintype.card Y)
    (hAInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
            -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
          ) xy) μ)
    (hBInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
            -2 * ((Fintype.card Y : ℝ)⁻¹ - q xy.1 (w xy)) *
              ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
          ) xy) μ)
    (hAUpperInt :
      Integrable
        (fun xy : X × Y =>
          (-2 * (1 - (Fintype.card Y : ℝ)⁻¹)) *
            (Prod.fst ⁻¹' Sba).indicator
              (fun xy : X × Y => 1 - q xy.1 z) xy) μ)
    (hBUpperInt :
      Integrable
        (fun xy : X × Y =>
          (2 * (Fintype.card Y : ℝ)⁻¹) *
            (Prod.fst ⁻¹' Sbc).indicator
              (fun xy : X × Y => q xy.1 z - (Fintype.card Y : ℝ)⁻¹) xy) μ)
    (hSbaRegion :
      ∀ x, x ∈ Sba →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hSbcRegion :
      ∀ x, x ∈ Sbc →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hqw_le_u :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sba ∪ Sbc → q xy.1 (w xy) ≤ (Fintype.card Y : ℝ)⁻¹)
    (hqw_nonneg :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sbc → 0 ≤ q xy.1 (w xy))
    (hbalance :
      (∫ xy : X × Y,
          (Prod.fst ⁻¹' Sbc).indicator
            (fun xy : X × Y => q xy.1 z - (Fintype.card Y : ℝ)⁻¹) xy ∂μ) =
        ∫ xy : X × Y,
          (Prod.fst ⁻¹' Sba).indicator
            (fun xy : X × Y => 1 - q xy.1 z) xy ∂μ) :
    (∫ xy : X × Y,
        (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
          -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
        ) xy +
        (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
          -2 * ((Fintype.card Y : ℝ)⁻¹ - q xy.1 (w xy)) *
            ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
        ) xy ∂μ) ≤ 0 :=
  sourceSb_split_twoCoordinate_delta_integral_nonpos_of_balance_region
    μ q Sba Sbc z w (Fintype.card Y : ℝ)⁻¹
    hAInt hBInt hAUpperInt hBUpperInt hSbaRegion hSbcRegion
    hqw_le_u hqw_nonneg hbalance
    (uniform_inverse_card_le_half_of_one_lt_card hcard_gt_one)

/--
Patched aggregate `S_b` source accounting.

On `Sba`, this uses the multiclass-safe collapse-to-focal move.  On `Sbc`, it
uses the usual lowering-to-uniform two-coordinate move.  The original focal
balance equation is enough: collapse-to-focal decreases MAE by at least
`2 * q_z * (1 - q_z)`, and on `S_b` the focal score is at least the uniform
score `u`.
-/
theorem integral_paperConditionalMAE_delta_sourceSb_collapse_toOne_lower_toUniform_twoRegion_nonpos
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q qNext : X → Y → ℝ)
    (Sba Sbc : Set X) (z : Y) (w : X × Y → Y) (u : ℝ)
    (hdisj : Disjoint Sba Sbc)
    (hDeltaInt :
      Integrable
        (fun xy : X × Y =>
          Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) μ)
    (hAUpperInt :
      Integrable
        (fun xy : X × Y =>
          (-2 * u) *
            (Prod.fst ⁻¹' Sba).indicator
              (fun xy : X × Y => 1 - q xy.1 z) xy) μ)
    (hBUpperInt :
      Integrable
        (fun xy : X × Y =>
          (2 * u) *
            (Prod.fst ⁻¹' Sbc).indicator
              (fun xy : X × Y => q xy.1 z - u) xy) μ)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x, ∀ a : Y, 0 ≤ q x a)
    (hSbaRegion : ∀ x, x ∈ Sba → x ∈ sourceSbRegion q z u)
    (hSbcRegion : ∀ x, x ∈ Sbc → x ∈ sourceSbRegion q z u)
    (hzw : ∀ᵐ xy ∂μ, xy.1 ∈ Sbc → z ≠ w xy)
    (hshapeA :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sba → ∀ a : Y,
        qNext xy.1 a = if a = z then (1 : ℝ) else 0)
    (hshapeB :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sbc → ∀ a : Y,
        qNext xy.1 a =
          if a = z then u
          else if a = w xy then q xy.1 (w xy) + (q xy.1 z - u)
          else q xy.1 a)
    (hshapeOutside :
      ∀ᵐ xy ∂μ, xy.1 ∉ Sba → xy.1 ∉ Sbc → ∀ a : Y,
        qNext xy.1 a = q xy.1 a)
    (hbalance :
      (∫ xy : X × Y,
          (Prod.fst ⁻¹' Sbc).indicator
            (fun xy : X × Y => q xy.1 z - u) xy ∂μ) =
        ∫ xy : X × Y,
          (Prod.fst ⁻¹' Sba).indicator
            (fun xy : X × Y => 1 - q xy.1 z) xy ∂μ) :
    (∫ xy : X × Y,
        (Finite.paperConditionalMAE qNext xy.1 -
          Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let Aupper : X × Y → ℝ := fun xy =>
    (-2 * u) *
      (Prod.fst ⁻¹' Sba).indicator
        (fun xy : X × Y => 1 - q xy.1 z) xy
  let Bupper : X × Y → ℝ := fun xy =>
    (2 * u) *
      (Prod.fst ⁻¹' Sbc).indicator
        (fun xy : X × Y => q xy.1 z - u) xy
  let delta : X × Y → ℝ := fun xy =>
    Finite.paperConditionalMAE qNext xy.1 -
      Finite.paperConditionalMAE q xy.1
  have hle_ae : delta ≤ᵐ[μ] fun xy => Aupper xy + Bupper xy := by
    filter_upwards [hzw, hshapeA, hshapeB, hshapeOutside] with
      xy hneq hA hB hOutside
    by_cases hxA : xy.1 ∈ Sba
    · have hxBnot : xy.1 ∉ Sbc := by
        intro hxB
        exact (Set.disjoint_left.mp hdisj) hxA hxB
      have hzero :
          Finite.paperConditionalMAE qNext xy.1 = 0 :=
        paperConditionalMAE_eq_zero_of_focal_one_else_zero
          qNext xy.1 z (hA hxA)
      have hmae_lb :
          2 * q xy.1 z * (1 - q xy.1 z) ≤
            Finite.paperConditionalMAE q xy.1 :=
        paperConditionalMAE_ge_two_focal_mul_deficit
          q xy.1 z (hsum xy.1) (hnonneg xy.1)
      have hqz_ge_u : u ≤ q xy.1 z := (hSbaRegion xy.1 hxA).1.le
      have hdef_nonneg : 0 ≤ 1 - q xy.1 z :=
        sub_nonneg.mpr (hSbaRegion xy.1 hxA).2.le
      have hdelta_le :
          delta xy ≤ (-2 * u) * (1 - q xy.1 z) := by
        dsimp [delta]
        rw [hzero]
        nlinarith
      calc
        delta xy ≤ (-2 * u) * (1 - q xy.1 z) := hdelta_le
        _ = Aupper xy + Bupper xy := by
          simp [Aupper, Bupper, Set.indicator, hxA, hxBnot]
    · by_cases hxB : xy.1 ∈ Sbc
      · have hdelta :
            delta xy =
              -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) := by
          dsimp [delta]
          exact
            paperConditionalMAE_twoCoordinate_lower_focal_to_uniform_delta
              q qNext xy.1 xy.1 (hneq hxB) u (hB hxB)
        have hqz_ge_u : u ≤ q xy.1 z := (hSbcRegion xy.1 hxB).1.le
        have hfactor_nonneg : 0 ≤ q xy.1 z - u := sub_nonneg.mpr hqz_ge_u
        have hfactor_le : u - q xy.1 (w xy) ≤ u := by
          linarith [hnonneg xy.1 (w xy)]
        have hprod :
            (u - q xy.1 (w xy)) * (q xy.1 z - u) ≤
              u * (q xy.1 z - u) :=
          mul_le_mul_of_nonneg_right hfactor_le hfactor_nonneg
        have hmul :
            2 * ((u - q xy.1 (w xy)) * (q xy.1 z - u)) ≤
              2 * (u * (q xy.1 z - u)) :=
          mul_le_mul_of_nonneg_left hprod (by norm_num)
        have hrewrite :
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) =
              2 * ((u - q xy.1 (w xy)) * (q xy.1 z - u)) := by
          ring
        calc
          delta xy =
              -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) := hdelta
          _ = 2 * ((u - q xy.1 (w xy)) * (q xy.1 z - u)) := hrewrite
          _ ≤ 2 * (u * (q xy.1 z - u)) := hmul
          _ = Aupper xy + Bupper xy := by
            simp [Aupper, Bupper, Set.indicator, hxA, hxB]
            ring
      · have hsame :
            Finite.paperConditionalMAE qNext xy.1 =
              Finite.paperConditionalMAE q xy.1 := by
          unfold Finite.paperConditionalMAE
          refine Finset.sum_congr rfl ?_
          intro a _
          rw [hOutside hxA hxB a]
        calc
          delta xy = 0 := by
            dsimp [delta]
            linarith
          _ ≤ Aupper xy + Bupper xy := by
            simp [Aupper, Bupper, Set.indicator, hxA, hxB]
  have hUpperInt : Integrable (fun xy => Aupper xy + Bupper xy) μ :=
    hAUpperInt.add hBUpperInt
  have hle_int :
      (∫ xy : X × Y, delta xy ∂μ) ≤
        ∫ xy : X × Y, Aupper xy + Bupper xy ∂μ :=
    integral_mono_ae hDeltaInt hUpperInt hle_ae
  have hUpper_eq_zero :
      (∫ xy : X × Y, Aupper xy + Bupper xy ∂μ) = 0 := by
    rw [integral_add hAUpperInt hBUpperInt]
    change
      (∫ xy : X × Y,
          (-2 * u) *
            (Prod.fst ⁻¹' Sba).indicator
              (fun xy : X × Y => 1 - q xy.1 z) xy ∂μ) +
        (∫ xy : X × Y,
          (2 * u) *
            (Prod.fst ⁻¹' Sbc).indicator
              (fun xy : X × Y => q xy.1 z - u) xy ∂μ) = 0
    rw [integral_const_mul, integral_const_mul, hbalance]
    ring
  change (∫ xy : X × Y, delta xy ∂μ) ≤ 0
  have hupper_nonpos :
      (∫ xy : X × Y, Aupper xy + Bupper xy ∂μ) ≤ 0 := by
    rw [hUpper_eq_zero]
  exact hle_int.trans hupper_nonpos

/--
Region-subset version of the balanced `S_d` aggregate MAE accounting.  The
source-region hypotheses discharge the focal-score sign obligations.
-/
theorem sourceSd_split_twoCoordinate_delta_integral_nonpos_of_balance_region
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (Sdc Sde : Set X) (z : Y) (w : X × Y → Y) (u c : ℝ)
    (hCInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sdc).indicator (fun xy : X × Y =>
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
          ) xy) μ)
    (hEInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sde).indicator (fun xy : X × Y =>
            -2 * q xy.1 (w xy) * q xy.1 z
          ) xy) μ)
    (hCUpperInt :
      Integrable
        (fun xy : X × Y =>
          (2 * c) *
            (Prod.fst ⁻¹' Sdc).indicator
              (fun xy : X × Y => u - q xy.1 z) xy) μ)
    (hEUpperInt :
      Integrable
        (fun xy : X × Y =>
          (-2 * c) *
            (Prod.fst ⁻¹' Sde).indicator
              (fun xy : X × Y => q xy.1 z) xy) μ)
    (hSdcRegion : ∀ x, x ∈ Sdc → x ∈ sourceSdRegion q z u)
    (hSdeRegion : ∀ x, x ∈ Sde → x ∈ sourceSdRegion q z u)
    (hqw_excess_le :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sdc → q xy.1 (w xy) - u ≤ c)
    (hc_le_qw :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sde → c ≤ q xy.1 (w xy))
    (hbalance :
      (∫ xy : X × Y,
          (Prod.fst ⁻¹' Sdc).indicator
            (fun xy : X × Y => u - q xy.1 z) xy ∂μ) =
        ∫ xy : X × Y,
          (Prod.fst ⁻¹' Sde).indicator
            (fun xy : X × Y => q xy.1 z) xy ∂μ) :
    (∫ xy : X × Y,
        (Prod.fst ⁻¹' Sdc).indicator (fun xy : X × Y =>
          -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
        ) xy +
        (Prod.fst ⁻¹' Sde).indicator (fun xy : X × Y =>
          -2 * q xy.1 (w xy) * q xy.1 z
        ) xy ∂μ) ≤ 0 :=
  sourceSd_split_twoCoordinate_delta_integral_nonpos_of_balance
    μ q Sdc Sde z w u c hCInt hEInt hCUpperInt hEUpperInt
    hqw_excess_le hc_le_qw
    (Filter.Eventually.of_forall fun xy hx => (hSdcRegion xy.1 hx).2.le)
    (Filter.Eventually.of_forall fun xy hx => (hSdeRegion xy.1 hx).1.le)
    hbalance

/--
Multiclass-safe aggregate `S_d` source accounting.

On `Sdc`, this uses the usual two-coordinate raise-to-uniform move.  On `Sde`,
it collapses the whole posterior to the selected nonfocal label.  The collapse
side decreases MAE by at least `2 * q_z * (1 - q_z)`, which is enough to pay
for the raise-to-uniform side using only `q_w ≤ 1` and the same focal balance
equation.  No global threshold `c` is needed.
-/
theorem integral_paperConditionalMAE_delta_sourceSd_raise_toUniform_collapseNonfocal_twoRegion_nonpos
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q qNext : X → Y → ℝ)
    (Sdc Sde : Set X) (z : Y) (w : X × Y → Y) (u : ℝ)
    (hdisj : Disjoint Sdc Sde)
    (hDeltaInt :
      Integrable
        (fun xy : X × Y =>
          Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) μ)
    (hCUpperInt :
      Integrable
        (fun xy : X × Y =>
          (2 * (1 - u)) *
            (Prod.fst ⁻¹' Sdc).indicator
              (fun xy : X × Y => u - q xy.1 z) xy) μ)
    (hEUpperInt :
      Integrable
        (fun xy : X × Y =>
          (-2 * (1 - u)) *
            (Prod.fst ⁻¹' Sde).indicator
              (fun xy : X × Y => q xy.1 z) xy) μ)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x, ∀ a : Y, 0 ≤ q x a)
    (hSdcRegion : ∀ x, x ∈ Sdc → x ∈ sourceSdRegion q z u)
    (hSdeRegion : ∀ x, x ∈ Sde → x ∈ sourceSdRegion q z u)
    (hzwC : ∀ᵐ xy ∂μ, xy.1 ∈ Sdc → z ≠ w xy)
    (hshapeC :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sdc → ∀ a : Y,
        qNext xy.1 a =
          if a = z then u
          else if a = w xy then q xy.1 (w xy) - (u - q xy.1 z)
          else q xy.1 a)
    (hshapeE :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sde → ∀ a : Y,
        qNext xy.1 a = if a = w xy then (1 : ℝ) else 0)
    (hshapeOutside :
      ∀ᵐ xy ∂μ, xy.1 ∉ Sdc → xy.1 ∉ Sde → ∀ a : Y,
        qNext xy.1 a = q xy.1 a)
    (hbalance :
      (∫ xy : X × Y,
          (Prod.fst ⁻¹' Sdc).indicator
            (fun xy : X × Y => u - q xy.1 z) xy ∂μ) =
        ∫ xy : X × Y,
          (Prod.fst ⁻¹' Sde).indicator
            (fun xy : X × Y => q xy.1 z) xy ∂μ) :
    (∫ xy : X × Y,
        (Finite.paperConditionalMAE qNext xy.1 -
          Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let Cupper : X × Y → ℝ := fun xy =>
    (2 * (1 - u)) *
      (Prod.fst ⁻¹' Sdc).indicator
        (fun xy : X × Y => u - q xy.1 z) xy
  let Eupper : X × Y → ℝ := fun xy =>
    (-2 * (1 - u)) *
      (Prod.fst ⁻¹' Sde).indicator
        (fun xy : X × Y => q xy.1 z) xy
  let delta : X × Y → ℝ := fun xy =>
    Finite.paperConditionalMAE qNext xy.1 -
      Finite.paperConditionalMAE q xy.1
  have hle_ae : delta ≤ᵐ[μ] fun xy => Cupper xy + Eupper xy := by
    filter_upwards [hzwC, hshapeC, hshapeE, hshapeOutside] with
      xy hneqC hC hE hOutside
    by_cases hxC : xy.1 ∈ Sdc
    · have hxEnot : xy.1 ∉ Sde := by
        intro hxE
        exact (Set.disjoint_left.mp hdisj) hxC hxE
      have hdelta :
          delta xy =
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) := by
        dsimp [delta]
        exact
          paperConditionalMAE_twoCoordinate_raise_focal_to_uniform_delta
            q qNext xy.1 xy.1 (hneqC hxC) u (hC hxC)
      have hqw_le_one : q xy.1 (w xy) ≤ 1 :=
        posterior_coord_le_one_of_sum_nonneg
          q xy.1 (w xy) (hsum xy.1) (hnonneg xy.1)
      have hqz_le_u : q xy.1 z ≤ u := (hSdcRegion xy.1 hxC).2.le
      have hfactor_nonneg : 0 ≤ u - q xy.1 z := sub_nonneg.mpr hqz_le_u
      have hfactor_le : q xy.1 (w xy) - u ≤ 1 - u := by
        linarith
      have hprod :
          (q xy.1 (w xy) - u) * (u - q xy.1 z) ≤
            (1 - u) * (u - q xy.1 z) :=
        mul_le_mul_of_nonneg_right hfactor_le hfactor_nonneg
      have hmul :
          2 * ((q xy.1 (w xy) - u) * (u - q xy.1 z)) ≤
            2 * ((1 - u) * (u - q xy.1 z)) :=
        mul_le_mul_of_nonneg_left hprod (by norm_num)
      have hrewrite :
          -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) =
            2 * ((q xy.1 (w xy) - u) * (u - q xy.1 z)) := by
        ring
      calc
        delta xy =
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) := hdelta
        _ = 2 * ((q xy.1 (w xy) - u) * (u - q xy.1 z)) := hrewrite
        _ ≤ 2 * ((1 - u) * (u - q xy.1 z)) := hmul
        _ = Cupper xy + Eupper xy := by
          simp [Cupper, Eupper, Set.indicator, hxC, hxEnot]
          ring
    · by_cases hxE : xy.1 ∈ Sde
      · have hzero :
            Finite.paperConditionalMAE qNext xy.1 = 0 :=
          paperConditionalMAE_eq_zero_of_focal_one_else_zero
            qNext xy.1 (w xy) (hE hxE)
        have hmae_lb :
            2 * q xy.1 z * (1 - q xy.1 z) ≤
              Finite.paperConditionalMAE q xy.1 :=
          paperConditionalMAE_ge_two_focal_mul_deficit
            q xy.1 z (hsum xy.1) (hnonneg xy.1)
        have hqz_nonneg : 0 ≤ q xy.1 z := (hSdeRegion xy.1 hxE).1.le
        have hqz_le_u : q xy.1 z ≤ u := (hSdeRegion xy.1 hxE).2.le
        have hdelta_le :
            delta xy ≤ (-2 * (1 - u)) * q xy.1 z := by
          dsimp [delta]
          rw [hzero]
          nlinarith
        calc
          delta xy ≤ (-2 * (1 - u)) * q xy.1 z := hdelta_le
          _ = Cupper xy + Eupper xy := by
            simp [Cupper, Eupper, Set.indicator, hxC, hxE]
      · have hsame :
            Finite.paperConditionalMAE qNext xy.1 =
              Finite.paperConditionalMAE q xy.1 := by
          unfold Finite.paperConditionalMAE
          refine Finset.sum_congr rfl ?_
          intro a _
          rw [hOutside hxC hxE a]
        calc
          delta xy = 0 := by
            dsimp [delta]
            linarith
          _ ≤ Cupper xy + Eupper xy := by
            simp [Cupper, Eupper, Set.indicator, hxC, hxE]
  have hUpperInt : Integrable (fun xy => Cupper xy + Eupper xy) μ :=
    hCUpperInt.add hEUpperInt
  have hle_int :
      (∫ xy : X × Y, delta xy ∂μ) ≤
        ∫ xy : X × Y, Cupper xy + Eupper xy ∂μ :=
    integral_mono_ae hDeltaInt hUpperInt hle_ae
  have hUpper_eq_zero :
      (∫ xy : X × Y, Cupper xy + Eupper xy ∂μ) = 0 := by
    rw [integral_add hCUpperInt hEUpperInt]
    change
      (∫ xy : X × Y,
          (2 * (1 - u)) *
            (Prod.fst ⁻¹' Sdc).indicator
              (fun xy : X × Y => u - q xy.1 z) xy ∂μ) +
        (∫ xy : X × Y,
          (-2 * (1 - u)) *
            (Prod.fst ⁻¹' Sde).indicator
              (fun xy : X × Y => q xy.1 z) xy ∂μ) = 0
    rw [integral_const_mul, integral_const_mul, hbalance]
    ring
  change (∫ xy : X × Y, delta xy ∂μ) ≤ 0
  have hupper_nonpos :
      (∫ xy : X × Y, Cupper xy + Eupper xy ∂μ) ≤ 0 := by
    rw [hUpper_eq_zero]
  exact hle_int.trans hupper_nonpos

theorem jointFeatureSetScoreMass_eq_featureMarginal_integral
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z) :
    jointFeatureSetScoreMass μ q S z =
      ∫ x, S.indicator (fun x => q x z) x ∂(Measure.map Prod.fst μ) := by
  simpa [jointFeatureSetScoreMass] using
    jointFeatureSetWeightedMass_eq_featureMarginal_integral
      μ S (fun x => q x z) hS hqz

theorem jointFeatureSetScoreExcess_eq_featureMarginal_integral
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y)
    (uniformScore : ℝ)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z) :
    jointFeatureSetScoreExcess μ q S z uniformScore =
      ∫ x, S.indicator (fun x => q x z - uniformScore) x
        ∂(Measure.map Prod.fst μ) := by
  simpa [jointFeatureSetScoreExcess] using
    jointFeatureSetWeightedMass_eq_featureMarginal_integral
      μ S (fun x => q x z - uniformScore) hS (hqz.sub measurable_const)

theorem jointFeatureSetScoreDeficitToOne_eq_featureMarginal_integral
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z) :
    jointFeatureSetScoreDeficitToOne μ q S z =
      ∫ x, S.indicator (fun x => 1 - q x z) x
        ∂(Measure.map Prod.fst μ) := by
  simpa [jointFeatureSetScoreDeficitToOne] using
    jointFeatureSetWeightedMass_eq_featureMarginal_integral
      μ S (fun x => 1 - q x z) hS (measurable_const.sub hqz)

theorem jointFeatureSetScoreDeficitToUniform_eq_featureMarginal_integral
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y)
    (uniformScore : ℝ)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z) :
    jointFeatureSetScoreDeficitToUniform μ q S z uniformScore =
      ∫ x, S.indicator (fun x => uniformScore - q x z) x
        ∂(Measure.map Prod.fst μ) := by
  simpa [jointFeatureSetScoreDeficitToUniform] using
    jointFeatureSetWeightedMass_eq_featureMarginal_integral
      μ S (fun x => uniformScore - q x z) hS (measurable_const.sub hqz)

theorem jointFeatureSetMass_eq_featureMarginal_real
    {X Z : Type*} [MeasurableSpace X] [MeasurableSpace Z]
    (μ : Measure (X × Z)) (S : Set X) (hS : MeasurableSet S) :
    jointFeatureSetMass μ S = (Measure.map Prod.fst μ).real S := by
  rw [jointFeatureSetMass_eq_featureMarginal_integral μ S hS]
  exact integral_indicator_one hS

/-- Feature-region indicators are integrable under finite laws once measurable. -/
theorem integrable_jointFeatureSetIndicator_of_finite
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] (S : Set X)
    (hmeas :
      AEStronglyMeasurable
        (fun xy : X × Y => S.indicator (fun _ : X => (1 : ℝ)) xy.1) μ) :
    Integrable
      (fun xy : X × Y => S.indicator (fun _ : X => (1 : ℝ)) xy.1) μ := by
  refine Integrable.of_bound hmeas 1 ?_
  filter_upwards with xy
  by_cases hx : xy.1 ∈ S <;> simp [Set.indicator, hx]

theorem aestronglyMeasurable_jointFeatureSetIndicator_of_measurableSet
    {X Z : Type*} [MeasurableSpace X] [MeasurableSpace Z]
    (μ : Measure (X × Z)) {S : Set X} (hS : MeasurableSet S) :
    AEStronglyMeasurable
      (fun xz : X × Z => S.indicator (fun _ : X => (1 : ℝ)) xz.1) μ := by
  have hmeas :
      Measurable (fun xz : X × Z =>
        S.indicator (fun _ : X => (1 : ℝ)) xz.1) := by
    simpa [Function.comp_def] using
      ((measurable_const.indicator hS).comp measurable_fst)
  exact hmeas.aestronglyMeasurable

theorem integrable_jointFeatureSetIndicator_of_measurableSet_finite
    {X Z : Type*} [MeasurableSpace X] [MeasurableSpace Z]
    (μ : Measure (X × Z)) [IsFiniteMeasure μ] (S : Set X)
    (hS : MeasurableSet S) :
    Integrable
      (fun xz : X × Z => S.indicator (fun _ : X => (1 : ℝ)) xz.1) μ :=
  integrable_jointFeatureSetIndicator_of_finite μ S
    (aestronglyMeasurable_jointFeatureSetIndicator_of_measurableSet μ hS)

theorem aestronglyMeasurable_jointFeatureSetWeightedIndicator_of_measurable
    {X Z : Type*} [MeasurableSpace X] [MeasurableSpace Z]
    (μ : Measure (X × Z)) {S : Set X} {w : X → ℝ}
    (hS : MeasurableSet S) (hw : Measurable w) :
    AEStronglyMeasurable (fun xz : X × Z => S.indicator w xz.1) μ := by
  have hmeas :
      Measurable (fun xz : X × Z => S.indicator w xz.1) := by
    simpa [Function.comp_def] using ((hw.indicator hS).comp measurable_fst)
  exact hmeas.aestronglyMeasurable

theorem integrable_jointFeatureSetWeightedIndicator_of_measurable_bounded_finite
    {X Z : Type*} [MeasurableSpace X] [MeasurableSpace Z]
    (μ : Measure (X × Z)) [IsFiniteMeasure μ] (S : Set X) (w : X → ℝ)
    (C : ℝ) (hS : MeasurableSet S) (hw : Measurable w)
    (hCnonneg : 0 ≤ C)
    (hbound : ∀ x : X, ‖w x‖ ≤ C) :
    Integrable (fun xz : X × Z => S.indicator w xz.1) μ := by
  refine Integrable.of_bound
    (aestronglyMeasurable_jointFeatureSetWeightedIndicator_of_measurable
      μ hS hw) C ?_
  filter_upwards with xz
  by_cases hx : xz.1 ∈ S
  · simpa [Set.indicator, hx] using hbound xz.1
  · simpa [Set.indicator, hx] using hCnonneg

/--
Bounded measurable indicators are integrable under finite laws.  This product-
free form is useful for selected-coordinate functions whose indicator set lives
directly in the ambient joint space.
-/
theorem integrable_indicator_of_measurable_bounded_finite
    {Ω : Type*} [MeasurableSpace Ω]
    (μ : Measure Ω) [IsFiniteMeasure μ] (S : Set Ω) (f : Ω → ℝ)
    (C : ℝ) (hS : MeasurableSet S) (hf : Measurable f)
    (hCnonneg : 0 ≤ C)
    (hbound : ∀ ω : Ω, ‖f ω‖ ≤ C) :
    Integrable (fun ω : Ω => S.indicator f ω) μ := by
  refine Integrable.of_bound (hf.indicator hS).aestronglyMeasurable C ?_
  filter_upwards with ω
  by_cases hω : ω ∈ S
  · simpa [Set.indicator, hω] using hbound ω
  · simpa [Set.indicator, hω] using hCnonneg

/--
With finitely many labels, a measurable selector into the label set makes the
selected score measurable on a product space.
-/
theorem measurable_selectedScore_product
    {X Z Y : Type*} [MeasurableSpace X] [MeasurableSpace Z]
    [MeasurableSpace Y] [MeasurableSingletonClass Y] [Fintype Y] [DecidableEq Y]
    (q : X → Y → ℝ) (w : X × Z → Y)
    (hq : ∀ a : Y, Measurable fun x : X => q x a)
    (hw : Measurable w) :
    Measurable fun xz : X × Z => q xz.1 (w xz) := by
  classical
  have hterm :
      ∀ a : Y,
        Measurable fun xz : X × Z =>
          if w xz = a then q xz.1 a else 0 := by
    intro a
    have hset : MeasurableSet {xz : X × Z | w xz = a} := by
      rw [show {xz : X × Z | w xz = a} = w ⁻¹' {a} by
        ext xz
        simp]
      exact hw (measurableSet_singleton a)
    exact Measurable.ite hset ((hq a).comp measurable_fst) measurable_const
  have hsum :
      Measurable fun xz : X × Z =>
        ∑ a : Y, if w xz = a then q xz.1 a else 0 :=
    Finset.measurable_sum Finset.univ (fun a _ => hterm a)
  have h_eq :
      (fun xz : X × Z => q xz.1 (w xz)) =
        fun xz : X × Z =>
          ∑ a : Y, if w xz = a then q xz.1 a else 0 := by
    funext xz
    symm
    rw [Finset.sum_eq_single (w xz)]
    · simp
    · intro b _ hb
      have hne : ¬ w xz = b := fun h => hb h.symm
      simp [hne]
    · intro hnot
      exact False.elim (hnot (Finset.mem_univ (w xz)))
  rw [h_eq]
  exact hsum

/--
With finitely many labels, a measurable feature-level selector makes the
selected score measurable.
-/
theorem measurable_selectedScore
    {X Y : Type*} [MeasurableSpace X]
    [MeasurableSpace Y] [MeasurableSingletonClass Y] [Fintype Y] [DecidableEq Y]
    (q : X → Y → ℝ) (w : X → Y)
    (hq : ∀ a : Y, Measurable fun x : X => q x a)
    (hw : Measurable w) :
    Measurable fun x : X => q x (w x) := by
  classical
  have hterm :
      ∀ a : Y,
        Measurable fun x : X => if w x = a then q x a else 0 := by
    intro a
    have hset : MeasurableSet {x : X | w x = a} := by
      rw [show {x : X | w x = a} = w ⁻¹' {a} by
        ext x
        simp]
      exact hw (measurableSet_singleton a)
    exact Measurable.ite hset (hq a) measurable_const
  have hsum :
      Measurable fun x : X =>
        ∑ a : Y, if w x = a then q x a else 0 :=
    Finset.measurable_sum Finset.univ (fun a _ => hterm a)
  have h_eq :
      (fun x : X => q x (w x)) =
        fun x : X =>
          ∑ a : Y, if w x = a then q x a else 0 := by
    funext x
    symm
    rw [Finset.sum_eq_single (w x)]
    · simp
    · intro b _ hb
      have hne : ¬ w x = b := fun h => hb h.symm
      simp [hne]
    · intro hnot
      exact False.elim (hnot (Finset.mem_univ (w x)))
  rw [h_eq]
  exact hsum

/-- Product-set score indicators are integrable under finite laws and unit bounds. -/
theorem integrable_fst_preimage_score_indicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z) (hle_one : ∀ x, q x z ≤ 1) :
    Integrable
      (fun xy : X × Y =>
        (Prod.fst ⁻¹' S).indicator (fun xy : X × Y => q xy.1 z) xy) μ :=
  integrable_indicator_of_measurable_bounded_finite μ (Prod.fst ⁻¹' S)
    (fun xy : X × Y => q xy.1 z) 1 (hS.preimage measurable_fst)
    (hqz.comp measurable_fst) (by norm_num) (fun xy => by
      rw [Real.norm_eq_abs, abs_of_nonneg (hnonneg xy.1)]
      exact hle_one xy.1)

/-- Product-set `1 - score` indicators are integrable under finite laws. -/
theorem integrable_fst_preimage_score_deficitToOne_indicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z) (hle_one : ∀ x, q x z ≤ 1) :
    Integrable
      (fun xy : X × Y =>
        (Prod.fst ⁻¹' S).indicator (fun xy : X × Y => 1 - q xy.1 z) xy) μ :=
  integrable_indicator_of_measurable_bounded_finite μ (Prod.fst ⁻¹' S)
    (fun xy : X × Y => 1 - q xy.1 z) 1 (hS.preimage measurable_fst)
    (measurable_const.sub (hqz.comp measurable_fst)) (by norm_num) (fun xy => by
      have hnonneg_def : 0 ≤ 1 - q xy.1 z := sub_nonneg.mpr (hle_one xy.1)
      rw [Real.norm_eq_abs, abs_of_nonneg hnonneg_def]
      linarith [hnonneg xy.1])

/-- Product-set `score - uniformScore` indicators are integrable under unit bounds. -/
theorem integrable_fst_preimage_score_excess_indicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y) (uniformScore : ℝ)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z) (hle_one : ∀ x, q x z ≤ 1)
    (huniform_nonneg : 0 ≤ uniformScore) (huniform_le_one : uniformScore ≤ 1) :
    Integrable
      (fun xy : X × Y =>
        (Prod.fst ⁻¹' S).indicator
          (fun xy : X × Y => q xy.1 z - uniformScore) xy) μ :=
  integrable_indicator_of_measurable_bounded_finite μ (Prod.fst ⁻¹' S)
    (fun xy : X × Y => q xy.1 z - uniformScore) 1
    (hS.preimage measurable_fst)
    ((hqz.comp measurable_fst).sub measurable_const) (by norm_num) (fun xy => by
      rw [Real.norm_eq_abs]
      exact abs_le.mpr
        ⟨by linarith [hnonneg xy.1, huniform_le_one],
          by linarith [hle_one xy.1, huniform_nonneg]⟩)

/-- Product-set `uniformScore - score` indicators are integrable under unit bounds. -/
theorem integrable_fst_preimage_score_deficitToUniform_indicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y) (uniformScore : ℝ)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z) (hle_one : ∀ x, q x z ≤ 1)
    (huniform_nonneg : 0 ≤ uniformScore) (huniform_le_one : uniformScore ≤ 1) :
    Integrable
      (fun xy : X × Y =>
        (Prod.fst ⁻¹' S).indicator
          (fun xy : X × Y => uniformScore - q xy.1 z) xy) μ :=
  integrable_indicator_of_measurable_bounded_finite μ (Prod.fst ⁻¹' S)
    (fun xy : X × Y => uniformScore - q xy.1 z) 1
    (hS.preimage measurable_fst)
    (measurable_const.sub (hqz.comp measurable_fst)) (by norm_num) (fun xy => by
      rw [Real.norm_eq_abs]
      exact abs_le.mpr
        ⟨by linarith [hle_one xy.1, huniform_nonneg],
          by linarith [hnonneg xy.1, huniform_le_one]⟩)

/--
The `S_b -> S_a` two-coordinate MAE delta integrand is bounded and integrable
under finite laws when the selected coordinate is measurable and all scores lie
in `[0,1]`.
-/
theorem integrable_fst_preimage_twoCoordinate_delta_toOne_indicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSingletonClass Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y) (w : X × Y → Y)
    (hS : MeasurableSet S)
    (hq : ∀ a : Y, Measurable fun x : X => q x a)
    (hw : Measurable w)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hle_one : ∀ x y, q x y ≤ 1) :
    Integrable
      (fun xy : X × Y =>
        (Prod.fst ⁻¹' S).indicator (fun xy : X × Y =>
          -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
        ) xy) μ := by
  have hqw : Measurable fun xy : X × Y => q xy.1 (w xy) :=
    measurable_selectedScore_product q w hq hw
  have hqz : Measurable fun xy : X × Y => q xy.1 z :=
    (hq z).comp measurable_fst
  have hf :
      Measurable fun xy : X × Y =>
        -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z) :=
    ((measurable_const.mul (measurable_const.sub hqw)).mul
      (measurable_const.sub hqz))
  refine integrable_indicator_of_measurable_bounded_finite μ (Prod.fst ⁻¹' S)
    (fun xy : X × Y =>
      -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z))
    2 (hS.preimage measurable_fst) hf (by norm_num) ?_
  intro xy
  rw [Real.norm_eq_abs]
  have hqw_nonneg : 0 ≤ q xy.1 (w xy) := hnonneg xy.1 (w xy)
  have hqw_le_one : q xy.1 (w xy) ≤ 1 := hle_one xy.1 (w xy)
  have hqz_nonneg : 0 ≤ q xy.1 z := hnonneg xy.1 z
  have hqz_le_one : q xy.1 z ≤ 1 := hle_one xy.1 z
  have ha0 : 0 ≤ 1 - q xy.1 (w xy) := sub_nonneg.mpr hqw_le_one
  have ha1 : 1 - q xy.1 (w xy) ≤ 1 := by linarith
  have hb0 : 0 ≤ 1 - q xy.1 z := sub_nonneg.mpr hqz_le_one
  have hb1 : 1 - q xy.1 z ≤ 1 := by linarith
  have hprod_nonneg :
      0 ≤ (1 - q xy.1 (w xy)) * (1 - q xy.1 z) :=
    mul_nonneg ha0 hb0
  have hprod_le :
      (1 - q xy.1 (w xy)) * (1 - q xy.1 z) ≤ 1 :=
    mul_le_one₀ ha1 hb0 hb1
  exact abs_le.mpr ⟨by nlinarith [hprod_le], by nlinarith [hprod_nonneg]⟩

/--
The two-coordinate MAE delta for moving a focal coordinate to a uniform score
is bounded and integrable under finite laws and unit score bounds.
-/
theorem integrable_fst_preimage_twoCoordinate_delta_toUniform_indicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSingletonClass Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y) (w : X × Y → Y)
    (u : ℝ) (hS : MeasurableSet S)
    (hq : ∀ a : Y, Measurable fun x : X => q x a)
    (hw : Measurable w)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hle_one : ∀ x y, q x y ≤ 1)
    (hu_nonneg : 0 ≤ u) (hu_le_one : u ≤ 1) :
    Integrable
      (fun xy : X × Y =>
        (Prod.fst ⁻¹' S).indicator (fun xy : X × Y =>
          -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
        ) xy) μ := by
  have hqw : Measurable fun xy : X × Y => q xy.1 (w xy) :=
    measurable_selectedScore_product q w hq hw
  have hqz : Measurable fun xy : X × Y => q xy.1 z :=
    (hq z).comp measurable_fst
  have hf :
      Measurable fun xy : X × Y =>
        -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) :=
    ((measurable_const.mul (measurable_const.sub hqw)).mul
      (measurable_const.sub hqz))
  refine integrable_indicator_of_measurable_bounded_finite μ (Prod.fst ⁻¹' S)
    (fun xy : X × Y =>
      -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z))
    2 (hS.preimage measurable_fst) hf (by norm_num) ?_
  intro xy
  let a : ℝ := u - q xy.1 (w xy)
  let b : ℝ := u - q xy.1 z
  change ‖-2 * a * b‖ ≤ 2
  have ha_abs : |a| ≤ 1 := by
    rw [abs_le]
    constructor <;> simp [a] <;> linarith [hnonneg xy.1 (w xy), hle_one xy.1 (w xy),
      hu_nonneg, hu_le_one]
  have hb_abs : |b| ≤ 1 := by
    rw [abs_le]
    constructor <;> simp [b] <;> linarith [hnonneg xy.1 z, hle_one xy.1 z,
      hu_nonneg, hu_le_one]
  have hprod_abs : |a| * |b| ≤ 1 := by
    have hmul := mul_le_mul ha_abs hb_abs (abs_nonneg b) (by norm_num : (0 : ℝ) ≤ 1)
    simpa using hmul
  rw [Real.norm_eq_abs]
  calc
    |(-2) * a * b| = 2 * (|a| * |b|) := by
      rw [show (-2 : ℝ) * a * b = (-2 : ℝ) * (a * b) by ring]
      rw [abs_mul, abs_mul]
      norm_num
    _ ≤ 2 := by nlinarith [hprod_abs]

/--
The `S_d -> S_e` two-coordinate MAE delta integrand is bounded and integrable
under finite laws when the selected coordinate is measurable and all scores lie
in `[0,1]`.
-/
theorem integrable_fst_preimage_twoCoordinate_delta_toZero_indicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSingletonClass Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y) (w : X × Y → Y)
    (hS : MeasurableSet S)
    (hq : ∀ a : Y, Measurable fun x : X => q x a)
    (hw : Measurable w)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hle_one : ∀ x y, q x y ≤ 1) :
    Integrable
      (fun xy : X × Y =>
        (Prod.fst ⁻¹' S).indicator (fun xy : X × Y =>
          -2 * q xy.1 (w xy) * q xy.1 z
        ) xy) μ := by
  have hqw : Measurable fun xy : X × Y => q xy.1 (w xy) :=
    measurable_selectedScore_product q w hq hw
  have hqz : Measurable fun xy : X × Y => q xy.1 z :=
    (hq z).comp measurable_fst
  have hf :
      Measurable fun xy : X × Y =>
        -2 * q xy.1 (w xy) * q xy.1 z :=
    ((measurable_const.mul hqw).mul hqz)
  refine integrable_indicator_of_measurable_bounded_finite μ (Prod.fst ⁻¹' S)
    (fun xy : X × Y => -2 * q xy.1 (w xy) * q xy.1 z)
    2 (hS.preimage measurable_fst) hf (by norm_num) ?_
  intro xy
  rw [Real.norm_eq_abs]
  have hqw_nonneg : 0 ≤ q xy.1 (w xy) := hnonneg xy.1 (w xy)
  have hqw_le_one : q xy.1 (w xy) ≤ 1 := hle_one xy.1 (w xy)
  have hqz_nonneg : 0 ≤ q xy.1 z := hnonneg xy.1 z
  have hqz_le_one : q xy.1 z ≤ 1 := hle_one xy.1 z
  have hprod_nonneg : 0 ≤ q xy.1 (w xy) * q xy.1 z :=
    mul_nonneg hqw_nonneg hqz_nonneg
  have hprod_le : q xy.1 (w xy) * q xy.1 z ≤ 1 :=
    mul_le_one₀ hqw_le_one hqz_nonneg hqz_le_one
  exact abs_le.mpr ⟨by nlinarith [hprod_le], by nlinarith [hprod_nonneg]⟩

theorem integrable_jointFeatureSetScoreIndicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z) (hle_one : ∀ x, q x z ≤ 1) :
    Integrable (fun xy : X × Y => S.indicator (fun x => q x z) xy.1) μ :=
  integrable_jointFeatureSetWeightedIndicator_of_measurable_bounded_finite
    μ S (fun x => q x z) 1 hS hqz (by norm_num) (fun x => by
      rw [Real.norm_eq_abs, abs_of_nonneg (hnonneg x)]
      exact hle_one x)

theorem integrable_jointFeatureSetScoreDeficitToOneIndicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z) (hle_one : ∀ x, q x z ≤ 1) :
    Integrable (fun xy : X × Y =>
      S.indicator (fun x : X => 1 - q x z) xy.1) μ :=
  integrable_jointFeatureSetWeightedIndicator_of_measurable_bounded_finite
    μ S (fun x : X => 1 - q x z) 1 hS (measurable_const.sub hqz)
    (by norm_num) (fun x => by
      have hnonneg_def : 0 ≤ 1 - q x z := sub_nonneg.mpr (hle_one x)
      rw [Real.norm_eq_abs, abs_of_nonneg hnonneg_def]
      linarith [hnonneg x])

theorem integrable_jointFeatureSetScoreExcessIndicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y) (uniformScore : ℝ)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z) (hle_one : ∀ x, q x z ≤ 1)
    (huniform_nonneg : 0 ≤ uniformScore) (huniform_le_one : uniformScore ≤ 1) :
    Integrable (fun xy : X × Y =>
      S.indicator (fun x : X => q x z - uniformScore) xy.1) μ :=
  integrable_jointFeatureSetWeightedIndicator_of_measurable_bounded_finite
    μ S (fun x : X => q x z - uniformScore) 1 hS
    (hqz.sub measurable_const) (by norm_num) (fun x => by
      rw [Real.norm_eq_abs]
      exact abs_le.mpr
        ⟨by linarith [hnonneg x, huniform_le_one],
          by linarith [hle_one x, huniform_nonneg]⟩)

theorem integrable_jointFeatureSetScoreDeficitToUniformIndicator_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (S : Set X) (z : Y) (uniformScore : ℝ)
    (hS : MeasurableSet S) (hqz : Measurable fun x : X => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z) (hle_one : ∀ x, q x z ≤ 1)
    (huniform_nonneg : 0 ≤ uniformScore) (huniform_le_one : uniformScore ≤ 1) :
    Integrable (fun xy : X × Y =>
      S.indicator (fun x : X => uniformScore - q x z) xy.1) μ :=
  integrable_jointFeatureSetWeightedIndicator_of_measurable_bounded_finite
    μ S (fun x : X => uniformScore - q x z) 1 hS
    (measurable_const.sub hqz) (by norm_num) (fun x => by
      rw [Real.norm_eq_abs]
      exact abs_le.mpr
        ⟨by linarith [hle_one x, huniform_nonneg],
          by linarith [hnonneg x, huniform_le_one]⟩)

theorem jointFeatureSetWeightedMass_union_of_disjoint
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (S T : Set X) (w : X → ℝ)
    (hdisj : Disjoint S T)
    (hSInt :
      Integrable (fun xy : X × Y => S.indicator w xy.1) μ)
    (hTInt :
      Integrable (fun xy : X × Y => T.indicator w xy.1) μ) :
    jointFeatureSetWeightedMass μ (S ∪ T) w =
      jointFeatureSetWeightedMass μ S w + jointFeatureSetWeightedMass μ T w := by
  unfold jointFeatureSetWeightedMass
  have hpoint : ∀ xy : X × Y,
      (S ∪ T).indicator w xy.1 =
        S.indicator w xy.1 + T.indicator w xy.1 := by
    intro xy
    by_cases hS : xy.1 ∈ S
    · have hnotT : xy.1 ∉ T := Set.disjoint_left.mp hdisj hS
      simp [hS, hnotT]
    · by_cases hT : xy.1 ∈ T <;> simp [hS, hT]
  calc
    (∫ xy : X × Y, (S ∪ T).indicator w xy.1 ∂μ)
        = ∫ xy : X × Y, S.indicator w xy.1 + T.indicator w xy.1 ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ = (∫ xy : X × Y, S.indicator w xy.1 ∂μ) +
          ∫ xy : X × Y, T.indicator w xy.1 ∂μ := by
          rw [integral_add hSInt hTInt]

theorem jointFeatureSetScoreMass_union_of_disjoint
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S T : Set X) (z : Y)
    (hdisj : Disjoint S T)
    (hSInt :
      Integrable (fun xy : X × Y => S.indicator (fun x => q x z) xy.1) μ)
    (hTInt :
      Integrable (fun xy : X × Y => T.indicator (fun x => q x z) xy.1) μ) :
    jointFeatureSetScoreMass μ q (S ∪ T) z =
      jointFeatureSetScoreMass μ q S z + jointFeatureSetScoreMass μ q T z := by
  simpa [jointFeatureSetScoreMass] using
    jointFeatureSetWeightedMass_union_of_disjoint
      μ S T (fun x => q x z) hdisj hSInt hTInt

/--
If a transformed posterior preserves focal score mass on a split and leaves the
focal score unchanged outside the split, then it preserves the global focal
aggregate posterior.
-/
theorem continuousJointAggregatePosterior_eq_of_split_scoreMass_preserved
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q qNext : X → Y → ℝ) (R : Set X) (z : Y)
    (hRInt :
      Integrable (fun xy : X × Y => R.indicator (fun x => q x z) xy.1) μ)
    (hRComplInt :
      Integrable (fun xy : X × Y => Rᶜ.indicator (fun x => q x z) xy.1) μ)
    (hRNextInt :
      Integrable (fun xy : X × Y => R.indicator (fun x => qNext x z) xy.1) μ)
    (hRComplNextInt :
      Integrable (fun xy : X × Y => Rᶜ.indicator (fun x => qNext x z) xy.1) μ)
    (hmass :
      jointFeatureSetScoreMass μ qNext R z =
        jointFeatureSetScoreMass μ q R z)
    (hoff : ∀ x, x ∉ R → qNext x z = q x z) :
    continuousJointAggregatePosterior μ qNext z =
      continuousJointAggregatePosterior μ q z := by
  have hdisj : Disjoint R Rᶜ := disjoint_compl_right
  have hcover : R ∪ Rᶜ = (univ : Set X) := Set.union_compl_self R
  have hcompl :
      jointFeatureSetScoreMass μ qNext Rᶜ z =
        jointFeatureSetScoreMass μ q Rᶜ z :=
    jointFeatureSetScoreMass_eq_of_eq_on
      μ q qNext Rᶜ z (fun x hx => hoff x (by simpa using hx))
  have hNextUnion :
      jointFeatureSetScoreMass μ qNext (R ∪ Rᶜ) z =
        jointFeatureSetScoreMass μ qNext R z +
          jointFeatureSetScoreMass μ qNext Rᶜ z :=
    jointFeatureSetScoreMass_union_of_disjoint
      μ qNext R Rᶜ z hdisj hRNextInt hRComplNextInt
  have hOrigUnion :
      jointFeatureSetScoreMass μ q (R ∪ Rᶜ) z =
        jointFeatureSetScoreMass μ q R z +
          jointFeatureSetScoreMass μ q Rᶜ z :=
    jointFeatureSetScoreMass_union_of_disjoint
      μ q R Rᶜ z hdisj hRInt hRComplInt
  rw [← jointFeatureSetScoreMass_univ_eq_jointAggregatePosterior]
  rw [← jointFeatureSetScoreMass_univ_eq_jointAggregatePosterior]
  calc
    jointFeatureSetScoreMass μ qNext (univ : Set X) z =
        jointFeatureSetScoreMass μ qNext (R ∪ Rᶜ) z := by rw [hcover]
    _ = jointFeatureSetScoreMass μ qNext R z +
          jointFeatureSetScoreMass μ qNext Rᶜ z := hNextUnion
    _ = jointFeatureSetScoreMass μ q R z +
          jointFeatureSetScoreMass μ q Rᶜ z := by rw [hmass, hcompl]
    _ = jointFeatureSetScoreMass μ q (R ∪ Rᶜ) z := hOrigUnion.symm
    _ = jointFeatureSetScoreMass μ q (univ : Set X) z := by rw [hcover]

theorem continuousJointAggregatePosterior_eq_of_split_scoreMass_preserved_simplex_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q qNext : X → Y → ℝ) (R : Set X) (z : Y)
    (hR : MeasurableSet R)
    (hqz : Measurable fun x : X => q x z)
    (hqNextz : Measurable fun x : X => qNext x z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hsumNext : ∀ x, (∑ a : Y, qNext x a) = 1)
    (hnonnegNext : ∀ x y, 0 ≤ qNext x y)
    (hmass :
      jointFeatureSetScoreMass μ qNext R z =
        jointFeatureSetScoreMass μ q R z)
    (hoff : ∀ x, x ∉ R → qNext x z = q x z) :
    continuousJointAggregatePosterior μ qNext z =
      continuousJointAggregatePosterior μ q z :=
  continuousJointAggregatePosterior_eq_of_split_scoreMass_preserved
    μ q qNext R z
    (integrable_jointFeatureSetScoreIndicator_finite
      μ q R z hR hqz
      (fun x => hnonneg x z)
      (fun x => posterior_coord_le_one_of_sum_nonneg q x z (hsum x) (hnonneg x)))
    (integrable_jointFeatureSetScoreIndicator_finite
      μ q Rᶜ z hR.compl hqz
      (fun x => hnonneg x z)
      (fun x => posterior_coord_le_one_of_sum_nonneg q x z (hsum x) (hnonneg x)))
    (integrable_jointFeatureSetScoreIndicator_finite
      μ qNext R z hR hqNextz
      (fun x => hnonnegNext x z)
      (fun x =>
        posterior_coord_le_one_of_sum_nonneg qNext x z
          (hsumNext x) (hnonnegNext x)))
    (integrable_jointFeatureSetScoreIndicator_finite
      μ qNext Rᶜ z hR.compl hqNextz
      (fun x => hnonnegNext x z)
      (fun x =>
        posterior_coord_le_one_of_sum_nonneg qNext x z
          (hsumNext x) (hnonnegNext x)))
    hmass hoff

theorem jointFeatureSetScoreMass_eq_uniform_plus_excess
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y)
    (uniformScore : ℝ)
    (hUniformInt :
      Integrable
        (fun xy : X × Y =>
          uniformScore * S.indicator (fun _ : X => (1 : ℝ)) xy.1) μ)
    (hExcessInt :
      Integrable
        (fun xy : X × Y =>
          S.indicator (fun x : X => q x z - uniformScore) xy.1) μ) :
    jointFeatureSetScoreMass μ q S z =
      uniformScore * jointFeatureSetMass μ S +
        jointFeatureSetScoreExcess μ q S z uniformScore := by
  have hpoint : ∀ xy : X × Y,
      S.indicator (fun x : X => q x z) xy.1 =
        uniformScore * S.indicator (fun _ : X => (1 : ℝ)) xy.1 +
          S.indicator (fun x : X => q x z - uniformScore) xy.1 := by
    intro xy
    by_cases hx : xy.1 ∈ S
    · simp [Set.indicator, hx]
    · simp [Set.indicator, hx]
  unfold jointFeatureSetScoreMass jointFeatureSetScoreExcess
    jointFeatureSetWeightedMass jointFeatureSetMass
  calc
    (∫ xy : X × Y, S.indicator (fun x : X => q x z) xy.1 ∂μ)
        = ∫ xy : X × Y,
            uniformScore * S.indicator (fun _ : X => (1 : ℝ)) xy.1 +
              S.indicator (fun x : X => q x z - uniformScore) xy.1 ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ =
        (∫ xy : X × Y,
          uniformScore * S.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
            ∫ xy : X × Y,
              S.indicator (fun x : X => q x z - uniformScore) xy.1 ∂μ := by
          rw [integral_add hUniformInt hExcessInt]
    _ =
        uniformScore *
          (∫ xy : X × Y, S.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ) +
            ∫ xy : X × Y,
              S.indicator (fun x : X => q x z - uniformScore) xy.1 ∂μ := by
          rw [integral_const_mul]

theorem jointFeatureSetMass_eq_score_plus_deficitToOne
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y)
    (hScoreInt :
      Integrable (fun xy : X × Y => S.indicator (fun x => q x z) xy.1) μ)
    (hDeficitInt :
      Integrable
        (fun xy : X × Y => S.indicator (fun x : X => 1 - q x z) xy.1) μ) :
    jointFeatureSetMass μ S =
      jointFeatureSetScoreMass μ q S z +
        jointFeatureSetScoreDeficitToOne μ q S z := by
  have hpoint : ∀ xy : X × Y,
      S.indicator (fun _ : X => (1 : ℝ)) xy.1 =
        S.indicator (fun x : X => q x z) xy.1 +
          S.indicator (fun x : X => 1 - q x z) xy.1 := by
    intro xy
    by_cases hx : xy.1 ∈ S
    · simp [Set.indicator, hx]
    · simp [Set.indicator, hx]
  unfold jointFeatureSetMass jointFeatureSetScoreMass
    jointFeatureSetScoreDeficitToOne jointFeatureSetWeightedMass
  calc
    (∫ xy : X × Y, S.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ)
        = ∫ xy : X × Y,
            S.indicator (fun x : X => q x z) xy.1 +
              S.indicator (fun x : X => 1 - q x z) xy.1 ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ =
        (∫ xy : X × Y, S.indicator (fun x : X => q x z) xy.1 ∂μ) +
          ∫ xy : X × Y, S.indicator (fun x : X => 1 - q x z) xy.1 ∂μ := by
          rw [integral_add hScoreInt hDeficitInt]

theorem jointFeatureSetUniformMass_eq_score_plus_deficitToUniform
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (S : Set X) (z : Y)
    (uniformScore : ℝ)
    (hScoreInt :
      Integrable (fun xy : X × Y => S.indicator (fun x => q x z) xy.1) μ)
    (hDeficitInt :
      Integrable
        (fun xy : X × Y =>
          S.indicator (fun x : X => uniformScore - q x z) xy.1) μ) :
    uniformScore * jointFeatureSetMass μ S =
      jointFeatureSetScoreMass μ q S z +
        jointFeatureSetScoreDeficitToUniform μ q S z uniformScore := by
  have hpoint : ∀ xy : X × Y,
      uniformScore * S.indicator (fun _ : X => (1 : ℝ)) xy.1 =
        S.indicator (fun x : X => q x z) xy.1 +
          S.indicator (fun x : X => uniformScore - q x z) xy.1 := by
    intro xy
    by_cases hx : xy.1 ∈ S
    · simp [Set.indicator, hx]
    · simp [Set.indicator, hx]
  unfold jointFeatureSetMass jointFeatureSetScoreMass
    jointFeatureSetScoreDeficitToUniform jointFeatureSetWeightedMass
  calc
    uniformScore *
        (∫ xy : X × Y, S.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ)
        = ∫ xy : X × Y,
            uniformScore * S.indicator (fun _ : X => (1 : ℝ)) xy.1 ∂μ := by
          rw [integral_const_mul]
    _ = ∫ xy : X × Y,
            S.indicator (fun x : X => q x z) xy.1 +
              S.indicator (fun x : X => uniformScore - q x z) xy.1 ∂μ := by
          exact integral_congr_ae (Filter.Eventually.of_forall hpoint)
    _ =
        (∫ xy : X × Y, S.indicator (fun x : X => q x z) xy.1 ∂μ) +
          ∫ xy : X × Y,
            S.indicator (fun x : X => uniformScore - q x z) xy.1 ∂μ := by
          rw [integral_add hScoreInt hDeficitInt]

/--
Source Step 1 focal-prior algebra for the `S_b` split.

If the part sent to the uniform-score region has total excess above `u` equal
to the part sent to score-one's deficit from one, then replacing `S_{b→a}` by
score one and `S_{b→c}` by score `u` preserves the focal aggregate posterior on
their union.
-/
theorem sourceSb_balance_preserves_focal_score_mass
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (Sba Sbc : Set X) (z : Y) (uniformScore : ℝ)
    (hdisj : Disjoint Sba Sbc)
    (hSbaScoreInt :
      Integrable (fun xy : X × Y => Sba.indicator (fun x => q x z) xy.1) μ)
    (hSbcScoreInt :
      Integrable (fun xy : X × Y => Sbc.indicator (fun x => q x z) xy.1) μ)
    (hSbaDeficitInt :
      Integrable
        (fun xy : X × Y => Sba.indicator (fun x : X => 1 - q x z) xy.1) μ)
    (hSbcUniformInt :
      Integrable
        (fun xy : X × Y =>
          uniformScore * Sbc.indicator (fun _ : X => (1 : ℝ)) xy.1) μ)
    (hSbcExcessInt :
      Integrable
        (fun xy : X × Y =>
          Sbc.indicator (fun x : X => q x z - uniformScore) xy.1) μ)
    (hbalance :
      jointFeatureSetScoreExcess μ q Sbc z uniformScore =
        jointFeatureSetScoreDeficitToOne μ q Sba z) :
    jointFeatureSetScoreMass μ q (Sba ∪ Sbc) z =
      jointFeatureSetMass μ Sba +
        uniformScore * jointFeatureSetMass μ Sbc := by
  have hUnion :
      jointFeatureSetScoreMass μ q (Sba ∪ Sbc) z =
        jointFeatureSetScoreMass μ q Sba z +
          jointFeatureSetScoreMass μ q Sbc z :=
    jointFeatureSetScoreMass_union_of_disjoint
      μ q Sba Sbc z hdisj hSbaScoreInt hSbcScoreInt
  have hSbaMass :
      jointFeatureSetMass μ Sba =
        jointFeatureSetScoreMass μ q Sba z +
          jointFeatureSetScoreDeficitToOne μ q Sba z :=
    jointFeatureSetMass_eq_score_plus_deficitToOne
      μ q Sba z hSbaScoreInt hSbaDeficitInt
  have hSbaScore :
      jointFeatureSetScoreMass μ q Sba z =
        jointFeatureSetMass μ Sba -
          jointFeatureSetScoreDeficitToOne μ q Sba z := by
    linarith
  have hSbcScore :
      jointFeatureSetScoreMass μ q Sbc z =
        uniformScore * jointFeatureSetMass μ Sbc +
          jointFeatureSetScoreExcess μ q Sbc z uniformScore :=
    jointFeatureSetScoreMass_eq_uniform_plus_excess
      μ q Sbc z uniformScore hSbcUniformInt hSbcExcessInt
  calc
    jointFeatureSetScoreMass μ q (Sba ∪ Sbc) z =
        jointFeatureSetScoreMass μ q Sba z +
          jointFeatureSetScoreMass μ q Sbc z := hUnion
    _ =
        (jointFeatureSetMass μ Sba -
          jointFeatureSetScoreDeficitToOne μ q Sba z) +
          (uniformScore * jointFeatureSetMass μ Sbc +
            jointFeatureSetScoreExcess μ q Sbc z uniformScore) := by
          rw [hSbaScore, hSbcScore]
    _ = jointFeatureSetMass μ Sba +
          uniformScore * jointFeatureSetMass μ Sbc := by
          rw [hbalance]
          ring

/--
Source Step 2 focal-prior algebra for the `S_d` split.

If the part sent to score zero has focal score mass equal to the part sent to
the uniform-score region's deficit from `u`, then replacing `S_{d→c}` by score
`u` and `S_{d→e}` by score zero preserves the focal aggregate posterior on
their union.
-/
theorem sourceSd_balance_preserves_focal_score_mass
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (Sdc Sde : Set X) (z : Y) (uniformScore : ℝ)
    (hdisj : Disjoint Sdc Sde)
    (hSdcScoreInt :
      Integrable (fun xy : X × Y => Sdc.indicator (fun x => q x z) xy.1) μ)
    (hSdeScoreInt :
      Integrable (fun xy : X × Y => Sde.indicator (fun x => q x z) xy.1) μ)
    (hSdcDeficitInt :
      Integrable
        (fun xy : X × Y =>
          Sdc.indicator (fun x : X => uniformScore - q x z) xy.1) μ)
    (hbalance :
      jointFeatureSetScoreMass μ q Sde z =
        jointFeatureSetScoreDeficitToUniform μ q Sdc z uniformScore) :
    jointFeatureSetScoreMass μ q (Sdc ∪ Sde) z =
      uniformScore * jointFeatureSetMass μ Sdc := by
  have hUnion :
      jointFeatureSetScoreMass μ q (Sdc ∪ Sde) z =
        jointFeatureSetScoreMass μ q Sdc z +
          jointFeatureSetScoreMass μ q Sde z :=
    jointFeatureSetScoreMass_union_of_disjoint
      μ q Sdc Sde z hdisj hSdcScoreInt hSdeScoreInt
  have hSdcMass :
      uniformScore * jointFeatureSetMass μ Sdc =
        jointFeatureSetScoreMass μ q Sdc z +
          jointFeatureSetScoreDeficitToUniform μ q Sdc z uniformScore :=
    jointFeatureSetUniformMass_eq_score_plus_deficitToUniform
      μ q Sdc z uniformScore hSdcScoreInt hSdcDeficitInt
  calc
    jointFeatureSetScoreMass μ q (Sdc ∪ Sde) z =
        jointFeatureSetScoreMass μ q Sdc z +
          jointFeatureSetScoreMass μ q Sde z := hUnion
    _ = jointFeatureSetScoreMass μ q Sdc z +
          jointFeatureSetScoreDeficitToUniform μ q Sdc z uniformScore := by
          rw [hbalance]
    _ = uniformScore * jointFeatureSetMass μ Sdc := hSdcMass.symm

/--
If an `S_b` split has the focal score-mass balance and a transformed posterior
sets the upper piece to focal score one and the lower piece to the uniform
score, then the transformed posterior preserves focal score mass on the split.
-/
theorem sourceSb_qNext_preserves_focal_score_mass_of_shapes
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q qNext : X → Y → ℝ)
    (Sba Sbc : Set X) (z : Y) (uniformScore : ℝ)
    (hdisj : Disjoint Sba Sbc)
    (hOrig :
      jointFeatureSetScoreMass μ q (Sba ∪ Sbc) z =
        jointFeatureSetMass μ Sba +
          uniformScore * jointFeatureSetMass μ Sbc)
    (hSbaNextInt :
      Integrable (fun xy : X × Y => Sba.indicator (fun x => qNext x z) xy.1) μ)
    (hSbcNextInt :
      Integrable (fun xy : X × Y => Sbc.indicator (fun x => qNext x z) xy.1) μ)
    (hSbaShape : ∀ x, x ∈ Sba → qNext x z = 1)
    (hSbcShape : ∀ x, x ∈ Sbc → qNext x z = uniformScore) :
    jointFeatureSetScoreMass μ qNext (Sba ∪ Sbc) z =
      jointFeatureSetScoreMass μ q (Sba ∪ Sbc) z := by
  have hUnionNext :
      jointFeatureSetScoreMass μ qNext (Sba ∪ Sbc) z =
        jointFeatureSetScoreMass μ qNext Sba z +
          jointFeatureSetScoreMass μ qNext Sbc z :=
    jointFeatureSetScoreMass_union_of_disjoint
      μ qNext Sba Sbc z hdisj hSbaNextInt hSbcNextInt
  have hSbaNext :
      jointFeatureSetScoreMass μ qNext Sba z =
        jointFeatureSetMass μ Sba := by
    simpa using
      jointFeatureSetScoreMass_eq_const_mul_mass_of_eq_on
        μ qNext Sba z 1 hSbaShape
  have hSbcNext :
      jointFeatureSetScoreMass μ qNext Sbc z =
        uniformScore * jointFeatureSetMass μ Sbc :=
    jointFeatureSetScoreMass_eq_const_mul_mass_of_eq_on
      μ qNext Sbc z uniformScore hSbcShape
  calc
    jointFeatureSetScoreMass μ qNext (Sba ∪ Sbc) z =
        jointFeatureSetScoreMass μ qNext Sba z +
          jointFeatureSetScoreMass μ qNext Sbc z := hUnionNext
    _ = jointFeatureSetMass μ Sba +
          uniformScore * jointFeatureSetMass μ Sbc := by
          rw [hSbaNext, hSbcNext]
    _ = jointFeatureSetScoreMass μ q (Sba ∪ Sbc) z := hOrig.symm

/--
If an `S_d` split has the focal score-mass balance and a transformed posterior
sets the upper piece to the uniform score and the lower piece to focal score
zero, then the transformed posterior preserves focal score mass on the split.
-/
theorem sourceSd_qNext_preserves_focal_score_mass_of_shapes
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q qNext : X → Y → ℝ)
    (Sdc Sde : Set X) (z : Y) (uniformScore : ℝ)
    (hdisj : Disjoint Sdc Sde)
    (hOrig :
      jointFeatureSetScoreMass μ q (Sdc ∪ Sde) z =
        uniformScore * jointFeatureSetMass μ Sdc)
    (hSdcNextInt :
      Integrable (fun xy : X × Y => Sdc.indicator (fun x => qNext x z) xy.1) μ)
    (hSdeNextInt :
      Integrable (fun xy : X × Y => Sde.indicator (fun x => qNext x z) xy.1) μ)
    (hSdcShape : ∀ x, x ∈ Sdc → qNext x z = uniformScore)
    (hSdeShape : ∀ x, x ∈ Sde → qNext x z = 0) :
    jointFeatureSetScoreMass μ qNext (Sdc ∪ Sde) z =
      jointFeatureSetScoreMass μ q (Sdc ∪ Sde) z := by
  have hUnionNext :
      jointFeatureSetScoreMass μ qNext (Sdc ∪ Sde) z =
        jointFeatureSetScoreMass μ qNext Sdc z +
          jointFeatureSetScoreMass μ qNext Sde z :=
    jointFeatureSetScoreMass_union_of_disjoint
      μ qNext Sdc Sde z hdisj hSdcNextInt hSdeNextInt
  have hSdcNext :
      jointFeatureSetScoreMass μ qNext Sdc z =
        uniformScore * jointFeatureSetMass μ Sdc :=
    jointFeatureSetScoreMass_eq_const_mul_mass_of_eq_on
      μ qNext Sdc z uniformScore hSdcShape
  have hSdeNext :
      jointFeatureSetScoreMass μ qNext Sde z = 0 := by
    simpa using
      jointFeatureSetScoreMass_eq_const_mul_mass_of_eq_on
        μ qNext Sde z 0 hSdeShape
  calc
    jointFeatureSetScoreMass μ qNext (Sdc ∪ Sde) z =
        jointFeatureSetScoreMass μ qNext Sdc z +
          jointFeatureSetScoreMass μ qNext Sde z := hUnionNext
    _ = uniformScore * jointFeatureSetMass μ Sdc := by
          rw [hSdcNext, hSdeNext]
          ring
    _ = jointFeatureSetScoreMass μ q (Sdc ∪ Sde) z := hOrig.symm

theorem sourceSb_featureMarginal_balance_preserves_focal_score_mass
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (Sba Sbc : Set X) (z : Y) (uniformScore : ℝ)
    (hSbaMeas : MeasurableSet Sba) (hSbcMeas : MeasurableSet Sbc)
    (hqz : Measurable fun x : X => q x z)
    (hdisj : Disjoint Sba Sbc)
    (hSbaScoreInt :
      Integrable (fun xy : X × Y => Sba.indicator (fun x => q x z) xy.1) μ)
    (hSbcScoreInt :
      Integrable (fun xy : X × Y => Sbc.indicator (fun x => q x z) xy.1) μ)
    (hSbaDeficitInt :
      Integrable
        (fun xy : X × Y => Sba.indicator (fun x : X => 1 - q x z) xy.1) μ)
    (hSbcUniformInt :
      Integrable
        (fun xy : X × Y =>
          uniformScore * Sbc.indicator (fun _ : X => (1 : ℝ)) xy.1) μ)
    (hSbcExcessInt :
      Integrable
        (fun xy : X × Y =>
          Sbc.indicator (fun x : X => q x z - uniformScore) xy.1) μ)
    (hbalance :
      (∫ x, Sbc.indicator (fun x : X => q x z - uniformScore) x
          ∂(Measure.map Prod.fst μ)) =
        ∫ x, Sba.indicator (fun x : X => 1 - q x z) x
          ∂(Measure.map Prod.fst μ)) :
    jointFeatureSetScoreMass μ q (Sba ∪ Sbc) z =
      jointFeatureSetMass μ Sba +
        uniformScore * jointFeatureSetMass μ Sbc := by
  have hbalanceJoint :
      jointFeatureSetScoreExcess μ q Sbc z uniformScore =
        jointFeatureSetScoreDeficitToOne μ q Sba z := by
    rw [jointFeatureSetScoreExcess_eq_featureMarginal_integral
      μ q Sbc z uniformScore hSbcMeas hqz]
    rw [jointFeatureSetScoreDeficitToOne_eq_featureMarginal_integral
      μ q Sba z hSbaMeas hqz]
    exact hbalance
  exact sourceSb_balance_preserves_focal_score_mass
    μ q Sba Sbc z uniformScore hdisj hSbaScoreInt hSbcScoreInt
    hSbaDeficitInt hSbcUniformInt hSbcExcessInt hbalanceJoint

