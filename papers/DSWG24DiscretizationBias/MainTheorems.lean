/-- The `S_b -> S_a` two-coordinate posterior update preserves total mass. -/
theorem posteriorSum_twoCoordinate_raise_focal_to_one
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w)
    (hsum : (∑ a : Y, q a) = 1) :
    let q' : Y → ℝ :=
      fun a => if a = z then 1 else if a = w then q w - (1 - q z) else q a
    (∑ a : Y, q' a) = 1 := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then 1 else if a = w then q w - (1 - q z) else q a
  have hsum' :
      (∑ a : Y, q' a) =
        (∑ a : Y, q a) + (q' z - q z) + (q' w - q w) := by
    exact EconCSLib.FiniteSum.sum_eq_sum_add_sub_add_sub_of_eq_off
      (f := q') (g := q) (a := z) (b := w) hzw
      (by
        intro a haz haw
        simp [q', haz, haw])
  dsimp only
  simp [q', hzw.symm] at hsum' ⊢
  linarith

/-- The `S_b -> S_a` two-coordinate posterior update is nonnegative under the
single-coordinate feasibility condition on the selected nonfocal mass. -/
theorem posteriorNonneg_twoCoordinate_raise_focal_to_one
    {Y : Type*} [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w)
    (hnonneg : ∀ a : Y, 0 ≤ q a)
    (hdeficit_le : 1 - q z ≤ q w) :
    let q' : Y → ℝ :=
      fun a => if a = z then 1 else if a = w then q w - (1 - q z) else q a
    ∀ a : Y, 0 ≤ q' a := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then 1 else if a = w then q w - (1 - q z) else q a
  dsimp only
  intro a
  by_cases haz : a = z
  · simp [haz]
  · by_cases haw : a = w
    · have hw_nonneg : 0 ≤ q w - (1 - q z) := sub_nonneg.mpr hdeficit_le
      have hw_ne_z : w ≠ z := hzw.symm
      simpa [q', haz, haw, hw_ne_z] using hw_nonneg
    · simpa [q', haz, haw] using hnonneg a

/-- Lowering the focal coordinate to the uniform score preserves total mass. -/
theorem posteriorSum_twoCoordinate_lower_focal_to_uniform
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w) (u : ℝ)
    (hsum : (∑ a : Y, q a) = 1) :
    let q' : Y → ℝ :=
      fun a => if a = z then u else if a = w then q w + (q z - u) else q a
    (∑ a : Y, q' a) = 1 := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then u else if a = w then q w + (q z - u) else q a
  have hsum' :
      (∑ a : Y, q' a) =
        (∑ a : Y, q a) + (q' z - q z) + (q' w - q w) := by
    exact EconCSLib.FiniteSum.sum_eq_sum_add_sub_add_sub_of_eq_off
      (f := q') (g := q) (a := z) (b := w) hzw
      (by
        intro a haz haw
        simp [q', haz, haw])
  dsimp only
  simp [q', hzw.symm] at hsum' ⊢
  linarith

/-- Lowering the focal coordinate to the uniform score preserves nonnegativity. -/
theorem posteriorNonneg_twoCoordinate_lower_focal_to_uniform
    {Y : Type*} [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w) (u : ℝ)
    (hu_nonneg : 0 ≤ u) (hnonneg : ∀ a : Y, 0 ≤ q a)
    (hu_le_qz : u ≤ q z) :
    let q' : Y → ℝ :=
      fun a => if a = z then u else if a = w then q w + (q z - u) else q a
    ∀ a : Y, 0 ≤ q' a := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then u else if a = w then q w + (q z - u) else q a
  dsimp only
  intro a
  by_cases haz : a = z
  · simpa [q', haz] using hu_nonneg
  · by_cases haw : a = w
    · have hw_nonneg : 0 ≤ q w + (q z - u) := by
        linarith [hnonneg w, hu_le_qz]
      have hw_ne_z : w ≠ z := hzw.symm
      simpa [q', haz, haw, hw_ne_z] using hw_nonneg
    · simpa [q', haz, haw] using hnonneg a

/-- Raising the focal coordinate to the uniform score preserves total mass. -/
theorem posteriorSum_twoCoordinate_raise_focal_to_uniform
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w) (u : ℝ)
    (hsum : (∑ a : Y, q a) = 1) :
    let q' : Y → ℝ :=
      fun a => if a = z then u else if a = w then q w - (u - q z) else q a
    (∑ a : Y, q' a) = 1 := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then u else if a = w then q w - (u - q z) else q a
  have hsum' :
      (∑ a : Y, q' a) =
        (∑ a : Y, q a) + (q' z - q z) + (q' w - q w) := by
    exact EconCSLib.FiniteSum.sum_eq_sum_add_sub_add_sub_of_eq_off
      (f := q') (g := q) (a := z) (b := w) hzw
      (by
        intro a haz haw
        simp [q', haz, haw])
  dsimp only
  simp [q', hzw.symm] at hsum' ⊢
  linarith

/-- Raising the focal coordinate to the uniform score preserves nonnegativity
when the selected nonfocal coordinate is at least the uniform score. -/
theorem posteriorNonneg_twoCoordinate_raise_focal_to_uniform
    {Y : Type*} [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w) (u : ℝ)
    (hu_nonneg : 0 ≤ u) (hnonneg : ∀ a : Y, 0 ≤ q a)
    (hu_le_qw : u ≤ q w) :
    let q' : Y → ℝ :=
      fun a => if a = z then u else if a = w then q w - (u - q z) else q a
    ∀ a : Y, 0 ≤ q' a := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then u else if a = w then q w - (u - q z) else q a
  dsimp only
  intro a
  by_cases haz : a = z
  · simpa [q', haz] using hu_nonneg
  · by_cases haw : a = w
    · have hw_nonneg : 0 ≤ q w - (u - q z) := by
        linarith [hu_le_qw, hnonneg z]
      have hw_ne_z : w ≠ z := hzw.symm
      simpa [q', haz, haw, hw_ne_z] using hw_nonneg
    · simpa [q', haz, haw] using hnonneg a

/-- Lowering the focal coordinate to zero preserves total mass. -/
theorem posteriorSum_twoCoordinate_lower_focal_to_zero
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w)
    (hsum : (∑ a : Y, q a) = 1) :
    let q' : Y → ℝ :=
      fun a => if a = z then 0 else if a = w then q w + q z else q a
    (∑ a : Y, q' a) = 1 := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then 0 else if a = w then q w + q z else q a
  have hsum' :
      (∑ a : Y, q' a) =
        (∑ a : Y, q a) + (q' z - q z) + (q' w - q w) := by
    exact EconCSLib.FiniteSum.sum_eq_sum_add_sub_add_sub_of_eq_off
      (f := q') (g := q) (a := z) (b := w) hzw
      (by
        intro a haz haw
        simp [q', haz, haw])
  dsimp only
  simp [q', hzw.symm] at hsum' ⊢
  linarith

/-- Lowering the focal coordinate to zero preserves nonnegativity. -/
theorem posteriorNonneg_twoCoordinate_lower_focal_to_zero
    {Y : Type*} [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w)
    (hnonneg : ∀ a : Y, 0 ≤ q a) :
    let q' : Y → ℝ :=
      fun a => if a = z then 0 else if a = w then q w + q z else q a
    ∀ a : Y, 0 ≤ q' a := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then 0 else if a = w then q w + q z else q a
  dsimp only
  intro a
  by_cases haz : a = z
  · simp [haz]
  · by_cases haw : a = w
    · have hw_nonneg : 0 ≤ q w + q z := add_nonneg (hnonneg w) (hnonneg z)
      have hw_ne_z : w ≠ z := hzw.symm
      simpa [q', haz, haw, hw_ne_z] using hw_nonneg
    · simpa [q', haz, haw] using hnonneg a

/--
In the binary case, the only nonfocal coordinate carries exactly the complement
of the focal posterior mass.
-/
theorem posterior_nonfocal_eq_one_sub_focal_of_card_two
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) {z w : Y}
    (hcard_two : Fintype.card Y = 2) (hw_ne_z : w ≠ z)
    (hsum : (∑ a : Y, q a) = 1) :
    q w = 1 - q z := by
  classical
  have hcard_erase : (Finset.univ.erase z : Finset Y).card = 1 := by
    rw [Finset.card_erase_of_mem (Finset.mem_univ z)]
    change Fintype.card Y - 1 = 1
    omega
  rcases Finset.card_eq_one.mp hcard_erase with ⟨a, ha⟩
  have hw_mem : w ∈ (Finset.univ.erase z : Finset Y) := by
    simp [hw_ne_z]
  have hw_eq_a : w = a := by
    simpa [ha] using hw_mem
  have hsumErase :
      Finset.sum (Finset.univ.erase z) q = 1 - q z := by
    have hdecomp :
        Finset.sum (Finset.univ.erase z) q + q z =
          ∑ a : Y, q a :=
      Finset.sum_erase_add (Finset.univ : Finset Y) q (Finset.mem_univ z)
    linarith
  have hsingle : Finset.sum (Finset.univ.erase z) q = q w := by
    rw [ha]
    simp [hw_eq_a]
  linarith

/-- The rule chooses a posterior maximizer at every feature value. -/
def IsArgmaxRule (q : X → Y → ℝ) (argmaxRule : X → Y) : Prop :=
  ∀ x a, q x a ≤ q x (argmaxRule x)

/--
Turn an implication between focal decisions into the `0/1` indicator inequality
used by the measure-integral source-transformation certificates.
-/
theorem focalDecisionIndicator_le_of_imp
    {Y : Type*} [DecidableEq Y] {oldDecision newDecision z : Y}
    (himp : oldDecision = z → newDecision = z) :
    (if oldDecision = z then (1 : ℝ) else 0) ≤
      if newDecision = z then (1 : ℝ) else 0 := by
  by_cases hold : oldDecision = z
  · simp [hold, himp hold]
  · by_cases hnew : newDecision = z <;> simp [hold, hnew]

/--
Pointwise implication between two feature rules gives the a.e. focal decision
indicator inequality used by source-transformation certificates.
-/
theorem focalDecisionIndicator_ae_le_of_imp
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (rule ruleNext : X → Y) (z : Y)
    (himp : ∀ x : X, rule x = z → ruleNext x = z) :
    (fun xy : X × Y => if rule xy.1 = z then (1 : ℝ) else 0) ≤ᵐ[μ]
      fun xy : X × Y => if ruleNext xy.1 = z then (1 : ℝ) else 0 :=
  Filter.Eventually.of_forall fun xy =>
    focalDecisionIndicator_le_of_imp (himp xy.1)

/-- Source region `S_a`: the focal posterior is one. -/
def sourceSaRegion (q : X → Y → ℝ) (z : Y) : Set X :=
  {x | q x z = 1}

/-- Source region `S_b`: the focal posterior lies strictly between `1/K` and one. -/
def sourceSbRegion (q : X → Y → ℝ) (z : Y) (invK : ℝ) : Set X :=
  {x | invK < q x z ∧ q x z < 1}

/-- Source region `S_c`: the focal posterior is exactly `1/K`. -/
def sourceScRegion (q : X → Y → ℝ) (z : Y) (invK : ℝ) : Set X :=
  {x | q x z = invK}

/-- Source region `S_d`: the focal posterior lies strictly between zero and `1/K`. -/
def sourceSdRegion (q : X → Y → ℝ) (z : Y) (invK : ℝ) : Set X :=
  {x | 0 < q x z ∧ q x z < invK}

/-- Source region `S_e`: the focal posterior is zero. -/
def sourceSeRegion (q : X → Y → ℝ) (z : Y) : Set X :=
  {x | q x z = 0}

/--
Canonical reduced-source decision rule: select the focal class on `S_a ∪ S_c`
and a fixed nonfocal fallback elsewhere.
-/
noncomputable def sourceReducedDecisionRule
    (q : X → Y → ℝ) (z : Y) (uniformScore : ℝ) (fallback : Y) : X → Y := by
  classical
  exact fun x =>
    if x ∈ sourceSaRegion q z ∪ sourceScRegion q z uniformScore then z
    else fallback

theorem measurableSet_sourceSaRegion
    {X Y : Type*} [MeasurableSpace X] {q : X → Y → ℝ} {z : Y}
    (hqz : Measurable fun x => q x z) :
    MeasurableSet (sourceSaRegion q z) := by
  change MeasurableSet ((fun x : X => q x z) ⁻¹' ({(1 : ℝ)} : Set ℝ))
  exact hqz (measurableSet_singleton (1 : ℝ))

theorem measurableSet_sourceSbRegion
    {X Y : Type*} [MeasurableSpace X] {q : X → Y → ℝ} {z : Y} {invK : ℝ}
    (hqz : Measurable fun x => q x z) :
    MeasurableSet (sourceSbRegion q z invK) := by
  change MeasurableSet ((fun x : X => q x z) ⁻¹' Ioo invK (1 : ℝ))
  exact hqz measurableSet_Ioo

theorem measurableSet_sourceScRegion
    {X Y : Type*} [MeasurableSpace X] {q : X → Y → ℝ} {z : Y} {invK : ℝ}
    (hqz : Measurable fun x => q x z) :
    MeasurableSet (sourceScRegion q z invK) := by
  change MeasurableSet ((fun x : X => q x z) ⁻¹' ({invK} : Set ℝ))
  exact hqz (measurableSet_singleton invK)

theorem measurableSet_sourceSdRegion
    {X Y : Type*} [MeasurableSpace X] {q : X → Y → ℝ} {z : Y} {invK : ℝ}
    (hqz : Measurable fun x => q x z) :
    MeasurableSet (sourceSdRegion q z invK) := by
  change MeasurableSet ((fun x : X => q x z) ⁻¹' Ioo (0 : ℝ) invK)
  exact hqz measurableSet_Ioo

theorem measurableSet_sourceSeRegion
    {X Y : Type*} [MeasurableSpace X] {q : X → Y → ℝ} {z : Y}
    (hqz : Measurable fun x => q x z) :
    MeasurableSet (sourceSeRegion q z) := by
  change MeasurableSet ((fun x : X => q x z) ⁻¹' ({(0 : ℝ)} : Set ℝ))
  exact hqz (measurableSet_singleton (0 : ℝ))

theorem measurable_sourceReducedDecisionRule
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    {q : X → Y → ℝ} {z fallback : Y} {uniformScore : ℝ}
    (hqz : Measurable fun x => q x z) :
    Measurable (sourceReducedDecisionRule q z uniformScore fallback) := by
  classical
  have htarget :
      MeasurableSet (sourceSaRegion q z ∪ sourceScRegion q z uniformScore) :=
    (measurableSet_sourceSaRegion hqz).union
      (measurableSet_sourceScRegion hqz)
  unfold sourceReducedDecisionRule
  exact Measurable.ite htarget measurable_const measurable_const

theorem sourceReducedDecisionRule_eq_z_iff
    {X Y : Type*} [DecidableEq Y]
    (q : X → Y → ℝ) (z fallback : Y) (uniformScore : ℝ)
    (hfallback : fallback ≠ z) (x : X) :
    sourceReducedDecisionRule q z uniformScore fallback x = z ↔
      x ∈ sourceSaRegion q z ∪ sourceScRegion q z uniformScore := by
  classical
  unfold sourceReducedDecisionRule
  by_cases hx : x ∈ sourceSaRegion q z ∪ sourceScRegion q z uniformScore
  · simp [hx]
  · simp [hx, hfallback]

theorem focalDecisionIndicator_ae_le_sourceReducedDecisionRule_of_subset
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (rule : X → Y) (z fallback : Y) (uniformScore : ℝ)
    (hfallback : fallback ≠ z)
    (hsubset :
      ∀ x : X, rule x = z →
        x ∈ sourceSaRegion q z ∪ sourceScRegion q z uniformScore) :
    (fun xy : X × Y => if rule xy.1 = z then (1 : ℝ) else 0) ≤ᵐ[μ]
      fun xy : X × Y =>
        if sourceReducedDecisionRule q z uniformScore fallback xy.1 = z
        then (1 : ℝ) else 0 :=
  focalDecisionIndicator_ae_le_of_imp μ rule
    (sourceReducedDecisionRule q z uniformScore fallback) z
    (fun x hx =>
      (sourceReducedDecisionRule_eq_z_iff q z fallback uniformScore
        hfallback x).2 (hsubset x hx))

/--
The five focal regions exhaust the feature space whenever the focal posterior
is pointwise bounded between zero and one.
-/
theorem sourceFocalRegions_exhaustive_of_bounds
    {q : X → Y → ℝ} {z : Y} {invK : ℝ}
    (hnonneg : ∀ x, 0 ≤ q x z)
    (hle_one : ∀ x, q x z ≤ 1) (x : X) :
    x ∈ sourceSaRegion q z ∨
      x ∈ sourceSbRegion q z invK ∨
        x ∈ sourceScRegion q z invK ∨
          x ∈ sourceSdRegion q z invK ∨
            x ∈ sourceSeRegion q z := by
  by_cases htop : q x z = 1
  · exact Or.inl htop
  by_cases hmid : q x z = invK
  · exact Or.inr (Or.inr (Or.inl hmid))
  by_cases hbot : q x z = 0
  · exact Or.inr (Or.inr (Or.inr (Or.inr hbot)))
  rcases lt_or_gt_of_ne hmid with hlt | hgt
  · have hpos : 0 < q x z := lt_of_le_of_ne (hnonneg x) (Ne.symm hbot)
    exact Or.inr (Or.inr (Or.inr (Or.inl ⟨hpos, hlt⟩)))
  · have hlt_one : q x z < 1 := lt_of_le_of_ne (hle_one x) htop
    exact Or.inr (Or.inl ⟨hgt, hlt_one⟩)

/-- Set-union version of `sourceFocalRegions_exhaustive_of_bounds`. -/
theorem sourceFocalRegions_cover_of_bounds
    {q : X → Y → ℝ} {z : Y} {invK : ℝ}
    (hnonneg : ∀ x, 0 ≤ q x z)
    (hle_one : ∀ x, q x z ≤ 1) :
    (sourceSaRegion q z ∪
      (sourceSbRegion q z invK ∪
        (sourceScRegion q z invK ∪
          (sourceSdRegion q z invK ∪ sourceSeRegion q z)))) = univ := by
  ext x
  constructor
  · intro _
    trivial
  · intro _
    rcases sourceFocalRegions_exhaustive_of_bounds hnonneg hle_one x with
      ha | hb | hc | hd | he
    · exact Or.inl ha
    · exact Or.inr (Or.inl hb)
    · exact Or.inr (Or.inr (Or.inl hc))
    · exact Or.inr (Or.inr (Or.inr (Or.inl hd)))
    · exact Or.inr (Or.inr (Or.inr (Or.inr he)))

theorem sourceFocalRegions_exhaustive_of_simplex
    {q : X → Y → ℝ} {z : Y} {invK : ℝ}
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a) (x : X) :
    x ∈ sourceSaRegion q z ∨
      x ∈ sourceSbRegion q z invK ∨
        x ∈ sourceScRegion q z invK ∨
          x ∈ sourceSdRegion q z invK ∨
            x ∈ sourceSeRegion q z :=
  sourceFocalRegions_exhaustive_of_bounds
    (fun x => hnonneg x z)
    (fun x => posterior_coord_le_one_of_sum_nonneg q x z (hsum x) (hnonneg x))
    x

theorem sourceFocalRegions_cover_of_simplex
    {q : X → Y → ℝ} {z : Y} {invK : ℝ}
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a) :
    (sourceSaRegion q z ∪
      (sourceSbRegion q z invK ∪
        (sourceScRegion q z invK ∪
          (sourceSdRegion q z invK ∪ sourceSeRegion q z)))) = univ :=
  sourceFocalRegions_cover_of_bounds
    (fun x => hnonneg x z)
    (fun x => posterior_coord_le_one_of_sum_nonneg q x z (hsum x) (hnonneg x))

theorem sourceSaScSe_cover_of_no_sourceSbSd_simplex
    {q : X → Y → ℝ} {z : Y} {invK : ℝ}
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a)
    (hSb_empty : sourceSbRegion q z invK = ∅)
    (hSd_empty : sourceSdRegion q z invK = ∅) :
    sourceSaRegion q z ∪ (sourceScRegion q z invK ∪ sourceSeRegion q z) =
      univ := by
  have hcover := sourceFocalRegions_cover_of_simplex
    (q := q) (z := z) (invK := invK) hsum hnonneg
  ext x
  constructor
  · intro _
    trivial
  · intro _
    have hxcover :
        x ∈ sourceSaRegion q z ∪
          (sourceSbRegion q z invK ∪
            (sourceScRegion q z invK ∪
              (sourceSdRegion q z invK ∪ sourceSeRegion q z))) := by
      rw [hcover]
      trivial
    rcases hxcover with hSa | hrest
    · exact Or.inl hSa
    rcases hrest with hSb | hrest
    · rw [hSb_empty] at hSb
      exact False.elim hSb
    rcases hrest with hSc | hrest
    · exact Or.inr (Or.inl hSc)
    rcases hrest with hSd | hSe
    · rw [hSd_empty] at hSd
      exact False.elim hSd
    · exact Or.inr (Or.inr hSe)

/--
Once the `S_b` and `S_d` regions are empty, any point outside `S_e` belongs to
the reduced decision region `S_a ∪ S_c`.
-/
theorem sourceSaSc_of_no_sourceSbSd_simplex_of_not_sourceSe
    {q : X → Y → ℝ} {z : Y} {invK : ℝ} {x : X}
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a)
    (hSb_empty : sourceSbRegion q z invK = ∅)
    (hSd_empty : sourceSdRegion q z invK = ∅)
    (hnotSe : x ∉ sourceSeRegion q z) :
    x ∈ sourceSaRegion q z ∪ sourceScRegion q z invK := by
  have hcover :
      sourceSaRegion q z ∪ (sourceScRegion q z invK ∪ sourceSeRegion q z) =
        univ :=
    sourceSaScSe_cover_of_no_sourceSbSd_simplex
      (q := q) (z := z) (invK := invK)
      hsum hnonneg hSb_empty hSd_empty
  have hxcover :
      x ∈ sourceSaRegion q z ∪
        (sourceScRegion q z invK ∪ sourceSeRegion q z) := by
    rw [hcover]
    trivial
  rcases hxcover with hSa | hrest
  · exact Or.inl hSa
  rcases hrest with hSc | hSe
  · exact Or.inr hSc
  · exact False.elim (hnotSe hSe)

/--
Positive focal posterior is a convenient pointwise way to discharge the
non-`S_e` obligation after the reduced source transformations.
-/
theorem sourceSaSc_of_no_sourceSbSd_simplex_of_focal_pos
    {q : X → Y → ℝ} {z : Y} {invK : ℝ} {x : X}
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a)
    (hSb_empty : sourceSbRegion q z invK = ∅)
    (hSd_empty : sourceSdRegion q z invK = ∅)
    (hpos : 0 < q x z) :
    x ∈ sourceSaRegion q z ∪ sourceScRegion q z invK :=
  sourceSaSc_of_no_sourceSbSd_simplex_of_not_sourceSe
    (q := q) (z := z) (invK := invK) (x := x)
    hsum hnonneg hSb_empty hSd_empty
    (by
      intro hSe
      have hz : q x z = 0 := hSe
      linarith)

/--
An argmax rule cannot choose the focal class on an `S_e` point if some class has
posterior mass one there.
-/
theorem not_sourceSeRegion_of_argmax_focal_decision_of_exists_one
    {q : X → Y → ℝ} {rule : X → Y} {z : Y} {x : X}
    (hargmax : IsArgmaxRule q rule)
    (hdecision : rule x = z)
    (hperfect : ∃ a : Y, q x a = 1) :
    x ∉ sourceSeRegion q z := by
  intro hSe
  rcases hperfect with ⟨a, ha⟩
  have hle : q x a ≤ q x (rule x) := hargmax x a
  have hz : q x (rule x) = 0 := by
    simpa [hdecision] using hSe
  have hone_le_zero : (1 : ℝ) ≤ 0 := by
    calc
      (1 : ℝ) = q x a := ha.symm
      _ ≤ q x (rule x) := hle
      _ = 0 := hz
  linarith

/--
For a final reduced posterior, an argmax rule's focal decisions automatically
satisfy the canonical-rule subset obligation: all such points are in
`S_a ∪ S_c`.
-/
theorem argmax_focal_decision_subset_sourceSaSc_of_no_sourceSbSd_simplex
    {q : X → Y → ℝ} {rule : X → Y} {z : Y} {invK : ℝ}
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a)
    (hSb_empty : sourceSbRegion q z invK = ∅)
    (hSd_empty : sourceSdRegion q z invK = ∅)
    (hargmax : IsArgmaxRule q rule)
    (hSePerfect : ∀ x, x ∈ sourceSeRegion q z → ∃ a : Y, q x a = 1) :
    ∀ x, rule x = z →
      x ∈ sourceSaRegion q z ∪ sourceScRegion q z invK := by
  intro x hdecision
  exact
    sourceSaSc_of_no_sourceSbSd_simplex_of_not_sourceSe
      (q := q) (z := z) (invK := invK) (x := x)
      hsum hnonneg hSb_empty hSd_empty
      (by
        intro hSe
        exact not_sourceSeRegion_of_argmax_focal_decision_of_exists_one
          (q := q) (rule := rule) (z := z) (x := x)
          hargmax hdecision (hSePerfect x hSe) hSe)

/--
Pointwise reduced uniform-middle shape for a transformed source posterior:
each feature value is focal-certain, fully uniform, or focal-zero with some
perfect class.
-/
def SourceReducedUniformMiddlePointShape
    (q : X → Y → ℝ) (z : Y) (uniformScore : ℝ) (x : X) : Prop :=
  q x z = 1 ∨
    (∀ a : Y, q x a = uniformScore) ∨
      (q x z = 0 ∧ ∃ a : Y, q x a = 1)

/--
Global reduced uniform-middle shape, packaged as a pointwise trichotomy.
-/
def SourceReducedUniformMiddleShape
    (q : X → Y → ℝ) (z : Y) (uniformScore : ℝ) : Prop :=
  ∀ x : X,
    q x z = 1 ∨
      (∀ a : Y, q x a = uniformScore) ∨
        (q x z = 0 ∧ ∃ a : Y, q x a = 1)

theorem sourceReducedUniformMiddleShape_iff_pointShape
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ} :
    SourceReducedUniformMiddleShape q z uniformScore ↔
      ∀ x : X, SourceReducedUniformMiddlePointShape q z uniformScore x := by
  rfl

theorem sourceReducedUniformMiddlePointShape_of_focal_one_else_zero
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ} {x : X}
    (hshape : ∀ a : Y, q x a = if a = z then (1 : ℝ) else 0) :
    SourceReducedUniformMiddlePointShape q z uniformScore x := by
  left
  simpa using hshape z

theorem sourceReducedUniformMiddlePointShape_of_nonfocal_one_else_zero
    {q : X → Y → ℝ} {z w : Y} {uniformScore : ℝ} {x : X}
    (hw : w ≠ z)
    (hshape : ∀ a : Y, q x a = if a = w then (1 : ℝ) else 0) :
    SourceReducedUniformMiddlePointShape q z uniformScore x := by
  right
  right
  constructor
  · have hzw : z ≠ w := hw.symm
    simpa [hzw] using hshape z
  · refine ⟨w, ?_⟩
    simpa using hshape w

theorem sourceReducedUniformMiddlePointShape_of_all_uniform
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ} {x : X}
    (hshape : ∀ a : Y, q x a = uniformScore) :
    SourceReducedUniformMiddlePointShape q z uniformScore x := by
  right
  left
  exact hshape

theorem sourceReducedUniformMiddleShape_of_pointShape
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (hshape : ∀ x : X,
      SourceReducedUniformMiddlePointShape q z uniformScore x) :
    SourceReducedUniformMiddleShape q z uniformScore := by
  rwa [sourceReducedUniformMiddleShape_iff_pointShape]

theorem sourceReducedUniformMiddlePointShape_congr
    {q qNext : X → Y → ℝ} {z : Y} {uniformScore : ℝ} {x : X}
    (heq : ∀ a : Y, qNext x a = q x a)
    (hshape : SourceReducedUniformMiddlePointShape q z uniformScore x) :
    SourceReducedUniformMiddlePointShape qNext z uniformScore x := by
  rcases hshape with hone | hrest
  · left
    rw [heq z]
    exact hone
  rcases hrest with huniform | hzero
  · right
    left
    intro a
    rw [heq a]
    exact huniform a
  · right
    right
    constructor
    · rw [heq z]
      exact hzero.1
    · rcases hzero.2 with ⟨a, ha⟩
      exact ⟨a, by rw [heq a]; exact ha⟩

theorem sourceReducedUniformMiddleShape_congr
    {q qNext : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (heq : ∀ x : X, ∀ a : Y, qNext x a = q x a)
    (hshape : SourceReducedUniformMiddleShape q z uniformScore) :
    SourceReducedUniformMiddleShape qNext z uniformScore := by
  rw [sourceReducedUniformMiddleShape_iff_pointShape]
  intro x
  exact sourceReducedUniformMiddlePointShape_congr
    (q := q) (qNext := qNext) (z := z) (uniformScore := uniformScore)
    (x := x) (heq x) (hshape x)

theorem sourceReducedUniformMiddleShape_of_all_uniform
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (hshape : ∀ x : X, ∀ a : Y, q x a = uniformScore) :
    SourceReducedUniformMiddleShape q z uniformScore := by
  rw [sourceReducedUniformMiddleShape_iff_pointShape]
  intro x
  exact sourceReducedUniformMiddlePointShape_of_all_uniform
    (q := q) (z := z) (uniformScore := uniformScore) (x := x)
    (hshape x)

theorem sourceReducedUniformMiddleShape_of_piecewise_two_sets
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (A B : Set X)
    (hA : ∀ x : X, x ∈ A →
      SourceReducedUniformMiddlePointShape q z uniformScore x)
    (hB : ∀ x : X, x ∈ B →
      SourceReducedUniformMiddlePointShape q z uniformScore x)
    (hout : ∀ x : X, x ∉ A → x ∉ B →
      SourceReducedUniformMiddlePointShape q z uniformScore x) :
    SourceReducedUniformMiddleShape q z uniformScore := by
  rw [sourceReducedUniformMiddleShape_iff_pointShape]
  intro x
  by_cases hxA : x ∈ A
  · exact hA x hxA
  by_cases hxB : x ∈ B
  · exact hB x hxB
  exact hout x hxA hxB

theorem sourceReducedUniformMiddleShape_of_focal_one_piecewise_two_sets
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (A B : Set X)
    (hA : ∀ x : X, x ∈ A → ∀ a : Y,
      q x a = if a = z then (1 : ℝ) else 0)
    (hB : ∀ x : X, x ∈ B →
      SourceReducedUniformMiddlePointShape q z uniformScore x)
    (hout : ∀ x : X, x ∉ A → x ∉ B →
      SourceReducedUniformMiddlePointShape q z uniformScore x) :
    SourceReducedUniformMiddleShape q z uniformScore :=
  sourceReducedUniformMiddleShape_of_piecewise_two_sets
    (q := q) (z := z) (uniformScore := uniformScore) A B
    (fun x hx => sourceReducedUniformMiddlePointShape_of_focal_one_else_zero
      (q := q) (z := z) (uniformScore := uniformScore) (x := x) (hA x hx))
    hB hout

theorem sourceReducedUniformMiddleShape_of_nonfocal_one_piecewise_two_sets
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (A B : Set X) (w : X → Y)
    (hA : ∀ x : X, x ∈ A →
      w x ≠ z ∧ ∀ a : Y, q x a = if a = w x then (1 : ℝ) else 0)
    (hB : ∀ x : X, x ∈ B →
      SourceReducedUniformMiddlePointShape q z uniformScore x)
    (hout : ∀ x : X, x ∉ A → x ∉ B →
      SourceReducedUniformMiddlePointShape q z uniformScore x) :
    SourceReducedUniformMiddleShape q z uniformScore :=
  sourceReducedUniformMiddleShape_of_piecewise_two_sets
    (q := q) (z := z) (uniformScore := uniformScore) A B
    (fun x hx =>
      sourceReducedUniformMiddlePointShape_of_nonfocal_one_else_zero
        (q := q) (z := z) (w := w x) (uniformScore := uniformScore)
        (x := x) (hA x hx).1 (hA x hx).2)
    hB hout

theorem sourceReducedUniformMiddleShape_of_sourceSb_collapse_interval_piecewise
    {qNext : ℝ → Y → ℝ} {z : Y} {uniformScore lo cut hi : ℝ}
    (hupper : ∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
      qNext x a = if a = z then (1 : ℝ) else 0)
    (hlower : ∀ x : ℝ, x ∈ Ioc lo cut →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x)
    (hout : ∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x) :
    SourceReducedUniformMiddleShape qNext z uniformScore :=
  sourceReducedUniformMiddleShape_of_focal_one_piecewise_two_sets
    (q := qNext) (z := z) (uniformScore := uniformScore)
    (Ioc cut hi) (Ioc lo cut) hupper hlower hout

theorem sourceReducedUniformMiddleShape_of_sourceSd_collapse_interval_piecewise
    {qNext : ℝ → Y → ℝ} {w : ℝ → Y} {z : Y}
    {uniformScore lo cut hi : ℝ}
    (hupper : ∀ x : ℝ, x ∈ Ioc cut hi →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x)
    (hlower : ∀ x : ℝ, x ∈ Ioc lo cut →
      w x ≠ z ∧ ∀ a : Y, qNext x a = if a = w x then (1 : ℝ) else 0)
    (hout : ∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x) :
    SourceReducedUniformMiddleShape qNext z uniformScore :=
  sourceReducedUniformMiddleShape_of_nonfocal_one_piecewise_two_sets
    (q := qNext) (z := z) (uniformScore := uniformScore)
    (Ioc lo cut) (Ioc cut hi) w hlower hupper (by
      intro x hxLower hxUpper
      exact hout x hxUpper hxLower)

theorem sourceReducedUniformMiddleShape_of_sourceSb_collapse_subset_interval_piecewise
    {qNext : ℝ → Y → ℝ} {S : Set ℝ} {z : Y}
    {uniformScore lo cut hi : ℝ}
    (hupper : ∀ x : ℝ, x ∈ S ∩ Ioc cut hi → ∀ a : Y,
      qNext x a = if a = z then (1 : ℝ) else 0)
    (hlower : ∀ x : ℝ, x ∈ S ∩ Ioc lo cut →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x)
    (hout : ∀ x : ℝ, x ∉ S ∩ Ioc cut hi → x ∉ S ∩ Ioc lo cut →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x) :
    SourceReducedUniformMiddleShape qNext z uniformScore :=
  sourceReducedUniformMiddleShape_of_focal_one_piecewise_two_sets
    (q := qNext) (z := z) (uniformScore := uniformScore)
    (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) hupper hlower hout

theorem sourceReducedUniformMiddleShape_of_sourceSd_collapse_subset_interval_piecewise
    {qNext : ℝ → Y → ℝ} {w : ℝ → Y} {S : Set ℝ} {z : Y}
    {uniformScore lo cut hi : ℝ}
    (hupper : ∀ x : ℝ, x ∈ S ∩ Ioc cut hi →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x)
    (hlower : ∀ x : ℝ, x ∈ S ∩ Ioc lo cut →
      w x ≠ z ∧ ∀ a : Y, qNext x a = if a = w x then (1 : ℝ) else 0)
    (hout : ∀ x : ℝ, x ∉ S ∩ Ioc cut hi → x ∉ S ∩ Ioc lo cut →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x) :
    SourceReducedUniformMiddleShape qNext z uniformScore :=
  sourceReducedUniformMiddleShape_of_nonfocal_one_piecewise_two_sets
    (q := qNext) (z := z) (uniformScore := uniformScore)
    (S ∩ Ioc lo cut) (S ∩ Ioc cut hi) w hlower hupper (by
      intro x hxLower hxUpper
      exact hout x hxUpper hxLower)

theorem sourceSb_collapse_upperInterval_reducedUniformMiddlePointShape
    {qNext : ℝ → Y → ℝ} {z : Y} {uniformScore cut hi : ℝ}
    (hupper : ∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
      qNext x a = if a = z then (1 : ℝ) else 0) :
    ∀ x : ℝ, x ∈ Ioc cut hi →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x := by
  intro x hx
  exact sourceReducedUniformMiddlePointShape_of_focal_one_else_zero
    (q := qNext) (z := z) (uniformScore := uniformScore) (x := x)
    (hupper x hx)

theorem sourceSd_collapse_lowerInterval_reducedUniformMiddlePointShape
    {qNext : ℝ → Y → ℝ} {w : ℝ → Y} {z : Y}
    {uniformScore lo cut : ℝ}
    (hselector : ∀ x : ℝ, x ∈ Ioc lo cut → w x ≠ z)
    (hlower : ∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
      qNext x a = if a = w x then (1 : ℝ) else 0) :
    ∀ x : ℝ, x ∈ Ioc lo cut →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x := by
  intro x hx
  exact sourceReducedUniformMiddlePointShape_of_nonfocal_one_else_zero
    (q := qNext) (z := z) (w := w x) (uniformScore := uniformScore)
    (x := x) (hselector x hx) (hlower x hx)

theorem sourceSb_collapse_upperSubsetInterval_reducedUniformMiddlePointShape
    {qNext : ℝ → Y → ℝ} {S : Set ℝ} {z : Y}
    {uniformScore cut hi : ℝ}
    (hupper : ∀ x : ℝ, x ∈ S ∩ Ioc cut hi → ∀ a : Y,
      qNext x a = if a = z then (1 : ℝ) else 0) :
    ∀ x : ℝ, x ∈ S ∩ Ioc cut hi →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x := by
  intro x hx
  exact sourceReducedUniformMiddlePointShape_of_focal_one_else_zero
    (q := qNext) (z := z) (uniformScore := uniformScore) (x := x)
    (hupper x hx)

theorem sourceSd_collapse_lowerSubsetInterval_reducedUniformMiddlePointShape
    {qNext : ℝ → Y → ℝ} {w : ℝ → Y} {S : Set ℝ} {z : Y}
    {uniformScore lo cut : ℝ}
    (hselector : ∀ x : ℝ, x ∈ S ∩ Ioc lo cut → w x ≠ z)
    (hlower : ∀ x : ℝ, x ∈ S ∩ Ioc lo cut → ∀ a : Y,
      qNext x a = if a = w x then (1 : ℝ) else 0) :
    ∀ x : ℝ, x ∈ S ∩ Ioc lo cut →
      SourceReducedUniformMiddlePointShape qNext z uniformScore x := by
  intro x hx
  exact sourceReducedUniformMiddlePointShape_of_nonfocal_one_else_zero
    (q := qNext) (z := z) (w := w x) (uniformScore := uniformScore)
    (x := x) (hselector x hx) (hlower x hx)

theorem sourceSbRegion_empty_of_reducedUniformMiddleShape
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (hzero_lt_uniform : 0 < uniformScore)
    (hshape : SourceReducedUniformMiddleShape q z uniformScore) :
    sourceSbRegion q z uniformScore = ∅ := by
  ext x
  constructor
  · intro hx
    have hx' : uniformScore < q x z ∧ q x z < 1 := by
      simpa [sourceSbRegion] using hx
    exfalso
    rcases hshape x with hOne | hrest
    · linarith
    rcases hrest with hUniform | hZero
    · have hz : q x z = uniformScore := hUniform z
      linarith
    · linarith
  · intro hx
    exact False.elim hx

theorem sourceSdRegion_empty_of_reducedUniformMiddleShape
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (huniform_lt_one : uniformScore < 1)
    (hshape : SourceReducedUniformMiddleShape q z uniformScore) :
    sourceSdRegion q z uniformScore = ∅ := by
  ext x
  constructor
  · intro hx
    have hx' : 0 < q x z ∧ q x z < uniformScore := by
      simpa [sourceSdRegion] using hx
    exfalso
    rcases hshape x with hOne | hrest
    · linarith
    rcases hrest with hUniform | hZero
    · have hz : q x z = uniformScore := hUniform z
      linarith
    · linarith
  · intro hx
    exact False.elim hx

theorem sourceSc_uniform_of_reducedUniformMiddleShape
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (hzero_lt_uniform : 0 < uniformScore)
    (huniform_lt_one : uniformScore < 1)
    (hshape : SourceReducedUniformMiddleShape q z uniformScore) :
    ∀ x, x ∈ sourceScRegion q z uniformScore →
      ∀ a : Y, q x a = uniformScore := by
  intro x hx
  have hx' : q x z = uniformScore := by
    simpa [sourceScRegion] using hx
  rcases hshape x with hOne | hrest
  · exfalso
    linarith
  rcases hrest with hUniform | hZero
  · exact hUniform
  · exfalso
    linarith

theorem sourceSe_perfect_of_reducedUniformMiddleShape
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (hzero_lt_uniform : 0 < uniformScore)
    (hshape : SourceReducedUniformMiddleShape q z uniformScore) :
    ∀ x, x ∈ sourceSeRegion q z → ∃ a : Y, q x a = 1 := by
  intro x hx
  have hx' : q x z = 0 := by
    simpa [sourceSeRegion] using hx
  rcases hshape x with hOne | hrest
  · exfalso
    linarith
  rcases hrest with hUniform | hZero
  · exfalso
    have hz : q x z = uniformScore := hUniform z
    linarith
  · exact hZero.2

theorem sourceReducedUniformMiddle_obligations_of_shape
    {q : X → Y → ℝ} {z : Y} {uniformScore : ℝ}
    (hzero_lt_uniform : 0 < uniformScore)
    (huniform_lt_one : uniformScore < 1)
    (hshape : SourceReducedUniformMiddleShape q z uniformScore) :
    sourceSbRegion q z uniformScore = ∅ ∧
      sourceSdRegion q z uniformScore = ∅ ∧
        (∀ x, x ∈ sourceScRegion q z uniformScore →
          ∀ a : Y, q x a = uniformScore) ∧
          (∀ x, x ∈ sourceSeRegion q z → ∃ a : Y, q x a = 1) :=
  ⟨sourceSbRegion_empty_of_reducedUniformMiddleShape
      hzero_lt_uniform hshape,
    sourceSdRegion_empty_of_reducedUniformMiddleShape
      huniform_lt_one hshape,
    sourceSc_uniform_of_reducedUniformMiddleShape
      hzero_lt_uniform huniform_lt_one hshape,
    sourceSe_perfect_of_reducedUniformMiddleShape
      hzero_lt_uniform hshape⟩

theorem sourceReducedUniformMiddle_obligations_of_shape_uniform_simplex
    {q : X → Y → ℝ} {z : Y}
    [Fintype Y]
    (hcard_gt_one : 1 < Fintype.card Y)
    (hshape :
      SourceReducedUniformMiddleShape q z (Fintype.card Y : ℝ)⁻¹) :
    sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹ = ∅ ∧
      sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹ = ∅ ∧
        (∀ x, x ∈ sourceScRegion q z (Fintype.card Y : ℝ)⁻¹ →
          ∀ a : Y, q x a = (Fintype.card Y : ℝ)⁻¹) ∧
          (∀ x, x ∈ sourceSeRegion q z → ∃ a : Y, q x a = 1) :=
  sourceReducedUniformMiddle_obligations_of_shape
    (q := q) (z := z) (uniformScore := (Fintype.card Y : ℝ)⁻¹)
    (uniform_inverse_card_pos z)
    (uniform_inverse_card_lt_one_of_one_lt_card hcard_gt_one)
    hshape

theorem sourceSbRegion_weights_nonneg
    {q : X → Y → ℝ} {z : Y} {invK : ℝ} {x : X}
    (hx : x ∈ sourceSbRegion q z invK) :
    0 ≤ q x z - invK ∧ 0 ≤ 1 - q x z :=
  ⟨sub_nonneg.mpr hx.1.le, sub_nonneg.mpr hx.2.le⟩

theorem sourceSdRegion_weights_nonneg
    {q : X → Y → ℝ} {z : Y} {invK : ℝ} {x : X}
    (hx : x ∈ sourceSdRegion q z invK) :
    0 ≤ q x z ∧ 0 ≤ invK - q x z :=
  ⟨hx.1.le, sub_nonneg.mpr hx.2.le⟩

theorem exists_nonfocal_below_uniform_of_sourceSbRegion_simplex
    {q : X → Y → ℝ} {z : Y} {x : X}
    (hsum : (∑ a : Y, q x a) = 1)
    (hx : x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ y : Y, y ≠ z ∧ q x y < (Fintype.card Y : ℝ)⁻¹ :=
  exists_coord_lt_uniform_of_coord_gt_uniform (fun a : Y => q x a) z hsum hx.1

theorem exists_nonfocal_above_uniform_of_sourceSdRegion_simplex
    {q : X → Y → ℝ} {z : Y} {x : X}
    (hsum : (∑ a : Y, q x a) = 1)
    (hx : x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ y : Y, y ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x y :=
  exists_coord_gt_uniform_of_coord_lt_uniform (fun a : Y => q x a) z hsum hx.2

theorem exists_nonfocal_below_invK_of_sourceSbRegion_simplex
    {q : X → Y → ℝ} {z : Y} {invK : ℝ} {x : X}
    (hinvK : invK = (Fintype.card Y : ℝ)⁻¹)
    (hsum : (∑ a : Y, q x a) = 1)
    (hx : x ∈ sourceSbRegion q z invK) :
    ∃ y : Y, y ≠ z ∧ q x y < invK := by
  subst invK
  exact exists_nonfocal_below_uniform_of_sourceSbRegion_simplex hsum hx

theorem exists_nonfocal_above_invK_of_sourceSdRegion_simplex
    {q : X → Y → ℝ} {z : Y} {invK : ℝ} {x : X}
    (hinvK : invK = (Fintype.card Y : ℝ)⁻¹)
    (hsum : (∑ a : Y, q x a) = 1)
    (hx : x ∈ sourceSdRegion q z invK) :
    ∃ y : Y, y ≠ z ∧ invK < q x y := by
  subst invK
  exact exists_nonfocal_above_uniform_of_sourceSdRegion_simplex hsum hx

/--
Classical finite-label selector for the source proof's `S_b` moves.

On any subregion of `S_b`, every point has some nonfocal class below the
uniform score.  This packages those pointwise witnesses as a single selector.
-/
theorem exists_sourceSbRegion_nonfocal_selector_uniform_simplex
    {X Y : Type*} [MeasurableSpace X] [Fintype Y] [DecidableEq Y]
    (q : X → Y → ℝ) (S : Set X) (z : Y)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hregion :
      ∀ x, x ∈ S →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ w : X → Y,
      ∀ x, x ∈ S → w x ≠ z ∧ q x (w x) < (Fintype.card Y : ℝ)⁻¹ := by
  classical
  have hex :
      ∀ x, x ∈ S →
        ∃ y : Y, y ≠ z ∧ q x y < (Fintype.card Y : ℝ)⁻¹ := by
    intro x hx
    exact exists_nonfocal_below_uniform_of_sourceSbRegion_simplex
      (q := q) (z := z) (x := x) (hsum x) (hregion x hx)
  let w : X → Y := fun x =>
    if hx : x ∈ S then Classical.choose (hex x hx) else z
  refine ⟨w, ?_⟩
  intro x hx
  simpa [w, hx] using Classical.choose_spec (hex x hx)

/--
Classical finite-label selector for the source proof's `S_d` moves.

On any subregion of `S_d`, every point has some nonfocal class above the
uniform score.  This packages those pointwise witnesses as a single selector.
-/
theorem exists_sourceSdRegion_nonfocal_selector_uniform_simplex
    {X Y : Type*} [MeasurableSpace X] [Fintype Y] [DecidableEq Y]
    (q : X → Y → ℝ) (S : Set X) (z : Y)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hregion :
      ∀ x, x ∈ S →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ w : X → Y,
      ∀ x, x ∈ S → w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x) := by
  classical
  have hex :
      ∀ x, x ∈ S →
        ∃ y : Y, y ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x y := by
    intro x hx
    exact exists_nonfocal_above_uniform_of_sourceSdRegion_simplex
      (q := q) (z := z) (x := x) (hsum x) (hregion x hx)
  let w : X → Y := fun x =>
    if hx : x ∈ S then Classical.choose (hex x hx) else z
  refine ⟨w, ?_⟩
  intro x hx
  simpa [w, hx] using Classical.choose_spec (hex x hx)

/--
Finite measurable selector over an explicit priority list.  If some label in
the list satisfies a measurable predicate, the returned measurable function
chooses one such label.
-/
theorem exists_measurable_selector_from_list
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    (p : X → Y → Prop) (default : Y) :
    ∀ L : List Y,
      (∀ y, y ∈ L → MeasurableSet {x : X | p x y}) →
        ∃ w : X → Y, Measurable w ∧
          ∀ x, (∃ y, y ∈ L ∧ p x y) → p x (w x)
  | [], _ => by
      refine ⟨fun _ => default, measurable_const, ?_⟩
      intro x hx
      rcases hx with ⟨y, hy, _⟩
      simp at hy
  | y :: ys, hp => by
      classical
      have hp_tail : ∀ a, a ∈ ys → MeasurableSet {x : X | p x a} := by
        intro a ha
        exact hp a (by simp [ha])
      rcases exists_measurable_selector_from_list p default ys hp_tail with
        ⟨wTail, hwTail_meas, hwTail⟩
      let w : X → Y := fun x => if p x y then y else wTail x
      have hpy : MeasurableSet {x : X | p x y} := hp y (by simp)
      have hw_meas : Measurable w := by
        exact Measurable.ite hpy measurable_const hwTail_meas
      refine ⟨w, hw_meas, ?_⟩
      intro x hx
      by_cases hxy : p x y
      · simpa [w, hxy] using hxy
      · rcases hx with ⟨a, ha_mem, hpa⟩
        have hex_tail : ∃ a, a ∈ ys ∧ p x a := by
          have ha_cases : a = y ∨ a ∈ ys := by
            simpa using ha_mem
          rcases ha_cases with h_eq | ha_tail
          · subst a
            exact False.elim (hxy hpa)
          · exact ⟨a, ha_tail, hpa⟩
        simpa [w, hxy] using hwTail x hex_tail

/--
Finite-label measurable selector.  This is the measurable counterpart of the
classical selectors above and is used to discharge source-route integrability
obligations.
-/
theorem exists_measurable_selector_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y] (p : X → Y → Prop) (default : Y)
    (hp : ∀ y : Y, MeasurableSet {x : X | p x y})
    (hex : ∀ x, ∃ y : Y, p x y) :
    ∃ w : X → Y, Measurable w ∧ ∀ x, p x (w x) := by
  classical
  rcases exists_measurable_selector_from_list p default
      (Finset.univ.toList)
      (fun y _ => hp y) with
    ⟨w, hw_meas, hw⟩
  refine ⟨w, hw_meas, ?_⟩
  intro x
  exact hw x ⟨Classical.choose (hex x), by
      simp, Classical.choose_spec (hex x)⟩

/--
Measurable below-uniform nonfocal selector for `S_b` source subregions.
-/
theorem exists_measurable_sourceSbRegion_nonfocal_selector_uniform_simplex
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y] [DecidableEq Y]
    (q : X → Y → ℝ) (S : Set X) (z : Y)
    (hq : ∀ a : Y, Measurable fun x : X => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hregion :
      ∀ x, x ∈ S →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ w : X → Y, Measurable w ∧
      ∀ x, x ∈ S → w x ≠ z ∧ q x (w x) < (Fintype.card Y : ℝ)⁻¹ := by
  classical
  let p : X → Y → Prop := fun x y =>
    y ≠ z ∧ q x y < (Fintype.card Y : ℝ)⁻¹
  have hp : ∀ y : Y, MeasurableSet {x : X | p x y} := by
    intro y
    by_cases hy : y ≠ z
    · have hlt :
          MeasurableSet
            ((fun x : X => q x y) ⁻¹'
              Iio ((Fintype.card Y : ℝ)⁻¹)) :=
        (hq y) measurableSet_Iio
      convert hlt using 1
      ext x
      simp [p, hy]
    · have hempty : {x : X | p x y} = ∅ := by
        ext x
        simp [p, hy]
      rw [hempty]
      exact MeasurableSet.empty
  have hexS :
      ∀ x, x ∈ S → ∃ y : Y, p x y := by
    intro x hx
    exact exists_nonfocal_below_uniform_of_sourceSbRegion_simplex
      (q := q) (z := z) (x := x) (hsum x) (hregion x hx)
  rcases exists_measurable_selector_from_list p z
      (Finset.univ.toList)
      (fun y _ => hp y) with
    ⟨w, hw_meas, hw⟩
  refine ⟨w, hw_meas, ?_⟩
  intro x hx
  exact hw x ⟨Classical.choose (hexS x hx), by
      simp, Classical.choose_spec (hexS x hx)⟩

