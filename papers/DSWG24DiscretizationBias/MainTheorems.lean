threshold comparisons used by the balanced `S_d` accounting.
-/
theorem sourceSd_interval_split_exists_measurable_nonfocal_twoRegion_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q qNext : ℝ → Y → ℝ) (z : Y) (c : ℝ) {lo hi : ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hqw_excess_le :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi →
          q xy.1 (w xy) - (Fintype.card Y : ℝ)⁻¹ ≤ c)
    (hc_le_qw :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc lo cut → c ≤ q xy.1 (w xy))
    (hshapeC :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi → ∀ a : Y,
          qNext xy.1 a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w xy then
              q xy.1 (w xy) - ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
            else q xy.1 a)
    (hshapeE :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc lo cut → ∀ a : Y,
          qNext xy.1 a =
            if a = z then 0
            else if a = w xy then q xy.1 (w xy) + q xy.1 z
            else q xy.1 a)
    (hshapeOutside :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∉ Ioc cut hi → xy.1 ∉ Ioc lo cut → ∀ a : Y,
          qNext xy.1 a = q xy.1 a) :
    ∃ cut : ℝ, ∃ w : ℝ × Y → Y,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSd_interval_split_exists_measurable_nonfocal_twoCoordinate_delta_integral_nonpos_uniform_simplex_finite
      μ q z c hlohi hfinite hq hsum hnonneg hregion hqw_excess_le hc_le_qw with
    ⟨cut, w, hcut, hw_meas, hsel, hformula_nonpos⟩
  have hdisj : Disjoint (Ioc cut hi) (Ioc lo cut) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    exact (not_lt_of_ge hx_lo.2) hx_hi.1
  have hzw :
      ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut → z ≠ w xy :=
    Filter.Eventually.of_forall fun xy hxy => (hsel xy hxy).1.symm
  refine ⟨cut, w, hcut, hw_meas, hsel, ?_⟩
  simpa [u] using
    integral_paperConditionalMAE_delta_sourceSd_twoRegion_nonpos
      μ q qNext (Ioc cut hi) (Ioc lo cut) z w u hdisj hzw
      (by simpa [u] using hshapeC cut w hcut hw_meas hsel)
      (hshapeE cut w hcut hw_meas hsel)
      (hshapeOutside cut w hcut hw_meas hsel)
      (by simpa [u] using hformula_nonpos)

/--
Constructive `S_d` interval source transformation.

This endpoint chooses the balancing cut, a measurable feature-level above-
uniform nonfocal selector, and the piecewise transformed posterior `qNext`.  It
proves the resulting integrated classifier-MAE delta is nonpositive under the
threshold comparisons required by the `S_d` aggregate accounting.
-/
theorem sourceSd_interval_split_exists_measurable_feature_qNext_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) (c : ℝ) {lo hi : ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hqw_excess_le :
      ∀ cut (w : ℝ → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi →
          q xy.1 (w xy.1) - (Fintype.card Y : ℝ)⁻¹ ≤ c)
    (hc_le_qw :
      ∀ cut (w : ℝ → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc lo cut → c ≤ q xy.1 (w xy.1)) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) - ((Fintype.card Y : ℝ)⁻¹ - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
          qNext x a =
            if a = z then 0
            else if a = w x then q x (w x) + q x z
            else q x a) ∧
        (∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSd_interval_split_exists_measurable_feature_nonfocal_selector_product_balance_simplex_finite
      μ q z hlohi hfinite hq hsum hnonneg hregion with
    ⟨cut, w, hcut, hw_meas, hsel, hbalance⟩
  let wProd : ℝ × Y → Y := fun xy => w xy.1
  let qNext : ℝ → Y → ℝ := fun x a =>
    if x ∈ Ioc cut hi then
      if a = z then u
      else if a = w x then q x (w x) - (u - q x z)
      else q x a
    else if x ∈ Ioc lo cut then
      if a = z then 0
      else if a = w x then q x (w x) + q x z
      else q x a
    else q x a
  have hle_one : ∀ x y, q x y ≤ 1 := fun x y =>
    posterior_coord_le_one_of_sum_nonneg q x y (hsum x) (hnonneg x)
  have hdisj : Disjoint (Ioc cut hi) (Ioc lo cut) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    exact (not_lt_of_ge hx_lo.2) hx_hi.1
  have hwProd_meas : Measurable wProd := hw_meas.comp measurable_fst
  have hselProd :
      ∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
        wProd xy ≠ z ∧ u < q xy.1 (wProd xy) := by
    intro xy hxy
    simpa [wProd, u] using hsel xy.1 hxy
  have hSdcRegion :
      ∀ x, x ∈ Ioc cut hi →
        x ∈ sourceSdRegion q z u := by
    intro x hx
    simpa [u] using hregion x ⟨hcut.1.trans hx.1.le, hx.2⟩
  have hSdeRegion :
      ∀ x, x ∈ Ioc lo cut →
        x ∈ sourceSdRegion q z u := by
    intro x hx
    simpa [u] using hregion x ⟨hx.1.le, hx.2.trans hcut.2⟩
  have hCInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc cut hi).indicator (fun xy : ℝ × Y =>
            -2 * (u - q xy.1 (wProd xy)) * (u - q xy.1 z)
          ) xy) μ :=
    integrable_fst_preimage_twoCoordinate_delta_toUniform_indicator_finite
      μ q (Ioc cut hi) z wProd u measurableSet_Ioc hq hwProd_meas hnonneg hle_one
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hEInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc lo cut).indicator (fun xy : ℝ × Y =>
            -2 * q xy.1 (wProd xy) * q xy.1 z
          ) xy) μ :=
    integrable_fst_preimage_twoCoordinate_delta_toZero_indicator_finite
      μ q (Ioc lo cut) z wProd measurableSet_Ioc hq hwProd_meas hnonneg hle_one
  have hCUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc cut hi).indicator
            (fun xy : ℝ × Y => u - q xy.1 z) xy) μ :=
    integrable_fst_preimage_score_deficitToUniform_indicator_finite
      μ q (Ioc cut hi) z u measurableSet_Ioc (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hCUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (2 * c) *
            (Prod.fst ⁻¹' Ioc cut hi).indicator
              (fun xy : ℝ × Y => u - q xy.1 z) xy) μ := by
    simpa [smul_eq_mul] using hCUpperBase.const_mul (2 * c)
  have hEUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc lo cut).indicator
            (fun xy : ℝ × Y => q xy.1 z) xy) μ :=
    integrable_fst_preimage_score_indicator_finite
      μ q (Ioc lo cut) z measurableSet_Ioc (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
  have hEUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (-2 * c) *
            (Prod.fst ⁻¹' Ioc lo cut).indicator
              (fun xy : ℝ × Y => q xy.1 z) xy) μ := by
    simpa [smul_eq_mul] using hEUpperBase.const_mul (-2 * c)
  have hformula_nonpos :
      (∫ xy : ℝ × Y,
          (Prod.fst ⁻¹' Ioc cut hi).indicator (fun xy : ℝ × Y =>
            -2 * (u - q xy.1 (wProd xy)) * (u - q xy.1 z)
          ) xy +
          (Prod.fst ⁻¹' Ioc lo cut).indicator (fun xy : ℝ × Y =>
            -2 * q xy.1 (wProd xy) * q xy.1 z
          ) xy ∂μ) ≤ 0 :=
    sourceSd_split_twoCoordinate_delta_integral_nonpos_of_balance_region
      μ q (Ioc cut hi) (Ioc lo cut) z wProd u c
      hCInt hEInt hCUpperInt hEUpperInt
      hSdcRegion hSdeRegion
      (by simpa [wProd, u] using hqw_excess_le cut w hcut hw_meas hsel)
      (by simpa [wProd] using hc_le_qw cut w hcut hw_meas hsel)
      (by simpa [u] using hbalance)
  have hqNextC :
      ∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
        qNext x a =
          if a = z then u
          else if a = w x then q x (w x) - (u - q x z)
          else q x a := by
    intro x hx a
    have hx' : cut < x ∧ x ≤ hi := hx
    simp [qNext, hx']
  have hqNextE :
      ∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
        qNext x a =
          if a = z then 0
          else if a = w x then q x (w x) + q x z
          else q x a := by
    intro x hx a
    have hxC : x ∉ Ioc cut hi := by
      intro hxC
      exact (Set.disjoint_left.mp hdisj) hxC hx
    have hxC' : ¬ (cut < x ∧ x ≤ hi) := by
      simpa using hxC
    have hx' : lo < x ∧ x ≤ cut := hx
    simp [qNext, hxC', hx']
  have hqNextOutside :
      ∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
        qNext x a = q x a := by
    intro x hxC hxE a
    have hxC' : ¬ (cut < x ∧ x ≤ hi) := by
      simpa using hxC
    have hxE' : ¬ (lo < x ∧ x ≤ cut) := by
      simpa using hxE
    simp [qNext, hxC', hxE']
  have hzw :
      ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut → z ≠ wProd xy :=
    Filter.Eventually.of_forall fun xy hxy => (hselProd xy hxy).1.symm
  have hshapeC :
      ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi → ∀ a : Y,
        qNext xy.1 a =
          if a = z then u
          else if a = wProd xy then q xy.1 (wProd xy) - (u - q xy.1 z)
          else q xy.1 a :=
    Filter.Eventually.of_forall fun xy hx => by
      simpa [wProd] using hqNextC xy.1 hx
  have hshapeE :
      ∀ᵐ xy ∂μ, xy.1 ∈ Ioc lo cut → ∀ a : Y,
        qNext xy.1 a =
          if a = z then 0
          else if a = wProd xy then q xy.1 (wProd xy) + q xy.1 z
          else q xy.1 a :=
    Filter.Eventually.of_forall fun xy hx => by
      simpa [wProd] using hqNextE xy.1 hx
  have hshapeOutside :
      ∀ᵐ xy ∂μ, xy.1 ∉ Ioc cut hi → xy.1 ∉ Ioc lo cut → ∀ a : Y,
        qNext xy.1 a = q xy.1 a :=
    Filter.Eventually.of_forall fun xy hxC hxE => hqNextOutside xy.1 hxC hxE
  have hmae_nonpos :
      (∫ xy : ℝ × Y,
          (Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 :=
    integral_paperConditionalMAE_delta_sourceSd_twoRegion_nonpos
      μ q qNext (Ioc cut hi) (Ioc lo cut) z wProd u hdisj hzw
      hshapeC hshapeE hshapeOutside hformula_nonpos
  refine ⟨cut, w, qNext, hcut, hw_meas, ?_, ?_, ?_, ?_, hmae_nonpos⟩
  · simpa [u] using hsel
  · intro x hx a
    simpa [u] using hqNextC x hx a
  · exact hqNextE
  · exact hqNextOutside

/--
Constructive `S_d` interval source transformation as a genuine posterior.

This strengthens the MAE-delta endpoint by proving that the constructed
`qNext` is measurable, preserves the posterior sum pointwise, and remains
nonnegative pointwise.  Thus the `S_d` two-piece construction is a valid
simplex-valued posterior transformation, subject to the same aggregate
threshold comparisons used by the MAE accounting.
-/
theorem sourceSd_interval_split_exists_measurable_feature_qNext_simplex_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) (c : ℝ) {lo hi : ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hqw_excess_le :
      ∀ cut (w : ℝ → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi →
          q xy.1 (w xy.1) - (Fintype.card Y : ℝ)⁻¹ ≤ c)
    (hc_le_qw :
      ∀ cut (w : ℝ → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc lo cut → c ≤ q xy.1 (w xy.1)) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ a : Y, Measurable fun x : ℝ => qNext x a) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) - ((Fintype.card Y : ℝ)⁻¹ - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
          qNext x a =
            if a = z then 0
            else if a = w x then q x (w x) + q x z
            else q x a) ∧
        (∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∀ x : ℝ, (∑ a : Y, qNext x a) = 1) ∧
        (∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSd_interval_split_exists_measurable_feature_qNext_mae_delta_nonpos_uniform_simplex_finite
      μ q z c hlohi hfinite hq hsum hnonneg hregion hqw_excess_le hc_le_qw with
    ⟨cut, w, qNext, hcut, hw_meas, hsel, hshapeC, hshapeE, hshapeOutside,
      hmae_nonpos⟩
  have hselected_meas : Measurable fun x : ℝ => q x (w x) :=
    measurable_selectedScore q w hq hw_meas
  have hqNext_meas : ∀ a : Y, Measurable fun x : ℝ => qNext x a := by
    intro a
    have hCMeas :
        Measurable fun x : ℝ =>
          if a = z then u
          else if a = w x then q x (w x) - (u - q x z)
          else q x a := by
      by_cases haz : a = z
      · simpa [haz] using measurable_const
      · have hset : MeasurableSet {x : ℝ | a = w x} := by
          have hset' : MeasurableSet {x : ℝ | w x = a} := by
            rw [show {x : ℝ | w x = a} = w ⁻¹' {a} by
              ext x
              simp]
            exact hw_meas (measurableSet_singleton a)
          simpa [eq_comm] using hset'
        have hinner :
            Measurable fun x : ℝ =>
              if a = w x then q x (w x) - (u - q x z) else q x a :=
          Measurable.ite hset
            (hselected_meas.sub (measurable_const.sub (hq z))) (hq a)
        simpa [haz] using hinner
    have hEMeas :
        Measurable fun x : ℝ =>
          if a = z then 0
          else if a = w x then q x (w x) + q x z
          else q x a := by
      by_cases haz : a = z
      · simpa [haz] using measurable_const
      · have hset : MeasurableSet {x : ℝ | a = w x} := by
          have hset' : MeasurableSet {x : ℝ | w x = a} := by
            rw [show {x : ℝ | w x = a} = w ⁻¹' {a} by
              ext x
              simp]
            exact hw_meas (measurableSet_singleton a)
          simpa [eq_comm] using hset'
        have hinner :
            Measurable fun x : ℝ =>
              if a = w x then q x (w x) + q x z else q x a :=
          Measurable.ite hset (hselected_meas.add (hq z)) (hq a)
        simpa [haz] using hinner
    have hpiece_meas :
        Measurable fun x : ℝ =>
          if x ∈ Ioc cut hi then
            if a = z then u
            else if a = w x then q x (w x) - (u - q x z)
            else q x a
          else if x ∈ Ioc lo cut then
            if a = z then 0
            else if a = w x then q x (w x) + q x z
            else q x a
          else q x a :=
      Measurable.ite measurableSet_Ioc hCMeas
        (Measurable.ite measurableSet_Ioc hEMeas (hq a))
    have h_eq :
        (fun x : ℝ => qNext x a) =
          fun x : ℝ =>
            if x ∈ Ioc cut hi then
              if a = z then u
              else if a = w x then q x (w x) - (u - q x z)
              else q x a
            else if x ∈ Ioc lo cut then
              if a = z then 0
              else if a = w x then q x (w x) + q x z
              else q x a
            else q x a := by
      funext x
      by_cases hxC : x ∈ Ioc cut hi
      · simp [hxC, u, hshapeC x hxC a]
      · by_cases hxE : x ∈ Ioc lo cut
        · simp [hxC, hxE, hshapeE x hxE a]
        · simp [hxC, hxE, hshapeOutside x hxC hxE a]
    rw [h_eq]
    exact hpiece_meas
  have hsumNext : ∀ x : ℝ, (∑ a : Y, qNext x a) = 1 := by
    intro x
    by_cases hxC : x ∈ Ioc cut hi
    · have hzw : z ≠ w x := (hsel x (Or.inl hxC)).1.symm
      calc
        (∑ a : Y, qNext x a) =
            ∑ a : Y,
              (if a = z then u
              else if a = w x then q x (w x) - (u - q x z)
              else q x a) := by
            refine Finset.sum_congr rfl ?_
            intro a _
            simpa [u] using hshapeC x hxC a
        _ = 1 := by
            simpa using
              posteriorSum_twoCoordinate_raise_focal_to_uniform
                (fun a : Y => q x a) hzw u (hsum x)
    · by_cases hxE : x ∈ Ioc lo cut
      · have hzw : z ≠ w x := (hsel x (Or.inr hxE)).1.symm
        calc
          (∑ a : Y, qNext x a) =
              ∑ a : Y,
                (if a = z then 0
                else if a = w x then q x (w x) + q x z
                else q x a) := by
              refine Finset.sum_congr rfl ?_
              intro a _
              exact hshapeE x hxE a
          _ = 1 := by
              simpa using
                posteriorSum_twoCoordinate_lower_focal_to_zero
                  (fun a : Y => q x a) hzw (hsum x)
      · calc
          (∑ a : Y, qNext x a) = ∑ a : Y, q x a := by
              refine Finset.sum_congr rfl ?_
              intro a _
              exact hshapeOutside x hxC hxE a
          _ = 1 := hsum x
  have hnonnegNext : ∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a := by
    intro x a
    by_cases hxC : x ∈ Ioc cut hi
    · have hzw : z ≠ w x := (hsel x (Or.inl hxC)).1.symm
      have hu_nonneg : 0 ≤ u := by
        simpa [u] using uniform_inverse_card_nonneg (Y := Y)
      have hu_le_qw : u ≤ q x (w x) := (hsel x (Or.inl hxC)).2.le
      have hpoint :
          0 ≤
            (if a = z then u
            else if a = w x then q x (w x) - (u - q x z)
            else q x a) := by
        simpa using
          (posteriorNonneg_twoCoordinate_raise_focal_to_uniform
            (fun a : Y => q x a) hzw u hu_nonneg (hnonneg x) hu_le_qw) a
      rw [hshapeC x hxC a]
      simpa [u] using hpoint
    · by_cases hxE : x ∈ Ioc lo cut
      · have hzw : z ≠ w x := (hsel x (Or.inr hxE)).1.symm
        have hpoint :
            0 ≤
              (if a = z then 0
              else if a = w x then q x (w x) + q x z
              else q x a) := by
          simpa using
            (posteriorNonneg_twoCoordinate_lower_focal_to_zero
              (fun a : Y => q x a) hzw (hnonneg x)) a
        rw [hshapeE x hxE a]
        exact hpoint
      · rw [hshapeOutside x hxC hxE a]
        exact hnonneg x a
  refine ⟨cut, w, qNext, hcut, hw_meas, hqNext_meas, hsel, hshapeC,
    hshapeE, hshapeOutside, hsumNext, hnonnegNext, hmae_nonpos⟩

/--
Multiclass-safe constructive `S_d` interval source transformation.

The upper interval raises the focal score to uniform by subtracting mass from a
selected above-uniform nonfocal coordinate.  The lower interval collapses the
posterior to the selected nonfocal label.  This removes the global threshold
comparisons from the multiclass `S_d` construction while preserving the same
focal balance equation and proving a measurable simplex-valued `qNext` with
nonpositive integrated classifier-MAE delta.
-/
theorem sourceSd_interval_split_exists_measurable_feature_qNext_collapse_simplex_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ a : Y, Measurable fun x : ℝ => qNext x a) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) - ((Fintype.card Y : ℝ)⁻¹ - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
          qNext x a = if a = w x then (1 : ℝ) else 0) ∧
        (∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∀ x : ℝ, (∑ a : Y, qNext x a) = 1) ∧
        (∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a) ∧
        jointFeatureSetScoreMass μ qNext (Ioc cut hi ∪ Ioc lo cut) z =
          jointFeatureSetScoreMass μ q (Ioc cut hi ∪ Ioc lo cut) z ∧
        continuousJointAggregatePosterior μ qNext z =
          continuousJointAggregatePosterior μ q z ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSd_interval_split_exists_measurable_feature_nonfocal_selector_product_balance_simplex_finite
      μ q z hlohi hfinite hq hsum hnonneg hregion with
    ⟨cut, w, hcut, hw_meas, hsel, hbalance⟩
  let wProd : ℝ × Y → Y := fun xy => w xy.1
  let qNext : ℝ → Y → ℝ := fun x a =>
    if x ∈ Ioc cut hi then
      if a = z then u
      else if a = w x then q x (w x) - (u - q x z)
      else q x a
    else if x ∈ Ioc lo cut then
      if a = w x then 1 else 0
    else q x a
  have hle_one : ∀ x y, q x y ≤ 1 := fun x y =>
    posterior_coord_le_one_of_sum_nonneg q x y (hsum x) (hnonneg x)
  have hdisj : Disjoint (Ioc cut hi) (Ioc lo cut) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    exact (not_lt_of_ge hx_lo.2) hx_hi.1
  have hselected_meas : Measurable fun x : ℝ => q x (w x) :=
    measurable_selectedScore q w hq hw_meas
  have hselProd :
      ∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
        wProd xy ≠ z ∧ u < q xy.1 (wProd xy) := by
    intro xy hxy
    simpa [wProd, u] using hsel xy.1 hxy
  have hSdcRegion :
      ∀ x, x ∈ Ioc cut hi →
        x ∈ sourceSdRegion q z u := by
    intro x hx
    simpa [u] using hregion x ⟨hcut.1.trans hx.1.le, hx.2⟩
  have hSdeRegion :
      ∀ x, x ∈ Ioc lo cut →
        x ∈ sourceSdRegion q z u := by
    intro x hx
    simpa [u] using hregion x ⟨hx.1.le, hx.2.trans hcut.2⟩
  have hqNextC :
      ∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
        qNext x a =
          if a = z then u
          else if a = w x then q x (w x) - (u - q x z)
          else q x a := by
    intro x hx a
    have hx' : cut < x ∧ x ≤ hi := hx
    simp [qNext, hx']
  have hqNextE :
      ∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
        qNext x a = if a = w x then (1 : ℝ) else 0 := by
    intro x hx a
    have hxC : x ∉ Ioc cut hi := by
      intro hxC
      exact (Set.disjoint_left.mp hdisj) hxC hx
    have hxC' : ¬ (cut < x ∧ x ≤ hi) := by
      simpa using hxC
    have hx' : lo < x ∧ x ≤ cut := hx
    simp [qNext, hxC', hx']
  have hqNextOutside :
      ∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
        qNext x a = q x a := by
    intro x hxC hxE a
    have hxC' : ¬ (cut < x ∧ x ≤ hi) := by
      simpa using hxC
    have hxE' : ¬ (lo < x ∧ x ≤ cut) := by
      simpa using hxE
    simp [qNext, hxC', hxE']
  have hqNext_meas : ∀ a : Y, Measurable fun x : ℝ => qNext x a := by
    intro a
    have hCMeas :
        Measurable fun x : ℝ =>
          if a = z then u
          else if a = w x then q x (w x) - (u - q x z)
          else q x a := by
      by_cases haz : a = z
      · simpa [haz] using measurable_const
      · have hset : MeasurableSet {x : ℝ | a = w x} := by
          have hset' : MeasurableSet {x : ℝ | w x = a} := by
            rw [show {x : ℝ | w x = a} = w ⁻¹' {a} by
              ext x
              simp]
            exact hw_meas (measurableSet_singleton a)
          simpa [eq_comm] using hset'
        have hinner :
            Measurable fun x : ℝ =>
              if a = w x then q x (w x) - (u - q x z) else q x a :=
          Measurable.ite hset
            (hselected_meas.sub (measurable_const.sub (hq z))) (hq a)
        simpa [haz] using hinner
    have hEMeas :
        Measurable fun x : ℝ => if a = w x then (1 : ℝ) else 0 := by
      have hset : MeasurableSet {x : ℝ | a = w x} := by
        have hset' : MeasurableSet {x : ℝ | w x = a} := by
          rw [show {x : ℝ | w x = a} = w ⁻¹' {a} by
            ext x
            simp]
          exact hw_meas (measurableSet_singleton a)
        simpa [eq_comm] using hset'
      exact Measurable.ite hset measurable_const measurable_const
    have hpiece_meas :
        Measurable fun x : ℝ =>
          if x ∈ Ioc cut hi then
            if a = z then u
            else if a = w x then q x (w x) - (u - q x z)
            else q x a
          else if x ∈ Ioc lo cut then
            if a = w x then (1 : ℝ) else 0
          else q x a :=
      Measurable.ite measurableSet_Ioc hCMeas
        (Measurable.ite measurableSet_Ioc hEMeas (hq a))
    have h_eq :
        (fun x : ℝ => qNext x a) =
          fun x : ℝ =>
            if x ∈ Ioc cut hi then
              if a = z then u
              else if a = w x then q x (w x) - (u - q x z)
              else q x a
            else if x ∈ Ioc lo cut then
              if a = w x then (1 : ℝ) else 0
            else q x a := by
      funext x
      by_cases hxC : x ∈ Ioc cut hi
      · simp [hxC, u, hqNextC x hxC a]
      · by_cases hxE : x ∈ Ioc lo cut
        · simp [hxC, hxE, hqNextE x hxE a]
        · simp [hxC, hxE, hqNextOutside x hxC hxE a]
    rw [h_eq]
    exact hpiece_meas
  have hsumNext : ∀ x : ℝ, (∑ a : Y, qNext x a) = 1 := by
    intro x
    by_cases hxC : x ∈ Ioc cut hi
    · have hzw : z ≠ w x := (hsel x (Or.inl hxC)).1.symm
      calc
        (∑ a : Y, qNext x a) =
            ∑ a : Y,
              (if a = z then u
              else if a = w x then q x (w x) - (u - q x z)
              else q x a) := by
            refine Finset.sum_congr rfl ?_
            intro a _
            exact hqNextC x hxC a
        _ = 1 := by
            simpa using
              posteriorSum_twoCoordinate_raise_focal_to_uniform
                (fun a : Y => q x a) hzw u (hsum x)
    · by_cases hxE : x ∈ Ioc lo cut
      · calc
          (∑ a : Y, qNext x a) =
              ∑ a : Y, (if a = w x then (1 : ℝ) else 0) := by
              refine Finset.sum_congr rfl ?_
              intro a _
              exact hqNextE x hxE a
          _ = 1 := posteriorSum_focal_one_else_zero (w x)
      · calc
          (∑ a : Y, qNext x a) = ∑ a : Y, q x a := by
              refine Finset.sum_congr rfl ?_
              intro a _
              exact hqNextOutside x hxC hxE a
          _ = 1 := hsum x
  have hnonnegNext : ∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a := by
    intro x a
    by_cases hxC : x ∈ Ioc cut hi
    · have hzw : z ≠ w x := (hsel x (Or.inl hxC)).1.symm
      have hu_nonneg : 0 ≤ u := by
        simpa [u] using uniform_inverse_card_nonneg (Y := Y)
      have hu_le_qw : u ≤ q x (w x) := (hsel x (Or.inl hxC)).2.le
      have hpoint :
          0 ≤
            (if a = z then u
            else if a = w x then q x (w x) - (u - q x z)
            else q x a) := by
        simpa using
          (posteriorNonneg_twoCoordinate_raise_focal_to_uniform
            (fun a : Y => q x a) hzw u hu_nonneg (hnonneg x) hu_le_qw) a
      rw [hqNextC x hxC a]
      exact hpoint
    · by_cases hxE : x ∈ Ioc lo cut
      · rw [hqNextE x hxE a]
        exact posteriorNonneg_focal_one_else_zero (w x) a
      · rw [hqNextOutside x hxC hxE a]
        exact hnonneg x a
  have hscoreNext :
      ∀ y : Y, Measurable (fun xy : ℝ × Y => qNext xy.1 y) :=
    fun y => (hqNext_meas y).comp measurable_fst
  have hscoreOrig :
      ∀ y : Y, Measurable (fun xy : ℝ × Y => q xy.1 y) :=
    fun y => (hq y).comp measurable_fst
  have hmaeNextInt :
      Integrable (fun xy : ℝ × Y => Finite.paperConditionalMAE qNext xy.1) μ :=
    integrable_jointConditionalMAE_of_scores_simplex_finite
      μ qNext hscoreNext hsumNext hnonnegNext
  have hmaeOrigInt :
      Integrable (fun xy : ℝ × Y => Finite.paperConditionalMAE q xy.1) μ :=
    integrable_jointConditionalMAE_of_scores_simplex_finite
      μ q hscoreOrig hsum hnonneg
  have hDeltaInt :
      Integrable
        (fun xy : ℝ × Y =>
          Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) μ :=
    hmaeNextInt.sub hmaeOrigInt
  have hCUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc cut hi).indicator
            (fun xy : ℝ × Y => u - q xy.1 z) xy) μ :=
    integrable_fst_preimage_score_deficitToUniform_indicator_finite
      μ q (Ioc cut hi) z u measurableSet_Ioc (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hCUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (2 * (1 - u)) *
            (Prod.fst ⁻¹' Ioc cut hi).indicator
              (fun xy : ℝ × Y => u - q xy.1 z) xy) μ := by
    simpa [smul_eq_mul] using hCUpperBase.const_mul (2 * (1 - u))
  have hEUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc lo cut).indicator
            (fun xy : ℝ × Y => q xy.1 z) xy) μ :=
    integrable_fst_preimage_score_indicator_finite
      μ q (Ioc lo cut) z measurableSet_Ioc (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
  have hEUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (-2 * (1 - u)) *
            (Prod.fst ⁻¹' Ioc lo cut).indicator
              (fun xy : ℝ × Y => q xy.1 z) xy) μ := by
    simpa [smul_eq_mul] using hEUpperBase.const_mul (-2 * (1 - u))
  have hzwC :
      ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi → z ≠ wProd xy :=
    Filter.Eventually.of_forall fun xy hxy => (hselProd xy (Or.inl hxy)).1.symm
  have hshapeC :
      ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi → ∀ a : Y,
        qNext xy.1 a =
          if a = z then u
          else if a = wProd xy then q xy.1 (wProd xy) - (u - q xy.1 z)
          else q xy.1 a :=
    Filter.Eventually.of_forall fun xy hx => by
      simpa [wProd] using hqNextC xy.1 hx
  have hshapeE :
      ∀ᵐ xy ∂μ, xy.1 ∈ Ioc lo cut → ∀ a : Y,
        qNext xy.1 a = if a = wProd xy then (1 : ℝ) else 0 :=
    Filter.Eventually.of_forall fun xy hx => by
      simpa [wProd] using hqNextE xy.1 hx
  have hshapeOutside :
      ∀ᵐ xy ∂μ, xy.1 ∉ Ioc cut hi → xy.1 ∉ Ioc lo cut → ∀ a : Y,
        qNext xy.1 a = q xy.1 a :=
    Filter.Eventually.of_forall fun xy hxC hxE => hqNextOutside xy.1 hxC hxE
  have hmae_nonpos :
      (∫ xy : ℝ × Y,
          (Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
    simpa [u, wProd] using
      integral_paperConditionalMAE_delta_sourceSd_raise_toUniform_collapseNonfocal_twoRegion_nonpos
        μ q qNext (Ioc cut hi) (Ioc lo cut) z wProd u hdisj
        hDeltaInt hCUpperInt hEUpperInt hsum hnonneg
        hSdcRegion hSdeRegion hzwC hshapeC hshapeE hshapeOutside
        (by simpa [u] using hbalance)
  have hbalanceFeature :
      (∫ x, (Ioc lo cut).indicator (fun x : ℝ => q x z) x
          ∂(Measure.map Prod.fst μ)) =
        ∫ x, (Ioc cut hi).indicator (fun x : ℝ => u - q x z) x
          ∂(Measure.map Prod.fst μ) := by
    have hleft :
        (∫ xy : ℝ × Y,
            (Prod.fst ⁻¹' Ioc cut hi).indicator
              (fun xy : ℝ × Y => u - q xy.1 z) xy ∂μ) =
          ∫ x, (Ioc cut hi).indicator (fun x : ℝ => u - q x z) x
            ∂(Measure.map Prod.fst μ) :=
      integral_fst_preimage_indicator_eq_featureMarginal_integral
        μ (Ioc cut hi) (fun x : ℝ => u - q x z)
        measurableSet_Ioc (measurable_const.sub (hq z))
    have hright :
        (∫ xy : ℝ × Y,
            (Prod.fst ⁻¹' Ioc lo cut).indicator
              (fun xy : ℝ × Y => q xy.1 z) xy ∂μ) =
          ∫ x, (Ioc lo cut).indicator (fun x : ℝ => q x z) x
            ∂(Measure.map Prod.fst μ) :=
      integral_fst_preimage_indicator_eq_featureMarginal_integral
        μ (Ioc lo cut) (fun x : ℝ => q x z)
        measurableSet_Ioc (hq z)
    rw [← hright, ← hleft]
    exact hbalance.symm
  have hmassOrig :
      jointFeatureSetScoreMass μ q (Ioc cut hi ∪ Ioc lo cut) z =
        u * jointFeatureSetMass μ (Ioc cut hi) :=
    sourceSd_featureMarginal_balance_preserves_focal_score_mass_simplex_finite
      μ q (Ioc cut hi) (Ioc lo cut) z u
      measurableSet_Ioc measurableSet_Ioc (hq z) hsum hnonneg
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
      hdisj hbalanceFeature
  have hle_oneNext : ∀ x y, qNext x y ≤ 1 := fun x y =>
    posterior_coord_le_one_of_sum_nonneg qNext x y (hsumNext x) (hnonnegNext x)
  have hNextCInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Ioc cut hi).indicator (fun x => qNext x z) xy.1) μ :=
    integrable_jointFeatureSetScoreIndicator_finite
      μ qNext (Ioc cut hi) z measurableSet_Ioc (hqNext_meas z)
      (fun x => hnonnegNext x z) (fun x => hle_oneNext x z)
  have hNextEInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Ioc lo cut).indicator (fun x => qNext x z) xy.1) μ :=
    integrable_jointFeatureSetScoreIndicator_finite
      μ qNext (Ioc lo cut) z measurableSet_Ioc (hqNext_meas z)
      (fun x => hnonnegNext x z) (fun x => hle_oneNext x z)
  have hmass_preserved :
      jointFeatureSetScoreMass μ qNext (Ioc cut hi ∪ Ioc lo cut) z =
        jointFeatureSetScoreMass μ q (Ioc cut hi ∪ Ioc lo cut) z :=
    sourceSd_qNext_preserves_focal_score_mass_of_shapes
      μ q qNext (Ioc cut hi) (Ioc lo cut) z u hdisj hmassOrig
      hNextCInt hNextEInt
      (fun x hx => by simpa using hqNextC x hx z)
      (fun x hx => by
        have hne : z ≠ w x := (hsel x (Or.inr hx)).1.symm
        simpa [hne] using hqNextE x hx z)
  have haggregate_preserved :
      continuousJointAggregatePosterior μ qNext z =
        continuousJointAggregatePosterior μ q z :=
    continuousJointAggregatePosterior_eq_of_split_scoreMass_preserved_simplex_finite
      μ q qNext (Ioc cut hi ∪ Ioc lo cut) z
      (measurableSet_Ioc.union measurableSet_Ioc)
      (hq z) (hqNext_meas z) hsum hnonneg hsumNext hnonnegNext
      hmass_preserved
      (fun x hxR => by
        have hxC : x ∉ Ioc cut hi := fun hxC => hxR (Or.inl hxC)
        have hxE : x ∉ Ioc lo cut := fun hxE => hxR (Or.inr hxE)
        exact hqNextOutside x hxC hxE z)
  refine ⟨cut, w, qNext, hcut, hw_meas, hqNext_meas, ?_, ?_, ?_, ?_,
    hsumNext, hnonnegNext, hmass_preserved, haggregate_preserved,
    hmae_nonpos⟩
  · simpa [u] using hsel
  · intro x hx a
    simpa [u] using hqNextC x hx a
  · intro x hx a
    exact hqNextE x hx a
  · exact hqNextOutside

/--
Binary specialization of the constructive `S_d` interval source transformation.

For `|Y| = 2`, the uniform score is `1/2`.  Taking the aggregate threshold
`c = 1/2` discharges the two `S_d` threshold side conditions: the chosen
nonfocal coordinate is above uniform, and its excess above uniform is at most
uniform because posterior coordinates are at most one.
-/
theorem sourceSd_interval_split_exists_measurable_feature_qNext_simplex_mae_delta_nonpos_binary_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ}
    (hcard_two : Fintype.card Y = 2)
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ a : Y, Measurable fun x : ℝ => qNext x a) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi ∪ Ioc lo cut →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) ∧
        (∀ x : ℝ, x ∈ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) - ((Fintype.card Y : ℝ)⁻¹ - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ Ioc lo cut → ∀ a : Y,
          qNext x a =
            if a = z then 0
            else if a = w x then q x (w x) + q x z
            else q x a) ∧
        (∀ x : ℝ, x ∉ Ioc cut hi → x ∉ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∀ x : ℝ, (∑ a : Y, qNext x a) = 1) ∧
        (∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  refine
    sourceSd_interval_split_exists_measurable_feature_qNext_simplex_mae_delta_nonpos_uniform_simplex_finite
      μ q z u hlohi hfinite hq hsum hnonneg hregion ?_ ?_
  · intro cut w hcut hw_meas hsel
    filter_upwards with xy hxy
    have hle_one :
        q xy.1 (w xy.1) ≤ 1 :=
      posterior_coord_le_one_of_sum_nonneg q xy.1 (w xy.1)
        (hsum xy.1) (hnonneg xy.1)
    have hu_eq : u = (1 / 2 : ℝ) := by
      norm_num [u, hcard_two]
    nlinarith
  · intro cut w hcut hw_meas hsel
    filter_upwards with xy hxy
    exact (hsel xy.1 (Or.inr hxy)).2.le

/--
When only the worst-case focal regions `S_a`, `S_c`, and `S_e` remain, the
focal aggregate-posterior score mass is exactly `mass(S_a) + u * mass(S_c)`.
-/
theorem jointFeatureSetScoreMass_sourceSaScSe_sum_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (z : Y) (uniformScore : ℝ)
    (hqz : Measurable fun x : X => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z) (hle_one : ∀ x, q x z ≤ 1)
    (hzero_lt_uniform : 0 < uniformScore) (huniform_lt_one : uniformScore < 1) :
    jointFeatureSetScoreMass μ q
        (sourceSaRegion q z ∪
          (sourceScRegion q z uniformScore ∪ sourceSeRegion q z)) z =
      jointFeatureSetMass μ (sourceSaRegion q z) +
        uniformScore * jointFeatureSetMass μ (sourceScRegion q z uniformScore) := by
  classical
  let Sa : Set X := sourceSaRegion q z
  let Sc : Set X := sourceScRegion q z uniformScore
  let Se : Set X := sourceSeRegion q z
  have hSaSc : Disjoint Sa Sc :=
    sourceSaRegion_disjoint_sourceScRegion huniform_lt_one
  have hSaSe : Disjoint Sa Se := sourceSaRegion_disjoint_sourceSeRegion
  have hScSe : Disjoint Sc Se :=
    sourceScRegion_disjoint_sourceSeRegion hzero_lt_uniform
  have hSaScSe : Disjoint Sa (Sc ∪ Se) := by
    rw [Set.disjoint_left]
    intro x hSa hx
    rcases hx with hSc | hSe
    · exact Set.disjoint_left.mp hSaSc hSa hSc
    · exact Set.disjoint_left.mp hSaSe hSa hSe
  have hSaMeas : MeasurableSet Sa := measurableSet_sourceSaRegion hqz
  have hScMeas : MeasurableSet Sc := measurableSet_sourceScRegion hqz
  have hSeMeas : MeasurableSet Se := measurableSet_sourceSeRegion hqz
  have hSaInt :
      Integrable (fun xy : X × Y => Sa.indicator (fun x => q x z) xy.1) μ :=
    integrable_jointFeatureSetScoreIndicator_finite
      μ q Sa z hSaMeas hqz hnonneg hle_one
  have hScInt :
      Integrable (fun xy : X × Y => Sc.indicator (fun x => q x z) xy.1) μ :=
    integrable_jointFeatureSetScoreIndicator_finite
      μ q Sc z hScMeas hqz hnonneg hle_one
  have hSeInt :
      Integrable (fun xy : X × Y => Se.indicator (fun x => q x z) xy.1) μ :=
    integrable_jointFeatureSetScoreIndicator_finite
      μ q Se z hSeMeas hqz hnonneg hle_one
  have hScSeInt :
      Integrable
        (fun xy : X × Y => (Sc ∪ Se).indicator (fun x => q x z) xy.1) μ := by
    have hpoint : ∀ xy : X × Y,
        (Sc ∪ Se).indicator (fun x : X => q x z) xy.1 =
          Sc.indicator (fun x : X => q x z) xy.1 +
            Se.indicator (fun x : X => q x z) xy.1 := by
      intro xy
      by_cases hScx : xy.1 ∈ Sc
      · have hnotSe : xy.1 ∉ Se := Set.disjoint_left.mp hScSe hScx
        simp [Set.indicator, hScx, hnotSe]
      · by_cases hSex : xy.1 ∈ Se <;> simp [Set.indicator, hScx, hSex]
    refine hScInt.add hSeInt |>.congr ?_
    exact Filter.Eventually.of_forall (fun xy => (hpoint xy).symm)
  have hScSeScore :
      jointFeatureSetScoreMass μ q (Sc ∪ Se) z =
        jointFeatureSetScoreMass μ q Sc z +
          jointFeatureSetScoreMass μ q Se z :=
    jointFeatureSetScoreMass_union_of_disjoint
      μ q Sc Se z hScSe hScInt hSeInt
  have hAllScore :
      jointFeatureSetScoreMass μ q (Sa ∪ (Sc ∪ Se)) z =
        jointFeatureSetScoreMass μ q Sa z +
          jointFeatureSetScoreMass μ q (Sc ∪ Se) z :=
    jointFeatureSetScoreMass_union_of_disjoint
      μ q Sa (Sc ∪ Se) z hSaScSe hSaInt hScSeInt
  calc
    jointFeatureSetScoreMass μ q (sourceSaRegion q z ∪
        (sourceScRegion q z uniformScore ∪ sourceSeRegion q z)) z =
        jointFeatureSetScoreMass μ q (Sa ∪ (Sc ∪ Se)) z := by rfl
    _ = jointFeatureSetScoreMass μ q Sa z +
          jointFeatureSetScoreMass μ q (Sc ∪ Se) z := hAllScore
    _ = jointFeatureSetScoreMass μ q Sa z +
          (jointFeatureSetScoreMass μ q Sc z +
            jointFeatureSetScoreMass μ q Se z) := by
          rw [hScSeScore]
    _ = jointFeatureSetMass μ Sa + uniformScore * jointFeatureSetMass μ Sc := by
          rw [jointFeatureSetScoreMass_sourceSaRegion,
            jointFeatureSetScoreMass_sourceScRegion,
            jointFeatureSetScoreMass_sourceSeRegion]
          ring

theorem continuousJointAggregatePosterior_sourceSaScSe_sum_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [Fintype Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (z : Y) (uniformScore : ℝ)
    (hqz : Measurable fun x : X => q x z)
    (hnonneg : ∀ x, 0 ≤ q x z) (hle_one : ∀ x, q x z ≤ 1)
    (hzero_lt_uniform : 0 < uniformScore) (huniform_lt_one : uniformScore < 1)
    (hcover :
      sourceSaRegion q z ∪
          (sourceScRegion q z uniformScore ∪ sourceSeRegion q z) =
        univ) :
    continuousJointAggregatePosterior μ q z =
      jointFeatureSetMass μ (sourceSaRegion q z) +
        uniformScore * jointFeatureSetMass μ (sourceScRegion q z uniformScore) := by
  rw [← jointFeatureSetScoreMass_univ_eq_jointAggregatePosterior]
  rw [← hcover]
  exact jointFeatureSetScoreMass_sourceSaScSe_sum_finite
    μ q z uniformScore hqz hnonneg hle_one hzero_lt_uniform huniform_lt_one

