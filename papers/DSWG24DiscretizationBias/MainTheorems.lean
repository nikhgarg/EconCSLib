/--
Coordinate-pullback constructive `S_b` source transformation.

This packages the easier general-feature route used in the formalization:
push the joint law through a measurable real coordinate, apply the real-line
subset construction, and pull the constructed posterior back along the
coordinate.  The resulting feature-space posterior preserves the focal
aggregate posterior and has nonpositive integrated paper-MAE delta.
-/
theorem sourceSb_coordinate_subset_interval_split_exists_feature_qNext_collapse_simplex_mae_delta_nonpos_uniform_simplex_finite
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSingletonClass Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    {r : X → ℝ} (hr : Measurable r)
    [NoAtoms (Measure.map r (Measure.map Prod.fst μ))]
    (q : X → Y → ℝ) (qCoord : ℝ → Y → ℝ) (z : Y)
    {lo hi : ℝ} {S : Set ℝ}
    (hlohi : lo ≤ hi) (hS : MeasurableSet S)
    (hqCoord : ∀ a : Y, Measurable fun t : ℝ => qCoord t a)
    (hfactor : ∀ x a, q x a = qCoord (r x) a)
    (hsumCoord : ∀ t, (∑ a : Y, qCoord t a) = 1)
    (hnonnegCoord : ∀ t y, 0 ≤ qCoord t y)
    (hregion :
      ∀ t, t ∈ S → t ∈ Icc lo hi →
        t ∈ sourceSbRegion qCoord z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, ∃ wCoord : ℝ → Y, ∃ qNextCoord : ℝ → Y → ℝ,
      ∃ qNext : X → Y → ℝ,
        cut ∈ Icc lo hi ∧ Measurable wCoord ∧
          (∀ a : Y, Measurable fun t : ℝ => qNextCoord t a) ∧
          (∀ a : Y, Measurable fun x : X => qNext x a) ∧
          (∀ x : X, (∑ a : Y, qNext x a) = 1) ∧
          (∀ x : X, ∀ a : Y, 0 ≤ qNext x a) ∧
          (∀ x : X, ∀ a : Y, qNext x a = qNextCoord (r x) a) ∧
          (∀ x : X, r x ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
            wCoord (r x) ≠ z ∧
              qCoord (r x) (wCoord (r x)) < (Fintype.card Y : ℝ)⁻¹) ∧
          (∀ x : X, r x ∈ S ∩ Ioc cut hi → ∀ a : Y,
            qNext x a = if a = z then (1 : ℝ) else 0) ∧
          (∀ x : X, r x ∈ S ∩ Ioc lo cut → ∀ a : Y,
            qNext x a =
              if a = z then (Fintype.card Y : ℝ)⁻¹
              else if a = wCoord (r x) then
                qCoord (r x) (wCoord (r x)) +
                  (qCoord (r x) z - (Fintype.card Y : ℝ)⁻¹)
              else qCoord (r x) a) ∧
          (∀ x : X, r x ∉ S ∩ Ioc cut hi → r x ∉ S ∩ Ioc lo cut →
            ∀ a : Y, qNext x a = q x a) ∧
          jointFeatureSetScoreMass μ qNext
