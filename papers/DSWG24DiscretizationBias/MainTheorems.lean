/--
Theorem 1(iii), joint prior-reference form from finite-score calibration.

This closes the paper's calibration-to-consistency step for classifiers whose
realized score levels can be represented by a finite score partition: level-set
calibration implies that the aggregate posterior equals the true prior, and
the continuous MAE bound therefore applies with the prior as reference.
-/
theorem paper_theorem1iii_continuous_joint_prior_bias_le_mae_of_finiteScoreCalibration
    {X Y C : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    [Fintype C] [DecidableEq C]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (argmaxRule : X → Y)
    (score : Y → C → ℝ) (bin : X → Y → C) (y : Y)
    (hind : Integrable
      (fun xy : X × Y => if argmaxRule xy.1 = y then (1 : ℝ) else 0) μ)
    (hq : Integrable (fun xy : X × Y => q xy.1 y) μ)
    (hmae : Integrable (fun xy : X × Y => Finite.paperConditionalMAE q xy.1) μ)
    (hargmax : ∀ x a, q x a ≤ q x (argmaxRule x))
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a)
    (hle_one : ∀ x a, q x a ≤ 1)
    (hrepr : ∀ x y, q x y = score y (bin x y))
    (hlabelInt : ∀ y c,
      Integrable
        (fun xy : X × Y => if bin xy.1 y = c then
          if xy.2 = y then (1 : ℝ) else 0
        else 0) μ)
    (hmassInt : ∀ y c,
      Integrable
        (fun xy : X × Y => if bin xy.1 y = c then (1 : ℝ) else 0) μ)
    (hcal : FiniteScoreCalibration μ score bin) :
    continuousJointPriorBias μ argmaxRule y ≤ continuousJointClassifierMAE μ q := by
  classical
  let qJoint : X × Y → Y → ℝ := fun xy a => q xy.1 a
  let ruleJoint : X × Y → Y := fun xy => argmaxRule xy.1
  have hpref :
      (fun a : Y => continuousJointPrior μ a) y =
        continuousAggregatePosterior μ qJoint y := by
    simpa [continuousJointAggregatePosterior, continuousAggregatePosterior, qJoint] using
      (continuousJointPrior_eq_jointAggregatePosterior_of_finiteScoreCalibration
        μ q score bin hrepr hlabelInt hmassInt hcal y)
  have hbound :
      continuousBias μ ruleJoint (fun a : Y => continuousJointPrior μ a) y ≤
        continuousClassifierMAE μ qJoint :=
    paper_theorem1iii_continuous_reference_bias_le_mae_of_consistency
      μ qJoint ruleJoint (fun a : Y => continuousJointPrior μ a) y
      hind hq hmae
      (fun xy a => hargmax xy.1 a)
      (fun xy => hsum xy.1)
      (fun xy a => hnonneg xy.1 a)
      (fun xy a => hle_one xy.1 a)
      hpref
  simpa [continuousBias, continuousMarginalLabelShare, continuousJointPriorBias,
    continuousJointDecisionShare, continuousJointPrior, continuousJointClassifierMAE,
    continuousClassifierMAE, qJoint, ruleJoint] using hbound

/--
Finite product-law finite-score calibration wrapper.  Measurable bin fibers
discharge the level-set label and mass integrability obligations; measurable
bounded score coordinates discharge the decision and score integrability
obligations, while the MAE integrand is supplied by a bounded-measurable
certificate.
-/
theorem paper_theorem1iii_continuous_joint_prior_bias_le_mae_of_finiteScoreCalibration_finite
    {X Y C : Type*} [MeasurableSpace X] [MeasurableSpace Y] [MeasurableSpace C]
    [MeasurableSingletonClass Y] [MeasurableSingletonClass C]
    [Fintype Y] [DecidableEq Y] [Fintype C] [DecidableEq C]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (argmaxRule : X → Y)
    (score : Y → C → ℝ) (bin : X → Y → C) (y : Y)
    (hrule : Measurable argmaxRule)
    (hmaeMeas :
      AEStronglyMeasurable
        (fun xy : X × Y => Finite.paperConditionalMAE q xy.1) μ)
    (CMAE : ℝ)
    (hmaeBound :
      ∀ᵐ xy ∂μ, ‖Finite.paperConditionalMAE q xy.1‖ ≤ CMAE)
    (hargmax : ∀ x a, q x a ≤ q x (argmaxRule x))
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a)
    (hle_one : ∀ x a, q x a ≤ 1)
    (hrepr : ∀ x y, q x y = score y (bin x y))
    (hscore : ∀ y : Y, Measurable (fun xy : X × Y => q xy.1 y))
    (hbin : ∀ y : Y, Measurable (fun xy : X × Y => bin xy.1 y))
    (hcal : FiniteScoreCalibration μ score bin) :
    continuousJointPriorBias μ argmaxRule y ≤ continuousJointClassifierMAE μ q :=
  paper_theorem1iii_continuous_joint_prior_bias_le_mae_of_finiteScoreCalibration
    μ q argmaxRule score bin y
    (integrable_jointDecisionIndicator_product_finite μ argmaxRule y hrule)
    (integrable_jointScore_of_bounds_finite μ q y
      (hscore y).aestronglyMeasurable (fun x => hnonneg x y)
      (fun x => hle_one x y))
    (integrable_continuousJointClassifierMAE_of_ae_bound
      μ q CMAE hmaeMeas hmaeBound)
    hargmax hsum hnonneg hle_one hrepr
    (fun y c => integrable_finiteScoreLabelFiber_product_finite μ bin y c (hbin y))
    (fun y c => integrable_finiteScoreMassFiber_product_finite μ bin y c (hbin y))
    hcal

/--
Finite product-law finite-score calibration wrapper with the MAE
integrability obligations discharged from measurable, `[0,1]`-bounded score
coordinates.
-/
theorem paper_theorem1iii_continuous_joint_prior_bias_le_mae_of_finiteScoreCalibration_finite_scoreBounded
    {X Y C : Type*} [MeasurableSpace X] [MeasurableSpace Y] [MeasurableSpace C]
