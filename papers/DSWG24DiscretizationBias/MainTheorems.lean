/--
Conditional-expectation calibration gives the paper's calibration-to-prior
bridge directly: the class prior equals the aggregate posterior.
-/
theorem continuousJointPrior_eq_jointAggregatePosterior_of_condExpCalibration
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (y : Y)
    (hscore : Measurable (fun xy : X × Y => q xy.1 y))
    (htrim : SigmaFinite (μ.trim (Measurable.comap_le hscore)))
    (hcal : ConditionalExpectationCalibration μ q) :
    continuousJointPrior μ y = continuousJointAggregatePosterior μ q y := by
  classical
  let f : X × Y → ℝ := fun xy => if xy.2 = y then (1 : ℝ) else 0
  have hhm : scoreSigma q y ≤ ‹MeasurableSpace (X × Y)› :=
    Measurable.comap_le hscore
  haveI : SigmaFinite (μ.trim hhm) := by
    exact htrim
  calc
    continuousJointPrior μ y = ∫ xy, f xy ∂μ := by
      rfl
    _ = ∫ xy, μ[f | scoreSigma q y] xy ∂μ := by
      exact (integral_condExp hhm).symm
    _ = continuousJointAggregatePosterior μ q y := by
      simpa [continuousJointAggregatePosterior] using
        integral_congr_ae (hcal y)

