/--
Abstract aggregate-delta accounting for a balanced source split.

This is the algebraic core used when a locally increasing move is paired with a
locally decreasing move.  The functions `A` and `B` are the two pulled-back MAE
deltas; `p` and `r` are the balanced focal-score masses.  If `r` and `p` have
equal integral, the `B` side is bounded by `2u * r`, the `A` side by
`-2(1-u) * p`, and `u <= 1/2`, then the total integrated delta is nonpositive.
-/
theorem balanced_twoCoordinate_delta_integral_nonpos_of_balance
    {Ω : Type*} [MeasurableSpace Ω] (μ : Measure Ω)
    (A B p r : Ω → ℝ) (u : ℝ)
    (hAInt : Integrable A μ) (hBInt : Integrable B μ)
    (hAUpperInt : Integrable (fun ω => (-2 * (1 - u)) * p ω) μ)
    (hBUpperInt : Integrable (fun ω => (2 * u) * r ω) μ)
    (hA_le : A ≤ᵐ[μ] fun ω => (-2 * (1 - u)) * p ω)
    (hB_le : B ≤ᵐ[μ] fun ω => (2 * u) * r ω)
    (hbalance : (∫ ω, r ω ∂μ) = ∫ ω, p ω ∂μ)
    (hp_nonneg : 0 ≤ ∫ ω, p ω ∂μ)
    (hu_le_half : u ≤ (1 / 2 : ℝ)) :
    (∫ ω, A ω + B ω ∂μ) ≤ 0 := by
  have hA_integral_le :
      (∫ ω, A ω ∂μ) ≤ ∫ ω, (-2 * (1 - u)) * p ω ∂μ :=
    integral_mono_ae hAInt hAUpperInt hA_le
  have hB_integral_le :
      (∫ ω, B ω ∂μ) ≤ ∫ ω, (2 * u) * r ω ∂μ :=
    integral_mono_ae hBInt hBUpperInt hB_le
  have hsum_le :
      (∫ ω, A ω + B ω ∂μ) ≤
        (∫ ω, (-2 * (1 - u)) * p ω ∂μ) +
          ∫ ω, (2 * u) * r ω ∂μ := by
    rw [integral_add hAInt hBInt]
    linarith
  have hupper_eq :
      (∫ ω, (-2 * (1 - u)) * p ω ∂μ) +
          ∫ ω, (2 * u) * r ω ∂μ =
        (4 * u - 2) * ∫ ω, p ω ∂μ := by
    rw [integral_const_mul, integral_const_mul, hbalance]
    ring
  have hcoef_nonpos : 4 * u - 2 ≤ 0 := by
    nlinarith
  have hupper_nonpos :
      (∫ ω, (-2 * (1 - u)) * p ω ∂μ) +
          ∫ ω, (2 * u) * r ω ∂μ ≤ 0 := by
    rw [hupper_eq]
    exact mul_nonpos_of_nonpos_of_nonneg hcoef_nonpos hp_nonneg
  exact hsum_le.trans hupper_nonpos

/--
Aggregate MAE accounting for the source proof's balanced `S_b` split.

The part sent to `S_a` has nonpositive MAE delta; the part sent to `S_c` may
increase MAE pointwise.  If the focal balance equation holds and the affected
nonfocal coordinate is at most the uniform score on both pieces, the total
integrated two-coordinate delta is still nonpositive for `u <= 1/2`.
-/
theorem sourceSb_split_twoCoordinate_delta_integral_nonpos_of_balance
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (Sba Sbc : Set X) (z : Y) (w : X × Y → Y) (u : ℝ)
    (hAInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
            -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
          ) xy) μ)
    (hBInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
          ) xy) μ)
    (hAUpperInt :
      Integrable
        (fun xy : X × Y =>
          (-2 * (1 - u)) *
            (Prod.fst ⁻¹' Sba).indicator
              (fun xy : X × Y => 1 - q xy.1 z) xy) μ)
    (hBUpperInt :
      Integrable
        (fun xy : X × Y =>
          (2 * u) *
            (Prod.fst ⁻¹' Sbc).indicator
              (fun xy : X × Y => q xy.1 z - u) xy) μ)
    (hqw_le_u :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sba ∪ Sbc → q xy.1 (w xy) ≤ u)
    (hqw_nonneg :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sbc → 0 ≤ q xy.1 (w xy))
    (hz_le_one :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sba → q xy.1 z ≤ 1)
    (hu_le_qz :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sbc → u ≤ q xy.1 z)
    (hbalance :
      (∫ xy : X × Y,
          (Prod.fst ⁻¹' Sbc).indicator
            (fun xy : X × Y => q xy.1 z - u) xy ∂μ) =
        ∫ xy : X × Y,
          (Prod.fst ⁻¹' Sba).indicator
            (fun xy : X × Y => 1 - q xy.1 z) xy ∂μ)
    (hSbaMass_nonneg :
      0 ≤ ∫ xy : X × Y,
        (Prod.fst ⁻¹' Sba).indicator
          (fun xy : X × Y => 1 - q xy.1 z) xy ∂μ)
    (hu_le_half : u ≤ (1 / 2 : ℝ)) :
    (∫ xy : X × Y,
        (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
          -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
        ) xy +
        (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
          -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
        ) xy ∂μ) ≤ 0 := by
  classical
  let A : X × Y → ℝ := fun xy =>
    (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
      -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
    ) xy
  let B : X × Y → ℝ := fun xy =>
    (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
      -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
    ) xy
  let p : X × Y → ℝ := fun xy =>
    (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y => 1 - q xy.1 z) xy
  let r : X × Y → ℝ := fun xy =>
    (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y => q xy.1 z - u) xy
  have hA_le : A ≤ᵐ[μ] fun xy => (-2 * (1 - u)) * p xy := by
    filter_upwards [hqw_le_u, hz_le_one] with xy hqw hz1
    by_cases hx : xy.1 ∈ Sba
    · have hqw_xy : q xy.1 (w xy) ≤ u := hqw (Or.inl hx)
      have hz_nonneg : 0 ≤ 1 - q xy.1 z := sub_nonneg.mpr (hz1 hx)
      have hbase : (1 - u) ≤ 1 - q xy.1 (w xy) := by linarith
      have hprod :
          (1 - u) * (1 - q xy.1 z) ≤
            (1 - q xy.1 (w xy)) * (1 - q xy.1 z) :=
        mul_le_mul_of_nonneg_right hbase hz_nonneg
      have hmul :
          (-2 : ℝ) * ((1 - q xy.1 (w xy)) * (1 - q xy.1 z)) ≤
            (-2 : ℝ) * ((1 - u) * (1 - q xy.1 z)) :=
        mul_le_mul_of_nonpos_left hprod (by norm_num)
      simpa [A, p, Set.indicator, hx, mul_assoc] using hmul
    · simp [A, p, Set.indicator, hx]
  have hB_le : B ≤ᵐ[μ] fun xy => (2 * u) * r xy := by
    filter_upwards [hqw_le_u, hqw_nonneg, hu_le_qz] with xy hqw hqwnonneg hzge
    by_cases hx : xy.1 ∈ Sbc
    · have hqw_xy : q xy.1 (w xy) ≤ u := hqw (Or.inr hx)
      have hqw_nonneg_xy : 0 ≤ q xy.1 (w xy) := hqwnonneg hx
      have hqz_ge_xy : u ≤ q xy.1 z := hzge hx
      have hfactor_le : u - q xy.1 (w xy) ≤ u := by linarith
      have hfactor_nonneg : 0 ≤ q xy.1 z - u := sub_nonneg.mpr hqz_ge_xy
      have hprod :
          (u - q xy.1 (w xy)) * (q xy.1 z - u) ≤
            u * (q xy.1 z - u) :=
        mul_le_mul_of_nonneg_right hfactor_le hfactor_nonneg
      have hmul :
          2 * ((u - q xy.1 (w xy)) * (q xy.1 z - u)) ≤
            2 * (u * (q xy.1 z - u)) :=
        mul_le_mul_of_nonneg_left hprod (by norm_num)
      have hrewrite :
          -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) =
            2 * ((u - q xy.1 (w xy)) * (q xy.1 z - u)) := by
        ring
      have hrewrite_upper :
          (2 * u) * (q xy.1 z - u) =
            2 * (u * (q xy.1 z - u)) := by
        ring
      calc
        B xy =
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) := by
              simp [B, Set.indicator, hx]
        _ = 2 * ((u - q xy.1 (w xy)) * (q xy.1 z - u)) := hrewrite
        _ ≤ 2 * (u * (q xy.1 z - u)) := hmul
        _ = (2 * u) * r xy := by
              simp [r, Set.indicator, hx]
              ring
    · simp [B, r, Set.indicator, hx]
  exact
    balanced_twoCoordinate_delta_integral_nonpos_of_balance
      μ A B p r u hAInt hBInt hAUpperInt hBUpperInt
      hA_le hB_le hbalance hSbaMass_nonneg hu_le_half

/--
Uniform-score specialization of the balanced `S_b` aggregate MAE accounting.
For the paper's `u = 1 / |Y|`, the half-bound follows from `1 < |Y|`.
-/
theorem sourceSb_split_twoCoordinate_delta_integral_nonpos_of_balance_uniform
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (Sba Sbc : Set X) (z : Y) (w : X × Y → Y)
    (hcard_gt_one : 1 < Fintype.card Y)
    (hAInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
            -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
          ) xy) μ)
    (hBInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
            -2 * ((Fintype.card Y : ℝ)⁻¹ - q xy.1 (w xy)) *
              ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
          ) xy) μ)
    (hAUpperInt :
      Integrable
        (fun xy : X × Y =>
          (-2 * (1 - (Fintype.card Y : ℝ)⁻¹)) *
            (Prod.fst ⁻¹' Sba).indicator
              (fun xy : X × Y => 1 - q xy.1 z) xy) μ)
    (hBUpperInt :
      Integrable
        (fun xy : X × Y =>
          (2 * (Fintype.card Y : ℝ)⁻¹) *
            (Prod.fst ⁻¹' Sbc).indicator
              (fun xy : X × Y => q xy.1 z - (Fintype.card Y : ℝ)⁻¹) xy) μ)
    (hqw_le_u :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sba ∪ Sbc → q xy.1 (w xy) ≤ (Fintype.card Y : ℝ)⁻¹)
    (hqw_nonneg :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sbc → 0 ≤ q xy.1 (w xy))
    (hz_le_one :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sba → q xy.1 z ≤ 1)
    (hu_le_qz :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sbc → (Fintype.card Y : ℝ)⁻¹ ≤ q xy.1 z)
    (hbalance :
      (∫ xy : X × Y,
          (Prod.fst ⁻¹' Sbc).indicator
            (fun xy : X × Y => q xy.1 z - (Fintype.card Y : ℝ)⁻¹) xy ∂μ) =
        ∫ xy : X × Y,
          (Prod.fst ⁻¹' Sba).indicator
            (fun xy : X × Y => 1 - q xy.1 z) xy ∂μ)
    (hSbaMass_nonneg :
      0 ≤ ∫ xy : X × Y,
        (Prod.fst ⁻¹' Sba).indicator
          (fun xy : X × Y => 1 - q xy.1 z) xy ∂μ) :
    (∫ xy : X × Y,
        (Prod.fst ⁻¹' Sba).indicator (fun xy : X × Y =>
          -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
        ) xy +
        (Prod.fst ⁻¹' Sbc).indicator (fun xy : X × Y =>
          -2 * ((Fintype.card Y : ℝ)⁻¹ - q xy.1 (w xy)) *
            ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
        ) xy ∂μ) ≤ 0 :=
  sourceSb_split_twoCoordinate_delta_integral_nonpos_of_balance
    μ q Sba Sbc z w (Fintype.card Y : ℝ)⁻¹
    hAInt hBInt hAUpperInt hBUpperInt hqw_le_u hqw_nonneg
    hz_le_one hu_le_qz hbalance hSbaMass_nonneg
    (uniform_inverse_card_le_half_of_one_lt_card hcard_gt_one)

/--
Abstract aggregate-delta accounting for a balanced split with cancelling
coefficients.  This covers the `S_d` source split after the two pieces are
matched using a common nonfocal threshold `c`.
-/
theorem balanced_twoCoordinate_delta_integral_nonpos_of_canceling_balance
    {Ω : Type*} [MeasurableSpace Ω] (μ : Measure Ω)
    (A B p r : Ω → ℝ) (c : ℝ)
    (hAInt : Integrable A μ) (hBInt : Integrable B μ)
    (hAUpperInt : Integrable (fun ω => (2 * c) * p ω) μ)
    (hBUpperInt : Integrable (fun ω => (-2 * c) * r ω) μ)
    (hA_le : A ≤ᵐ[μ] fun ω => (2 * c) * p ω)
    (hB_le : B ≤ᵐ[μ] fun ω => (-2 * c) * r ω)
    (hbalance : (∫ ω, p ω ∂μ) = ∫ ω, r ω ∂μ) :
    (∫ ω, A ω + B ω ∂μ) ≤ 0 := by
  have hA_integral_le :
      (∫ ω, A ω ∂μ) ≤ ∫ ω, (2 * c) * p ω ∂μ :=
    integral_mono_ae hAInt hAUpperInt hA_le
  have hB_integral_le :
      (∫ ω, B ω ∂μ) ≤ ∫ ω, (-2 * c) * r ω ∂μ :=
    integral_mono_ae hBInt hBUpperInt hB_le
  have hsum_le :
      (∫ ω, A ω + B ω ∂μ) ≤
        (∫ ω, (2 * c) * p ω ∂μ) +
          ∫ ω, (-2 * c) * r ω ∂μ := by
    rw [integral_add hAInt hBInt]
    linarith
  have hupper_eq :
      (∫ ω, (2 * c) * p ω ∂μ) +
          ∫ ω, (-2 * c) * r ω ∂μ = 0 := by
    rw [integral_const_mul, integral_const_mul, hbalance]
    ring
  exact hsum_le.trans (le_of_eq hupper_eq)

/--
Aggregate MAE accounting for the source proof's balanced `S_d` split.

The part sent to `S_c` can increase MAE pointwise, while the part sent to `S_e`
decreases it.  The balance equation gives a nonpositive total delta once the
chosen nonfocal coordinate on the `S_d -> S_c` side has excess above uniform at
most `c`, and the coordinate on the `S_d -> S_e` side has score at least `c`.
-/
theorem sourceSd_split_twoCoordinate_delta_integral_nonpos_of_balance
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (Sdc Sde : Set X) (z : Y) (w : X × Y → Y) (u c : ℝ)
    (hCInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sdc).indicator (fun xy : X × Y =>
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
          ) xy) μ)
    (hEInt :
      Integrable
        (fun xy : X × Y =>
          (Prod.fst ⁻¹' Sde).indicator (fun xy : X × Y =>
            -2 * q xy.1 (w xy) * q xy.1 z
          ) xy) μ)
    (hCUpperInt :
      Integrable
        (fun xy : X × Y =>
          (2 * c) *
            (Prod.fst ⁻¹' Sdc).indicator
              (fun xy : X × Y => u - q xy.1 z) xy) μ)
    (hEUpperInt :
      Integrable
        (fun xy : X × Y =>
          (-2 * c) *
            (Prod.fst ⁻¹' Sde).indicator
              (fun xy : X × Y => q xy.1 z) xy) μ)
    (hqw_excess_le :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sdc → q xy.1 (w xy) - u ≤ c)
    (hc_le_qw :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sde → c ≤ q xy.1 (w xy))
    (hqz_le_u :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sdc → q xy.1 z ≤ u)
    (hqz_nonneg :
      ∀ᵐ xy ∂μ, xy.1 ∈ Sde → 0 ≤ q xy.1 z)
    (hbalance :
      (∫ xy : X × Y,
          (Prod.fst ⁻¹' Sdc).indicator
            (fun xy : X × Y => u - q xy.1 z) xy ∂μ) =
        ∫ xy : X × Y,
          (Prod.fst ⁻¹' Sde).indicator
            (fun xy : X × Y => q xy.1 z) xy ∂μ) :
    (∫ xy : X × Y,
        (Prod.fst ⁻¹' Sdc).indicator (fun xy : X × Y =>
          -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
        ) xy +
        (Prod.fst ⁻¹' Sde).indicator (fun xy : X × Y =>
          -2 * q xy.1 (w xy) * q xy.1 z
        ) xy ∂μ) ≤ 0 := by
  classical
  let C : X × Y → ℝ := fun xy =>
    (Prod.fst ⁻¹' Sdc).indicator (fun xy : X × Y =>
      -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
    ) xy
  let E : X × Y → ℝ := fun xy =>
    (Prod.fst ⁻¹' Sde).indicator (fun xy : X × Y =>
      -2 * q xy.1 (w xy) * q xy.1 z
    ) xy
  let p : X × Y → ℝ := fun xy =>
    (Prod.fst ⁻¹' Sdc).indicator (fun xy : X × Y => u - q xy.1 z) xy
  let r : X × Y → ℝ := fun xy =>
    (Prod.fst ⁻¹' Sde).indicator (fun xy : X × Y => q xy.1 z) xy
  have hC_le : C ≤ᵐ[μ] fun xy => (2 * c) * p xy := by
    filter_upwards [hqw_excess_le, hqz_le_u] with xy hqw hqz
    by_cases hx : xy.1 ∈ Sdc
    · have hfactor_le : q xy.1 (w xy) - u ≤ c := hqw hx
      have hfactor_nonneg : 0 ≤ u - q xy.1 z := sub_nonneg.mpr (hqz hx)
      have hprod :
          (q xy.1 (w xy) - u) * (u - q xy.1 z) ≤
            c * (u - q xy.1 z) :=
        mul_le_mul_of_nonneg_right hfactor_le hfactor_nonneg
      have hmul :
          2 * ((q xy.1 (w xy) - u) * (u - q xy.1 z)) ≤
            2 * (c * (u - q xy.1 z)) :=
        mul_le_mul_of_nonneg_left hprod (by norm_num)
      have hrewrite :
          -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) =
            2 * ((q xy.1 (w xy) - u) * (u - q xy.1 z)) := by
        ring
      calc
        C xy =
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z) := by
              simp [C, Set.indicator, hx]
        _ = 2 * ((q xy.1 (w xy) - u) * (u - q xy.1 z)) := hrewrite
        _ ≤ 2 * (c * (u - q xy.1 z)) := hmul
        _ = (2 * c) * p xy := by
              simp [p, Set.indicator, hx]
              ring
    · simp [C, p, Set.indicator, hx]
  have hE_le : E ≤ᵐ[μ] fun xy => (-2 * c) * r xy := by
    filter_upwards [hc_le_qw, hqz_nonneg] with xy hqw hqz
    by_cases hx : xy.1 ∈ Sde
    · have hfactor_le : c * q xy.1 z ≤ q xy.1 (w xy) * q xy.1 z :=
        mul_le_mul_of_nonneg_right (hqw hx) (hqz hx)
      have hmul :
          (-2 : ℝ) * (q xy.1 (w xy) * q xy.1 z) ≤
            (-2 : ℝ) * (c * q xy.1 z) :=
        mul_le_mul_of_nonpos_left hfactor_le (by norm_num)
      calc
        E xy = -2 * q xy.1 (w xy) * q xy.1 z := by
          simp [E, Set.indicator, hx]
        _ = (-2 : ℝ) * (q xy.1 (w xy) * q xy.1 z) := by ring
        _ ≤ (-2 : ℝ) * (c * q xy.1 z) := hmul
        _ = (-2 * c) * r xy := by
              simp [r, Set.indicator, hx]
              ring
    · simp [E, r, Set.indicator, hx]
  exact
    balanced_twoCoordinate_delta_integral_nonpos_of_canceling_balance
      μ C E p r c hCInt hEInt hCUpperInt hEUpperInt
      hC_le hE_le hbalance

/--
Feature-level wrapper for the `S_b -> S_a` MAE-nonincreasing move.
-/
theorem paperConditionalMAE_twoCoordinate_raise_focal_to_one_le
    {X Y : Type*} [Fintype Y] [DecidableEq Y]
    (q qNext : X → Y → ℝ) (x xNext : X) {z w : Y} (hzw : z ≠ w)
    (hshape : ∀ a : Y,
      qNext xNext a =
        if a = z then 1 else if a = w then q x w - (1 - q x z) else q x a)
    (hw_le_one : q x w ≤ 1) (hz_le_one : q x z ≤ 1) :
    Finite.paperConditionalMAE qNext xNext ≤ Finite.paperConditionalMAE q x := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then 1 else if a = w then q x w - (1 - q x z) else q x a
  have hsum_next :
      (∑ a : Y, qNext xNext a * (1 - qNext xNext a)) =
        ∑ a : Y, q' a * (1 - q' a) := by
    refine Finset.sum_congr rfl ?_
    intro a _
    simp [q', hshape a]
  have hle :
      (∑ a : Y, q' a * (1 - q' a)) ≤
        ∑ a : Y, q x a * (1 - q x a) :=
    posteriorMAESum_twoCoordinate_raise_focal_to_one_le
      (fun a : Y => q x a) hzw hw_le_one hz_le_one
  unfold Finite.paperConditionalMAE
  rwa [hsum_next]

/--
Feature-level wrapper for a MAE-nonincreasing lowering-to-uniform move.
-/
theorem paperConditionalMAE_twoCoordinate_lower_focal_to_uniform_le
    {X Y : Type*} [Fintype Y] [DecidableEq Y]
    (q qNext : X → Y → ℝ) (x xNext : X) {z w : Y} (hzw : z ≠ w) (u : ℝ)
    (hshape : ∀ a : Y,
      qNext xNext a =
        if a = z then u else if a = w then q x w + (q x z - u) else q x a)
    (hprod_nonneg : 0 ≤ (u - q x w) * (u - q x z)) :
    Finite.paperConditionalMAE qNext xNext ≤ Finite.paperConditionalMAE q x := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then u else if a = w then q x w + (q x z - u) else q x a
  have hsum_next :
      (∑ a : Y, qNext xNext a * (1 - qNext xNext a)) =
        ∑ a : Y, q' a * (1 - q' a) := by
    refine Finset.sum_congr rfl ?_
    intro a _
    simp [q', hshape a]
  have hle :
      (∑ a : Y, q' a * (1 - q' a)) ≤
        ∑ a : Y, q x a * (1 - q x a) :=
    posteriorMAESum_twoCoordinate_lower_focal_to_uniform_le
      (fun a : Y => q x a) hzw u hprod_nonneg
  unfold Finite.paperConditionalMAE
  rwa [hsum_next]

