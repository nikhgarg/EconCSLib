`c`.
-/
theorem sourceSd_interval_split_exists_nonfocal_twoCoordinate_delta_integral_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) (c : ℝ) {lo hi : ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hqz : Measurable fun x : ℝ => q x z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hCInt :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        Integrable
          (fun xy : ℝ × Y =>
            (Prod.fst ⁻¹' Ioc cut hi).indicator (fun xy : ℝ × Y =>
              -2 * ((Fintype.card Y : ℝ)⁻¹ - q xy.1 (w xy)) *
                ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
            ) xy) μ)
    (hEInt :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        Integrable
          (fun xy : ℝ × Y =>
            (Prod.fst ⁻¹' Ioc lo cut).indicator (fun xy : ℝ × Y =>
              -2 * q xy.1 (w xy) * q xy.1 z
            ) xy) μ)
    (hCUpperInt :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        Integrable
          (fun xy : ℝ × Y =>
            (2 * c) *
              (Prod.fst ⁻¹' Ioc cut hi).indicator
                (fun xy : ℝ × Y =>
                  (Fintype.card Y : ℝ)⁻¹ - q xy.1 z) xy) μ)
    (hEUpperInt :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        Integrable
          (fun xy : ℝ × Y =>
            (-2 * c) *
              (Prod.fst ⁻¹' Ioc lo cut).indicator
                (fun xy : ℝ × Y => q xy.1 z) xy) μ)
    (hqw_excess_le :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc cut hi →
          q xy.1 (w xy) - (Fintype.card Y : ℝ)⁻¹ ≤ c)
    (hc_le_qw :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ Ioc lo cut → c ≤ q xy.1 (w xy)) :
    ∃ cut : ℝ, ∃ w : ℝ × Y → Y,
      cut ∈ Icc lo hi ∧
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) ∧
        (∫ xy : ℝ × Y,
            (Prod.fst ⁻¹' Ioc cut hi).indicator (fun xy : ℝ × Y =>
              -2 * ((Fintype.card Y : ℝ)⁻¹ - q xy.1 (w xy)) *
                ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
            ) xy +
            (Prod.fst ⁻¹' Ioc lo cut).indicator (fun xy : ℝ × Y =>
              -2 * q xy.1 (w xy) * q xy.1 z
            ) xy ∂μ) ≤ 0 := by
  classical
  rcases sourceSd_interval_split_exists_nonfocal_selector_product_balance_simplex_finite
      μ q z hlohi hfinite hqz hsum hnonneg hregion with
    ⟨cut, w, hcut, hsel, hbalance⟩
  have hSdcRegion :
      ∀ x, x ∈ Ioc cut hi →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹ := by
    intro x hx
    exact hregion x ⟨hcut.1.trans hx.1.le, hx.2⟩
  have hSdeRegion :
      ∀ x, x ∈ Ioc lo cut →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹ := by
    intro x hx
    exact hregion x ⟨hx.1.le, hx.2.trans hcut.2⟩
  refine ⟨cut, w, hcut, hsel, ?_⟩
  exact
    sourceSd_split_twoCoordinate_delta_integral_nonpos_of_balance_region
      μ q (Ioc cut hi) (Ioc lo cut) z w
      (Fintype.card Y : ℝ)⁻¹ c
      (hCInt cut w hcut hsel) (hEInt cut w hcut hsel)
      (hCUpperInt cut w hcut hsel) (hEUpperInt cut w hcut hsel)
      hSdcRegion hSdeRegion
      (hqw_excess_le cut w hcut hsel) (hc_le_qw cut w hcut hsel)
