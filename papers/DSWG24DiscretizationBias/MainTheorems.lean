    hmaeNextInt.sub hmaeOrigInt
  have hCUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator
            (fun xy : ℝ × Y => u - q xy.1 z) xy) μ :=
    integrable_fst_preimage_score_deficitToUniform_indicator_finite
