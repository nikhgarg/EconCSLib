              if a = w x then q x (w x) - (u - q x z) else q x a :=
          Measurable.ite hset
            (hselected_meas.sub (measurable_const.sub (hq z))) (hq a)
        simpa [haz] using hinner
    have hEMeas :
        Measurable fun x : ℝ => if a = w x then (1 : ℝ) else 0 := by
      have hset : MeasurableSet {x : ℝ | a = w x} := by
        have hset' : MeasurableSet {x : ℝ | w x = a} := by
          rw [show {x : ℝ | w x = a} = w ⁻¹' {a} by
            ext x
            simp]
          exact hw_meas (measurableSet_singleton a)
        simpa [eq_comm] using hset'
      exact Measurable.ite hset measurable_const measurable_const
    have hpiece_meas :
        Measurable fun x : ℝ =>
          if x ∈ S ∩ Ioc cut hi then
            if a = z then u
            else if a = w x then q x (w x) - (u - q x z)
            else q x a
          else if x ∈ S ∩ Ioc lo cut then
            if a = w x then (1 : ℝ) else 0
          else q x a :=
      Measurable.ite (hS.inter measurableSet_Ioc) hCMeas
        (Measurable.ite (hS.inter measurableSet_Ioc) hEMeas (hq a))
    have h_eq :
        (fun x : ℝ => qNext x a) =
          fun x : ℝ =>
            if x ∈ S ∩ Ioc cut hi then
              if a = z then u
              else if a = w x then q x (w x) - (u - q x z)
              else q x a
            else if x ∈ S ∩ Ioc lo cut then
              if a = w x then (1 : ℝ) else 0
            else q x a := by
      funext x
      by_cases hxC : x ∈ S ∩ Ioc cut hi
      · simp [hxC, u, hqNextC x hxC a]
      · by_cases hxE : x ∈ S ∩ Ioc lo cut
        · simp [hxC, hxE, hqNextE x hxE a]
        · simp [hxC, hxE, hqNextOutside x hxC hxE a]
    rw [h_eq]
    exact hpiece_meas
  have hsumNext : ∀ x : ℝ, (∑ a : Y, qNext x a) = 1 := by
    intro x
    by_cases hxC : x ∈ S ∩ Ioc cut hi
    · have hzw : z ≠ w x := (hsel x (Or.inl hxC)).1.symm
      calc
        (∑ a : Y, qNext x a) =
