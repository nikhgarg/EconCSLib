  paper_theorem1iii_continuous_joint_prior_bias_le_mae_of_condExpKernelCalibration_finite
    μ q argmaxRule y hrule
    (aestronglyMeasurable_jointConditionalMAE_of_scores μ q hscore)
    (Fintype.card Y : ℝ)
    (eventually_norm_jointConditionalMAE_le_card_of_bounds μ q hnonneg hle_one)
    hargmax hsum hnonneg hle_one hscore hcal

theorem paper_theorem1iii_continuous_joint_prior_bias_le_mae_of_condExpKernelCalibration_finite_simplex
    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
