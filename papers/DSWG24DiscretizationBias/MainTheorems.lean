    {X Y : Type*} [MeasurableSpace X] [MeasurableSpace Y]
    [MeasurableSingletonClass Y] [Fintype Y] [DecidableEq Y]
    (μ : Measure X) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (argmaxRule : X → Y)
    (pref : Y → ℝ) (y : Y)
    (hrule : Measurable argmaxRule)
    (hmaeMeas :
      AEStronglyMeasurable (fun x : X => Finite.paperConditionalMAE q x) μ)
    (CMAE : ℝ)
    (hmaeBound : ∀ᵐ x ∂μ, ‖Finite.paperConditionalMAE q x‖ ≤ CMAE)
    (hargmax : IsArgmaxRule q argmaxRule)
    (hsimplex : PosteriorSimplex q)
    (hscore : ∀ y : Y, Measurable (fun x : X => q x y))
    (hconsistent : BayesianConsistent μ q pref) :
    continuousBias μ argmaxRule pref y ≤ continuousClassifierMAE μ q :=
  paper_theorem1iii_continuous_reference_bias_le_mae μ q argmaxRule pref y
    (integrable_featureDecisionIndicator_measurable_finite μ argmaxRule y hrule)
    (integrable_featureScore_of_bounds_finite μ q y
      (hscore y).aestronglyMeasurable
      (fun x => hsimplex.2.1 x y) (fun x => hsimplex.2.2 x y))
    (integrable_continuousClassifierMAE_of_ae_bound
      μ q CMAE hmaeMeas hmaeBound)
    hargmax hsimplex hconsistent

