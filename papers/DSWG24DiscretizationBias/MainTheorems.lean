  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSb_subset_interval_split_exists_measurable_feature_qNext_mae_delta_nonpos_uniform_simplex_finite
      μ q z hcard_gt_one hlohi hfinite hS hq hsum hnonneg hregion with
    ⟨cut, w, qNext, hcut, hw_meas, hsel, hshapeA, hshapeB, hshapeOutside,
      hmae_nonpos⟩
  have hselected_meas : Measurable fun x : ℝ => q x (w x) :=
    measurable_selectedScore q w hq hw_meas
  have hqNext_meas : ∀ a : Y, Measurable fun x : ℝ => qNext x a := by
    intro a
    have hAMeas :
        Measurable fun x : ℝ =>
          if a = z then 1
          else if a = w x then q x (w x) - (1 - q x z)
          else q x a := by
      by_cases haz : a = z
      · simpa [haz] using measurable_const
      · have hset : MeasurableSet {x : ℝ | a = w x} := by
          have hset' : MeasurableSet {x : ℝ | w x = a} := by
            rw [show {x : ℝ | w x = a} = w ⁻¹' {a} by
              ext x
              simp]
            exact hw_meas (measurableSet_singleton a)
          simpa [eq_comm] using hset'
        have hinner :
            Measurable fun x : ℝ =>
              if a = w x then q x (w x) - (1 - q x z) else q x a :=
          Measurable.ite hset
            (hselected_meas.sub (measurable_const.sub (hq z))) (hq a)
        simpa [haz] using hinner
    have hBMeas :
        Measurable fun x : ℝ =>
          if a = z then u
          else if a = w x then q x (w x) + (q x z - u)
          else q x a := by
      by_cases haz : a = z
      · simpa [haz] using measurable_const
      · have hset : MeasurableSet {x : ℝ | a = w x} := by
          have hset' : MeasurableSet {x : ℝ | w x = a} := by
            rw [show {x : ℝ | w x = a} = w ⁻¹' {a} by
              ext x
              simp]
            exact hw_meas (measurableSet_singleton a)
          simpa [eq_comm] using hset'
        have hinner :
            Measurable fun x : ℝ =>
              if a = w x then q x (w x) + (q x z - u) else q x a :=
          Measurable.ite hset
            (hselected_meas.add ((hq z).sub measurable_const)) (hq a)
        simpa [haz] using hinner
    have hpiece_meas :
        Measurable fun x : ℝ =>
          if x ∈ S ∩ Ioc cut hi then
            if a = z then 1
            else if a = w x then q x (w x) - (1 - q x z)
            else q x a
          else if x ∈ S ∩ Ioc lo cut then
            if a = z then u
            else if a = w x then q x (w x) + (q x z - u)
            else q x a
          else q x a :=
      Measurable.ite (hS.inter measurableSet_Ioc) hAMeas
        (Measurable.ite (hS.inter measurableSet_Ioc) hBMeas (hq a))
    have h_eq :
        (fun x : ℝ => qNext x a) =
          fun x : ℝ =>
            if x ∈ S ∩ Ioc cut hi then
              if a = z then 1
              else if a = w x then q x (w x) - (1 - q x z)
              else q x a
            else if x ∈ S ∩ Ioc lo cut then
              if a = z then u
              else if a = w x then q x (w x) + (q x z - u)
              else q x a
            else q x a := by
      funext x
      by_cases hxA : x ∈ S ∩ Ioc cut hi
      · simp [hxA, hshapeA x hxA a]
      · by_cases hxB : x ∈ S ∩ Ioc lo cut
        · simp [hxA, hxB, u, hshapeB x hxB a]
        · simp [hxA, hxB, hshapeOutside x hxA hxB a]
    rw [h_eq]
    exact hpiece_meas
  have hsumNext : ∀ x : ℝ, (∑ a : Y, qNext x a) = 1 := by
    intro x
    by_cases hxA : x ∈ S ∩ Ioc cut hi
    · have hzw : z ≠ w x := (hsel x (Or.inl hxA)).1.symm
      calc
        (∑ a : Y, qNext x a) =
            ∑ a : Y,
              (if a = z then 1
              else if a = w x then q x (w x) - (1 - q x z)
              else q x a) := by
            refine Finset.sum_congr rfl ?_
            intro a _
            exact hshapeA x hxA a
        _ = 1 := by
            simpa using
              posteriorSum_twoCoordinate_raise_focal_to_one
                (fun a : Y => q x a) hzw (hsum x)
    · by_cases hxB : x ∈ S ∩ Ioc lo cut
      · have hzw : z ≠ w x := (hsel x (Or.inr hxB)).1.symm
        calc
          (∑ a : Y, qNext x a) =
              ∑ a : Y,
                (if a = z then u
                else if a = w x then q x (w x) + (q x z - u)
                else q x a) := by
              refine Finset.sum_congr rfl ?_
              intro a _
              simpa [u] using hshapeB x hxB a
          _ = 1 := by
              simpa using
                posteriorSum_twoCoordinate_lower_focal_to_uniform
                  (fun a : Y => q x a) hzw u (hsum x)
      · calc
          (∑ a : Y, qNext x a) = ∑ a : Y, q x a := by
              refine Finset.sum_congr rfl ?_
              intro a _
              exact hshapeOutside x hxA hxB a
          _ = 1 := hsum x
  have hnonnegNext : ∀ x : ℝ, ∀ a : Y, 0 ≤ qNext x a := by
    intro x a
    by_cases hxA : x ∈ S ∩ Ioc cut hi
    · have hzw : z ≠ w x := (hsel x (Or.inl hxA)).1.symm
      have hpoint :
          0 ≤
            (if a = z then 1
            else if a = w x then q x (w x) - (1 - q x z)
            else q x a) := by
        simpa using
          (posteriorNonneg_twoCoordinate_raise_focal_to_one
            (fun a : Y => q x a) hzw (hnonneg x)
            (hdeficit_le cut w hcut hw_meas hsel x hxA)) a
      rw [hshapeA x hxA a]
      exact hpoint
    · by_cases hxB : x ∈ S ∩ Ioc lo cut
      · have hzw : z ≠ w x := (hsel x (Or.inr hxB)).1.symm
        have hu_nonneg : 0 ≤ u := by
          simpa [u] using uniform_inverse_card_nonneg (Y := Y)
        have hu_le_qz : u ≤ q x z := by
          have hxRegion : x ∈ sourceSbRegion q z u := by
            simpa [u] using hregion x hxB.1 ⟨hxB.2.1.le, hxB.2.2.trans hcut.2⟩
          exact hxRegion.1.le
        have hpoint :
            0 ≤
              (if a = z then u
              else if a = w x then q x (w x) + (q x z - u)
              else q x a) := by
          simpa using
            (posteriorNonneg_twoCoordinate_lower_focal_to_uniform
              (fun a : Y => q x a) hzw u hu_nonneg (hnonneg x) hu_le_qz) a
        rw [hshapeB x hxB a]
        simpa [u] using hpoint
      · rw [hshapeOutside x hxA hxB a]
        exact hnonneg x a
  refine ⟨cut, w, qNext, hcut, hw_meas, hqNext_meas, hsel, ?_, ?_, ?_,
    hsumNext, hnonnegNext, hmae_nonpos⟩
  · exact hshapeA
  · intro x hx a
    simpa [u] using hshapeB x hx a
  · exact hshapeOutside

/--
Constructive `S_d` subset interval source transformation.

This endpoint chooses a subset-sweep cut, a measurable feature-level
above-uniform nonfocal selector, and the piecewise transformed posterior
`qNext`.  It proves the resulting integrated classifier-MAE delta is
nonpositive on the arbitrary measurable source subregion `S`, subject to the
same threshold comparisons required by the `S_d` aggregate accounting.
-/
theorem sourceSd_subset_interval_split_exists_measurable_feature_qNext_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) (c : ℝ) {lo hi : ℝ} {S : Set ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hS : MeasurableSet S)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ S → x ∈ Icc lo hi →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hqw_excess_le :
      ∀ cut (w : ℝ → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ x : ℝ, x ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc cut hi →
          q xy.1 (w xy.1) - (Fintype.card Y : ℝ)⁻¹ ≤ c)
    (hc_le_qw :
      ∀ cut (w : ℝ → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ x : ℝ, x ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc lo cut → c ≤ q xy.1 (w xy.1)) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ x : ℝ, x ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
          w x ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q x (w x)) ∧
        (∀ x : ℝ, x ∈ S ∩ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) - ((Fintype.card Y : ℝ)⁻¹ - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ S ∩ Ioc lo cut → ∀ a : Y,
          qNext x a =
            if a = z then 0
            else if a = w x then q x (w x) + q x z
            else q x a) ∧
        (∀ x : ℝ, x ∉ S ∩ Ioc cut hi → x ∉ S ∩ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSd_subset_interval_split_exists_measurable_feature_nonfocal_selector_product_balance_simplex_finite
      μ q z hlohi hfinite hS hq hsum hnonneg hregion with
    ⟨cut, w, hcut, hw_meas, hsel, hbalance⟩
  let wProd : ℝ × Y → Y := fun xy => w xy.1
  let qNext : ℝ → Y → ℝ := fun x a =>
    if x ∈ S ∩ Ioc cut hi then
      if a = z then u
      else if a = w x then q x (w x) - (u - q x z)
      else q x a
    else if x ∈ S ∩ Ioc lo cut then
      if a = z then 0
      else if a = w x then q x (w x) + q x z
      else q x a
    else q x a
  have hle_one : ∀ x y, q x y ≤ 1 := fun x y =>
    posterior_coord_le_one_of_sum_nonneg q x y (hsum x) (hnonneg x)
  have hdisj : Disjoint (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    exact (not_lt_of_ge hx_lo.2.2) hx_hi.2.1
  have hwProd_meas : Measurable wProd := hw_meas.comp measurable_fst
  have hselProd :
      ∀ xy : ℝ × Y,
        xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
          wProd xy ≠ z ∧ u < q xy.1 (wProd xy) := by
    intro xy hxy
    simpa [wProd, u] using hsel xy.1 hxy
  have hSdcRegion :
      ∀ x, x ∈ S ∩ Ioc cut hi →
        x ∈ sourceSdRegion q z u := by
    intro x hx
    simpa [u] using hregion x hx.1 ⟨hcut.1.trans hx.2.1.le, hx.2.2⟩
  have hSdeRegion :
      ∀ x, x ∈ S ∩ Ioc lo cut →
        x ∈ sourceSdRegion q z u := by
    intro x hx
    simpa [u] using hregion x hx.1 ⟨hx.2.1.le, hx.2.2.trans hcut.2⟩
  have hCInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator (fun xy : ℝ × Y =>
            -2 * (u - q xy.1 (wProd xy)) * (u - q xy.1 z)
          ) xy) μ :=
    integrable_fst_preimage_twoCoordinate_delta_toUniform_indicator_finite
      μ q (S ∩ Ioc cut hi) z wProd u (hS.inter measurableSet_Ioc)
      hq hwProd_meas hnonneg hle_one
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hEInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' (S ∩ Ioc lo cut)).indicator (fun xy : ℝ × Y =>
            -2 * q xy.1 (wProd xy) * q xy.1 z
          ) xy) μ :=
    integrable_fst_preimage_twoCoordinate_delta_toZero_indicator_finite
      μ q (S ∩ Ioc lo cut) z wProd (hS.inter measurableSet_Ioc)
      hq hwProd_meas hnonneg hle_one
  have hCUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator
            (fun xy : ℝ × Y => u - q xy.1 z) xy) μ :=
    integrable_fst_preimage_score_deficitToUniform_indicator_finite
      μ q (S ∩ Ioc cut hi) z u (hS.inter measurableSet_Ioc) (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hCUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (2 * c) *
            (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator
              (fun xy : ℝ × Y => u - q xy.1 z) xy) μ := by
    simpa [smul_eq_mul] using hCUpperBase.const_mul (2 * c)
  have hEUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' (S ∩ Ioc lo cut)).indicator
            (fun xy : ℝ × Y => q xy.1 z) xy) μ :=
    integrable_fst_preimage_score_indicator_finite
      μ q (S ∩ Ioc lo cut) z (hS.inter measurableSet_Ioc) (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
  have hEUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (-2 * c) *
            (Prod.fst ⁻¹' (S ∩ Ioc lo cut)).indicator
              (fun xy : ℝ × Y => q xy.1 z) xy) μ := by
    simpa [smul_eq_mul] using hEUpperBase.const_mul (-2 * c)
  have hformula_nonpos :
      (∫ xy : ℝ × Y,
          (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator (fun xy : ℝ × Y =>
            -2 * (u - q xy.1 (wProd xy)) * (u - q xy.1 z)
          ) xy +
          (Prod.fst ⁻¹' (S ∩ Ioc lo cut)).indicator (fun xy : ℝ × Y =>
            -2 * q xy.1 (wProd xy) * q xy.1 z
          ) xy ∂μ) ≤ 0 :=
    sourceSd_split_twoCoordinate_delta_integral_nonpos_of_balance_region
      μ q (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) z wProd u c
      hCInt hEInt hCUpperInt hEUpperInt
      hSdcRegion hSdeRegion
      (by simpa [wProd, u] using hqw_excess_le cut w hcut hw_meas hsel)
      (by simpa [wProd] using hc_le_qw cut w hcut hw_meas hsel)
      (by simpa [u] using hbalance)
  have hqNextC :
      ∀ x : ℝ, x ∈ S ∩ Ioc cut hi → ∀ a : Y,
        qNext x a =
          if a = z then u
          else if a = w x then q x (w x) - (u - q x z)
          else q x a := by
    intro x hx a
    have hxC : x ∈ S ∧ cut < x ∧ x ≤ hi :=
      ⟨hx.1, hx.2.1, hx.2.2⟩
    simp [qNext, hxC]
  have hqNextE :
      ∀ x : ℝ, x ∈ S ∩ Ioc lo cut → ∀ a : Y,
        qNext x a =
          if a = z then 0
          else if a = w x then q x (w x) + q x z
          else q x a := by
    intro x hx a
    have hxE : x ∈ S ∧ lo < x ∧ x ≤ cut :=
      ⟨hx.1, hx.2.1, hx.2.2⟩
    simp [qNext, hxE]
  have hqNextOutside :
      ∀ x : ℝ, x ∉ S ∩ Ioc cut hi → x ∉ S ∩ Ioc lo cut → ∀ a : Y,
        qNext x a = q x a := by
    intro x hxC hxE a
    have hxC' : ¬ (x ∈ S ∧ cut < x ∧ x ≤ hi) := by
      intro h
      exact hxC ⟨h.1, ⟨h.2.1, h.2.2⟩⟩
    have hxE' : ¬ (x ∈ S ∧ lo < x ∧ x ≤ cut) := by
      intro h
      exact hxE ⟨h.1, ⟨h.2.1, h.2.2⟩⟩
    simp [qNext, hxC', hxE']
  have hzw :
      ∀ᵐ xy ∂μ,
        xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) → z ≠ wProd xy :=
    Filter.Eventually.of_forall fun xy hxy => (hselProd xy hxy).1.symm
  have hshapeC :
      ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc cut hi → ∀ a : Y,
        qNext xy.1 a =
          if a = z then u
          else if a = wProd xy then q xy.1 (wProd xy) - (u - q xy.1 z)
          else q xy.1 a :=
    Filter.Eventually.of_forall fun xy hx => by
      simpa [wProd] using hqNextC xy.1 hx
  have hshapeE :
      ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc lo cut → ∀ a : Y,
        qNext xy.1 a =
          if a = z then 0
          else if a = wProd xy then q xy.1 (wProd xy) + q xy.1 z
          else q xy.1 a :=
    Filter.Eventually.of_forall fun xy hx => by
      simpa [wProd] using hqNextE xy.1 hx
  have hshapeOutside :
      ∀ᵐ xy ∂μ, xy.1 ∉ S ∩ Ioc cut hi → xy.1 ∉ S ∩ Ioc lo cut →
        ∀ a : Y, qNext xy.1 a = q xy.1 a :=
    Filter.Eventually.of_forall fun xy hxC hxE => hqNextOutside xy.1 hxC hxE
  have hmae_nonpos :
      (∫ xy : ℝ × Y,
          (Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
    simpa [u, wProd] using
      integral_paperConditionalMAE_delta_sourceSd_twoRegion_nonpos
        μ q qNext (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) z wProd u hdisj
        hzw hshapeC hshapeE hshapeOutside hformula_nonpos
  refine ⟨cut, w, qNext, hcut, hw_meas, ?_, ?_, ?_, ?_, hmae_nonpos⟩
  · simpa [u] using hsel
  · intro x hx a
    simpa [u] using hqNextC x hx a
  · intro x hx a
    simpa [u] using hqNextE x hx a
  · exact hqNextOutside

/--
Constructive `S_d` subset interval source transformation as a genuine
simplex-valued posterior.

This strengthens the subset MAE-delta endpoint by proving that the constructed
`qNext` is measurable, preserves the posterior sum pointwise, and remains
