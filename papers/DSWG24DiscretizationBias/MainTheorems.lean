      (by simpa [u] using hformula_nonpos)

/--
Source Step 2 subset interval split as an actual two-region posterior
transformation.

The theorem chooses a subset-sweep cut and a measurable above-uniform nonfocal
selector.  Any `qNext` with the corresponding `S_d -> S_c` shape on
`S ∩ (cut, hi]`, `S_d -> S_e` shape on `S ∩ (lo, cut]`, and unchanged outside
the two swept pieces has nonpositive integrated MAE delta, subject to the
threshold comparisons needed by the `S_d` accounting.
-/
theorem sourceSd_subset_interval_split_exists_measurable_nonfocal_twoRegion_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q qNext : ℝ → Y → ℝ) (z : Y) (c : ℝ) {lo hi : ℝ} {S : Set ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hS : MeasurableSet S)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ S → x ∈ Icc lo hi →
        x ∈ sourceSdRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hqw_excess_le :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y,
          xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
            w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc cut hi →
          q xy.1 (w xy) - (Fintype.card Y : ℝ)⁻¹ ≤ c)
    (hc_le_qw :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y,
          xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
            w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc lo cut → c ≤ q xy.1 (w xy))
    (hshapeC :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
