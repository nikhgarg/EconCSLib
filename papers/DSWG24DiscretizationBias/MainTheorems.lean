    ∃ cut : ℝ, ∃ w : ℝ × Y → Y,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ xy : ℝ × Y,
          xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
            w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSb_subset_interval_split_exists_measurable_nonfocal_twoCoordinate_delta_integral_nonpos_uniform_simplex_finite
      μ q z hcard_gt_one hlohi hfinite hS hq hsum hnonneg hregion with
    ⟨cut, w, hcut, hw_meas, hsel, hformula_nonpos⟩
  have hdisj : Disjoint (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    exact (not_lt_of_ge hx_lo.2.2) hx_hi.2.1
  have hzw :
      ∀ᵐ xy ∂μ,
        xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) → z ≠ w xy :=
    Filter.Eventually.of_forall fun xy hxy => (hsel xy hxy).1.symm
  refine ⟨cut, w, hcut, hw_meas, hsel, ?_⟩
  simpa [u] using
    integral_paperConditionalMAE_delta_sourceSb_twoRegion_nonpos
      μ q qNext (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) z w u hdisj hzw
      (hshapeA cut w hcut hw_meas hsel)
      (by simpa [u] using hshapeB cut w hcut hw_meas hsel)
