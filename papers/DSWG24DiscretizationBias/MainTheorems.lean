          Pareto.weightedObjective γ
            (measureExpectedDatasetAccuracy (iidSampleMeasure μ N) posterior)
            (measureExpectedDatasetFidelity (iidSampleMeasure μ N) pref) policy :=
  not_measureExpectedDataset_weightedObjective_maximizer_of_positive_measure_event_dominated
