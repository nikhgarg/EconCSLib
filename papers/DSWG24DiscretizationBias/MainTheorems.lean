          xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
            w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc cut hi → ∀ a : Y,
          qNext xy.1 a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w xy then
              q xy.1 (w xy) - ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
            else q xy.1 a)
    (hshapeE :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ xy : ℝ × Y,
          xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
            w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc lo cut → ∀ a : Y,
          qNext xy.1 a =
            if a = z then 0
            else if a = w xy then q xy.1 (w xy) + q xy.1 z
            else q xy.1 a)
    (hshapeOutside :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi → Measurable w →
        (∀ xy : ℝ × Y,
          xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
            w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) →
        ∀ᵐ xy ∂μ, xy.1 ∉ S ∩ Ioc cut hi → xy.1 ∉ S ∩ Ioc lo cut →
          ∀ a : Y, qNext xy.1 a = q xy.1 a) :
    ∃ cut : ℝ, ∃ w : ℝ × Y → Y,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ xy : ℝ × Y,
          xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
            w xy ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q xy.1 (w xy)) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSd_subset_interval_split_exists_measurable_nonfocal_twoCoordinate_delta_integral_nonpos_uniform_simplex_finite
      μ q z c hlohi hfinite hS hq hsum hnonneg hregion
      hqw_excess_le hc_le_qw with
    ⟨cut, w, hcut, hw_meas, hsel, hformula_nonpos⟩
  have hdisj : Disjoint (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    exact (not_lt_of_ge hx_lo.2.2) hx_hi.2.1
  have hzw :
      ∀ᵐ xy ∂μ,
        xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) → z ≠ w xy :=
    Filter.Eventually.of_forall fun xy hxy => (hsel xy hxy).1.symm
  refine ⟨cut, w, hcut, hw_meas, hsel, ?_⟩
  simpa [u] using
    integral_paperConditionalMAE_delta_sourceSd_twoRegion_nonpos
      μ q qNext (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) z w u hdisj hzw
      (by simpa [u] using hshapeC cut w hcut hw_meas hsel)
      (hshapeE cut w hcut hw_meas hsel)
      (hshapeOutside cut w hcut hw_meas hsel)
      (by simpa [u] using hformula_nonpos)

/--
Constructive `S_b` subset interval source transformation.

This endpoint chooses a subset-sweep cut, a measurable feature-level
below-uniform nonfocal selector, and the piecewise transformed posterior
`qNext`.  It proves the resulting integrated classifier-MAE delta is
nonpositive on the arbitrary measurable source subregion `S`.
-/
theorem sourceSb_subset_interval_split_exists_measurable_feature_qNext_mae_delta_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ} {S : Set ℝ}
    (hcard_gt_one : 1 < Fintype.card Y)
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hS : MeasurableSet S)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ S → x ∈ Icc lo hi →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, ∃ w : ℝ → Y, ∃ qNext : ℝ → Y → ℝ,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ x : ℝ, x ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
          w x ≠ z ∧ q x (w x) < (Fintype.card Y : ℝ)⁻¹) ∧
        (∀ x : ℝ, x ∈ S ∩ Ioc cut hi → ∀ a : Y,
          qNext x a =
            if a = z then 1
            else if a = w x then q x (w x) - (1 - q x z)
            else q x a) ∧
        (∀ x : ℝ, x ∈ S ∩ Ioc lo cut → ∀ a : Y,
          qNext x a =
            if a = z then (Fintype.card Y : ℝ)⁻¹
            else if a = w x then q x (w x) + (q x z - (Fintype.card Y : ℝ)⁻¹)
            else q x a) ∧
        (∀ x : ℝ, x ∉ S ∩ Ioc cut hi → x ∉ S ∩ Ioc lo cut → ∀ a : Y,
          qNext x a = q x a) ∧
        (∫ xy : ℝ × Y,
            (Finite.paperConditionalMAE qNext xy.1 -
              Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  rcases sourceSb_subset_interval_split_exists_measurable_feature_nonfocal_selector_product_balance_simplex_finite
      μ q z hlohi hfinite hS hq hsum hnonneg hregion with
    ⟨cut, w, hcut, hw_meas, hsel, hbalance⟩
  let wProd : ℝ × Y → Y := fun xy => w xy.1
  let qNext : ℝ → Y → ℝ := fun x a =>
    if x ∈ S ∩ Ioc cut hi then
      if a = z then 1
      else if a = w x then q x (w x) - (1 - q x z)
      else q x a
    else if x ∈ S ∩ Ioc lo cut then
      if a = z then u
      else if a = w x then q x (w x) + (q x z - u)
      else q x a
    else q x a
  have hle_one : ∀ x y, q x y ≤ 1 := fun x y =>
    posterior_coord_le_one_of_sum_nonneg q x y (hsum x) (hnonneg x)
  have hdisj : Disjoint (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) := by
    rw [Set.disjoint_left]
    intro x hx_hi hx_lo
    exact (not_lt_of_ge hx_lo.2.2) hx_hi.2.1
  have hwProd_meas : Measurable wProd := hw_meas.comp measurable_fst
  have hselProd :
      ∀ xy : ℝ × Y,
        xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) →
          wProd xy ≠ z ∧ q xy.1 (wProd xy) < u := by
    intro xy hxy
    simpa [wProd, u] using hsel xy.1 hxy
  have hSbaRegion :
      ∀ x, x ∈ S ∩ Ioc cut hi →
        x ∈ sourceSbRegion q z u := by
    intro x hx
    simpa [u] using hregion x hx.1 ⟨hcut.1.trans hx.2.1.le, hx.2.2⟩
  have hSbcRegion :
      ∀ x, x ∈ S ∩ Ioc lo cut →
        x ∈ sourceSbRegion q z u := by
    intro x hx
    simpa [u] using hregion x hx.1 ⟨hx.2.1.le, hx.2.2.trans hcut.2⟩
  have hAInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator (fun xy : ℝ × Y =>
            -2 * (1 - q xy.1 (wProd xy)) * (1 - q xy.1 z)
          ) xy) μ :=
    integrable_fst_preimage_twoCoordinate_delta_toOne_indicator_finite
      μ q (S ∩ Ioc cut hi) z wProd (hS.inter measurableSet_Ioc)
      hq hwProd_meas hnonneg hle_one
  have hBInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' (S ∩ Ioc lo cut)).indicator (fun xy : ℝ × Y =>
            -2 * (u - q xy.1 (wProd xy)) * (u - q xy.1 z)
          ) xy) μ :=
    integrable_fst_preimage_twoCoordinate_delta_toUniform_indicator_finite
      μ q (S ∩ Ioc lo cut) z wProd u (hS.inter measurableSet_Ioc)
      hq hwProd_meas hnonneg hle_one
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hAUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator
            (fun xy : ℝ × Y => 1 - q xy.1 z) xy) μ :=
    integrable_fst_preimage_score_deficitToOne_indicator_finite
      μ q (S ∩ Ioc cut hi) z (hS.inter measurableSet_Ioc) (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
  have hAUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (-2 * (1 - u)) *
            (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator
              (fun xy : ℝ × Y => 1 - q xy.1 z) xy) μ := by
    simpa [smul_eq_mul] using hAUpperBase.const_mul (-2 * (1 - u))
  have hBUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' (S ∩ Ioc lo cut)).indicator
            (fun xy : ℝ × Y => q xy.1 z - u) xy) μ :=
    integrable_fst_preimage_score_excess_indicator_finite
      μ q (S ∩ Ioc lo cut) z u (hS.inter measurableSet_Ioc) (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hBUpperInt :
      Integrable
        (fun xy : ℝ × Y =>
          (2 * u) *
            (Prod.fst ⁻¹' (S ∩ Ioc lo cut)).indicator
              (fun xy : ℝ × Y => q xy.1 z - u) xy) μ := by
    simpa [smul_eq_mul] using hBUpperBase.const_mul (2 * u)
  have hformula_nonpos :
      (∫ xy : ℝ × Y,
          (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator (fun xy : ℝ × Y =>
            -2 * (1 - q xy.1 (wProd xy)) * (1 - q xy.1 z)
          ) xy +
          (Prod.fst ⁻¹' (S ∩ Ioc lo cut)).indicator (fun xy : ℝ × Y =>
            -2 * (u - q xy.1 (wProd xy)) * (u - q xy.1 z)
          ) xy ∂μ) ≤ 0 :=
    sourceSb_split_twoCoordinate_delta_integral_nonpos_of_balance_uniform_region
      μ q (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) z wProd hcard_gt_one
      hAInt hBInt hAUpperInt hBUpperInt
      hSbaRegion hSbcRegion
      (Filter.Eventually.of_forall fun xy hxy => (hselProd xy hxy).2.le)
      (Filter.Eventually.of_forall fun xy _ => hnonneg xy.1 (wProd xy))
      (by simpa [u] using hbalance)
  have hqNextA :
      ∀ x : ℝ, x ∈ S ∩ Ioc cut hi → ∀ a : Y,
        qNext x a =
          if a = z then 1
          else if a = w x then q x (w x) - (1 - q x z)
          else q x a := by
    intro x hx a
    have hxA : x ∈ S ∧ cut < x ∧ x ≤ hi :=
      ⟨hx.1, hx.2.1, hx.2.2⟩
    simp [qNext, hxA]
  have hqNextB :
      ∀ x : ℝ, x ∈ S ∩ Ioc lo cut → ∀ a : Y,
        qNext x a =
          if a = z then u
          else if a = w x then q x (w x) + (q x z - u)
          else q x a := by
    intro x hx a
    have hxB : x ∈ S ∧ lo < x ∧ x ≤ cut :=
      ⟨hx.1, hx.2.1, hx.2.2⟩
    simp [qNext, hxB]
  have hqNextOutside :
      ∀ x : ℝ, x ∉ S ∩ Ioc cut hi → x ∉ S ∩ Ioc lo cut → ∀ a : Y,
        qNext x a = q x a := by
    intro x hxA hxB a
    have hxA' : ¬ (x ∈ S ∧ cut < x ∧ x ≤ hi) := by
      intro h
      exact hxA ⟨h.1, ⟨h.2.1, h.2.2⟩⟩
    have hxB' : ¬ (x ∈ S ∧ lo < x ∧ x ≤ cut) := by
      intro h
      exact hxB ⟨h.1, ⟨h.2.1, h.2.2⟩⟩
    simp [qNext, hxA', hxB']
  have hzw :
      ∀ᵐ xy ∂μ,
        xy.1 ∈ (S ∩ Ioc cut hi) ∪ (S ∩ Ioc lo cut) → z ≠ wProd xy :=
    Filter.Eventually.of_forall fun xy hxy => (hselProd xy hxy).1.symm
  have hshapeA :
      ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc cut hi → ∀ a : Y,
        qNext xy.1 a =
          if a = z then 1
          else if a = wProd xy then q xy.1 (wProd xy) - (1 - q xy.1 z)
          else q xy.1 a :=
    Filter.Eventually.of_forall fun xy hx => by
      simpa [wProd] using hqNextA xy.1 hx
  have hshapeB :
      ∀ᵐ xy ∂μ, xy.1 ∈ S ∩ Ioc lo cut → ∀ a : Y,
        qNext xy.1 a =
          if a = z then u
          else if a = wProd xy then q xy.1 (wProd xy) + (q xy.1 z - u)
          else q xy.1 a :=
    Filter.Eventually.of_forall fun xy hx => by
      simpa [wProd] using hqNextB xy.1 hx
  have hshapeOutside :
      ∀ᵐ xy ∂μ, xy.1 ∉ S ∩ Ioc cut hi → xy.1 ∉ S ∩ Ioc lo cut →
        ∀ a : Y, qNext xy.1 a = q xy.1 a :=
    Filter.Eventually.of_forall fun xy hxA hxB => hqNextOutside xy.1 hxA hxB
  have hmae_nonpos :
      (∫ xy : ℝ × Y,
          (Finite.paperConditionalMAE qNext xy.1 -
            Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
    simpa [u, wProd] using
      integral_paperConditionalMAE_delta_sourceSb_twoRegion_nonpos
        μ q qNext (S ∩ Ioc cut hi) (S ∩ Ioc lo cut) z wProd u hdisj
        hzw hshapeA hshapeB hshapeOutside hformula_nonpos
  refine ⟨cut, w, qNext, hcut, hw_meas, ?_, ?_, ?_, ?_, hmae_nonpos⟩
  · simpa [u] using hsel
  · intro x hx a
    simpa [u] using hqNextA x hx a
  · intro x hx a
    simpa [u] using hqNextB x hx a
  · exact hqNextOutside

/--
Constructive `S_b` subset interval source transformation as a genuine
