/--
Source Step 1 interval split with measurable nonfocal selector and all
integrability obligations discharged from finite-law, measurability, and
simplex bounds.
-/
theorem sourceSb_interval_split_exists_measurable_nonfocal_twoCoordinate_delta_integral_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ}
    (hcard_gt_one : 1 < Fintype.card Y)
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hq : ∀ a : Y, Measurable fun x : ℝ => q x a)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹) :
    ∃ cut : ℝ, ∃ w : ℝ × Y → Y,
      cut ∈ Icc lo hi ∧ Measurable w ∧
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) ∧
        (∫ xy : ℝ × Y,
            (Prod.fst ⁻¹' Ioc cut hi).indicator (fun xy : ℝ × Y =>
              -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
            ) xy +
            (Prod.fst ⁻¹' Ioc lo cut).indicator (fun xy : ℝ × Y =>
              -2 * ((Fintype.card Y : ℝ)⁻¹ - q xy.1 (w xy)) *
                ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
            ) xy ∂μ) ≤ 0 := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  have hle_one : ∀ x y, q x y ≤ 1 := fun x y =>
    posterior_coord_le_one_of_sum_nonneg q x y (hsum x) (hnonneg x)
  rcases sourceSb_interval_split_exists_measurable_nonfocal_selector_product_balance_simplex_finite
      μ q z hlohi hfinite hq hsum hnonneg hregion with
    ⟨cut, w, hcut, hw_meas, hsel, hbalance⟩
  have hSbaRegion :
      ∀ x, x ∈ Ioc cut hi →
        x ∈ sourceSbRegion q z u := by
    intro x hx
    simpa [u] using hregion x ⟨hcut.1.trans hx.1.le, hx.2⟩
  have hSbcRegion :
      ∀ x, x ∈ Ioc lo cut →
        x ∈ sourceSbRegion q z u := by
    intro x hx
    simpa [u] using hregion x ⟨hx.1.le, hx.2.trans hcut.2⟩
  have hAInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc cut hi).indicator (fun xy : ℝ × Y =>
            -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
          ) xy) μ :=
    integrable_fst_preimage_twoCoordinate_delta_toOne_indicator_finite
      μ q (Ioc cut hi) z w measurableSet_Ioc hq hw_meas hnonneg hle_one
  have hBInt :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc lo cut).indicator (fun xy : ℝ × Y =>
            -2 * (u - q xy.1 (w xy)) * (u - q xy.1 z)
          ) xy) μ :=
    integrable_fst_preimage_twoCoordinate_delta_toUniform_indicator_finite
      μ q (Ioc lo cut) z w u measurableSet_Ioc hq hw_meas hnonneg hle_one
      (by simpa [u] using uniform_inverse_card_nonneg (Y := Y))
      (by simpa [u] using uniform_inverse_card_le_one z)
  have hAUpperBase :
      Integrable
        (fun xy : ℝ × Y =>
          (Prod.fst ⁻¹' Ioc cut hi).indicator
            (fun xy : ℝ × Y => 1 - q xy.1 z) xy) μ :=
    integrable_fst_preimage_score_deficitToOne_indicator_finite
      μ q (Ioc cut hi) z measurableSet_Ioc (hq z)
      (fun x => hnonneg x z) (fun x => hle_one x z)
