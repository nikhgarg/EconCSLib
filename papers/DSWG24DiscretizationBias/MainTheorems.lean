/-!
# Paper-Facing Theorems: Addressing Discretization-Induced Bias

This file is the public theorem interface for the current discretization-bias
formalization. The main wrappers below state source-facing expected-objective
results for Theorem 2(i)--(ii), using an abstract finite-linear expectation
operator to represent the paper's expectation over sampled datasets and the
Bayes tower-property step.

## Main declarations

- `paperONObjective`: per-dataset objective from Equations (1)/(3).
- `paperExpectedONObjective`: expected paper objective using expected true
  accuracy and expected fidelity.
- `paperBias`, `paperFidelity`, `paperClassifierMAE`: finite source formulas
  for bias, distributional fidelity, and predictive error.
- `ContinuousCalibration`, `FiniteScoreCalibration`: continuous calibration
  interfaces, plus `ConditionalExpectationCalibration`, proving the paper's
  calibration-to-consistency bridge for Theorem 1.
- `paper_theorem1iii_argmax_bias_le_mae`: finite Bayes-posterior argmax-bias
  bound corresponding to Theorem 1(iii).
- `paper_theorem2i_joint_optimization_rule_exists`: conditional source-facing
  wrapper for Theorem 2(i).
- `paper_theorem2i_joint_optimization_rule_exists_finite_bayes`: finite
  Bayes-optimal dataset wrapper for Theorem 2(i), with the row Bayes identities
  discharged from atom-level Bayes equations.
- `paper_theorem2ii_argmax_expected_accuracy_maximizing`: conditional
  source-facing wrapper for Theorem 2(ii).
- `paper_theorem2ii_argmax_expected_accuracy_maximizing_finite_bayes`: finite
  Bayes-optimal dataset wrapper for Theorem 2(ii).
- `paper_theorem2iii_not_expected_pareto_of_independent_rule_disagrees_pos`:
  finite expected-policy Pareto bridge for non-argmax independent rules.
- `paper_theorem2iii_not_expected_pareto_of_augmented_rule_disagrees_pos`:
  finite augmented-atom wrapper for randomized independent rules.
-/

namespace DSWG24DiscretizationBias

open scoped BigOperators ProbabilityTheory
open MeasureTheory
open Set

namespace Finite

variable {Ω σ X Y : Type*}

/-- Finite PMF expectations satisfy the abstract finite-linearity interface used by the optimizer layer. -/
theorem pmfExp_finiteLinearExpectation
    [Fintype Ω] [DecidableEq Ω] (μ : PMF Ω) :
    EconCSLib.Decision.FiniteLinearExpectation (EconCSLib.pmfExp μ) := by
  refine ⟨?_, ?_, ?_⟩
  · intro f g h
    exact EconCSLib.pmfExp_le_pmfExp_of_forall_le μ f g h
  · intro c f
    exact EconCSLib.pmfExp_const_mul μ c f
  · intro f g
    exact EconCSLib.pmfExp_add μ f g

/-- Marginal law of features under a finite joint law. -/
noncomputable def featureMarginal [Fintype X] [DecidableEq X]
    [Fintype Y] [DecidableEq Y] (μ : PMF (X × Y)) : PMF X :=
  μ.map Prod.fst

/-- Marginal law of labels under a finite joint law. -/
noncomputable def labelMarginal [Fintype X] [DecidableEq X]
    [Fintype Y] [DecidableEq Y] (μ : PMF (X × Y)) : PMF Y :=
  μ.map Prod.snd

/-- Paper marginal label share `\hat p_marg(y)` induced by a deterministic rule. -/
noncomputable def paperMarginalLabelShare [Fintype X] [DecidableEq X]
    [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (rule : X → Y) (y : Y) : ℝ :=
  EconCSLib.pmfProb (featureMarginal μ) (fun x => rule x = y)

/-- Prior class probability `Pr(y)`. -/
noncomputable def paperPrior [Fintype X] [DecidableEq X]
    [Fintype Y] [DecidableEq Y] (μ : PMF (X × Y)) (y : Y) : ℝ :=
  ((labelMarginal μ) y).toReal

/-- Aggregate posterior reference distribution. -/
noncomputable def paperAggregatePosterior [Fintype X] [DecidableEq X]
    [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (q : X → Y → ℝ) (y : Y) : ℝ :=
  EconCSLib.pmfExp (featureMarginal μ) (fun x => q x y)

/-- Source bias formula: label share minus a supplied reference distribution. -/
noncomputable def paperBias [Fintype X] [DecidableEq X]
    [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (rule : X → Y) (pref : Y → ℝ) (y : Y) : ℝ :=
  paperMarginalLabelShare μ rule y - pref y

/-- Source fidelity formula: negative `\ell_1` distance to the reference distribution. -/
noncomputable def paperFidelity [Fintype X] [DecidableEq X]
    [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (rule : X → Y) (pref : Y → ℝ) : ℝ :=
  -∑ y : Y, |paperBias μ rule pref y|

/-- Conditional Bayes-posterior MAE contribution at one feature value. -/
noncomputable def paperConditionalMAE [Fintype Y]
    (q : X → Y → ℝ) (x : X) : ℝ :=
  ∑ y : Y, q x y * (1 - q x y)

/-- Pointwise posterior-simplex algebra behind the argmax-bias MAE bound. -/
theorem pointwise_argmax_bias_le_conditionalMAE
    [Fintype Y] [DecidableEq Y]
    (q : X → Y → ℝ) (argmaxRule : X → Y) (x : X) (y : Y)
    (hargmax : ∀ a, q x a ≤ q x (argmaxRule x))
    (hsum : (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ a, 0 ≤ q x a)
    (hle_one : ∀ a, q x a ≤ 1) :
    ((if argmaxRule x = y then (1 : ℝ) else 0) - q x y) ≤
      paperConditionalMAE q x := by
  classical
  have hmae_eq :
      paperConditionalMAE q x = 1 - ∑ a : Y, q x a * q x a := by
    unfold paperConditionalMAE
    calc
      (∑ a : Y, q x a * (1 - q x a)) =
          ∑ a : Y, (q x a - q x a * q x a) := by
            refine Finset.sum_congr rfl ?_
            intro a _
            ring
      _ = (∑ a : Y, q x a) - ∑ a : Y, q x a * q x a := by
            rw [Finset.sum_sub_distrib]
      _ = 1 - ∑ a : Y, q x a * q x a := by
            rw [hsum]
  by_cases hay : argmaxRule x = y
  · have hsquares_le : (∑ a : Y, q x a * q x a) ≤ q x y := by
      calc
        (∑ a : Y, q x a * q x a) ≤ ∑ a : Y, q x y * q x a := by
          refine Finset.sum_le_sum ?_
          intro a _
          have hqa : q x a ≤ q x y := by
            simpa [hay] using hargmax a
          exact mul_le_mul_of_nonneg_right hqa (hnonneg a)
        _ = q x y * ∑ a : Y, q x a := by
          rw [Finset.mul_sum]
        _ = q x y := by
          rw [hsum]
          ring
    rw [hmae_eq]
    simp [hay]
    linarith
  · have hmae_nonneg : 0 ≤ paperConditionalMAE q x := by
      unfold paperConditionalMAE
      refine Finset.sum_nonneg ?_
      intro a _
      exact mul_nonneg (hnonneg a) (sub_nonneg.mpr (hle_one a))
    simp [hay]
    linarith [hnonneg y]

/-- Predictive MAE for a Bayes-posterior finite model. -/
noncomputable def paperClassifierMAE [Fintype X] [DecidableEq X]
    [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (q : X → Y → ℝ) : ℝ :=
  EconCSLib.pmfExp (featureMarginal μ) (paperConditionalMAE q)

/-- Bias to the aggregate-posterior reference. -/
noncomputable def paperAggregateBias [Fintype X] [DecidableEq X]
    [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (q : X → Y → ℝ) (rule : X → Y) (y : Y) : ℝ :=
  paperBias μ rule (paperAggregatePosterior μ q) y

theorem paperMarginalLabelShare_const [Fintype X] [DecidableEq X] [Nonempty X]
    [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (z y : Y) :
    paperMarginalLabelShare μ (fun _ : X => z) y =
      if z = y then 1 else 0 := by
  classical
  by_cases hzy : z = y
  · simp [paperMarginalLabelShare, EconCSLib.pmfProb, hzy]
  · have hfalse : (fun _ : X => z = y) = fun _ : X => False := by
      funext x
      simp [hzy]
    simp [paperMarginalLabelShare, EconCSLib.pmfProb, hzy]

/--
Theorem 1(i), finite prior-reference form.

When every point is assigned to a plurality class `z`, the bias is exactly the
paper's displayed `1 - Pr(z)` for `z` and `-Pr(y)` for every other class.
-/
theorem paper_theorem1i_no_information_prior_bias [Fintype X] [DecidableEq X] [Nonempty X]
    [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (z y : Y) :
    paperBias μ (fun _ : X => z) (paperPrior μ) y =
      if z = y then 1 - paperPrior μ y else -paperPrior μ y := by
  classical
  rw [paperBias, paperMarginalLabelShare_const]
  by_cases hzy : z = y <;> simp [hzy]

theorem paperMarginalLabelShare_eq_truth_share_of_rule_eq_truth
    [Fintype X] [DecidableEq X] [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (rule : X → Y)
    (htruth : ∀ xy : X × Y, rule xy.1 = xy.2) (y : Y) :
    paperMarginalLabelShare μ rule y = paperPrior μ y := by
  classical
  unfold paperMarginalLabelShare paperPrior featureMarginal labelMarginal
  rw [EconCSLib.pmf_map_apply_toReal_eq_pmfProb_preimage]
  unfold EconCSLib.pmfProb
  rw [EconCSLib.pmfExp_map]
  refine EconCSLib.pmfExp_congr μ ?_
  intro xy
  simp [htruth xy]

/--
Theorem 1(ii), finite prior-reference form.

If the classifier is perfect in the sense that the induced rule equals the true
label at every atom, the expected argmax bias is zero for every class.
-/
theorem paper_theorem1ii_perfect_classifier_prior_bias_zero
    [Fintype X] [DecidableEq X] [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (rule : X → Y)
    (htruth : ∀ xy : X × Y, rule xy.1 = xy.2) (y : Y) :
    paperBias μ rule (paperPrior μ) y = 0 := by
  rw [paperBias, paperMarginalLabelShare_eq_truth_share_of_rule_eq_truth μ rule htruth y]
  ring

theorem paperAggregateBias_eq_pmfExp_pointwise
    [Fintype X] [DecidableEq X] [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (q : X → Y → ℝ) (rule : X → Y) (y : Y) :
    paperAggregateBias μ q rule y =
      EconCSLib.pmfExp (featureMarginal μ)
        (fun x => (if rule x = y then (1 : ℝ) else 0) - q x y) := by
  classical
  unfold paperAggregateBias paperBias paperMarginalLabelShare paperAggregatePosterior
  unfold EconCSLib.pmfProb
  rw [← EconCSLib.pmfExp_sub]

/--
Theorem 1(iii), finite Bayes-posterior aggregate-reference form.

The pointwise inequality is the paper's MAE/bias comparison after conditioning
on features.  It follows from the Bayes posterior simplex assumptions and
pointwise argmax optimality; it is kept explicit here so the paper-facing
wrapper can be used with either a direct posterior proof or a supplied
calibration-to-posterior bridge.
-/
theorem paper_theorem1iii_argmax_bias_le_mae_of_pointwise
    [Fintype X] [DecidableEq X] [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (q : X → Y → ℝ) (argmaxRule : X → Y) (y : Y)
    (hpoint : ∀ x,
      (if argmaxRule x = y then (1 : ℝ) else 0) - q x y ≤
        paperConditionalMAE q x) :
    paperAggregateBias μ q argmaxRule y ≤ paperClassifierMAE μ q := by
  rw [paperAggregateBias_eq_pmfExp_pointwise]
  unfold paperClassifierMAE
  exact EconCSLib.pmfExp_le_pmfExp_of_forall_le
    (featureMarginal μ)
    (fun x => (if argmaxRule x = y then (1 : ℝ) else 0) - q x y)
    (paperConditionalMAE q) hpoint

/--
Theorem 1(iii), named finite wrapper.

This is the closed finite Bayes-posterior seam: once the source's calibration
argument supplies the pointwise posterior-MAE comparison, the expected argmax
bias is bounded by predictive MAE.
-/
theorem paper_theorem1iii_argmax_bias_le_mae
    [Fintype X] [DecidableEq X] [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (q : X → Y → ℝ) (argmaxRule : X → Y) (y : Y)
    (hpoint : ∀ x,
      (if argmaxRule x = y then (1 : ℝ) else 0) - q x y ≤
        paperConditionalMAE q x) :
    paperAggregateBias μ q argmaxRule y ≤ paperClassifierMAE μ q :=
  paper_theorem1iii_argmax_bias_le_mae_of_pointwise μ q argmaxRule y hpoint

/--
Theorem 1(iii), finite Bayes-posterior aggregate-reference form with the
posterior-simplex and argmax assumptions discharged pointwise.
-/
theorem paper_theorem1iii_argmax_bias_le_mae_of_simplex
    [Fintype X] [DecidableEq X] [Fintype Y] [DecidableEq Y]
    (μ : PMF (X × Y)) (q : X → Y → ℝ) (argmaxRule : X → Y) (y : Y)
    (hargmax : ∀ x a, q x a ≤ q x (argmaxRule x))
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a)
    (hle_one : ∀ x a, q x a ≤ 1) :
    paperAggregateBias μ q argmaxRule y ≤ paperClassifierMAE μ q :=
  paper_theorem1iii_argmax_bias_le_mae μ q argmaxRule y
    (fun x => pointwise_argmax_bias_le_conditionalMAE
      q argmaxRule x y (hargmax x) (hsum x) (hnonneg x) (hle_one x))

/-- The binary one-feature witness used for Theorem 1(iii) tightness. -/
noncomputable def paperTheorem1TightMu : PMF (Unit × Fin 2) :=
  PMF.pure ((), (0 : Fin 2))

/-- Uniform binary posterior in the Theorem 1(iii) tightness witness. -/
noncomputable def paperTheorem1TightQ (_ : Unit) (_ : Fin 2) : ℝ :=
  1 / 2

/-- Deterministic tie-breaking to class `0` in the Theorem 1(iii) witness. -/
def paperTheorem1TightArgmax (_ : Unit) : Fin 2 :=
  0

theorem paper_theorem1iii_tight_binary_uniform_bias :
    paperAggregateBias paperTheorem1TightMu paperTheorem1TightQ
      paperTheorem1TightArgmax 0 = 1 / 2 := by
  norm_num [paperAggregateBias, paperBias, paperMarginalLabelShare,
    paperAggregatePosterior, paperTheorem1TightMu, paperTheorem1TightQ,
    paperTheorem1TightArgmax, featureMarginal, EconCSLib.pmfProb]

theorem paper_theorem1iii_tight_binary_uniform_mae :
    paperClassifierMAE paperTheorem1TightMu paperTheorem1TightQ = 1 / 2 := by
  unfold paperClassifierMAE featureMarginal
  rw [EconCSLib.pmfExp_map]
  simp [paperTheorem1TightMu, paperConditionalMAE, paperTheorem1TightQ]
  norm_num

/--
Theorem 1(iii) tightness witness.

For the binary one-feature uniform posterior with deterministic tie-breaking to
class `0`, aggregate-posterior argmax bias equals predictive MAE.
-/
theorem paper_theorem1iii_tight_binary_uniform_example :
    paperAggregateBias paperTheorem1TightMu paperTheorem1TightQ
      paperTheorem1TightArgmax 0 =
        paperClassifierMAE paperTheorem1TightMu paperTheorem1TightQ := by
  rw [paper_theorem1iii_tight_binary_uniform_bias,
    paper_theorem1iii_tight_binary_uniform_mae]

/--
Atom-level finite Bayes-optimal dataset model.

The `bayes_atom` field is the concrete finite version of
`q(y, x) = Pr(Y = y | X = x)`: for every observed dataset, row, and label, the
joint atom mass of observation and row label factors as observation mass times
the supplied posterior score.
-/
structure FiniteBayesDatasetModel
    (Ω σ : Type*) [Fintype Ω] [DecidableEq Ω] [Fintype σ] [DecidableEq σ]
    (N K : ℕ) where
  μ : PMF Ω
  observedDataset : Ω → σ
  trueLabels : Ω → Fin N → Fin K
  posterior : σ → Fin N → Fin K → ℝ
  bayes_atom : ∀ xs i y,
    EconCSLib.pmfProb μ
        (fun w => observedDataset w = xs ∧ trueLabels w i = y) =
      posterior xs i y *
        EconCSLib.pmfProb μ (fun w => observedDataset w = xs)

namespace FiniteBayesDatasetModel

variable [Fintype Ω] [DecidableEq Ω] [Fintype σ] [DecidableEq σ]
variable {N K : ℕ} (M : FiniteBayesDatasetModel Ω σ N K)

theorem row_bayes (i : Fin N) (choose : σ → Fin K) :
    EconCSLib.pmfExp M.μ (fun w =>
        if choose (M.observedDataset w) = M.trueLabels w i then (1 : ℝ) else 0) =
      EconCSLib.pmfExp M.μ (fun w =>
        M.posterior (M.observedDataset w) i (choose (M.observedDataset w))) := by
  classical
  have hpartition :
      (fun w : Ω =>
          if choose (M.observedDataset w) = M.trueLabels w i then (1 : ℝ) else 0) =
        fun w : Ω =>
          ∑ xs : σ,
            if M.observedDataset w = xs ∧ M.trueLabels w i = choose xs then
              (1 : ℝ) else 0 := by
    funext w
    by_cases hhit : choose (M.observedDataset w) = M.trueLabels w i
    · rw [if_pos hhit]
      rw [Finset.sum_eq_single (M.observedDataset w)]
      · simp [hhit.symm]
      · intro xs _ hxs
        have hne : M.observedDataset w ≠ xs := hxs.symm
        simp [hne]
      · intro hmem
        exact False.elim (hmem (Finset.mem_univ (M.observedDataset w)))
    · rw [if_neg hhit]
      rw [Finset.sum_eq_zero]
      intro xs _
      by_cases hobs : M.observedDataset w = xs
      · have hlabel : ¬ M.trueLabels w i = choose xs := by
          intro hlabel
          apply hhit
          rw [hobs, hlabel]
        simp [hobs, hlabel]
      · simp [hobs]
  calc
    EconCSLib.pmfExp M.μ (fun w =>
        if choose (M.observedDataset w) = M.trueLabels w i then (1 : ℝ) else 0)
        =
      EconCSLib.pmfExp M.μ (fun w =>
        ∑ xs : σ,
          if M.observedDataset w = xs ∧ M.trueLabels w i = choose xs then
            (1 : ℝ) else 0) := by
        exact EconCSLib.pmfExp_congr M.μ (fun w => congrFun hpartition w)
    _ = ∑ xs : σ,
        EconCSLib.pmfExp M.μ (fun w =>
          if M.observedDataset w = xs ∧ M.trueLabels w i = choose xs then
            (1 : ℝ) else 0) := by
        rw [EconCSLib.pmfExp_finset_sum]
    _ = ∑ xs : σ,
        EconCSLib.pmfProb M.μ
          (fun w => M.observedDataset w = xs ∧ M.trueLabels w i = choose xs) := by
        rfl
    _ = ∑ xs : σ,
        M.posterior xs i (choose xs) *
          EconCSLib.pmfProb M.μ (fun w => M.observedDataset w = xs) := by
        refine Finset.sum_congr rfl ?_
        intro xs _
        exact M.bayes_atom xs i (choose xs)
    _ = ∑ xs : σ,
        EconCSLib.pmfExp M.μ (fun w =>
          if M.observedDataset w = xs then
            M.posterior xs i (choose xs) else 0) := by
        refine Finset.sum_congr rfl ?_
        intro xs _
        rw [EconCSLib.pmfExp_eq_prob_mul_add_one_sub_prob_mul_of_forall_eq_if
          M.μ (fun w => M.observedDataset w = xs)
          (fun w => if M.observedDataset w = xs then
            M.posterior xs i (choose xs) else 0)
          (M.posterior xs i (choose xs)) 0]
        · ring
        · intro w
          rfl
    _ = EconCSLib.pmfExp M.μ (fun w =>
        ∑ xs : σ,
          if M.observedDataset w = xs then
            M.posterior xs i (choose xs) else 0) := by
        rw [EconCSLib.pmfExp_finset_sum]
    _ = EconCSLib.pmfExp M.μ (fun w =>
        M.posterior (M.observedDataset w) i (choose (M.observedDataset w))) := by
        refine EconCSLib.pmfExp_congr M.μ ?_
        intro w
        rw [Finset.sum_eq_single (M.observedDataset w)]
        · simp
        · intro xs _ hxs
          have hne : M.observedDataset w ≠ xs := hxs.symm
          simp [hne]
        · intro hmem
          exact False.elim (hmem (Finset.mem_univ (M.observedDataset w)))

end FiniteBayesDatasetModel

end Finite

namespace ContinuousTheorem1

variable {X Y : Type*} [MeasurableSpace X] [Fintype Y] [DecidableEq Y]

/-- Continuous feature-space version of the paper marginal share `\hat p_marg(y)`. -/
noncomputable def continuousMarginalLabelShare
    (μ : Measure X) (rule : X → Y) (y : Y) : ℝ :=
  ∫ x, (if rule x = y then (1 : ℝ) else 0) ∂μ

/-- Continuous aggregate posterior reference distribution. -/
noncomputable def continuousAggregatePosterior
    (μ : Measure X) (q : X → Y → ℝ) (y : Y) : ℝ :=
  ∫ x, q x y ∂μ

/-- Continuous source bias formula relative to the aggregate-posterior reference. -/
noncomputable def continuousAggregateBias
    (μ : Measure X) (q : X → Y → ℝ) (rule : X → Y) (y : Y) : ℝ :=
  continuousMarginalLabelShare μ rule y - continuousAggregatePosterior μ q y

/-- Continuous source bias formula relative to an arbitrary reference distribution. -/
noncomputable def continuousBias
    (μ : Measure X) (rule : X → Y) (pref : Y → ℝ) (y : Y) : ℝ :=
  continuousMarginalLabelShare μ rule y - pref y

/-- Continuous predictive MAE for a posterior classifier. -/
noncomputable def continuousClassifierMAE
    (μ : Measure X) (q : X → Y → ℝ) : ℝ :=
  ∫ x, Finite.paperConditionalMAE q x ∂μ

/-- Pointwise posterior-simplex assumptions for a continuous classifier. -/
def PosteriorSimplex (q : X → Y → ℝ) : Prop :=
  (∀ x, (∑ a : Y, q x a) = 1) ∧
    (∀ x a, 0 ≤ q x a) ∧
      (∀ x a, q x a ≤ 1)

theorem posterior_coord_le_one_of_sum_nonneg
    {X Y : Type*} [Fintype Y] (q : X → Y → ℝ) (x : X) (y : Y)
    (hsum : (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ a : Y, 0 ≤ q x a) :
    q x y ≤ 1 := by
  have hy_mem : y ∈ (Finset.univ : Finset Y) := Finset.mem_univ y
  have hle_sum : q x y ≤ ∑ a : Y, q x a :=
    Finset.single_le_sum (fun a _ => hnonneg a) hy_mem
  simpa [hsum] using hle_sum

theorem PosteriorSimplex.of_sum_nonneg
    [Fintype Y] (q : X → Y → ℝ)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x a, 0 ≤ q x a) :
    PosteriorSimplex q :=
  ⟨hsum, hnonneg, fun x y =>
    posterior_coord_le_one_of_sum_nonneg q x y (hsum x) (hnonneg x)⟩

theorem sum_uniform_inverse_card_eq_one
    {Y : Type*} [Fintype Y] (z : Y) :
    (∑ _ : Y, (Fintype.card Y : ℝ)⁻¹) = 1 := by
  rw [Finset.sum_const, Finset.card_univ]
  have hcard : (Fintype.card Y : ℝ) ≠ 0 := by
    exact_mod_cast (Fintype.card_pos_iff.mpr ⟨z⟩).ne'
  rw [nsmul_eq_mul]
  field_simp [hcard]

theorem uniform_inverse_card_nonneg
    {Y : Type*} [Fintype Y] :
    0 ≤ (Fintype.card Y : ℝ)⁻¹ :=
  inv_nonneg.mpr (Nat.cast_nonneg (Fintype.card Y))

theorem uniform_inverse_card_pos
    {Y : Type*} [Fintype Y] (z : Y) :
    0 < (Fintype.card Y : ℝ)⁻¹ := by
  have hcard_pos : 0 < Fintype.card Y :=
    Fintype.card_pos_iff.mpr ⟨z⟩
  exact inv_pos.mpr (by exact_mod_cast hcard_pos)

theorem uniform_inverse_card_le_one
    {Y : Type*} [Fintype Y] (z : Y) :
    (Fintype.card Y : ℝ)⁻¹ ≤ 1 := by
  have hcard_pos : 0 < Fintype.card Y :=
    Fintype.card_pos_iff.mpr ⟨z⟩
  have hcard_ge_one : (1 : ℝ) ≤ (Fintype.card Y : ℝ) := by
    exact_mod_cast (Nat.succ_le_of_lt hcard_pos)
  exact inv_le_one_of_one_le₀ hcard_ge_one

theorem uniform_inverse_card_lt_one_of_one_lt_card
    {Y : Type*} [Fintype Y] (hcard_gt_one : 1 < Fintype.card Y) :
    (Fintype.card Y : ℝ)⁻¹ < 1 := by
  have hcard_gt_one_real : (1 : ℝ) < (Fintype.card Y : ℝ) := by
    exact_mod_cast hcard_gt_one
  exact inv_lt_one_of_one_lt₀ hcard_gt_one_real

theorem uniform_inverse_card_le_half_of_one_lt_card
    {Y : Type*} [Fintype Y] (hcard_gt_one : 1 < Fintype.card Y) :
    (Fintype.card Y : ℝ)⁻¹ ≤ (1 / 2 : ℝ) := by
  have hcard_ge_two_nat : 2 ≤ Fintype.card Y :=
    Nat.succ_le_iff.mpr hcard_gt_one
  have hcard_ge_two : (2 : ℝ) ≤ (Fintype.card Y : ℝ) := by
    exact_mod_cast hcard_ge_two_nat
  have hcard_pos : 0 < (Fintype.card Y : ℝ) :=
    lt_of_lt_of_le (by norm_num) hcard_ge_two
  have htwo_pos : 0 < (2 : ℝ) := by norm_num
  have hle : (Fintype.card Y : ℝ)⁻¹ ≤ (2 : ℝ)⁻¹ :=
    (inv_le_inv₀ hcard_pos htwo_pos).mpr hcard_ge_two
  simpa using hle

theorem exists_coord_lt_uniform_of_coord_gt_uniform
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) (z : Y)
    (hsum : (∑ a : Y, q a) = 1)
    (hz : (Fintype.card Y : ℝ)⁻¹ < q z) :
    ∃ y : Y, y ≠ z ∧ q y < (Fintype.card Y : ℝ)⁻¹ := by
  classical
  by_contra hnone
  have hle : ∀ y ∈ (Finset.univ : Finset Y),
      (Fintype.card Y : ℝ)⁻¹ ≤ q y := by
    intro y _
    by_cases hy : y = z
    · simpa [hy] using hz.le
    · have hnot_lt : ¬ q y < (Fintype.card Y : ℝ)⁻¹ := by
        intro hlt
        exact hnone ⟨y, hy, hlt⟩
      exact le_of_not_gt hnot_lt
  have hstrict :
      ∃ y ∈ (Finset.univ : Finset Y),
        (Fintype.card Y : ℝ)⁻¹ < q y :=
    ⟨z, Finset.mem_univ z, hz⟩
  have hsum_lt :
      (∑ y : Y, (Fintype.card Y : ℝ)⁻¹) < ∑ y : Y, q y :=
    Finset.sum_lt_sum hle hstrict
  rw [sum_uniform_inverse_card_eq_one z, hsum] at hsum_lt
  exact (lt_irrefl (1 : ℝ)) hsum_lt

theorem exists_coord_gt_uniform_of_coord_lt_uniform
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) (z : Y)
    (hsum : (∑ a : Y, q a) = 1)
    (hz : q z < (Fintype.card Y : ℝ)⁻¹) :
    ∃ y : Y, y ≠ z ∧ (Fintype.card Y : ℝ)⁻¹ < q y := by
  classical
  by_contra hnone
  have hle : ∀ y ∈ (Finset.univ : Finset Y),
      q y ≤ (Fintype.card Y : ℝ)⁻¹ := by
    intro y _
    by_cases hy : y = z
    · simpa [hy] using hz.le
    · have hnot_lt : ¬ (Fintype.card Y : ℝ)⁻¹ < q y := by
        intro hlt
        exact hnone ⟨y, hy, hlt⟩
      exact le_of_not_gt hnot_lt
  have hstrict :
      ∃ y ∈ (Finset.univ : Finset Y),
        q y < (Fintype.card Y : ℝ)⁻¹ :=
    ⟨z, Finset.mem_univ z, hz⟩
  have hsum_lt :
      (∑ y : Y, q y) < ∑ y : Y, (Fintype.card Y : ℝ)⁻¹ :=
    Finset.sum_lt_sum hle hstrict
  rw [hsum, sum_uniform_inverse_card_eq_one z] at hsum_lt
  exact (lt_irrefl (1 : ℝ)) hsum_lt

theorem sum_nonfocal_deviation_from_uniform
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) (z : Y)
    (hsum : (∑ a : Y, q a) = 1) :
    Finset.sum (Finset.univ.erase z)
        (fun a : Y => q a - (Fintype.card Y : ℝ)⁻¹) =
      (Fintype.card Y : ℝ)⁻¹ - q z := by
  classical
  let u : ℝ := (Fintype.card Y : ℝ)⁻¹
  have hq_decomp :
      Finset.sum (Finset.univ.erase z) q + q z =
        ∑ a : Y, q a :=
    Finset.sum_erase_add (Finset.univ : Finset Y) q (Finset.mem_univ z)
  have hq_erase :
      Finset.sum (Finset.univ.erase z) q = 1 - q z := by
    linarith
  have hu_sum : (∑ _ : Y, u) = 1 := by
    simpa [u] using sum_uniform_inverse_card_eq_one z
  have hu_decomp :
      Finset.sum (Finset.univ.erase z) (fun _ : Y => u) + u =
        ∑ _ : Y, u :=
    Finset.sum_erase_add (Finset.univ : Finset Y) (fun _ : Y => u)
      (Finset.mem_univ z)
  have hu_erase :
      Finset.sum (Finset.univ.erase z) (fun _ : Y => u) = 1 - u := by
    linarith
  rw [Finset.sum_sub_distrib, hq_erase, hu_erase]
  ring

theorem sum_nonfocal_deviation_from_uniform_at
    {X Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : X → Y → ℝ) (x : X) (z : Y)
    (hsum : (∑ a : Y, q x a) = 1) :
    Finset.sum (Finset.univ.erase z)
        (fun a : Y => q x a - (Fintype.card Y : ℝ)⁻¹) =
      (Fintype.card Y : ℝ)⁻¹ - q x z :=
  sum_nonfocal_deviation_from_uniform (fun a : Y => q x a) z hsum

theorem sum_nonfocal_deviation_from_uniform_neg_of_coord_gt_uniform
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) (z : Y)
    (hsum : (∑ a : Y, q a) = 1)
    (hz : (Fintype.card Y : ℝ)⁻¹ < q z) :
    Finset.sum (Finset.univ.erase z)
        (fun a : Y => q a - (Fintype.card Y : ℝ)⁻¹) < 0 := by
  rw [sum_nonfocal_deviation_from_uniform q z hsum]
  linarith

theorem sum_nonfocal_deviation_from_uniform_pos_of_coord_lt_uniform
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) (z : Y)
    (hsum : (∑ a : Y, q a) = 1)
    (hz : q z < (Fintype.card Y : ℝ)⁻¹) :
    0 < Finset.sum (Finset.univ.erase z)
        (fun a : Y => q a - (Fintype.card Y : ℝ)⁻¹) := by
  rw [sum_nonfocal_deviation_from_uniform q z hsum]
  linarith

theorem norm_paperConditionalMAE_le_one_of_sum_nonneg
    {X Y : Type*} [Fintype Y] (q : X → Y → ℝ) (x : X)
    (hsum : (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ a : Y, 0 ≤ q x a) :
    ‖Finite.paperConditionalMAE q x‖ ≤ 1 := by
  classical
  have hle_one : ∀ a : Y, q x a ≤ 1 :=
    fun a => posterior_coord_le_one_of_sum_nonneg q x a hsum hnonneg
  have hnonneg_mae : 0 ≤ Finite.paperConditionalMAE q x := by
    unfold Finite.paperConditionalMAE
    refine Finset.sum_nonneg ?_
    intro a _
    exact mul_nonneg (hnonneg a) (sub_nonneg.mpr (hle_one a))
  rw [Real.norm_eq_abs, abs_of_nonneg hnonneg_mae]
  unfold Finite.paperConditionalMAE
  calc
    (∑ a : Y, q x a * (1 - q x a)) ≤ ∑ a : Y, q x a := by
      refine Finset.sum_le_sum ?_
      intro a _
      have hsub_le_one : 1 - q x a ≤ 1 := by linarith [hnonneg a]
      simpa using mul_le_mul_of_nonneg_left hsub_le_one (hnonneg a)
    _ = 1 := hsum

theorem paperConditionalMAE_eq_zero_of_coord_eq_one
    {X Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : X → Y → ℝ) (x : X) (z : Y)
    (hsum : (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ a : Y, 0 ≤ q x a)
    (hz : q x z = 1) :
    Finite.paperConditionalMAE q x = 0 := by
  classical
  have hsumErase :
      Finset.sum (Finset.univ.erase z) (fun a : Y => q x a) = 0 := by
    have hdecomp :
        Finset.sum (Finset.univ.erase z) (fun a : Y => q x a) + q x z =
          ∑ a : Y, q x a :=
      Finset.sum_erase_add (Finset.univ : Finset Y) (fun a : Y => q x a)
        (Finset.mem_univ z)
    linarith
  have hzero_of_ne : ∀ a : Y, a ≠ z → q x a = 0 := by
    intro a hne
    have ha_mem : a ∈ (Finset.univ.erase z) := by
      simp [hne]
    have hle_sum :
        q x a ≤ Finset.sum (Finset.univ.erase z) (fun b : Y => q x b) :=
      Finset.single_le_sum (fun b _ => hnonneg b) ha_mem
    have hle_zero : q x a ≤ 0 := by
      simpa [hsumErase] using hle_sum
    exact le_antisymm hle_zero (hnonneg a)
  unfold Finite.paperConditionalMAE
  refine Finset.sum_eq_zero ?_
  intro a _
  by_cases ha : a = z
  · simp [ha, hz]
  · simp [hzero_of_ne a ha]

theorem paperConditionalMAE_eq_zero_of_exists_coord_eq_one
    {X Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : X → Y → ℝ) (x : X)
    (hsum : (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ a : Y, 0 ≤ q x a)
    (hone : ∃ z : Y, q x z = 1) :
    Finite.paperConditionalMAE q x = 0 := by
  rcases hone with ⟨z, hz⟩
  exact paperConditionalMAE_eq_zero_of_coord_eq_one q x z hsum hnonneg hz

/-- Posterior MAE is nonnegative for pointwise simplex-valued scores. -/
theorem paperConditionalMAE_nonneg_of_sum_nonneg
    {X Y : Type*} [Fintype Y]
    (q : X → Y → ℝ) (x : X)
    (hsum : (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ a : Y, 0 ≤ q x a) :
    0 ≤ Finite.paperConditionalMAE q x := by
  have hle_one : ∀ a : Y, q x a ≤ 1 :=
    fun a => posterior_coord_le_one_of_sum_nonneg q x a hsum hnonneg
  unfold Finite.paperConditionalMAE
  refine Finset.sum_nonneg ?_
  intro a _
  exact mul_nonneg (hnonneg a) (sub_nonneg.mpr (hle_one a))

/--
For a simplex posterior, the paper conditional MAE is at least twice the focal
coordinate times its nonfocal complement.  This is the vector-level inequality
needed by the multiclass-safe collapse-to-focal source patch.
-/
theorem paperConditionalMAE_ge_two_focal_mul_deficit
    {X Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : X → Y → ℝ) (x : X) (z : Y)
    (hsum : (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ a : Y, 0 ≤ q x a) :
    2 * q x z * (1 - q x z) ≤ Finite.paperConditionalMAE q x := by
  classical
  let p : ℝ := 1 - q x z
  have hle_one_z : q x z ≤ 1 :=
    posterior_coord_le_one_of_sum_nonneg q x z hsum hnonneg
  have hp_nonneg : 0 ≤ p := by
    dsimp [p]
    linarith
  have hsumErase :
      Finset.sum (Finset.univ.erase z) (fun a : Y => q x a) = p := by
    have hdecomp :
        Finset.sum (Finset.univ.erase z) (fun a : Y => q x a) + q x z =
          ∑ a : Y, q x a :=
      Finset.sum_erase_add (Finset.univ : Finset Y) (fun a : Y => q x a)
        (Finset.mem_univ z)
    dsimp [p]
    linarith
  have hnonfocal_lb :
      p * q x z ≤
        Finset.sum (Finset.univ.erase z)
          (fun a : Y => q x a * (1 - q x a)) := by
    calc
      p * q x z =
          (Finset.sum (Finset.univ.erase z) (fun a : Y => q x a)) * q x z := by
            rw [hsumErase]
      _ = Finset.sum (Finset.univ.erase z) (fun a : Y => q x a * q x z) := by
            rw [Finset.sum_mul]
      _ ≤ Finset.sum (Finset.univ.erase z)
            (fun a : Y => q x a * (1 - q x a)) := by
            refine Finset.sum_le_sum ?_
            intro a ha
            have ha_le_p : q x a ≤ p := by
              have hle_sum :
                  q x a ≤ Finset.sum (Finset.univ.erase z)
                    (fun b : Y => q x b) :=
                Finset.single_le_sum (fun b _ => hnonneg b) ha
              simpa [hsumErase] using hle_sum
            have hz_le_deficit : q x z ≤ 1 - q x a := by
              dsimp [p] at ha_le_p
              linarith
            exact mul_le_mul_of_nonneg_left hz_le_deficit (hnonneg a)
  have hmae_decomp :
      Finite.paperConditionalMAE q x =
        q x z * (1 - q x z) +
          Finset.sum (Finset.univ.erase z)
            (fun a : Y => q x a * (1 - q x a)) := by
    unfold Finite.paperConditionalMAE
    have hdecomp :
        Finset.sum (Finset.univ.erase z)
            (fun a : Y => q x a * (1 - q x a)) +
          q x z * (1 - q x z) =
            ∑ a : Y, q x a * (1 - q x a) :=
      Finset.sum_erase_add (Finset.univ : Finset Y)
        (fun a : Y => q x a * (1 - q x a)) (Finset.mem_univ z)
    linarith
  calc
    2 * q x z * (1 - q x z) =
        q x z * p + p * q x z := by
          dsimp [p]
          ring
    _ ≤ q x z * (1 - q x z) +
        Finset.sum (Finset.univ.erase z)
          (fun a : Y => q x a * (1 - q x a)) := by
          dsimp [p]
          linarith
    _ = Finite.paperConditionalMAE q x := hmae_decomp.symm

/-- The focal-one/all-other-zero posterior has total mass one. -/
theorem posteriorSum_focal_one_else_zero
    {Y : Type*} [Fintype Y] [DecidableEq Y] (z : Y) :
    (∑ a : Y, if a = z then (1 : ℝ) else 0) = 1 := by
  classical
  rw [Finset.sum_eq_single z]
  · simp
  · intro b _ hb
    simp [hb]
  · intro hz
    exact False.elim (hz (Finset.mem_univ z))

/-- The focal-one/all-other-zero posterior is pointwise nonnegative. -/
theorem posteriorNonneg_focal_one_else_zero
    {Y : Type*} [DecidableEq Y] (z a : Y) :
    0 ≤ if a = z then (1 : ℝ) else 0 := by
  by_cases ha : a = z <;> simp [ha]

/-- A posterior that puts all mass on one focal label has zero paper MAE. -/
theorem paperConditionalMAE_eq_zero_of_focal_one_else_zero
    {X Y : Type*} [Fintype Y] [DecidableEq Y]
    (qNext : X → Y → ℝ) (x : X) (z : Y)
    (hshape : ∀ a : Y, qNext x a = if a = z then (1 : ℝ) else 0) :
    Finite.paperConditionalMAE qNext x = 0 := by
  classical
  unfold Finite.paperConditionalMAE
  refine Finset.sum_eq_zero ?_
  intro a _
  by_cases ha : a = z
  · subst a
    simp [hshape z]
  · rw [hshape a]
    simp [ha]

/--
Multiclass-safe patched `S_b -> S_a` pointwise move: setting the focal label
to one and every nonfocal label to zero weakly decreases paper MAE for any
simplex-valued original posterior.
-/
theorem paperConditionalMAE_collapse_to_focal_one_le
    {X Y : Type*} [Fintype Y] [DecidableEq Y]
    (q qNext : X → Y → ℝ) (x xNext : X) (z : Y)
    (hsum : (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ a : Y, 0 ≤ q x a)
    (hshape : ∀ a : Y, qNext xNext a = if a = z then (1 : ℝ) else 0) :
    Finite.paperConditionalMAE qNext xNext ≤ Finite.paperConditionalMAE q x := by
  have hzero :
      Finite.paperConditionalMAE qNext xNext = 0 :=
    paperConditionalMAE_eq_zero_of_focal_one_else_zero qNext xNext z hshape
  have hnonneg_mae : 0 ≤ Finite.paperConditionalMAE q x :=
    paperConditionalMAE_nonneg_of_sum_nonneg q x hsum hnonneg
  linarith

theorem paperConditionalMAE_eq_one_sub_uniform_of_all_eq_uniform
    {X Y : Type*} [Fintype Y] (q : X → Y → ℝ) (x : X) (z : Y)
    (hall : ∀ a : Y, q x a = (Fintype.card Y : ℝ)⁻¹) :
    Finite.paperConditionalMAE q x =
      1 - (Fintype.card Y : ℝ)⁻¹ := by
  unfold Finite.paperConditionalMAE
  simp [hall]
  have hcard : (Fintype.card Y : ℝ) ≠ 0 := by
    exact_mod_cast (Fintype.card_pos_iff.mpr ⟨z⟩).ne'
  field_simp [hcard]

/--
Pointwise MAE algebra for the `S_b -> S_a` part of the source
transformation.

Only two coordinates change: the focal coordinate `z` is raised to `1`, and a
nonfocal coordinate `w` is lowered by the same amount.  The exact change in
the posterior MAE sum is the displayed negative product.
-/
theorem posteriorMAESum_twoCoordinate_raise_focal_to_one
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w) :
    let q' : Y → ℝ :=
      fun a => if a = z then 1 else if a = w then q w - (1 - q z) else q a
    (∑ a : Y, q' a * (1 - q' a)) -
        ∑ a : Y, q a * (1 - q a) =
      -2 * (1 - q w) * (1 - q z) := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then 1 else if a = w then q w - (1 - q z) else q a
  let fnew : Y → ℝ := fun a => q' a * (1 - q' a)
  let fold : Y → ℝ := fun a => q a * (1 - q a)
  have hsum :
      (∑ a : Y, fnew a) =
        (∑ a : Y, fold a) + (fnew z - fold z) + (fnew w - fold w) := by
    exact EconCSLib.FiniteSum.sum_eq_sum_add_sub_add_sub_of_eq_off
      (f := fnew) (g := fold) (a := z) (b := w) hzw
      (by
        intro a haz haw
        simp [fnew, fold, q', haz, haw])
  have hdiff :
      (∑ a : Y, fnew a) - ∑ a : Y, fold a =
        (fnew z - fold z) + (fnew w - fold w) := by
    linarith
  calc
    (∑ a : Y, q' a * (1 - q' a)) -
        ∑ a : Y, q a * (1 - q a) =
        (fnew z - fold z) + (fnew w - fold w) := by
        simpa [fnew, fold] using hdiff
    _ = -2 * (1 - q w) * (1 - q z) := by
        simp [fnew, fold, q', hzw.symm]
        ring

/--
Pointwise MAE algebra for the `S_b -> S_c` part of the source
transformation.

The focal coordinate is lowered to the uniform value `u`, and the same mass is
added to one nonfocal coordinate.  The exact MAE change is the corresponding
two-coordinate product.
-/
theorem posteriorMAESum_twoCoordinate_lower_focal_to_uniform
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w) (u : ℝ) :
    let q' : Y → ℝ :=
      fun a => if a = z then u else if a = w then q w + (q z - u) else q a
    (∑ a : Y, q' a * (1 - q' a)) -
        ∑ a : Y, q a * (1 - q a) =
      -2 * (u - q w) * (u - q z) := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then u else if a = w then q w + (q z - u) else q a
  let fnew : Y → ℝ := fun a => q' a * (1 - q' a)
  let fold : Y → ℝ := fun a => q a * (1 - q a)
  have hsum :
      (∑ a : Y, fnew a) =
        (∑ a : Y, fold a) + (fnew z - fold z) + (fnew w - fold w) := by
    exact EconCSLib.FiniteSum.sum_eq_sum_add_sub_add_sub_of_eq_off
      (f := fnew) (g := fold) (a := z) (b := w) hzw
      (by
        intro a haz haw
        simp [fnew, fold, q', haz, haw])
  have hdiff :
      (∑ a : Y, fnew a) - ∑ a : Y, fold a =
        (fnew z - fold z) + (fnew w - fold w) := by
    linarith
  calc
    (∑ a : Y, q' a * (1 - q' a)) -
        ∑ a : Y, q a * (1 - q a) =
        (fnew z - fold z) + (fnew w - fold w) := by
        simpa [fnew, fold] using hdiff
    _ = -2 * (u - q w) * (u - q z) := by
        simp [fnew, fold, q', hzw.symm]
        ring

/--
Pointwise MAE algebra for the `S_d -> S_c` part of the source
transformation.

The focal coordinate is raised to the uniform value `u`, and the same mass is
removed from a nonfocal coordinate.
-/
theorem posteriorMAESum_twoCoordinate_raise_focal_to_uniform
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w) (u : ℝ) :
    let q' : Y → ℝ :=
      fun a => if a = z then u else if a = w then q w - (u - q z) else q a
    (∑ a : Y, q' a * (1 - q' a)) -
        ∑ a : Y, q a * (1 - q a) =
      -2 * (u - q w) * (u - q z) := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then u else if a = w then q w - (u - q z) else q a
  let fnew : Y → ℝ := fun a => q' a * (1 - q' a)
  let fold : Y → ℝ := fun a => q a * (1 - q a)
  have hsum :
      (∑ a : Y, fnew a) =
        (∑ a : Y, fold a) + (fnew z - fold z) + (fnew w - fold w) := by
    exact EconCSLib.FiniteSum.sum_eq_sum_add_sub_add_sub_of_eq_off
      (f := fnew) (g := fold) (a := z) (b := w) hzw
      (by
        intro a haz haw
        simp [fnew, fold, q', haz, haw])
  have hdiff :
      (∑ a : Y, fnew a) - ∑ a : Y, fold a =
        (fnew z - fold z) + (fnew w - fold w) := by
    linarith
  calc
    (∑ a : Y, q' a * (1 - q' a)) -
        ∑ a : Y, q a * (1 - q a) =
        (fnew z - fold z) + (fnew w - fold w) := by
        simpa [fnew, fold] using hdiff
    _ = -2 * (u - q w) * (u - q z) := by
        simp [fnew, fold, q', hzw.symm]
        ring

/--
Pointwise MAE algebra for the `S_d -> S_e` part of the source
transformation.

The focal coordinate is lowered to `0`, and the same mass is added to one
nonfocal coordinate.
-/
theorem posteriorMAESum_twoCoordinate_lower_focal_to_zero
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w) :
    let q' : Y → ℝ :=
      fun a => if a = z then 0 else if a = w then q w + q z else q a
    (∑ a : Y, q' a * (1 - q' a)) -
        ∑ a : Y, q a * (1 - q a) =
      -2 * q w * q z := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then 0 else if a = w then q w + q z else q a
  let fnew : Y → ℝ := fun a => q' a * (1 - q' a)
  let fold : Y → ℝ := fun a => q a * (1 - q a)
  have hsum :
      (∑ a : Y, fnew a) =
        (∑ a : Y, fold a) + (fnew z - fold z) + (fnew w - fold w) := by
    exact EconCSLib.FiniteSum.sum_eq_sum_add_sub_add_sub_of_eq_off
      (f := fnew) (g := fold) (a := z) (b := w) hzw
      (by
        intro a haz haw
        simp [fnew, fold, q', haz, haw])
  have hdiff :
      (∑ a : Y, fnew a) - ∑ a : Y, fold a =
        (fnew z - fold z) + (fnew w - fold w) := by
    linarith
  calc
    (∑ a : Y, q' a * (1 - q' a)) -
        ∑ a : Y, q a * (1 - q a) =
        (fnew z - fold z) + (fnew w - fold w) := by
        simpa [fnew, fold] using hdiff
    _ = -2 * q w * q z := by
        simp [fnew, fold, q', hzw.symm]
        ring

/--
The `S_b -> S_a` two-coordinate move weakly decreases posterior MAE whenever
the two affected original coordinates are at most one.
-/
theorem posteriorMAESum_twoCoordinate_raise_focal_to_one_le
    {Y : Type*} [Fintype Y] [DecidableEq Y]
    (q : Y → ℝ) {z w : Y} (hzw : z ≠ w)
    (hw_le_one : q w ≤ 1) (hz_le_one : q z ≤ 1) :
    let q' : Y → ℝ :=
      fun a => if a = z then 1 else if a = w then q w - (1 - q z) else q a
    (∑ a : Y, q' a * (1 - q' a)) ≤
      ∑ a : Y, q a * (1 - q a) := by
  classical
  let q' : Y → ℝ :=
    fun a => if a = z then 1 else if a = w then q w - (1 - q z) else q a
  have hdelta :=
    posteriorMAESum_twoCoordinate_raise_focal_to_one q hzw
  have hprod_nonneg : 0 ≤ (1 - q w) * (1 - q z) :=
    mul_nonneg (sub_nonneg.mpr hw_le_one) (sub_nonneg.mpr hz_le_one)
  have hdelta_nonpos : -2 * (1 - q w) * (1 - q z) ≤ 0 := by
    have hmul : -2 * ((1 - q w) * (1 - q z)) ≤ 0 :=
      mul_nonpos_of_nonpos_of_nonneg (by norm_num) hprod_nonneg
    simpa [mul_assoc] using hmul
  dsimp only at hdelta ⊢
  linarith

