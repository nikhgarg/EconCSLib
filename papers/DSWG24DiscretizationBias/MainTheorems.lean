/-- Bayesian consistency: the reference distribution agrees with the aggregate posterior. -/
def BayesianConsistent
    (μ : Measure X) (q : X → Y → ℝ) (pref : Y → ℝ) : Prop :=
  ∀ y, pref y = continuousAggregatePosterior μ q y

/--
Continuous interval splitting for the source proof of Theorem 1(iii).

When the feature space has been refined by a non-atomic real coordinate, the
paper expands one side of a candidate split continuously until the two
calibration-preservation integrals balance.  This lemma formalizes that
intermediate-value step: if the left and right weights are nonnegative on the
same interval, then some cut equates the left mass accumulated before the cut
with the right mass remaining after it.
-/
theorem exists_source_balancing_interval_cut
    {μ : Measure ℝ} [NoAtoms μ] {lo hi : ℝ}
    {leftWeight rightWeight : ℝ → ℝ}
    (hlohi : lo ≤ hi)
    (hleftInt : IntegrableOn leftWeight (Icc lo hi) μ)
    (hrightInt : IntegrableOn rightWeight (Icc lo hi) μ)
    (hleft_nonneg : ∀ x, x ∈ Icc lo hi → 0 ≤ leftWeight x)
    (hright_nonneg : ∀ x, x ∈ Icc lo hi → 0 ≤ rightWeight x) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      (∫ x in lo..cut, leftWeight x ∂μ) =
        ∫ x in cut..hi, rightWeight x ∂μ := by
  let balance : ℝ → ℝ := fun cut =>
    (∫ x in lo..cut, leftWeight x ∂μ) -
      ∫ x in cut..hi, rightWeight x ∂μ
  have hleftIntU : IntegrableOn leftWeight (uIcc lo hi) μ := by
    simpa [uIcc, hlohi] using hleftInt
  have hrightIntU : IntegrableOn rightWeight (uIcc lo hi) μ := by
    simpa [uIcc, hlohi] using hrightInt
  have hleftCont :
      ContinuousOn (fun cut => ∫ x in lo..cut, leftWeight x ∂μ) (Icc lo hi) := by
    simpa [uIcc, hlohi] using
      (intervalIntegral.continuousOn_primitive_interval (μ := μ) hleftIntU)
  have hrightCont :
      ContinuousOn (fun cut => ∫ x in cut..hi, rightWeight x ∂μ) (Icc lo hi) := by
    simpa [uIcc, hlohi] using
      (intervalIntegral.continuousOn_primitive_interval_left (μ := μ) hrightIntU)
  have hbalanceCont : ContinuousOn balance (Icc lo hi) :=
    hleftCont.sub hrightCont
  have hbalance_lo : balance lo ≤ 0 := by
    dsimp [balance]
    rw [intervalIntegral.integral_same]
    have hnonneg_right : 0 ≤ ∫ x in lo..hi, rightWeight x ∂μ :=
      intervalIntegral.integral_nonneg hlohi hright_nonneg
    linarith
  have hbalance_hi : 0 ≤ balance hi := by
    dsimp [balance]
    rw [intervalIntegral.integral_same]
    have hnonneg_left : 0 ≤ ∫ x in lo..hi, leftWeight x ∂μ :=
      intervalIntegral.integral_nonneg hlohi hleft_nonneg
    linarith
  have hzero_mem : (0 : ℝ) ∈ Icc (balance lo) (balance hi) :=
    ⟨hbalance_lo, hbalance_hi⟩
  rcases (intermediate_value_Icc hlohi hbalanceCont hzero_mem) with
    ⟨cut, hcut, hcut_zero⟩
  refine ⟨cut, hcut, ?_⟩
  dsimp [balance] at hcut_zero
  linarith

/--
Interval-sweep split for an arbitrary measurable subregion.

The paper's "expand a set continuously" step can be implemented on a real
feature coordinate by sweeping the subregion `S` with the ordered family
`S ∩ (lo, cut]`.  This is just the interval-cut lemma applied to
indicator-weighted left and right integrands.
-/
theorem exists_source_balancing_subset_interval_cut
    {μ : Measure ℝ} [NoAtoms μ] {lo hi : ℝ} {S : Set ℝ}
    {leftWeight rightWeight : ℝ → ℝ}
    (hlohi : lo ≤ hi)
    (hleftInt : IntegrableOn (S.indicator leftWeight) (Icc lo hi) μ)
    (hrightInt : IntegrableOn (S.indicator rightWeight) (Icc lo hi) μ)
    (hleft_nonneg : ∀ x, x ∈ S → x ∈ Icc lo hi → 0 ≤ leftWeight x)
    (hright_nonneg : ∀ x, x ∈ S → x ∈ Icc lo hi → 0 ≤ rightWeight x) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      (∫ x in lo..cut, S.indicator leftWeight x ∂μ) =
        ∫ x in cut..hi, S.indicator rightWeight x ∂μ := by
  refine exists_source_balancing_interval_cut
    (μ := μ) (lo := lo) (hi := hi)
    (leftWeight := S.indicator leftWeight)
    (rightWeight := S.indicator rightWeight)
    hlohi hleftInt hrightInt ?_ ?_
  · intro x hxI
    by_cases hxS : x ∈ S
    · simp [Set.indicator, hxS, hleft_nonneg x hxS hxI]
    · simp [Set.indicator, hxS]
  · intro x hxI
    by_cases hxS : x ∈ S
    · simp [Set.indicator, hxS, hright_nonneg x hxS hxI]
    · simp [Set.indicator, hxS]

theorem integrableOn_of_measurable_norm_le
    {μ : Measure ℝ} {s : Set ℝ} {f : ℝ → ℝ} {C : ℝ}
    (hsfinite : μ s < ⊤) (hf : Measurable f)
    (hbound : ∀ x, ‖f x‖ ≤ C) :
    IntegrableOn f s μ :=
  IntegrableOn.of_bound hsfinite
    (hf.aestronglyMeasurable.mono_measure Measure.restrict_le_self)
    C (Filter.Eventually.of_forall hbound)

theorem integrableOn_score_of_measurable_unit_interval
    {μ : Measure ℝ} {s : Set ℝ} {qz : ℝ → ℝ}
    (hsfinite : μ s < ⊤) (hqz : Measurable qz)
    (hnonneg : ∀ x, 0 ≤ qz x) (hle_one : ∀ x, qz x ≤ 1) :
    IntegrableOn qz s μ :=
  integrableOn_of_measurable_norm_le hsfinite hqz (C := 1) (fun x => by
    rw [Real.norm_eq_abs, abs_of_nonneg (hnonneg x)]
    exact hle_one x)

/--
Source Step 1 split for `S_b`.

On an interval where `q_z(x)` lies between the uniform score `1/K` and `1`,
there is a cut satisfying Equation (17):
`∫_{S_{b to c}} (q_z - 1/K) = ∫_{S_{b to a}} (1 - q_z)`.
-/
theorem exists_source_Sb_balancing_interval_cut
    {μ : Measure ℝ} [NoAtoms μ] {lo hi invK : ℝ} {qz : ℝ → ℝ}
    (hlohi : lo ≤ hi)
    (hleftInt : IntegrableOn (fun x => qz x - invK) (Icc lo hi) μ)
    (hrightInt : IntegrableOn (fun x => 1 - qz x) (Icc lo hi) μ)
    (hscore_ge : ∀ x, x ∈ Icc lo hi → invK ≤ qz x)
    (hscore_le_one : ∀ x, x ∈ Icc lo hi → qz x ≤ 1) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      (∫ x in lo..cut, (qz x - invK) ∂μ) =
        ∫ x in cut..hi, (1 - qz x) ∂μ :=
  exists_source_balancing_interval_cut hlohi hleftInt hrightInt
    (fun x hx => sub_nonneg.mpr (hscore_ge x hx))
    (fun x hx => sub_nonneg.mpr (hscore_le_one x hx))

theorem exists_source_Sb_balancing_interval_cut_of_measurable_bounded
    {μ : Measure ℝ} [NoAtoms μ] {lo hi invK : ℝ} {qz : ℝ → ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : μ (Icc lo hi) < ⊤)
    (hqz : Measurable qz)
    (hnonneg : ∀ x, 0 ≤ qz x)
    (hle_one : ∀ x, qz x ≤ 1)
    (hscore_ge : ∀ x, x ∈ Icc lo hi → invK ≤ qz x) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      (∫ x in lo..cut, (qz x - invK) ∂μ) =
        ∫ x in cut..hi, (1 - qz x) ∂μ := by
  have hqzInt : IntegrableOn qz (Icc lo hi) μ :=
    integrableOn_score_of_measurable_unit_interval hfinite hqz hnonneg hle_one
  have hconstInvK : IntegrableOn (fun _ : ℝ => invK) (Icc lo hi) μ :=
    integrableOn_const (μ := μ) (s := Icc lo hi) (C := invK) (ne_of_lt hfinite)
  have hconstOne : IntegrableOn (fun _ : ℝ => (1 : ℝ)) (Icc lo hi) μ :=
    integrableOn_const (μ := μ) (s := Icc lo hi) (C := (1 : ℝ)) (ne_of_lt hfinite)
  exact exists_source_Sb_balancing_interval_cut hlohi
    (hqzInt.sub hconstInvK) (hconstOne.sub hqzInt)
    hscore_ge (fun x _ => hle_one x)

/--
Source Step 2 split for `S_d`.

On an interval where `q_z(x)` lies between `0` and the uniform score `1/K`,
there is a cut satisfying the analogous balance equation used before moving
mass to `S_c` and `S_e`.
-/
theorem exists_source_Sd_balancing_interval_cut
    {μ : Measure ℝ} [NoAtoms μ] {lo hi invK : ℝ} {qz : ℝ → ℝ}
    (hlohi : lo ≤ hi)
    (hleftInt : IntegrableOn qz (Icc lo hi) μ)
    (hrightInt : IntegrableOn (fun x => invK - qz x) (Icc lo hi) μ)
    (hscore_nonneg : ∀ x, x ∈ Icc lo hi → 0 ≤ qz x)
    (hscore_le : ∀ x, x ∈ Icc lo hi → qz x ≤ invK) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      (∫ x in lo..cut, qz x ∂μ) =
        ∫ x in cut..hi, (invK - qz x) ∂μ :=
  exists_source_balancing_interval_cut hlohi hleftInt hrightInt
    hscore_nonneg
    (fun x hx => sub_nonneg.mpr (hscore_le x hx))

theorem exists_source_Sd_balancing_interval_cut_of_measurable_bounded
    {μ : Measure ℝ} [NoAtoms μ] {lo hi invK : ℝ} {qz : ℝ → ℝ}
    (hlohi : lo ≤ hi)
    (hfinite : μ (Icc lo hi) < ⊤)
    (hqz : Measurable qz)
    (hnonneg : ∀ x, 0 ≤ qz x)
    (hle_one : ∀ x, qz x ≤ 1)
    (hscore_le : ∀ x, x ∈ Icc lo hi → qz x ≤ invK) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      (∫ x in lo..cut, qz x ∂μ) =
        ∫ x in cut..hi, (invK - qz x) ∂μ := by
  have hqzInt : IntegrableOn qz (Icc lo hi) μ :=
    integrableOn_score_of_measurable_unit_interval hfinite hqz hnonneg hle_one
  have hconstInvK : IntegrableOn (fun _ : ℝ => invK) (Icc lo hi) μ :=
    integrableOn_const (μ := μ) (s := Icc lo hi) (C := invK) (ne_of_lt hfinite)
  exact exists_source_Sd_balancing_interval_cut hlohi
    hqzInt (hconstInvK.sub hqzInt)
    (fun x _ => hnonneg x) hscore_le

/--
Source Step 1 split for an interval known to lie inside the focal region `S_b`.
-/
theorem exists_source_Sb_balancing_interval_cut_of_region_subset
    {Y : Type*} {μ : Measure ℝ} [NoAtoms μ] {lo hi invK : ℝ}
    {q : ℝ → Y → ℝ} {z : Y}
    (hlohi : lo ≤ hi)
    (hleftInt : IntegrableOn (fun x => q x z - invK) (Icc lo hi) μ)
    (hrightInt : IntegrableOn (fun x => 1 - q x z) (Icc lo hi) μ)
    (hregion : ∀ x, x ∈ Icc lo hi → x ∈ sourceSbRegion q z invK) :
    ∃ cut : ℝ, cut ∈ Icc lo hi ∧
      (∫ x in lo..cut, (q x z - invK) ∂μ) =
        ∫ x in cut..hi, (1 - q x z) ∂μ :=
