          continuousJointAggregatePosterior μ qNext z =
            continuousJointAggregatePosterior μ q z ∧
          (∫ xy : X × Y,
              (Finite.paperConditionalMAE qNext xy.1 -
                Finite.paperConditionalMAE q xy.1) ∂μ) ≤ 0 := by
  classical
  let T : X × Y → ℝ × Y := featureCoordinateJointMap (Y := Y) r
  let μR : Measure (ℝ × Y) := Measure.map T μ
  have hT : Measurable T := measurable_featureCoordinateJointMap (Y := Y) hr
  haveI : IsFiniteMeasure μR := by
    dsimp [μR]
    infer_instance
  have hfst :
      Measure.map Prod.fst μR =
        Measure.map r (Measure.map Prod.fst μ) := by
    simpa [μR, T] using
      featureCoordinateJointMap_fst_marginal (Y := Y) μ hr
