/--
Source Step 1 interval split with nonfocal selector and aggregate MAE-delta
accounting in one endpoint.

This packages the source proof's continuous `S_b` step: the theorem chooses a
balancing cut and a below-uniform nonfocal selector, then proves the total
two-coordinate MAE delta is nonpositive once the resulting integrands are
integrable.
-/
theorem sourceSb_interval_split_exists_nonfocal_twoCoordinate_delta_integral_nonpos_uniform_simplex_finite
    {Y : Type*} [MeasurableSpace Y] [MeasurableSingletonClass Y]
    [Fintype Y] [DecidableEq Y]
    (μ : Measure (ℝ × Y)) [IsFiniteMeasure μ]
    [NoAtoms (Measure.map Prod.fst μ)]
    (q : ℝ → Y → ℝ) (z : Y) {lo hi : ℝ}
    (hcard_gt_one : 1 < Fintype.card Y)
    (hlohi : lo ≤ hi)
    (hfinite : (Measure.map Prod.fst μ) (Icc lo hi) < ⊤)
    (hqz : Measurable fun x : ℝ => q x z)
    (hsum : ∀ x, (∑ a : Y, q x a) = 1)
    (hnonneg : ∀ x y, 0 ≤ q x y)
    (hregion :
      ∀ x, x ∈ Icc lo hi →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹)
    (hAInt :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) →
        Integrable
          (fun xy : ℝ × Y =>
            (Prod.fst ⁻¹' Ioc cut hi).indicator (fun xy : ℝ × Y =>
              -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
            ) xy) μ)
    (hBInt :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) →
        Integrable
          (fun xy : ℝ × Y =>
            (Prod.fst ⁻¹' Ioc lo cut).indicator (fun xy : ℝ × Y =>
              -2 * ((Fintype.card Y : ℝ)⁻¹ - q xy.1 (w xy)) *
                ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
            ) xy) μ)
    (hAUpperInt :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) →
        Integrable
          (fun xy : ℝ × Y =>
            (-2 * (1 - (Fintype.card Y : ℝ)⁻¹)) *
              (Prod.fst ⁻¹' Ioc cut hi).indicator
                (fun xy : ℝ × Y => 1 - q xy.1 z) xy) μ)
    (hBUpperInt :
      ∀ cut (w : ℝ × Y → Y), cut ∈ Icc lo hi →
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) →
        Integrable
          (fun xy : ℝ × Y =>
            (2 * (Fintype.card Y : ℝ)⁻¹) *
              (Prod.fst ⁻¹' Ioc lo cut).indicator
                (fun xy : ℝ × Y =>
                  q xy.1 z - (Fintype.card Y : ℝ)⁻¹) xy) μ) :
    ∃ cut : ℝ, ∃ w : ℝ × Y → Y,
      cut ∈ Icc lo hi ∧
        (∀ xy : ℝ × Y, xy.1 ∈ Ioc cut hi ∪ Ioc lo cut →
          w xy ≠ z ∧ q xy.1 (w xy) < (Fintype.card Y : ℝ)⁻¹) ∧
        (∫ xy : ℝ × Y,
            (Prod.fst ⁻¹' Ioc cut hi).indicator (fun xy : ℝ × Y =>
              -2 * (1 - q xy.1 (w xy)) * (1 - q xy.1 z)
            ) xy +
            (Prod.fst ⁻¹' Ioc lo cut).indicator (fun xy : ℝ × Y =>
              -2 * ((Fintype.card Y : ℝ)⁻¹ - q xy.1 (w xy)) *
                ((Fintype.card Y : ℝ)⁻¹ - q xy.1 z)
            ) xy ∂μ) ≤ 0 := by
  classical
  rcases sourceSb_interval_split_exists_nonfocal_selector_product_balance_simplex_finite
      μ q z hlohi hfinite hqz hsum hnonneg hregion with
    ⟨cut, w, hcut, hsel, hbalance⟩
  have hSbaRegion :
      ∀ x, x ∈ Ioc cut hi →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹ := by
    intro x hx
    exact hregion x ⟨hcut.1.trans hx.1.le, hx.2⟩
  have hSbcRegion :
      ∀ x, x ∈ Ioc lo cut →
        x ∈ sourceSbRegion q z (Fintype.card Y : ℝ)⁻¹ := by
    intro x hx
    exact hregion x ⟨hx.1.le, hx.2.trans hcut.2⟩
  refine ⟨cut, w, hcut, hsel, ?_⟩
  exact
    sourceSb_split_twoCoordinate_delta_integral_nonpos_of_balance_uniform_region
      μ q (Ioc cut hi) (Ioc lo cut) z w hcard_gt_one
      (hAInt cut w hcut hsel) (hBInt cut w hcut hsel)
      (hAUpperInt cut w hcut hsel) (hBUpperInt cut w hcut hsel)
      hSbaRegion hSbcRegion
      (Filter.Eventually.of_forall fun xy hxy => (hsel xy hxy).2.le)
