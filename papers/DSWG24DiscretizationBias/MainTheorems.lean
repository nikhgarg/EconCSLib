      integral_fst_preimage_indicator_eq_featureMarginal_integral
        μ (S ∩ Ioc lo cut) (fun x : ℝ => q x z - u)
        (hS.inter measurableSet_Ioc) ((hq z).sub measurable_const)
    have hright :
        (∫ xy : ℝ × Y,
            (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator
