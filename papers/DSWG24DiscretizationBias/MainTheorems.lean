/-- Sigma-algebra generated by the score coordinate `q_y(X)`. -/
@[reducible] noncomputable def scoreSigma
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (q : X → Y → ℝ) (y : Y) : MeasurableSpace (X × Y) :=
  MeasurableSpace.comap (fun xy : X × Y => q xy.1 y) (borel ℝ)

/--
Conditional-expectation calibration for a continuous score.

This is the Mathlib conditional-expectation version of the paper's display
`Pr(Y = y | q_y(X)) = q_y(X)`: for each label, the conditional expectation of
the true label indicator with respect to the sigma-algebra generated by the
score coordinate is almost surely the score itself.
-/
noncomputable def ConditionalExpectationCalibration
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) : Prop :=
  ∀ y : Y,
    μ[(fun xy : X × Y => if xy.2 = y then (1 : ℝ) else 0) | scoreSigma q y] =ᵐ[μ]
      fun xy => q xy.1 y

/--
Kernel calibration using Mathlib's standard-Borel conditional-expectation
kernel.

For each label, integrating the true label indicator against
`condExpKernel μ (scoreSigma q y)` recovers the score almost surely.  This is a
regular-kernel version of the same calibration bridge used by
`ConditionalExpectationCalibration`.
-/
noncomputable def ConditionalExpectationKernelCalibration
    {X Y : Type*} [MeasurableSpace (X × Y)] [StandardBorelSpace (X × Y)]
    [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] (q : X → Y → ℝ) : Prop :=
  ∀ y : Y,
    (fun xy : X × Y =>
      ∫ z, (if z.2 = y then (1 : ℝ) else 0) ∂
        ProbabilityTheory.condExpKernel μ (scoreSigma q y) xy) =ᵐ[μ]
      fun xy => q xy.1 y

theorem conditionalExpectationCalibration_of_condExpKernelCalibration
    {X Y : Type*} [MeasurableSpace (X × Y)] [StandardBorelSpace (X × Y)]
    [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun xy : X × Y => q xy.1 y))
    (hlabelInt : ∀ y : Y,
      Integrable (fun xy : X × Y => if xy.2 = y then (1 : ℝ) else 0) μ)
    (hcal : ConditionalExpectationKernelCalibration μ q) :
    ConditionalExpectationCalibration μ q := by
  intro y
  let f : X × Y → ℝ := fun xy => if xy.2 = y then (1 : ℝ) else 0
  have hhm : scoreSigma q y ≤ ‹MeasurableSpace (X × Y)› :=
    Measurable.comap_le (hscore y)
  have hkernel :
      μ[f | scoreSigma q y] =ᵐ[μ]
        fun xy => ∫ z, f z ∂ProbabilityTheory.condExpKernel μ (scoreSigma q y) xy := by
    exact ProbabilityTheory.condExp_ae_eq_integral_condExpKernel hhm (hlabelInt y)
  exact hkernel.trans (hcal y)

/--
Measure-theoretic calibration for a continuous score.

For every label `y` and every measurable score event `s`, the true label-`y`
mass among observations whose score falls in `s` equals the aggregate score
mass on that same event.  This is the event-preimage form of
`E[1{Y = y} | q_y(X)] = q_y(X)`.
-/
noncomputable def ContinuousCalibration
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) : Prop := by
  classical
  exact
    ∀ (y : Y) (s : Set ℝ), MeasurableSet s →
      (∫ xy, (if q xy.1 y ∈ s then
          if xy.2 = y then (1 : ℝ) else 0
        else 0) ∂μ) =
        ∫ xy, (if q xy.1 y ∈ s then q xy.1 y else 0) ∂μ

/-- Mass of the score fiber `{q_y(X)=c}` under the joint distribution. -/
noncomputable def scoreFiberMass
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (y : Y) (c : ℝ) : ℝ :=
  ∫ xy, (if q xy.1 y = c then (1 : ℝ) else 0) ∂μ

/-- True label-`y` mass on the score fiber `{q_y(X)=c}`. -/
noncomputable def scoreFiberLabelMass
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (y : Y) (c : ℝ) : ℝ :=
  ∫ xy, (if q xy.1 y = c then
      if xy.2 = y then (1 : ℝ) else 0
    else 0) ∂μ

/--
Positive-mass score-fiber calibration.

This is a literal finite-mass reading of the source notation
`Pr(Y = y | q_y(X)=c) = c`: on every score fiber with positive mass, the true
label-`y` mass divided by the fiber mass equals the score value.
-/
def ScoreFiberConditionalCalibration
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) : Prop :=
  ∀ (y : Y) (c : ℝ), 0 < scoreFiberMass μ q y c →
    scoreFiberLabelMass μ q y c / scoreFiberMass μ q y c = c

/--
Event-preimage calibration implies the literal positive-mass score-fiber
conditional-probability statement by applying calibration to the singleton
score event `{c}`.
-/
theorem scoreFiberConditionalCalibration_of_continuousCalibration
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (hcal : ContinuousCalibration μ q) :
    ScoreFiberConditionalCalibration μ q := by
  classical
  intro y c hpos
  have h := hcal y ({c} : Set ℝ) (measurableSet_singleton c)
  have hlhs :
      (∫ xy, (if q xy.1 y ∈ ({c} : Set ℝ) then
          if xy.2 = y then (1 : ℝ) else 0
        else 0) ∂μ) = scoreFiberLabelMass μ q y c := by
    simp [scoreFiberLabelMass]
  have hrhs :
      (∫ xy, (if q xy.1 y ∈ ({c} : Set ℝ) then q xy.1 y else 0) ∂μ) =
        c * scoreFiberMass μ q y c := by
    unfold scoreFiberMass
    calc
      (∫ xy, (if q xy.1 y ∈ ({c} : Set ℝ) then q xy.1 y else 0) ∂μ) =
          ∫ xy, c * (if q xy.1 y = c then (1 : ℝ) else 0) ∂μ := by
            refine integral_congr_ae (Filter.Eventually.of_forall ?_)
            intro xy
            by_cases hqc : q xy.1 y = c <;> simp [hqc]
      _ = c * ∫ xy, (if q xy.1 y = c then (1 : ℝ) else 0) ∂μ := by
            rw [integral_const_mul]
  have hnum : scoreFiberLabelMass μ q y c = c * scoreFiberMass μ q y c := by
    calc
      scoreFiberLabelMass μ q y c =
          ∫ xy, (if q xy.1 y ∈ ({c} : Set ℝ) then
            if xy.2 = y then (1 : ℝ) else 0
          else 0) ∂μ := hlhs.symm
      _ = ∫ xy, (if q xy.1 y ∈ ({c} : Set ℝ) then q xy.1 y else 0) ∂μ := h
      _ = c * scoreFiberMass μ q y c := hrhs
  have hne : scoreFiberMass μ q y c ≠ 0 := ne_of_gt hpos
  calc
    scoreFiberLabelMass μ q y c / scoreFiberMass μ q y c =
        (c * scoreFiberMass μ q y c) / scoreFiberMass μ q y c := by
          rw [hnum]
    _ = c := by
          exact mul_div_cancel_right₀ c hne

/--
Mathlib conditional-expectation calibration implies the event-preimage
calibration interface used by the direct paper wrapper.

The integrability assumption is the one required by Mathlib's
`setIntegral_condExp` theorem for integrating conditional expectations over
score-measurable events.
-/
theorem continuousCalibration_of_condExpCalibration
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun xy : X × Y => q xy.1 y))
    (hlabelInt : ∀ y : Y,
      Integrable (fun xy : X × Y => if xy.2 = y then (1 : ℝ) else 0) μ)
    (htrim : ∀ y : Y, SigmaFinite (μ.trim (Measurable.comap_le (hscore y))))
    (hcal : ConditionalExpectationCalibration μ q) :
    ContinuousCalibration μ q := by
  classical
  intro y s hs
  let t : Set (X × Y) := {xy | q xy.1 y ∈ s}
  let f : X × Y → ℝ := fun xy => if xy.2 = y then (1 : ℝ) else 0
  have hhm : scoreSigma q y ≤ ‹MeasurableSpace (X × Y)› :=
    Measurable.comap_le (hscore y)
  haveI : SigmaFinite (μ.trim hhm) := by
    exact htrim y
  have ht_score : @MeasurableSet (X × Y) (scoreSigma q y) t := by
    exact ⟨s, hs, rfl⟩
  have ht_ambient : MeasurableSet t :=
    MeasurableSet.preimage hs (hscore y)
  have hset :
      (∫ xy in t, μ[f | scoreSigma q y] xy ∂μ) = ∫ xy in t, f xy ∂μ := by
    exact setIntegral_condExp hhm (hlabelInt y) ht_score
  have hcond_q :
      (∫ xy in t, μ[f | scoreSigma q y] xy ∂μ) =
        ∫ xy in t, q xy.1 y ∂μ := by
    exact integral_congr_ae (ae_restrict_of_ae (hcal y))
  have hset_f_q : (∫ xy in t, f xy ∂μ) = ∫ xy in t, q xy.1 y ∂μ :=
    hset.symm.trans hcond_q
  calc
    (∫ xy, (if q xy.1 y ∈ s then
        if xy.2 = y then (1 : ℝ) else 0
      else 0) ∂μ)
        = ∫ xy, t.indicator f xy ∂μ := by
          simp [t, f, Set.indicator]
    _ = ∫ xy in t, f xy ∂μ := by
          exact integral_indicator ht_ambient
    _ = ∫ xy in t, q xy.1 y ∂μ := hset_f_q
    _ = ∫ xy, t.indicator (fun xy : X × Y => q xy.1 y) xy ∂μ := by
          exact (integral_indicator ht_ambient).symm
    _ = ∫ xy, (if q xy.1 y ∈ s then q xy.1 y else 0) ∂μ := by
          simp [t, Set.indicator]

theorem continuousCalibration_of_condExpKernelCalibration
    {X Y : Type*} [MeasurableSpace (X × Y)] [StandardBorelSpace (X × Y)]
    [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] (q : X → Y → ℝ)
    (hscore : ∀ y : Y, Measurable (fun xy : X × Y => q xy.1 y))
    (hlabelInt : ∀ y : Y,
      Integrable (fun xy : X × Y => if xy.2 = y then (1 : ℝ) else 0) μ)
    (hcal : ConditionalExpectationKernelCalibration μ q) :
    ContinuousCalibration μ q := by
  classical
  have htrim : ∀ y : Y,
      SigmaFinite (μ.trim (Measurable.comap_le (hscore y))) := by
    intro y
    infer_instance
  exact continuousCalibration_of_condExpCalibration
    μ q hscore hlabelInt htrim
    (conditionalExpectationCalibration_of_condExpKernelCalibration
      μ q hscore hlabelInt hcal)

theorem scoreFiberConditionalCalibration_of_condExpCalibration
