        ∫ x, (S ∩ Ioc cut hi).indicator (fun x : ℝ => u - q x z) x
          ∂(Measure.map Prod.fst μ) := by
    have hleft :
        (∫ xy : ℝ × Y,
            (Prod.fst ⁻¹' (S ∩ Ioc cut hi)).indicator
