/-- Continuous prior/share of a label under a joint feature-label distribution. -/
noncomputable def continuousJointPrior
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (y : Y) : ℝ :=
  ∫ xy, (if xy.2 = y then (1 : ℝ) else 0) ∂μ

/-- Continuous decision share under a joint feature-label distribution. -/
noncomputable def continuousJointDecisionShare
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (rule : X → Y) (y : Y) : ℝ :=
  ∫ xy, (if rule xy.1 = y then (1 : ℝ) else 0) ∂μ

/-- Continuous prior-reference bias under a joint feature-label distribution. -/
noncomputable def continuousJointPriorBias
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) (rule : X → Y) (y : Y) : ℝ :=
  continuousJointDecisionShare μ rule y - continuousJointPrior μ y

/-- Joint-distribution aggregate posterior, integrating the feature posterior over `F_{X,Y}`. -/
noncomputable def continuousJointAggregatePosterior
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) (y : Y) : ℝ :=
  ∫ xy, q xy.1 y ∂μ

/-- Joint-distribution predictive MAE, integrating the feature conditional MAE over `F_{X,Y}`. -/
noncomputable def continuousJointClassifierMAE
    {X Y : Type*} [MeasurableSpace (X × Y)] [Fintype Y]
    (μ : Measure (X × Y)) (q : X → Y → ℝ) : ℝ :=
  ∫ xy, Finite.paperConditionalMAE q xy.1 ∂μ

/-- Label indicators are integrable under finite joint laws once measurable. -/
theorem integrable_jointLabelIndicator_of_finite
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] (z : Y)
    (hmeas :
      AEStronglyMeasurable (fun xy : X × Y => if xy.2 = z then (1 : ℝ) else 0)
        μ) :
    Integrable (fun xy : X × Y => if xy.2 = z then (1 : ℝ) else 0) μ := by
  refine Integrable.of_bound hmeas 1 ?_
  filter_upwards with xy
  by_cases h : xy.2 = z <;> simp [h]

/-- Decision indicators are integrable under finite joint laws once measurable. -/
theorem integrable_jointDecisionIndicator_of_finite
    {X Y : Type*} [MeasurableSpace (X × Y)] [DecidableEq Y]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ] (rule : X → Y) (z : Y)
    (hmeas :
      AEStronglyMeasurable
        (fun xy : X × Y => if rule xy.1 = z then (1 : ℝ) else 0) μ) :
    Integrable (fun xy : X × Y => if rule xy.1 = z then (1 : ℝ) else 0) μ := by
  refine Integrable.of_bound hmeas 1 ?_
  filter_upwards with xy
  by_cases h : rule xy.1 = z <;> simp [h]

theorem integrable_jointScore_of_bounds_finite
    {X Y : Type*} [MeasurableSpace (X × Y)]
    (μ : Measure (X × Y)) [IsFiniteMeasure μ]
    (q : X → Y → ℝ) (z : Y)
    (hmeas : AEStronglyMeasurable (fun xy : X × Y => q xy.1 z) μ)
    (hnonneg : ∀ x, 0 ≤ q x z)
    (hle_one : ∀ x, q x z ≤ 1) :
    Integrable (fun xy : X × Y => q xy.1 z) μ := by
  refine Integrable.of_bound hmeas 1 ?_
  filter_upwards with xy
  rw [Real.norm_eq_abs, abs_of_nonneg (hnonneg xy.1)]
  exact hle_one xy.1

/-- Feature-space decision indicators are integrable under finite laws once measurable. -/
