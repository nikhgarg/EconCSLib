    (CAccOld CAccNew CFidOld CFidNew : ℝ)
    (haccOldMeas :
      AEStronglyMeasurable
        (fun sample =>
          datasetAccuracyScore
            (fun i y => posterior (sample i).1 y) (policy sample))
        (iidSampleMeasure (randomizedKernelAugmentedLaw μ κ) N))
    (haccOldBound :
      ∀ᵐ sample ∂iidSampleMeasure (randomizedKernelAugmentedLaw μ κ) N,
