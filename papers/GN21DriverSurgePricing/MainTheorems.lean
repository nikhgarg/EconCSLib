    (hmR_pos : 0 < m - R1)
    (hR1_nonneg : 0 ‚â§ R1)
    (hT1_nonneg : 0 ‚â§ T1)
    (hQ1_pos : 0 < Q1)
    (hswitch21_pos : 0 < switch21)
    (hsum : 0 < switch21 + switch12)
    (hswitch_lt_Q2 : switch21 < Q2)
    (hgap_nonneg : 0 ‚â§ switch21 * T2 - Q2) :
    Lemma9SurgeDerivativeCertificate where
  ratio := ratio
  T1 := T1
  Q1 := Q1
  Tbar2 := T2
  Qbar2 := Q2
  switch21 := switch21
