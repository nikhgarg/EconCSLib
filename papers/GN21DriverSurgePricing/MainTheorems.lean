      theorem3FeasibilityThresholdC T1 T2 Q1 Q2 switch12 < rho)
    (hrho_lt_one : rho < 1)
    (hT1_pos : 0 < T1)
    (hQ1_pos : 0 < Q1)
    (hQ1_sub_switch12_pos : 0 < Q1 - switch12)
    (hden_theorem3_pos :
      0 < theorem3FeasibilityDenominator T1 T2 Q1 Q2 switch12)
    (hswitch21_pos : 0 < switch21)
    (hgap2_nonneg : 0 ‚â§ switch21 * T2 - Q2)
    (hT2_ge_one : 1 ‚â§ T2)
    (hswitch21_lt_Q2 : switch21 < Q2)
    (hweak :
      ‚àÄ m z : Fin 2 ‚Üí ‚Ñù,
        (0 ‚â§ m 0 ‚àß 0 ‚â§ m 1 ‚àß 0 ‚â§ z 1) ‚Üí
        (‚àÉ nonsurgeRatio surgeRatio : ‚Ñù,
          lemma10StructuredBounds nonsurgeRatio T2 Q2 T1 Q1 switch12 ‚àß
