/-- Paper cross-state subcycle probability `p_{ij} = Q_i/(Œª_i F_i+Œª_{i‚Üíj})`. -/
def gn21CrossSubcycleProb
    (arrivalRate acceptProb switchRate exitWeight : ‚Ñù) : ‚Ñù :=
  exitWeight / (arrivalRate * acceptProb + switchRate)

/-- Time fraction from renewal-cycle subcycle probabilities and subcycle lengths. -/
def gn21TimeFractionFromCycles
    (otherToThisProb thisSubcycleLength thisToOtherProb otherSubcycleLength : ‚Ñù) : ‚Ñù :=
  otherToThisProb * thisSubcycleLength /
    (otherToThisProb * thisSubcycleLength +
      thisToOtherProb * otherSubcycleLength)

/-- Lemma 3 displayed time-fraction formula for state `i`. -/
def gn21TimeFractionFormula
    (arrivalI acceptI timeI exitWeightJ
      arrivalJ acceptJ timeJ exitWeightI : ‚Ñù) : ‚Ñù :=
  arrivalI * acceptI * timeI * exitWeightJ /
    (arrivalJ * acceptJ * timeJ * exitWeightI +
      arrivalI * acceptI * timeI * exitWeightJ)

/-- Lemma 3 displayed time-fraction formula using the paper's measured `T_i` and `Q_i`. -/
def gn21MeasuredTimeFraction
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (œÉI œÉJ : TripPolicy) : ‚Ñù :=
  gn21TimeFractionFormula
    arrivalI (singleStateTripMass ŒºI œÉI)
    (gn21StateCycleTime ŒºI arrivalI œÉI)
    (gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ)
    arrivalJ (singleStateTripMass ŒºJ œÉJ)
    (gn21StateCycleTime ŒºJ arrivalJ œÉJ)
    (gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI)

/-- The two displayed time-fraction formulas for states `i` and `j` add to one. -/
theorem gn21TimeFractionFormula_add_swap_eq_one
    (arrivalI acceptI timeI exitWeightJ
      arrivalJ acceptJ timeJ exitWeightI : ‚Ñù)
    (hden :
      arrivalJ * acceptJ * timeJ * exitWeightI +
          arrivalI * acceptI * timeI * exitWeightJ ‚âÝ 0) :
    gn21TimeFractionFormula arrivalI acceptI timeI exitWeightJ
        arrivalJ acceptJ timeJ exitWeightI +
      gn21TimeFractionFormula arrivalJ acceptJ timeJ exitWeightI
        arrivalI acceptI timeI exitWeightJ = 1 := by
  unfold gn21TimeFractionFormula
  have hden' :
      arrivalI * acceptI * timeI * exitWeightJ +
          arrivalJ * acceptJ * timeJ * exitWeightI ‚âÝ 0 := by
    simpa [add_comm] using hden
  field_simp [hden, hden']
  ring

/-- Lemma 3 measured time fractions for the two states add to one. -/
theorem paper_lemma3_measured_time_fractions_sum_to_one
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (œÉI œÉJ : TripPolicy)
    (hden :
      arrivalJ * singleStateTripMass ŒºJ œÉJ *
            gn21StateCycleTime ŒºJ arrivalJ œÉJ *
            gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI +
          arrivalI * singleStateTripMass ŒºI œÉI *
            gn21StateCycleTime ŒºI arrivalI œÉI *
            gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ ‚âÝ 0) :
    gn21MeasuredTimeFraction ŒºI ŒºJ arrivalI arrivalJ switchIJ switchJI œÉI œÉJ +
      gn21MeasuredTimeFraction ŒºJ ŒºI arrivalJ arrivalI switchJI switchIJ œÉJ œÉI =
        1 := by
  unfold gn21MeasuredTimeFraction
  exact gn21TimeFractionFormula_add_swap_eq_one
    arrivalI (singleStateTripMass ŒºI œÉI)
    (gn21StateCycleTime ŒºI arrivalI œÉI)
    (gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ)
    arrivalJ (singleStateTripMass ŒºJ œÉJ)
    (gn21StateCycleTime ŒºJ arrivalJ œÉJ)
    (gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI)
    hden

/--
Lemma 3 algebra: substituting the paper's subcycle length and transition
probability formulas into the renewal-cycle expression gives the displayed
closed form for `Œº_i`.
-/
theorem paper_lemma3_time_fraction_formula_algebra
    (arrivalI acceptI switchI timeI exitWeightI
      arrivalJ acceptJ switchJ timeJ exitWeightJ : ‚Ñù)
    (hi : arrivalI * acceptI + switchI ‚âÝ 0)
    (hj : arrivalJ * acceptJ + switchJ ‚âÝ 0) :
    gn21TimeFractionFromCycles
        (gn21CrossSubcycleProb arrivalJ acceptJ switchJ exitWeightJ)
        (gn21SubcycleLength arrivalI acceptI switchI timeI)
        (gn21CrossSubcycleProb arrivalI acceptI switchI exitWeightI)
        (gn21SubcycleLength arrivalJ acceptJ switchJ timeJ)
      =
        gn21TimeFractionFormula arrivalI acceptI timeI exitWeightJ
          arrivalJ acceptJ timeJ exitWeightI := by
  unfold gn21TimeFractionFromCycles gn21CrossSubcycleProb gn21SubcycleLength
    gn21TimeFractionFormula
  field_simp [hi, hj]
  ring

/--
Lemma 3 measured algebra: once the continuous `T_i(œÉ_i)` and `Q_i(œÉ_i)` set
integrals have been defined, the subcycle expression reduces to the displayed
time-fraction formula.
-/
theorem paper_lemma3_measured_time_fraction_formula_algebra
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (œÉI œÉJ : TripPolicy)
    (hi : arrivalI * singleStateTripMass ŒºI œÉI + switchIJ ‚âÝ 0)
    (hj : arrivalJ * singleStateTripMass ŒºJ œÉJ + switchJI ‚âÝ 0) :
    gn21TimeFractionFromCycles
        (gn21CrossSubcycleProb arrivalJ (singleStateTripMass ŒºJ œÉJ) switchJI
          (gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ))
        (gn21SubcycleLength arrivalI (singleStateTripMass ŒºI œÉI) switchIJ
          (gn21StateCycleTime ŒºI arrivalI œÉI))
        (gn21CrossSubcycleProb arrivalI (singleStateTripMass ŒºI œÉI) switchIJ
          (gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI))
        (gn21SubcycleLength arrivalJ (singleStateTripMass ŒºJ œÉJ) switchJI
          (gn21StateCycleTime ŒºJ arrivalJ œÉJ))
      =
        gn21MeasuredTimeFraction ŒºI ŒºJ arrivalI arrivalJ switchIJ switchJI œÉI œÉJ := by
  unfold gn21MeasuredTimeFraction
  exact paper_lemma3_time_fraction_formula_algebra
    arrivalI (singleStateTripMass ŒºI œÉI) switchIJ
    (gn21StateCycleTime ŒºI arrivalI œÉI)
    (gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI)
    arrivalJ (singleStateTripMass ŒºJ œÉJ) switchJI
    (gn21StateCycleTime ŒºJ arrivalJ œÉJ)
    (gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ)
    hi hj

/-!
Lemma 1 decomposes dynamic earnings into state reward rates and time fractions.
The continuous renewal-reward and CTMC cycle construction is still the source
proof obligation; the definitions and theorem below close the displayed
reward-rate cancellation once subcycle earnings and lengths have been reduced
to their common cycle factor.
-/

/-- Paper subcycle earnings with the same cycle factor as subcycle length. -/
def gn21SubcycleEarning
    (arrivalRate acceptProb switchRate meanEarning : ‚Ñù) : ‚Ñù :=
  (arrivalRate * acceptProb) / (arrivalRate * acceptProb + switchRate) *
    meanEarning

/-- Paper one-state reward rate `W_i / T_i`. -/
def gn21StateRewardRate (meanEarning stateCycleTime : ‚Ñù) : ‚Ñù :=
  meanEarning / stateCycleTime

/-- Lemma 1 mean earning per accepted trip, `W_i(œÉ_i)`. -/
def gn21StateMeanEarning
    (Œº : Measure TripLength) (w : PricingFunction) (œÉ : TripPolicy) : ‚Ñù :=
  singleStateTripPayment Œº w œÉ / singleStateTripMass Œº œÉ

/-- Lemma 1 measured state reward rate `R_i(w_i,œÉ_i)=W_i(œÉ_i)/T_i(œÉ_i)`. -/
def gn21MeasuredStateRewardRate
    (Œº : Measure TripLength) (arrivalRate : ‚Ñù)
    (w : PricingFunction) (œÉ : TripPolicy) : ‚Ñù :=
  gn21StateRewardRate
    (gn21StateMeanEarning Œº w œÉ)
    (gn21StateCycleTime Œº arrivalRate œÉ)

/-- Lemma 1 dynamic reward decomposition from time fractions and state reward rates. -/
def gn21DynamicRewardFormula
    (timeFractionI rewardRateI timeFractionJ rewardRateJ : ‚Ñù) : ‚Ñù :=
  timeFractionI * rewardRateI + timeFractionJ * rewardRateJ

/--
Lemma 1 measured dynamic reward formula with the paper's measured time
fractions and one-state reward rates.
-/
def gn21MeasuredDynamicReward
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (wI wJ : PricingFunction) (œÉI œÉJ : TripPolicy) : ‚Ñù :=
  gn21DynamicRewardFormula
    (gn21MeasuredTimeFraction ŒºI ŒºJ arrivalI arrivalJ switchIJ switchJI œÉI œÉJ)
    (gn21MeasuredStateRewardRate ŒºI arrivalI wI œÉI)
    (gn21MeasuredTimeFraction ŒºJ ŒºI arrivalJ arrivalI switchJI switchIJ œÉJ œÉI)
    (gn21MeasuredStateRewardRate ŒºJ arrivalJ wJ œÉJ)

/-- Lemma 1 measured endpoint: dynamic reward decomposes into `Œº_i R_i + Œº_j R_j`. -/
theorem paper_lemma1_measured_dynamic_reward_decomposition
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (wI wJ : PricingFunction) (œÉI œÉJ : TripPolicy) :
    gn21MeasuredDynamicReward ŒºI ŒºJ arrivalI arrivalJ switchIJ switchJI
        wI wJ œÉI œÉJ =
      gn21MeasuredTimeFraction ŒºI ŒºJ arrivalI arrivalJ switchIJ switchJI œÉI œÉJ *
          gn21MeasuredStateRewardRate ŒºI arrivalI wI œÉI +
        gn21MeasuredTimeFraction ŒºJ ŒºI arrivalJ arrivalI switchJI switchIJ œÉJ œÉI *
          gn21MeasuredStateRewardRate ŒºJ arrivalJ wJ œÉJ := by
  rfl

/--
Measured one-state reward-rate algebra in Appendix-D scaled primitives:
`R_i = W_i/T_i`.
-/
theorem gn21MeasuredStateRewardRate_eq_scaled_primitives
    (Œº : Measure TripLength) (arrivalRate : ‚Ñù)
    (w : PricingFunction) (œÉ : TripPolicy)
    (hmass : singleStateTripMass Œº œÉ ‚âÝ 0)
    (harrivalMass : arrivalRate * singleStateTripMass Œº œÉ ‚âÝ 0) :
    gn21MeasuredStateRewardRate Œº arrivalRate w œÉ =
      gn21ScaledStateEarning Œº arrivalRate w œÉ /
        gn21ScaledStateTime Œº arrivalRate œÉ := by
  unfold gn21MeasuredStateRewardRate gn21StateRewardRate gn21StateMeanEarning
    gn21StateCycleTime gn21ScaledStateEarning gn21ScaledStateTime
  have harrival : arrivalRate ‚âÝ 0 := by
    intro hzero
    exact harrivalMass (by simp [hzero])
  field_simp [hmass, harrival, harrivalMass]

/--
State reward-rate equality as the scaled earning identity used in Appendix D.
This is the source-facing bridge from `R_i(w_i, œÉ_i) = R_i` to
`W_i(œÉ_i) = R_i T_i(œÉ_i)`.
-/
theorem gn21ScaledStateEarning_eq_reward_mul_scaled_time_of_measuredStateRewardRate
    (Œº : Measure TripLength) (arrivalRate rewardRate : ‚Ñù)
    (w : PricingFunction) (œÉ : TripPolicy)
    (hmass : singleStateTripMass Œº œÉ ‚âÝ 0)
    (harrivalMass : arrivalRate * singleStateTripMass Œº œÉ ‚âÝ 0)
    (hscaledTime : gn21ScaledStateTime Œº arrivalRate œÉ ‚âÝ 0)
    (hreward :
      gn21MeasuredStateRewardRate Œº arrivalRate w œÉ = rewardRate) :
    gn21ScaledStateEarning Œº arrivalRate w œÉ =
      rewardRate * gn21ScaledStateTime Œº arrivalRate œÉ := by
  have hscaled :=
    gn21MeasuredStateRewardRate_eq_scaled_primitives
      Œº arrivalRate w œÉ hmass harrivalMass
  rw [hreward] at hscaled
  have hmul :=
    congrArg (fun x => x * gn21ScaledStateTime Œº arrivalRate œÉ) hscaled
  field_simp [hscaledTime] at hmul
  exact hmul.symm

/--
Measured time-fraction algebra in Appendix-D scaled primitives:
`mu_i = T_i Q_j / (T_j Q_i + T_i Q_j)`.
-/
theorem gn21MeasuredTimeFraction_eq_scaled_primitives
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (œÉI œÉJ : TripPolicy)
    (hmassI : singleStateTripMass ŒºI œÉI ‚âÝ 0)
    (hmassJ : singleStateTripMass ŒºJ œÉJ ‚âÝ 0)
    (harrivalMassI : arrivalI * singleStateTripMass ŒºI œÉI ‚âÝ 0)
    (harrivalMassJ : arrivalJ * singleStateTripMass ŒºJ œÉJ ‚âÝ 0) :
    gn21MeasuredTimeFraction ŒºI ŒºJ arrivalI arrivalJ switchIJ switchJI œÉI œÉJ =
      gn21ScaledStateTime ŒºI arrivalI œÉI *
          gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ /
        (gn21ScaledStateTime ŒºJ arrivalJ œÉJ *
            gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI +
          gn21ScaledStateTime ŒºI arrivalI œÉI *
            gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ) := by
  unfold gn21MeasuredTimeFraction gn21TimeFractionFormula
  change
    gn21ScaledStateCycleTime ŒºI arrivalI œÉI *
          gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ /
        (gn21ScaledStateCycleTime ŒºJ arrivalJ œÉJ *
            gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI +
          gn21ScaledStateCycleTime ŒºI arrivalI œÉI *
            gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ) =
      gn21ScaledStateTime ŒºI arrivalI œÉI *
          gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ /
        (gn21ScaledStateTime ŒºJ arrivalJ œÉJ *
            gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI +
          gn21ScaledStateTime ŒºI arrivalI œÉI *
            gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ)
  rw [gn21ScaledStateCycleTime_eq_scaledStateTime ŒºI arrivalI œÉI
      hmassI harrivalMassI,
    gn21ScaledStateCycleTime_eq_scaledStateTime ŒºJ arrivalJ œÉJ
      hmassJ harrivalMassJ]

/--
Lemma 1/3 measured algebra in Appendix-D primitives: after scaling out the
arrival-rate and acceptance-mass factors, the measured two-state dynamic reward
is the aggregate quotient used in Lemma 6.
-/
theorem paper_lemma1_measured_dynamic_reward_eq_aggregate_scaled_primitives
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (wI wJ : PricingFunction) (œÉI œÉJ : TripPolicy)
    (hmassI : singleStateTripMass ŒºI œÉI ‚âÝ 0)
    (hmassJ : singleStateTripMass ŒºJ œÉJ ‚âÝ 0)
    (harrivalMassI : arrivalI * singleStateTripMass ŒºI œÉI ‚âÝ 0)
    (harrivalMassJ : arrivalJ * singleStateTripMass ŒºJ œÉJ ‚âÝ 0)
    (hscaledTimeI : gn21ScaledStateTime ŒºI arrivalI œÉI ‚âÝ 0)
    (hscaledTimeJ : gn21ScaledStateTime ŒºJ arrivalJ œÉJ ‚âÝ 0)
    (hden :
      gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI *
          gn21ScaledStateTime ŒºJ arrivalJ œÉJ +
        gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ *
          gn21ScaledStateTime ŒºI arrivalI œÉI ‚âÝ 0) :
    gn21MeasuredDynamicReward ŒºI ŒºJ arrivalI arrivalJ switchIJ switchJI
        wI wJ œÉI œÉJ =
      gn21AggregateDynamicReward
        (gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI)
        (gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ)
        (gn21ScaledStateTime ŒºI arrivalI œÉI)
        (gn21ScaledStateTime ŒºJ arrivalJ œÉJ)
        (gn21ScaledStateEarning ŒºI arrivalI wI œÉI)
        (gn21ScaledStateEarning ŒºJ arrivalJ wJ œÉJ) := by
  have hRi :=
    gn21MeasuredStateRewardRate_eq_scaled_primitives
      ŒºI arrivalI wI œÉI hmassI harrivalMassI
  have hRj :=
    gn21MeasuredStateRewardRate_eq_scaled_primitives
      ŒºJ arrivalJ wJ œÉJ hmassJ harrivalMassJ
  have hŒºi :=
    gn21MeasuredTimeFraction_eq_scaled_primitives
      ŒºI ŒºJ arrivalI arrivalJ switchIJ switchJI œÉI œÉJ
      hmassI hmassJ harrivalMassI harrivalMassJ
  have hŒºj :=
    gn21MeasuredTimeFraction_eq_scaled_primitives
      ŒºJ ŒºI arrivalJ arrivalI switchJI switchIJ œÉJ œÉI
      hmassJ hmassI harrivalMassJ harrivalMassI
  have hden_time :
      gn21ScaledStateTime ŒºJ arrivalJ œÉJ *
            gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI +
          gn21ScaledStateTime ŒºI arrivalI œÉI *
            gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ ‚âÝ 0 := by
    simpa [mul_comm, mul_left_comm, mul_assoc] using hden
  have hden_time_swap :
      gn21ScaledStateTime ŒºI arrivalI œÉI *
            gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ +
          gn21ScaledStateTime ŒºJ arrivalJ œÉJ *
            gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI ‚âÝ 0 := by
    simpa [add_comm] using hden_time
  unfold gn21MeasuredDynamicReward gn21DynamicRewardFormula
  rw [hŒºi, hŒºj, hRi, hRj]
  unfold gn21AggregateDynamicReward
  field_simp [hden, hden_time, hden_time_swap, hscaledTimeI, hscaledTimeJ]
  ring

/--
Measured two-state reward written directly in the Appendix-D `Q,T,W`
aggregate primitives.
-/
def gn21MeasuredAggregateRewardPrimitives
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (wI wJ : PricingFunction) (œÉI œÉJ : TripPolicy) : ‚Ñù :=
  gn21AggregateDynamicReward
    (gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI)
    (gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ)
    (gn21ScaledStateTime ŒºI arrivalI œÉI)
    (gn21ScaledStateTime ŒºJ arrivalJ œÉJ)
    (gn21ScaledStateEarning ŒºI arrivalI wI œÉI)
    (gn21ScaledStateEarning ŒºJ arrivalJ wJ œÉJ)

/--
Measured aggregate weak improvement from adding a disjoint left-state accepted
set whose primitive increments have nonnegative integrated Lemma 6 kernel.
-/
theorem gn21MeasuredAggregateRewardPrimitives_le_union_left_of_kernel_nonneg
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (wI wJ : PricingFunction) (œÉI œÉJ added : TripPolicy)
    (hdisjoint : Disjoint œÉI added)
    (hadded_measurable : MeasurableSet added)
    (hq_integrable_œÉ :
      IntegrableOn
        (fun œÑ : TripLength => gn21SwitchProb switchIJ switchJI œÑ) œÉI ŒºI)
    (hq_integrable_added :
      IntegrableOn
        (fun œÑ : TripLength => gn21SwitchProb switchIJ switchJI œÑ) added ŒºI)
    (htime_integrable_œÉ :
      IntegrableOn (fun œÑ : TripLength => œÑ) œÉI ŒºI)
    (htime_integrable_added :
      IntegrableOn (fun œÑ : TripLength => œÑ) added ŒºI)
    (hw_integrable_œÉ : IntegrableOn wI œÉI ŒºI)
    (hw_integrable_added : IntegrableOn wI added ŒºI)
    (hden_pos :
      0 <
        gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI *
            gn21ScaledStateTime ŒºJ arrivalJ œÉJ +
          gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ *
            gn21ScaledStateTime ŒºI arrivalI œÉI)
    (hden_add_pos :
      0 <
        (gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI +
            arrivalI *
              ‚à´ œÑ in added, gn21SwitchProb switchIJ switchJI œÑ ‚àÇŒºI) *
            gn21ScaledStateTime ŒºJ arrivalJ œÉJ +
          gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ *
            (gn21ScaledStateTime ŒºI arrivalI œÉI +
              arrivalI * ‚à´ œÑ in added, œÑ ‚àÇŒºI))
    (hQj_nonneg :
      0 ‚â§ gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ)
    (hkernel_nonneg :
      0 ‚â§
        (arrivalI * ‚à´ œÑ in added, gn21SwitchProb switchIJ switchJI œÑ ‚àÇŒºI) *
            (gn21ScaledStateEarning ŒºJ arrivalJ wJ œÉJ *
                gn21ScaledStateTime ŒºI arrivalI œÉI -
              gn21ScaledStateTime ŒºJ arrivalJ œÉJ *
                gn21ScaledStateEarning ŒºI arrivalI wI œÉI) +
          (arrivalI * ‚à´ œÑ in added, wI œÑ ‚àÇŒºI) *
            (gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI *
                gn21ScaledStateTime ŒºJ arrivalJ œÉJ +
              gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ *
                gn21ScaledStateTime ŒºI arrivalI œÉI) -
            (arrivalI * ‚à´ œÑ in added, œÑ ‚àÇŒºI) *
              (gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI *
                  gn21ScaledStateEarning ŒºJ arrivalJ wJ œÉJ +
                gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ *
                  gn21ScaledStateEarning ŒºI arrivalI wI œÉI)) :
    gn21MeasuredAggregateRewardPrimitives ŒºI ŒºJ arrivalI arrivalJ
        switchIJ switchJI wI wJ œÉI œÉJ ‚â§
      gn21MeasuredAggregateRewardPrimitives ŒºI ŒºJ arrivalI arrivalJ
        switchIJ switchJI wI wJ (œÉI ‚à™ added) œÉJ := by
  unfold gn21MeasuredAggregateRewardPrimitives
  rw [gn21ExitWeightIntegral_union ŒºI arrivalI switchIJ switchJI œÉI added
      hdisjoint hadded_measurable hq_integrable_œÉ hq_integrable_added,
    gn21ScaledStateTime_union ŒºI arrivalI œÉI added hdisjoint
      hadded_measurable htime_integrable_œÉ htime_integrable_added,
    gn21ScaledStateEarning_union ŒºI arrivalI wI œÉI added hdisjoint
      hadded_measurable hw_integrable_œÉ hw_integrable_added]
  exact
    gn21AggregateDynamicReward_le_add_left_of_kernel_nonneg
      (gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI)
      (gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ)
      (gn21ScaledStateTime ŒºI arrivalI œÉI)
      (gn21ScaledStateTime ŒºJ arrivalJ œÉJ)
      (gn21ScaledStateEarning ŒºI arrivalI wI œÉI)
      (gn21ScaledStateEarning ŒºJ arrivalJ wJ œÉJ)
      (arrivalI * ‚à´ œÑ in added, gn21SwitchProb switchIJ switchJI œÑ ‚àÇŒºI)
      (arrivalI * ‚à´ œÑ in added, œÑ ‚àÇŒºI)
      (arrivalI * ‚à´ œÑ in added, wI œÑ ‚àÇŒºI)
      hden_pos hden_add_pos hQj_nonneg hkernel_nonneg

/--
Measured aggregate weak improvement from adding a disjoint right-state accepted
set whose primitive increments have nonnegative integrated Lemma 6 kernel.
-/
theorem gn21MeasuredAggregateRewardPrimitives_le_union_right_of_kernel_nonneg
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (wI wJ : PricingFunction) (œÉI œÉJ added : TripPolicy)
    (hdisjoint : Disjoint œÉJ added)
    (hadded_measurable : MeasurableSet added)
    (hq_integrable_œÉ :
      IntegrableOn
        (fun œÑ : TripLength => gn21SwitchProb switchJI switchIJ œÑ) œÉJ ŒºJ)
    (hq_integrable_added :
      IntegrableOn
        (fun œÑ : TripLength => gn21SwitchProb switchJI switchIJ œÑ) added ŒºJ)
    (htime_integrable_œÉ :
      IntegrableOn (fun œÑ : TripLength => œÑ) œÉJ ŒºJ)
    (htime_integrable_added :
      IntegrableOn (fun œÑ : TripLength => œÑ) added ŒºJ)
    (hw_integrable_œÉ : IntegrableOn wJ œÉJ ŒºJ)
    (hw_integrable_added : IntegrableOn wJ added ŒºJ)
    (hden_pos :
      0 <
        gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI *
            gn21ScaledStateTime ŒºJ arrivalJ œÉJ +
          gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ *
            gn21ScaledStateTime ŒºI arrivalI œÉI)
    (hden_add_pos :
      0 <
        gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI *
            (gn21ScaledStateTime ŒºJ arrivalJ œÉJ +
              arrivalJ * ‚à´ œÑ in added, œÑ ‚àÇŒºJ) +
          (gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ +
            arrivalJ *
              ‚à´ œÑ in added, gn21SwitchProb switchJI switchIJ œÑ ‚àÇŒºJ) *
            gn21ScaledStateTime ŒºI arrivalI œÉI)
