  | strictlyDecreasing =>
      exact theorem4NonsurgeShape_of_lemma5_strictlyDecreasing hform
  | strictlyQuasiConvex =>
      exact False.elim hallowed
  | strictlyQuasiConcave =>
      exact theorem4NonsurgeShape_of_lemma5_strictlyQuasiConcave hform

