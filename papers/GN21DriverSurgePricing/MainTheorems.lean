            m 0 = R2 ∧
            z 0 = nonsurgeRatio * R2 ∧
            m 1 =
              theorem3SurgeMultiplierFromRatio R1 R2 T2 Q2 switch21 surgeRatio ∧
            z 1 =
              theorem3SurgeZFromRatio R1 R2 T2 Q2 switch21 surgeRatio ∧
            m 0 * (T1 - 1) + z 0 * (Q1 - switch12) = R1 * T1 ∧
