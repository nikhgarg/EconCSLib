        singleStateTripPayment Œº w replacement) :
    singleStateRenewalReward Œº arrivalRate w œÉ <
      singleStateRenewalReward Œº arrivalRate w replacement := by
  change
    renewalRewardRate arrivalRate
        (singleStateTripPayment Œº w œÉ) (singleStateTripTime Œº œÉ) <
      renewalRewardRate arrivalRate
        (singleStateTripPayment Œº w replacement)
        (singleStateTripTime Œº replacement)
  rw [htime_same]
  exact renewalRewardRate_lt_replace_reward_same_time_of_lt
    arrivalRate (singleStateTripPayment Œº w œÉ) (singleStateTripTime Œº œÉ)
    (singleStateTripPayment Œº w replacement) hlambda htime_nonneg
    hpayment_gain

/--
Theorem 1 Step 1 source swap: replacing an accepted set by an equal-utilization
set with larger total payment strictly improves reward.  The set-integral
decomposition hypotheses are the measurable algebra for
`œÉ' = (œÉ \ removed) ‚à™ added`.
-/
theorem paper_theorem1_step1_equal_utilization_swap_improves_reward
    (Œº : Measure TripLength) (arrivalRate : ‚Ñù) (w : PricingFunction)
    (œÉ removed added : TripPolicy)
    (hlambda : 0 < arrivalRate)
    (htime_nonneg : 0 ‚â§ singleStateTripTime Œº œÉ)
    (hreplacement_payment :
      singleStateTripPayment Œº w ((œÉ \ removed) ‚à™ added) =
        singleStateTripPayment Œº w œÉ -
          singleStateTripPayment Œº w removed +
            singleStateTripPayment Œº w added)
    (hreplacement_time :
      singleStateTripTime Œº ((œÉ \ removed) ‚à™ added) =
        singleStateTripTime Œº œÉ)
    (hadded_payment_gt_removed :
      singleStateTripPayment Œº w removed <
        singleStateTripPayment Œº w added) :
    singleStateRenewalReward Œº arrivalRate w œÉ <
      singleStateRenewalReward Œº arrivalRate w ((œÉ \ removed) ‚à™ added) := by
  apply paper_theorem1_step1_same_time_more_payment_improves_reward
    Œº arrivalRate w œÉ ((œÉ \ removed) ‚à™ added)
    hlambda htime_nonneg hreplacement_time
  rw [hreplacement_payment]
