          m * (T2 - 1) + z * (Q2 - switch21))
    (hbounds : lemma9StructuredBounds ratio T1 Q1 T2 Q2 switch21)
    (hz : z = ratio * (m - R1))
    (hmR_pos : 0 < m - R1)
    (hR1_nonneg : 0 ‚â§ R1)
    (hT1_nonneg : 0 ‚â§ T1)
    (hswitch21_pos : 0 < switch21)
    (hsum : 0 < switch21 + switch12)
