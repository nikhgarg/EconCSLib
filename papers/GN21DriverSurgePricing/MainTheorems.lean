/-- Middle-rejection policies have nonzero Lebesgue volume because they include a tail. -/
theorem volume_rejectMiddleTripsPolicy_ne_zero (lo hi : ‚Ñù) :
    volume (rejectMiddleTripsPolicy lo hi) ‚âÝ 0 := by
  intro hzero
  have hsubset : Set.Ioi (max hi 0) ‚äÜ rejectMiddleTripsPolicy lo hi := by
    intro œÑ hœÑ
    have h0 : 0 < œÑ := lt_of_le_of_lt (le_max_right hi 0) hœÑ
    have hhi : hi < œÑ := lt_of_le_of_lt (le_max_left hi 0) hœÑ
    exact ‚ü®h0, Or.inr hhi‚ü©
  have hle : volume (Set.Ioi (max hi 0)) ‚â§
      volume (rejectMiddleTripsPolicy lo hi) :=
    measure_mono hsubset
  have hbad : ¬¨ ((‚ä§ : ‚Ñù‚â•0‚àû) ‚â§ 0) := by simp
  exact hbad (by simpa [Real.volume_Ioi, hzero] using hle)

