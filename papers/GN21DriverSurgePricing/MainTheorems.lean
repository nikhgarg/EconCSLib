          Rmax = R2) ∨
        (0 ≤ theorem3NonsurgeZRatio rho T1 Q1 switch12 * R2 ∧
          Rmax =
            max R2
              (arrival1 *
                (theorem3NonsurgeZRatio rho T1 Q1 switch12 * R2))))
    (hRmax_zero_ratio_pos : 0 < R2 * T2 - Rmax * (T2 - 1))
    (hU_pos : 0 < U) :
    ∃ m z : Fin 2 → ℝ,
      (0 ≤ m 0 ∧ 0 ≤ m 1 ∧ 0 ≤ z 1) ∧
        (∃ nonsurgeRatio surgeRatio : ℝ,
