/--
Shared regular support gives positive surge current mass from the allowed
Lemma 5 policy-form classification.  The accept-all branch uses positive
accept-all measure; the short-tail and middle-rejection branches use the
with-density support package.
-/
theorem GN21RegularEndpointSharedSourceData.surge_current_mass_pos_of_allowed_policy_form
    {Œº : Fin 2 ‚Üí Measure TripLength}
    {arrival : Fin 2 ‚Üí ‚Ñù}
    {switch12 switch21 : ‚Ñù}
    {œÅ : Fin 2 ‚Üí TripPolicy}
    (S : GN21RegularEndpointSharedSourceData Œº arrival switch12 switch21)
    (hœÅ_feasible : dynamicFeasibleMeasurablePolicy œÅ)
    (hmeasure_acceptAll_pos : 0 < Œº 1 acceptAllPolicy)
    (hform :
      ‚àÉ shape : Lemma5DerivativeShape,
        theorem4SurgeAllowedLemma5Shape shape ‚àß
          lemma5PolicyForm shape (œÅ 1)) :
    0 < singleStateTripMass (Œº 1) (œÅ 1) := by
  rcases hform with ‚ü®shape, hallowed, hpolicy‚ü©
  cases shape with
  | positive =>
      change acceptsAllTrips (œÅ 1) at hpolicy
      have hpolicy_eq : œÅ 1 = acceptAllPolicy :=
        eq_acceptAllPolicy_of_subset_acceptAll_of_acceptsAll
          (hœÅ_feasible 1).1 hpolicy
      simpa [hpolicy_eq] using
        S.surge_acceptAll_mass_pos hmeasure_acceptAll_pos
  | strictlyIncreasing =>
      change ‚àÉ t : ‚Ñù, rejectsShortTrips t (œÅ 1) at hpolicy
      rcases hpolicy with ‚ü®t, ht‚ü©
      exact S.surge_rejectShort_current_mass_pos hœÅ_feasible ht
  | strictlyDecreasing =>
      exact False.elim
        (by simpa [theorem4SurgeAllowedLemma5Shape] using hallowed)
  | strictlyQuasiConvex =>
      change ‚àÉ lo hi : ‚Ñù, rejectsMiddleTrips lo hi (œÅ 1) at hpolicy
      rcases hpolicy with ‚ü®lo, hi, hshape‚ü©
      exact S.surge_rejectMiddle_current_mass_pos hœÅ_feasible hshape
  | strictlyQuasiConcave =>
      exact False.elim
        (by simpa [theorem4SurgeAllowedLemma5Shape] using hallowed)

/--
