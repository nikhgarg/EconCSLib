      htime_integrable_œÉ htime_integrable_rejected hq_integrable_œÉ
      hq_integrable_rejected hincrement

/--
Reverse accept-all complement specialization whose increment-ratio side
condition is discharged from a pointwise ratio comparison on rejected trips.
-/
theorem gn21FixedStateCross_ge_acceptAll_of_complement_pointwise_increment_ratio_le
    (Œº : Measure TripLength) (arrivalRate switchIJ switchJI : ‚Ñù)
    (œÉ : TripPolicy)
    (harrival_nonneg : 0 ‚â§ arrivalRate)
    (hœÉ_subset : œÉ ‚äÜ acceptAllPolicy)
    (hœÉ_measurable : MeasurableSet œÉ)
    (htime_integrable_œÉ :
      IntegrableOn (fun œÑ : TripLength => œÑ) œÉ Œº)
    (htime_integrable_rejected :
      IntegrableOn (fun œÑ : TripLength => œÑ) (acceptAllPolicy \ œÉ) Œº)
    (hq_integrable_œÉ :
      IntegrableOn
        (fun œÑ : TripLength => gn21SwitchProb switchIJ switchJI œÑ) œÉ Œº)
    (hq_integrable_rejected :
      IntegrableOn
        (fun œÑ : TripLength => gn21SwitchProb switchIJ switchJI œÑ)
        (acceptAllPolicy \ œÉ) Œº)
    (hpointwise :
      ‚àÄ œÑ ‚àà acceptAllPolicy \ œÉ,
        gn21ScaledStateTime Œº arrivalRate œÉ *
            gn21SwitchProb switchIJ switchJI œÑ ‚â§
          gn21ExitWeightIntegral Œº arrivalRate switchIJ switchJI œÉ * œÑ) :
    gn21ScaledStateTime Œº arrivalRate œÉ *
        gn21ExitWeightIntegral Œº arrivalRate switchIJ switchJI acceptAllPolicy ‚â§
      gn21ScaledStateTime Œº arrivalRate acceptAllPolicy *
        gn21ExitWeightIntegral Œº arrivalRate switchIJ switchJI œÉ := by
  exact
    gn21FixedStateCross_ge_acceptAll_of_complement_increment_ratio_le
      Œº arrivalRate switchIJ switchJI œÉ hœÉ_subset hœÉ_measurable
      htime_integrable_œÉ htime_integrable_rejected hq_integrable_œÉ
      hq_integrable_rejected
      (arrivalScaledIntegral_mul_ge_of_pointwise Œº arrivalRate
        (gn21ExitWeightIntegral Œº arrivalRate switchIJ switchJI œÉ)
        (gn21ScaledStateTime Œº arrivalRate œÉ)
        (fun œÑ : TripLength => gn21SwitchProb switchIJ switchJI œÑ)
        (acceptAllPolicy \ œÉ) harrival_nonneg
        (measurableSet_acceptAllPolicy.diff hœÉ_measurable)
        htime_integrable_rejected hq_integrable_rejected hpointwise)

/-- Structured IC price family from Theorem 3: `w_i(œÑ)=m_i œÑ + z_i q_{i‚Üíj}(œÑ)`. -/
def structuredSurgePrice (m z : ‚Ñù) (q : TripLength ‚Üí ‚Ñù) : PricingFunction :=
  fun œÑ => m * œÑ + z * q œÑ

/-- Theorem 3 structured price using the Lemma 2 two-state CTMC switch probability. -/
def ctmcStructuredSurgePrice
    (m z lambdaIJ lambdaJI : ‚Ñù) : PricingFunction :=
  structuredSurgePrice m z (gn21SwitchProb lambdaIJ lambdaJI)

/--
Structured CTMC prices are integrable on a policy set whenever trip time and
the CTMC switch probability are integrable there.
-/
theorem integrableOn_ctmcStructuredSurgePrice
    (Œº : Measure TripLength)
    (m z switchIJ switchJI : ‚Ñù)
    (œÉ : TripPolicy)
    (htime_integrable :
      IntegrableOn (fun œÑ : TripLength => œÑ) œÉ Œº)
    (hq_integrable :
      IntegrableOn
        (fun œÑ : TripLength => gn21SwitchProb switchIJ switchJI œÑ) œÉ Œº) :
    IntegrableOn (ctmcStructuredSurgePrice m z switchIJ switchJI) œÉ Œº := by
  unfold ctmcStructuredSurgePrice structuredSurgePrice
  exact (htime_integrable.const_mul m).add (hq_integrable.const_mul z)

/-- Structured CTMC prices are continuous in trip length. -/
theorem continuous_ctmcStructuredSurgePrice
    (m z switchIJ switchJI : ‚Ñù) :
    Continuous (ctmcStructuredSurgePrice m z switchIJ switchJI) := by
  unfold ctmcStructuredSurgePrice structuredSurgePrice
  exact
    (continuous_const.mul continuous_id).add
      (continuous_const.mul (continuous_gn21SwitchProb switchIJ switchJI))

/-- Product with a continuous real-valued density is continuous at an endpoint. -/
theorem continuousAt_mul_density_of_continuous
    {f : TripLength ‚Üí ‚Ñù} {densityNN : TripLength ‚Üí NNReal}
    (hf : Continuous f)
    (hdensity_cont : Continuous fun œÑ => (densityNN œÑ : ‚Ñù))
    (u : ‚Ñù) :
    ContinuousAt (fun œÑ => f œÑ * (densityNN œÑ : ‚Ñù)) u :=
  (hf.mul hdensity_cont).continuousAt

/--
Product with a continuous real-valued density is strongly measurable at an
endpoint filter.
-/
theorem stronglyMeasurableAtFilter_mul_density_of_continuous
    {f : TripLength ‚Üí ‚Ñù} {densityNN : TripLength ‚Üí NNReal}
    (hf : Continuous f)
    (hdensity_cont : Continuous fun œÑ => (densityNN œÑ : ‚Ñù))
    (u : ‚Ñù) :
    StronglyMeasurableAtFilter
      (fun œÑ => f œÑ * (densityNN œÑ : ‚Ñù)) (ùìù u) :=
  (hf.mul hdensity_cont).stronglyMeasurableAtFilter volume (ùìù u)

/-- Product with a continuous density is interval-integrable on finite intervals. -/
theorem intervalIntegrable_mul_density_of_continuous
    {f : TripLength ‚Üí ‚Ñù} {densityNN : TripLength ‚Üí NNReal}
    (hf : Continuous f)
    (hdensity_cont : Continuous fun œÑ => (densityNN œÑ : ‚Ñù))
    (a b : ‚Ñù) :
    IntervalIntegrable (fun œÑ => f œÑ * (densityNN œÑ : ‚Ñù)) volume a b :=
  (hf.mul hdensity_cont).intervalIntegrable a b

/--
Endpoint continuity data for the three product integrands used by the Lemma 6
FTC bridge: switch probability times density, payment times density, and trip
time times density.
-/
structure GN21EndpointProductContinuityData
    (densityNN : TripLength ‚Üí NNReal)
    (switchProb payment : TripLength ‚Üí ‚Ñù)
    (u : ‚Ñù) where
  q_meas :
    StronglyMeasurableAtFilter
      (fun œÑ => switchProb œÑ * (densityNN œÑ : ‚Ñù)) (ùìù u)
  q_cont :
    ContinuousAt (fun œÑ => switchProb œÑ * (densityNN œÑ : ‚Ñù)) u
  w_meas :
    StronglyMeasurableAtFilter
      (fun œÑ => payment œÑ * (densityNN œÑ : ‚Ñù)) (ùìù u)
  w_cont :
    ContinuousAt (fun œÑ => payment œÑ * (densityNN œÑ : ‚Ñù)) u
  t_meas :
    StronglyMeasurableAtFilter
      (fun œÑ => œÑ * (densityNN œÑ : ‚Ñù)) (ùìù u)
  t_cont :
    ContinuousAt (fun œÑ => œÑ * (densityNN œÑ : ‚Ñù)) u

/-- Build endpoint product-continuity data from continuous factors. -/
def GN21EndpointProductContinuityData.of_continuous
    {densityNN : TripLength ‚Üí NNReal}
    {switchProb payment : TripLength ‚Üí ‚Ñù}
    (hdensity_cont : Continuous fun œÑ => (densityNN œÑ : ‚Ñù))
    (hswitch_cont : Continuous switchProb)
    (hpayment_cont : Continuous payment)
    (u : ‚Ñù) :
    GN21EndpointProductContinuityData densityNN switchProb payment u where
  q_meas :=
    stronglyMeasurableAtFilter_mul_density_of_continuous
      hswitch_cont hdensity_cont u
  q_cont :=
    continuousAt_mul_density_of_continuous hswitch_cont hdensity_cont u
  w_meas :=
    stronglyMeasurableAtFilter_mul_density_of_continuous
      hpayment_cont hdensity_cont u
  w_cont :=
    continuousAt_mul_density_of_continuous hpayment_cont hdensity_cont u
  t_meas :=
    stronglyMeasurableAtFilter_mul_density_of_continuous
      continuous_id hdensity_cont u
  t_cont :=
    continuousAt_mul_density_of_continuous continuous_id hdensity_cont u

/-- Endpoint product-continuity data for structured CTMC prices. -/
def GN21EndpointProductContinuityData.of_ctmcStructured
    {densityNN : TripLength ‚Üí NNReal}
    (hdensity_cont : Continuous fun œÑ => (densityNN œÑ : ‚Ñù))
    (m z switchIJ switchJI u : ‚Ñù) :
