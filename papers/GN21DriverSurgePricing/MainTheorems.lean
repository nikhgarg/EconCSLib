/-- Lemma 5 derivative-shape cases and their policy forms. -/
inductive Lemma5DerivativeShape where
  | positive
  | strictlyIncreasing
  | strictlyDecreasing
  | strictlyQuasiConvex
  | strictlyQuasiConcave
  deriving DecidableEq

/-- The policy form produced by Lemma 5 for each derivative-shape case. -/
def lemma5PolicyForm (shape : Lemma5DerivativeShape) (œÉ : TripPolicy) : Prop :=
  match shape with
  | .positive => acceptsAllTrips œÉ
  | .strictlyIncreasing => ‚àÉ t : ‚Ñù, rejectsShortTrips t œÉ
  | .strictlyDecreasing => ‚àÉ t : ‚Ñù, rejectsLongTrips t œÉ
  | .strictlyQuasiConvex => ‚àÉ lo hi : ‚Ñù, rejectsMiddleTrips lo hi œÉ
  | .strictlyQuasiConcave => ‚àÉ lo hi : ‚Ñù, acceptsMiddleTrips lo hi œÉ

/--
Analytic witness behind each Lemma 5 derivative-shape case.  The policy-form
predicate above records the optimizer shape; this predicate records the
response-function shape that produces it in the source proof.
-/
def lemma5DerivativeShapeWitness
    (response : TripLength ‚Üí ‚Ñù) : Lemma5DerivativeShape ‚Üí Prop
  | .positive => ‚àÄ u : TripLength, 0 < u ‚Üí 0 < response u
  | .strictlyIncreasing => StrictMonoOn response (Set.Ioi 0)
  | .strictlyDecreasing => StrictAntiOn response (Set.Ioi 0)
  | .strictlyQuasiConvex => strictQuasiConvexOnPositive response
  | .strictlyQuasiConcave => strictQuasiConcaveOnPositive response

/-- Lemma 7 supplies Lemma 5's strictly quasi-convex derivative-shape witness. -/
theorem lemma5DerivativeShapeWitness_strictlyQuasiConvex_of_lemma7_affine_ctmc_response
    (m a Qi Qj Ti Tj Ri Rj lambdaIJ lambdaJI : ‚Ñù)
    (hstate_weight_pos : 0 < Qi / Ti + Qj / Tj)
    (ha_pos : 0 < a)
    (hgap_nonneg : 0 ‚â§ Ri - Rj)
    (hlambdaIJ : 0 < lambdaIJ)
    (hsum : 0 < lambdaIJ + lambdaJI)
    (hTi : Ti ‚âÝ 0)
    (hTj : Tj ‚âÝ 0) :
    lemma5DerivativeShapeWitness
      (fun u : TripLength =>
        gn21Lemma6Response
          (gn21SwitchProb lambdaIJ lambdaJI u) u (m * u + a)
          Qi Qj Ti Tj Ri Rj)
      .strictlyQuasiConvex := by
  exact
    paper_lemma7_affine_ctmc_response_quasi_convex
      m a Qi Qj Ti Tj Ri Rj lambdaIJ lambdaJI
      hstate_weight_pos ha_pos hgap_nonneg hlambdaIJ hsum hTi hTj

/-- Lemma 8 supplies Lemma 5's strictly quasi-concave derivative-shape witness. -/
theorem lemma5DerivativeShapeWitness_strictlyQuasiConcave_of_lemma8_affine_ctmc_response
    (m a Qi Qj Ti Tj Ri Rj lambdaIJ lambdaJI : ‚Ñù)
    (hstate_weight_pos : 0 < Qi / Ti + Qj / Tj)
    (ha_neg : a < 0)
    (hgap_nonneg : 0 ‚â§ Rj - Ri)
    (hlambdaIJ : 0 < lambdaIJ)
    (hsum : 0 < lambdaIJ + lambdaJI)
    (hTi : Ti ‚âÝ 0)
    (hTj : Tj ‚âÝ 0) :
    lemma5DerivativeShapeWitness
      (fun u : TripLength =>
        gn21Lemma6Response
          (gn21SwitchProb lambdaIJ lambdaJI u) u (m * u + a)
          Qi Qj Ti Tj Ri Rj)
      .strictlyQuasiConcave := by
  exact
    paper_lemma8_affine_ctmc_response_quasi_concave
      m a Qi Qj Ti Tj Ri Rj lambdaIJ lambdaJI
      hstate_weight_pos ha_neg hgap_nonneg hlambdaIJ hsum hTi hTj

/-- Canonical policy accepting short trips and rejecting trips above threshold `t`. -/
def rejectLongTripsPolicy (t : ‚Ñù) : TripPolicy :=
  Set.Ioi (0 : ‚Ñù) ‚à© Set.Iio t

/-- Canonical policy rejecting short trips and accepting trips above threshold `t`. -/
def rejectShortTripsPolicy (t : ‚Ñù) : TripPolicy :=
  Set.Ioi (0 : ‚Ñù) ‚à© Set.Ioi t

/-- Canonical policy accepting only middle-length trips. -/
def acceptMiddleTripsPolicy (lo hi : ‚Ñù) : TripPolicy :=
  Set.Ioi (0 : ‚Ñù) ‚à© Set.Ioi lo ‚à© Set.Iio hi

/-- Canonical policy rejecting middle-length trips. -/
def rejectMiddleTripsPolicy (lo hi : ‚Ñù) : TripPolicy :=
  Set.Ioi (0 : ‚Ñù) ‚à© (Set.Iio lo ‚à™ Set.Ioi hi)

/-- The canonical long-trip-rejection policy has the corresponding Lemma 5 form. -/
theorem rejectsLongTrips_rejectLongTripsPolicy (t : ‚Ñù) :
    rejectsLongTrips t (rejectLongTripsPolicy t) := by
  intro œÑ hœÑ
  simp [rejectLongTripsPolicy, hœÑ]

/-- The canonical short-trip-rejection policy has the corresponding Lemma 5 form. -/
theorem rejectsShortTrips_rejectShortTripsPolicy (t : ‚Ñù) :
    rejectsShortTrips t (rejectShortTripsPolicy t) := by
  intro œÑ hœÑ
  simp [rejectShortTripsPolicy, hœÑ]

/-- The canonical middle-acceptance policy has the corresponding Lemma 5 form. -/
theorem acceptsMiddleTrips_acceptMiddleTripsPolicy (lo hi : ‚Ñù) :
    acceptsMiddleTrips lo hi (acceptMiddleTripsPolicy lo hi) := by
  intro œÑ hœÑ
  simp [acceptMiddleTripsPolicy, hœÑ]

/-- The canonical middle-rejection policy has the corresponding Lemma 5 form. -/
theorem rejectsMiddleTrips_rejectMiddleTripsPolicy (lo hi : ‚Ñù) :
    rejectsMiddleTrips lo hi (rejectMiddleTripsPolicy lo hi) := by
  intro œÑ hœÑ
  simp [rejectMiddleTripsPolicy, hœÑ]

/-- Any finite long-trip cutoff misses some positive trip. -/
theorem not_acceptsAllTrips_rejectLongTripsPolicy (t : ‚Ñù) :
    ¬¨ acceptsAllTrips (rejectLongTripsPolicy t) := by
  refine not_acceptsAllTrips_iff_exists_pos_not_mem.mpr ?_
  refine ‚ü®max t 0 + 1, ?_, ?_‚ü©
  ¬∑ have hnonneg : 0 ‚â§ max t 0 := le_max_right t 0
    linarith
  ¬∑ have ht_le : t ‚â§ max t 0 + 1 := by
      have hle : t ‚â§ max t 0 := le_max_left t 0
      linarith
    simp [rejectLongTripsPolicy, not_lt_of_ge ht_le]

/-- A positive short-trip cutoff misses sufficiently short positive trips. -/
theorem not_acceptsAllTrips_rejectShortTripsPolicy_of_pos
    {t : ‚Ñù} (ht : 0 < t) :
    ¬¨ acceptsAllTrips (rejectShortTripsPolicy t) := by
  refine not_acceptsAllTrips_iff_exists_pos_not_mem.mpr ?_
  refine ‚ü®t / 2, by positivity, ?_‚ü©
  have hhalf_lt : t / 2 < t := by linarith
  simp [rejectShortTripsPolicy, not_lt_of_ge (le_of_lt hhalf_lt)]

/-- Any finite middle-acceptance interval misses large positive trips. -/
theorem not_acceptsAllTrips_acceptMiddleTripsPolicy (lo hi : ‚Ñù) :
    ¬¨ acceptsAllTrips (acceptMiddleTripsPolicy lo hi) := by
  refine not_acceptsAllTrips_iff_exists_pos_not_mem.mpr ?_
  refine ‚ü®max hi 0 + 1, ?_, ?_‚ü©
  ¬∑ have hnonneg : 0 ‚â§ max hi 0 := le_max_right hi 0
    linarith
  ¬∑ have hhi_le : hi ‚â§ max hi 0 + 1 := by
      have hle : hi ‚â§ max hi 0 := le_max_left hi 0
      linarith
    simp [acceptMiddleTripsPolicy, not_lt_of_ge hhi_le]

/-- A nontrivial positive middle-rejection gap misses a positive trip. -/
theorem not_acceptsAllTrips_rejectMiddleTripsPolicy_of_pos_lt
    {lo hi : ‚Ñù} (hlo_pos : 0 < lo) (hlohi : lo < hi) :
    ¬¨ acceptsAllTrips (rejectMiddleTripsPolicy lo hi) := by
  refine not_acceptsAllTrips_iff_exists_pos_not_mem.mpr ?_
  let mid := (lo + hi) / 2
  have hlo_mid : lo < mid := by
    dsimp [mid]
    linarith
  have hmid_hi : mid < hi := by
    dsimp [mid]
    linarith
  refine ‚ü®mid, lt_trans hlo_pos hlo_mid, ?_‚ü©
  simp [rejectMiddleTripsPolicy, not_lt_of_ge (le_of_lt hlo_mid),
    not_lt_of_ge (le_of_lt hmid_hi)]

/--
A feasible policy with the long-trip-rejection shape is exactly the canonical
long-trip-rejection set.
-/
theorem eq_rejectLongTripsPolicy_of_rejectsLongTrips_of_subset_acceptAll
    {œÉ : TripPolicy} {t : ‚Ñù}
    (hshape : rejectsLongTrips t œÉ)
    (hsub : œÉ ‚äÜ acceptAllPolicy) :
    œÉ = rejectLongTripsPolicy t := by
  ext œÑ
  constructor
  ¬∑ intro hœÑ
    have hpos : 0 < œÑ := hsub hœÑ
    exact ‚ü®hpos, (hshape hpos).mp hœÑ‚ü©
  ¬∑ intro hœÑ
    exact (hshape hœÑ.1).mpr hœÑ.2

/--
A feasible policy with the short-trip-rejection shape is exactly the canonical
tail set.
-/
theorem eq_rejectShortTripsPolicy_of_rejectsShortTrips_of_subset_acceptAll
    {œÉ : TripPolicy} {t : ‚Ñù}
    (hshape : rejectsShortTrips t œÉ)
    (hsub : œÉ ‚äÜ acceptAllPolicy) :
    œÉ = rejectShortTripsPolicy t := by
  ext œÑ
  constructor
  ¬∑ intro hœÑ
    have hpos : 0 < œÑ := hsub hœÑ
    exact ‚ü®hpos, (hshape hpos).mp hœÑ‚ü©
  ¬∑ intro hœÑ
    exact (hshape hœÑ.1).mpr hœÑ.2

/--
A feasible policy with the middle-acceptance shape is exactly the canonical
bounded middle interval.
-/
theorem eq_acceptMiddleTripsPolicy_of_acceptsMiddleTrips_of_subset_acceptAll
    {œÉ : TripPolicy} {lo hi : ‚Ñù}
    (hshape : acceptsMiddleTrips lo hi œÉ)
    (hsub : œÉ ‚äÜ acceptAllPolicy) :
    œÉ = acceptMiddleTripsPolicy lo hi := by
  ext œÑ
  constructor
  ¬∑ intro hœÑ
    have hpos : 0 < œÑ := hsub hœÑ
    rcases (hshape hpos).mp hœÑ with ‚ü®hlo, hhi‚ü©
    exact ‚ü®‚ü®hpos, hlo‚ü©, hhi‚ü©
  ¬∑ intro hœÑ
    exact (hshape hœÑ.1.1).mpr ‚ü®hœÑ.1.2, hœÑ.2‚ü©

/--
A feasible policy with the middle-rejection shape is exactly the canonical
short-or-tail set.
-/
theorem eq_rejectMiddleTripsPolicy_of_rejectsMiddleTrips_of_subset_acceptAll
    {œÉ : TripPolicy} {lo hi : ‚Ñù}
    (hshape : rejectsMiddleTrips lo hi œÉ)
    (hsub : œÉ ‚äÜ acceptAllPolicy) :
    œÉ = rejectMiddleTripsPolicy lo hi := by
  ext œÑ
  constructor
  ¬∑ intro hœÑ
    have hpos : 0 < œÑ := hsub hœÑ
    exact ‚ü®hpos, (hshape hpos).mp hœÑ‚ü©
  ¬∑ intro hœÑ
    exact (hshape hœÑ.1).mpr hœÑ.2

/-- A feasible long-trip-rejection shape cannot be accept-all for finite cutoff. -/
theorem not_acceptsAllTrips_of_rejectsLongTrips_of_subset_acceptAll
    {œÉ : TripPolicy} {t : ‚Ñù}
    (hshape : rejectsLongTrips t œÉ)
    (hsub : œÉ ‚äÜ acceptAllPolicy) :
    ¬¨ acceptsAllTrips œÉ := by
  rw [eq_rejectLongTripsPolicy_of_rejectsLongTrips_of_subset_acceptAll
    hshape hsub]
  exact not_acceptsAllTrips_rejectLongTripsPolicy t

/-- A feasible positive-cutoff short-trip-rejection shape is not accept-all. -/
theorem not_acceptsAllTrips_of_rejectsShortTrips_of_subset_acceptAll_of_pos
    {œÉ : TripPolicy} {t : ‚Ñù}
    (hshape : rejectsShortTrips t œÉ)
    (hsub : œÉ ‚äÜ acceptAllPolicy)
    (ht : 0 < t) :
    ¬¨ acceptsAllTrips œÉ := by
  rw [eq_rejectShortTripsPolicy_of_rejectsShortTrips_of_subset_acceptAll
    hshape hsub]
  exact not_acceptsAllTrips_rejectShortTripsPolicy_of_pos ht

/-- A feasible middle-acceptance shape cannot be accept-all for finite endpoints. -/
theorem not_acceptsAllTrips_of_acceptsMiddleTrips_of_subset_acceptAll
    {œÉ : TripPolicy} {lo hi : ‚Ñù}
    (hshape : acceptsMiddleTrips lo hi œÉ)
    (hsub : œÉ ‚äÜ acceptAllPolicy) :
    ¬¨ acceptsAllTrips œÉ := by
  rw [eq_acceptMiddleTripsPolicy_of_acceptsMiddleTrips_of_subset_acceptAll
    hshape hsub]
  exact not_acceptsAllTrips_acceptMiddleTripsPolicy lo hi

/-- A feasible middle-rejection shape with a positive gap is not accept-all. -/
theorem not_acceptsAllTrips_of_rejectsMiddleTrips_of_subset_acceptAll_of_pos_lt
    {œÉ : TripPolicy} {lo hi : ‚Ñù}
    (hshape : rejectsMiddleTrips lo hi œÉ)
    (hsub : œÉ ‚äÜ acceptAllPolicy)
    (hlo_pos : 0 < lo)
    (hlohi : lo < hi) :
    ¬¨ acceptsAllTrips œÉ := by
  rw [eq_rejectMiddleTripsPolicy_of_rejectsMiddleTrips_of_subset_acceptAll
    hshape hsub]
  exact not_acceptsAllTrips_rejectMiddleTripsPolicy_of_pos_lt hlo_pos hlohi

/-- Canonical long-trip-rejection policies are measurable. -/
theorem measurableSet_rejectLongTripsPolicy (t : ‚Ñù) :
    MeasurableSet (rejectLongTripsPolicy t) := by
  unfold rejectLongTripsPolicy
  exact (measurableSet_Ioi (a := (0 : ‚Ñù))).inter (measurableSet_Iio (a := t))

/-- Canonical short-trip-rejection policies are measurable. -/
theorem measurableSet_rejectShortTripsPolicy (t : ‚Ñù) :
    MeasurableSet (rejectShortTripsPolicy t) := by
  unfold rejectShortTripsPolicy
  exact (measurableSet_Ioi (a := (0 : ‚Ñù))).inter (measurableSet_Ioi (a := t))

/-- Canonical middle-acceptance policies are measurable. -/
theorem measurableSet_acceptMiddleTripsPolicy (lo hi : ‚Ñù) :
    MeasurableSet (acceptMiddleTripsPolicy lo hi) := by
  unfold acceptMiddleTripsPolicy
  exact
    ((measurableSet_Ioi (a := (0 : ‚Ñù))).inter
      (measurableSet_Ioi (a := lo))).inter (measurableSet_Iio (a := hi))

/-- Canonical middle-rejection policies are measurable. -/
theorem measurableSet_rejectMiddleTripsPolicy (lo hi : ‚Ñù) :
    MeasurableSet (rejectMiddleTripsPolicy lo hi) := by
  have htail :
      MeasurableSet (Set.Iio lo ‚à™ Set.Ioi hi) :=
    (measurableSet_Iio (a := lo)).union (measurableSet_Ioi (a := hi))
  unfold rejectMiddleTripsPolicy
  exact (measurableSet_Ioi (a := (0 : ‚Ñù))).inter htail

/-- Canonical long-trip-rejection policies only accept positive trips. -/
theorem rejectLongTripsPolicy_subset_acceptAll (t : ‚Ñù) :
    rejectLongTripsPolicy t ‚äÜ acceptAllPolicy := by
  intro œÑ hœÑ
  exact hœÑ.1

/--
Canonical long-trip-rejection policy realizes the endpoint `Q_i` path with
lower endpoint `0`; the open/closed endpoint difference is null for Lebesgue
`withDensity` primitives.
-/
theorem gn21ExitWeightIntegral_rejectLongTripsPolicy_withDensity_eq_endpointQiPath
    (arrivalRate switchIJ switchJI t : ‚Ñù)
    (density : ‚Ñù ‚Üí NNReal)
    (hdensity_meas : Measurable density)
    (ht_nonneg : 0 ‚â§ t) :
    gn21ExitWeightIntegral
        (volume.withDensity fun œÑ => (density œÑ : ‚Ñù‚â•0‚àû))
        arrivalRate switchIJ switchJI
        (rejectLongTripsPolicy t) =
      gn21EndpointQiPath arrivalRate switchIJ 0
        (fun œÑ => (density œÑ : ‚Ñù))
        (gn21SwitchProb switchIJ switchJI) t := by
  unfold gn21ExitWeightIntegral gn21EndpointQiPath rejectLongTripsPolicy
  rw [intervalIntegral.integral_of_le ht_nonneg]
  rw [setIntegral_withDensity_eq_setIntegral_smul
    (Œº := volume) (f := density)
    hdensity_meas
    (fun œÑ => gn21SwitchProb switchIJ switchJI œÑ)
    ((measurableSet_Ioi (a := (0 : ‚Ñù))).inter
      (measurableSet_Iio (a := t)))]
  apply congrArg (fun y => switchIJ + arrivalRate * y)
  rw [integral_Ioc_eq_integral_Ioo]
  apply setIntegral_congr_fun measurableSet_Ioo
  intro œÑ _hœÑ
