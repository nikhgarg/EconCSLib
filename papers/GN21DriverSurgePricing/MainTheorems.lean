    (hrho_lt_one : rho < 1)
    (hT1_pos : 0 < T1)
    (hQ1_sub_switch12_pos : 0 < Q1 - switch12)
    (hden_theorem3_pos :
      0 < theorem3FeasibilityDenominator T1 T2 Q1 Q2 switch12)
    (hlemma9_den_lower :
      0 < lemma9StructuredLowerDenominator T1 Q1 T2 Q2 switch21)
    (hlemma9_den_upper :
