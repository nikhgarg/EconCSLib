      (0 ≤ m 0 ∧ 0 ≤ m 1 ∧ 0 ≤ z 1) →
        theorem3AcceptAllStructuredParameterEvidence
          μ arrival R1 R2 switch12 switch21 m z →
        ∀ ρ : Fin 2 → TripPolicy,
          dynamicFeasibleMeasurablePositiveMassPolicy μ ρ →
            0 < m 1 - R1 ∧
              gn21MeasuredStateRewardRate (μ 0) (arrival 0)
