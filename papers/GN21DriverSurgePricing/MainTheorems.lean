theorem lemma10StructuredBounds_acceptAll_of_theorem3_ratio_measured
    (rho : ‚Ñù)
    (Œº1 Œº2 : Measure TripLength)
    (arrival1 arrival2 switch12 switch21 : ‚Ñù)
    (hC_lt_rho :
      theorem3FeasibilityThresholdC
          (gn21ScaledStateTime Œº1 arrival1 acceptAllPolicy)
          (gn21ScaledStateTime Œº2 arrival2 acceptAllPolicy)
          (gn21ExitWeightIntegral Œº1 arrival1 switch12 switch21 acceptAllPolicy)
          (gn21ExitWeightIntegral Œº2 arrival2 switch21 switch12 acceptAllPolicy)
          switch12 < rho)
    (hrho_lt_one : rho < 1)
    (harrival1_pos : 0 < arrival1)
    (harrival2_nonneg : 0 ‚â§ arrival2)
    (hswitch12_pos : 0 < switch12)
    (hswitch21_pos : 0 < switch21)
    (htime1_integrable :
      IntegrableOn (fun œÑ : TripLength => œÑ) acceptAllPolicy Œº1)
    (hq1_integrable :
      IntegrableOn
        (fun œÑ : TripLength => gn21SwitchProb switch12 switch21 œÑ)
        acceptAllPolicy Œº1)
    (hmeasure1_pos : 0 < Œº1 acceptAllPolicy) :
    lemma10StructuredBounds
      (theorem3NonsurgeZRatio rho
        (gn21ScaledStateTime Œº1 arrival1 acceptAllPolicy)
        (gn21ExitWeightIntegral Œº1 arrival1 switch12 switch21 acceptAllPolicy)
        switch12)
      (gn21ScaledStateTime Œº2 arrival2 acceptAllPolicy)
      (gn21ExitWeightIntegral Œº2 arrival2 switch21 switch12 acceptAllPolicy)
      (gn21ScaledStateTime Œº1 arrival1 acceptAllPolicy)
      (gn21ExitWeightIntegral Œº1 arrival1 switch12 switch21 acceptAllPolicy)
      switch12 := by
  have hsum12 : 0 < switch12 + switch21 := by
    linarith
  have hsum21 : 0 < switch21 + switch12 := by
    linarith
  have hT1_pos :
      0 < gn21ScaledStateTime Œº1 arrival1 acceptAllPolicy :=
    gn21ScaledStateTime_pos_of_nonneg Œº1 arrival1 acceptAllPolicy
      (le_of_lt harrival1_pos) measurableSet_acceptAllPolicy (fun _ hœÑ => hœÑ)
  have hT2_nonneg :
      0 ‚â§ gn21ScaledStateTime Œº2 arrival2 acceptAllPolicy := by
    exact le_of_lt
      (gn21ScaledStateTime_pos_of_nonneg Œº2 arrival2 acceptAllPolicy
        harrival2_nonneg measurableSet_acceptAllPolicy (fun _ hœÑ => hœÑ))
  have hQ2_pos :
      0 <
        gn21ExitWeightIntegral Œº2 arrival2 switch21 switch12 acceptAllPolicy :=
    gn21ExitWeightIntegral_pos_of_switch_pos Œº2 arrival2 switch21 switch12
      acceptAllPolicy harrival2_nonneg hswitch21_pos hsum21
      measurableSet_acceptAllPolicy (fun _ hœÑ => hœÑ)
  have hQ1_sub_switch_pos :
      0 <
        gn21ExitWeightIntegral Œº1 arrival1 switch12 switch21 acceptAllPolicy -
          switch12 :=
    sub_pos.mpr
      (paper_remark4_exit_weight_gt_switch_of_positive_measure
        Œº1 arrival1 switch12 switch21 acceptAllPolicy harrival1_pos
        hswitch12_pos hsum12 measurableSet_acceptAllPolicy (fun _ hœÑ => hœÑ)
        hq1_integrable hmeasure1_pos)
  have hgap_pos :
      0 <
        switch12 * gn21ScaledStateTime Œº1 arrival1 acceptAllPolicy -
          gn21ExitWeightIntegral Œº1 arrival1 switch12 switch21 acceptAllPolicy :=
    paper_remark4_scaled_time_minus_exit_weight_pos_of_positive_measure
      Œº1 arrival1 switch12 switch21 acceptAllPolicy harrival1_pos hswitch12_pos
      hsum12 measurableSet_acceptAllPolicy (fun _ hœÑ => hœÑ)
      htime1_integrable hq1_integrable hmeasure1_pos
  have hsecond_nonneg :
      0 ‚â§
        gn21ScaledStateTime Œº2 arrival2 acceptAllPolicy * switch12 +
          gn21ExitWeightIntegral Œº2 arrival2 switch21 switch12 acceptAllPolicy :=
    paper_theorem3_switch_term_nonneg
      (gn21ScaledStateTime Œº2 arrival2 acceptAllPolicy)
      (gn21ExitWeightIntegral Œº2 arrival2 switch21 switch12 acceptAllPolicy)
      switch12 hT2_nonneg (le_of_lt hQ2_pos) (le_of_lt hswitch12_pos)
  have hden_pos :
      0 <
        theorem3FeasibilityDenominator
          (gn21ScaledStateTime Œº1 arrival1 acceptAllPolicy)
          (gn21ScaledStateTime Œº2 arrival2 acceptAllPolicy)
          (gn21ExitWeightIntegral Œº1 arrival1 switch12 switch21 acceptAllPolicy)
          (gn21ExitWeightIntegral Œº2 arrival2 switch21 switch12 acceptAllPolicy)
          switch12 :=
    paper_theorem3_feasibility_denominator_pos_of_positive_pieces
      (gn21ScaledStateTime Œº1 arrival1 acceptAllPolicy)
      (gn21ScaledStateTime Œº2 arrival2 acceptAllPolicy)
      (gn21ExitWeightIntegral Œº1 arrival1 switch12 switch21 acceptAllPolicy)
      (gn21ExitWeightIntegral Œº2 arrival2 switch21 switch12 acceptAllPolicy)
      switch12 hQ2_pos hgap_pos hswitch12_pos hsecond_nonneg
  exact lemma10StructuredBounds_of_theorem3_ratio
    rho
    (gn21ScaledStateTime Œº1 arrival1 acceptAllPolicy)
    (gn21ScaledStateTime Œº2 arrival2 acceptAllPolicy)
    (gn21ExitWeightIntegral Œº1 arrival1 switch12 switch21 acceptAllPolicy)
    (gn21ExitWeightIntegral Œº2 arrival2 switch21 switch12 acceptAllPolicy)
    switch12 hC_lt_rho hrho_lt_one hT1_pos hQ1_sub_switch_pos hden_pos

