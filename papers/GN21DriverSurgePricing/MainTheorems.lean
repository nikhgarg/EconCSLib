    (hsum : 0 < switch21 + switch12)
    (hu : 0 < u)
    (hswitch_lt_Q2 : switch21 < Q2)
    (hgap_nonneg : 0 ≤ switch21 * T2 - Q2)
    (hδ : 0 < δ)
    (Hcur :
