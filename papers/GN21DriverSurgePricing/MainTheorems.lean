    volume (gn21RejectMiddleLoReplacement lo hi Œµ) ‚âÝ 0 := by
  simpa [gn21RejectMiddleLoReplacement] using
    volume_rejectMiddleTripsPolicy_ne_zero (lo + Œµ) hi

