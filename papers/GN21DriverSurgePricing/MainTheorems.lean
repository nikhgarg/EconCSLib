def lemma9SurgeDerivativeCertificate_of_current_bounds
    (ratio T1 Q1 T2 Q2 switch21 switch12 m R1 z : ‚Ñù)
    (hbounds : lemma9StructuredBounds ratio T1 Q1 T2 Q2 switch21)
