    (hTi : C.Ti = T1)
    (hTj : C.Tj = T2)
    (hWi : C.Wi = R2 * (T1 - 1) + z * (Q1 - switch12))
    (hWj : C.Wj = R2 * T2)
    (hbounds : lemma10StructuredBounds ratio T2 Q2 T1 Q1 switch12)
    (hz : z = ratio * R2)
    (hR2_pos : 0 < R2)
    (hQ2_pos : 0 < Q2)
