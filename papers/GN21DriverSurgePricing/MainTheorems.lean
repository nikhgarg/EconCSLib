    (hQi_nonneg :
      0 ≤ gn21ExitWeightIntegral μI arrivalI switchIJ switchJI σI)
    (hkernel_nonneg :
      0 ≤
        (arrivalJ * ∫ τ in added, gn21SwitchProb switchJI switchIJ τ ∂μJ) *
            (gn21ScaledStateEarning μI arrivalI wI σI *
                gn21ScaledStateTime μJ arrivalJ σJ -
