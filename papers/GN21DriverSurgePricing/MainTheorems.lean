    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (œÉI œÉJ : TripPolicy) : Prop where
  massI_ne : singleStateTripMass ŒºI œÉI ‚âÝ 0
  massJ_ne : singleStateTripMass ŒºJ œÉJ ‚âÝ 0
  arrivalMassI_ne : arrivalI * singleStateTripMass ŒºI œÉI ‚âÝ 0
  arrivalMassJ_ne : arrivalJ * singleStateTripMass ŒºJ œÉJ ‚âÝ 0
  scaledTimeI_ne : gn21ScaledStateTime ŒºI arrivalI œÉI ‚âÝ 0
  scaledTimeJ_ne : gn21ScaledStateTime ŒºJ arrivalJ œÉJ ‚âÝ 0
  denominator_ne :
    gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI *
        gn21ScaledStateTime ŒºJ arrivalJ œÉJ +
      gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ *
        gn21ScaledStateTime ŒºI arrivalI œÉI ‚âÝ 0

/-- Positive primitive conditions imply the measured pair is nondegenerate. -/
theorem gn21MeasuredPairNondegenerate_of_positive_primitives
    (ŒºI ŒºJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ‚Ñù)
    (œÉI œÉJ : TripPolicy)
    (hmassI_pos : 0 < singleStateTripMass ŒºI œÉI)
    (hmassJ_pos : 0 < singleStateTripMass ŒºJ œÉJ)
    (harrivalI_pos : 0 < arrivalI)
    (harrivalJ_pos : 0 < arrivalJ)
    (hscaledTimeI_pos : 0 < gn21ScaledStateTime ŒºI arrivalI œÉI)
    (hscaledTimeJ_pos : 0 < gn21ScaledStateTime ŒºJ arrivalJ œÉJ)
    (hexitI_pos :
      0 < gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI)
    (hexitJ_pos :
      0 < gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ) :
    GN21MeasuredPairNondegenerate ŒºI ŒºJ arrivalI arrivalJ switchIJ switchJI
      œÉI œÉJ where
  massI_ne := ne_of_gt hmassI_pos
  massJ_ne := ne_of_gt hmassJ_pos
  arrivalMassI_ne := ne_of_gt (mul_pos harrivalI_pos hmassI_pos)
  arrivalMassJ_ne := ne_of_gt (mul_pos harrivalJ_pos hmassJ_pos)
  scaledTimeI_ne := ne_of_gt hscaledTimeI_pos
  scaledTimeJ_ne := ne_of_gt hscaledTimeJ_pos
  denominator_ne := by
    have hleft :
        0 <
          gn21ExitWeightIntegral ŒºI arrivalI switchIJ switchJI œÉI *
            gn21ScaledStateTime ŒºJ arrivalJ œÉJ :=
      mul_pos hexitI_pos hscaledTimeJ_pos
    have hright :
        0 <
          gn21ExitWeightIntegral ŒºJ arrivalJ switchJI switchIJ œÉJ *
            gn21ScaledStateTime ŒºI arrivalI œÉI :=
      mul_pos hexitJ_pos hscaledTimeI_pos
    exact ne_of_gt (add_pos hleft hright)

