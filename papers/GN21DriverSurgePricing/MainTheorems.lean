        renewalRewardRate] using hcurrent_le_added_average)

/--
Theorem 1 marginal step, remove version: removing a measurable accepted subset
of positive total trip time whose average payment rate is at most the current
renewal-reward rate cannot reduce the single-state reward.
-/
theorem paper_theorem1_remove_positive_time_set_if_average_below_current
    (Œº : Measure TripLength) (arrivalRate : ‚Ñù) (w : PricingFunction)
    (œÉ removed : TripPolicy)
    (hremoved_subset : removed ‚äÜ œÉ)
    (hremoved_measurable : MeasurableSet removed)
    (hw_integrable_œÉ : IntegrableOn w œÉ Œº)
    (htime_integrable_œÉ :
      IntegrableOn (fun œÑ : TripLength => œÑ) œÉ Œº)
    (hlambda : 0 < arrivalRate)
    (htime_remaining_nonneg : 0 ‚â§ singleStateTripTime Œº œÉ - singleStateTripTime Œº removed)
    (hremoved_time_pos : 0 < singleStateTripTime Œº removed)
    (hremoved_average_le_current :
      singleStateAverageTripRate Œº w removed ‚â§
        singleStateRenewalReward Œº arrivalRate w œÉ) :
    singleStateRenewalReward Œº arrivalRate w œÉ ‚â§
      singleStateRenewalReward Œº arrivalRate w (œÉ \ removed) := by
  change
    renewalRewardRate arrivalRate
        (singleStateTripPayment Œº w œÉ) (singleStateTripTime Œº œÉ) ‚â§
      renewalRewardRate arrivalRate
        (singleStateTripPayment Œº w (œÉ \ removed))
        (singleStateTripTime Œº (œÉ \ removed))
  rw [singleStateTripPayment_diff Œº w œÉ removed hremoved_subset hremoved_measurable
      hw_integrable_œÉ,
    singleStateTripTime_diff Œº œÉ removed hremoved_subset hremoved_measurable
      htime_integrable_œÉ]
  exact renewalRewardRate_remove_component_ge_of_average_le
    arrivalRate (singleStateTripPayment Œº w œÉ) (singleStateTripTime Œº œÉ)
    (singleStateTripPayment Œº w removed) (singleStateTripTime Œº removed)
    hlambda htime_remaining_nonneg hremoved_time_pos
    (by
      simpa [singleStateRenewalReward, singleStateAverageTripRate,
        renewalRewardRate] using hremoved_average_le_current)

/--
Theorem 1 pointwise add step: adding a disjoint measurable positive-time set
whose every trip pays at least the current renewal-reward rate per unit time
cannot reduce reward.
-/
theorem paper_theorem1_add_positive_time_set_if_pointwise_rate_above_current
    (Œº : Measure TripLength) (arrivalRate : ‚Ñù) (w : PricingFunction)
    (œÉ added : TripPolicy)
    (hdisjoint : Disjoint œÉ added)
    (hadded_measurable : MeasurableSet added)
