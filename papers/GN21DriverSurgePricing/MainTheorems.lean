-/
theorem GN21RegularEndpointSharedSourceData.nonsurge_fixed_cross_le_acceptAll_of_complement_pointwise
    {Œº : Fin 2 ‚Üí Measure TripLength}
    {arrival : Fin 2 ‚Üí ‚Ñù}
    {switch12 switch21 : ‚Ñù}
    {œÅ : Fin 2 ‚Üí TripPolicy}
    (S : GN21RegularEndpointSharedSourceData Œº arrival switch12 switch21)
    (hœÅ_feasible : dynamicFeasibleMeasurablePolicy œÅ)
    (hpointwise :
      ‚àÄ œÑ ‚àà acceptAllPolicy \ œÅ 0,
        gn21ExitWeightIntegral (Œº 0) (arrival 0) switch12 switch21 (œÅ 0) *
            œÑ ‚â§
