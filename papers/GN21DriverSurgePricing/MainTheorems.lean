-/
theorem paper_theorem1_single_state_threshold_best_response_measurable_of_compact_upperSemicontinuity_tail_bounds
    (μ : Measure TripLength) (arrivalRate : ℝ) (w : PricingFunction) (C : ℝ)
    (hC_nonneg : 0 ≤ C)
