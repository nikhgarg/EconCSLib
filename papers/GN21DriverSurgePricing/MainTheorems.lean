            m 1 =
              theorem3SurgeMultiplierFromRatio R1 R2 T2 Q2 switch21 surgeRatio ‚àß
            z 1 =
              theorem3SurgeZFromRatio R1 R2 T2 Q2 switch21 surgeRatio ‚àß
            m 0 * (T1 - 1) + z 0 * (Q1 - switch12) = R1 * T1 ‚àß
            m 1 * (T2 - 1) + z 1 * (Q2 - switch21) = R2 * T2) ‚Üí
        Theorem4StatewiseAcceptAllWeakRewardCertificate
          (gn21MeasuredCTMCStructuredDynamicReward
            Œº arrival switch12 switch21 m z)) :
    ‚àÉ m z : Fin 2 ‚Üí ‚Ñù,
      (0 ‚â§ m 0 ‚àß 0 ‚â§ m 1 ‚àß 0 ‚â§ z 1) ‚àß
        dynamicIncentiveCompatible
          (gn21MeasuredCTMCStructuredDynamicReward
            Œº arrival switch12 switch21 m z) ‚àß
        (‚àÉ q : Fin 2 ‚Üí TripLength ‚Üí ‚Ñù,
          ‚àÄ i œÑ,
            ctmcStructuredDynamicSurgePrice m z switch12 switch21 i œÑ =
              structuredSurgePrice (m i) (z i) (q i) œÑ) ‚àß
        ‚àÉ nonsurgeRatio surgeRatio : ‚Ñù,
          lemma10StructuredBounds nonsurgeRatio T2 Q2 T1 Q1 switch12 ‚àß
            lemma9StructuredBounds surgeRatio T1 Q1 T2 Q2 switch21 ‚àß
            m 0 = R2 ‚àß
            z 0 = nonsurgeRatio * R2 ‚àß
            m 1 =
              theorem3SurgeMultiplierFromRatio R1 R2 T2 Q2 switch21 surgeRatio ‚àß
            z 1 =
              theorem3SurgeZFromRatio R1 R2 T2 Q2 switch21 surgeRatio ‚àß
            m 0 * (T1 - 1) + z 0 * (Q1 - switch12) = R1 * T1 ‚àß
            m 1 * (T2 - 1) + z 1 * (Q2 - switch21) = R2 * T2 := by
  rcases theorem3StructuredParameters_exist_of_ratio_and_lemma9_positive_primitives
      rho R1 R2 T1 Q1 T2 Q2 switch12 switch21 hR1_eq hR1_pos
      hR1_lt_R2 hR2_pos hC_lt_rho hrho_lt_one hT1_pos hQ1_pos
      hQ1_sub_switch12_pos hden_theorem3_pos hswitch21_pos hgap2_nonneg
      hT2_ge_one hswitch21_lt_Q2 with
    ‚ü®m, z, hnonneg, nonsurgeRatio, surgeRatio, hnBounds, hsBounds,
      hm0_eq, hz0_eq, hm1_eq, hz1_eq, hnAccount, hsAccount‚ü©
  have hparams :
      ‚àÉ nonsurgeRatio surgeRatio : ‚Ñù,
        lemma10StructuredBounds nonsurgeRatio T2 Q2 T1 Q1 switch12 ‚àß
          lemma9StructuredBounds surgeRatio T1 Q1 T2 Q2 switch21 ‚àß
          m 0 = R2 ‚àß
          z 0 = nonsurgeRatio * R2 ‚àß
          m 1 =
            theorem3SurgeMultiplierFromRatio R1 R2 T2 Q2 switch21 surgeRatio ‚àß
          z 1 =
            theorem3SurgeZFromRatio R1 R2 T2 Q2 switch21 surgeRatio ‚àß
          m 0 * (T1 - 1) + z 0 * (Q1 - switch12) = R1 * T1 ‚àß
          m 1 * (T2 - 1) + z 1 * (Q2 - switch21) = R2 * T2 := by
    exact ‚ü®nonsurgeRatio, surgeRatio, hnBounds, hsBounds, hm0_eq, hz0_eq,
      hm1_eq, hz1_eq, hnAccount, hsAccount‚ü©
  let R : DynamicReward :=
