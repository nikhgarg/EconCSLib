  have hcomponent :=
    paper_remark4_exit_weight_integral_component_le_acceptAll
      Œº arrivalRate switchIJ switchJI œÉ harrival_nonneg hswitch_nonneg hsum
      hq_acceptAll_integrable hœÉ_subset
  unfold gn21ExitWeightIntegral
  linarith

/-!
Appendix D.3 works with a derivative-sign expression.  The declarations below
formalize the algebraic kernel used in Lemma 6 and the structured-price
simplification in Remark 2.  They do not assert differentiability of the
underlying set-valued reward functional; that analytic bridge remains tracked
separately in the README.
-/

/--
Lemma 6 scaled derivative-sign kernel:
`q(W_j T_i - T_j W_i) + w_i(u)(Q_i T_j + Q_j T_i)
 - u(Q_i W_j + Q_j W_i)`.
-/
def gn21DerivativeSignKernel
    (q u wi Qi Qj Ti Tj Wi Wj : ‚Ñù) : ‚Ñù :=
  q * (Wj * Ti - Tj * Wi) +
    wi * (Qi * Tj + Qj * Ti) -
      u * (Qi * Wj + Qj * Wi)

/-- Lemma 6 derivative kernel after substituting state reward rates `W_k=R_kT_k`. -/
def gn21DerivativeSignKernelWithRates
    (q u wi Qi Qj Ti Tj Ri Rj : ‚Ñù) : ‚Ñù :=
  q * ((Rj - Ri) * Tj * Ti) +
    wi * (Qi * Tj + Qj * Ti) -
      u * (Qi * Rj * Tj + Qj * Ri * Ti)

/--
Lemma 6 normalized response expression:
`q/u * (R_j-R_i) + w_i(u)/u * (Q_i/T_i + Q_j/T_j)
 - (Q_i/T_i R_j + Q_j/T_j R_i)`.
-/
def gn21Lemma6Response
    (q u wi Qi Qj Ti Tj Ri Rj : ‚Ñù) : ‚Ñù :=
  q / u * (Rj - Ri) +
    wi / u * (Qi / Ti + Qj / Tj) -
      (Qi / Ti * Rj + Qj / Tj * Ri)

/--
Lemma 6 aggregate dynamic reward after Lemma 1's time-fraction reduction:
`(Q_i W_j + Q_j W_i)/(Q_i T_j + Q_j T_i)`.
-/
def gn21AggregateDynamicReward
    (Qi Qj Ti Tj Wi Wj : ‚Ñù) : ‚Ñù :=
  (Qi * Wj + Qj * Wi) / (Qi * Tj + Qj * Ti)

/-- The aggregate dynamic-reward denominator is positive from positive primitives. -/
theorem gn21AggregateDenominator_pos_of_pos
    (Qi Qj Ti Tj : ‚Ñù)
    (hQi_pos : 0 < Qi) (hQj_pos : 0 < Qj)
    (hTi_pos : 0 < Ti) (hTj_pos : 0 < Tj) :
    0 < Qi * Tj + Qj * Ti := by
  exact add_pos (mul_pos hQi_pos hTj_pos) (mul_pos hQj_pos hTi_pos)

/--
The aggregate denominator is positive when the left exit/time primitives are
nonnegative and the right-exit/left-time product is strictly positive.
-/
theorem gn21AggregateDenominator_pos_of_nonneg_left
    (Qi Qj Ti Tj : ‚Ñù)
    (hQi_nonneg : 0 ‚â§ Qi) (hQj_pos : 0 < Qj)
    (hTi_pos : 0 < Ti) (hTj_nonneg : 0 ‚â§ Tj) :
    0 < Qi * Tj + Qj * Ti := by
  exact add_pos_of_nonneg_of_pos
    (mul_nonneg hQi_nonneg hTj_nonneg)
    (mul_pos hQj_pos hTi_pos)

/--
The aggregate denominator is positive when the right exit/time primitives are
nonnegative and the left-exit/right-time product is strictly positive.
-/
theorem gn21AggregateDenominator_pos_of_nonneg_right
    (Qi Qj Ti Tj : ‚Ñù)
    (hQi_pos : 0 < Qi) (hQj_nonneg : 0 ‚â§ Qj)
    (hTi_nonneg : 0 ‚â§ Ti) (hTj_pos : 0 < Tj) :
    0 < Qi * Tj + Qj * Ti := by
  exact add_pos_of_pos_of_nonneg
    (mul_pos hQi_pos hTj_pos)
    (mul_nonneg hQj_nonneg hTi_nonneg)

/-- The aggregate two-state quotient is symmetric in the order of the states. -/
theorem gn21AggregateDynamicReward_swap
    (Qi Qj Ti Tj Wi Wj : ‚Ñù) :
    gn21AggregateDynamicReward Qi Qj Ti Tj Wi Wj =
      gn21AggregateDynamicReward Qj Qi Tj Ti Wj Wi := by
  unfold gn21AggregateDynamicReward
  ring

/--
Aggregate quotient monotonicity for adding accepted trips to the left state.
The sufficient condition is exactly the integrated Lemma 6 derivative kernel
for the added primitive increments `(dQ,dT,dW)`.
-/
theorem gn21AggregateDynamicReward_le_add_left_of_kernel_nonneg
    (Qi Qj Ti Tj Wi Wj dQ dT dW : ‚Ñù)
    (hden_pos : 0 < Qi * Tj + Qj * Ti)
    (hden_add_pos : 0 < (Qi + dQ) * Tj + Qj * (Ti + dT))
    (hQj_nonneg : 0 ‚â§ Qj)
    (hkernel_nonneg :
      0 ‚â§
        dQ * (Wj * Ti - Tj * Wi) +
          dW * (Qi * Tj + Qj * Ti) -
            dT * (Qi * Wj + Qj * Wi)) :
    gn21AggregateDynamicReward Qi Qj Ti Tj Wi Wj ‚â§
      gn21AggregateDynamicReward
        (Qi + dQ) Qj (Ti + dT) Tj (Wi + dW) Wj := by
  unfold gn21AggregateDynamicReward
  rw [div_le_div_iff‚ÇÄ hden_pos hden_add_pos]
  have hidentity :
      ((Qi + dQ) * Wj + Qj * (Wi + dW)) * (Qi * Tj + Qj * Ti) -
          (Qi * Wj + Qj * Wi) * ((Qi + dQ) * Tj + Qj * (Ti + dT)) =
        Qj *
          (dQ * (Wj * Ti - Tj * Wi) +
            dW * (Qi * Tj + Qj * Ti) -
              dT * (Qi * Wj + Qj * Wi)) := by
    ring
  have hdiff_nonneg :
      0 ‚â§
        ((Qi + dQ) * Wj + Qj * (Wi + dW)) * (Qi * Tj + Qj * Ti) -
          (Qi * Wj + Qj * Wi) * ((Qi + dQ) * Tj + Qj * (Ti + dT)) := by
    rw [hidentity]
    exact mul_nonneg hQj_nonneg hkernel_nonneg
  linarith

/--
Aggregate quotient monotonicity for adding accepted trips to the right state.
This is the state-swapped counterpart of
`gn21AggregateDynamicReward_le_add_left_of_kernel_nonneg`.
-/
theorem gn21AggregateDynamicReward_le_add_right_of_kernel_nonneg
    (Qi Qj Ti Tj Wi Wj dQ dT dW : ‚Ñù)
    (hden_pos : 0 < Qi * Tj + Qj * Ti)
    (hden_add_pos : 0 < Qi * (Tj + dT) + (Qj + dQ) * Ti)
    (hQi_nonneg : 0 ‚â§ Qi)
    (hkernel_nonneg :
      0 ‚â§
        dQ * (Wi * Tj - Ti * Wj) +
          dW * (Qj * Ti + Qi * Tj) -
            dT * (Qj * Wi + Qi * Wj)) :
    gn21AggregateDynamicReward Qi Qj Ti Tj Wi Wj ‚â§
      gn21AggregateDynamicReward
        Qi (Qj + dQ) Ti (Tj + dT) Wi (Wj + dW) := by
  unfold gn21AggregateDynamicReward
  rw [div_le_div_iff‚ÇÄ hden_pos hden_add_pos]
  have hidentity :
      (Qi * (Wj + dW) + (Qj + dQ) * Wi) * (Qi * Tj + Qj * Ti) -
          (Qi * Wj + Qj * Wi) * (Qi * (Tj + dT) + (Qj + dQ) * Ti) =
        Qi *
          (dQ * (Wi * Tj - Ti * Wj) +
            dW * (Qj * Ti + Qi * Tj) -
              dT * (Qj * Wi + Qi * Wj)) := by
    ring
  have hdiff_nonneg :
      0 ‚â§
        (Qi * (Wj + dW) + (Qj + dQ) * Wi) * (Qi * Tj + Qj * Ti) -
          (Qi * Wj + Qj * Wi) * (Qi * (Tj + dT) + (Qj + dQ) * Ti) := by
    rw [hidentity]
    exact mul_nonneg hQi_nonneg hkernel_nonneg
  linarith

/--
Set-integral form of the Lemma 6 kernel: the scalar primitive expression used
by the aggregate add lemmas is the arrival-rate multiple of the integrated
pointwise derivative-sign kernel.
-/
theorem gn21IntegratedDerivativeSignKernel_eq_primitive_kernel
    (Œº : Measure TripLength)
    (arrival Qi Qj Ti Tj Wi Wj : ‚Ñù)
    (q w : TripLength ‚Üí ‚Ñù) (added : TripPolicy)
    (hq_integrable : IntegrableOn q added Œº)
    (hw_integrable : IntegrableOn w added Œº)
    (htime_integrable : IntegrableOn (fun œÑ : TripLength => œÑ) added Œº) :
    arrival *
        ‚à´ œÑ in added,
          gn21DerivativeSignKernel (q œÑ) œÑ (w œÑ) Qi Qj Ti Tj Wi Wj ‚àÇŒº =
      (arrival * ‚à´ œÑ in added, q œÑ ‚àÇŒº) * (Wj * Ti - Tj * Wi) +
        (arrival * ‚à´ œÑ in added, w œÑ ‚àÇŒº) * (Qi * Tj + Qj * Ti) -
          (arrival * ‚à´ œÑ in added, œÑ ‚àÇŒº) * (Qi * Wj + Qj * Wi) := by
  let A := Wj * Ti - Tj * Wi
  let B := Qi * Tj + Qj * Ti
  let C := Qi * Wj + Qj * Wi
  have hqA : IntegrableOn (fun œÑ : TripLength => q œÑ * A) added Œº :=
    hq_integrable.mul_const A
  have hwB : IntegrableOn (fun œÑ : TripLength => w œÑ * B) added Œº :=
    hw_integrable.mul_const B
  have htC : IntegrableOn (fun œÑ : TripLength => œÑ * C) added Œº :=
    htime_integrable.mul_const C
  unfold gn21DerivativeSignKernel
  change
    arrival * ‚à´ œÑ in added, q œÑ * A + w œÑ * B - œÑ * C ‚àÇŒº =
      (arrival * ‚à´ œÑ in added, q œÑ ‚àÇŒº) * A +
        (arrival * ‚à´ œÑ in added, w œÑ ‚àÇŒº) * B -
          (arrival * ‚à´ œÑ in added, œÑ ‚àÇŒº) * C
  have hsub :
      ‚à´ œÑ in added, q œÑ * A + w œÑ * B - œÑ * C ‚àÇŒº =
        ‚à´ œÑ in added, q œÑ * A + w œÑ * B ‚àÇŒº -
          ‚à´ œÑ in added, œÑ * C ‚àÇŒº := by
    simpa only [Pi.add_apply, Pi.sub_apply] using
      integral_sub (Œº := Œº.restrict added)
        (f := fun œÑ : TripLength => q œÑ * A + w œÑ * B)
        (g := fun œÑ : TripLength => œÑ * C) (hf := hqA.add hwB)
        (hg := htC)
  have hadd :
      ‚à´ œÑ in added, q œÑ * A + w œÑ * B ‚àÇŒº =
        ‚à´ œÑ in added, q œÑ * A ‚àÇŒº + ‚à´ œÑ in added, w œÑ * B ‚àÇŒº := by
    simpa only [Pi.add_apply] using
      integral_add (Œº := Œº.restrict added)
        (f := fun œÑ : TripLength => q œÑ * A)
        (g := fun œÑ : TripLength => w œÑ * B) hqA hwB
  rw [hsub, hadd,
    integral_mul_const (Œº := Œº.restrict added) A q,
    integral_mul_const (Œº := Œº.restrict added) B w,
    integral_mul_const (Œº := Œº.restrict added) C (fun œÑ : TripLength => œÑ)]
  ring

/--
Pointwise nonnegativity of the Lemma 6 derivative-sign kernel on an added set
implies the integrated primitive-kernel side condition used by the aggregate
add lemmas.
-/
theorem gn21PrimitiveKernel_nonneg_of_pointwise_derivative_kernel_nonneg
    (Œº : Measure TripLength)
    (arrival Qi Qj Ti Tj Wi Wj : ‚Ñù)
    (q w : TripLength ‚Üí ‚Ñù) (added : TripPolicy)
    (harrival_nonneg : 0 ‚â§ arrival)
    (hadded_measurable : MeasurableSet added)
    (hq_integrable : IntegrableOn q added Œº)
    (hw_integrable : IntegrableOn w added Œº)
    (htime_integrable : IntegrableOn (fun œÑ : TripLength => œÑ) added Œº)
    (hpointwise :
      ‚àÄ œÑ : TripLength, œÑ ‚àà added ‚Üí
        0 ‚â§ gn21DerivativeSignKernel (q œÑ) œÑ (w œÑ)
          Qi Qj Ti Tj Wi Wj) :
    0 ‚â§
      (arrival * ‚à´ œÑ in added, q œÑ ‚àÇŒº) * (Wj * Ti - Tj * Wi) +
        (arrival * ‚à´ œÑ in added, w œÑ ‚àÇŒº) * (Qi * Tj + Qj * Ti) -
          (arrival * ‚à´ œÑ in added, œÑ ‚àÇŒº) * (Qi * Wj + Qj * Wi) := by
  have hkernel_integral_nonneg :
      0 ‚â§
        ‚à´ œÑ in added,
          gn21DerivativeSignKernel (q œÑ) œÑ (w œÑ) Qi Qj Ti Tj Wi Wj ‚àÇŒº :=
    setIntegral_nonneg hadded_measurable hpointwise
  have hscaled_nonneg :
      0 ‚â§
        arrival *
          ‚à´ œÑ in added,
            gn21DerivativeSignKernel (q œÑ) œÑ (w œÑ) Qi Qj Ti Tj Wi Wj ‚àÇŒº :=
    mul_nonneg harrival_nonneg hkernel_integral_nonneg
  have heq :=
    gn21IntegratedDerivativeSignKernel_eq_primitive_kernel
      Œº arrival Qi Qj Ti Tj Wi Wj q w added
      hq_integrable hw_integrable htime_integrable
  rwa [heq] at hscaled_nonneg

/-- Endpoint path for `Q_i = lambda_{i‚Üíj} + lambda_i ‚à´ q_{i‚Üíj}(œÑ) f_i(œÑ)dœÑ`. -/
def gn21EndpointQiPath
    (arrivalRate switchRate lowerEndpoint : ‚Ñù)
    (density switchProb : ‚Ñù ‚Üí ‚Ñù) (x : ‚Ñù) : ‚Ñù :=
  switchRate +
    arrivalRate * ‚à´ œÑ in lowerEndpoint..x, switchProb œÑ * density œÑ

/-- Endpoint path for `W_i = lambda_i ‚à´ w_i(œÑ) f_i(œÑ)dœÑ`. -/
def gn21EndpointWiPath
    (arrivalRate lowerEndpoint : ‚Ñù)
    (density payment : ‚Ñù ‚Üí ‚Ñù) (x : ‚Ñù) : ‚Ñù :=
  arrivalRate * ‚à´ œÑ in lowerEndpoint..x, payment œÑ * density œÑ

/-- Endpoint path for `T_i = 1 + lambda_i ‚à´ œÑ f_i(œÑ)dœÑ`. -/
def gn21EndpointTiPath
    (arrivalRate lowerEndpoint : ‚Ñù)
    (density : ‚Ñù ‚Üí ‚Ñù) (x : ‚Ñù) : ‚Ñù :=
  1 + arrivalRate * ‚à´ œÑ in lowerEndpoint..x, œÑ * density œÑ

/-- Lower-endpoint path for `Q_i` with fixed upper endpoint. -/
def gn21LowerEndpointQiPath
    (arrivalRate switchRate upperEndpoint : ‚Ñù)
    (density switchProb : ‚Ñù ‚Üí ‚Ñù) (x : ‚Ñù) : ‚Ñù :=
  switchRate +
    arrivalRate * ‚à´ œÑ in x..upperEndpoint, switchProb œÑ * density œÑ

/-- Lower-endpoint path for `W_i` with fixed upper endpoint. -/
def gn21LowerEndpointWiPath
    (arrivalRate upperEndpoint : ‚Ñù)
    (density payment : ‚Ñù ‚Üí ‚Ñù) (x : ‚Ñù) : ‚Ñù :=
  arrivalRate * ‚à´ œÑ in x..upperEndpoint, payment œÑ * density œÑ

/-- Lower-endpoint path for `T_i` with fixed upper endpoint. -/
def gn21LowerEndpointTiPath
    (arrivalRate upperEndpoint : ‚Ñù)
    (density : ‚Ñù ‚Üí ‚Ñù) (x : ‚Ñù) : ‚Ñù :=
  1 + arrivalRate * ‚à´ œÑ in x..upperEndpoint, œÑ * density œÑ

/-- Tail path for `Q_i` on the unbounded policy interval `(x,‚àû)`. -/
def gn21TailQiPath
    (arrivalRate switchRate : ‚Ñù)
    (density switchProb : ‚Ñù ‚Üí ‚Ñù) (x : ‚Ñù) : ‚Ñù :=
  switchRate + arrivalRate * ‚à´ œÑ in Set.Ioi x, switchProb œÑ * density œÑ

/-- Tail path for `W_i` on the unbounded policy interval `(x,‚àû)`. -/
def gn21TailWiPath
    (arrivalRate : ‚Ñù)
    (density payment : ‚Ñù ‚Üí ‚Ñù) (x : ‚Ñù) : ‚Ñù :=
  arrivalRate * ‚à´ œÑ in Set.Ioi x, payment œÑ * density œÑ

/-- Tail path for `T_i` on the unbounded policy interval `(x,‚àû)`. -/
def gn21TailTiPath
    (arrivalRate : ‚Ñù)
    (density : ‚Ñù ‚Üí ‚Ñù) (x : ‚Ñù) : ‚Ñù :=
  1 + arrivalRate * ‚à´ œÑ in Set.Ioi x, œÑ * density œÑ

/-- Two-piece path for `Q_i` on the middle-rejection policy `(0,lo) ‚à™ (hi,‚àû)`. -/
def gn21RejectMiddleQiPath
    (arrivalRate switchRate : ‚Ñù)
    (density switchProb : ‚Ñù ‚Üí ‚Ñù) (lo hi : ‚Ñù) : ‚Ñù :=
  switchRate +
    arrivalRate *
      ((‚à´ œÑ in (0 : ‚Ñù)..lo, switchProb œÑ * density œÑ) +
        ‚à´ œÑ in Set.Ioi hi, switchProb œÑ * density œÑ)

/-- Two-piece path for `W_i` on the middle-rejection policy `(0,lo) ‚à™ (hi,‚àû)`. -/
def gn21RejectMiddleWiPath
    (arrivalRate : ‚Ñù)
    (density payment : ‚Ñù ‚Üí ‚Ñù) (lo hi : ‚Ñù) : ‚Ñù :=
  arrivalRate *
    ((‚à´ œÑ in (0 : ‚Ñù)..lo, payment œÑ * density œÑ) +
      ‚à´ œÑ in Set.Ioi hi, payment œÑ * density œÑ)

/-- Two-piece path for `T_i` on the middle-rejection policy `(0,lo) ‚à™ (hi,‚àû)`. -/
def gn21RejectMiddleTiPath
    (arrivalRate : ‚Ñù)
    (density : ‚Ñù ‚Üí ‚Ñù) (lo hi : ‚Ñù) : ‚Ñù :=
  1 + arrivalRate *
    ((‚à´ œÑ in (0 : ‚Ñù)..lo, œÑ * density œÑ) +
      ‚à´ œÑ in Set.Ioi hi, œÑ * density œÑ)

/-- Upper-endpoint interval policy used by the interval-density endpoint paths. -/
def gn21UpperEndpointPolicy (lowerEndpoint x : ‚Ñù) : TripPolicy :=
  Set.Ioc lowerEndpoint x

/-- Measurability of the upper-endpoint interval policy. -/
theorem measurableSet_gn21UpperEndpointPolicy (lowerEndpoint x : ‚Ñù) :
    MeasurableSet (gn21UpperEndpointPolicy lowerEndpoint x) := by
  simpa [gn21UpperEndpointPolicy] using measurableSet_Ioc

/--
Measured-policy realization of the endpoint `Q_i` path when trip lengths are
Lebesgue distributed with density `density` and the accepted set is the upper
endpoint interval `(lowerEndpoint, x]`.
-/
theorem gn21ExitWeightIntegral_upperEndpoint_withDensity_eq_endpointQiPath
    (arrivalRate switchIJ switchJI lowerEndpoint x : ‚Ñù)
    (density : ‚Ñù ‚Üí NNReal)
    (hdensity_meas : Measurable density)
    (hle : lowerEndpoint ‚â§ x) :
    gn21ExitWeightIntegral
        (volume.withDensity fun œÑ => (density œÑ : ‚Ñù‚â•0‚àû))
        arrivalRate switchIJ switchJI
        (gn21UpperEndpointPolicy lowerEndpoint x) =
      gn21EndpointQiPath arrivalRate switchIJ lowerEndpoint
        (fun œÑ => (density œÑ : ‚Ñù))
        (gn21SwitchProb switchIJ switchJI) x := by
  unfold gn21ExitWeightIntegral gn21EndpointQiPath gn21UpperEndpointPolicy
  rw [intervalIntegral.integral_of_le hle]
  rw [setIntegral_withDensity_eq_setIntegral_smul
    (Œº := volume) (f := density)
    hdensity_meas
    (fun œÑ => gn21SwitchProb switchIJ switchJI œÑ)
    measurableSet_Ioc]
  apply congrArg (fun y => switchIJ + arrivalRate * y)
  apply setIntegral_congr_fun measurableSet_Ioc
  intro œÑ _hœÑ
  simp [Algebra.smul_def, mul_comm]

/--
Measured-policy realization of the endpoint `T_i` path under an interval policy
and a Lebesgue density.
-/
theorem gn21ScaledStateTime_upperEndpoint_withDensity_eq_endpointTiPath
    (arrivalRate lowerEndpoint x : ‚Ñù)
    (density : ‚Ñù ‚Üí NNReal)
    (hdensity_meas : Measurable density)
    (hle : lowerEndpoint ‚â§ x) :
    gn21ScaledStateTime
        (volume.withDensity fun œÑ => (density œÑ : ‚Ñù‚â•0‚àû))
        arrivalRate
        (gn21UpperEndpointPolicy lowerEndpoint x) =
      gn21EndpointTiPath arrivalRate lowerEndpoint
        (fun œÑ => (density œÑ : ‚Ñù)) x := by
  unfold gn21ScaledStateTime singleStateTripTime gn21EndpointTiPath
    gn21UpperEndpointPolicy
  rw [intervalIntegral.integral_of_le hle]
  rw [setIntegral_withDensity_eq_setIntegral_smul
    (Œº := volume) (f := density) hdensity_meas (fun œÑ => œÑ)
    measurableSet_Ioc]
  apply congrArg (fun y => 1 + arrivalRate * y)
  apply setIntegral_congr_fun measurableSet_Ioc
  intro œÑ _hœÑ
  simp [Algebra.smul_def, mul_comm]

/--
Measured-policy realization of the endpoint `W_i` path under an interval policy
and a Lebesgue density.
-/
theorem gn21ScaledStateEarning_upperEndpoint_withDensity_eq_endpointWiPath
    (arrivalRate lowerEndpoint x : ‚Ñù)
    (density : ‚Ñù ‚Üí NNReal)
    (payment : PricingFunction)
    (hdensity_meas : Measurable density)
    (hle : lowerEndpoint ‚â§ x) :
    gn21ScaledStateEarning
