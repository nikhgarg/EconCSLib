          (gn21AcceptAllExitWeightIntegral (Œº 0) (arrival 0) switch12 switch21)
          (gn21AcceptAllExitWeightIntegral (Œº 1) (arrival 1) switch21 switch12)
          switch12 ‚àß
      1 ‚â§ gn21AcceptAllScaledStateTime (Œº 1) (arrival 1) ‚àß
      switch21 <
        gn21AcceptAllExitWeightIntegral (Œº 1) (arrival 1) switch21 switch12 := by
  have hsum12 : 0 < switch12 + switch21 := by
    linarith
  have hsum21 : 0 < switch21 + switch12 := by
    linarith
  have hT1_pos :
