theorem paper_lemma9_exists_pos_left_improvement_of_reject_middle_hi_interval_density_current_bounds
    (arrivalRate lo hi T1 Q1 T2 Q2 switch21 switch12 m R1 z ratio Œ¥ : ‚Ñù)
