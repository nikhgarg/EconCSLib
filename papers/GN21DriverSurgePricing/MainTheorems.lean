  hw_cont :
    ContinuousAt
      (fun τ => ctmcStructuredSurgePrice R2 (z 0) switch12 switch21 τ *
        density τ) u
  ht_int :
    IntervalIntegrable (fun τ => τ * density τ) volume lowerEndpoint u
  ht_meas :
    StronglyMeasurableAtFilter (fun τ => τ * density τ) (𝓝 u)
