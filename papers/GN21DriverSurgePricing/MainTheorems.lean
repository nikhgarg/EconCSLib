    (R : SingleStateReward) (w : PricingFunction) where
  policy : TripPolicy
  threshold : ‚Ñù
  threshold_nonneg : 0 ‚â§ threshold
  threshold_shape : thresholdRatePolicy w threshold policy
  reward_eq_threshold : R policy = threshold
