theorem gn21MeasuredAggregateRewardPrimitives_lt_union_left_of_kernel_pos
    (μI μJ : Measure TripLength)
    (arrivalI arrivalJ switchIJ switchJI : ℝ)
    (wI wJ : PricingFunction) (σI σJ added : TripPolicy)
