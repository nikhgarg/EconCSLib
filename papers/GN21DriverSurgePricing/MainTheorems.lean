    exact dynamicAcceptAllAlmostEverywhere_of_eq_acceptAllDynamicPolicy
      μ (H.2 ρ hρR)
  exact
    ⟨m, z, hnonneg, by simpa [R] using H.1, hAE,
      ⟨ctmcDynamicSwitchProb switch12 switch21, by intro i τ; rfl⟩,
      hparams⟩

