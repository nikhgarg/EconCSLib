/--
Local FTC bridge for an improper tail integral.  Around `u`, the tail
`‚à´_(x,‚àû) f` is a fixed tail constant minus the finite interval integral
`‚à´_(u-1)^x f`, so its derivative is `-f u`.
-/
theorem integral_Ioi_hasDerivAt
    (f : ‚Ñù ‚Üí ‚Ñù) (u : ‚Ñù)
    (hint : IntegrableOn f (Set.Ioi (u - 1)) volume)
    (hmeas : StronglyMeasurableAtFilter f (ùìù u))
    (hcont : ContinuousAt f u) :
    HasDerivAt (fun x => ‚à´ œÑ in Set.Ioi x, f œÑ) (-(f u)) u := by
  let a : ‚Ñù := u - 1
  have hau : a < u := by
    dsimp [a]
    linarith
  have hinterval : IntervalIntegrable f volume a u := by
    rw [intervalIntegrable_iff_integrableOn_Ioc_of_le hau.le]
    exact hint.mono_set (fun _ hœÑ => hœÑ.1)
  have hfinite :
      HasDerivAt
        (fun x => (‚à´ œÑ in Set.Ioi a, f œÑ) - ‚à´ œÑ in a..x, f œÑ)
        (-(f u)) u := by
    have h :=
      (intervalIntegral.integral_hasDerivAt_right hinterval hmeas hcont).const_sub
        (‚à´ œÑ in Set.Ioi a, f œÑ)
    simpa using h
  have heq :
      (fun x => ‚à´ œÑ in Set.Ioi x, f œÑ) =·∂Ý[ùìù u]
        (fun x => (‚à´ œÑ in Set.Ioi a, f œÑ) - ‚à´ œÑ in a..x, f œÑ) := by
    filter_upwards [Ioi_mem_nhds hau] with x hx
    have hsub := intervalIntegral.integral_Ioi_sub_Ioi hint (le_of_lt hx)
    have hsub' :
        (‚à´ œÑ in Set.Ioi a, f œÑ) - (‚à´ œÑ in Set.Ioi x, f œÑ) =
          ‚à´ œÑ in a..x, f œÑ := by
      simpa [a] using hsub
    linarith
  exact hfinite.congr_of_eventuallyEq heq

