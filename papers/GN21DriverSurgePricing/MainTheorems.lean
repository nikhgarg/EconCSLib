  ⟨⟨.strictlyDecreasing, theorem4NonsurgeAllowedLemma5Shape_strictlyDecreasing⟩,
    lemma5StrictlyDecreasingOptimizerReplacementCertificate_rejectLong
      Rhat σ0 t hreward_ge hstrict_unless_rejects_long⟩

