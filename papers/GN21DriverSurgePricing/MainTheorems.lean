            R hœÅstar 1 sdata.2.2.1)
      only_policy_forms := by
        intro œÅ hœÅ
        rcases C.replacements œÅ hœÅ with
          ‚ü®‚ü®‚ü®nshape, hnallowed‚ü©, ‚ü®hnreplacement, hnfeasible‚ü©‚ü©,
            ‚ü®‚ü®sshape, hsallowed‚ü©, ‚ü®hsreplacement, hsfeasible‚ü©‚ü©‚ü©
        exact
          ‚ü®‚ü®nshape, hnallowed,
              lemma5PolicyForm_of_optimizer_replacement_certificate_of_candidate_le
                (dynamicStateReward R œÅ 0) (œÅ 0) nshape hnreplacement
                (dynamicStateReward_optimal_of_dynamicMeasurableOptimal
                  R hœÅ 0 hnfeasible.1)‚ü©,
            ‚ü®sshape, hsallowed,
              lemma5PolicyForm_of_optimizer_replacement_certificate_of_candidate_le
                (dynamicStateReward R œÅ 1) (œÅ 1) sshape hsreplacement
                (dynamicStateReward_optimal_of_dynamicMeasurableOptimal
                  R hœÅ 1 hsfeasible.1)‚ü©‚ü© }

