/--
Theorem 1 Step 2 add case: for a partial threshold policy, adding a positive
time boundary set with rate `c` cannot reduce reward when `c` is at least the
current reward rate.
-/
theorem paper_theorem1_step2_add_boundary_set_if_threshold_ge_current
    (Œº : Measure TripLength) (arrivalRate : ‚Ñù) (w : PricingFunction)
    (œÉ boundary : TripPolicy) (c : ‚Ñù)
    (hdisjoint : Disjoint œÉ boundary)
    (hboundary_measurable : MeasurableSet boundary)
    (hw_integrable_œÉ : IntegrableOn w œÉ Œº)
    (hw_integrable_boundary : IntegrableOn w boundary Œº)
    (htime_integrable_œÉ :
      IntegrableOn (fun œÑ : TripLength => œÑ) œÉ Œº)
    (htime_integrable_boundary :
      IntegrableOn (fun œÑ : TripLength => œÑ) boundary Œº)
    (hlambda : 0 < arrivalRate)
    (htime_nonneg : 0 ‚â§ singleStateTripTime Œº œÉ)
    (hboundary_time_pos : 0 < singleStateTripTime Œº boundary)
    (hboundary_positive : boundary ‚äÜ acceptAllPolicy)
