/-- Replacing one state by accept-all preserves feasible measurability. -/
theorem dynamicFeasibleMeasurablePolicy_update_acceptAll
    {œÉ : Fin 2 ‚Üí TripPolicy}
    (hœÉ : dynamicFeasibleMeasurablePolicy œÉ)
    (i : Fin 2) :
    dynamicFeasibleMeasurablePolicy
      (Function.update œÉ i acceptAllPolicy) := by
  intro j
  by_cases hji : j = i
  ¬∑ subst j
    constructor
    ¬∑ intro œÑ hœÑ
      simpa [Function.update] using hœÑ
    ¬∑ simpa [Function.update] using measurableSet_acceptAllPolicy
  ¬∑ have hj := hœÉ j
    constructor
    ¬∑ intro œÑ hœÑ
      exact hj.1 (by simpa [Function.update, hji] using hœÑ)
    ¬∑ simpa [Function.update, hji] using hj.2

/-- Replacing one state by any feasible measurable trip policy preserves the domain. -/
theorem dynamicFeasibleMeasurablePolicy_update
    {œÉ : Fin 2 ‚Üí TripPolicy}
    (hœÉ : dynamicFeasibleMeasurablePolicy œÉ)
    (i : Fin 2) (œÑ : TripPolicy)
    (hœÑ_subset : œÑ ‚äÜ acceptAllPolicy)
    (hœÑ_measurable : MeasurableSet œÑ) :
    dynamicFeasibleMeasurablePolicy (Function.update œÉ i œÑ) := by
  intro j
  by_cases hji : j = i
  ¬∑ subst j
    constructor
    ¬∑ intro x hx
      exact hœÑ_subset (by simpa [Function.update] using hx)
    ¬∑ simpa [Function.update] using hœÑ_measurable
  ¬∑ have hj := hœÉ j
    constructor
    ¬∑ intro x hx
      exact hj.1 (by simpa [Function.update, hji] using hx)
    ¬∑ simpa [Function.update, hji] using hj.2

/--
Dynamic optimality restricted to the source feasible measurable policy domain.
The target policy is included in the domain explicitly.
-/
def dynamicMeasurableOptimal
    (R : DynamicReward) (œÉ : Fin 2 ‚Üí TripPolicy) : Prop :=
  dynamicFeasibleMeasurablePolicy œÉ ‚àß
    ‚àÄ œÅ : Fin 2 ‚Üí TripPolicy,
      dynamicFeasibleMeasurablePolicy œÅ ‚Üí R œÅ ‚â§ R œÉ

/--
Dynamic measurable IC predicate: accepting all trips in both states is optimal
among feasible measurable dynamic policies.
-/
def dynamicMeasurableIncentiveCompatible (R : DynamicReward) : Prop :=
  dynamicMeasurableOptimal R acceptAllDynamicPolicy

/--
Statewise continuation reward induced by a dynamic reward functional after
holding the other state's policy fixed.
-/
def dynamicStateReward
    (R : DynamicReward) (œÉ : Fin 2 ‚Üí TripPolicy) (i : Fin 2) :
    SingleStateReward :=
  fun œÑ => R (Function.update œÉ i œÑ)

/--
A dynamically optimal policy is locally optimal in each state when the other
state's policy is fixed.
-/
theorem dynamicStateReward_optimal_of_dynamicOptimal
    (R : DynamicReward) {œÉ : Fin 2 ‚Üí TripPolicy}
    (hœÉ : dynamicOptimal R œÉ) (i : Fin 2) :
    ‚àÄ œÑ : TripPolicy,
      dynamicStateReward R œÉ i œÑ ‚â§ dynamicStateReward R œÉ i (œÉ i) := by
  intro œÑ
  unfold dynamicStateReward
  simpa [Function.update_eq_self] using hœÉ (Function.update œÉ i œÑ)

/--
A measurably optimal dynamic policy is locally optimal against feasible
measurable one-state replacements.
-/
theorem dynamicStateReward_optimal_of_dynamicMeasurableOptimal
    (R : DynamicReward) {œÉ : Fin 2 ‚Üí TripPolicy}
    (hœÉ : dynamicMeasurableOptimal R œÉ) (i : Fin 2)
    {œÑ : TripPolicy}
    (hœÑ : dynamicFeasibleMeasurablePolicy (Function.update œÉ i œÑ)) :
    dynamicStateReward R œÉ i œÑ ‚â§ dynamicStateReward R œÉ i (œÉ i) := by
  unfold dynamicStateReward
  simpa [Function.update_eq_self] using hœÉ.2 (Function.update œÉ i œÑ) hœÑ

/--
If replacing either state's policy by accept-all weakly improves reward, then
accept-all is dynamically optimal.
-/
theorem dynamicOptimal_acceptAll_of_statewise_acceptAll_improvements
    (R : DynamicReward)
    (hnonsurge :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicStateReward R œÉ 0 (œÉ 0) ‚â§
          dynamicStateReward R œÉ 0 acceptAllPolicy)
    (hsurge :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicStateReward R œÉ 1 (œÉ 1) ‚â§
          dynamicStateReward R œÉ 1 acceptAllPolicy) :
    dynamicOptimal R acceptAllDynamicPolicy := by
  intro œÉ
  have h0 :
      R œÉ ‚â§ R (Function.update œÉ 0 acceptAllPolicy) := by
    simpa [dynamicStateReward, Function.update_eq_self] using hnonsurge œÉ
  have h1 :
      R (Function.update œÉ 0 acceptAllPolicy) ‚â§ R acceptAllDynamicPolicy := by
    have h := hsurge (Function.update œÉ 0 acceptAllPolicy)
    unfold dynamicStateReward at h
    have hcur :
        Function.update (Function.update œÉ 0 acceptAllPolicy) 1
            (œÉ 1) =
          Function.update œÉ 0 acceptAllPolicy := by
      have hval : (Function.update œÉ 0 acceptAllPolicy) 1 = œÉ 1 := by
        simp
      rw [‚Üê hval]
      exact Function.update_eq_self 1 (Function.update œÉ 0 acceptAllPolicy)
    have htarget :
        Function.update (Function.update œÉ 0 acceptAllPolicy) 1
            acceptAllPolicy =
          acceptAllDynamicPolicy := by
      funext i
      fin_cases i <;> simp [acceptAllDynamicPolicy]
    simpa [hcur, htarget] using h
  exact le_trans h0 h1

/--
If replacing either state's policy by accept-all weakly improves reward for
every feasible measurable dynamic policy, then accept-all is optimal on the
source feasible measurable policy domain.
-/
theorem dynamicMeasurableOptimal_acceptAll_of_statewise_acceptAll_improvements
    (R : DynamicReward)
    (hnonsurge :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicFeasibleMeasurablePolicy œÉ ‚Üí
          dynamicStateReward R œÉ 0 (œÉ 0) ‚â§
            dynamicStateReward R œÉ 0 acceptAllPolicy)
    (hsurge :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicFeasibleMeasurablePolicy œÉ ‚Üí
          dynamicStateReward R œÉ 1 (œÉ 1) ‚â§
            dynamicStateReward R œÉ 1 acceptAllPolicy) :
    dynamicMeasurableOptimal R acceptAllDynamicPolicy := by
  constructor
  ¬∑ exact dynamicFeasibleMeasurablePolicy_acceptAll
  ¬∑ intro œÉ hœÉ
    have h0 :
        R œÉ ‚â§ R (Function.update œÉ 0 acceptAllPolicy) := by
      simpa [dynamicStateReward, Function.update_eq_self] using
        hnonsurge œÉ hœÉ
    have hœÉ0 :
        dynamicFeasibleMeasurablePolicy
          (Function.update œÉ 0 acceptAllPolicy) :=
      dynamicFeasibleMeasurablePolicy_update_acceptAll hœÉ 0
    have h1 :
        R (Function.update œÉ 0 acceptAllPolicy) ‚â§
          R acceptAllDynamicPolicy := by
      have h := hsurge (Function.update œÉ 0 acceptAllPolicy) hœÉ0
      unfold dynamicStateReward at h
      have hcur :
          Function.update (Function.update œÉ 0 acceptAllPolicy) 1
              (œÉ 1) =
            Function.update œÉ 0 acceptAllPolicy := by
        have hval : (Function.update œÉ 0 acceptAllPolicy) 1 = œÉ 1 := by
          simp
        rw [‚Üê hval]
        exact Function.update_eq_self 1 (Function.update œÉ 0 acceptAllPolicy)
      have htarget :
          Function.update (Function.update œÉ 0 acceptAllPolicy) 1
              acceptAllPolicy =
            acceptAllDynamicPolicy := by
        funext i
        fin_cases i <;> simp [acceptAllDynamicPolicy]
      simpa [hcur, htarget] using h
    exact le_trans h0 h1

/--
Accept-all unique optimality from a strict global dominance certificate. This
is the direct order-theoretic endpoint used after the continuous derivative
arguments rule out every non-accept-all optimum.
-/
theorem acceptAllDynamic_unique_optimal_of_strict_dominates
    (R : DynamicReward)
    (hweak : ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy, R œÉ ‚â§ R acceptAllDynamicPolicy)
    (hstrict :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        œÉ ‚âÝ acceptAllDynamicPolicy ‚Üí R œÉ < R acceptAllDynamicPolicy) :
    dynamicOptimal R acceptAllDynamicPolicy ‚àß
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicOptimal R œÉ ‚Üí œÉ = acceptAllDynamicPolicy := by
  constructor
  ¬∑ exact hweak
  ¬∑ intro œÉ hopt
    by_contra hne
    have hlt := hstrict œÉ hne
    have hge : R acceptAllDynamicPolicy ‚â§ R œÉ := hopt acceptAllDynamicPolicy
    linarith

/--
Accept-all unique optimality from the statewise conclusion that every optimal
policy is feasible and accepts all positive trip requests in both states.
-/
theorem acceptAllDynamic_unique_optimal_of_statewise_accept_all_optima
    (R : DynamicReward)
    (haccept_opt : dynamicOptimal R acceptAllDynamicPolicy)
    (hfeasible :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicOptimal R œÉ ‚Üí ‚àÄ i : Fin 2, œÉ i ‚äÜ acceptAllPolicy)
    (hall :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicOptimal R œÉ ‚Üí ‚àÄ i : Fin 2, acceptsAllTrips (œÉ i)) :
    dynamicOptimal R acceptAllDynamicPolicy ‚àß
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicOptimal R œÉ ‚Üí œÉ = acceptAllDynamicPolicy := by
  constructor
  ¬∑ exact haccept_opt
  ¬∑ intro œÉ hœÉ
    exact eq_acceptAllDynamicPolicy_of_statewise_subset_acceptsAll
      (hfeasible œÉ hœÉ) (hall œÉ hœÉ)

/--
Strict local-improvement certificate: if an optimal policy fails accept-all in
some state, the one-state continuation problem has a strict profitable local
replacement.  Together with existence of an optimum and feasibility of all
optima, this is enough to recover accept-all unique optimality without a global
weak-dominance comparison against accept-all.
-/
structure Theorem4StrictLocalImprovementCertificate
    (R : DynamicReward) where
  exists_optimal : ‚àÉ œÉ : Fin 2 ‚Üí TripPolicy, dynamicOptimal R œÉ
  feasible_optimal :
    ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy, dynamicOptimal R œÉ ‚Üí
      ‚àÄ i : Fin 2, œÉ i ‚äÜ acceptAllPolicy
  nonsurge_strict_improvement_unless :
    ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy, (hœÉ : dynamicOptimal R œÉ) ‚Üí
      ¬¨ acceptsAllTrips (œÉ 0) ‚Üí
        ‚àÉ œÑ : TripPolicy,
          dynamicStateReward R œÉ 0 (œÉ 0) < dynamicStateReward R œÉ 0 œÑ
  surge_strict_improvement_unless :
    ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy, (hœÉ : dynamicOptimal R œÉ) ‚Üí
      ¬¨ acceptsAllTrips (œÉ 1) ‚Üí
        ‚àÉ œÑ : TripPolicy,
          dynamicStateReward R œÉ 1 (œÉ 1) < dynamicStateReward R œÉ 1 œÑ

/--
Strict local improvements rule out every non-accept-all optimum.  An existing
optimum must therefore equal accept-all, which gives accept-all optimality and
uniqueness.
-/
theorem acceptAllDynamic_unique_optimal_of_strict_local_improvements
    (R : DynamicReward)
    (C : Theorem4StrictLocalImprovementCertificate R) :
    dynamicOptimal R acceptAllDynamicPolicy ‚àß
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicOptimal R œÉ ‚Üí œÉ = acceptAllDynamicPolicy := by
  have hall :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicOptimal R œÉ ‚Üí ‚àÄ i : Fin 2, acceptsAllTrips (œÉ i) := by
    intro œÉ hœÉ i
    fin_cases i
    ¬∑ by_contra hnot
      rcases C.nonsurge_strict_improvement_unless œÉ hœÉ hnot with
        ‚ü®œÑ, hlt‚ü©
      have hlocal := dynamicStateReward_optimal_of_dynamicOptimal R hœÉ 0 œÑ
      linarith
    ¬∑ by_contra hnot
      rcases C.surge_strict_improvement_unless œÉ hœÉ hnot with
        ‚ü®œÑ, hlt‚ü©
      have hlocal := dynamicStateReward_optimal_of_dynamicOptimal R hœÉ 1 œÑ
      linarith
  have hunique :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicOptimal R œÉ ‚Üí œÉ = acceptAllDynamicPolicy := by
    intro œÉ hœÉ
    exact eq_acceptAllDynamicPolicy_of_statewise_subset_acceptsAll
      (C.feasible_optimal œÉ hœÉ) (hall œÉ hœÉ)
  rcases C.exists_optimal with ‚ü®œÉstar, hœÉstar‚ü©
  have hstar_eq := hunique œÉstar hœÉstar
  have haccept : dynamicOptimal R acceptAllDynamicPolicy := by
    simpa [hstar_eq] using hœÉstar
  exact ‚ü®haccept, hunique‚ü©

/--
Strict local-improvement certificate on the source feasible measurable domain.
The replacement itself is required to remain feasible measurable.
-/
structure Theorem4MeasurableStrictLocalImprovementCertificate
    (R : DynamicReward) where
  exists_optimal :
    ‚àÉ œÉ : Fin 2 ‚Üí TripPolicy, dynamicMeasurableOptimal R œÉ
  nonsurge_strict_improvement_unless :
    ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy, (hœÉ : dynamicMeasurableOptimal R œÉ) ‚Üí
      ¬¨ acceptsAllTrips (œÉ 0) ‚Üí
        ‚àÉ œÑ : TripPolicy,
          dynamicFeasibleMeasurablePolicy (Function.update œÉ 0 œÑ) ‚àß
            dynamicStateReward R œÉ 0 (œÉ 0) <
              dynamicStateReward R œÉ 0 œÑ
  surge_strict_improvement_unless :
    ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy, (hœÉ : dynamicMeasurableOptimal R œÉ) ‚Üí
      ¬¨ acceptsAllTrips (œÉ 1) ‚Üí
        ‚àÉ œÑ : TripPolicy,
          dynamicFeasibleMeasurablePolicy (Function.update œÉ 1 œÑ) ‚àß
            dynamicStateReward R œÉ 1 (œÉ 1) <
              dynamicStateReward R œÉ 1 œÑ

/--
Strict feasible-measurable local improvements rule out every non-accept-all
measurable optimum.  Existence of a feasible measurable optimum then promotes
accept-all itself to the measurable optimum.
-/
theorem acceptAllDynamic_measurable_unique_optimal_of_strict_local_improvements
    (R : DynamicReward)
    (C : Theorem4MeasurableStrictLocalImprovementCertificate R) :
    dynamicMeasurableOptimal R acceptAllDynamicPolicy ‚àß
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicMeasurableOptimal R œÉ ‚Üí œÉ = acceptAllDynamicPolicy := by
  have hall :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicMeasurableOptimal R œÉ ‚Üí ‚àÄ i : Fin 2, acceptsAllTrips (œÉ i) := by
    intro œÉ hœÉ i
    fin_cases i
    ¬∑ by_contra hnot
      rcases C.nonsurge_strict_improvement_unless œÉ hœÉ hnot with
        ‚ü®œÑ, hœÑ_feasible, hlt‚ü©
      have hlocal :=
        dynamicStateReward_optimal_of_dynamicMeasurableOptimal
          R hœÉ 0 hœÑ_feasible
      linarith
    ¬∑ by_contra hnot
      rcases C.surge_strict_improvement_unless œÉ hœÉ hnot with
        ‚ü®œÑ, hœÑ_feasible, hlt‚ü©
      have hlocal :=
        dynamicStateReward_optimal_of_dynamicMeasurableOptimal
          R hœÉ 1 hœÑ_feasible
      linarith
  have hunique :
      ‚àÄ œÉ : Fin 2 ‚Üí TripPolicy,
        dynamicMeasurableOptimal R œÉ ‚Üí œÉ = acceptAllDynamicPolicy := by
    intro œÉ hœÉ
    exact eq_acceptAllDynamicPolicy_of_statewise_subset_acceptsAll
      (fun i => (hœÉ.1 i).1) (hall œÉ hœÉ)
  rcases C.exists_optimal with ‚ü®œÉstar, hœÉstar‚ü©
  have hstar_eq := hunique œÉstar hœÉstar
  have haccept : dynamicMeasurableOptimal R acceptAllDynamicPolicy := by
    simpa [hstar_eq] using hœÉstar
  exact ‚ü®haccept, hunique‚ü©

/-- Concrete dynamic profitable-deviation witness against accept-all behavior. -/
def dynamicProfitableDeviation (R : DynamicReward) (œÅ : Fin 2 ‚Üí TripPolicy) : Prop :=
  R acceptAllDynamicPolicy < R œÅ

/-- A profitable dynamic deviation refutes incentive compatibility. -/
theorem not_dynamicIncentiveCompatible_of_profitableDeviation
    (R : DynamicReward) (œÅ : Fin 2 ‚Üí TripPolicy)
    (hdev : dynamicProfitableDeviation R œÅ) :
    ¬¨ dynamicIncentiveCompatible R := by
  intro hIC
  exact not_le_of_gt hdev (hIC œÅ)

/--
Section 4.1 two-state CTMC transition probability from state `i` to the other
state after elapsed time `s`.
-/
def gn21SwitchProb (lambdaIJ lambdaJI s : ‚Ñù) : ‚Ñù :=
  twoStateCtmcSwitchProb lambdaIJ lambdaJI s

/-- Section 4.1 two-state CTMC transition kernel on non-surge/surge states. -/
def gn21TransitionProb (lambda01 lambda10 s : ‚Ñù) (i j : Fin 2) : ‚Ñù :=
  twoStateCtmcTransitionProb lambda01 lambda10 s i j

/-- Lemma 2 formula, as the reusable two-state CTMC switch probability. -/
theorem paper_lemma2_switch_probability_formula
    (lambdaIJ lambdaJI s : ‚Ñù) :
    gn21SwitchProb lambdaIJ lambdaJI s =
      lambdaIJ / (lambdaIJ + lambdaJI) *
        (1 - Real.exp (-(lambdaIJ + lambdaJI) * s)) := by
  rfl

/-- Lemma 2 initial condition: the switch probability is zero at elapsed time zero. -/
@[simp] theorem paper_lemma2_switch_probability_zero
    (lambdaIJ lambdaJI : ‚Ñù) :
    gn21SwitchProb lambdaIJ lambdaJI 0 = 0 := by
  simp [gn21SwitchProb]

/--
Lemma 2 ODE check: the closed-form switch probability satisfies the two-state
Kolmogorov forward equation.
-/
theorem paper_lemma2_switch_probability_forward_equation
    (lambdaIJ lambdaJI s : ‚Ñù) (hsum : lambdaIJ + lambdaJI ‚âÝ 0) :
    deriv (fun t => gn21SwitchProb lambdaIJ lambdaJI t) s =
      lambdaIJ * (1 - gn21SwitchProb lambdaIJ lambdaJI s) -
        lambdaJI * gn21SwitchProb lambdaIJ lambdaJI s := by
  exact twoStateCtmcSwitchProb_deriv_eq_forward lambdaIJ lambdaJI s hsum

/-- Lemma 2 probability-range lower bound for the closed-form switch probability. -/
theorem paper_lemma2_switch_probability_nonneg
    (lambdaIJ lambdaJI s : ‚Ñù)
    (hlambdaIJ : 0 ‚â§ lambdaIJ)
    (hsum : 0 < lambdaIJ + lambdaJI)
    (hs : 0 ‚â§ s) :
    0 ‚â§ gn21SwitchProb lambdaIJ lambdaJI s := by
  exact twoStateCtmcSwitchProb_nonneg lambdaIJ lambdaJI s hlambdaIJ hsum hs

/-- Lemma 2 strict positivity for positive elapsed time and positive outbound rate. -/
theorem paper_lemma2_switch_probability_pos
    (lambdaIJ lambdaJI s : ‚Ñù)
    (hlambdaIJ : 0 < lambdaIJ)
    (hsum : 0 < lambdaIJ + lambdaJI)
    (hs : 0 < s) :
    0 < gn21SwitchProb lambdaIJ lambdaJI s := by
  exact twoStateCtmcSwitchProb_pos lambdaIJ lambdaJI s hlambdaIJ hsum hs

/-- Lemma 2 probability-range upper bound for the closed-form switch probability. -/
theorem paper_lemma2_switch_probability_le_one
    (lambdaIJ lambdaJI s : ‚Ñù)
    (hlambdaIJ : 0 ‚â§ lambdaIJ) (hlambdaJI : 0 ‚â§ lambdaJI)
    (hsum : 0 < lambdaIJ + lambdaJI)
    (hs : 0 ‚â§ s) :
    gn21SwitchProb lambdaIJ lambdaJI s ‚â§ 1 := by
  exact twoStateCtmcSwitchProb_le_one lambdaIJ lambdaJI s
    hlambdaIJ hlambdaJI hsum hs

/-- Lemma 2 transition-kernel initial condition. -/
theorem paper_lemma2_transition_probability_zero_time
    (lambda01 lambda10 : ‚Ñù) (i j : Fin 2) :
    gn21TransitionProb lambda01 lambda10 0 i j =
      if i = j then 1 else 0 := by
  exact twoStateCtmcTransitionProb_zero_time lambda01 lambda10 i j

/-- Lemma 2 transition-kernel row-sum identity. -/
theorem paper_lemma2_transition_probability_row_sum
    (lambda01 lambda10 s : ‚Ñù) (i : Fin 2) :
    gn21TransitionProb lambda01 lambda10 s i 0 +
        gn21TransitionProb lambda01 lambda10 s i 1 = 1 := by
  exact twoStateCtmcTransitionProb_row_sum lambda01 lambda10 s i

/-- The CTMC switch probability is continuous in elapsed trip length. -/
theorem continuous_gn21SwitchProb
    (lambdaIJ lambdaJI : ‚Ñù) :
    Continuous (gn21SwitchProb lambdaIJ lambdaJI) := by
  unfold gn21SwitchProb twoStateCtmcSwitchProb
  fun_prop

/-!
Lemma 3's stochastic renewal argument has a law-of-large-numbers layer and a
deterministic algebra layer.  The declarations below close the algebra layer:
once subcycle lengths and cross-state subcycle probabilities are reduced to
the paper's `T_i` and `Q_i` quantities, the displayed formula for `Œº_i`
follows by cancellation.
-/

/-- Paper subcycle length `S_i = Œª_i F_i/(Œª_i F_i+Œª_{i‚Üíj}) * T_i`. -/
def gn21SubcycleLength
    (arrivalRate acceptProb switchRate stateCycleTime : ‚Ñù) : ‚Ñù :=
  (arrivalRate * acceptProb) / (arrivalRate * acceptProb + switchRate) *
    stateCycleTime

/-- Lemma 1/3 one-state cycle time `T_i(œÉ_i)` from the source paper. -/
def gn21StateCycleTime
    (Œº : Measure TripLength) (arrivalRate : ‚Ñù) (œÉ : TripPolicy) : ‚Ñù :=
  1 / (arrivalRate * singleStateTripMass Œº œÉ) +
    singleStateTripTime Œº œÉ / singleStateTripMass Œº œÉ

/-- Lemma 3 integral exit weight `Q_i(œÉ_i)`. -/
def gn21ExitWeightIntegral
    (Œº : Measure TripLength) (arrivalRate switchIJ switchJI : ‚Ñù)
    (œÉ : TripPolicy) : ‚Ñù :=
  switchIJ + arrivalRate * ‚à´ œÑ in œÉ, gn21SwitchProb switchIJ switchJI œÑ ‚àÇŒº

/-- Exit weights are at least the raw switch rate under nonnegative arrivals and feasible trips. -/
theorem gn21ExitWeightIntegral_ge_switch_of_nonneg
    (Œº : Measure TripLength) (arrivalRate switchIJ switchJI : ‚Ñù)
    (œÉ : TripPolicy)
    (harrival_nonneg : 0 ‚â§ arrivalRate)
    (hswitch_nonneg : 0 ‚â§ switchIJ)
    (hsum : 0 < switchIJ + switchJI)
    (hœÉ_measurable : MeasurableSet œÉ)
    (hœÉ_positive : œÉ ‚äÜ acceptAllPolicy) :
    switchIJ ‚â§ gn21ExitWeightIntegral Œº arrivalRate switchIJ switchJI œÉ := by
  unfold gn21ExitWeightIntegral
  have hintegral_nonneg :
      0 ‚â§ ‚à´ œÑ in œÉ, gn21SwitchProb switchIJ switchJI œÑ ‚àÇŒº := by
    exact setIntegral_nonneg hœÉ_measurable (fun œÑ hœÑ =>
      paper_lemma2_switch_probability_nonneg switchIJ switchJI œÑ
        hswitch_nonneg hsum (le_of_lt (hœÉ_positive hœÑ)))
  have hcomponent_nonneg :
      0 ‚â§ arrivalRate * ‚à´ œÑ in œÉ, gn21SwitchProb switchIJ switchJI œÑ ‚àÇŒº :=
    mul_nonneg harrival_nonneg hintegral_nonneg
  linarith

/-- Exit weights are positive when the raw switch rate is positive. -/
theorem gn21ExitWeightIntegral_pos_of_switch_pos
    (Œº : Measure TripLength) (arrivalRate switchIJ switchJI : ‚Ñù)
    (œÉ : TripPolicy)
    (harrival_nonneg : 0 ‚â§ arrivalRate)
    (hswitch_pos : 0 < switchIJ)
    (hsum : 0 < switchIJ + switchJI)
    (hœÉ_measurable : MeasurableSet œÉ)
    (hœÉ_positive : œÉ ‚äÜ acceptAllPolicy) :
    0 < gn21ExitWeightIntegral Œº arrivalRate switchIJ switchJI œÉ := by
  exact lt_of_lt_of_le hswitch_pos
    (gn21ExitWeightIntegral_ge_switch_of_nonneg Œº arrivalRate switchIJ switchJI œÉ
      harrival_nonneg (le_of_lt hswitch_pos) hsum hœÉ_measurable hœÉ_positive)

/--
Appendix D scaled state time `T_i = Œª_i F_i(œÉ_i)T_i(œÉ_i) =
1 + Œª_i ‚à´_œÉ œÑ dF_i(œÑ)`.
-/
def gn21ScaledStateTime
    (Œº : Measure TripLength) (arrivalRate : ‚Ñù) (œÉ : TripPolicy) : ‚Ñù :=
  1 + arrivalRate * singleStateTripTime Œº œÉ

/-- Scaled state time is monotone among feasible policies under nonnegative arrivals. -/
theorem gn21ScaledStateTime_le_acceptAll_of_subset
    (Œº : Measure TripLength) (arrivalRate : ‚Ñù) (œÉ : TripPolicy)
    (harrival_nonneg : 0 ‚â§ arrivalRate)
    (htime_integrable_acceptAll :
      IntegrableOn (fun œÑ : TripLength => œÑ) acceptAllPolicy Œº)
    (hœÉ_subset : œÉ ‚äÜ acceptAllPolicy) :
    gn21ScaledStateTime Œº arrivalRate œÉ ‚â§
      gn21ScaledStateTime Œº arrivalRate acceptAllPolicy := by
  unfold gn21ScaledStateTime
  have htime_le :
      singleStateTripTime Œº œÉ ‚â§ singleStateTripTime Œº acceptAllPolicy :=
