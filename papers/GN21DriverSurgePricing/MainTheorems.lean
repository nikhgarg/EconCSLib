def Theorem4MeasuredAggregateStructuredCurrentBoundsSourceFeasibleCertificate.of_reward_rate
    (μ : Fin 2 → Measure TripLength)
    (arrival : Fin 2 → ℝ)
    (R1 R2 switch12 switch21 : ℝ)
