              switch12 switch21 (policy 0))
            (gn21AcceptAllScaledStateTime (μ 1) (arrival 1))
            (gn21AcceptAllExitWeightIntegral (μ 1) (arrival 1)
              switch21 switch12)
            switch21 *
          lemma9StructuredUpperDenominator
            (gn21ExitWeightIntegral (μ 0) (arrival 0)
              switch12 switch21 (policy 0))
