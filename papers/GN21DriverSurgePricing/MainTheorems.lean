          (Ri * C.Ti) (Rj * C.Tj) := by
    simp [hWi, hWj]
  refine sameStrictSign_trans C.same_sign ?_
  rw [hkernel]
  exact paper_lemma6_derivative_kernel_same_sign_response
    C.q C.u C.wi C.Qi C.Qj C.Ti C.Tj Ri Rj hu hTi_pos hTj_pos

