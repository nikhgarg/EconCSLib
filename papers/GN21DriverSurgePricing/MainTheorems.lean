    (hδ : 0 < δ)
    (Hcur :
      GN21MeasuredPairNondegenerate (μ 0) (μ 1) (arrival 0) (arrival 1)
        switch12 switch21 (ρ 0) (ρ 1))
    (Hrep :
      ∀ ε : ℝ, 0 < ε → ε < δ →
        GN21MeasuredPairNondegenerate (μ 0) (μ 1) (arrival 0) (arrival 1)
          switch12 switch21 (ρ 0) (replacement ε))
