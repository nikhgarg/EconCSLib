          lemma10StructuredBounds nonsurgeRatio T2 Q2 T1 Q1 switch12 ∧
            lemma9StructuredBounds surgeRatio T1 Q1 T2 Q2 switch21 ∧
            m 0 = R2 ∧
            z 0 = nonsurgeRatio * R2 ∧
            m 1 =
              theorem3SurgeMultiplierFromRatio R1 R2 T2 Q2 switch21 surgeRatio ∧
