/--
Terminal-dynamic certificate for the strict ordered local-deviation
constructed outcome from clock-sorted finite exact-drop schedule data.  This
keeps local-deviation schedule statements in terms of the paper-facing
`exact_schedule_model` while reusing the generic dynamic-certificate
constructor internally.
-/
noncomputable def paper_theorem8_bstar_ranked_threshold_strict_ordered_local_deviation_terminal_dynamic_certificate_of_clock_sorted_nodup_unscheduled_threshold_gt
    (model :
      PaperTheorem8BStarRankedThresholdStrictOrderedLocalOptimalityCertificate)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
