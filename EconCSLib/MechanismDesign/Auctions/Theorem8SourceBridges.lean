/--
History-local advance safety controls realized clock advances, but it does not
repair an initial state whose clock has already overshot an active rank's
finite `B*` threshold. The one-step overshoot witness is source-extensive,
history-locally advance-safe (vacuously: the only step is a dropout), and still
not an exact finite `B*` dropout history.
-/
theorem paper_theorem8_bstar_ranked_threshold_source_extensive_rationality_local_advance_safe_allows_preexisting_overshoot_not_exact_drop_history
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (rank : ℕ) :
    let state :=
      paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
        model rank
    let finalState :=
      PaperTheorem8GeneralizedEnglishAuctionState.recordDropout state rank
    let namedStrategy :=
      paper_theorem8_bstar_ranked_threshold_strategy
        model.value model.clickThroughRate model.remaining
    ∃ hsource_extensive :
      paper_theorem8_bstar_ranked_threshold_source_extensive_rationality_statement
        model state finalState namedStrategy,
      PaperTheorem8BStarRankedThresholdStrategyHistoryAdvanceSafe
          model hsource_extensive.2.1 ∧
        ¬ PaperTheorem8BStarRankedThresholdExactDropHistory
          model state finalState := by
  dsimp
  let state :=
    paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
      model rank
  let finalState :=
    PaperTheorem8GeneralizedEnglishAuctionState.recordDropout state rank
  let namedStrategy :=
    paper_theorem8_bstar_ranked_threshold_strategy
      model.value model.clickThroughRate model.remaining
  have hactive :
      state.IsActive rank := by
    simp [state, paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state,
      PaperTheorem8GeneralizedEnglishAuctionState.IsActive]
  have hstrategy :
      namedStrategy state rank := by
    exact
      (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
        model.value model.clickThroughRate state rank model.remaining
        (ne_of_gt (model.click_pos rank))
        (ne_of_gt (model.click_pos (rank + 1)))).mpr
        (by
          simp [state,
            paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state])
  let hstep :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep
        namedStrategy state finalState :=
    PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep.dropout
      state rank hactive hstrategy
  let hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        namedStrategy state finalState :=
    PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.cons
      hstep
      (PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.refl
        finalState)
  have hterminal :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyTerminal
        namedStrategy finalState := by
    intro bidder hactive_bidder
    exfalso
    by_cases hsame : bidder = rank
    · subst bidder
      simpa [finalState, state,
        PaperTheorem8GeneralizedEnglishAuctionState.IsActive,
        PaperTheorem8GeneralizedEnglishAuctionState.recordDropout] using
        hactive_bidder
    · simpa [finalState, state,
        PaperTheorem8GeneralizedEnglishAuctionState.IsActive,
        PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
        paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state,
        hsame] using hactive_bidder
  have hnot_exact :
      ¬ PaperTheorem8BStarRankedThresholdExactDropHistory
        model state finalState := by
    simpa [state, finalState] using
      (paper_theorem8_bstar_ranked_threshold_ordinary_strategy_history_allows_overshoot_not_exact_drop_history
        model rank).2.2
  let hsource_extensive :
      paper_theorem8_bstar_ranked_threshold_source_extensive_rationality_statement
        model state finalState namedStrategy :=
    ⟨paper_theorem8_bstar_ranked_threshold_named_strategy_source_sequential_rationality
        model state,
      hhist,
      hterminal⟩
  have hadvance_safe :
      PaperTheorem8BStarRankedThresholdStrategyHistoryAdvanceSafe
        model hsource_extensive.2.1 := by
    dsimp [hsource_extensive]
    refine
      PaperTheorem8BStarRankedThresholdStrategyHistoryAdvanceSafe.cons
        hstep ?_
        (PaperTheorem8BStarRankedThresholdStrategyHistoryAdvanceSafe.refl
          finalState)
    intro realizedPrice hnext activeRank hactive_activeRank
    exfalso
    have hactive_after :
        (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
          state realizedPrice).IsActive rank := by
      simpa [PaperTheorem8GeneralizedEnglishAuctionState.advanceClock]
        using hactive
    have hinactive_after :
        ¬ finalState.IsActive rank := by
      simp [finalState, PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
        PaperTheorem8GeneralizedEnglishAuctionState.IsActive]
    exact hinactive_after (by simpa [hnext] using hactive_after)
  exact ⟨hsource_extensive, hadvance_safe, hnot_exact⟩

