        model hstep)

/--
A paper-style source event step is exactly an ordinary named-strategy step
together with source-event evidence for any realized clock advance. The extra
evidence records the active rank whose finite `B*` threshold is the event price,
as well as the active-rank no-overshoot bound at that event.
-/
theorem paper_theorem8_bstar_ranked_threshold_source_event_step_iff_strategy_step_threshold_event_advance_safe
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state next : PaperTheorem8GeneralizedEnglishAuctionState ℕ} :
    PaperTheorem8BStarRankedThresholdSourceEventStep
        model state next ↔
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep
          (paper_theorem8_bstar_ranked_threshold_strategy
            model.value model.clickThroughRate model.remaining)
          state next ∧
        ∀ newPrice,
          next =
            PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
              state newPrice →
            (∃ eventRank,
              state.IsActive eventRank ∧
                newPrice =
                  paper_theorem8_bstar_threshold_bid
                    model.value model.clickThroughRate
                    (model.remaining + 1) (eventRank + 1)) ∧
              ∀ rank,
                state.IsActive rank →
                  newPrice ≤
                    paper_theorem8_bstar_threshold_bid
                      model.value model.clickThroughRate
                      (model.remaining + 1) (rank + 1) := by
  constructor
  · intro hstep
    constructor
    · exact
        paper_theorem8_bstar_ranked_threshold_source_event_step_to_strategy_step
          model hstep
    · intro realizedPrice hnext
      cases hstep with
      | advance eventRank newPrice hactive_event hevent_price _hclock hsafe =>
          have hprice : newPrice = realizedPrice := by
            have hclock_eq :=
              congrArg
                (fun s : PaperTheorem8GeneralizedEnglishAuctionState ℕ =>
                  s.clockPrice) hnext
            simpa [PaperTheorem8GeneralizedEnglishAuctionState.advanceClock]
              using hclock_eq
          constructor
          · refine ⟨eventRank, hactive_event, ?_⟩
            exact hprice ▸ hevent_price
          · intro rank hactive
            simpa [← hprice] using hsafe rank hactive
      | dropout dropRank hactive_drop _hstrategy =>
          exfalso
          have hactive_after :
              (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
                state realizedPrice).IsActive dropRank := by
            simpa [PaperTheorem8GeneralizedEnglishAuctionState.advanceClock]
              using hactive_drop
          have hinactive_after :
              ¬ (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
                state dropRank).IsActive dropRank := by
            simp [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
              PaperTheorem8GeneralizedEnglishAuctionState.IsActive]
          exact hinactive_after (by simpa [hnext] using hactive_after)
  · intro h
    rcases h with ⟨hstep, hadvance⟩
    cases hstep with
    | advance newPrice hclock =>
        rcases hadvance newPrice rfl with
          ⟨⟨eventRank, hactive_event, hevent_price⟩, hsafe⟩
        exact
          PaperTheorem8BStarRankedThresholdSourceEventStep.advance
            state eventRank newPrice hactive_event hevent_price hclock hsafe
    | dropout rank hactive hstrategy =>
        exact
          PaperTheorem8BStarRankedThresholdSourceEventStep.dropout
            state rank hactive hstrategy

