/--
Finite-active exact-record schedules produce a paper-style source event trace.
The finite-active state makes the active ranks exactly `activeRanks`, so a
covering schedule removes the unscheduled-active side condition that the
ambient all-ranks cold-start model cannot satisfy finitely.
-/
theorem paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_schedule_to_source_event_trace
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (activeRanks : Finset ℕ) (scheduledRanks : List ℕ)
    (hsorted :
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted
        model
        (paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state
          model activeRanks).clockPrice
        scheduledRanks)
    (hnodup : scheduledRanks.Nodup)
    (hcover : ∀ rank, rank ∈ activeRanks ↔ rank ∈ scheduledRanks) :
    let initialState :=
      paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state
        model activeRanks
    PaperTheorem8BStarRankedThresholdSourceEventTrace
      model initialState
      (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
        model initialState scheduledRanks) := by
  dsimp
  let initialState :=
    paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state
      model activeRanks
  exact
    paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted_nodup_to_source_event_trace
      model initialState scheduledRanks hsorted hnodup
      (by
        intro rank hrank
        exact
          (paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_active_iff
            model activeRanks rank).mpr ((hcover rank).mpr hrank))
      (by
        intro _scheduledRank _hscheduled otherRank hother_not_scheduled
          hactive_other
        have hmem_active : otherRank ∈ activeRanks :=
          (paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_active_iff
            model activeRanks otherRank).mp hactive_other
        have hmem_scheduled : otherRank ∈ scheduledRanks :=
          (hcover otherRank).mp hmem_active
        exact False.elim (hother_not_scheduled hmem_scheduled))

