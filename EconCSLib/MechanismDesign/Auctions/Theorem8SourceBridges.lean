            (fun earlier later =>
              paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
                  model earlier.val ≤
                paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
                  model later.val) :=
        List.Pairwise.of_cons hpair
