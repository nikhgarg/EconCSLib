/--
Finite generalized-English histories over the current `ℕ`-rank source model
cannot consume every initially active rank.  If all ranks outside a finite
ledger are active at the start, then after any finite strategy-consistent
history there is still an active rank outside any requested finite forbidden
list.
-/
theorem paper_theorem8_generalized_english_strategy_history_exists_active_not_mem_of_initial_active_off_list
    {strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        strategy state finalState)
    (inactive forbidden : List ℕ)
    (hactive_off :
      ∀ rank, rank ∉ inactive → state.IsActive rank) :
    ∃ rank, rank ∉ forbidden ∧ finalState.IsActive rank := by
  induction hhist generalizing inactive forbidden with
  | refl state =>
      let rank := paper_theorem8_fresh_unscheduled_rank (inactive ++ forbidden)
      have hnot_all : rank ∉ inactive ++ forbidden := by
        exact paper_theorem8_fresh_unscheduled_rank_not_mem
          (inactive ++ forbidden)
      have hnot_inactive : rank ∉ inactive := by
        intro hrank
        exact hnot_all (List.mem_append.mpr (Or.inl hrank))
      have hnot_forbidden : rank ∉ forbidden := by
        intro hrank
        exact hnot_all (List.mem_append.mpr (Or.inr hrank))
      exact ⟨rank, hnot_forbidden, hactive_off rank hnot_inactive⟩
  | @cons state mid finalState hstep htail ih =>
      cases hstep with
      | advance newPrice hclock =>
          exact
            ih inactive forbidden
              (by
                intro rank hrank
                simpa [PaperTheorem8GeneralizedEnglishAuctionState.advanceClock,
                  PaperTheorem8GeneralizedEnglishAuctionState.IsActive]
                  using hactive_off rank hrank)
      | dropout dropRank hactive_drop hstrategy =>
          exact
            ih (dropRank :: inactive) forbidden
              (by
                intro rank hrank
                have hne : rank ≠ dropRank := by
                  intro hsame
                  exact hrank (by simp [hsame])
                have hnot_inactive : rank ∉ inactive := by
                  intro hinactive
                  exact hrank (by simp [hinactive])
                have hactive_rank : state.IsActive rank :=
                  hactive_off rank hnot_inactive
                simpa [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
                  PaperTheorem8GeneralizedEnglishAuctionState.IsActive, hne]
                  using hactive_rank)

/--
A finite generalized-English strategy history from a state where every natural
rank is active cannot end in a no-active state.
-/
theorem paper_theorem8_generalized_english_strategy_history_not_no_active_of_initial_all_active
    {strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        strategy state finalState)
    (hinitial_active : ∀ rank, state.IsActive rank) :
    ¬ (∀ rank, ¬ finalState.IsActive rank) := by
  intro hno_active
  rcases
    paper_theorem8_generalized_english_strategy_history_exists_active_not_mem_of_initial_active_off_list
      hhist [] [] (by
        intro rank _hrank
        exact hinitial_active rank) with
    ⟨rank, _hnot_forbidden, hactive⟩
  exact hno_active rank hactive

