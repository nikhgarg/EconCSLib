schedule is added.
-/
noncomputable def paper_theorem8_bstar_ranked_threshold_strict_ordered_one_step_tie_break_core_source_completion_certificate_of_source_sequential_no_overshoot_terminal_dynamic
    (terminal :
      PaperTheorem8BStarRankedThresholdNoOvershootTerminalHistoryBehaviorCertificate)
    (model :
      PaperTheorem8BStarRankedThresholdStrictOrderedLocalOptimalityCertificate)
    (hmodel :
      paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
          (paper_theorem8_bstar_ranked_threshold_strict_ordered_source_sequential_constructed_outcome_certificate
            model terminal.initialState).base.strictModel =
        terminal.localModel) :
    PaperTheorem8BStarRankedThresholdStrictOrderedOneStepTieBreakCoreSourceCompletionCertificate
      Unit :=
  paper_theorem8_bstar_ranked_threshold_strict_ordered_one_step_tie_break_core_source_completion_certificate_of_sequential_rationality
    (paper_theorem8_bstar_ranked_threshold_strict_ordered_sequential_rationality_core_source_completion_certificate_of_local_deviation
      (paper_theorem8_bstar_ranked_threshold_strict_ordered_local_deviation_core_source_completion_certificate_of_source_sequential_rationality
        (paper_theorem8_bstar_ranked_threshold_strict_ordered_source_sequential_no_overshoot_terminal_dynamic_source_sequential_core_source_completion_certificate
          terminal model hmodel)))

/--
Finite exact-schedule constructor from the local one-step/tie-break source
certificate. Reviewers can check the local source-PBE behavior separately from
the deterministic exact-drop schedule; Lean then assembles the finite-schedule
core source-completion certificate used by the trace-full PBE endpoint.
-/
noncomputable def paper_theorem8_bstar_ranked_threshold_strict_ordered_finite_schedule_core_source_completion_certificate_of_one_step_tie_break_clock_sorted_nodup
    {Belief : Type*}
    (src :
      PaperTheorem8BStarRankedThresholdStrictOrderedOneStepTieBreakCoreSourceCompletionCertificate
        Belief)
    (completedRanks : Finset ℕ) (scheduledRanks : List ℕ)
    (hfinal :
      src.integrated.terminal.finalState =
        paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
          src.integrated.terminal.localModel
          src.integrated.terminal.initialState
          scheduledRanks)
    (hsorted :
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted
        src.integrated.terminal.localModel
        src.integrated.terminal.initialState.clockPrice
        scheduledRanks)
    (hnodup : scheduledRanks.Nodup)
    (hsubset :
      ∀ rank, rank ∈ completedRanks → rank ∈ scheduledRanks) :
    PaperTheorem8BStarRankedThresholdStrictOrderedFiniteScheduleCoreSourceCompletionCertificate
      Belief where
  source :=
    paper_theorem8_bstar_ranked_threshold_strict_ordered_core_source_completion_certificate_of_one_step_tie_break
      src
  completedRanks := completedRanks
  scheduledRanks := scheduledRanks
  schedule := by
    change
      PaperTheorem8BStarRankedThresholdExactDropSchedule
        src.integrated.terminal.localModel
        src.integrated.terminal.initialState
        scheduledRanks
        src.integrated.terminal.finalState
    have hsched_det :
        PaperTheorem8BStarRankedThresholdExactDropSchedule
          src.integrated.terminal.localModel
          src.integrated.terminal.initialState
          scheduledRanks
          (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
            src.integrated.terminal.localModel
            src.integrated.terminal.initialState
            scheduledRanks) :=
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_of_clock_sorted_nodup
        src.integrated.terminal.localModel
        src.integrated.terminal.initialState
        scheduledRanks hsorted hnodup
        (fun rank _hrank => src.integrated.terminal.initially_active rank)
    simpa [hfinal] using hsched_det
  completed_subset_schedule := hsubset

