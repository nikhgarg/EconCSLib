        PaperTheorem8BStarRankedThresholdSourceEventTrace.cons
          hstep (ih hsecond)

/--
A single paper-style source event step is the corresponding one-step event
trace. This is the primitive constructor used when assembling concrete source
paths one transition at a time.
-/
theorem paper_theorem8_bstar_ranked_threshold_source_event_step_to_trace
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state next : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (hstep :
      PaperTheorem8BStarRankedThresholdSourceEventStep
        model state next) :
    PaperTheorem8BStarRankedThresholdSourceEventTrace
      model state next := by
  exact
    PaperTheorem8BStarRankedThresholdSourceEventTrace.cons
      hstep
      (PaperTheorem8BStarRankedThresholdSourceEventTrace.refl next)

/--
Append one checked paper-style source event step to an existing event trace.
This is the event-level analogue of extending a source proof by one concrete
threshold event.
-/
theorem paper_theorem8_bstar_ranked_threshold_source_event_trace_append_step
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state mid finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (htrace :
      PaperTheorem8BStarRankedThresholdSourceEventTrace
        model state mid)
    (hstep :
      PaperTheorem8BStarRankedThresholdSourceEventStep
        model mid finalState) :
    PaperTheorem8BStarRankedThresholdSourceEventTrace
      model state finalState := by
  exact
    PaperTheorem8BStarRankedThresholdSourceEventTrace.trans
      model htrace
      (paper_theorem8_bstar_ranked_threshold_source_event_step_to_trace
        model hstep)

/--
One-event source scheduler. If the chosen active rank has the next threshold
event among all active ranks, then advancing to that threshold and dropping the
rank is a valid paper-style source-event trace. The same transition is an exact
finite `B*` drop, preserves the active-rank no-overshoot invariant, and records
the selected rank's threshold price.
-/
theorem paper_theorem8_bstar_ranked_threshold_next_active_threshold_source_event_trace
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {eventRank : ℕ}
    (hactive_event : state.IsActive eventRank)
    (hclock_le_event :
      state.clockPrice ≤
        paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (eventRank + 1))
    (hevent_min :
      ∀ rank,
        state.IsActive rank →
          paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (eventRank + 1) ≤
            paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1)) :
    let eventPrice :=
      paper_theorem8_bstar_threshold_bid
        model.value model.clickThroughRate (model.remaining + 1)
        (eventRank + 1)
    let midState :=
      PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
        state eventPrice
    let nextState :=
      PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
        midState eventRank
    PaperTheorem8BStarRankedThresholdSourceEventTrace
        model state nextState ∧
      PaperTheorem8BStarRankedThresholdExactDropHistory
        model state nextState ∧
        (∀ rank,
          nextState.IsActive rank →
            nextState.clockPrice ≤
              paper_theorem8_bstar_threshold_bid
                model.value model.clickThroughRate (model.remaining + 1)
                (rank + 1)) ∧
          nextState.lastDropout eventRank = some eventPrice := by
  dsimp
  let eventPrice :=
    paper_theorem8_bstar_threshold_bid
      model.value model.clickThroughRate (model.remaining + 1)
      (eventRank + 1)
  let midState :=
    PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
      state eventPrice
  let nextState :=
    PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
      midState eventRank
  have hadvance_step :
      PaperTheorem8BStarRankedThresholdSourceEventStep
        model state midState :=
    PaperTheorem8BStarRankedThresholdSourceEventStep.advance
      state eventRank eventPrice hactive_event (by simp [eventPrice])
      hclock_le_event
      (by
        intro rank hactive_rank
        simpa [eventPrice] using hevent_min rank hactive_rank)
  have hactive_mid : midState.IsActive eventRank := by
    simpa [midState,
      PaperTheorem8GeneralizedEnglishAuctionState.advanceClock,
      PaperTheorem8GeneralizedEnglishAuctionState.IsActive] using
      hactive_event
  have hstrategy_mid :
      paper_theorem8_bstar_ranked_threshold_strategy
        model.value model.clickThroughRate model.remaining
        midState eventRank := by
    have hthreshold_le_clock :
        paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (eventRank + 1) ≤
          midState.clockPrice := by
      simp [midState, eventPrice,
        PaperTheorem8GeneralizedEnglishAuctionState.advanceClock]
    exact
      (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
        model.value model.clickThroughRate midState eventRank model.remaining
        (ne_of_gt (model.click_pos eventRank))
        (ne_of_gt (model.click_pos (eventRank + 1)))).mpr
        hthreshold_le_clock
  have hdrop_step :
      PaperTheorem8BStarRankedThresholdSourceEventStep
        model midState nextState :=
    PaperTheorem8BStarRankedThresholdSourceEventStep.dropout
      midState eventRank hactive_mid hstrategy_mid
  have htrace :
      PaperTheorem8BStarRankedThresholdSourceEventTrace
        model state nextState :=
    PaperTheorem8BStarRankedThresholdSourceEventTrace.cons
      hadvance_step
      (PaperTheorem8BStarRankedThresholdSourceEventTrace.cons
        hdrop_step
        (PaperTheorem8BStarRankedThresholdSourceEventTrace.refl
          nextState))
  have hexact :
      PaperTheorem8BStarRankedThresholdExactDropHistory
        model state nextState := by
    simpa [eventPrice, midState, nextState] using
      paper_theorem8_bstar_ranked_threshold_single_exact_drop_history
        model state eventRank hclock_le_event hactive_event
  have hnext_no_overshoot :
      ∀ rank,
        nextState.IsActive rank →
          nextState.clockPrice ≤
            paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1) := by
    intro rank hactive_next
    have hactive_state : state.IsActive rank := by
      by_cases hsame : rank = eventRank
      · subst rank
        exact hactive_event
      · simpa [nextState, midState,
          PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
          PaperTheorem8GeneralizedEnglishAuctionState.advanceClock,
          PaperTheorem8GeneralizedEnglishAuctionState.IsActive, hsame]
          using hactive_next
    simpa [nextState, midState, eventPrice,
      PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
      PaperTheorem8GeneralizedEnglishAuctionState.advanceClock] using
      hevent_min rank hactive_state
  have hdrop_record :
      nextState.lastDropout eventRank = some eventPrice := by
    simp [nextState, midState,
      PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
      PaperTheorem8GeneralizedEnglishAuctionState.advanceClock]
  exact ⟨htrace, hexact, hnext_no_overshoot, hdrop_record⟩

/--
Cons-peel source-event constructor for exact-drop schedules. If the scheduled
head is active and is the next active threshold event in the current state,
then the one-event scheduler builds the head trace and composes it with any
already-built tail source-event trace.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_source_event_trace_cons_of_next_active_threshold
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {head : ℕ}
    (hhead_active : state.IsActive head)
    (hclock_le_head :
      state.clockPrice ≤
        paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
          model head)
    (hhead_next :
      ∀ rank,
        state.IsActive rank →
          paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
              model head ≤
            paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
              model rank)
    (htail :
      PaperTheorem8BStarRankedThresholdSourceEventTrace
        model
        (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_next_state
          model state head)
        finalState) :
    PaperTheorem8BStarRankedThresholdSourceEventTrace
      model state finalState := by
  have hhead_trace :
      PaperTheorem8BStarRankedThresholdSourceEventTrace
        model state
        (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_next_state
          model state head) := by
    have hscheduler :=
      paper_theorem8_bstar_ranked_threshold_next_active_threshold_source_event_trace
        model hhead_active
        (by
          simpa [paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price]
            using hclock_le_head)
        (by
          intro rank hactive
          simpa [paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price]
            using hhead_next rank hactive)
    simpa [paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_next_state,
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price] using
      hscheduler.1
  exact
    PaperTheorem8BStarRankedThresholdSourceEventTrace.trans
      model hhead_trace htail

/--
Schedule-specialized cons-peel source-event constructor. This is the recursive
shape used by a source-history proof: construct the head threshold event from
local next-threshold evidence, then append a tail trace for the recursively
computed next state.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_source_event_trace_cons_schedule_of_next_active_threshold
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (head : ℕ) (tail : List ℕ)
    (hhead_active : state.IsActive head)
    (hclock_le_head :
      state.clockPrice ≤
        paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
          model head)
    (hhead_next :
      ∀ rank,
        state.IsActive rank →
          paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
              model head ≤
            paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
              model rank)
    (htail :
      PaperTheorem8BStarRankedThresholdSourceEventTrace
        model
        (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_next_state
          model state head)
        (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
          model
          (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_next_state
            model state head)
          tail)) :
    PaperTheorem8BStarRankedThresholdSourceEventTrace
      model state
      (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
        model state (head :: tail)) := by
  simpa [paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state]
    using
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_source_event_trace_cons_of_next_active_threshold
        model hhead_active hclock_le_head hhead_next htail

/--
History-local threshold-event advance safety for an ordinary generated
named-strategy history. This strengthens `StrategyHistoryAdvanceSafe` by
recording that every realized clock advance is exactly a finite `B*` threshold
event for some active rank.
-/
inductive PaperTheorem8BStarRankedThresholdStrategyHistoryThresholdEventAdvanceSafe
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate) :
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ} →
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining)
        state finalState → Prop
  | refl (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ) :
      PaperTheorem8BStarRankedThresholdStrategyHistoryThresholdEventAdvanceSafe
        model
        (PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.refl
          state)
  | cons {state mid finalState :
        PaperTheorem8GeneralizedEnglishAuctionState ℕ}
      (hstep :
        PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep
          (paper_theorem8_bstar_ranked_threshold_strategy
            model.value model.clickThroughRate model.remaining)
          state mid)
      {htail :
        PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
          (paper_theorem8_bstar_ranked_threshold_strategy
            model.value model.clickThroughRate model.remaining)
          mid finalState}
      (hstep_safe :
        ∀ newPrice,
          mid =
            PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
              state newPrice →
            (∃ eventRank,
              state.IsActive eventRank ∧
                newPrice =
                  paper_theorem8_bstar_threshold_bid
                    model.value model.clickThroughRate
                    (model.remaining + 1) (eventRank + 1)) ∧
              ∀ rank,
                state.IsActive rank →
                  newPrice ≤
                    paper_theorem8_bstar_threshold_bid
                      model.value model.clickThroughRate
                      (model.remaining + 1) (rank + 1))
      (htail_safe :
        PaperTheorem8BStarRankedThresholdStrategyHistoryThresholdEventAdvanceSafe
          model htail) :
      PaperTheorem8BStarRankedThresholdStrategyHistoryThresholdEventAdvanceSafe
        model
        (PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.cons
          hstep htail)

/--
Threshold-event advance safety implies the older local advance-safety proof
object by forgetting the event-rank witness.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_history_threshold_event_advance_safe_to_advance_safe
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining)
        state finalState}
    (hevent_safe :
      PaperTheorem8BStarRankedThresholdStrategyHistoryThresholdEventAdvanceSafe
        model hhist) :
    PaperTheorem8BStarRankedThresholdStrategyHistoryAdvanceSafe
      model hhist := by
  induction hevent_safe with
  | refl state =>
      exact
        PaperTheorem8BStarRankedThresholdStrategyHistoryAdvanceSafe.refl
          state
  | cons hstep hstep_safe _htail_safe ih =>
      exact
        PaperTheorem8BStarRankedThresholdStrategyHistoryAdvanceSafe.cons
          hstep
          (by
            intro newPrice hnext rank hactive
            exact (hstep_safe newPrice hnext).2 rank hactive)
          ih

/--
Ordinary generated histories with threshold-event advance safety reconstruct
the paper-style source event trace. This is the trace-level converse to
forgetting source events into ordinary generated histories.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_history_to_source_event_trace_of_history_threshold_event_advance_safe
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining)
        state finalState)
    (hevent_safe :
      PaperTheorem8BStarRankedThresholdStrategyHistoryThresholdEventAdvanceSafe
        model hhist) :
    PaperTheorem8BStarRankedThresholdSourceEventTrace
      model state finalState := by
  induction hevent_safe with
  | refl state =>
      exact
        PaperTheorem8BStarRankedThresholdSourceEventTrace.refl
          state
  | cons hstep hstep_safe _htail_safe ih =>
      exact
        PaperTheorem8BStarRankedThresholdSourceEventTrace.cons
          ((paper_theorem8_bstar_ranked_threshold_source_event_step_iff_strategy_step_threshold_event_advance_safe
            model).mpr ⟨hstep, hstep_safe⟩)
          ih

/--
Paper-style source event traces can be forgotten to ordinary generated
histories while retaining the stronger threshold-event advance-safety proof
object.
-/
theorem paper_theorem8_bstar_ranked_threshold_source_event_trace_to_strategy_history_threshold_event_advance_safe
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (htrace :
      PaperTheorem8BStarRankedThresholdSourceEventTrace
        model state finalState) :
    ∃ hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining)
        state finalState,
      PaperTheorem8BStarRankedThresholdStrategyHistoryThresholdEventAdvanceSafe
        model hhist := by
  induction htrace with
  | refl state =>
      exact
        ⟨PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.refl
            state,
          PaperTheorem8BStarRankedThresholdStrategyHistoryThresholdEventAdvanceSafe.refl
            state⟩
  | @cons state mid finalState hstep htail ih =>
      rcases ih with ⟨htail_hist, htail_safe⟩
      have hordinary :
          PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep
            (paper_theorem8_bstar_ranked_threshold_strategy
              model.value model.clickThroughRate model.remaining)
            state mid :=
        paper_theorem8_bstar_ranked_threshold_source_event_step_to_strategy_step
          model hstep
      have hstep_safe :
          ∀ newPrice,
            mid =
              PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
                state newPrice →
              (∃ eventRank,
                state.IsActive eventRank ∧
                  newPrice =
                    paper_theorem8_bstar_threshold_bid
                      model.value model.clickThroughRate
                      (model.remaining + 1) (eventRank + 1)) ∧
                ∀ rank,
                  state.IsActive rank →
                    newPrice ≤
                      paper_theorem8_bstar_threshold_bid
                        model.value model.clickThroughRate
                        (model.remaining + 1) (rank + 1) :=
        (paper_theorem8_bstar_ranked_threshold_source_event_step_iff_strategy_step_threshold_event_advance_safe
          model).mp hstep |>.2
      exact
        ⟨PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.cons
            hordinary htail_hist,
          PaperTheorem8BStarRankedThresholdStrategyHistoryThresholdEventAdvanceSafe.cons
            hordinary hstep_safe htail_safe⟩

/--
Paper-style source event traces are exactly ordinary generated histories
equipped with threshold-event advance safety.
-/
theorem paper_theorem8_bstar_ranked_threshold_source_event_trace_iff_strategy_history_threshold_event_advance_safe
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ} :
    PaperTheorem8BStarRankedThresholdSourceEventTrace
        model state finalState ↔
      ∃ hordinary :
        PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
          (paper_theorem8_bstar_ranked_threshold_strategy
            model.value model.clickThroughRate model.remaining)
          state finalState,
        PaperTheorem8BStarRankedThresholdStrategyHistoryThresholdEventAdvanceSafe
          model hordinary := by
  constructor
  · intro htrace
    exact
      paper_theorem8_bstar_ranked_threshold_source_event_trace_to_strategy_history_threshold_event_advance_safe
        model htrace
  · rintro ⟨hhist, hevent_safe⟩
    exact
      paper_theorem8_bstar_ranked_threshold_strategy_history_to_source_event_trace_of_history_threshold_event_advance_safe
        model hhist hevent_safe

/--
Clock-sorted no-duplicate finite exact-drop schedules induce paper-style
source event traces. Each scheduled rank advances the source clock to that
rank's finite `B*` threshold, records the named-strategy dropout, and then
continues with the tail schedule.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted_nodup_to_source_event_trace
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (ranks : List ℕ)
    (hsorted :
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted
        model state.clockPrice ranks)
    (hnodup : ranks.Nodup)
    (hinitial_active : ∀ rank, rank ∈ ranks → state.IsActive rank)
    (hunscheduled_active_threshold :
      ∀ scheduledRank,
        scheduledRank ∈ ranks →
          ∀ otherRank,
            otherRank ∉ ranks →
              state.IsActive otherRank →
                paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
                    model scheduledRank ≤
                  paper_theorem8_bstar_threshold_bid
                    model.value model.clickThroughRate (model.remaining + 1)
                    (otherRank + 1)) :
    PaperTheorem8BStarRankedThresholdSourceEventTrace
      model state
      (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
        model state ranks) := by
  induction ranks generalizing state with
  | nil =>
      exact
        PaperTheorem8BStarRankedThresholdSourceEventTrace.refl state
  | cons head tail ih =>
      simp only
        [paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted]
        at hsorted
      rcases hsorted with ⟨hclock, htail_sorted⟩
      have hhead_active : state.IsActive head := by
        exact hinitial_active head (by simp)
      have hnodup_tail : tail.Nodup := hnodup.tail
      have hhead_not_mem_tail : head ∉ tail := hnodup.notMem
      let dropPrice :=
        paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
          model head
      let nextState :=
        paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_next_state
          model state head
      have hadvance_safe :
          ∀ otherRank,
            state.IsActive otherRank →
              dropPrice ≤
                paper_theorem8_bstar_threshold_bid
                  model.value model.clickThroughRate (model.remaining + 1)
                  (otherRank + 1) := by
        intro otherRank hactive_other
        by_cases hmem : otherRank ∈ head :: tail
        · rcases (List.mem_cons.mp hmem) with hsame | htail_mem
          · subst otherRank
            simp [dropPrice,
              paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price]
          · exact
              paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted_le_price_of_mem
                model htail_sorted htail_mem
        · exact
            hunscheduled_active_threshold head (by simp) otherRank hmem
              hactive_other
      have hactive_advanced :
          (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
            state dropPrice).IsActive head := by
        simpa [PaperTheorem8GeneralizedEnglishAuctionState.advanceClock,
          dropPrice] using hhead_active
      have hstrategy :
          paper_theorem8_bstar_ranked_threshold_strategy
            model.value model.clickThroughRate model.remaining
            (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
              state dropPrice) head := by
        have hthreshold_le_clock :
            paper_theorem8_bstar_threshold_bid
                model.value model.clickThroughRate (model.remaining + 1)
                (head + 1) ≤
              (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
                state dropPrice).clockPrice := by
          simp [PaperTheorem8GeneralizedEnglishAuctionState.advanceClock,
            dropPrice,
            paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price]
        exact
          (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
            model.value model.clickThroughRate
            (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
              state dropPrice)
            head model.remaining
            (ne_of_gt (model.click_pos head))
            (ne_of_gt (model.click_pos (head + 1)))).mpr
            hthreshold_le_clock
      have htail_active :
          ∀ rank, rank ∈ tail → nextState.IsActive rank := by
        intro rank hrank
        have hactive_initial : state.IsActive rank :=
          hinitial_active rank (by simp [hrank])
        have hne : rank ≠ head := by
          intro hsame
          exact hhead_not_mem_tail (by simpa [hsame] using hrank)
        simpa [nextState,
          paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_next_state,
          dropPrice,
          paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price]
          using
            paper_theorem8_bstar_ranked_threshold_single_exact_drop_preserves_active_of_ne
              model state hne hactive_initial
      have htail_unscheduled_active_threshold :
          ∀ scheduledRank,
            scheduledRank ∈ tail →
              ∀ otherRank,
                otherRank ∉ tail →
                  nextState.IsActive otherRank →
                    paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price
                        model scheduledRank ≤
                      paper_theorem8_bstar_threshold_bid
                        model.value model.clickThroughRate
                        (model.remaining + 1) (otherRank + 1) := by
        intro scheduledRank hscheduled otherRank hother_not_tail hactive_next
        by_cases hsame : otherRank = head
        · subst otherRank
          exfalso
          simpa [nextState,
            paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_next_state,
            PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
            PaperTheorem8GeneralizedEnglishAuctionState.IsActive]
            using hactive_next
        · have hother_not_cons : otherRank ∉ head :: tail := by
            intro hmem
            rcases (List.mem_cons.mp hmem) with hhead_eq | htail_mem
            · exact hsame hhead_eq
            · exact hother_not_tail htail_mem
          have hactive_state : state.IsActive otherRank := by
            simpa [nextState,
              paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_next_state,
              PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
              PaperTheorem8GeneralizedEnglishAuctionState.advanceClock,
              PaperTheorem8GeneralizedEnglishAuctionState.IsActive, hsame]
              using hactive_next
          exact
            hunscheduled_active_threshold scheduledRank (by simp [hscheduled])
              otherRank hother_not_cons hactive_state
      refine
        PaperTheorem8BStarRankedThresholdSourceEventTrace.cons
          (PaperTheorem8BStarRankedThresholdSourceEventStep.advance
            state head dropPrice hhead_active ?_ ?_ ?_)
          ?_
      · simp [dropPrice,
          paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_price]
      · simpa [dropPrice,
