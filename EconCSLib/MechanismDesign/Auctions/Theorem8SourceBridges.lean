  | [_], _ => by
      simp [paper_theorem8_bstar_ranked_threshold_fin_schedule_ranks,
        paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_threshold_sorted]
  | rank :: nextRank :: tail, hpair => by
