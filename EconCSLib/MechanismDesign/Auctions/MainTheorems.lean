        model hstep hactive hinactive⟩

/--
A strategy-consistent finite-`B*` ranked-threshold step cannot newly drop a rank
before its finite `B*` threshold bid.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_step_no_new_dropout_before_threshold
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state next : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hstep :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining) state next)
    (hclock_lt :
      state.clockPrice <
        paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1) (rank + 1))
    (hactive : state.IsActive rank) :
    next.IsActive rank := by
  by_contra hinactive
  have hthreshold :=
    paper_theorem8_bstar_ranked_threshold_strategy_step_new_dropout_threshold_le
      model hstep hactive hinactive
  exact (not_le_of_gt hclock_lt) hthreshold

/--
A finite-`B*` ranked-threshold strategy-consistent history cannot newly drop a
rank if the final clock is still strictly below that rank's finite `B*`
threshold bid.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_history_no_new_dropout_before_threshold
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining) state finalState)
    (hfinal_lt :
      finalState.clockPrice <
        paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1) (rank + 1))
    (hactive : state.IsActive rank) :
    finalState.IsActive rank := by
  induction hhist with
  | refl state =>
      exact hactive
  | cons hstep hhist ih =>
      have hstate_lt :
          _ <
            paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1) :=
        lt_of_le_of_lt
          (le_trans
            (PaperTheorem8GeneralizedEnglishAuctionState.Step_clock_mono
              hstep.toStep)
            (PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory_clock_mono
              hhist))
          hfinal_lt
      have hactive_mid :
          _ :=
        paper_theorem8_bstar_ranked_threshold_strategy_step_no_new_dropout_before_threshold
          model hstep hstate_lt hactive
      exact ih hfinal_lt hactive_mid

/--
If a rank starts active but is inactive after a finite-`B*`
ranked-threshold-strategy-consistent history, the final clock has reached that
rank's finite `B*` threshold bid.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_history_new_dropout_threshold_le
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining) state finalState)
    (hactive : state.IsActive rank) (hinactive : ¬ finalState.IsActive rank) :
    paper_theorem8_bstar_threshold_bid
      model.value model.clickThroughRate (model.remaining + 1) (rank + 1) ≤
        finalState.clockPrice := by
  by_contra hnot
  have hfinal_lt :
      finalState.clockPrice <
        paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (rank + 1) := not_le.mp hnot
  exact
    hinactive
      (paper_theorem8_bstar_ranked_threshold_strategy_history_no_new_dropout_before_threshold
        model hhist hfinal_lt hactive)

/--
If a rank starts active but is inactive after a finite-`B*`
ranked-threshold-strategy-consistent history, the final state contains a
concrete dropout record at some price that reached the finite `B*` threshold
bid and is no later than the final clock.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_history_new_dropout_record_exists
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining) state finalState)
    (hactive : state.IsActive rank) (hinactive : ¬ finalState.IsActive rank) :
    ∃ price,
      finalState.lastDropout rank = some price ∧
        paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1) (rank + 1) ≤
            price ∧
          price ≤ finalState.clockPrice := by
  induction hhist with
  | refl state =>
      exact False.elim (hinactive hactive)
  | @cons state0 mid finalState0 hstep hhist ih =>
      by_cases hmid_active : mid.IsActive rank
      · exact ih hmid_active hinactive
      · have hrecord :=
          paper_theorem8_bstar_ranked_threshold_strategy_step_new_dropout_record_eq_and_threshold_le
            model hstep hactive hmid_active
        refine ⟨state0.clockPrice, ?_, hrecord.2, ?_⟩
        · exact
            PaperTheorem8GeneralizedEnglishAuctionState.History_lastDropout_eq_of_initial_some
              hhist.toHistory hrecord.1
        · exact
            le_trans
              (PaperTheorem8GeneralizedEnglishAuctionState.Step_clock_mono
                hstep.toStep)
              (PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory_clock_mono
                hhist)

/--
In a terminal finite-`B*` ranked-threshold-strategy-consistent history, a rank
remains active at the final state exactly when the final clock is still below
that rank's finite `B*` threshold bid.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_terminal_history_active_iff_clock_lt_threshold_bid
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining) state finalState)
    (hterminal :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyTerminal
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining) finalState)
    (hinitial_active : state.IsActive rank) :
    finalState.IsActive rank ↔
      finalState.clockPrice <
        paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1) (rank + 1) := by
  constructor
  · intro hactive_final
    have hnot_drop :
        ¬ paper_theorem8_bstar_ranked_threshold_strategy
            model.value model.clickThroughRate model.remaining finalState rank :=
      hterminal rank hactive_final
    have hiff :=
      paper_theorem8_bstar_ranked_threshold_strategy_not_drop_iff_clock_lt_threshold_bid
        model.value model.clickThroughRate finalState rank model.remaining
        (ne_of_gt (model.click_pos rank))
        (ne_of_gt (model.click_pos (rank + 1)))
    exact hiff.mp hnot_drop
  · intro hclock_lt
    exact
      paper_theorem8_bstar_ranked_threshold_strategy_history_no_new_dropout_before_threshold
        model hhist hclock_lt hinitial_active

/--
In a terminal finite-`B*` ranked-threshold-strategy-consistent history, a rank
