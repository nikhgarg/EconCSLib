/--
EOS Theorem 7 `B*` payment identity specialized to finite VCG tail payments.
If rank `i` pays the next `B*` bid per click, its total payment is the finite
tail-payment value for rank `i`.
-/
theorem paper_theorem7_bstar_next_bid_payment_eq_vcg_tail
    (value clickThroughRate : ℕ → ℝ) (i remaining : ℕ)
    (hclick_ne : clickThroughRate i ≠ 0) :
    clickThroughRate i *
      paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j remaining)
        clickThroughRate (i + 1) =
      paper_theorem7_ranked_vcg_tail_payment
        value clickThroughRate i remaining := by
  exact
    paper_theorem7_bstar_next_bid_payment_eq_vcg
      value
      (fun j =>
        paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate j remaining)
      clickThroughRate i hclick_ne

/--
EOS Theorem 7 local-envy step specialized to the finite VCG tail-payment
formula: rank `i+1` is exactly indifferent between its own position and rank
`i`'s position/payment.
-/
theorem paper_theorem7_ranked_adjacent_locally_envy_free_of_vcg_tail_payment
    (value clickThroughRate : ℕ → ℝ) (i remaining : ℕ) :
    clickThroughRate i * value (i + 1) -
        paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate i (remaining + 1) ≤
      clickThroughRate (i + 1) * value (i + 1) -
        paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate (i + 1) remaining := by
  rw [paper_theorem7_ranked_vcg_tail_payment_rec]
  ring_nf
  exact le_rfl

/--
EOS Theorem 7 exact local-indifference step specialized to the finite VCG
tail-payment formula.
-/
theorem paper_theorem7_ranked_adjacent_indifferent_of_vcg_tail_payment
    (value clickThroughRate : ℕ → ℝ) (i remaining : ℕ) :
    clickThroughRate i * value (i + 1) -
        paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate i (remaining + 1) =
      clickThroughRate (i + 1) * value (i + 1) -
        paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate (i + 1) remaining := by
  rw [paper_theorem7_ranked_vcg_tail_payment_rec]
  ring

/--
Paper-facing certificate boundary for EOS Theorem 8. The source theorem is a
dynamic generalized-English-auction uniqueness/PBE statement. This structure
keeps the theorem surface explicit while making the missing dynamic-game
formalization an exact input: a strategy space, an outcome map, a PBE predicate,
the candidate equilibrium, uniqueness, and the VCG outcome equivalence.
-/
structure PaperTheorem8GeneralizedEnglishPBECertificate
    (StrategyProfile Outcome : Type*) where
  isPerfectBayesianEquilibrium : StrategyProfile → Prop
  outcomeOf : StrategyProfile → Outcome
  equilibrium : StrategyProfile
  vcgOutcome : Outcome
  equilibrium_is_pbe : isPerfectBayesianEquilibrium equilibrium
  unique_pbe :
    ∀ strategy,
      isPerfectBayesianEquilibrium strategy → strategy = equilibrium
  equilibrium_outcome_eq_vcg : outcomeOf equilibrium = vcgOutcome

/--
EOS Theorem 8 certificate form: from an explicit dynamic-game/PBE certificate,
the generalized English auction has a unique perfect Bayesian equilibrium and
its outcome is the VCG-equivalent outcome.
-/
theorem paper_theorem8_generalized_english_unique_pbe_of_certificate
    {StrategyProfile Outcome : Type*}
    (model :
      PaperTheorem8GeneralizedEnglishPBECertificate StrategyProfile Outcome) :
    ∃ equilibrium : StrategyProfile,
      model.isPerfectBayesianEquilibrium equilibrium ∧
        (∀ strategy,
          model.isPerfectBayesianEquilibrium strategy →
            strategy = equilibrium) ∧
        model.outcomeOf equilibrium = model.vcgOutcome := by
  exact ⟨model.equilibrium, model.equilibrium_is_pbe,
    model.unique_pbe, model.equilibrium_outcome_eq_vcg⟩

/--
EOS Theorem 8 dropout-price formula. Given adjacent click-through rates
`alphaAbove` and `alphaCurrent`, previous dropout price `lastDropout`, and
value `value`, this is the price `q` at which the bidder is indifferent between
the higher position at price `q` and the current position at `lastDropout`.
-/
noncomputable def paper_theorem8_generalized_english_indifference_price
    (alphaAbove alphaCurrent lastDropout value : ℝ) : ℝ :=
  value - (alphaCurrent / alphaAbove) * (value - lastDropout)

/--
EOS Theorem 8 indifference algebra:
`alphaAbove * (value - q) = alphaCurrent * (value - lastDropout)`.
-/
theorem paper_theorem8_generalized_english_indifference_price_eq
    {alphaAbove alphaCurrent lastDropout value : ℝ}
    (halphaAbove_ne : alphaAbove ≠ 0) :
    alphaAbove *
        (value -
          paper_theorem8_generalized_english_indifference_price
            alphaAbove alphaCurrent lastDropout value) =
      alphaCurrent * (value - lastDropout) := by
  unfold paper_theorem8_generalized_english_indifference_price
  field_simp [halphaAbove_ne]
  ring

/--
EOS Theorem 8 monotonicity algebra for the dropout-price formula. If the lower
slot has weakly smaller click-through rate than the higher slot, then the
indifference dropout price is weakly increasing in the bidder's value.
-/
theorem paper_theorem8_generalized_english_indifference_price_mono_value
    {alphaAbove alphaCurrent lastDropout value value' : ℝ}
    (halphaAbove_pos : 0 < alphaAbove)
    (halphaCurrent_nonneg : 0 ≤ alphaCurrent)
    (halphaCurrent_le : alphaCurrent ≤ alphaAbove)
    (hvalue_le : value ≤ value') :
    paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value ≤
      paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value' := by
  have hcoef_nonneg : 0 ≤ 1 - alphaCurrent / alphaAbove := by
    rw [sub_nonneg]
    exact (div_le_one halphaAbove_pos).mpr halphaCurrent_le
  have hdiff :
      paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value' -
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value =
      (1 - alphaCurrent / alphaAbove) * (value' - value) := by
    unfold paper_theorem8_generalized_english_indifference_price
    ring
  rw [← sub_nonneg, hdiff]
  exact mul_nonneg hcoef_nonneg (sub_nonneg.mpr hvalue_le)

/--
EOS Theorem 8 algebra for the generalized-English dropout formula. The
indifference price is an affine interpolation between the bidder's value and
the last dropout price, with weight `alphaCurrent / alphaAbove` on the last
dropout price.
-/
theorem paper_theorem8_generalized_english_indifference_price_affine_eq
    {alphaAbove alphaCurrent lastDropout value : ℝ} :
    paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value =
      (1 - alphaCurrent / alphaAbove) * value +
        (alphaCurrent / alphaAbove) * lastDropout := by
  unfold paper_theorem8_generalized_english_indifference_price
  ring

/--
EOS Theorem 8 continuity algebra: for fixed click-through rates and previous
dropout price, the indifference dropout price is continuous in the bidder's
per-click valuation. This is the scalar formal counterpart of the paper's
"strategies continuous in valuations" restriction.
-/
theorem paper_theorem8_generalized_english_indifference_price_continuous_value
    (alphaAbove alphaCurrent lastDropout : ℝ) :
    Continuous
      (fun value : ℝ =>
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value) := by
  have hfun :
      (fun value : ℝ =>
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value) =
        fun value : ℝ =>
          (1 - alphaCurrent / alphaAbove) * value +
            (alphaCurrent / alphaAbove) * lastDropout := by
    funext value
    exact paper_theorem8_generalized_english_indifference_price_affine_eq
  rw [hfun]
  exact (continuous_const.mul continuous_id).add continuous_const

/--
EOS Theorem 8 source-proof algebra: when the affine coefficient on the
bidder's value is positive, the indifference dropout price is unbounded above
as the bidder's value increases. This is a topology-free formulation of the
paper proof's statement that the dropout price tends to infinity with value.
-/
theorem paper_theorem8_generalized_english_indifference_price_unbounded_value_of_coeff_pos
    {alphaAbove alphaCurrent lastDropout : ℝ}
    (hcoeff_pos : 0 < 1 - alphaCurrent / alphaAbove) (target : ℝ) :
    ∃ value : ℝ,
      target <
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value := by
  let coeff : ℝ := 1 - alphaCurrent / alphaAbove
  let offset : ℝ := (alphaCurrent / alphaAbove) * lastDropout
  refine ⟨(target - offset) / coeff + 1, ?_⟩
  have hcoeff_pos' : 0 < coeff := by
    simpa [coeff] using hcoeff_pos
  have hcoeff_ne : coeff ≠ 0 := ne_of_gt hcoeff_pos'
  have hcalc :
      coeff * ((target - offset) / coeff + 1) + offset =
        target + coeff := by
    field_simp [hcoeff_ne]
    ring
  have htarget : target < target + coeff := by
    linarith
  simpa [paper_theorem8_generalized_english_indifference_price_affine_eq,
    coeff, offset, hcalc] using htarget

/--
EOS Theorem 8 source-proof algebra under the paper click-rate condition: if the
higher position has positive click-through rate and the current position has a
strictly lower click-through rate, the indifference price is unbounded above in
the bidder's value.
-/
theorem paper_theorem8_generalized_english_indifference_price_unbounded_value_of_strict_click
    {alphaAbove alphaCurrent lastDropout : ℝ}
    (halphaAbove_pos : 0 < alphaAbove)
    (halphaCurrent_lt : alphaCurrent < alphaAbove) (target : ℝ) :
    ∃ value : ℝ,
      target <
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value := by
  have hcoeff_pos : 0 < 1 - alphaCurrent / alphaAbove := by
    rw [sub_pos]
    rw [div_lt_one halphaAbove_pos]
    exact halphaCurrent_lt
  exact
    paper_theorem8_generalized_english_indifference_price_unbounded_value_of_coeff_pos
      hcoeff_pos target

/--
EOS Theorem 8 strict monotonicity algebra for the dropout-price formula. If the
lower slot has strictly smaller click-through rate than the higher slot, then
the indifference dropout price is strictly increasing in the bidder's value.
-/
theorem paper_theorem8_generalized_english_indifference_price_strict_mono_value
    {alphaAbove alphaCurrent lastDropout value value' : ℝ}
    (halphaAbove_pos : 0 < alphaAbove)
    (halphaCurrent_lt : alphaCurrent < alphaAbove)
    (hvalue_lt : value < value') :
    paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value <
      paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value' := by
  have hcoef_pos : 0 < 1 - alphaCurrent / alphaAbove := by
    rw [sub_pos]
    exact (div_lt_one halphaAbove_pos).mpr halphaCurrent_lt
  have hdiff :
      paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value' -
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value =
      (1 - alphaCurrent / alphaAbove) * (value' - value) := by
    unfold paper_theorem8_generalized_english_indifference_price
    ring
  rw [← sub_pos, hdiff]
  exact mul_pos hcoef_pos (sub_pos.mpr hvalue_lt)

/--
EOS Theorem 8 uniqueness algebra: under strict adjacent click-through rates,
the indifference dropout-price formula is injective in the bidder's value.
-/
theorem paper_theorem8_generalized_english_indifference_price_injective_value_of_strict_click
    {alphaAbove alphaCurrent lastDropout : ℝ}
    (halphaAbove_pos : 0 < alphaAbove)
    (halphaCurrent_lt : alphaCurrent < alphaAbove) :
    Function.Injective
      (fun value : ℝ =>
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value) := by
  intro value value' hprice
  change
    paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value =
      paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value' at hprice
  by_contra hne
  rcases lt_or_gt_of_ne hne with hlt | hgt
  · have hstrict :=
      paper_theorem8_generalized_english_indifference_price_strict_mono_value
        (lastDropout := lastDropout)
        halphaAbove_pos halphaCurrent_lt hlt
    rw [hprice] at hstrict
    exact (lt_irrefl _) hstrict
  · have hstrict :=
      paper_theorem8_generalized_english_indifference_price_strict_mono_value
        (lastDropout := lastDropout)
        halphaAbove_pos halphaCurrent_lt hgt
    rw [hprice] at hstrict
    exact (lt_irrefl _) hstrict

/--
EOS Theorem 8 lower-bound algebra for the dropout-price formula. Under the
usual CTR normalization and when the last dropout price is below the bidder's
value, the indifference price is at least the last dropout price.
-/
theorem paper_theorem8_generalized_english_indifference_price_lastDropout_le
    {alphaAbove alphaCurrent lastDropout value : ℝ}
    (halphaAbove_pos : 0 < alphaAbove)
    (halphaCurrent_le : alphaCurrent ≤ alphaAbove)
    (hlastDropout_le : lastDropout ≤ value) :
    lastDropout ≤
      paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value := by
  have hcoef_nonneg : 0 ≤ 1 - alphaCurrent / alphaAbove := by
    rw [sub_nonneg]
    exact (div_le_one halphaAbove_pos).mpr halphaCurrent_le
  have hdiff :
      paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value - lastDropout =
      (1 - alphaCurrent / alphaAbove) * (value - lastDropout) := by
    unfold paper_theorem8_generalized_english_indifference_price
    ring
  rw [← sub_nonneg, hdiff]
  exact mul_nonneg hcoef_nonneg (sub_nonneg.mpr hlastDropout_le)

/--
EOS Theorem 8 upper-bound algebra for the dropout-price formula. Under the
usual CTR normalization and when the last dropout price is below the bidder's
value, the indifference price is at most the bidder's value.
-/
theorem paper_theorem8_generalized_english_indifference_price_le_value
    {alphaAbove alphaCurrent lastDropout value : ℝ}
    (halphaAbove_pos : 0 < alphaAbove)
    (halphaCurrent_nonneg : 0 ≤ alphaCurrent)
    (hlastDropout_le : lastDropout ≤ value) :
    paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value ≤ value := by
  have hratio_nonneg : 0 ≤ alphaCurrent / alphaAbove :=
    div_nonneg halphaCurrent_nonneg (le_of_lt halphaAbove_pos)
  have hdiff :
      value -
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value =
      (alphaCurrent / alphaAbove) * (value - lastDropout) := by
    unfold paper_theorem8_generalized_english_indifference_price
    ring
  rw [← sub_nonneg, hdiff]
  exact mul_nonneg hratio_nonneg (sub_nonneg.mpr hlastDropout_le)

/--
EOS Theorem 8 interval certificate for the dropout-price formula. Under the
usual CTR normalization and when the last dropout price is below the bidder's
value, the indifference price lies between the last dropout price and the
bidder's value.
-/
theorem paper_theorem8_generalized_english_indifference_price_mem_interval
    {alphaAbove alphaCurrent lastDropout value : ℝ}
    (halphaAbove_pos : 0 < alphaAbove)
    (halphaCurrent_nonneg : 0 ≤ alphaCurrent)
    (halphaCurrent_le : alphaCurrent ≤ alphaAbove)
    (hlastDropout_le : lastDropout ≤ value) :
    lastDropout ≤
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value ∧
      paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value ≤ value := by
  constructor
  · exact
      paper_theorem8_generalized_english_indifference_price_lastDropout_le
        halphaAbove_pos halphaCurrent_le hlastDropout_le
  · exact
      paper_theorem8_generalized_english_indifference_price_le_value
        halphaAbove_pos halphaCurrent_nonneg hlastDropout_le

/--
EOS Theorem 8 strict interval certificate for the dropout-price formula. With
a strictly positive lower click-through rate strictly below the upper
click-through rate, and with the previous dropout strictly below value, the
indifference price lies strictly between the previous dropout price and value.
-/
theorem paper_theorem8_generalized_english_indifference_price_strict_mem_interval
    {alphaAbove alphaCurrent lastDropout value : ℝ}
    (halphaAbove_pos : 0 < alphaAbove)
    (halphaCurrent_pos : 0 < alphaCurrent)
    (halphaCurrent_lt : alphaCurrent < alphaAbove)
    (hlastDropout_lt : lastDropout < value) :
    lastDropout <
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value ∧
      paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value < value := by
  constructor
  · have hcoef_pos : 0 < 1 - alphaCurrent / alphaAbove := by
      rw [sub_pos]
      exact (div_lt_one halphaAbove_pos).mpr halphaCurrent_lt
    have hdiff :
        paper_theorem8_generalized_english_indifference_price
            alphaAbove alphaCurrent lastDropout value - lastDropout =
          (1 - alphaCurrent / alphaAbove) * (value - lastDropout) := by
      unfold paper_theorem8_generalized_english_indifference_price
      ring
    rw [← sub_pos, hdiff]
    exact mul_pos hcoef_pos (sub_pos.mpr hlastDropout_lt)
  · have hratio_pos : 0 < alphaCurrent / alphaAbove :=
      div_pos halphaCurrent_pos halphaAbove_pos
    have hdiff :
        value -
          paper_theorem8_generalized_english_indifference_price
            alphaAbove alphaCurrent lastDropout value =
          (alphaCurrent / alphaAbove) * (value - lastDropout) := by
      unfold paper_theorem8_generalized_english_indifference_price
      ring
    rw [← sub_pos, hdiff]
    exact mul_pos hratio_pos (sub_pos.mpr hlastDropout_lt)

/--
EOS Theorem 8 endpoint algebra for the dropout-price formula. With zero current
click-through rate, the indifference price equals the bidder's value.
-/
theorem paper_theorem8_generalized_english_indifference_price_zero_current_eq
    {alphaAbove lastDropout value : ℝ} :
    paper_theorem8_generalized_english_indifference_price
        alphaAbove 0 lastDropout value = value := by
  unfold paper_theorem8_generalized_english_indifference_price
  ring

/--
EOS Theorem 8 endpoint algebra for the dropout-price formula. When the current
and upper click-through rates agree, the indifference price equals the last
dropout price.
-/
theorem paper_theorem8_generalized_english_indifference_price_full_current_eq
    {alphaAbove lastDropout value : ℝ}
    (halphaAbove_ne : alphaAbove ≠ 0) :
    paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaAbove lastDropout value = lastDropout := by
  unfold paper_theorem8_generalized_english_indifference_price
  field_simp [halphaAbove_ne]
  ring

/--
EOS Theorem 8 empty-history convention: when the previous dropout price
`b_{k+1}` is the paper's empty-history value `0`, the indifference price is the
corresponding affine fraction of the bidder's value.
-/
theorem paper_theorem8_generalized_english_indifference_price_empty_history_eq
    {alphaAbove alphaCurrent value : ℝ} :
    paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent 0 value =
      (1 - alphaCurrent / alphaAbove) * value := by
  unfold paper_theorem8_generalized_english_indifference_price
  ring

/--
EOS Theorem 8 monotonicity algebra for the dropout-price formula. With
nonnegative current click-through rate, the indifference price is weakly
increasing in the previous dropout price.
-/
theorem paper_theorem8_generalized_english_indifference_price_mono_lastDropout
    {alphaAbove alphaCurrent lastDropout lastDropout' value : ℝ}
    (halphaAbove_pos : 0 < alphaAbove)
    (halphaCurrent_nonneg : 0 ≤ alphaCurrent)
    (hlastDropout_le : lastDropout ≤ lastDropout') :
    paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value ≤
      paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout' value := by
  have hratio_nonneg : 0 ≤ alphaCurrent / alphaAbove :=
    div_nonneg halphaCurrent_nonneg (le_of_lt halphaAbove_pos)
  have hdiff :
      paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout' value -
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value =
      (alphaCurrent / alphaAbove) * (lastDropout' - lastDropout) := by
    unfold paper_theorem8_generalized_english_indifference_price
    ring
  rw [← sub_nonneg, hdiff]
  exact mul_nonneg hratio_nonneg (sub_nonneg.mpr hlastDropout_le)

/--
EOS Theorem 8 strict monotonicity algebra for the dropout-price formula. With
positive current click-through rate, the indifference price is strictly
increasing in the previous dropout price.
-/
theorem paper_theorem8_generalized_english_indifference_price_strict_mono_lastDropout
    {alphaAbove alphaCurrent lastDropout lastDropout' value : ℝ}
    (halphaAbove_pos : 0 < alphaAbove)
    (halphaCurrent_pos : 0 < alphaCurrent)
    (hlastDropout_lt : lastDropout < lastDropout') :
    paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout value <
      paper_theorem8_generalized_english_indifference_price
        alphaAbove alphaCurrent lastDropout' value := by
  have hratio_pos : 0 < alphaCurrent / alphaAbove :=
    div_pos halphaCurrent_pos halphaAbove_pos
  have hdiff :
      paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout' value -
        paper_theorem8_generalized_english_indifference_price
          alphaAbove alphaCurrent lastDropout value =
      (alphaCurrent / alphaAbove) * (lastDropout' - lastDropout) := by
    unfold paper_theorem8_generalized_english_indifference_price
    ring
  rw [← sub_pos, hdiff]
  exact mul_pos hratio_pos (sub_pos.mpr hlastDropout_lt)

/--
EOS Theorem 8 ranked dropout-price formula. For adjacent ranks `rank` and
`rank + 1`, this is the generalized-English price at which the lower-ranked
bidder is indifferent between moving up and staying at the current
last-dropout price.
-/
noncomputable def paper_theorem8_generalized_english_ranked_dropout_price
    (clickThroughRate lastDropout value : ℕ → ℝ) (rank : ℕ) : ℝ :=
  paper_theorem8_generalized_english_indifference_price
    (clickThroughRate rank) (clickThroughRate (rank + 1))
    (lastDropout rank) (value (rank + 1))

/--
EOS Theorem 8 ranked continuity algebra: holding the history and all other
values fixed, the rank-indexed dropout price is continuous in the valuation of
the bidder currently considering rank `rank + 1`.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_continuous_value_update
    (clickThroughRate lastDropout value : ℕ → ℝ) (rank : ℕ) :
    Continuous
      (fun bidderValue : ℝ =>
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout
          (Function.update value (rank + 1) bidderValue)
          rank) := by
  simpa [paper_theorem8_generalized_english_ranked_dropout_price] using
    paper_theorem8_generalized_english_indifference_price_continuous_value
      (clickThroughRate rank) (clickThroughRate (rank + 1))
      (lastDropout rank)

/--
EOS Theorem 8 ranked dropout-price indifference algebra. The rank-indexed
dropout formula satisfies the adjacent-slot utility indifference equation.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_eq
    {clickThroughRate lastDropout value : ℕ → ℝ} {rank : ℕ}
    (hclick_ne : clickThroughRate rank ≠ 0) :
    clickThroughRate rank *
        (value (rank + 1) -
          paper_theorem8_generalized_english_ranked_dropout_price
            clickThroughRate lastDropout value rank) =
      clickThroughRate (rank + 1) *
        (value (rank + 1) - lastDropout rank) := by
  exact
    paper_theorem8_generalized_english_indifference_price_eq
      (alphaAbove := clickThroughRate rank)
      (alphaCurrent := clickThroughRate (rank + 1))
      (lastDropout := lastDropout rank)
      (value := value (rank + 1))
      hclick_ne

/--
EOS Theorem 8 ranked dropout price agrees with the finite VCG-tail per-click
price when the previous dropout price is the next rank's finite VCG-tail
per-click price. This is the algebraic bridge from the generalized-English
dropout formula back to the Theorem 7 VCG-tail payment recursion.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_eq_vcg_tail_per_click
    (value clickThroughRate : ℕ → ℝ) (rank remaining : ℕ)
    (hclick_ne : clickThroughRate rank ≠ 0)
    (hnext_click_ne : clickThroughRate (rank + 1) ≠ 0) :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate
        (fun k =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate (k + 1) remaining /
              clickThroughRate (k + 1))
        value rank =
      paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate rank (remaining + 1) /
        clickThroughRate rank := by
  unfold paper_theorem8_generalized_english_ranked_dropout_price
    paper_theorem8_generalized_english_indifference_price
  rw [paper_theorem7_ranked_vcg_tail_payment_rec]
  field_simp [hclick_ne, hnext_click_ne]
  ring

/--
EOS Theorem 8 ranked dropout price agrees with the finite `B*` bid from
Theorem 7 when the previous dropout prices are the corresponding one-rank-lower
finite `B*` bids. This is the paper-facing bridge from generalized-English
threshold bidding back to the VCG-supporting bid vector.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_eq_bstar_bid_of_vcg_tail
    (value clickThroughRate : ℕ → ℝ) (rank remaining : ℕ)
    (hclick_ne : clickThroughRate rank ≠ 0)
    (hnext_click_ne : clickThroughRate (rank + 1) ≠ 0) :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate
        (fun k =>
          paper_theorem7_bstar_bid value
            (fun j =>
              paper_theorem7_ranked_vcg_tail_payment
                value clickThroughRate j remaining)
            clickThroughRate (k + 2))
        value rank =
      paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j (remaining + 1))
        clickThroughRate (rank + 1) := by
  simpa [paper_theorem7_bstar_bid] using
    paper_theorem8_generalized_english_ranked_dropout_price_eq_vcg_tail_per_click
      value clickThroughRate rank remaining hclick_ne hnext_click_ne

/--
EOS Theorem 8 ranked dropout-price interval bound. Under the usual adjacent
click-through-rate normalization and value condition, each ranked dropout price
lies between the previous dropout price and the lower bidder's value.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_mem_interval
    {clickThroughRate lastDropout value : ℕ → ℝ} {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_nonneg : 0 ≤ clickThroughRate (rank + 1))
    (hcurrent_le : clickThroughRate (rank + 1) ≤ clickThroughRate rank)
    (hlastDropout_le : lastDropout rank ≤ value (rank + 1)) :
    lastDropout rank ≤
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank ∧
      paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank ≤ value (rank + 1) := by
  exact
    paper_theorem8_generalized_english_indifference_price_mem_interval
      hclick_pos hcurrent_nonneg hcurrent_le hlastDropout_le

/--
EOS Theorem 8 ranked dropout-price strict interval bound. Under strict
adjacent click-through-rate decrease and a previous dropout strictly below the
lower bidder's value, the ranked dropout price is strictly between them.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_strict_mem_interval
    {clickThroughRate lastDropout value : ℕ → ℝ} {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_pos : 0 < clickThroughRate (rank + 1))
    (hcurrent_lt : clickThroughRate (rank + 1) < clickThroughRate rank)
    (hlastDropout_lt : lastDropout rank < value (rank + 1)) :
    lastDropout rank <
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank ∧
      paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank < value (rank + 1) := by
  exact
    paper_theorem8_generalized_english_indifference_price_strict_mem_interval
      hclick_pos hcurrent_pos hcurrent_lt hlastDropout_lt

/--
EOS Theorem 8 ranked dropout-price monotonicity. Holding adjacent
click-through rates and the previous dropout fixed, the ranked dropout price is
weakly increasing in the lower bidder's value.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_mono_value
    {clickThroughRate lastDropout value value' : ℕ → ℝ} {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_nonneg : 0 ≤ clickThroughRate (rank + 1))
    (hcurrent_le : clickThroughRate (rank + 1) ≤ clickThroughRate rank)
    (hvalue_le : value (rank + 1) ≤ value' (rank + 1)) :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank ≤
      paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value' rank := by
  exact
    paper_theorem8_generalized_english_indifference_price_mono_value
      hclick_pos hcurrent_nonneg hcurrent_le hvalue_le

/--
EOS Theorem 8 ranked dropout-price affine form. The rank-indexed dropout price
is the same affine interpolation between the lower bidder's value and the
previous dropout price as in the scalar formula.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_affine_eq
    {clickThroughRate lastDropout value : ℕ → ℝ} {rank : ℕ} :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank =
      (1 - clickThroughRate (rank + 1) / clickThroughRate rank) *
          value (rank + 1) +
        (clickThroughRate (rank + 1) / clickThroughRate rank) *
          lastDropout rank := by
  exact paper_theorem8_generalized_english_indifference_price_affine_eq

/--
EOS Theorem 8 ranked source-proof algebra: under a strict adjacent click-rate
drop, the rank-indexed dropout price can be made larger than any target by
raising the relevant lower bidder value.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_unbounded_value_of_strict_click
    {clickThroughRate lastDropout : ℕ → ℝ} {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_lt : clickThroughRate (rank + 1) < clickThroughRate rank)
    (target : ℝ) :
    ∃ value : ℕ → ℝ,
      target <
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank := by
  rcases
    paper_theorem8_generalized_english_indifference_price_unbounded_value_of_strict_click
      hclick_pos hcurrent_lt target with
    ⟨s, hs⟩
  refine ⟨fun _ => s, ?_⟩
  simpa [paper_theorem8_generalized_english_ranked_dropout_price] using hs

/--
EOS Theorem 8 ranked dropout-price strict value monotonicity. With a strict
click-through-rate drop, increasing the lower bidder's value strictly increases
the ranked dropout price.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_strict_mono_value
    {clickThroughRate lastDropout value value' : ℕ → ℝ} {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_lt : clickThroughRate (rank + 1) < clickThroughRate rank)
    (hvalue_lt : value (rank + 1) < value' (rank + 1)) :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank <
      paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value' rank := by
  exact
    paper_theorem8_generalized_english_indifference_price_strict_mono_value
      hclick_pos hcurrent_lt hvalue_lt

/--
Ranked Theorem 8 uniqueness algebra: holding the history and all other values
fixed, the rank-indexed dropout price is injective in the current bidder's
valuation under strict adjacent click-through rates.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_injective_value_update_of_strict_click
    (clickThroughRate lastDropout value : ℕ → ℝ) (rank : ℕ)
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_lt : clickThroughRate (rank + 1) < clickThroughRate rank) :
    Function.Injective
      (fun bidderValue : ℝ =>
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout
          (Function.update value (rank + 1) bidderValue)
          rank) := by
  intro bidderValue bidderValue' hprice
  exact
    paper_theorem8_generalized_english_indifference_price_injective_value_of_strict_click
      hclick_pos hcurrent_lt
      (by
        simpa [paper_theorem8_generalized_english_ranked_dropout_price] using
          hprice)

/--
EOS Theorem 8 ranked dropout-price lower bound. Under the usual adjacent
click-through-rate normalization, the ranked dropout price is at least the
previous dropout price whenever that previous price is below the lower bidder's
value.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_lastDropout_le
    {clickThroughRate lastDropout value : ℕ → ℝ} {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_le : clickThroughRate (rank + 1) ≤ clickThroughRate rank)
    (hlastDropout_le : lastDropout rank ≤ value (rank + 1)) :
    lastDropout rank ≤
      paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank := by
  exact
    paper_theorem8_generalized_english_indifference_price_lastDropout_le
      hclick_pos hcurrent_le hlastDropout_le

/--
EOS Theorem 8 ranked dropout-price upper bound. With nonnegative current
click-through rate, the ranked dropout price is at most the lower bidder's
value whenever the previous dropout price is below that value.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_le_value
    {clickThroughRate lastDropout value : ℕ → ℝ} {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_nonneg : 0 ≤ clickThroughRate (rank + 1))
    (hlastDropout_le : lastDropout rank ≤ value (rank + 1)) :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank ≤
      value (rank + 1) := by
  exact
    paper_theorem8_generalized_english_indifference_price_le_value
      hclick_pos hcurrent_nonneg hlastDropout_le

/--
EOS Theorem 8 ranked dropout-price monotonicity in the previous dropout price.
With nonnegative current click-through rate, a higher previous dropout price
weakly increases the next ranked dropout price.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_mono_lastDropout
    {clickThroughRate lastDropout lastDropout' value : ℕ → ℝ} {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_nonneg : 0 ≤ clickThroughRate (rank + 1))
    (hlastDropout_le : lastDropout rank ≤ lastDropout' rank) :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank ≤
      paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout' value rank := by
  exact
    paper_theorem8_generalized_english_indifference_price_mono_lastDropout
      hclick_pos hcurrent_nonneg hlastDropout_le

/--
EOS Theorem 8 ranked dropout-price strict monotonicity in the previous dropout
price. With positive current click-through rate, a strictly higher previous
dropout price strictly increases the next ranked dropout price.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_strict_mono_lastDropout
    {clickThroughRate lastDropout lastDropout' value : ℕ → ℝ} {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_pos : 0 < clickThroughRate (rank + 1))
    (hlastDropout_lt : lastDropout rank < lastDropout' rank) :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank <
      paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout' value rank := by
  exact
    paper_theorem8_generalized_english_indifference_price_strict_mono_lastDropout
      hclick_pos hcurrent_pos hlastDropout_lt

/--
EOS Theorem 8 ranked dropout-price endpoint. If the current lower slot has zero
click-through rate, the ranked dropout price equals the lower bidder's value.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_zero_current_eq
    {clickThroughRate lastDropout value : ℕ → ℝ} {rank : ℕ}
    (hcurrent_zero : clickThroughRate (rank + 1) = 0) :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank = value (rank + 1) := by
  simpa [paper_theorem8_generalized_english_ranked_dropout_price,
    hcurrent_zero] using
    (paper_theorem8_generalized_english_indifference_price_zero_current_eq
      (alphaAbove := clickThroughRate rank)
      (lastDropout := lastDropout rank)
      (value := value (rank + 1)))

/--
EOS Theorem 8 ranked dropout-price endpoint. If adjacent click-through rates
are equal, the ranked dropout price equals the previous dropout price.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_full_current_eq
    {clickThroughRate lastDropout value : ℕ → ℝ} {rank : ℕ}
    (hclick_ne : clickThroughRate rank ≠ 0)
    (hcurrent_eq : clickThroughRate (rank + 1) = clickThroughRate rank) :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank = lastDropout rank := by
  simpa [paper_theorem8_generalized_english_ranked_dropout_price,
    hcurrent_eq] using
    (paper_theorem8_generalized_english_indifference_price_full_current_eq
      (alphaAbove := clickThroughRate rank)
      (lastDropout := lastDropout rank)
      (value := value (rank + 1))
      hclick_ne)

/--
Ranked empty-history convention for Theorem 8: if the relevant previous
dropout record is `0`, the ranked dropout price is the affine empty-history
formula in the current bidder's value.
-/
theorem paper_theorem8_generalized_english_ranked_dropout_price_empty_history_eq
    {clickThroughRate lastDropout value : ℕ → ℝ} {rank : ℕ}
    (hlast : lastDropout rank = 0) :
    paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank =
      (1 - clickThroughRate (rank + 1) / clickThroughRate rank) *
        value (rank + 1) := by
  unfold paper_theorem8_generalized_english_ranked_dropout_price
  rw [hlast]
  exact paper_theorem8_generalized_english_indifference_price_empty_history_eq

/--
Paper-facing ranked dropout certificate for EOS Theorem 8. It records the
ranked dropout formula and an explicit dynamic-game/PBE certificate.
-/
structure PaperTheorem8RankedDropoutPBECertificate
    (StrategyProfile Outcome : Type*) where
  clickThroughRate : ℕ → ℝ
  lastDropout : ℕ → ℝ
  value : ℕ → ℝ
  dropoutPrice : ℕ → ℝ
  dropout_eq :
    ∀ rank,
      dropoutPrice rank =
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank
  pbe :
    PaperTheorem8GeneralizedEnglishPBECertificate StrategyProfile Outcome

/--
EOS Theorem 8 ranked dropout certificate form. A ranked dropout profile that
matches the paper's formula, together with a dynamic-game/PBE certificate,
yields the unique-PBE and VCG-outcome conclusion while exposing the
rank-by-rank dropout equation for human verification.
-/
theorem paper_theorem8_ranked_dropout_unique_pbe_of_certificate
    {StrategyProfile Outcome : Type*}
    (model :
      PaperTheorem8RankedDropoutPBECertificate StrategyProfile Outcome) :
    (∀ rank,
      model.dropoutPrice rank =
        paper_theorem8_generalized_english_ranked_dropout_price
          model.clickThroughRate model.lastDropout model.value rank) ∧
      ∃ equilibrium : StrategyProfile,
        model.pbe.isPerfectBayesianEquilibrium equilibrium ∧
          (∀ strategy,
            model.pbe.isPerfectBayesianEquilibrium strategy →
              strategy = equilibrium) ∧
          model.pbe.outcomeOf equilibrium = model.pbe.vcgOutcome := by
  exact ⟨model.dropout_eq,
    paper_theorem8_generalized_english_unique_pbe_of_certificate model.pbe⟩

/--
EOS Theorem 8 concrete generalized-English auction state. The ascending clock
price is explicit, and each bidder either remains active (`none`) or has a
recorded dropout price (`some p`).
-/
structure PaperTheorem8GeneralizedEnglishAuctionState (Bidder : Type*) where
  clockPrice : ℝ
  lastDropout : Bidder → Option ℝ

namespace PaperTheorem8GeneralizedEnglishAuctionState

/-- A bidder is active exactly when no dropout price has been recorded. -/
def IsActive {Bidder : Type*}
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    (bidder : Bidder) : Prop :=
  state.lastDropout bidder = none

/-- A bidder has dropped at price `price` when that price is recorded. -/
def HasDropped {Bidder : Type*}
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    (bidder : Bidder) (price : ℝ) : Prop :=
  state.lastDropout bidder = some price

/-- Advance the English-auction clock without changing any dropout records. -/
def advanceClock {Bidder : Type*}
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    (newPrice : ℝ) : PaperTheorem8GeneralizedEnglishAuctionState Bidder where
  clockPrice := newPrice
  lastDropout := state.lastDropout

/-- Advancing the clock sets the clock price to the requested new price. -/
theorem advanceClock_clockPrice
    {Bidder : Type*}
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    (newPrice : ℝ) :
    (advanceClock state newPrice).clockPrice = newPrice := by
  rfl

/-- Advancing the clock preserves every bidder's dropout record. -/
theorem advanceClock_preserves_lastDropout
    {Bidder : Type*}
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    (newPrice : ℝ) (bidder : Bidder) :
    (advanceClock state newPrice).lastDropout bidder =
      state.lastDropout bidder := by
  rfl

/-- Record that bidder `bidder` drops at the current clock price. -/
def recordDropout {Bidder : Type*} [DecidableEq Bidder]
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    (bidder : Bidder) : PaperTheorem8GeneralizedEnglishAuctionState Bidder where
  clockPrice := state.clockPrice
  lastDropout j := if j = bidder then some state.clockPrice else state.lastDropout j

/-- Recording a dropout makes that bidder dropped at the current clock price. -/
theorem recordDropout_hasDropped
    {Bidder : Type*} [DecidableEq Bidder]
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    (bidder : Bidder) :
    (recordDropout state bidder).HasDropped bidder state.clockPrice := by
  simp [HasDropped, recordDropout]

/-- Recording a dropout preserves the current clock price. -/
theorem recordDropout_clockPrice
    {Bidder : Type*} [DecidableEq Bidder]
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    (bidder : Bidder) :
    (recordDropout state bidder).clockPrice = state.clockPrice := by
  rfl

/-- Recording a dropout makes that bidder inactive. -/
theorem recordDropout_not_active
    {Bidder : Type*} [DecidableEq Bidder]
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    (bidder : Bidder) :
    ¬ (recordDropout state bidder).IsActive bidder := by
  simp [IsActive, recordDropout]

/-- Recording one bidder's dropout leaves every other bidder's record unchanged. -/
theorem recordDropout_preserves_other
    {Bidder : Type*} [DecidableEq Bidder]
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    {bidder other : Bidder} (hother : other ≠ bidder) :
    (recordDropout state bidder).lastDropout other =
      state.lastDropout other := by
  simp [recordDropout, hother]

/--
One concrete generalized-English state transition: either the ascending clock
advances weakly upward without changing dropout records, or an active bidder
drops at the current clock price.
-/
inductive Step {Bidder : Type*} [DecidableEq Bidder] :
    PaperTheorem8GeneralizedEnglishAuctionState Bidder →
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Prop
  | advance (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
      (newPrice : ℝ) :
      state.clockPrice ≤ newPrice →
        Step state (advanceClock state newPrice)
  | dropout (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
      (bidder : Bidder) :
      state.IsActive bidder →
        Step state (recordDropout state bidder)

/-- Every concrete generalized-English state transition has a weakly increasing clock. -/
theorem Step_clock_mono
    {Bidder : Type*} [DecidableEq Bidder]
    {state next : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hstep : Step state next) :
    state.clockPrice ≤ next.clockPrice := by
  cases hstep with
  | advance newPrice hclock =>
      simpa [advanceClock] using hclock
  | dropout bidder hactive =>
      simp [recordDropout]

/-- A concrete generalized-English transition never reactivates an inactive bidder. -/
theorem Step_active_of_next_active
    {Bidder : Type*} [DecidableEq Bidder]
    {state next : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hstep : Step state next) {bidder : Bidder}
    (hactive_next : next.IsActive bidder) :
    state.IsActive bidder := by
  cases hstep with
  | advance newPrice hclock =>
      simpa [IsActive, advanceClock] using hactive_next
  | dropout dropped hactive =>
      by_cases hsame : bidder = dropped
      · subst bidder
        exfalso
        simpa [IsActive, recordDropout] using hactive_next
      · simpa [IsActive, recordDropout, hsame] using hactive_next

/--
Across one concrete generalized-English transition, a bidder's dropout record
is either preserved or newly set to the previous state's current clock price.
-/
theorem Step_lastDropout_eq_or_current_clock
    {Bidder : Type*} [DecidableEq Bidder]
    {state next : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hstep : Step state next) (bidder : Bidder) :
    next.lastDropout bidder = state.lastDropout bidder ∨
      next.lastDropout bidder = some state.clockPrice := by
  cases hstep with
  | advance newPrice hclock =>
      exact Or.inl rfl
  | dropout dropped hactive =>
      by_cases hsame : bidder = dropped
      · subst bidder
        exact Or.inr (by simp [recordDropout])
      · exact Or.inl (by simp [recordDropout, hsame])

/-- Multi-step generalized-English histories generated by concrete transitions. -/
inductive History {Bidder : Type*} [DecidableEq Bidder] :
    PaperTheorem8GeneralizedEnglishAuctionState Bidder →
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Prop
  | refl (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder) :
      History state state
  | cons {state mid finalState :
        PaperTheorem8GeneralizedEnglishAuctionState Bidder} :
      Step state mid → History mid finalState → History state finalState

/-- Every concrete generalized-English history has a weakly increasing clock. -/
theorem History_clock_mono
    {Bidder : Type*} [DecidableEq Bidder]
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hhist : History state finalState) :
    state.clockPrice ≤ finalState.clockPrice := by
  induction hhist with
  | refl state =>
      exact le_rfl
  | cons hstep hhist ih =>
      exact le_trans (Step_clock_mono hstep) ih

/-- A concrete generalized-English history never reactivates an inactive bidder. -/
theorem History_active_of_final_active
    {Bidder : Type*} [DecidableEq Bidder]
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hhist : History state finalState) {bidder : Bidder}
    (hactive_final : finalState.IsActive bidder) :
    state.IsActive bidder := by
  induction hhist with
  | refl state =>
      exact hactive_final
  | cons hstep hhist ih =>
      exact Step_active_of_next_active hstep (ih hactive_final)

/-- No bidder remains active in a concrete generalized-English state. -/
def NoActive {Bidder : Type*}
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder) : Prop :=
  ∀ bidder : Bidder, ¬ state.IsActive bidder

/-- At most one bidder remains active in a concrete generalized-English state. -/
def AtMostOneActive {Bidder : Type*}
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder) : Prop :=
  ∀ bidder other : Bidder,
    state.IsActive bidder → state.IsActive other → bidder = other

/-- A history starting from a no-active state remains no-active. -/
theorem History_noActive_of_initial
    {Bidder : Type*} [DecidableEq Bidder]
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hhist : History state finalState)
    (hno : state.NoActive) :
    finalState.NoActive := by
  intro bidder hactive_final
  exact hno bidder (History_active_of_final_active hhist hactive_final)

/-- A history starting from an at-most-one-active state remains at-most-one-active. -/
theorem History_atMostOneActive_of_initial
    {Bidder : Type*} [DecidableEq Bidder]
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hhist : History state finalState)
    (hatMostOne : state.AtMostOneActive) :
    finalState.AtMostOneActive := by
  intro bidder other hbidder hother
  exact
    hatMostOne bidder other
      (History_active_of_final_active hhist hbidder)
      (History_active_of_final_active hhist hother)

/--
Once a bidder has dropped, a concrete generalized-English transition preserves
that bidder's recorded dropout price. This rules out later overwrites of
dropout records.
-/
theorem Step_lastDropout_eq_of_initial_some
    {Bidder : Type*} [DecidableEq Bidder]
    {state next : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hstep : Step state next) {bidder : Bidder} {price : ℝ}
    (hdropped : state.lastDropout bidder = some price) :
    next.lastDropout bidder = some price := by
  cases hstep with
  | advance newPrice hclock =>
      simpa [advanceClock] using hdropped
  | dropout dropped hactive =>
      by_cases hsame : bidder = dropped
      · subst bidder
        have hnone : state.lastDropout dropped = none := by
          simpa [IsActive] using hactive
        rw [hdropped] at hnone
        cases hnone
      · simpa [recordDropout, hsame] using hdropped

/--
Once a bidder has dropped, every concrete generalized-English history preserves
that bidder's recorded dropout price.
-/
theorem History_lastDropout_eq_of_initial_some
    {Bidder : Type*} [DecidableEq Bidder]
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hhist : History state finalState) {bidder : Bidder} {price : ℝ}
    (hdropped : state.lastDropout bidder = some price) :
    finalState.lastDropout bidder = some price := by
  induction hhist with
  | refl state =>
      exact hdropped
  | cons hstep hhist ih =>
      exact ih (Step_lastDropout_eq_of_initial_some hstep hdropped)

/--
A concrete generalized-English transition that is consistent with a strategy:
clock advances are always allowed, while a dropout transition must be a dropout
that the strategy prescribes at the current state.
-/
inductive StrategyStep
    {Bidder : Type*} [DecidableEq Bidder]
    (strategy :
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Bidder → Prop) :
    PaperTheorem8GeneralizedEnglishAuctionState Bidder →
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Prop
  | advance (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
      (newPrice : ℝ) :
      state.clockPrice ≤ newPrice →
        StrategyStep strategy state (advanceClock state newPrice)
  | dropout (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
      (bidder : Bidder) :
      state.IsActive bidder →
        strategy state bidder →
          StrategyStep strategy state (recordDropout state bidder)

/-- Every strategy-consistent transition is a concrete transition. -/
theorem StrategyStep.toStep
    {Bidder : Type*} [DecidableEq Bidder]
    {strategy :
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Bidder → Prop}
    {state next : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hstep : StrategyStep strategy state next) :
    Step state next := by
  cases hstep with
  | advance newPrice hclock =>
      exact Step.advance _ newPrice hclock
  | dropout bidder hactive hstrategy =>
      exact Step.dropout _ bidder hactive

/--
Multi-step generalized-English histories generated by strategy-consistent
transitions.
-/
inductive StrategyHistory
    {Bidder : Type*} [DecidableEq Bidder]
    (strategy :
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Bidder → Prop) :
    PaperTheorem8GeneralizedEnglishAuctionState Bidder →
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Prop
  | refl (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder) :
      StrategyHistory strategy state state
  | cons {state mid finalState :
        PaperTheorem8GeneralizedEnglishAuctionState Bidder} :
      StrategyStep strategy state mid →
        StrategyHistory strategy mid finalState →
          StrategyHistory strategy state finalState

/-- Every strategy-consistent history is a concrete history. -/
theorem StrategyHistory.toHistory
    {Bidder : Type*} [DecidableEq Bidder]
    {strategy :
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Bidder → Prop}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hhist : StrategyHistory strategy state finalState) :
    History state finalState := by
  induction hhist with
  | refl state =>
      exact History.refl state
  | cons hstep hhist ih =>
      exact History.cons hstep.toStep ih

/-- Strategy-consistent histories compose. -/
theorem StrategyHistory.trans
    {Bidder : Type*} [DecidableEq Bidder]
    {strategy :
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Bidder → Prop}
    {state mid finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hfirst : StrategyHistory strategy state mid)
    (hsecond : StrategyHistory strategy mid finalState) :
    StrategyHistory strategy state finalState := by
  induction hfirst with
  | refl state =>
      exact hsecond
  | cons hstep hhist ih =>
      exact StrategyHistory.cons hstep (ih hsecond)

/-- Strategy-consistent histories have weakly increasing clocks. -/
theorem StrategyHistory_clock_mono
    {Bidder : Type*} [DecidableEq Bidder]
    {strategy :
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Bidder → Prop}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hhist : StrategyHistory strategy state finalState) :
    state.clockPrice ≤ finalState.clockPrice :=
  History_clock_mono hhist.toHistory

/--
A strategy-terminal generalized-English state: every active bidder is one whom
the strategy does not prescribe to drop at that state.
-/
def StrategyTerminal
    {Bidder : Type*}
    (strategy :
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Bidder → Prop)
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder) : Prop :=
  ∀ bidder : Bidder, state.IsActive bidder → ¬ strategy state bidder

/--
If a bidder is active before a strategy-consistent step and inactive afterward,
then the strategy prescribed dropping that bidder at the previous state.
-/
theorem StrategyStep_new_dropout_strategy
    {Bidder : Type*} [DecidableEq Bidder]
    {strategy :
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Bidder → Prop}
    {state next : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hstep : StrategyStep strategy state next) {bidder : Bidder}
    (hactive : state.IsActive bidder) (hinactive : ¬ next.IsActive bidder) :
    strategy state bidder := by
  cases hstep with
  | advance newPrice hclock =>
      exfalso
      exact hinactive (by simpa [IsActive, advanceClock] using hactive)
  | dropout dropped hactive_dropped hstrategy =>
      by_cases hsame : bidder = dropped
      · subst bidder
        exact hstrategy
      · exfalso
        exact hinactive (by simpa [IsActive, recordDropout, hsame] using hactive)

/--
If a bidder is active before a strategy-consistent step and inactive afterward,
then that step records the bidder's dropout at the previous state's clock
price.
-/
theorem StrategyStep_new_dropout_lastDropout_eq_current_clock
    {Bidder : Type*} [DecidableEq Bidder]
    {strategy :
      PaperTheorem8GeneralizedEnglishAuctionState Bidder → Bidder → Prop}
    {state next : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hstep : StrategyStep strategy state next) {bidder : Bidder}
    (hactive : state.IsActive bidder) (hinactive : ¬ next.IsActive bidder) :
    next.lastDropout bidder = some state.clockPrice := by
  cases hstep with
  | advance newPrice hclock =>
      exfalso
      exact hinactive (by simpa [IsActive, advanceClock] using hactive)
  | dropout dropped hactive_dropped hstrategy =>
      by_cases hsame : bidder = dropped
      · subst bidder
        simp [recordDropout]
      · exfalso
        exact hinactive (by simpa [IsActive, recordDropout, hsame] using hactive)

end PaperTheorem8GeneralizedEnglishAuctionState

/--
EOS Theorem 8 generalized-English pure dropout strategy: at a state, a bidder
either drops (`True`) or remains active (`False`).
-/
abbrev PaperTheorem8GeneralizedEnglishStrategy (Bidder : Type*) :=
  PaperTheorem8GeneralizedEnglishAuctionState Bidder → Bidder → Prop

/--
EOS Theorem 8 threshold dropout strategy. Bidder `i` drops once the clock price
reaches the bidder's threshold.
-/
def paper_theorem8_threshold_dropout_strategy
    {Bidder : Type*} (dropoutPrice : Bidder → ℝ) :
    PaperTheorem8GeneralizedEnglishStrategy Bidder :=
  fun state bidder => dropoutPrice bidder ≤ state.clockPrice

/-- The threshold strategy drops exactly at or above the threshold price. -/
theorem paper_theorem8_threshold_dropout_strategy_drops_iff
    {Bidder : Type*} (dropoutPrice : Bidder → ℝ)
    (state : PaperTheorem8GeneralizedEnglishAuctionState Bidder)
    (bidder : Bidder) :
    paper_theorem8_threshold_dropout_strategy dropoutPrice state bidder ↔
      dropoutPrice bidder ≤ state.clockPrice := by
  rfl

/-- Threshold dropout strategies are monotone in the ascending clock price. -/
theorem paper_theorem8_threshold_dropout_strategy_monotone_clock
    {Bidder : Type*} {dropoutPrice : Bidder → ℝ}
    {state state' : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hclock : state.clockPrice ≤ state'.clockPrice)
    (hdrop :
      paper_theorem8_threshold_dropout_strategy dropoutPrice state bidder) :
    paper_theorem8_threshold_dropout_strategy dropoutPrice state' bidder := by
  exact le_trans hdrop hclock

/-- Threshold dropout strategies are monotone along concrete English-auction histories. -/
theorem paper_theorem8_threshold_dropout_strategy_monotone_history
    {Bidder : Type*} [DecidableEq Bidder]
    {dropoutPrice : Bidder → ℝ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.History state finalState)
    (hdrop :
      paper_theorem8_threshold_dropout_strategy dropoutPrice state bidder) :
    paper_theorem8_threshold_dropout_strategy dropoutPrice finalState bidder := by
  exact
    paper_theorem8_threshold_dropout_strategy_monotone_clock
      (PaperTheorem8GeneralizedEnglishAuctionState.History_clock_mono hhist)
      hdrop

/-- A threshold dropout strategy does not drop strictly below its threshold. -/
theorem paper_theorem8_threshold_dropout_strategy_not_drop_before_threshold
    {Bidder : Type*} {dropoutPrice : Bidder → ℝ}
    {state : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hclock_lt : state.clockPrice < dropoutPrice bidder) :
    ¬ paper_theorem8_threshold_dropout_strategy dropoutPrice state bidder := by
  intro hdrop
  exact (not_le_of_gt hclock_lt) hdrop

/--
A strategy-consistent threshold-step cannot newly drop a bidder while the clock
is still strictly below that bidder's threshold.
-/
theorem paper_theorem8_threshold_dropout_strategy_step_no_new_dropout_before_threshold
    {Bidder : Type*} [DecidableEq Bidder] {dropoutPrice : Bidder → ℝ}
    {state next : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hstep :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep
        (paper_theorem8_threshold_dropout_strategy dropoutPrice) state next)
    (hclock_lt : state.clockPrice < dropoutPrice bidder)
    (hactive : state.IsActive bidder) :
    next.IsActive bidder := by
  by_contra hinactive
  have hdrop :
      paper_theorem8_threshold_dropout_strategy dropoutPrice state bidder :=
    PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep_new_dropout_strategy
      hstep hactive hinactive
  exact
    paper_theorem8_threshold_dropout_strategy_not_drop_before_threshold
      hclock_lt hdrop

/--
In a threshold-strategy-consistent step, a bidder that newly becomes inactive
is recorded as dropping at the previous clock price, and that clock has reached
the bidder's threshold.
-/
theorem paper_theorem8_threshold_dropout_strategy_step_new_dropout_record_eq_and_threshold_le
    {Bidder : Type*} [DecidableEq Bidder] {dropoutPrice : Bidder → ℝ}
    {state next : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hstep :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep
        (paper_theorem8_threshold_dropout_strategy dropoutPrice) state next)
    (hactive : state.IsActive bidder) (hinactive : ¬ next.IsActive bidder) :
    next.lastDropout bidder = some state.clockPrice ∧
      dropoutPrice bidder ≤ state.clockPrice := by
  exact
    ⟨PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep_new_dropout_lastDropout_eq_current_clock
        hstep hactive hinactive,
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep_new_dropout_strategy
        hstep hactive hinactive⟩

/--
A threshold-strategy-consistent history cannot newly drop a bidder if the final
clock is still strictly below that bidder's threshold.
-/
theorem paper_theorem8_threshold_dropout_strategy_history_no_new_dropout_before_threshold
    {Bidder : Type*} [DecidableEq Bidder] {dropoutPrice : Bidder → ℝ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_threshold_dropout_strategy dropoutPrice)
        state finalState)
    (hfinal_lt : finalState.clockPrice < dropoutPrice bidder)
    (hactive : state.IsActive bidder) :
    finalState.IsActive bidder := by
  induction hhist with
  | refl state =>
      exact hactive
  | cons hstep hhist ih =>
      have hstate_lt :
          _ < dropoutPrice bidder :=
        lt_of_le_of_lt
          (le_trans
            (PaperTheorem8GeneralizedEnglishAuctionState.Step_clock_mono
              hstep.toStep)
            (PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory_clock_mono
              hhist))
          hfinal_lt
      have hactive_mid :
          _ :=
        paper_theorem8_threshold_dropout_strategy_step_no_new_dropout_before_threshold
          hstep hstate_lt hactive
      exact ih hfinal_lt hactive_mid

/--
If a bidder starts active but is inactive after a threshold-strategy-consistent
history, the final clock has reached that bidder's threshold.
-/
theorem paper_theorem8_threshold_dropout_strategy_history_new_dropout_threshold_le
    {Bidder : Type*} [DecidableEq Bidder] {dropoutPrice : Bidder → ℝ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_threshold_dropout_strategy dropoutPrice)
        state finalState)
    (hactive : state.IsActive bidder) (hinactive : ¬ finalState.IsActive bidder) :
    dropoutPrice bidder ≤ finalState.clockPrice := by
  by_contra hnot
  have hfinal_lt : finalState.clockPrice < dropoutPrice bidder := not_le.mp hnot
  exact
    hinactive
      (paper_theorem8_threshold_dropout_strategy_history_no_new_dropout_before_threshold
        hhist hfinal_lt hactive)

/--
If a bidder starts active but is inactive after a threshold-strategy-consistent
history, the final state contains a concrete dropout record at some price that
reached the bidder's threshold and is no later than the final clock.
-/
theorem paper_theorem8_threshold_dropout_strategy_history_new_dropout_record_exists
    {Bidder : Type*} [DecidableEq Bidder] {dropoutPrice : Bidder → ℝ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_threshold_dropout_strategy dropoutPrice)
        state finalState)
    (hactive : state.IsActive bidder) (hinactive : ¬ finalState.IsActive bidder) :
    ∃ price,
      finalState.lastDropout bidder = some price ∧
        dropoutPrice bidder ≤ price ∧
          price ≤ finalState.clockPrice := by
  induction hhist with
  | refl state =>
      exact False.elim (hinactive hactive)
  | @cons state0 mid finalState0 hstep hhist ih =>
      by_cases hmid_active : mid.IsActive bidder
      · exact ih hmid_active hinactive
      · have hrecord :=
          paper_theorem8_threshold_dropout_strategy_step_new_dropout_record_eq_and_threshold_le
            hstep hactive hmid_active
        refine ⟨state0.clockPrice, ?_, hrecord.2, ?_⟩
        · exact
            PaperTheorem8GeneralizedEnglishAuctionState.History_lastDropout_eq_of_initial_some
              hhist.toHistory hrecord.1
        · exact
            le_trans
              (PaperTheorem8GeneralizedEnglishAuctionState.Step_clock_mono
                hstep.toStep)
              (PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory_clock_mono
                hhist)

/--
In a terminal threshold-strategy-consistent history, a bidder remains active at
the final state exactly when the final clock is still below that bidder's
threshold.
-/
theorem paper_theorem8_threshold_dropout_strategy_terminal_history_active_iff_clock_lt_threshold
    {Bidder : Type*} [DecidableEq Bidder] {dropoutPrice : Bidder → ℝ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_threshold_dropout_strategy dropoutPrice)
        state finalState)
    (hterminal :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyTerminal
        (paper_theorem8_threshold_dropout_strategy dropoutPrice) finalState)
    (hinitial_active : state.IsActive bidder) :
    finalState.IsActive bidder ↔
      finalState.clockPrice < dropoutPrice bidder := by
  constructor
  · intro hactive_final
    have hnot_drop :
        ¬ paper_theorem8_threshold_dropout_strategy
            dropoutPrice finalState bidder :=
      hterminal bidder hactive_final
    have hnot_le : ¬ dropoutPrice bidder ≤ finalState.clockPrice := by
      simpa [paper_theorem8_threshold_dropout_strategy] using hnot_drop
    exact not_le.mp hnot_le
  · intro hclock_lt
    exact
      paper_theorem8_threshold_dropout_strategy_history_no_new_dropout_before_threshold
        hhist hclock_lt hinitial_active

/--
In a terminal threshold-strategy-consistent history, a bidder is inactive at
the final state exactly when the final clock has reached that bidder's
threshold, provided the bidder was initially active.
-/
theorem paper_theorem8_threshold_dropout_strategy_terminal_history_inactive_iff_threshold_le_clock
    {Bidder : Type*} [DecidableEq Bidder] {dropoutPrice : Bidder → ℝ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_threshold_dropout_strategy dropoutPrice)
        state finalState)
    (hterminal :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyTerminal
        (paper_theorem8_threshold_dropout_strategy dropoutPrice) finalState)
    (hinitial_active : state.IsActive bidder) :
    ¬ finalState.IsActive bidder ↔
      dropoutPrice bidder ≤ finalState.clockPrice := by
  have hactive_iff :=
    paper_theorem8_threshold_dropout_strategy_terminal_history_active_iff_clock_lt_threshold
      hhist hterminal hinitial_active
  rw [hactive_iff]
  exact not_lt

/--
In a terminal threshold-strategy-consistent history from an initially active
bidder, final inactivity is equivalent to the threshold strategy prescribing a
drop at the terminal state.
-/
theorem paper_theorem8_threshold_dropout_strategy_terminal_history_inactive_iff_strategy
    {Bidder : Type*} [DecidableEq Bidder] {dropoutPrice : Bidder → ℝ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_threshold_dropout_strategy dropoutPrice)
        state finalState)
    (hterminal :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyTerminal
        (paper_theorem8_threshold_dropout_strategy dropoutPrice) finalState)
    (hinitial_active : state.IsActive bidder) :
    ¬ finalState.IsActive bidder ↔
      paper_theorem8_threshold_dropout_strategy dropoutPrice finalState bidder := by
  rw [
    paper_theorem8_threshold_dropout_strategy_terminal_history_inactive_iff_threshold_le_clock
      hhist hterminal hinitial_active]
  rfl

/--
In a terminal threshold-strategy-consistent history from an initially active
bidder, final activity is equivalent to the threshold strategy not prescribing
a drop at the terminal state.
-/
theorem paper_theorem8_threshold_dropout_strategy_terminal_history_active_iff_not_strategy
    {Bidder : Type*} [DecidableEq Bidder] {dropoutPrice : Bidder → ℝ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_threshold_dropout_strategy dropoutPrice)
        state finalState)
    (hterminal :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyTerminal
        (paper_theorem8_threshold_dropout_strategy dropoutPrice) finalState)
    (hinitial_active : state.IsActive bidder) :
    finalState.IsActive bidder ↔
      ¬ paper_theorem8_threshold_dropout_strategy dropoutPrice finalState bidder := by
  constructor
  · intro hactive_final
    exact hterminal bidder hactive_final
  · intro hnot_drop
    have hnot_le : ¬ dropoutPrice bidder ≤ finalState.clockPrice := by
      simpa [paper_theorem8_threshold_dropout_strategy] using hnot_drop
    exact
      paper_theorem8_threshold_dropout_strategy_history_no_new_dropout_before_threshold
        hhist (not_le.mp hnot_le) hinitial_active

/--
Bundled terminal-history behavior conclusion for threshold strategies. From a
terminal strategy-consistent history starting with bidder `bidder` active, the
terminal activity status, terminal inactivity status, strategy drop predicate,
and strategy not-drop predicate are all the same threshold cutoff statement.
-/
theorem paper_theorem8_threshold_dropout_strategy_terminal_history_behavior_conclusion
    {Bidder : Type*} [DecidableEq Bidder] {dropoutPrice : Bidder → ℝ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_threshold_dropout_strategy dropoutPrice)
        state finalState)
    (hterminal :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyTerminal
        (paper_theorem8_threshold_dropout_strategy dropoutPrice) finalState)
    (hinitial_active : ∀ bidder, state.IsActive bidder) :
    (∀ bidder,
      finalState.IsActive bidder ↔
        finalState.clockPrice < dropoutPrice bidder) ∧
      (∀ bidder,
        ¬ finalState.IsActive bidder ↔
          dropoutPrice bidder ≤ finalState.clockPrice) ∧
        (∀ bidder,
          paper_theorem8_threshold_dropout_strategy
              dropoutPrice finalState bidder ↔
            ¬ finalState.IsActive bidder) ∧
          (∀ bidder,
            ¬ paper_theorem8_threshold_dropout_strategy
                dropoutPrice finalState bidder ↔
              finalState.IsActive bidder) := by
  constructor
  · intro bidder
    exact
      paper_theorem8_threshold_dropout_strategy_terminal_history_active_iff_clock_lt_threshold
        hhist hterminal (hinitial_active bidder)
  constructor
  · intro bidder
    exact
      paper_theorem8_threshold_dropout_strategy_terminal_history_inactive_iff_threshold_le_clock
        hhist hterminal (hinitial_active bidder)
  constructor
  · intro bidder
    exact
      (paper_theorem8_threshold_dropout_strategy_terminal_history_inactive_iff_strategy
        hhist hterminal (hinitial_active bidder)).symm
  · intro bidder
    exact
      (paper_theorem8_threshold_dropout_strategy_terminal_history_active_iff_not_strategy
        hhist hterminal (hinitial_active bidder)).symm

/--
Threshold dropout strategies have the exact complement cutoff rule: a bidder
does not drop iff the ascending clock is still strictly below the threshold.
-/
theorem paper_theorem8_threshold_dropout_strategy_not_drop_iff_clock_lt_threshold
    {Bidder : Type*} {dropoutPrice : Bidder → ℝ}
    {state : PaperTheorem8GeneralizedEnglishAuctionState Bidder}
    {bidder : Bidder} :
    ¬ paper_theorem8_threshold_dropout_strategy dropoutPrice state bidder ↔
      state.clockPrice < dropoutPrice bidder := by
  rw [paper_theorem8_threshold_dropout_strategy_drops_iff]
  exact not_le

/--
Extensional uniqueness of threshold strategies: any strategy with exactly the
threshold dropout condition is equal to the threshold strategy.
-/
theorem paper_theorem8_strategy_eq_threshold_of_drops_iff
    {Bidder : Type*}
    (strategy : PaperTheorem8GeneralizedEnglishStrategy Bidder)
    (dropoutPrice : Bidder → ℝ)
    (hstrategy :
      ∀ state bidder,
        strategy state bidder ↔ dropoutPrice bidder ≤ state.clockPrice) :
    strategy = paper_theorem8_threshold_dropout_strategy dropoutPrice := by
  funext state bidder
  exact propext (hstrategy state bidder)

/--
EOS Theorem 8 ranked threshold dropout strategy: the bidder at rank `r` drops
once the clock reaches the ranked generalized-English indifference price.
-/
def paper_theorem8_ranked_threshold_dropout_strategy
    (clickThroughRate lastDropout value : ℕ → ℝ) :
    PaperTheorem8GeneralizedEnglishStrategy ℕ :=
  paper_theorem8_threshold_dropout_strategy
    (fun rank =>
      paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank)

/-- The ranked threshold strategy drops exactly at or above the ranked formula. -/
theorem paper_theorem8_ranked_threshold_dropout_strategy_drops_iff
    (clickThroughRate lastDropout value : ℕ → ℝ)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (rank : ℕ) :
    paper_theorem8_ranked_threshold_dropout_strategy
        clickThroughRate lastDropout value state rank ↔
      paper_theorem8_generalized_english_ranked_dropout_price
        clickThroughRate lastDropout value rank ≤ state.clockPrice := by
  rfl

/--
EOS Theorem 8 ranked threshold strategy drops exactly at the finite `B*` bid
threshold when continuation dropout prices are the one-rank-lower finite `B*`
bids from Theorem 7.
-/
theorem paper_theorem8_ranked_threshold_dropout_strategy_drops_iff_bstar_bid_of_vcg_tail
    (value clickThroughRate : ℕ → ℝ)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (rank remaining : ℕ)
    (hclick_ne : clickThroughRate rank ≠ 0)
    (hnext_click_ne : clickThroughRate (rank + 1) ≠ 0) :
    paper_theorem8_ranked_threshold_dropout_strategy
        clickThroughRate
        (fun k =>
          paper_theorem7_bstar_bid value
            (fun j =>
              paper_theorem7_ranked_vcg_tail_payment
                value clickThroughRate j remaining)
            clickThroughRate (k + 2))
        value state rank ↔
      paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j (remaining + 1))
        clickThroughRate (rank + 1) ≤ state.clockPrice := by
  rw [paper_theorem8_ranked_threshold_dropout_strategy_drops_iff]
  rw [paper_theorem8_generalized_english_ranked_dropout_price_eq_bstar_bid_of_vcg_tail
    value clickThroughRate rank remaining hclick_ne hnext_click_ne]

/--
Finite `B*` ranked-threshold complement cutoff rule: under the VCG-tail
continuation prices, a ranked bidder has not dropped exactly when the clock is
strictly below the finite `B*` bid threshold.
-/
theorem paper_theorem8_ranked_threshold_dropout_strategy_not_drop_iff_clock_lt_bstar_bid_of_vcg_tail
    (value clickThroughRate : ℕ → ℝ)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (rank remaining : ℕ)
    (hclick_ne : clickThroughRate rank ≠ 0)
    (hnext_click_ne : clickThroughRate (rank + 1) ≠ 0) :
    ¬ paper_theorem8_ranked_threshold_dropout_strategy
        clickThroughRate
        (fun k =>
          paper_theorem7_bstar_bid value
            (fun j =>
              paper_theorem7_ranked_vcg_tail_payment
                value clickThroughRate j remaining)
            clickThroughRate (k + 2))
        value state rank ↔
      state.clockPrice <
        paper_theorem7_bstar_bid value
          (fun j =>
            paper_theorem7_ranked_vcg_tail_payment
              value clickThroughRate j (remaining + 1))
          clickThroughRate (rank + 1) := by
  rw [paper_theorem8_ranked_threshold_dropout_strategy_drops_iff_bstar_bid_of_vcg_tail
    value clickThroughRate state rank remaining hclick_ne hnext_click_ne]
  exact not_le

/--
Extensional uniqueness of ranked threshold strategies: any ranked strategy with
exactly the ranked dropout-price threshold condition equals the ranked
threshold strategy.
-/
theorem paper_theorem8_strategy_eq_ranked_threshold_of_drops_iff
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ)
    (clickThroughRate lastDropout value : ℕ → ℝ)
    (hstrategy :
      ∀ state rank,
        strategy state rank ↔
          paper_theorem8_generalized_english_ranked_dropout_price
            clickThroughRate lastDropout value rank ≤ state.clockPrice) :
    strategy =
      paper_theorem8_ranked_threshold_dropout_strategy
        clickThroughRate lastDropout value := by
  exact
    paper_theorem8_strategy_eq_threshold_of_drops_iff
      strategy
      (fun rank =>
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank)
      hstrategy

/-- Ranked threshold dropout strategies are monotone in the ascending clock. -/
theorem paper_theorem8_ranked_threshold_dropout_strategy_monotone_clock
    {clickThroughRate lastDropout value : ℕ → ℝ}
    {state state' : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hclock : state.clockPrice ≤ state'.clockPrice)
    (hdrop :
      paper_theorem8_ranked_threshold_dropout_strategy
        clickThroughRate lastDropout value state rank) :
    paper_theorem8_ranked_threshold_dropout_strategy
      clickThroughRate lastDropout value state' rank := by
  exact
    paper_theorem8_threshold_dropout_strategy_monotone_clock
      hclock hdrop

/-- Ranked threshold dropout strategies are monotone along concrete histories. -/
theorem paper_theorem8_ranked_threshold_dropout_strategy_monotone_history
    {clickThroughRate lastDropout value : ℕ → ℝ}
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.History state finalState)
    (hdrop :
      paper_theorem8_ranked_threshold_dropout_strategy
        clickThroughRate lastDropout value state rank) :
    paper_theorem8_ranked_threshold_dropout_strategy
      clickThroughRate lastDropout value finalState rank := by
  exact
    paper_theorem8_ranked_threshold_dropout_strategy_monotone_clock
      (PaperTheorem8GeneralizedEnglishAuctionState.History_clock_mono hhist)
      hdrop

/-- A ranked threshold dropout strategy does not drop below its ranked price. -/
theorem paper_theorem8_ranked_threshold_dropout_strategy_not_drop_before_threshold
    {clickThroughRate lastDropout value : ℕ → ℝ}
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hclock_lt :
      state.clockPrice <
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank) :
    ¬ paper_theorem8_ranked_threshold_dropout_strategy
        clickThroughRate lastDropout value state rank := by
  exact
    paper_theorem8_threshold_dropout_strategy_not_drop_before_threshold
      hclock_lt

/--
Ranked threshold strategies have the exact complement cutoff rule: a bidder at
rank `r` does not drop iff the clock is still below the rank-indexed dropout
price.
-/
theorem paper_theorem8_ranked_threshold_dropout_strategy_not_drop_iff_clock_lt_threshold
    {clickThroughRate lastDropout value : ℕ → ℝ}
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ} :
    ¬ paper_theorem8_ranked_threshold_dropout_strategy
        clickThroughRate lastDropout value state rank ↔
      state.clockPrice <
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank := by
  exact
    paper_theorem8_threshold_dropout_strategy_not_drop_iff_clock_lt_threshold

/--
The ranked threshold strategy never drops before the previous dropout price,
under the usual adjacent click-through-rate normalization and value condition.
-/
theorem paper_theorem8_ranked_threshold_dropout_strategy_not_before_lastDropout
    {clickThroughRate lastDropout value : ℕ → ℝ}
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_le : clickThroughRate (rank + 1) ≤ clickThroughRate rank)
    (hlastDropout_le : lastDropout rank ≤ value (rank + 1))
    (hclock_lt : state.clockPrice < lastDropout rank) :
    ¬ paper_theorem8_ranked_threshold_dropout_strategy
        clickThroughRate lastDropout value state rank := by
  have hthreshold_ge_last :
      lastDropout rank ≤
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank :=
    paper_theorem8_generalized_english_ranked_dropout_price_lastDropout_le
      hclick_pos hcurrent_le hlastDropout_le
  exact
    paper_theorem8_ranked_threshold_dropout_strategy_not_drop_before_threshold
      (lt_of_lt_of_le hclock_lt hthreshold_ge_last)

/--
The ranked threshold strategy has dropped by the time the clock reaches the
lower bidder's value, under the usual click-through-rate normalization and
value condition.
-/
theorem paper_theorem8_ranked_threshold_dropout_strategy_drops_by_value
    {clickThroughRate lastDropout value : ℕ → ℝ}
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hcurrent_nonneg : 0 ≤ clickThroughRate (rank + 1))
    (hlastDropout_le : lastDropout rank ≤ value (rank + 1))
    (hvalue_le_clock : value (rank + 1) ≤ state.clockPrice) :
    paper_theorem8_ranked_threshold_dropout_strategy
        clickThroughRate lastDropout value state rank := by
  have hthreshold_le_value :
      paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank ≤
        value (rank + 1) :=
    paper_theorem8_generalized_english_ranked_dropout_price_le_value
      hclick_pos hcurrent_nonneg hlastDropout_le
  exact le_trans hthreshold_le_value hvalue_le_clock

/--
At the ranked threshold clock price, the lower-ranked bidder is exactly
indifferent between the higher slot at the current clock and the lower slot at
the previous dropout price.
-/
theorem paper_theorem8_ranked_threshold_indifferent_at_clock
    {clickThroughRate lastDropout value : ℕ → ℝ}
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hclick_ne : clickThroughRate rank ≠ 0)
    (hclock_eq :
      state.clockPrice =
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank) :
    clickThroughRate rank * (value (rank + 1) - state.clockPrice) =
      clickThroughRate (rank + 1) *
        (value (rank + 1) - lastDropout rank) := by
  rw [hclock_eq]
  exact
    paper_theorem8_generalized_english_ranked_dropout_price_eq
      hclick_ne

/--
Below the ranked threshold clock price, the lower-ranked bidder strictly
prefers continuing for the higher slot over taking the lower slot at the
previous dropout price.
-/
theorem paper_theorem8_ranked_threshold_prefers_active_before_threshold
    {clickThroughRate lastDropout value : ℕ → ℝ}
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hclock_lt :
      state.clockPrice <
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank) :
    clickThroughRate (rank + 1) *
        (value (rank + 1) - lastDropout rank) <
      clickThroughRate rank * (value (rank + 1) - state.clockPrice) := by
  rw [← paper_theorem8_generalized_english_ranked_dropout_price_eq
    (hclick_ne := ne_of_gt hclick_pos)]
  nlinarith

/--
Above the ranked threshold clock price, the lower-ranked bidder strictly
prefers the lower slot at the previous dropout price over continuing for the
higher slot at the current clock.
-/
theorem paper_theorem8_ranked_threshold_prefers_drop_after_threshold
    {clickThroughRate lastDropout value : ℕ → ℝ}
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {rank : ℕ}
    (hclick_pos : 0 < clickThroughRate rank)
    (hthreshold_lt :
      paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate lastDropout value rank <
        state.clockPrice) :
    clickThroughRate rank * (value (rank + 1) - state.clockPrice) <
      clickThroughRate (rank + 1) *
        (value (rank + 1) - lastDropout rank) := by
  rw [← paper_theorem8_generalized_english_ranked_dropout_price_eq
    (hclick_ne := ne_of_gt hclick_pos)]
  nlinarith

/--
At the finite `B*` bid threshold induced by the Theorem 7 VCG-tail recursion,
the lower-ranked bidder is exactly indifferent between continuing for the
higher adjacent slot and taking the lower adjacent slot at the continuation
`B*` bid.
-/
theorem paper_theorem8_ranked_threshold_indifferent_at_bstar_bid_of_vcg_tail
    (value clickThroughRate : ℕ → ℝ)
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (rank remaining : ℕ)
    (hclick_ne : clickThroughRate rank ≠ 0)
    (hnext_click_ne : clickThroughRate (rank + 1) ≠ 0)
    (hclock_eq :
      state.clockPrice =
        paper_theorem7_bstar_bid value
          (fun j =>
            paper_theorem7_ranked_vcg_tail_payment
              value clickThroughRate j (remaining + 1))
          clickThroughRate (rank + 1)) :
    clickThroughRate rank * (value (rank + 1) - state.clockPrice) =
      clickThroughRate (rank + 1) *
        (value (rank + 1) -
          paper_theorem7_bstar_bid value
            (fun j =>
              paper_theorem7_ranked_vcg_tail_payment
                value clickThroughRate j remaining)
            clickThroughRate (rank + 2)) := by
  let continuationDropout : ℕ → ℝ :=
    fun k =>
      paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j remaining)
        clickThroughRate (k + 2)
  have hclock_eq_threshold :
      state.clockPrice =
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate continuationDropout value rank := by
    rw [paper_theorem8_generalized_english_ranked_dropout_price_eq_bstar_bid_of_vcg_tail
      value clickThroughRate rank remaining hclick_ne hnext_click_ne]
    exact hclock_eq
  simpa [continuationDropout] using
    paper_theorem8_ranked_threshold_indifferent_at_clock
      (clickThroughRate := clickThroughRate)
      (lastDropout := continuationDropout)
      (value := value)
      (state := state)
      (rank := rank)
      hclick_ne hclock_eq_threshold

/--
Below the finite `B*` bid threshold induced by the Theorem 7 VCG-tail
recursion, the lower-ranked bidder strictly prefers continuing for the higher
adjacent slot.
-/
theorem paper_theorem8_ranked_threshold_prefers_active_before_bstar_bid_of_vcg_tail
    (value clickThroughRate : ℕ → ℝ)
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (rank remaining : ℕ)
    (hclick_pos : 0 < clickThroughRate rank)
    (hnext_click_ne : clickThroughRate (rank + 1) ≠ 0)
    (hclock_lt :
      state.clockPrice <
        paper_theorem7_bstar_bid value
          (fun j =>
            paper_theorem7_ranked_vcg_tail_payment
              value clickThroughRate j (remaining + 1))
          clickThroughRate (rank + 1)) :
    clickThroughRate (rank + 1) *
        (value (rank + 1) -
          paper_theorem7_bstar_bid value
            (fun j =>
              paper_theorem7_ranked_vcg_tail_payment
                value clickThroughRate j remaining)
            clickThroughRate (rank + 2)) <
      clickThroughRate rank * (value (rank + 1) - state.clockPrice) := by
  let continuationDropout : ℕ → ℝ :=
    fun k =>
      paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j remaining)
        clickThroughRate (k + 2)
  have hclock_lt_threshold :
      state.clockPrice <
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate continuationDropout value rank := by
    rw [paper_theorem8_generalized_english_ranked_dropout_price_eq_bstar_bid_of_vcg_tail
      value clickThroughRate rank remaining (ne_of_gt hclick_pos) hnext_click_ne]
    exact hclock_lt
  simpa [continuationDropout] using
    paper_theorem8_ranked_threshold_prefers_active_before_threshold
      (clickThroughRate := clickThroughRate)
      (lastDropout := continuationDropout)
      (value := value)
      (state := state)
      (rank := rank)
      hclick_pos hclock_lt_threshold

/--
Above the finite `B*` bid threshold induced by the Theorem 7 VCG-tail
recursion, the lower-ranked bidder strictly prefers dropping to the lower
adjacent slot.
-/
theorem paper_theorem8_ranked_threshold_prefers_drop_after_bstar_bid_of_vcg_tail
    (value clickThroughRate : ℕ → ℝ)
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (rank remaining : ℕ)
    (hclick_pos : 0 < clickThroughRate rank)
    (hnext_click_ne : clickThroughRate (rank + 1) ≠ 0)
    (hthreshold_lt :
      paper_theorem7_bstar_bid value
          (fun j =>
            paper_theorem7_ranked_vcg_tail_payment
              value clickThroughRate j (remaining + 1))
          clickThroughRate (rank + 1) <
        state.clockPrice) :
    clickThroughRate rank * (value (rank + 1) - state.clockPrice) <
      clickThroughRate (rank + 1) *
        (value (rank + 1) -
          paper_theorem7_bstar_bid value
            (fun j =>
              paper_theorem7_ranked_vcg_tail_payment
                value clickThroughRate j remaining)
            clickThroughRate (rank + 2)) := by
  let continuationDropout : ℕ → ℝ :=
    fun k =>
      paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j remaining)
        clickThroughRate (k + 2)
  have hthreshold_lt_clock :
      paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate continuationDropout value rank <
        state.clockPrice := by
    rw [paper_theorem8_generalized_english_ranked_dropout_price_eq_bstar_bid_of_vcg_tail
      value clickThroughRate rank remaining (ne_of_gt hclick_pos) hnext_click_ne]
    exact hthreshold_lt
  simpa [continuationDropout] using
    paper_theorem8_ranked_threshold_prefers_drop_after_threshold
      (clickThroughRate := clickThroughRate)
      (lastDropout := continuationDropout)
      (value := value)
      (state := state)
      (rank := rank)
      hclick_pos hthreshold_lt_clock

/--
EOS Theorem 8 exact finite-`B*` strict interval bridge. Under strict adjacent
click-through-rate decrease and strict continuation slack, the current finite
`B*` threshold is strictly between the continuation finite `B*` bid and the
lower bidder's value.
-/
theorem paper_theorem8_bstar_threshold_strict_interval_of_vcg_tail
    (value clickThroughRate : ℕ → ℝ) (rank remaining : ℕ)
    (hclick_pos : 0 < clickThroughRate rank)
    (hnext_click_pos : 0 < clickThroughRate (rank + 1))
    (hcurrent_lt : clickThroughRate (rank + 1) < clickThroughRate rank)
    (hcontinuation_lt_value :
      paper_theorem7_bstar_bid value
          (fun j =>
            paper_theorem7_ranked_vcg_tail_payment
              value clickThroughRate j remaining)
          clickThroughRate (rank + 2) <
        value (rank + 1)) :
    paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j remaining)
        clickThroughRate (rank + 2) <
        paper_theorem7_bstar_bid value
          (fun j =>
            paper_theorem7_ranked_vcg_tail_payment
              value clickThroughRate j (remaining + 1))
          clickThroughRate (rank + 1) ∧
      paper_theorem7_bstar_bid value
          (fun j =>
            paper_theorem7_ranked_vcg_tail_payment
              value clickThroughRate j (remaining + 1))
          clickThroughRate (rank + 1) <
        value (rank + 1) := by
  let continuationDropout : ℕ → ℝ :=
    fun k =>
      paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j remaining)
        clickThroughRate (k + 2)
  have hstrict :
      continuationDropout rank <
          paper_theorem8_generalized_english_ranked_dropout_price
            clickThroughRate continuationDropout value rank ∧
        paper_theorem8_generalized_english_ranked_dropout_price
            clickThroughRate continuationDropout value rank <
          value (rank + 1) :=
    paper_theorem8_generalized_english_ranked_dropout_price_strict_mem_interval
      hclick_pos hnext_click_pos hcurrent_lt
      (by simpa [continuationDropout] using hcontinuation_lt_value)
  have hprice_eq :
      paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate continuationDropout value rank =
        paper_theorem7_bstar_bid value
          (fun j =>
            paper_theorem7_ranked_vcg_tail_payment
              value clickThroughRate j (remaining + 1))
          clickThroughRate (rank + 1) :=
    paper_theorem8_generalized_english_ranked_dropout_price_eq_bstar_bid_of_vcg_tail
      value clickThroughRate rank remaining
      (ne_of_gt hclick_pos) (ne_of_gt hnext_click_pos)
  simpa [continuationDropout, hprice_eq] using hstrict

/--
Paper-facing local optimality assumptions for the ranked-threshold strategy in
EOS Theorem 8.
-/
structure PaperTheorem8RankedThresholdLocalOptimalityCertificate where
  clickThroughRate : ℕ → ℝ
  lastDropout : ℕ → ℝ
  value : ℕ → ℝ
  click_pos : ∀ rank, 0 < clickThroughRate rank
  current_nonneg : ∀ rank, 0 ≤ clickThroughRate (rank + 1)
  current_le : ∀ rank, clickThroughRate (rank + 1) ≤ clickThroughRate rank
  lastDropout_le_value : ∀ rank, lastDropout rank ≤ value (rank + 1)

/--
EOS Theorem 8 ranked-threshold local optimality package. Under the standard
adjacent click-through-rate and value assumptions, each ranked threshold lies
between the previous dropout and the bidder's value; the ranked threshold
strategy does not drop before the previous dropout, has dropped by the value,
is indifferent at the threshold, and has the strict preference direction on
each side of the threshold.
-/
theorem paper_theorem8_ranked_threshold_local_optimality_of_certificate
    (model : PaperTheorem8RankedThresholdLocalOptimalityCertificate) :
    ∀ rank,
      model.lastDropout rank ≤
          paper_theorem8_generalized_english_ranked_dropout_price
            model.clickThroughRate model.lastDropout model.value rank ∧
        paper_theorem8_generalized_english_ranked_dropout_price
            model.clickThroughRate model.lastDropout model.value rank ≤
          model.value (rank + 1) ∧
        (∀ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
          state.clockPrice < model.lastDropout rank →
            ¬ paper_theorem8_ranked_threshold_dropout_strategy
                model.clickThroughRate model.lastDropout model.value
                state rank) ∧
        (∀ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
          model.value (rank + 1) ≤ state.clockPrice →
            paper_theorem8_ranked_threshold_dropout_strategy
              model.clickThroughRate model.lastDropout model.value
              state rank) ∧
        (∀ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
          state.clockPrice =
              paper_theorem8_generalized_english_ranked_dropout_price
                model.clickThroughRate model.lastDropout model.value rank →
            model.clickThroughRate rank *
                (model.value (rank + 1) - state.clockPrice) =
              model.clickThroughRate (rank + 1) *
                (model.value (rank + 1) - model.lastDropout rank)) ∧
        (∀ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
          state.clockPrice <
              paper_theorem8_generalized_english_ranked_dropout_price
                model.clickThroughRate model.lastDropout model.value rank →
            model.clickThroughRate (rank + 1) *
                (model.value (rank + 1) - model.lastDropout rank) <
              model.clickThroughRate rank *
                (model.value (rank + 1) - state.clockPrice)) ∧
        (∀ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
          paper_theorem8_generalized_english_ranked_dropout_price
              model.clickThroughRate model.lastDropout model.value rank <
            state.clockPrice →
            model.clickThroughRate rank *
                (model.value (rank + 1) - state.clockPrice) <
              model.clickThroughRate (rank + 1) *
                (model.value (rank + 1) - model.lastDropout rank)) := by
  intro rank
  refine ⟨?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  · exact
      paper_theorem8_generalized_english_ranked_dropout_price_lastDropout_le
        (model.click_pos rank) (model.current_le rank)
        (model.lastDropout_le_value rank)
  · exact
      paper_theorem8_generalized_english_ranked_dropout_price_le_value
        (model.click_pos rank) (model.current_nonneg rank)
        (model.lastDropout_le_value rank)
  · intro state hclock_lt
    exact
      paper_theorem8_ranked_threshold_dropout_strategy_not_before_lastDropout
        (model.click_pos rank) (model.current_le rank)
        (model.lastDropout_le_value rank) hclock_lt
  · intro state hvalue_le_clock
    exact
      paper_theorem8_ranked_threshold_dropout_strategy_drops_by_value
        (model.click_pos rank) (model.current_nonneg rank)
        (model.lastDropout_le_value rank) hvalue_le_clock
  · intro state hclock_eq
    exact
      paper_theorem8_ranked_threshold_indifferent_at_clock
        (ne_of_gt (model.click_pos rank)) hclock_eq
  · intro state hclock_lt
    exact
      paper_theorem8_ranked_threshold_prefers_active_before_threshold
        (model.click_pos rank) hclock_lt
  · intro state hthreshold_lt
    exact
      paper_theorem8_ranked_threshold_prefers_drop_after_threshold
        (model.click_pos rank) hthreshold_lt

/--
The continuation finite `B*` bid is value-bounded whenever the corresponding
finite VCG-tail payment is bounded by click-through-rate times value. This is
the bridge from a paper-native total-payment bound to the per-click premise used
by the exact `B*` local-optimality certificate.
-/
theorem paper_theorem8_bstar_continuation_bid_le_value_of_tail_payment_le
    {value clickThroughRate : ℕ → ℝ} {rank remaining : ℕ}
    (hclick_pos : 0 < clickThroughRate (rank + 1))
    (htail_le :
      paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate (rank + 1) remaining ≤
        clickThroughRate (rank + 1) * value (rank + 1)) :
    paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j remaining)
        clickThroughRate (rank + 2) ≤ value (rank + 1) := by
  have hdiv :
      paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate (rank + 1) remaining /
          clickThroughRate (rank + 1) ≤
        value (rank + 1) := by
    rw [div_le_iff₀ hclick_pos]
    nlinarith [htail_le]
  simpa [paper_theorem7_bstar_bid] using hdiv

/--
The continuation finite `B*` bid is strictly value-bounded whenever the
corresponding finite VCG-tail payment is strictly below click-through-rate times
value. This is the strict paper-native total-payment bridge needed for
no-tie threshold intervals in EOS Theorem 8.
-/
theorem paper_theorem8_bstar_continuation_bid_lt_value_of_tail_payment_lt
    {value clickThroughRate : ℕ → ℝ} {rank remaining : ℕ}
    (hclick_pos : 0 < clickThroughRate (rank + 1))
    (htail_lt :
      paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate (rank + 1) remaining <
        clickThroughRate (rank + 1) * value (rank + 1)) :
    paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j remaining)
        clickThroughRate (rank + 2) < value (rank + 1) := by
  have hdiv :
      paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate (rank + 1) remaining /
          clickThroughRate (rank + 1) <
        value (rank + 1) := by
    rw [div_lt_iff₀ hclick_pos]
    nlinarith [htail_lt]
  simpa [paper_theorem7_bstar_bid] using hdiv

/--
The continuation finite `B*` bid is value-bounded under the standard ordered
rank assumptions. This combines the Theorem 7 finite VCG-tail upper bound with
the per-click `B*` bridge used by the exact Theorem 8 local-optimality package.
-/
theorem paper_theorem8_bstar_continuation_bid_le_value_of_ordered_tail
    {value clickThroughRate : ℕ → ℝ} {rank remaining : ℕ}
    (hvalue_nonneg : ∀ i, 0 ≤ value i)
    (hvalue_mono : ∀ i, value (i + 1) ≤ value i)
    (hclick_nonneg : ∀ i, 0 ≤ clickThroughRate i)
    (hclick_pos : 0 < clickThroughRate (rank + 1)) :
    paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j remaining)
        clickThroughRate (rank + 2) ≤ value (rank + 1) := by
  exact
    paper_theorem8_bstar_continuation_bid_le_value_of_tail_payment_le
      hclick_pos
      (paper_theorem7_ranked_vcg_tail_payment_le_click_value
        hvalue_nonneg hvalue_mono hclick_nonneg (rank + 1) remaining)

