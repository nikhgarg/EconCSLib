    · nlinarith [hstrict.1]
  · refine
      ⟨(paper_theorem7_bstar_bid model.value
            (fun j =>
              paper_theorem7_ranked_vcg_tail_payment
                model.value model.clickThroughRate j (model.remaining + 1))
