ranked-`B*` outcome boundary. Instead of assuming componentwise equality to the
VCG outcome, this records that the named generalized-English outcome and the
VCG outcome both equal the canonical ranked `B*` outcome.
-/
structure PaperTheorem8BStarRankedThresholdLocalOptimalityDynamicGameConstructedOutcomeCertificate
    (Belief : Type*) where
  game :
    PaperTheorem8GeneralizedEnglishDynamicGame
      ℕ ℕ (PaperTheorem8GeneralizedEnglishStrategy ℕ) Belief
  localModel : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate
  game_click_eq :
    ∀ rank,
      game.environment.clickThroughRate rank =
        localModel.clickThroughRate rank
  game_value_eq :
    ∀ rank, game.values rank = localModel.value rank
  belief : Belief
  equilibrium_consistent :
    game.isConsistentBelief
      (paper_theorem8_bstar_ranked_threshold_strategy
        localModel.value localModel.clickThroughRate localModel.remaining)
      belief
  local_optimality_implies_sequential_rationality :
    paper_theorem8_bstar_ranked_threshold_local_optimality_statement
        localModel.clickThroughRate localModel.value localModel.remaining →
      game.isSequentiallyRational
        (paper_theorem8_bstar_ranked_threshold_strategy
          localModel.value localModel.clickThroughRate localModel.remaining)
        belief
  pbe_bstar_threshold_characterization :
    ∀ strategy,
      game.PerfectBayesianEquilibrium strategy →
        ∀ state rank,
          strategy state rank ↔
            paper_theorem8_bstar_threshold_bid
              localModel.value localModel.clickThroughRate
              (localModel.remaining + 1) (rank + 1) ≤ state.clockPrice
  named_strategy_outcome_eq_bstar :
    game.outcomeOf
        (paper_theorem8_bstar_ranked_threshold_strategy
          localModel.value localModel.clickThroughRate localModel.remaining) =
      paper_theorem8_bstar_ranked_threshold_outcome
        localModel.value localModel.clickThroughRate localModel.remaining
  vcg_outcome_eq_bstar :
    game.vcgOutcome =
      paper_theorem8_bstar_ranked_threshold_outcome
        localModel.value localModel.clickThroughRate localModel.remaining

