  equilibrium_same_slots_as_vcg := model.equilibrium_same_slots_as_vcg
  equilibrium_same_payments_as_vcg := model.equilibrium_same_payments_as_vcg

/--
The sequential-rationality source certificate derives the one-step/tie-break
dynamic certificate by unpacking the sequential-rationality witness inside the
abstract PBE predicate.
-/
def paper_theorem8_bstar_ranked_threshold_one_step_tie_break_extensional_outcome_certificate_of_sequential_rationality
    {Belief : Type*}
    (model :
      PaperTheorem8BStarRankedThresholdSequentialRationalityDynamicGameExtensionalOutcomeCertificate
        Belief) :
    PaperTheorem8BStarRankedThresholdOneStepTieBreakDynamicGameExtensionalOutcomeCertificate
      Belief where
  game := model.game
  localModel := model.localModel
  game_click_eq := model.game_click_eq
  game_value_eq := model.game_value_eq
  belief := model.belief
  equilibrium_consistent := model.equilibrium_consistent
  one_step_best_response_implies_sequential_rationality :=
    model.one_step_best_response_implies_sequential_rationality
  pbe_one_step_best_response := by
    intro strategy hpbe
    rcases hpbe with ⟨belief, _hconsistent, hsequential⟩
    exact
      model.sequential_rationality_implies_one_step_best_response
        strategy belief hsequential
  pbe_drop_at_threshold := by
    intro strategy hpbe
    rcases hpbe with ⟨belief, _hconsistent, hsequential⟩
    exact
      model.sequential_rationality_implies_drop_at_threshold
        strategy belief hsequential
  equilibrium_same_slots_as_vcg := model.equilibrium_same_slots_as_vcg
  equilibrium_same_payments_as_vcg := model.equilibrium_same_payments_as_vcg

/--
The one-step/tie-breaking dynamic-game certificate forgets to the one-step
best-response dynamic certificate by deriving the full finite `B*` cutoff rule
for every PBE from local best response plus at-threshold tie-breaking.
-/
def paper_theorem8_bstar_ranked_threshold_one_step_best_response_extensional_outcome_certificate_of_tie_break
    {Belief : Type*}
    (model :
