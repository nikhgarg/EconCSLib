-/
theorem paper_theorem8_bstar_ranked_threshold_terminal_history_behavior_paper_conclusion
    (cert :
      PaperTheorem8BStarRankedThresholdTerminalHistoryBehaviorCertificate) :
    (∀ rank,
      cert.finalState.IsActive rank ↔
