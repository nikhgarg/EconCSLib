/--
An exact finite-`B*` schedule cannot schedule a rank whose dropout record was
already present in the initial state. This is the concrete no-re-drop invariant
for exact generalized-English histories.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_not_mem_of_initial_some
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {ranks : List ℕ}
    (hsched :
      PaperTheorem8BStarRankedThresholdExactDropSchedule
        model state ranks finalState)
    {rank : ℕ} {price : ℝ}
    (hdropped : state.lastDropout rank = some price) :
    rank ∉ ranks := by
  revert rank price
  induction hsched with
  | nil state =>
      intro rank price hdropped hrank
      simpa using hrank
  | @cons state0 finalState0 dropped tail hclock hactive htail ih =>
      intro rank price hdropped hrank
      simp only [List.mem_cons] at hrank
      rcases hrank with hsame | htail_mem
      · subst dropped
        have hnone : state0.lastDropout rank = none := by
          simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive] using
            hactive
        rw [hdropped] at hnone
        cases hnone
      · have hne : rank ≠ dropped := by
          intro hsame
          subst dropped
          have hnone : state0.lastDropout rank = none := by
            simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive] using
              hactive
          rw [hdropped] at hnone
          cases hnone
        have hmid_dropped :
            (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
              (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state0
                (paper_theorem8_bstar_threshold_bid
                  model.value model.clickThroughRate (model.remaining + 1)
                  (dropped + 1)))
              dropped).lastDropout rank = some price := by
          simpa [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
            PaperTheorem8GeneralizedEnglishAuctionState.advanceClock, hne]
            using hdropped
        exact ih hmid_dropped htail_mem

/--
Every exact finite-`B*` schedule is duplicate-free. The active-rank premise in
the schedule constructor, together with persistence of dropout records, rules
out dropping the same rank twice.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_nodup
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {ranks : List ℕ}
    (hsched :
      PaperTheorem8BStarRankedThresholdExactDropSchedule
        model state ranks finalState) :
    ranks.Nodup := by
  induction hsched with
  | nil state =>
      exact List.nodup_nil
  | @cons state0 finalState0 dropped tail hclock hactive htail ih =>
      have hmid_record :
          (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
            (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state0
              (paper_theorem8_bstar_threshold_bid
                model.value model.clickThroughRate (model.remaining + 1)
                (dropped + 1)))
            dropped).lastDropout dropped =
            some
              (paper_theorem8_bstar_threshold_bid
                model.value model.clickThroughRate (model.remaining + 1)
                (dropped + 1)) := by
        simp [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
          PaperTheorem8GeneralizedEnglishAuctionState.advanceClock]
      have hnot_tail :
          dropped ∉ tail :=
        paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_not_mem_of_initial_some
          model htail hmid_record
      exact List.nodup_cons.mpr ⟨hnot_tail, ih⟩

/--
Ranks absent from an exact finite-`B*` schedule keep exactly their initial
dropout records. This is stronger than the active-rank corollary and is the
record-level form needed by concrete terminal-history audits.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_lastDropout_eq_initial_of_not_mem
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {ranks : List ℕ}
    (hsched :
      PaperTheorem8BStarRankedThresholdExactDropSchedule
        model state ranks finalState) :
    ∀ rank,
      rank ∉ ranks →
        finalState.lastDropout rank = state.lastDropout rank := by
  induction hsched with
  | nil state =>
      intro rank hnot_mem
      rfl
  | @cons state0 finalState0 dropped tail hclock hactive htail ih =>
      intro rank hnot_mem
      have hne : rank ≠ dropped := by
        intro hsame
        exact hnot_mem (by simp [hsame])
      have hnot_tail : rank ∉ tail := by
        intro htail_mem
        exact hnot_mem (by simp [htail_mem])
      have htail_eq :
          finalState0.lastDropout rank =
            (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
              (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state0
                (paper_theorem8_bstar_threshold_bid
                  model.value model.clickThroughRate (model.remaining + 1)
                  (dropped + 1)))
              dropped).lastDropout rank :=
        ih rank hnot_tail
      have hmid_eq :
          (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
            (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state0
              (paper_theorem8_bstar_threshold_bid
                model.value model.clickThroughRate (model.remaining + 1)
                (dropped + 1)))
            dropped).lastDropout rank =
            state0.lastDropout rank := by
        simp [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
          PaperTheorem8GeneralizedEnglishAuctionState.advanceClock, hne]
      exact htail_eq.trans hmid_eq

/--
Record-level characterization for deterministic sorted exact-drop schedules:
scheduled ranks have their exact finite-`B*` threshold record, while
unscheduled ranks keep their initial record.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state_records_of_clock_sorted_nodup
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (ranks : List ℕ)
    (hsorted :
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted
        model state.clockPrice ranks)
    (hnodup : ranks.Nodup)
    (hinitial_active : ∀ rank, rank ∈ ranks → state.IsActive rank) :
    (∀ rank,
      rank ∈ ranks →
        (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
          model state ranks).lastDropout rank =
          some
            (paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1))) ∧
      (∀ rank,
        rank ∉ ranks →
          (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
            model state ranks).lastDropout rank =
            state.lastDropout rank) := by
  let hsched :=
    paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_of_clock_sorted_nodup
      model state ranks hsorted hnodup hinitial_active
  constructor
  · intro rank hrank
    exact
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_terminal_record_eq_threshold_of_mem
        model hsched rank hrank
  · intro rank hnot_mem
    exact
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_lastDropout_eq_initial_of_not_mem
        model hsched rank hnot_mem

/--
If unscheduled ranks already carry their exact finite-`B*` dropout records in
the initial state, then a sorted no-duplicate exact-drop schedule gives exact
finite-`B*` records for every rank in the deterministic final state.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state_all_records_eq_thresholds_of_clock_sorted_nodup_of_initial_unscheduled_records
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (ranks : List ℕ)
    (hsorted :
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted
        model state.clockPrice ranks)
    (hnodup : ranks.Nodup)
    (hinitial_active : ∀ rank, rank ∈ ranks → state.IsActive rank)
    (hunscheduled_initial_records :
      ∀ rank,
        rank ∉ ranks →
          state.lastDropout rank =
            some
              (paper_theorem8_bstar_threshold_bid
                model.value model.clickThroughRate (model.remaining + 1)
                (rank + 1))) :
    ∀ rank,
      (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
        model state ranks).lastDropout rank =
        some
          (paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1)) := by
  have hrecords :=
    paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state_records_of_clock_sorted_nodup
      model state ranks hsorted hnodup hinitial_active
  intro rank
  by_cases hrank : rank ∈ ranks
  · exact hrecords.1 rank hrank
  · rw [hrecords.2 rank hrank, hunscheduled_initial_records rank hrank]

/--
Exact initial records on unscheduled ranks close the deterministic finite
schedule to the full constructed ranked-`B*` terminal-record outcome.
