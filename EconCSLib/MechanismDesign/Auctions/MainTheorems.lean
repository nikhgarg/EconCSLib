/--
Under strict ordered Theorem 8 assumptions, the cold-start state is a formal
`StrategyTerminal` state for the finite-`B*` ranked-threshold strategy: every
rank remains active and, at clock `-1`, no active rank is prescribed to drop
because the clock is below its nonnegative finite-`B*` threshold bid. This is a
quiescent reduced-form terminal witness, not a source auction-completion
history.
-/
noncomputable def paper_theorem8_bstar_ranked_threshold_strict_ordered_cold_start_terminal_history_behavior_certificate
    (model :
      PaperTheorem8BStarRankedThresholdStrictOrderedLocalOptimalityCertificate) :
    PaperTheorem8BStarRankedThresholdTerminalHistoryBehaviorCertificate where
  localModel :=
    paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
      (paper_theorem8_bstar_ranked_threshold_strict_local_optimality_certificate_of_strict_ordered
        model)
  initialState := paper_theorem8_bstar_ranked_threshold_cold_start_state
  finalState := paper_theorem8_bstar_ranked_threshold_cold_start_state
  history := by
    exact PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.refl _
  terminal := by
    intro rank _hactive
    have hthreshold_nonneg :
        0 ≤
          paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) := by
      simpa [paper_theorem8_bstar_ranked_threshold_outcome] using
        (paper_theorem8_bstar_ranked_threshold_outcome_payment_nonneg_of_ordered
          (value := model.value) (clickThroughRate := model.clickThroughRate)
          (remaining := model.remaining + 1) (i := rank)
          model.value_nonneg
          (fun i => le_of_lt (model.current_lt i))
          model.click_pos)
    have hclock_lt :
        paper_theorem8_bstar_ranked_threshold_cold_start_state.clockPrice <
          paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) := by
      dsimp [paper_theorem8_bstar_ranked_threshold_cold_start_state]
      linarith
    have hnot_drop :
        ¬ paper_theorem8_bstar_ranked_threshold_strategy
            model.value model.clickThroughRate model.remaining
            paper_theorem8_bstar_ranked_threshold_cold_start_state rank :=
      (paper_theorem8_bstar_ranked_threshold_strategy_not_drop_iff_clock_lt_threshold_bid
        model.value model.clickThroughRate
        paper_theorem8_bstar_ranked_threshold_cold_start_state rank
        model.remaining
        (ne_of_gt (model.click_pos rank))
        (ne_of_gt (model.click_pos (rank + 1)))).mpr hclock_lt
    simpa
      [paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict,
        paper_theorem8_bstar_ranked_threshold_strict_local_optimality_certificate_of_strict_ordered]
      using hnot_drop
  initially_active := by
    intro rank
    rfl

