/--
Finite completed-rank version for exact terminal histories: on any completed
rank, every PBE in the terminal-record local-deviation game has the same slot
and payment as the successor-tail ranked `B*`/VCG target. This avoids requiring
all ambient natural-number ranks to be terminal-inactive.
-/
theorem paper_theorem8_bstar_ranked_threshold_terminal_record_local_deviation_dynamic_game_pbe_completed_rank_slot_payment_eq_vcg_of_exact_history
    (terminal :
      PaperTheorem8BStarRankedThresholdTerminalHistoryBehaviorCertificate)
    (exact_history :
      PaperTheorem8BStarRankedThresholdExactDropHistory
        terminal.localModel terminal.initialState terminal.finalState)
    (completedRanks : Finset ℕ)
    (inactive_on_completed :
      ∀ rank, rank ∈ completedRanks → ¬ terminal.finalState.IsActive rank)
    {strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ}
    (_hpbe :
      (paper_theorem8_bstar_ranked_threshold_terminal_record_local_deviation_dynamic_game
        terminal).PerfectBayesianEquilibrium strategy)
    {rank : ℕ} (hrank : rank ∈ completedRanks) :
    let G :=
      paper_theorem8_bstar_ranked_threshold_terminal_record_local_deviation_dynamic_game
        terminal
    (G.outcomeOf strategy).slotOf rank = G.vcgOutcome.slotOf rank ∧
      (G.outcomeOf strategy).paymentPerClick rank =
        G.vcgOutcome.paymentPerClick rank := by
  dsimp
  have hrecord :
      terminal.finalState.lastDropout rank =
        some
          (paper_theorem8_bstar_threshold_bid
            terminal.localModel.value terminal.localModel.clickThroughRate
            (terminal.localModel.remaining + 1) (rank + 1)) :=
    paper_theorem8_bstar_ranked_threshold_exact_drop_history_final_record_eq_threshold
      terminal.localModel exact_history (terminal.initially_active rank)
      (inactive_on_completed rank hrank)
  constructor
  · rfl
  · simp [paper_theorem8_bstar_ranked_threshold_terminal_record_local_deviation_dynamic_game,
      paper_theorem8_terminal_dropout_record_outcome,
      paper_theorem8_bstar_ranked_threshold_outcome, hrecord]

