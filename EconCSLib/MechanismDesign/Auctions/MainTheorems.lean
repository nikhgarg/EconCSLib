/--
Forgets no-overshoot annotations from the terminal history while preserving
the integrated strict ordered terminal/dynamic certificate.
-/
def paper_theorem8_bstar_ranked_threshold_strict_ordered_no_overshoot_terminal_dynamic_certificate_to_terminal_dynamic_certificate
    {Belief : Type*}
    (cert :
      PaperTheorem8BStarRankedThresholdStrictOrderedNoOvershootTerminalDynamicCertificate
        Belief) :
    PaperTheorem8BStarRankedThresholdStrictOrderedTerminalDynamicCertificate
      Belief where
  terminal :=
    paper_theorem8_bstar_ranked_threshold_no_overshoot_terminal_history_behavior_certificate_to_terminal_history_behavior_certificate
      cert.terminal
  dynamic := cert.dynamic
  localModel_eq := cert.localModel_eq

/--
Obligation ledger for strict ordered no-overshoot terminal/dynamic
certificates: the terminal side carries an annotated finite history, and that
history derives both the ordinary named-strategy history and exact finite `B*`
dropout history before the certificate is forgotten to the ordinary integrated
source boundary.
-/
theorem paper_theorem8_bstar_ranked_threshold_strict_ordered_no_overshoot_terminal_dynamic_history_obligations
    {Belief : Type*}
    (cert :
      PaperTheorem8BStarRankedThresholdStrictOrderedNoOvershootTerminalDynamicCertificate
        Belief) :
    PaperTheorem8BStarRankedThresholdNoOvershootStrategyHistory
        cert.terminal.localModel cert.terminal.initialState
        cert.terminal.finalState ∧
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          cert.terminal.localModel.value cert.terminal.localModel.clickThroughRate
          cert.terminal.localModel.remaining)
        cert.terminal.initialState cert.terminal.finalState ∧
        PaperTheorem8BStarRankedThresholdExactDropHistory
          cert.terminal.localModel cert.terminal.initialState
          cert.terminal.finalState := by
  exact
    ⟨cert.terminal.history,
      paper_theorem8_bstar_ranked_threshold_no_overshoot_strategy_history_to_strategy_history
        cert.terminal.localModel cert.terminal.history,
      paper_theorem8_bstar_ranked_threshold_no_overshoot_strategy_history_to_exact_drop_history
        cert.terminal.localModel cert.terminal.history⟩

/--
Build the integrated strict ordered terminal-dynamic certificate from a strict
ordered dynamic-game certificate and a clock-sorted finite exact-drop schedule.
The terminal history is generated from the schedule; the only terminality check
left to the caller is that unscheduled ranks have finite `B*` thresholds above
the deterministic final clock.
-/
noncomputable def paper_theorem8_bstar_ranked_threshold_strict_ordered_terminal_dynamic_certificate_of_clock_sorted_nodup_unscheduled_threshold_gt
    {Belief : Type*}
    (dynamic :
      PaperTheorem8BStarRankedThresholdStrictOrderedDynamicGameConstructedOutcomeCertificate
        Belief)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (ranks : List ℕ)
    (hsorted :
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted
        (paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
          dynamic.base.strictModel)
        state.clockPrice ranks)
    (hnodup : ranks.Nodup)
    (hinitial_active : ∀ rank, state.IsActive rank)
    (hunscheduled :
      ∀ rank,
        rank ∉ ranks →
          (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
            (paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
              dynamic.base.strictModel)
            state ranks).clockPrice <
            paper_theorem8_bstar_threshold_bid
              dynamic.base.strictModel.value
              dynamic.base.strictModel.clickThroughRate
              (dynamic.base.strictModel.remaining + 1)
              (rank + 1)) :
    PaperTheorem8BStarRankedThresholdStrictOrderedTerminalDynamicCertificate
      Belief where
  terminal :=
    paper_theorem8_bstar_ranked_threshold_terminal_history_behavior_certificate_of_clock_sorted_nodup_unscheduled_threshold_gt
      (paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
        dynamic.base.strictModel)
      state ranks hsorted hnodup hinitial_active
      (by
        intro rank hnot_mem
        simpa [paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict]
          using hunscheduled rank hnot_mem)
  dynamic := dynamic
  localModel_eq := rfl

/--
No-overshoot version of the integrated strict ordered terminal-dynamic
certificate from clock-sorted no-duplicate schedule data. The generated
terminal history retains local no-overshoot annotations for each scheduled
dropout.
-/
noncomputable def paper_theorem8_bstar_ranked_threshold_strict_ordered_no_overshoot_terminal_dynamic_certificate_of_clock_sorted_nodup_unscheduled_threshold_gt
    {Belief : Type*}
    (dynamic :
      PaperTheorem8BStarRankedThresholdStrictOrderedDynamicGameConstructedOutcomeCertificate
        Belief)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (ranks : List ℕ)
    (hsorted :
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted
        (paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
          dynamic.base.strictModel)
        state.clockPrice ranks)
    (hnodup : ranks.Nodup)
    (hinitial_active : ∀ rank, state.IsActive rank)
    (hunscheduled :
      ∀ rank,
        rank ∉ ranks →
          (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
            (paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
              dynamic.base.strictModel)
            state ranks).clockPrice <
            paper_theorem8_bstar_threshold_bid
              dynamic.base.strictModel.value
              dynamic.base.strictModel.clickThroughRate
              (dynamic.base.strictModel.remaining + 1)
              (rank + 1)) :
    PaperTheorem8BStarRankedThresholdStrictOrderedNoOvershootTerminalDynamicCertificate
      Belief where
  terminal :=
    paper_theorem8_bstar_ranked_threshold_no_overshoot_terminal_history_behavior_certificate_of_clock_sorted_nodup_unscheduled_threshold_gt
      (paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
        dynamic.base.strictModel)
      state ranks hsorted hnodup hinitial_active
      (by
        intro rank hnot_mem
        simpa [paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict]
          using hunscheduled rank hnot_mem)
  dynamic := dynamic
  localModel_eq := rfl

/--
Field-level model agreement exposed by the integrated strict ordered
terminal-dynamic certificate. This is a human-audit helper: the abstract
certificate equality is projected to values, click-through rates, and remaining
slots.
-/
theorem paper_theorem8_bstar_ranked_threshold_strict_ordered_terminal_dynamic_model_fields_eq
    {Belief : Type*}
    (cert :
      PaperTheorem8BStarRankedThresholdStrictOrderedTerminalDynamicCertificate
        Belief) :
    (∀ rank,
      cert.terminal.localModel.value rank =
        cert.dynamic.base.strictModel.value rank) ∧
      (∀ rank,
        cert.terminal.localModel.clickThroughRate rank =
          cert.dynamic.base.strictModel.clickThroughRate rank) ∧
        cert.terminal.localModel.remaining =
          cert.dynamic.base.strictModel.remaining := by
  constructor
  · intro rank
    have h :=
      congrArg
        (fun model :
          PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate =>
            model.value rank)
        cert.localModel_eq
    simpa [paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict] using
      h.symm
  constructor
  · intro rank
    have h :=
      congrArg
        (fun model :
          PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate =>
            model.clickThroughRate rank)
        cert.localModel_eq
    simpa [paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict] using
      h.symm
  · have h :=
      congrArg
        (fun model :
          PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate =>
            model.remaining)
        cert.localModel_eq
    simpa [paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict] using
      h.symm

/--
Field-level model agreement for no-overshoot integrated terminal/dynamic
certificates.
-/
theorem paper_theorem8_bstar_ranked_threshold_strict_ordered_no_overshoot_terminal_dynamic_model_fields_eq
    {Belief : Type*}
    (cert :
      PaperTheorem8BStarRankedThresholdStrictOrderedNoOvershootTerminalDynamicCertificate
        Belief) :
    (∀ rank,
      cert.terminal.localModel.value rank =
        cert.dynamic.base.strictModel.value rank) ∧
      (∀ rank,
        cert.terminal.localModel.clickThroughRate rank =
          cert.dynamic.base.strictModel.clickThroughRate rank) ∧
        cert.terminal.localModel.remaining =
          cert.dynamic.base.strictModel.remaining := by
  exact
    paper_theorem8_bstar_ranked_threshold_strict_ordered_terminal_dynamic_model_fields_eq
      (paper_theorem8_bstar_ranked_threshold_strict_ordered_no_overshoot_terminal_dynamic_certificate_to_terminal_dynamic_certificate
        cert)

/--
Strict constructed-outcome dynamic-game certificates transfer the ordered
constructed ranked-`B*` outcome conclusion to the certificate's VCG outcome.
-/
theorem paper_theorem8_bstar_ranked_threshold_strict_constructed_certificate_vcg_outcome_ordered_paper_conclusion
    {Belief : Type*}
    (cert :
      PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameConstructedOutcomeCertificate
        Belief)
    (hvalue_nonneg : ∀ i, 0 ≤ cert.strictModel.value i)
    (hvalue_mono :
      ∀ i, cert.strictModel.value (i + 1) ≤ cert.strictModel.value i)
    (hclick_mono :
      ∀ i, cert.strictModel.clickThroughRate (i + 1) ≤
        cert.strictModel.clickThroughRate i)
    (hclick_pos : ∀ i, 0 < cert.strictModel.clickThroughRate i) :
    (∀ rank, cert.game.vcgOutcome.slotOf rank = some rank) ∧
      (∀ rank,
        cert.game.vcgOutcome.paymentPerClick rank =
          paper_theorem8_bstar_threshold_bid
            cert.strictModel.value cert.strictModel.clickThroughRate
            cert.strictModel.remaining (rank + 1)) ∧
        (∀ rank,
          cert.strictModel.clickThroughRate rank *
              cert.game.vcgOutcome.paymentPerClick rank =
            paper_theorem7_ranked_vcg_tail_payment
              cert.strictModel.value cert.strictModel.clickThroughRate rank
              cert.strictModel.remaining) ∧
          (∀ rank,
            0 ≤ cert.game.vcgOutcome.paymentPerClick rank ∧
            cert.game.vcgOutcome.paymentPerClick rank ≤
              cert.strictModel.value rank) ∧
            cert.game.vcgOutcome.IndividuallyRational
              ({ clickThroughRate := cert.strictModel.clickThroughRate } :
                PositionEnvironment ℕ)
              cert.strictModel.value ∧
              paper_position_no_positive_transfers cert.game.vcgOutcome := by
  simpa [cert.vcg_outcome_eq_bstar] using
    paper_theorem8_bstar_ranked_threshold_constructed_outcome_ordered_paper_conclusion
      (value := cert.strictModel.value)
      (clickThroughRate := cert.strictModel.clickThroughRate)
      (remaining := cert.strictModel.remaining)
      hvalue_nonneg hvalue_mono hclick_mono hclick_pos

/--
Strict constructed-outcome dynamic-game certificates transfer the ordered
constructed ranked-`B*` outcome conclusion to the named finite-`B*` strategy
outcome.
-/
theorem paper_theorem8_bstar_ranked_threshold_strict_constructed_certificate_named_strategy_outcome_ordered_paper_conclusion
    {Belief : Type*}
    (cert :
      PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameConstructedOutcomeCertificate
        Belief)
    (hvalue_nonneg : ∀ i, 0 ≤ cert.strictModel.value i)
    (hvalue_mono :
      ∀ i, cert.strictModel.value (i + 1) ≤ cert.strictModel.value i)
    (hclick_mono :
      ∀ i, cert.strictModel.clickThroughRate (i + 1) ≤
        cert.strictModel.clickThroughRate i)
    (hclick_pos : ∀ i, 0 < cert.strictModel.clickThroughRate i) :
    (∀ rank,
      (cert.game.outcomeOf
        (paper_theorem8_bstar_ranked_threshold_strategy
          cert.strictModel.value cert.strictModel.clickThroughRate
          cert.strictModel.remaining)).slotOf rank = some rank) ∧
      (∀ rank,
        (cert.game.outcomeOf
          (paper_theorem8_bstar_ranked_threshold_strategy
            cert.strictModel.value cert.strictModel.clickThroughRate
            cert.strictModel.remaining)).paymentPerClick rank =
          paper_theorem8_bstar_threshold_bid
            cert.strictModel.value cert.strictModel.clickThroughRate
            cert.strictModel.remaining (rank + 1)) ∧
        (∀ rank,
          cert.strictModel.clickThroughRate rank *
              (cert.game.outcomeOf
                (paper_theorem8_bstar_ranked_threshold_strategy
                  cert.strictModel.value cert.strictModel.clickThroughRate
                  cert.strictModel.remaining)).paymentPerClick rank =
            paper_theorem7_ranked_vcg_tail_payment
              cert.strictModel.value cert.strictModel.clickThroughRate rank
              cert.strictModel.remaining) ∧
          (∀ rank,
            0 ≤
              (cert.game.outcomeOf
                (paper_theorem8_bstar_ranked_threshold_strategy
                  cert.strictModel.value cert.strictModel.clickThroughRate
                  cert.strictModel.remaining)).paymentPerClick rank ∧
            (cert.game.outcomeOf
              (paper_theorem8_bstar_ranked_threshold_strategy
                cert.strictModel.value cert.strictModel.clickThroughRate
                cert.strictModel.remaining)).paymentPerClick rank ≤
              cert.strictModel.value rank) ∧
            (cert.game.outcomeOf
              (paper_theorem8_bstar_ranked_threshold_strategy
                cert.strictModel.value cert.strictModel.clickThroughRate
                cert.strictModel.remaining)).IndividuallyRational
              ({ clickThroughRate := cert.strictModel.clickThroughRate } :
                PositionEnvironment ℕ)
              cert.strictModel.value ∧
              paper_position_no_positive_transfers
                (cert.game.outcomeOf
                  (paper_theorem8_bstar_ranked_threshold_strategy
                    cert.strictModel.value cert.strictModel.clickThroughRate
                    cert.strictModel.remaining)) := by
  simpa [cert.named_strategy_outcome_eq_bstar] using
    paper_theorem8_bstar_ranked_threshold_constructed_outcome_ordered_paper_conclusion
      (value := cert.strictModel.value)
