theorem paper_theorem7_ordered_ranked_canonical_tail_vcg_equivalent_locally_envy_free
    {n : ℕ} (model : PaperTheorem7OrderedRankedCanonicalTailCertificate n) :
    ∃ O : PositionOutcome (Fin n) (Fin n),
