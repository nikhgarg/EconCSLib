theorem paper_theorem8_bstar_ranked_threshold_strict_ordered_terminal_dynamic_pbe_terminal_behavior_with_records
    {Belief : Type*}
    (cert :
      PaperTheorem8BStarRankedThresholdStrictOrderedTerminalDynamicCertificate
        Belief)
