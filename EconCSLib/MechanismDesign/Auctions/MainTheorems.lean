/-- The finite value profile agrees with the paper's indexed value sequence. -/
theorem paper_eos_running_example_values3_eq_indexed (i : Fin 3) :
    paper_eos_running_example_values3 i =
      paper_eos_running_example_value i.val := by
  fin_cases i <;> norm_num [paper_eos_running_example_values3,
    paper_eos_running_example_value]

/-- Bidder-`0` explicit deviation profile equals the corresponding update. -/
theorem paper_eos_running_example_bidder0Report_eq_update (report : ℝ) :
    paper_eos_running_example_bidder0Report report =
      Function.update paper_eos_running_example_values3 (0 : Fin 3) report := by
  funext i
  fin_cases i <;> simp [paper_eos_running_example_bidder0Report,
    paper_eos_running_example_values3, Function.update]

/-- Bidder-`1` explicit deviation profile equals the corresponding update. -/
