        (value := model.value) (clickThroughRate := model.clickThroughRate)
        (remaining := model.remaining + 1)
        hvalue_nonneg hvalue_mono (fun i => le_of_lt (hclick_pos i))
        hclick_pos rank)
  exact
    ⟨paper_theorem8_terminal_dropout_record_outcome_slotOf finalState rank,
      hpay, by rw [hpay]; exact htotal, hpay_nonneg, hpay_le_value⟩

