/--
In a finite-`B*` exact-drop history, if a rank starts active and is inactive at
the final state, its terminal dropout record is exactly its finite-`B*`
threshold bid.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_history_final_record_eq_threshold
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (hhist :
      PaperTheorem8BStarRankedThresholdExactDropHistory model state finalState)
    {rank : ℕ}
    (hinitial_active : state.IsActive rank)
    (hfinal_inactive : ¬ finalState.IsActive rank) :
    finalState.lastDropout rank =
      some
        (paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (rank + 1)) := by
  induction hhist with
  | refl state =>
      exact False.elim (hfinal_inactive hinitial_active)
  | @advance state0 finalState0 newPrice hclock htail ih =>
      exact
        ih
          (by
            simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive,
              PaperTheorem8GeneralizedEnglishAuctionState.advanceClock] using
              hinitial_active)
          hfinal_inactive
  | @dropout state0 finalState0 dropped hactive hclock htail ih =>
      by_cases hsame : rank = dropped
      · subst dropped
        have hmid_record :
            (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
              state0 rank).lastDropout rank =
              some state0.clockPrice := by
          simp [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout]
        have htail_history :
            PaperTheorem8GeneralizedEnglishAuctionState.History
              (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
                state0 rank)
              finalState0 :=
          (paper_theorem8_bstar_ranked_threshold_exact_drop_history_to_strategy_history
            model htail).toHistory
        have hfinal_record :=
          PaperTheorem8GeneralizedEnglishAuctionState.History_lastDropout_eq_of_initial_some
            htail_history hmid_record
        simpa [hclock] using hfinal_record
      · have hmid_active :
            (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
              state0 dropped).IsActive rank := by
          simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive,
            PaperTheorem8GeneralizedEnglishAuctionState.recordDropout, hsame]
            using hinitial_active
        exact ih hmid_active hfinal_inactive

