        (∀ i, O.slotOf i = model.vcgOutcome.slotOf i) ∧
        (∀ i, O.paymentPerClick i = model.vcgOutcome.paymentPerClick i) ∧
        ∀ other : PositionOutcome (Fin n) (Fin n),
