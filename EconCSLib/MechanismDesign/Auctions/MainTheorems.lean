          other.FeasibleAssignment →
          other.IndividuallyRational
            (paper_theorem7_ranked_environment model.clickThroughRate)
            (fun i : Fin n => model.value i.val) →
          other.SlotEnvyFree
            (paper_theorem7_ranked_environment model.clickThroughRate)
            (fun i : Fin n => model.value i.val) →
            (∀ i, O.slotOf i = other.slotOf i) →
              O.revenue
                  (paper_theorem7_ranked_environment model.clickThroughRate) ≤
                other.revenue
                  (paper_theorem7_ranked_environment model.clickThroughRate) := by
  let finiteTailModel :
      PaperTheorem7OrderedRankedFiniteTailCertificate n :=
    { value := model.value
      vcgTotalPayment := model.vcgTotalPayment
      clickThroughRate := model.clickThroughRate
      vcgOutcome := model.vcgOutcome
      click_nonneg := model.click_nonneg
      click_pos := model.click_pos
      click_mono := model.click_mono
      value_mono := model.value_mono
      vcg_rec := model.vcg_rec
      payment_le_value := model.payment_le_value
      tailRemaining := paper_theorem7_ranked_canonical_tail_remaining
      tail_bound := paper_theorem7_ranked_canonical_tail_remaining_bound
      vcg_tail_eq := model.vcg_tail_eq
      terminal_total_nonneg := model.terminal_total_nonneg
      same_slots_as_vcg := model.same_slots_as_vcg
      same_payments_as_vcg := model.same_payments_as_vcg }
  exact
    paper_theorem7_ordered_ranked_finite_tail_vcg_equivalent_locally_envy_free
      finiteTailModel

/--
Paper-facing ordered ranked certificate for EOS Theorem 7 with canonical
finite-tail lengths and nonnegative comparison payments. This removes the raw
terminal total-payment nonnegativity field and replaces it with the usual
per-click payment nonnegativity condition for each stable comparison outcome.
-/
structure PaperTheorem7OrderedRankedCanonicalTailNonnegativePaymentCertificate
    (n : ℕ) where
  value : ℕ → ℝ
  vcgTotalPayment : ℕ → ℝ
  clickThroughRate : ℕ → ℝ
  vcgOutcome : PositionOutcome (Fin n) (Fin n)
  click_nonneg : ∀ s : Fin n, 0 ≤ clickThroughRate s.val
  click_pos : ∀ s : Fin n, 0 < clickThroughRate s.val
  click_mono : ∀ k : ℕ, clickThroughRate (k + 1) ≤ clickThroughRate k
  value_mono : ∀ a b : ℕ, a ≤ b → value b ≤ value a
  vcg_rec :
    ∀ k : ℕ,
      vcgTotalPayment k =
        (clickThroughRate k - clickThroughRate (k + 1)) * value (k + 1) +
          vcgTotalPayment (k + 1)
  payment_le_value :
    ∀ i : Fin n,
      vcgTotalPayment i.val ≤ clickThroughRate i.val * value i.val
  vcg_tail_eq :
    ∀ i : Fin n,
      vcgTotalPayment i.val =
        paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate i.val
          (paper_theorem7_ranked_canonical_tail_remaining i)
  comparison_payment_nonneg :
    ∀ other : PositionOutcome (Fin n) (Fin n),
      other.StableAssignment
          (paper_theorem7_ranked_environment clickThroughRate)
          (fun i : Fin n => value i.val) →
        (∀ i,
          (paper_theorem7_ranked_bstar_outcome
            value vcgTotalPayment clickThroughRate).slotOf i =
            other.slotOf i) →
          ∀ i : Fin n, 0 ≤ other.paymentPerClick i
  same_slots_as_vcg :
    ∀ i,
      (paper_theorem7_ranked_bstar_outcome
        value vcgTotalPayment clickThroughRate).slotOf i =
        vcgOutcome.slotOf i
  same_payments_as_vcg :
    ∀ i,
      (paper_theorem7_ranked_bstar_outcome
        value vcgTotalPayment clickThroughRate).paymentPerClick i =
        vcgOutcome.paymentPerClick i

/--
EOS Theorem 7 canonical finite-tail nonnegative-payment certificate form.
Nonnegative comparison payments imply the terminal total-payment condition used
by the finite-tail lower-bound induction, so the ranked `B*` outcome is locally
envy-free, stable, VCG-equivalent, and weakly revenue-minimal.
-/
theorem paper_theorem7_ordered_ranked_canonical_tail_nonnegative_payment_vcg_equivalent_locally_envy_free
    {n : ℕ}
    (model :
      PaperTheorem7OrderedRankedCanonicalTailNonnegativePaymentCertificate n) :
    ∃ O : PositionOutcome (Fin n) (Fin n),
      O.SlotEnvyFree
          (paper_theorem7_ranked_environment model.clickThroughRate)
          (fun i : Fin n => model.value i.val) ∧
