/--
Named proposition for the ordered strict constructed-outcome PBE conclusion.
This aliases the long one-stop theorem so later paper-facing statements can
refer to it without duplicating the full nested conjunction.
-/
def PaperTheorem8BStarRankedThresholdStrictOrderedConstructedPBEFullConclusion
    {Belief : Type*}
    (cert :
      PaperTheorem8BStarRankedThresholdStrictOrderedDynamicGameConstructedOutcomeCertificate
        Belief)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ) : Prop :=
  (∀ state rank,
    strategy state rank ↔
      paper_theorem8_bstar_threshold_bid
        cert.base.strictModel.value cert.base.strictModel.clickThroughRate
        (cert.base.strictModel.remaining + 1) (rank + 1) ≤ state.clockPrice) ∧
    (∀ state rank,
      ¬ strategy state rank ↔
        state.clockPrice <
          paper_theorem8_bstar_threshold_bid
            cert.base.strictModel.value cert.base.strictModel.clickThroughRate
            (cert.base.strictModel.remaining + 1) (rank + 1)) ∧
      (∀ state rank,
        state.clockPrice ≤
          paper_theorem8_bstar_threshold_bid
            cert.base.strictModel.value cert.base.strictModel.clickThroughRate
            cert.base.strictModel.remaining (rank + 2) →
          ¬ strategy state rank) ∧
        (∀ state rank,
          cert.base.strictModel.value (rank + 1) ≤ state.clockPrice →
            strategy state rank) ∧
          (∀ bidder,
            (cert.base.game.outcomeOf strategy).slotOf bidder =
              cert.base.game.vcgOutcome.slotOf bidder) ∧
            (∀ bidder,
              (cert.base.game.outcomeOf strategy).paymentPerClick bidder =
                cert.base.game.vcgOutcome.paymentPerClick bidder) ∧
              (∀ rank,
                (cert.base.game.outcomeOf strategy).slotOf rank = some rank) ∧
                (∀ rank,
                  (cert.base.game.outcomeOf strategy).paymentPerClick rank =
                    paper_theorem8_bstar_threshold_bid
                      cert.base.strictModel.value
                      cert.base.strictModel.clickThroughRate
                      cert.base.strictModel.remaining (rank + 1)) ∧
                  (∀ rank, cert.base.game.vcgOutcome.slotOf rank = some rank) ∧
                    (∀ rank,
                      cert.base.game.vcgOutcome.paymentPerClick rank =
                        paper_theorem8_bstar_threshold_bid
                          cert.base.strictModel.value
                          cert.base.strictModel.clickThroughRate
                          cert.base.strictModel.remaining (rank + 1)) ∧
                      (∀ rank,
                        cert.base.strictModel.clickThroughRate rank *
                            (cert.base.game.outcomeOf strategy).paymentPerClick
                              rank =
                          paper_theorem7_ranked_vcg_tail_payment
                            cert.base.strictModel.value
                            cert.base.strictModel.clickThroughRate rank
                            cert.base.strictModel.remaining) ∧
                        (∀ rank,
                          0 ≤
                            (cert.base.game.outcomeOf strategy).paymentPerClick
                              rank ∧
                          (cert.base.game.outcomeOf strategy).paymentPerClick
                              rank ≤
                            cert.base.strictModel.value rank) ∧
                          (cert.base.game.outcomeOf strategy).IndividuallyRational
                            ({ clickThroughRate :=
                                cert.base.strictModel.clickThroughRate } :
                              PositionEnvironment ℕ)
                            cert.base.strictModel.value ∧
                            paper_position_no_positive_transfers
                              (cert.base.game.outcomeOf strategy) ∧
                              cert.base.game.vcgOutcome.IndividuallyRational
                                ({ clickThroughRate :=
                                    cert.base.strictModel.clickThroughRate } :
                                  PositionEnvironment ℕ)
                                cert.base.strictModel.value ∧
                                paper_position_no_positive_transfers
                                  cert.base.game.vcgOutcome

