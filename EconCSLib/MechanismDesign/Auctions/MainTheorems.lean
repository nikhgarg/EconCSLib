  · intro state hthreshold_lt
    exact
      paper_theorem8_ranked_threshold_prefers_drop_after_bstar_bid_of_vcg_tail
        model.value model.clickThroughRate rank model.remaining
        (model.click_pos rank) (ne_of_gt (model.click_pos (rank + 1)))
        hthreshold_lt

/--
Paper-facing abbreviation for the finite `B*` threshold bid induced by a VCG
tail of length `remaining` and evaluated at click-through rate `rank`.
-/
noncomputable def paper_theorem8_bstar_threshold_bid
    (value clickThroughRate : ℕ → ℝ) (remaining rank : ℕ) : ℝ :=
  paper_theorem7_bstar_bid value
    (fun j =>
      paper_theorem7_ranked_vcg_tail_payment
        value clickThroughRate j remaining)
    clickThroughRate rank

/--
The continuation finite `B*` threshold is weakly below the current finite
`B*` dropout threshold. This is the shifted Theorem 8 bridge induced by the
Theorem 7 VCG-tail recursion: the lower adjacent slot's continuation bid from
tail length `remaining` is at most the current dropout threshold from tail
length `remaining + 1`.
-/
theorem paper_theorem8_bstar_continuation_threshold_le_current_threshold_of_ordered_tail
    {value clickThroughRate : ℕ → ℝ}
    (hvalue_nonneg : ∀ i, 0 ≤ value i)
    (hvalue_mono : ∀ i, value (i + 1) ≤ value i)
    (hclick_pos : ∀ i, 0 < clickThroughRate i)
    (hclick_mono : ∀ i, clickThroughRate (i + 1) ≤ clickThroughRate i)
    (remaining rank : ℕ) :
    paper_theorem8_bstar_threshold_bid
        value clickThroughRate remaining (rank + 2) ≤
      paper_theorem8_bstar_threshold_bid
        value clickThroughRate (remaining + 1) (rank + 1) := by
  let continuationDropout : ℕ → ℝ :=
    fun k =>
      paper_theorem7_bstar_bid value
        (fun j =>
          paper_theorem7_ranked_vcg_tail_payment
            value clickThroughRate j remaining)
        clickThroughRate (k + 2)
  have hlast :
      continuationDropout rank ≤ value (rank + 1) := by
    simpa [continuationDropout, paper_theorem8_bstar_threshold_bid] using
      paper_theorem8_bstar_continuation_bid_le_value_of_ordered_tail
        hvalue_nonneg hvalue_mono (fun i => le_of_lt (hclick_pos i))
        (hclick_pos (rank + 1))
  have hthreshold :
      continuationDropout rank ≤
        paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate continuationDropout value rank :=
    paper_theorem8_generalized_english_ranked_dropout_price_lastDropout_le
      (hclick_pos rank) (hclick_mono rank) hlast
  have hprice_eq :
      paper_theorem8_generalized_english_ranked_dropout_price
          clickThroughRate continuationDropout value rank =
        paper_theorem8_bstar_threshold_bid
          value clickThroughRate (remaining + 1) (rank + 1) := by
    simpa [continuationDropout, paper_theorem8_bstar_threshold_bid] using
      paper_theorem8_generalized_english_ranked_dropout_price_eq_bstar_bid_of_vcg_tail
        value clickThroughRate rank remaining
        (ne_of_gt (hclick_pos rank)) (ne_of_gt (hclick_pos (rank + 1)))
  simpa [continuationDropout, hprice_eq, paper_theorem8_bstar_threshold_bid] using
    hthreshold

/--
The exact finite `B*` ranked-threshold strategy used by the paper-facing
generalized-English certificate.
-/
noncomputable def paper_theorem8_bstar_ranked_threshold_strategy
    (value clickThroughRate : ℕ → ℝ) (remaining : ℕ) :
    PaperTheorem8GeneralizedEnglishStrategy ℕ :=
  paper_theorem8_ranked_threshold_dropout_strategy
    clickThroughRate
    (fun k =>
      paper_theorem8_bstar_threshold_bid
        value clickThroughRate remaining (k + 2))
    value

/--
The exact finite `B*` ranked-threshold strategy drops exactly when the clock
reaches the current finite `B*` threshold bid.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
    (value clickThroughRate : ℕ → ℝ)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (rank remaining : ℕ)
    (hclick_ne : clickThroughRate rank ≠ 0)
    (hnext_click_ne : clickThroughRate (rank + 1) ≠ 0) :
    paper_theorem8_bstar_ranked_threshold_strategy
        value clickThroughRate remaining state rank ↔
      paper_theorem8_bstar_threshold_bid
        value clickThroughRate (remaining + 1) (rank + 1) ≤
          state.clockPrice := by
  simpa [paper_theorem8_bstar_ranked_threshold_strategy,
    paper_theorem8_bstar_threshold_bid] using
    paper_theorem8_ranked_threshold_dropout_strategy_drops_iff_bstar_bid_of_vcg_tail
      value clickThroughRate state rank remaining hclick_ne hnext_click_ne

/--
The exact finite `B*` ranked-threshold strategy has not dropped exactly when
the clock is strictly below the current finite `B*` threshold bid.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_not_drop_iff_clock_lt_threshold_bid
    (value clickThroughRate : ℕ → ℝ)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (rank remaining : ℕ)
    (hclick_ne : clickThroughRate rank ≠ 0)
    (hnext_click_ne : clickThroughRate (rank + 1) ≠ 0) :
    ¬ paper_theorem8_bstar_ranked_threshold_strategy
        value clickThroughRate remaining state rank ↔
      state.clockPrice <
        paper_theorem8_bstar_threshold_bid
          value clickThroughRate (remaining + 1) (rank + 1) := by
  rw [paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
    value clickThroughRate state rank remaining hclick_ne hnext_click_ne]
  exact not_le

/--
EOS Theorem 8 exact finite-`B*` strict behavioral clock regions. The strict
certificate does not merely give nonempty clock intervals: it gives concrete
auction states before and after the finite `B*` threshold where the named
ranked-threshold strategy respectively has not dropped and has dropped.
-/
theorem paper_theorem8_bstar_ranked_threshold_strict_strategy_nonempty_behavior_regions
    (model :
      PaperTheorem8BStarRankedThresholdStrictLocalOptimalityCertificate) :
    ∀ rank,
      (∃ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
        paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate model.remaining (rank + 2) <
          state.clockPrice ∧
        state.clockPrice <
          paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) ∧
        ¬ paper_theorem8_bstar_ranked_threshold_strategy
            model.value model.clickThroughRate model.remaining state rank) ∧
      (∃ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
        paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) <
          state.clockPrice ∧
        state.clockPrice < model.value (rank + 1) ∧
        paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining state rank) := by
  intro rank
  rcases
    paper_theorem8_bstar_ranked_threshold_nonempty_clock_regions_of_certificate
      model rank with
    ⟨⟨clockBefore, hcont_lt_before, hbefore_lt_threshold⟩,
      ⟨clockAfter, hthreshold_lt_after, hafter_lt_value⟩⟩
  constructor
  · refine
      ⟨{ clockPrice := clockBefore, lastDropout := fun _ => none },
        ?_, ?_, ?_⟩
    · simpa [paper_theorem8_bstar_threshold_bid] using hcont_lt_before
    · simpa [paper_theorem8_bstar_threshold_bid] using hbefore_lt_threshold
    · exact
        (paper_theorem8_bstar_ranked_threshold_strategy_not_drop_iff_clock_lt_threshold_bid
          model.value model.clickThroughRate
          { clockPrice := clockBefore, lastDropout := fun _ => none }
          rank model.remaining
          (ne_of_gt (model.click_pos rank))
          (ne_of_gt (model.click_pos (rank + 1)))).mpr
          (by
            simpa [paper_theorem8_bstar_threshold_bid] using
              hbefore_lt_threshold)
  · refine
      ⟨{ clockPrice := clockAfter, lastDropout := fun _ => none },
        ?_, ?_, ?_⟩
    · simpa [paper_theorem8_bstar_threshold_bid] using hthreshold_lt_after
    · exact hafter_lt_value
    · exact
        (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
          model.value model.clickThroughRate
          { clockPrice := clockAfter, lastDropout := fun _ => none }
          rank model.remaining
          (ne_of_gt (model.click_pos rank))
          (ne_of_gt (model.click_pos (rank + 1)))).mpr
          (le_of_lt
            (by
              simpa [paper_theorem8_bstar_threshold_bid] using
                hthreshold_lt_after))

/--
Named statement of the exact finite-`B*` local-optimality package. This
packages the long paper-facing conclusion of
`paper_theorem8_bstar_ranked_threshold_local_optimality_of_certificate` under a
single predicate for dynamic-game certificates and audit files.
-/
def paper_theorem8_bstar_ranked_threshold_local_optimality_statement
    (clickThroughRate value : ℕ → ℝ) (remaining : ℕ) : Prop :=
  ∀ rank,
    paper_theorem8_bstar_threshold_bid value clickThroughRate remaining
        (rank + 2) ≤
      paper_theorem8_bstar_threshold_bid value clickThroughRate
        (remaining + 1) (rank + 1) ∧
    paper_theorem8_bstar_threshold_bid value clickThroughRate
        (remaining + 1) (rank + 1) ≤ value (rank + 1) ∧
    (∀ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
      state.clockPrice <
          paper_theorem8_bstar_threshold_bid value clickThroughRate remaining
            (rank + 2) →
        ¬ paper_theorem8_ranked_threshold_dropout_strategy
            clickThroughRate
            (fun k =>
              paper_theorem8_bstar_threshold_bid
                value clickThroughRate remaining (k + 2))
            value state rank) ∧
    (∀ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
      value (rank + 1) ≤ state.clockPrice →
        paper_theorem8_ranked_threshold_dropout_strategy
          clickThroughRate
          (fun k =>
            paper_theorem8_bstar_threshold_bid
              value clickThroughRate remaining (k + 2))
          value state rank) ∧
    (∀ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
      state.clockPrice =
          paper_theorem8_bstar_threshold_bid value clickThroughRate
            (remaining + 1) (rank + 1) →
        clickThroughRate rank * (value (rank + 1) - state.clockPrice) =
          clickThroughRate (rank + 1) *
            (value (rank + 1) -
              paper_theorem8_bstar_threshold_bid value clickThroughRate
                remaining (rank + 2))) ∧
    (∀ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
      state.clockPrice <
          paper_theorem8_bstar_threshold_bid value clickThroughRate
            (remaining + 1) (rank + 1) →
        clickThroughRate (rank + 1) *
            (value (rank + 1) -
              paper_theorem8_bstar_threshold_bid value clickThroughRate
                remaining (rank + 2)) <
          clickThroughRate rank * (value (rank + 1) - state.clockPrice)) ∧
    (∀ state : PaperTheorem8GeneralizedEnglishAuctionState ℕ,
      paper_theorem8_bstar_threshold_bid value clickThroughRate
          (remaining + 1) (rank + 1) < state.clockPrice →
        clickThroughRate rank * (value (rank + 1) - state.clockPrice) <
          clickThroughRate (rank + 1) *
            (value (rank + 1) -
              paper_theorem8_bstar_threshold_bid value clickThroughRate
                remaining (rank + 2)))

/-- The exact finite-`B*` local-optimality certificate proves the named
local-optimality statement. -/
theorem paper_theorem8_bstar_ranked_threshold_local_optimality_statement_of_certificate
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate) :
    paper_theorem8_bstar_ranked_threshold_local_optimality_statement
      model.clickThroughRate model.value model.remaining := by
  simpa [paper_theorem8_bstar_ranked_threshold_local_optimality_statement,
    paper_theorem8_bstar_threshold_bid] using
    paper_theorem8_bstar_ranked_threshold_local_optimality_of_certificate model

/-- The payoff from remaining active for rank `rank` at the current clock. -/
def paper_theorem8_bstar_ranked_threshold_continue_payoff
    (clickThroughRate value : ℕ → ℝ)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (rank : ℕ) : ℝ :=
  clickThroughRate rank * (value (rank + 1) - state.clockPrice)

/-- The payoff from dropping to the next rank at the continuation finite `B*`
threshold. -/
noncomputable def paper_theorem8_bstar_ranked_threshold_drop_payoff
    (clickThroughRate value : ℕ → ℝ) (remaining rank : ℕ) : ℝ :=
  clickThroughRate (rank + 1) *
    (value (rank + 1) -
      paper_theorem8_bstar_threshold_bid
        value clickThroughRate remaining (rank + 2))

/--
One-step best-response property for a finite `B*` ranked-threshold strategy:
whenever the strategy drops, dropping weakly dominates continuing at the current
clock; whenever it does not drop, continuing weakly dominates dropping to the
next rank at the continuation finite `B*` threshold.
-/
def paper_theorem8_bstar_ranked_threshold_one_step_best_response_statement
    (clickThroughRate value : ℕ → ℝ) (remaining : ℕ)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ) : Prop :=
  ∀ state rank,
    (strategy state rank →
      paper_theorem8_bstar_ranked_threshold_continue_payoff
          clickThroughRate value state rank ≤
        paper_theorem8_bstar_ranked_threshold_drop_payoff
          clickThroughRate value remaining rank) ∧
      (¬ strategy state rank →
        paper_theorem8_bstar_ranked_threshold_drop_payoff
            clickThroughRate value remaining rank ≤
          paper_theorem8_bstar_ranked_threshold_continue_payoff
            clickThroughRate value state rank)

/--
State-local one-step best-response obligation. This is the source-history
version of the global one-step predicate: at one concrete generalized-English
history state, every active rank's drop/continue action satisfies the audited
payoff comparison.
-/
def paper_theorem8_bstar_ranked_threshold_one_step_best_response_at_state
    (clickThroughRate value : ℕ → ℝ) (remaining : ℕ)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ) : Prop :=
  ∀ rank,
    (strategy state rank →
      paper_theorem8_bstar_ranked_threshold_continue_payoff
          clickThroughRate value state rank ≤
        paper_theorem8_bstar_ranked_threshold_drop_payoff
          clickThroughRate value remaining rank) ∧
      (¬ strategy state rank →
        paper_theorem8_bstar_ranked_threshold_drop_payoff
            clickThroughRate value remaining rank ≤
          paper_theorem8_bstar_ranked_threshold_continue_payoff
            clickThroughRate value state rank)

/--
The global one-step best-response predicate is exactly the requirement that the
state-local one-step condition holds at every generalized-English history
state.
-/
theorem paper_theorem8_bstar_ranked_threshold_one_step_best_response_statement_iff_forall_state
    (clickThroughRate value : ℕ → ℝ) (remaining : ℕ)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ) :
    paper_theorem8_bstar_ranked_threshold_one_step_best_response_statement
        clickThroughRate value remaining strategy ↔
      ∀ state,
        paper_theorem8_bstar_ranked_threshold_one_step_best_response_at_state
          clickThroughRate value remaining strategy state := by
  rfl

/--
The named finite `B*` ranked-threshold strategy is a one-step best response at
every state/rank under the local-optimality certificate. This packages the
paper proof's Step 1/Step 2 payoff comparisons as a reusable local
sequential-rationality seam.
-/
theorem paper_theorem8_bstar_ranked_threshold_named_strategy_one_step_best_response
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate) :
    paper_theorem8_bstar_ranked_threshold_one_step_best_response_statement
      model.clickThroughRate model.value model.remaining
      (paper_theorem8_bstar_ranked_threshold_strategy
        model.value model.clickThroughRate model.remaining) := by
  intro state rank
  have hlocal :=
    paper_theorem8_bstar_ranked_threshold_local_optimality_statement_of_certificate
      model
  rcases hlocal rank with
    ⟨_hcontinuation_le_current, _hcurrent_le_value, _hno_drop_before_continuation,
      _hdrop_after_value, hindifferent, hactive_before, hdrop_after⟩
  have hdrop_iff :=
    paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
      model.value model.clickThroughRate state rank model.remaining
      (ne_of_gt (model.click_pos rank))
      (ne_of_gt (model.click_pos (rank + 1)))
  constructor
  · intro hdrop
    have hthreshold_le : paper_theorem8_bstar_threshold_bid
        model.value model.clickThroughRate (model.remaining + 1) (rank + 1) ≤
        state.clockPrice :=
      hdrop_iff.mp hdrop
    rcases eq_or_lt_of_le hthreshold_le with hthreshold_eq | hthreshold_lt
    · have hpay_eq :=
        hindifferent state hthreshold_eq.symm
      exact
        le_of_eq
          (by
            simpa [paper_theorem8_bstar_ranked_threshold_continue_payoff,
              paper_theorem8_bstar_ranked_threshold_drop_payoff] using hpay_eq)
    · exact
        le_of_lt
          (by
            simpa [paper_theorem8_bstar_ranked_threshold_continue_payoff,
              paper_theorem8_bstar_ranked_threshold_drop_payoff] using
              hdrop_after state hthreshold_lt)
  · intro hnot_drop
    have hnot_le :
        ¬ paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) ≤ state.clockPrice := by
      intro hle
      exact hnot_drop (hdrop_iff.mpr hle)
    have hclock_lt :
        state.clockPrice <
          paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) :=
      not_le.mp hnot_le
    exact
      le_of_lt
        (by
          simpa [paper_theorem8_bstar_ranked_threshold_continue_payoff,
            paper_theorem8_bstar_ranked_threshold_drop_payoff] using
            hactive_before state hclock_lt)

/--
Off-threshold strict best-response property for a finite `B*` ranked-threshold
strategy. Strictly after the current finite `B*` threshold, dropping strictly
dominates continuing and the strategy drops; strictly before it, continuing
strictly dominates dropping and the strategy has not dropped.
-/
def paper_theorem8_bstar_ranked_threshold_off_threshold_strict_best_response_statement
    (clickThroughRate value : ℕ → ℝ) (remaining : ℕ)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ) : Prop :=
  ∀ state rank,
    (paper_theorem8_bstar_threshold_bid value clickThroughRate
          (remaining + 1) (rank + 1) < state.clockPrice →
      paper_theorem8_bstar_ranked_threshold_continue_payoff
          clickThroughRate value state rank <
        paper_theorem8_bstar_ranked_threshold_drop_payoff
          clickThroughRate value remaining rank ∧
        strategy state rank) ∧
      (state.clockPrice <
          paper_theorem8_bstar_threshold_bid value clickThroughRate
            (remaining + 1) (rank + 1) →
        paper_theorem8_bstar_ranked_threshold_drop_payoff
            clickThroughRate value remaining rank <
          paper_theorem8_bstar_ranked_threshold_continue_payoff
            clickThroughRate value state rank ∧
          ¬ strategy state rank)

/--
The named finite `B*` ranked-threshold strategy has strict local incentives on
both sides of the current finite `B*` threshold under the local-optimality
certificate. This packages the paper proof's Step 1/Step 2 strict comparisons
with the action chosen by the named strategy.
-/
theorem paper_theorem8_bstar_ranked_threshold_named_strategy_off_threshold_strict_best_response
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate) :
    paper_theorem8_bstar_ranked_threshold_off_threshold_strict_best_response_statement
      model.clickThroughRate model.value model.remaining
      (paper_theorem8_bstar_ranked_threshold_strategy
        model.value model.clickThroughRate model.remaining) := by
  intro state rank
  have hlocal :=
    paper_theorem8_bstar_ranked_threshold_local_optimality_statement_of_certificate
      model
  rcases hlocal rank with
    ⟨_hcontinuation_le_current, _hcurrent_le_value, _hno_drop_before_continuation,
      _hdrop_after_value, _hindifferent, hactive_before, hdrop_after⟩
  constructor
  · intro hthreshold_lt
    constructor
    · simpa [paper_theorem8_bstar_ranked_threshold_continue_payoff,
        paper_theorem8_bstar_ranked_threshold_drop_payoff] using
        hdrop_after state hthreshold_lt
    · exact
        (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
          model.value model.clickThroughRate state rank model.remaining
          (ne_of_gt (model.click_pos rank))
          (ne_of_gt (model.click_pos (rank + 1)))).mpr
          (le_of_lt hthreshold_lt)
  · intro hclock_lt
    constructor
    · simpa [paper_theorem8_bstar_ranked_threshold_continue_payoff,
        paper_theorem8_bstar_ranked_threshold_drop_payoff] using
        hactive_before state hclock_lt
    · exact
        (paper_theorem8_bstar_ranked_threshold_strategy_not_drop_iff_clock_lt_threshold_bid
          model.value model.clickThroughRate state rank model.remaining
          (ne_of_gt (model.click_pos rank))
          (ne_of_gt (model.click_pos (rank + 1)))).mpr
          hclock_lt

/--
Tie-breaking convention at the finite `B*` threshold: at exact indifference,
the strategy drops. This isolates the only behavioral convention not forced by
strict one-step incentives.
-/
def paper_theorem8_bstar_ranked_threshold_drop_at_threshold_statement
    (clickThroughRate value : ℕ → ℝ) (remaining : ℕ)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ) : Prop :=
  ∀ state rank,
    state.clockPrice =
      paper_theorem8_bstar_threshold_bid value clickThroughRate
        (remaining + 1) (rank + 1) →
      strategy state rank

/--
The named finite `B*` ranked-threshold strategy satisfies the paper's
drop-at-threshold tie-breaking convention.
-/
theorem paper_theorem8_bstar_ranked_threshold_named_strategy_drop_at_threshold
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate) :
    paper_theorem8_bstar_ranked_threshold_drop_at_threshold_statement
      model.clickThroughRate model.value model.remaining
      (paper_theorem8_bstar_ranked_threshold_strategy
        model.value model.clickThroughRate model.remaining) := by
  intro state rank hclock
  exact
    (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
      model.value model.clickThroughRate state rank model.remaining
      (ne_of_gt (model.click_pos rank))
      (ne_of_gt (model.click_pos (rank + 1)))).mpr
      (le_of_eq hclock.symm)

/--
Strict off-threshold behavior forced by one-step best response: strictly after
the finite `B*` threshold the strategy must drop, and strictly before the
threshold it must not drop.
-/
def paper_theorem8_bstar_ranked_threshold_one_step_off_threshold_behavior_statement
    (clickThroughRate value : ℕ → ℝ) (remaining : ℕ)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ) : Prop :=
  ∀ state rank,
    (paper_theorem8_bstar_threshold_bid value clickThroughRate
          (remaining + 1) (rank + 1) < state.clockPrice →
      strategy state rank) ∧
      (state.clockPrice <
          paper_theorem8_bstar_threshold_bid value clickThroughRate
            (remaining + 1) (rank + 1) →
        ¬ strategy state rank)

/--
Any one-step best-response strategy has the strict off-threshold behavior
required by the source proof. Tie-breaking is needed only at exact equality.
-/
theorem paper_theorem8_bstar_ranked_threshold_one_step_best_response_off_threshold_behavior
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ}
    (hbest :
      paper_theorem8_bstar_ranked_threshold_one_step_best_response_statement
        model.clickThroughRate model.value model.remaining strategy) :
    paper_theorem8_bstar_ranked_threshold_one_step_off_threshold_behavior_statement
      model.clickThroughRate model.value model.remaining strategy := by
  intro state rank
  have hlocal :=
    paper_theorem8_bstar_ranked_threshold_local_optimality_statement_of_certificate
      model
  rcases hlocal rank with
    ⟨_hcontinuation_le_current, _hcurrent_le_value, _hno_drop_before_continuation,
      _hdrop_after_value, _hindifferent, hactive_before, hdrop_after⟩
  constructor
  · intro hthreshold_lt
    by_contra hnot_drop
    have hpay_le := (hbest state rank).2 hnot_drop
    have hpay_lt :
        paper_theorem8_bstar_ranked_threshold_continue_payoff
            model.clickThroughRate model.value state rank <
          paper_theorem8_bstar_ranked_threshold_drop_payoff
            model.clickThroughRate model.value model.remaining rank := by
      simpa [paper_theorem8_bstar_ranked_threshold_continue_payoff,
        paper_theorem8_bstar_ranked_threshold_drop_payoff] using
        hdrop_after state hthreshold_lt
    exact not_le_of_gt hpay_lt hpay_le
  · intro hclock_lt hdrop
    have hpay_le := (hbest state rank).1 hdrop
    have hpay_lt :
        paper_theorem8_bstar_ranked_threshold_drop_payoff
            model.clickThroughRate model.value model.remaining rank <
          paper_theorem8_bstar_ranked_threshold_continue_payoff
            model.clickThroughRate model.value state rank := by
      simpa [paper_theorem8_bstar_ranked_threshold_continue_payoff,
        paper_theorem8_bstar_ranked_threshold_drop_payoff] using
        hactive_before state hclock_lt
    exact not_le_of_gt hpay_lt hpay_le

/--
Strict off-threshold behavior plus drop-at-threshold tie-breaking gives the
finite `B*` cutoff rule. This theorem is independent of how the off-threshold
behavior was proved.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_iff_of_off_threshold_behavior_and_drop_at_threshold
    {clickThroughRate value : ℕ → ℝ} {remaining : ℕ}
    {strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ}
    (hoff :
      paper_theorem8_bstar_ranked_threshold_one_step_off_threshold_behavior_statement
        clickThroughRate value remaining strategy)
    (htie :
      paper_theorem8_bstar_ranked_threshold_drop_at_threshold_statement
        clickThroughRate value remaining strategy) :
    ∀ state rank,
      strategy state rank ↔
        paper_theorem8_bstar_threshold_bid
          value clickThroughRate (remaining + 1) (rank + 1) ≤
          state.clockPrice := by
  intro state rank
  constructor
  · intro hdrop
    by_contra hnot_le
    exact (hoff state rank).2 (lt_of_not_ge hnot_le) hdrop
  · intro hthreshold_le
    rcases eq_or_lt_of_le hthreshold_le with hthreshold_eq | hthreshold_lt
    · exact htie state rank hthreshold_eq.symm
    · exact (hoff state rank).1 hthreshold_lt

/--
Strict off-threshold behavior plus drop-at-threshold tie-breaking identifies
the named finite `B*` ranked-threshold strategy extensionally.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_eq_of_off_threshold_behavior_and_drop_at_threshold
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ}
    (hoff :
      paper_theorem8_bstar_ranked_threshold_one_step_off_threshold_behavior_statement
        model.clickThroughRate model.value model.remaining strategy)
    (htie :
