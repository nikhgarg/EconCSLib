/--
Every rank appearing in a finite exact-drop schedule has final terminal record
equal to its finite `B*` threshold.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_terminal_record_eq_threshold_of_mem
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {ranks : List ℕ}
    (hsched :
      PaperTheorem8BStarRankedThresholdExactDropSchedule
        model state ranks finalState) :
    ∀ rank,
      rank ∈ ranks →
        finalState.lastDropout rank =
          some
            (paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1)) := by
  induction hsched with
  | nil state =>
      intro rank hrank
      simp at hrank
  | @cons state finalState dropped tailRanks hclock hactive htail ih =>
      intro rank hrank
      simp only [List.mem_cons] at hrank
      rcases hrank with hsame | htail_mem
      · subst rank
        have hmid_record :
            (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
              (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
                (paper_theorem8_bstar_threshold_bid
                  model.value model.clickThroughRate (model.remaining + 1)
                  (dropped + 1)))
              dropped).lastDropout dropped =
              some
                (paper_theorem8_bstar_threshold_bid
                  model.value model.clickThroughRate (model.remaining + 1)
                  (dropped + 1)) := by
          simp [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
            PaperTheorem8GeneralizedEnglishAuctionState.advanceClock]
        have htail_exact :
            PaperTheorem8BStarRankedThresholdExactDropHistory model
              (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
                (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
                  (paper_theorem8_bstar_threshold_bid
                    model.value model.clickThroughRate (model.remaining + 1)
                    (dropped + 1)))
                dropped)
              finalState :=
          paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_to_history
            model htail
        have htail_history :
            PaperTheorem8GeneralizedEnglishAuctionState.History
              (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
                (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
                  (paper_theorem8_bstar_threshold_bid
                    model.value model.clickThroughRate (model.remaining + 1)
                    (dropped + 1)))
                dropped)
              finalState :=
          (paper_theorem8_bstar_ranked_threshold_exact_drop_history_to_strategy_history
            model htail_exact).toHistory
        exact
          PaperTheorem8GeneralizedEnglishAuctionState.History_lastDropout_eq_of_initial_some
            htail_history hmid_record
      · exact ih rank htail_mem

/-- Every rank appearing in a finite exact-drop schedule is inactive in the
final state. -/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_inactive_of_mem
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {ranks : List ℕ}
    (hsched :
      PaperTheorem8BStarRankedThresholdExactDropSchedule
        model state ranks finalState) :
    ∀ rank, rank ∈ ranks → ¬ finalState.IsActive rank := by
  intro rank hrank hactive
  have hrecord :=
    paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_terminal_record_eq_threshold_of_mem
      model hsched rank hrank
  have hnone : finalState.lastDropout rank = none := by
    simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive] using hactive
  rw [hrecord] at hnone
  cases hnone

/--
Ranks not appearing in a finite exact-drop schedule remain active at the final
state whenever they were active initially. Exact schedules only record dropouts
for listed ranks.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_active_of_not_mem
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {ranks : List ℕ}
    (hsched :
      PaperTheorem8BStarRankedThresholdExactDropSchedule
        model state ranks finalState)
    {rank : ℕ}
    (hactive : state.IsActive rank)
    (hnot_mem : rank ∉ ranks) :
    finalState.IsActive rank := by
  induction hsched with
  | nil state =>
      simpa using hactive
  | @cons state0 finalState0 head tail hclock hhead_active htail ih =>
      have hne : rank ≠ head := by
        intro hsame
        exact hnot_mem (by simp [hsame])
      have hnot_tail : rank ∉ tail := by
        intro htail_mem
        exact hnot_mem (by simp [htail_mem])
      have hactive_next :
          (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
            (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state0
              (paper_theorem8_bstar_threshold_bid
                model.value model.clickThroughRate (model.remaining + 1)
                (head + 1)))
            head).IsActive rank :=
        paper_theorem8_bstar_ranked_threshold_single_exact_drop_preserves_active_of_ne
          model state0 hne hactive
      exact ih hactive_next hnot_tail

/--
Terminality criterion for finite exact-drop schedules. If every unscheduled
rank's finite `B*` threshold remains above the final clock, then every active
rank at the final state is one whom the named finite `B*` strategy does not
prescribe to drop.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_strategy_terminal_of_unscheduled_threshold_gt
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {ranks : List ℕ}
    (hsched :
      PaperTheorem8BStarRankedThresholdExactDropSchedule
        model state ranks finalState)
    (hunscheduled :
      ∀ rank,
        rank ∉ ranks →
          finalState.clockPrice <
            paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1)) :
    PaperTheorem8GeneralizedEnglishAuctionState.StrategyTerminal
      (paper_theorem8_bstar_ranked_threshold_strategy
        model.value model.clickThroughRate model.remaining)
      finalState := by
  intro rank hactive_final hdrop
  by_cases hrank : rank ∈ ranks
  · exact
      (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_inactive_of_mem
        model hsched rank hrank) hactive_final
  · have hlt := hunscheduled rank hrank
    have hdrop_iff :=
      paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
        model.value model.clickThroughRate finalState rank model.remaining
        (ne_of_gt (model.click_pos rank))
        (ne_of_gt (model.click_pos (rank + 1)))
    exact
      (not_le_of_gt hlt)
        (hdrop_iff.mp hdrop)

/--
Build the terminal-history behavior certificate from a finite exact-drop
