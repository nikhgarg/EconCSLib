certificate, but makes the terminal history more directly auditable.
-/
structure PaperTheorem8BStarRankedThresholdStrictOrderedNoOvershootTerminalDynamicCertificate
    (Belief : Type*) where
  terminal :
    PaperTheorem8BStarRankedThresholdNoOvershootTerminalHistoryBehaviorCertificate
  dynamic :
    PaperTheorem8BStarRankedThresholdStrictOrderedDynamicGameConstructedOutcomeCertificate
      Belief
  localModel_eq :
