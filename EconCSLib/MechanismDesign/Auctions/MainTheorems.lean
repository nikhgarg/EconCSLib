/--
Terminal-history bridge for any strategy satisfying the finite-`B*` cutoff
rule. This is the reusable connection from dynamic-game PBE characterizations
back to the concrete terminal history: at the terminal state, cutoff actions
are exactly inactive ranks, not acting is exactly active ranks, and every
acting rank has a recorded dropout price.
-/
theorem paper_theorem8_bstar_ranked_threshold_terminal_history_cutoff_strategy_behavior_with_records
    (cert :
      PaperTheorem8BStarRankedThresholdTerminalHistoryBehaviorCertificate)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ)
    (hstrategy :
      ∀ state rank,
        strategy state rank ↔
          paper_theorem8_bstar_threshold_bid
            cert.localModel.value cert.localModel.clickThroughRate
            (cert.localModel.remaining + 1) (rank + 1) ≤
            state.clockPrice) :
    (∀ rank, strategy cert.finalState rank ↔
      ¬ cert.finalState.IsActive rank) ∧
      (∀ rank, ¬ strategy cert.finalState rank ↔
        cert.finalState.IsActive rank) ∧
        (∀ rank,
          strategy cert.finalState rank →
            ∃ price,
              cert.finalState.lastDropout rank = some price ∧
                paper_theorem8_bstar_threshold_bid
                  cert.localModel.value cert.localModel.clickThroughRate
                  (cert.localModel.remaining + 1) (rank + 1) ≤
                  price ∧
                price ≤ cert.finalState.clockPrice) := by
  constructor
  · intro rank
    exact
      (hstrategy cert.finalState rank).trans
        (paper_theorem8_bstar_ranked_threshold_terminal_history_behavior_inactive_iff_threshold_le_clock
          cert rank).symm
  constructor
  · intro rank
    constructor
    · intro hnot_strategy
      have hnot_le :
          ¬ paper_theorem8_bstar_threshold_bid
              cert.localModel.value cert.localModel.clickThroughRate
              (cert.localModel.remaining + 1) (rank + 1) ≤
            cert.finalState.clockPrice := by
        intro hle
        exact hnot_strategy ((hstrategy cert.finalState rank).mpr hle)
      exact
        (paper_theorem8_bstar_ranked_threshold_terminal_history_behavior_active_iff_clock_lt_threshold_bid
          cert rank).mpr (lt_of_not_ge hnot_le)
    · intro hactive hdrop
      have hle := (hstrategy cert.finalState rank).mp hdrop
      have hlt :=
        (paper_theorem8_bstar_ranked_threshold_terminal_history_behavior_active_iff_clock_lt_threshold_bid
          cert rank).mp hactive
      exact not_le_of_gt hlt hle
  · intro rank hdrop
    have hinactive :
        ¬ cert.finalState.IsActive rank :=
      ((hstrategy cert.finalState rank).trans
        (paper_theorem8_bstar_ranked_threshold_terminal_history_behavior_inactive_iff_threshold_le_clock
          cert rank).symm).mp hdrop
    exact
      paper_theorem8_bstar_ranked_threshold_terminal_history_behavior_inactive_record_exists
        cert hinactive

/--
EOS Theorem 8 abstract dynamic-game interface for the generalized English
auction. It separates the dynamic proof obligations into belief consistency,
sequential rationality, an outcome map, and the target VCG outcome.
-/
structure PaperTheorem8GeneralizedEnglishDynamicGame
    (Bidder Slot StrategyProfile Belief : Type*) where
  environment : PositionEnvironment Slot
  values : Bidder → ℝ
  isConsistentBelief : StrategyProfile → Belief → Prop
  isSequentiallyRational : StrategyProfile → Belief → Prop
  outcomeOf : StrategyProfile → PositionOutcome Bidder Slot
  vcgOutcome : PositionOutcome Bidder Slot

namespace PaperTheorem8GeneralizedEnglishDynamicGame

/--
Perfect Bayesian equilibrium for the abstract generalized-English dynamic-game
interface: there exists a belief system under which the strategy profile is
both belief-consistent and sequentially rational.
-/
def PerfectBayesianEquilibrium
    {Bidder Slot StrategyProfile Belief : Type*}
    (G :
      PaperTheorem8GeneralizedEnglishDynamicGame
        Bidder Slot StrategyProfile Belief)
    (strategy : StrategyProfile) : Prop :=
  ∃ belief : Belief,
    G.isConsistentBelief strategy belief ∧
      G.isSequentiallyRational strategy belief

end PaperTheorem8GeneralizedEnglishDynamicGame

/--
Paper-facing expansion of the abstract generalized-English PBE predicate:
checking PBE is exactly checking that one belief system witnesses both
consistency and sequential rationality.
-/
theorem paper_theorem8_dynamic_game_pbe_iff_exists_consistent_sequential_belief
    {Bidder Slot StrategyProfile Belief : Type*}
    (G :
      PaperTheorem8GeneralizedEnglishDynamicGame
        Bidder Slot StrategyProfile Belief)
    (strategy : StrategyProfile) :
    G.PerfectBayesianEquilibrium strategy ↔
      ∃ belief : Belief,
        G.isConsistentBelief strategy belief ∧
          G.isSequentiallyRational strategy belief := by
  rfl

/--
Dynamic-game payoff bridge for Theorem 8: if a strategy outcome has the same
positions and per-click payments as the target VCG outcome, then every bidder
has the same utility in the two outcomes.
-/
theorem paper_theorem8_dynamic_game_utility_eq_vcg_of_same_slots_payments
    {Bidder Slot StrategyProfile Belief : Type*}
    (G :
      PaperTheorem8GeneralizedEnglishDynamicGame
        Bidder Slot StrategyProfile Belief)
    (strategy : StrategyProfile)
    (hslot :
      ∀ bidder,
        (G.outcomeOf strategy).slotOf bidder =
          G.vcgOutcome.slotOf bidder)
    (hpay :
      ∀ bidder,
        (G.outcomeOf strategy).paymentPerClick bidder =
          G.vcgOutcome.paymentPerClick bidder)
    (bidder : Bidder) :
    (G.outcomeOf strategy).utility G.environment G.values bidder =
      G.vcgOutcome.utility G.environment G.values bidder := by
  exact
    paper_position_utility_eq_of_slot_payment_eq
      G.environment (G.outcomeOf strategy) G.vcgOutcome G.values hslot hpay
      bidder

/--
Dynamic-game payoff bridge from outcome equality: if a strategy outcome is
equal to the target VCG outcome, then every bidder has the same utility in the
two outcomes.
-/
theorem paper_theorem8_dynamic_game_utility_eq_vcg_of_outcome_eq
    {Bidder Slot StrategyProfile Belief : Type*}
    (G :
      PaperTheorem8GeneralizedEnglishDynamicGame
        Bidder Slot StrategyProfile Belief)
    (strategy : StrategyProfile)
    (houtcome : G.outcomeOf strategy = G.vcgOutcome)
    (bidder : Bidder) :
    (G.outcomeOf strategy).utility G.environment G.values bidder =
      G.vcgOutcome.utility G.environment G.values bidder := by
  rw [houtcome]

/--
Every abstract generalized-English PBE exposes a belief that is consistent with
the strategy profile.
-/
theorem paper_theorem8_dynamic_game_pbe_consistent_belief_exists
    {Bidder Slot StrategyProfile Belief : Type*}
    {G :
      PaperTheorem8GeneralizedEnglishDynamicGame
        Bidder Slot StrategyProfile Belief}
    {strategy : StrategyProfile}
    (hpbe : G.PerfectBayesianEquilibrium strategy) :
    ∃ belief : Belief, G.isConsistentBelief strategy belief := by
  rcases hpbe with ⟨belief, hconsistent, _hsequential⟩
  exact ⟨belief, hconsistent⟩

/--
Every abstract generalized-English PBE exposes a belief that makes the strategy
profile sequentially rational.
-/
theorem paper_theorem8_dynamic_game_pbe_sequentially_rational_belief_exists
    {Bidder Slot StrategyProfile Belief : Type*}
    {G :
      PaperTheorem8GeneralizedEnglishDynamicGame
        Bidder Slot StrategyProfile Belief}
    {strategy : StrategyProfile}
    (hpbe : G.PerfectBayesianEquilibrium strategy) :
    ∃ belief : Belief, G.isSequentiallyRational strategy belief := by
  rcases hpbe with ⟨belief, _hconsistent, hsequential⟩
  exact ⟨belief, hsequential⟩

/--
Paper-facing dynamic-game/PBE certificate for EOS Theorem 8. The remaining
source-specific dynamic proof is isolated to consistency, sequential
rationality, uniqueness, and outcome equivalence fields.
-/
structure PaperTheorem8DynamicGamePBECertificate
    (Bidder Slot StrategyProfile Belief : Type*) where
  game :
    PaperTheorem8GeneralizedEnglishDynamicGame
      Bidder Slot StrategyProfile Belief
  equilibrium : StrategyProfile
  belief : Belief
  equilibrium_consistent :
    game.isConsistentBelief equilibrium belief
  equilibrium_sequentially_rational :
    game.isSequentiallyRational equilibrium belief
  unique_pbe :
    ∀ strategy,
      game.PerfectBayesianEquilibrium strategy → strategy = equilibrium
  equilibrium_outcome_eq_vcg :
    game.outcomeOf equilibrium = game.vcgOutcome

/--
EOS Theorem 8 dynamic-game certificate form. From explicit belief consistency,
sequential rationality, uniqueness, and VCG-outcome equivalence, Lean derives
the unique perfect Bayesian equilibrium statement for the abstract dynamic
generalized-English game.
-/
theorem paper_theorem8_dynamic_game_unique_pbe_of_certificate
    {Bidder Slot StrategyProfile Belief : Type*}
    (model :
      PaperTheorem8DynamicGamePBECertificate
        Bidder Slot StrategyProfile Belief) :
    ∃ equilibrium : StrategyProfile,
      model.game.PerfectBayesianEquilibrium equilibrium ∧
        (∀ strategy,
          model.game.PerfectBayesianEquilibrium strategy →
            strategy = equilibrium) ∧
        model.game.outcomeOf equilibrium = model.game.vcgOutcome := by
  exact ⟨model.equilibrium,
    ⟨model.belief, model.equilibrium_consistent,
      model.equilibrium_sequentially_rational⟩,
    model.unique_pbe, model.equilibrium_outcome_eq_vcg⟩

/--
EOS Theorem 8 dynamic-game certificate characterization form. The certified
equilibrium is not just unique: a strategy is a perfect Bayesian equilibrium
iff it is equal to the certified equilibrium.
-/
theorem paper_theorem8_dynamic_game_pbe_iff_equilibrium_of_certificate
    {Bidder Slot StrategyProfile Belief : Type*}
    (model :
      PaperTheorem8DynamicGamePBECertificate
        Bidder Slot StrategyProfile Belief)
    (strategy : StrategyProfile) :
    model.game.PerfectBayesianEquilibrium strategy ↔
      strategy = model.equilibrium := by
  constructor
  · intro hpbe
    exact model.unique_pbe strategy hpbe
  · intro h
    rw [h]
    exact
      ⟨model.belief, model.equilibrium_consistent,
        model.equilibrium_sequentially_rational⟩

/--
EOS Theorem 8 dynamic-game outcome characterization. Every certified PBE
strategy has the VCG outcome.
-/
theorem paper_theorem8_dynamic_game_pbe_outcome_eq_vcg_of_certificate
    {Bidder Slot StrategyProfile Belief : Type*}
    (model :
      PaperTheorem8DynamicGamePBECertificate
        Bidder Slot StrategyProfile Belief)
    {strategy : StrategyProfile}
    (hpbe : model.game.PerfectBayesianEquilibrium strategy) :
    model.game.outcomeOf strategy = model.game.vcgOutcome := by
  have hstrategy :
      strategy = model.equilibrium :=
    (paper_theorem8_dynamic_game_pbe_iff_equilibrium_of_certificate
      model strategy).mp hpbe
  rw [hstrategy]
  exact model.equilibrium_outcome_eq_vcg

/--
EOS Theorem 8 dynamic-game allocation/payment characterization. Every
certified PBE strategy has the VCG slot assignment and VCG per-click payments,
stated componentwise for paper-facing verification.
-/
theorem paper_theorem8_dynamic_game_pbe_slot_payment_eq_vcg_of_certificate
    {Bidder Slot StrategyProfile Belief : Type*}
    (model :
      PaperTheorem8DynamicGamePBECertificate
        Bidder Slot StrategyProfile Belief)
    {strategy : StrategyProfile}
    (hpbe : model.game.PerfectBayesianEquilibrium strategy) :
    (∀ bidder,
      (model.game.outcomeOf strategy).slotOf bidder =
        model.game.vcgOutcome.slotOf bidder) ∧
      (∀ bidder,
        (model.game.outcomeOf strategy).paymentPerClick bidder =
          model.game.vcgOutcome.paymentPerClick bidder) := by
  have hout :
      model.game.outcomeOf strategy = model.game.vcgOutcome :=
    paper_theorem8_dynamic_game_pbe_outcome_eq_vcg_of_certificate model hpbe
  constructor
  · intro bidder
    rw [hout]
  · intro bidder
    rw [hout]

