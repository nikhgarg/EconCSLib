/--
Cold-start generalized-English state for the finite-`B*` ranked-threshold
strategy: the clock begins below the nonnegative constructed `B*` bids and no
rank has a dropout record.
-/
def paper_theorem8_bstar_ranked_threshold_cold_start_state :
    PaperTheorem8GeneralizedEnglishAuctionState ℕ where
  clockPrice := -1
  lastDropout := fun _ => none

/--
At the cold-start state, ordered nonnegative finite `B*` bids discharge the
initial no-overshoot obligation needed by clock-disciplined source histories.
The cold-start clock is `-1`, while each constructed finite `B*` threshold is
nonnegative under the standard ordered value/click assumptions.
-/
theorem paper_theorem8_bstar_ranked_threshold_cold_start_initial_no_overshoot
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (hvalue_nonneg : ∀ rank, 0 ≤ model.value rank)
    (hclick_mono : ∀ rank,
      model.clickThroughRate (rank + 1) ≤ model.clickThroughRate rank)
    (hclick_pos : ∀ rank, 0 < model.clickThroughRate rank) :
    ∀ rank,
      paper_theorem8_bstar_ranked_threshold_cold_start_state.IsActive rank →
        paper_theorem8_bstar_ranked_threshold_cold_start_state.clockPrice ≤
          paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) := by
  intro rank _hactive
  have hthreshold_nonneg :
      0 ≤
        paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (rank + 1) := by
    simpa [paper_theorem8_bstar_ranked_threshold_outcome] using
      (paper_theorem8_bstar_ranked_threshold_outcome_payment_nonneg_of_ordered
        (value := model.value) (clickThroughRate := model.clickThroughRate)
        (remaining := model.remaining + 1) (i := rank)
        hvalue_nonneg hclick_mono hclick_pos)
  dsimp [paper_theorem8_bstar_ranked_threshold_cold_start_state]
  linarith

/--
Finite-active cold-start generalized-English state. Ranks in `activeRanks`
begin without a dropout record; all other ranks are already inactive with the
same explicit placeholder record. This is a finite-source helper, not the
paper's all-ranks-active cold start.
-/
def paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state
    (activeRanks : Finset ℕ) (inactivePrice : ℝ) :
    PaperTheorem8GeneralizedEnglishAuctionState ℕ where
  clockPrice := -1
  lastDropout rank := if rank ∈ activeRanks then none else some inactivePrice

/-- In the finite-active cold-start state, active ranks are exactly the listed
finite set. -/
theorem paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_active_iff
    (activeRanks : Finset ℕ) (inactivePrice : ℝ) (rank : ℕ) :
    (paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state
      activeRanks inactivePrice).IsActive rank ↔
      rank ∈ activeRanks := by
  by_cases hmem : rank ∈ activeRanks
  · simp [paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state,
      PaperTheorem8GeneralizedEnglishAuctionState.IsActive, hmem]
  · simp [paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state,
      PaperTheorem8GeneralizedEnglishAuctionState.IsActive, hmem]

/-- Ranks outside the finite active set begin with the explicit inactive
placeholder record. -/
theorem paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_lastDropout_of_not_mem
    (activeRanks : Finset ℕ) (inactivePrice : ℝ) {rank : ℕ}
    (hnot_mem : rank ∉ activeRanks) :
    (paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state
      activeRanks inactivePrice).lastDropout rank =
      some inactivePrice := by
  simp [paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state,
    hnot_mem]

/--
Finite-active cold-start state whose initially inactive ranks already carry
their exact finite-`B*` records. This is the finite-source specialization that
can still recover the full all-rank terminal-record `B*` outcome after the
finite active ranks drop.
-/
noncomputable def paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (activeRanks : Finset ℕ) :
    PaperTheorem8GeneralizedEnglishAuctionState ℕ where
  clockPrice := -1
  lastDropout rank :=
    if rank ∈ activeRanks then none
    else
      some
        (paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (rank + 1))

/-- In the exact-record finite-active cold-start state, active ranks are exactly
the listed finite set. -/
theorem paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_active_iff
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (activeRanks : Finset ℕ) (rank : ℕ) :
    (paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state
      model activeRanks).IsActive rank ↔
      rank ∈ activeRanks := by
  by_cases hmem : rank ∈ activeRanks
  · simp [paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state,
      PaperTheorem8GeneralizedEnglishAuctionState.IsActive, hmem]
  · simp [paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state,
      PaperTheorem8GeneralizedEnglishAuctionState.IsActive, hmem]

/-- Ranks outside the finite active set begin with their exact finite-`B*`
record in the exact-record cold-start state. -/
theorem paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_lastDropout_of_not_mem
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (activeRanks : Finset ℕ) {rank : ℕ}
    (hnot_mem : rank ∉ activeRanks) :
    (paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state
      model activeRanks).lastDropout rank =
      some
        (paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (rank + 1)) := by
  simp [paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state,
    hnot_mem]

/--
The finite-active cold-start state has the same no-overshoot initial clock
bound as the all-active cold start, because both clocks are `-1`.
-/
theorem paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_initial_no_overshoot
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (activeRanks : Finset ℕ) (inactivePrice : ℝ)
    (hvalue_nonneg : ∀ rank, 0 ≤ model.value rank)
    (hclick_mono : ∀ rank,
      model.clickThroughRate (rank + 1) ≤ model.clickThroughRate rank)
    (hclick_pos : ∀ rank, 0 < model.clickThroughRate rank) :
    ∀ rank,
      (paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state
        activeRanks inactivePrice).IsActive rank →
        (paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state
          activeRanks inactivePrice).clockPrice ≤
          paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) := by
  intro rank _hactive
  have hcold_active :
      paper_theorem8_bstar_ranked_threshold_cold_start_state.IsActive rank := by
    rfl
  simpa [paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state,
    paper_theorem8_bstar_ranked_threshold_cold_start_state] using
    (paper_theorem8_bstar_ranked_threshold_cold_start_initial_no_overshoot
      model hvalue_nonneg hclick_mono hclick_pos rank hcold_active)

/--
Finite-active terminality bridge for exact-drop schedules. If the scheduled
ranks are exactly the finite active set, then the deterministic final state has
no active ranks left. Unscheduled ranks stay inactive by preserving their
initial placeholder dropout records.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state_no_active_of_finite_active_cold_start_covers
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (activeRanks : Finset ℕ) (inactivePrice : ℝ)
    (scheduledRanks : List ℕ)
    (hsorted :
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted
        model
        (paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state
          activeRanks inactivePrice).clockPrice
        scheduledRanks)
    (hnodup : scheduledRanks.Nodup)
    (hcover : ∀ rank, rank ∈ activeRanks ↔ rank ∈ scheduledRanks) :
    ∀ rank,
      ¬ (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
          model
          (paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state
            activeRanks inactivePrice)
          scheduledRanks).IsActive rank := by
  let initialState :=
    paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_state
      activeRanks inactivePrice
  have hinitial_active :
      ∀ rank, rank ∈ scheduledRanks → initialState.IsActive rank := by
    intro rank hrank
    exact
      (paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_active_iff
        activeRanks inactivePrice rank).mpr ((hcover rank).mpr hrank)
  let hsched :=
    paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_of_clock_sorted_nodup
      model initialState scheduledRanks hsorted hnodup hinitial_active
  have hrecords :=
    paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state_records_of_clock_sorted_nodup
      model initialState scheduledRanks hsorted hnodup hinitial_active
  intro rank hactive_final
  by_cases hrank : rank ∈ scheduledRanks
  · exact
      (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_inactive_of_mem
        model hsched rank hrank) hactive_final
  · have hnot_activeRanks : rank ∉ activeRanks := by
      intro hactiveRank
      exact hrank ((hcover rank).mp hactiveRank)
    have hinit_record : initialState.lastDropout rank = some inactivePrice := by
      exact
        paper_theorem8_bstar_ranked_threshold_finite_active_cold_start_lastDropout_of_not_mem
          activeRanks inactivePrice hnot_activeRanks
    have hfinal_record :
        (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
          model initialState scheduledRanks).lastDropout rank =
          some inactivePrice := by
      rw [hrecords.2 rank hrank, hinit_record]
    have hnone :
        (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
          model initialState scheduledRanks).lastDropout rank = none := by
      simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive] using
        hactive_final
    rw [hfinal_record] at hnone
    cases hnone

/--
Exact-record finite-active terminality bridge. If the exact-drop schedule
covers exactly the finite active set, then the deterministic final state has no
active ranks left; initially inactive ranks retain their exact records.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state_no_active_of_finite_active_exact_record_cold_start_covers
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
