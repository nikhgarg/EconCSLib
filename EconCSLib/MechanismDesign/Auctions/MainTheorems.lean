  equilibrium_same_payments_as_vcg := model.equilibrium_same_payments_as_vcg

/--
Dynamic-game PBE cutoff characterization from the one-step/tie-breaking
boundary.
-/
theorem paper_theorem8_bstar_ranked_threshold_dynamic_game_pbe_drops_iff_threshold_bid_of_one_step_tie_break_extensional_outcome_certificate
    {Belief : Type*}
    (model :
