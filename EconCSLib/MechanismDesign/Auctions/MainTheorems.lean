  ∀ rank,
    paper_theorem8_bstar_threshold_bid value clickThroughRate remaining
        (rank + 2) <
      paper_theorem8_bstar_threshold_bid value clickThroughRate
        (remaining + 1) (rank + 1) ∧
    paper_theorem8_bstar_threshold_bid value clickThroughRate
        (remaining + 1) (rank + 1) < value (rank + 1)

