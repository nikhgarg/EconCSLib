  apply propext
  exact
    (paper_theorem8_bstar_ranked_threshold_strategy_iff_of_off_threshold_behavior_and_drop_at_threshold
        hoff htie state rank).trans
      (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
        model.value model.clickThroughRate state rank model.remaining
        (ne_of_gt (model.click_pos rank))
        (ne_of_gt (model.click_pos (rank + 1)))).symm

/--
A one-step best response with the paper's at-threshold drop tie-breaking has
the finite `B*` cutoff rule. Strict local incentives rule out dropping before
the threshold and rule out waiting after the threshold; tie-breaking handles
exact equality.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_iff_of_one_step_best_response_and_drop_at_threshold
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ}
    (hbest :
      paper_theorem8_bstar_ranked_threshold_one_step_best_response_statement
        model.clickThroughRate model.value model.remaining strategy)
    (htie :
      paper_theorem8_bstar_ranked_threshold_drop_at_threshold_statement
        model.clickThroughRate model.value model.remaining strategy) :
    ∀ state rank,
      strategy state rank ↔
        paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (rank + 1) ≤ state.clockPrice := by
  intro state rank
  have hlocal :=
    paper_theorem8_bstar_ranked_threshold_local_optimality_statement_of_certificate
      model
  rcases hlocal rank with
    ⟨_hcontinuation_le_current, _hcurrent_le_value, _hno_drop_before_continuation,
      _hdrop_after_value, _hindifferent, hactive_before, hdrop_after⟩
  constructor
  · intro hdrop
    by_contra hnot_le
    have hclock_lt :
        state.clockPrice <
          paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) :=
      lt_of_not_ge hnot_le
    have hpay_le := (hbest state rank).1 hdrop
    have hpay_lt :
        paper_theorem8_bstar_ranked_threshold_drop_payoff
            model.clickThroughRate model.value model.remaining rank <
          paper_theorem8_bstar_ranked_threshold_continue_payoff
            model.clickThroughRate model.value state rank := by
      simpa [paper_theorem8_bstar_ranked_threshold_continue_payoff,
        paper_theorem8_bstar_ranked_threshold_drop_payoff] using
        hactive_before state hclock_lt
    exact not_le_of_gt hpay_lt hpay_le
  · intro hthreshold_le
    rcases eq_or_lt_of_le hthreshold_le with hthreshold_eq | hthreshold_lt
    · exact htie state rank hthreshold_eq.symm
    · by_contra hnot_drop
      have hpay_le := (hbest state rank).2 hnot_drop
      have hpay_lt :
          paper_theorem8_bstar_ranked_threshold_continue_payoff
              model.clickThroughRate model.value state rank <
            paper_theorem8_bstar_ranked_threshold_drop_payoff
              model.clickThroughRate model.value model.remaining rank := by
        simpa [paper_theorem8_bstar_ranked_threshold_continue_payoff,
          paper_theorem8_bstar_ranked_threshold_drop_payoff] using
          hdrop_after state hthreshold_lt
      exact not_le_of_gt hpay_lt hpay_le

