No-overshoot source-history bridge. For the named finite `B*` strategy,
strategy consistency already gives that a dropout state has reached the rank's
threshold. Therefore a source proof only needs to show the clock did not
overshoot that threshold at actual dropout states; Lean derives exact finite
`B*` dropout timing and hence an exact-drop history.
-/
theorem paper_theorem8_bstar_ranked_threshold_strategy_history_to_exact_drop_history_of_no_overshoot_drop_steps
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (hhist :
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining)
        state finalState)
    (hno_overshoot :
      ∀ state rank,
        state.IsActive rank →
          paper_theorem8_bstar_ranked_threshold_strategy
            model.value model.clickThroughRate model.remaining state rank →
          state.clockPrice ≤
            paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1)) :
    PaperTheorem8BStarRankedThresholdExactDropHistory
      model state finalState := by
  exact
    paper_theorem8_bstar_ranked_threshold_strategy_history_to_exact_drop_history_of_exact_drop_steps
      model hhist
      (by
        intro state rank hactive hstrategy
        have hthreshold_le_clock :
            paper_theorem8_bstar_threshold_bid
                model.value model.clickThroughRate (model.remaining + 1)
                (rank + 1) ≤ state.clockPrice :=
          (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
            model.value model.clickThroughRate state rank model.remaining
            (ne_of_gt (model.click_pos rank))
            (ne_of_gt (model.click_pos (rank + 1)))).mp hstrategy
        exact le_antisymm (hno_overshoot state rank hactive hstrategy)
          hthreshold_le_clock)

/--
Single-active overshoot state for the named finite `B*` threshold strategy. The
chosen rank is still active, every other rank has already dropped, and the
clock is one unit above the chosen rank's finite `B*` threshold.
-/
noncomputable def paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (rank : ℕ) : PaperTheorem8GeneralizedEnglishAuctionState ℕ where
  clockPrice :=
    paper_theorem8_bstar_threshold_bid
      model.value model.clickThroughRate (model.remaining + 1) (rank + 1) + 1
  lastDropout bidder := if bidder = rank then none else some 0

/--
Ordinary strategy-consistent histories alone are too permissive for exact
terminal-record generation: a rank may be active after its finite `B*`
threshold, drop under the named strategy, and be recorded at an overshot clock
price. The source-facing exact-record routes therefore need either exact-drop
or no-overshoot timing evidence.
-/
theorem paper_theorem8_bstar_ranked_threshold_ordinary_strategy_history_allows_overshoot_record
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (rank : ℕ) :
    let state :=
      paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
        model rank
    let finalState :=
      PaperTheorem8GeneralizedEnglishAuctionState.recordDropout state rank
    let threshold :=
      paper_theorem8_bstar_threshold_bid
        model.value model.clickThroughRate (model.remaining + 1) (rank + 1)
    PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining)
        state finalState ∧
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyTerminal
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining)
        finalState ∧
        finalState.lastDropout rank = some (threshold + 1) ∧
          finalState.lastDropout rank ≠ some threshold := by
  dsimp
  refine ⟨?_, ?_, ?_, ?_⟩
  · have hactive :
        (paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
          model rank).IsActive rank := by
      simp [paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state,
        PaperTheorem8GeneralizedEnglishAuctionState.IsActive]
    have hstrategy :
        paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining
          (paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
            model rank)
          rank := by
      exact
        (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
          model.value model.clickThroughRate
          (paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
            model rank)
          rank model.remaining
          (ne_of_gt (model.click_pos rank))
          (ne_of_gt (model.click_pos (rank + 1)))).mpr
          (by
            simp [paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state])
    exact
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.cons
        (PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep.dropout
          (paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
            model rank)
          rank hactive hstrategy)
        (PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.refl
          (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
            (paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
              model rank)
            rank))
  · intro bidder hactive
    exfalso
    by_cases hsame : bidder = rank
    · subst bidder
      simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive,
        PaperTheorem8GeneralizedEnglishAuctionState.recordDropout] using
        hactive
    · simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive,
        PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
        paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state,
        hsame] using hactive
  · simp [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
      paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state]
  · intro hrecord
    have hsome :
        some
            (paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1) + 1) =
          some
            (paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1)) := by
      simpa [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
        paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state]
        using hrecord
    have hclock :
        paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) + 1 =
          paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) := by
      exact Option.some.inj hsome
    linarith

/--
Concrete no-overshoot strategy histories for the named finite `B*` strategy.
This source-facing history object records ordinary generalized-English clock
advances and dropouts, but at each actual dropout step also records that the
clock has not overshot the dropping rank's finite `B*` threshold. Strategy
consistency gives the opposite inequality, so this is exactly the local timing
condition needed to recover exact finite `B*` records.
