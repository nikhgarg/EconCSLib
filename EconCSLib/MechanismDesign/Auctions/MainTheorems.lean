/--
Terminal-history/PBE bridge for exact finite-`B*` dynamic certificates. If the
terminal-history certificate and dynamic-game certificate use the same local
model, then every certified PBE strategy acts exactly on the terminal inactive
ranks and every terminal PBE action has a concrete dropout record.
-/
theorem paper_theorem8_bstar_ranked_threshold_terminal_history_pbe_strategy_behavior_with_records_of_local_optimality_extensional_outcome_certificate
    {Belief : Type*}
    (terminalCert :
      PaperTheorem8BStarRankedThresholdTerminalHistoryBehaviorCertificate)
    (dynamicCert :
      PaperTheorem8BStarRankedThresholdLocalOptimalityDynamicGameExtensionalOutcomeCertificate
        Belief)
    (hmodel : dynamicCert.localModel = terminalCert.localModel)
    {strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ}
    (hpbe : dynamicCert.game.PerfectBayesianEquilibrium strategy) :
    (∀ rank, strategy terminalCert.finalState rank ↔
      ¬ terminalCert.finalState.IsActive rank) ∧
      (∀ rank, ¬ strategy terminalCert.finalState rank ↔
        terminalCert.finalState.IsActive rank) ∧
        (∀ rank,
          strategy terminalCert.finalState rank →
            ∃ price,
              terminalCert.finalState.lastDropout rank = some price ∧
                paper_theorem8_bstar_threshold_bid
                  terminalCert.localModel.value
                  terminalCert.localModel.clickThroughRate
                  (terminalCert.localModel.remaining + 1) (rank + 1) ≤
                  price ∧
                price ≤ terminalCert.finalState.clockPrice) := by
  exact
    paper_theorem8_bstar_ranked_threshold_terminal_history_cutoff_strategy_behavior_with_records
      terminalCert strategy
      (by
        intro state rank
        simpa [hmodel] using
          dynamicCert.pbe_bstar_threshold_characterization
            strategy hpbe state rank)

/--
Canonical ranked-`B*` outcome over the paper's ranked natural-number indexing.
This is the infinite-ranked analogue of the finite `B*` outcome from Theorem 7:
rank `i` gets slot `i` and pays the finite-tail `B*` bid per click.
-/
noncomputable def paper_theorem8_bstar_ranked_threshold_outcome
    (value clickThroughRate : ℕ → ℝ) (remaining : ℕ) :
    PositionOutcome ℕ ℕ where
  slotOf i := some i
  paymentPerClick i :=
    paper_theorem8_bstar_threshold_bid value clickThroughRate remaining (i + 1)

/-- The constructed ranked-`B*` Theorem 8 outcome assigns rank `i` to slot `i`. -/
theorem paper_theorem8_bstar_ranked_threshold_outcome_slotOf
    (value clickThroughRate : ℕ → ℝ) (remaining i : ℕ) :
    (paper_theorem8_bstar_ranked_threshold_outcome
      value clickThroughRate remaining).slotOf i = some i := by
  rfl

/--
The constructed ranked-`B*` Theorem 8 outcome charges the finite-tail `B*` bid
per click.
-/
theorem paper_theorem8_bstar_ranked_threshold_outcome_paymentPerClick
    (value clickThroughRate : ℕ → ℝ) (remaining i : ℕ) :
    (paper_theorem8_bstar_ranked_threshold_outcome
      value clickThroughRate remaining).paymentPerClick i =
      paper_theorem8_bstar_threshold_bid
        value clickThroughRate remaining (i + 1) := by
  rfl

/--
Terminal generalized-English dropout-record outcome. Rank `i` is assigned slot
`i`, and its per-click payment is the recorded terminal dropout price when one
is present. This is the source-facing outcome map for separating the concrete
history-to-record proof from the algebraic constructed-`B*` outcome proof.
-/
noncomputable def paper_theorem8_terminal_dropout_record_outcome
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ) :
    PositionOutcome ℕ ℕ where
  slotOf i := some i
  paymentPerClick i :=
    match state.lastDropout i with
    | some price => price
    | none => 0

/-- The terminal dropout-record outcome assigns rank `i` to slot `i`. -/
theorem paper_theorem8_terminal_dropout_record_outcome_slotOf
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ) (i : ℕ) :
    (paper_theorem8_terminal_dropout_record_outcome state).slotOf i = some i := by
  rfl

/-- If rank `i` has a terminal dropout record, that record is its per-click
payment in the terminal dropout-record outcome. -/
theorem paper_theorem8_terminal_dropout_record_outcome_paymentPerClick_of_lastDropout
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ} {i : ℕ}
    {price : ℝ} (hrecord : state.lastDropout i = some price) :
    (paper_theorem8_terminal_dropout_record_outcome state).paymentPerClick i =
      price := by
  simp [paper_theorem8_terminal_dropout_record_outcome, hrecord]

/--
If every rank's terminal dropout record is exactly its finite-`B*` threshold
bid, then the terminal dropout-record outcome is exactly the constructed
ranked-`B*` outcome. This is the algebraic half of the source
history-to-constructed-outcome obligation.
-/
theorem paper_theorem8_terminal_dropout_record_outcome_eq_bstar_ranked_threshold_outcome_of_exact_records'
    (value clickThroughRate : ℕ → ℝ) (remaining : ℕ)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (hrecords :
      ∀ rank,
        state.lastDropout rank =
          some
            (paper_theorem8_bstar_threshold_bid
              value clickThroughRate remaining (rank + 1))) :
    paper_theorem8_terminal_dropout_record_outcome state =
      paper_theorem8_bstar_ranked_threshold_outcome
        value clickThroughRate remaining := by
  exact
    paper_position_outcome_eq_of_same_slots_payments
      (paper_theorem8_terminal_dropout_record_outcome state)
      (paper_theorem8_bstar_ranked_threshold_outcome
        value clickThroughRate remaining)
      (by
        intro i
        rfl)
      (by
        intro i
        simp [paper_theorem8_terminal_dropout_record_outcome,
          paper_theorem8_bstar_ranked_threshold_outcome, hrecords i])

/--
Local-optimality certificate version of
`paper_theorem8_terminal_dropout_record_outcome_eq_bstar_ranked_threshold_outcome_of_exact_records'`.
-/
theorem paper_theorem8_terminal_dropout_record_outcome_eq_bstar_ranked_threshold_outcome_of_exact_records
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (hrecords :
      ∀ rank,
        state.lastDropout rank =
          some
            (paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate model.remaining (rank + 1))) :
    paper_theorem8_terminal_dropout_record_outcome state =
      paper_theorem8_bstar_ranked_threshold_outcome
        model.value model.clickThroughRate model.remaining := by
  exact
    paper_theorem8_terminal_dropout_record_outcome_eq_bstar_ranked_threshold_outcome_of_exact_records'
      model.value model.clickThroughRate model.remaining state hrecords

/--
Finite-`B*` exact-drop histories: clock advances are allowed, but a dropout
transition may occur only when the current clock is exactly the dropping rank's
finite-`B*` threshold. This strengthens ordinary strategy-consistent histories
and captures the source obligation needed for exact terminal payment records.
-/
inductive PaperTheorem8BStarRankedThresholdExactDropHistory
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate) :
    PaperTheorem8GeneralizedEnglishAuctionState ℕ →
      PaperTheorem8GeneralizedEnglishAuctionState ℕ → Prop
  | refl (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ) :
      PaperTheorem8BStarRankedThresholdExactDropHistory model state state
  | advance {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
      (newPrice : ℝ) :
      state.clockPrice ≤ newPrice →
        PaperTheorem8BStarRankedThresholdExactDropHistory model
          (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state newPrice)
          finalState →
        PaperTheorem8BStarRankedThresholdExactDropHistory model state finalState
  | dropout {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
      (rank : ℕ) :
      state.IsActive rank →
        state.clockPrice =
          paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) →
        PaperTheorem8BStarRankedThresholdExactDropHistory model
          (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout state rank)
          finalState →
        PaperTheorem8BStarRankedThresholdExactDropHistory model state finalState

/-- Exact finite-`B*` drop histories compose. This lets auditors build a
finite source history from individually checked exact-drop segments. -/
theorem PaperTheorem8BStarRankedThresholdExactDropHistory.trans
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state midState finalState :
      PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (hleft :
      PaperTheorem8BStarRankedThresholdExactDropHistory model state midState)
    (hright :
      PaperTheorem8BStarRankedThresholdExactDropHistory model midState finalState) :
    PaperTheorem8BStarRankedThresholdExactDropHistory model state finalState := by
  induction hleft with
  | refl state =>
      exact hright
  | @advance state0 midState0 newPrice hclock htail ih =>
      exact
        PaperTheorem8BStarRankedThresholdExactDropHistory.advance
          newPrice hclock (ih hright)
  | @dropout state0 midState0 rank hactive hclock htail ih =>
      exact
        PaperTheorem8BStarRankedThresholdExactDropHistory.dropout
          rank hactive hclock (ih hright)

/--
Every finite-`B*` exact-drop history is an ordinary strategy-consistent history
for the named finite-`B*` ranked-threshold strategy.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_history_to_strategy_history
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (hhist :
      PaperTheorem8BStarRankedThresholdExactDropHistory model state finalState) :
    PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
      (paper_theorem8_bstar_ranked_threshold_strategy
        model.value model.clickThroughRate model.remaining)
      state finalState := by
  induction hhist with
  | refl state =>
      exact PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.refl state
  | @advance state0 finalState0 newPrice hclock htail ih =>
      exact
        PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.cons
          (PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep.advance
            state0 newPrice hclock)
          ih
  | @dropout state0 finalState0 rank hactive hclock htail ih =>
      have hstrategy :
          paper_theorem8_bstar_ranked_threshold_strategy
            model.value model.clickThroughRate model.remaining
            state0 rank := by
        exact
          (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
            model.value model.clickThroughRate state0 rank model.remaining
            (ne_of_gt (model.click_pos rank))
            (ne_of_gt (model.click_pos (rank + 1)))).mpr
            (by rw [hclock])
      exact
        PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory.cons
          (PaperTheorem8GeneralizedEnglishAuctionState.StrategyStep.dropout
            state0 rank hactive hstrategy)
          ih

/--
Single-step exact finite-`B*` source-history constructor. If the current clock
can advance to rank `rank`'s finite-`B*` threshold and the rank is active, then
advancing to that threshold and recording the dropout is an exact-drop history.
-/
theorem paper_theorem8_bstar_ranked_threshold_single_exact_drop_history
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ) (rank : ℕ)
    (hclock :
      state.clockPrice ≤
        paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (rank + 1))
    (hactive : state.IsActive rank) :
    PaperTheorem8BStarRankedThresholdExactDropHistory model state
      (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
        (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
          (paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1)))
        rank) := by
  refine
    PaperTheorem8BStarRankedThresholdExactDropHistory.advance
      (model := model) (state := state)
      (finalState :=
        PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
          (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
            (paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1)))
          rank)
      (paper_theorem8_bstar_threshold_bid
        model.value model.clickThroughRate (model.remaining + 1) (rank + 1))
      hclock ?_
  refine
    PaperTheorem8BStarRankedThresholdExactDropHistory.dropout
      (model := model)
      (state :=
        PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
          (paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1)))
      (finalState :=
        PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
          (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
            (paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1)))
          rank)
      rank ?_ ?_ ?_
  · simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive,
      PaperTheorem8GeneralizedEnglishAuctionState.advanceClock] using hactive
  · simp [PaperTheorem8GeneralizedEnglishAuctionState.advanceClock]
  · exact
      PaperTheorem8BStarRankedThresholdExactDropHistory.refl
        (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
          (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
            (paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1)))
          rank)

/--
In the single-step exact finite-`B*` source-history constructor, the terminal
dropout record for the dropped rank is exactly its finite-`B*` threshold.
-/
theorem paper_theorem8_bstar_ranked_threshold_single_exact_drop_terminal_record_eq_threshold
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ) (rank : ℕ) :
    (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
        (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
          (paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1)))
        rank).lastDropout rank =
      some
        (paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (rank + 1)) := by
  simp [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
    PaperTheorem8GeneralizedEnglishAuctionState.advanceClock]

/-- Advancing the generalized-English clock preserves active ranks. -/
theorem paper_theorem8_generalized_english_advanceClock_isActive_iff
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (newPrice : ℝ) (rank : ℕ) :
    (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock
      state newPrice).IsActive rank ↔ state.IsActive rank := by
  rfl

/-- Recording a dropout makes that rank inactive. -/
theorem paper_theorem8_generalized_english_recordDropout_not_isActive_self
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ) (rank : ℕ) :
    ¬ (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
      state rank).IsActive rank := by
  intro hactive
  have hnone :
      (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
        state rank).lastDropout rank = none := by
    simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive] using hactive
  simp [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout] at hnone

/-- Recording one rank's dropout preserves activity of every other rank. -/
theorem paper_theorem8_generalized_english_recordDropout_isActive_of_ne
    {state : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    {dropped rank : ℕ}
    (hne : rank ≠ dropped)
    (hactive : state.IsActive rank) :
    (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
      state dropped).IsActive rank := by
  simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive,
    PaperTheorem8GeneralizedEnglishAuctionState.recordDropout, hne] using hactive

/--
A single exact finite-`B*` dropout preserves activity of any other rank that
was active before the clock advance and dropout.
-/
theorem paper_theorem8_bstar_ranked_threshold_single_exact_drop_preserves_active_of_ne
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    {dropped rank : ℕ}
    (hne : rank ≠ dropped)
    (hactive : state.IsActive rank) :
    (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
      (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
        (paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (dropped + 1)))
      dropped).IsActive rank := by
  exact
    paper_theorem8_generalized_english_recordDropout_isActive_of_ne hne
      ((paper_theorem8_generalized_english_advanceClock_isActive_iff
        state
        (paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (dropped + 1))
        rank).mpr hactive)

/--
Append one exact finite-`B*` dropout to an already checked exact-drop history.
This is the basic compositional building block for finite source schedules:
first run the existing exact history, then advance to the next active rank's
finite `B*` threshold and record its dropout.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_history_append_single
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state midState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (hhist :
      PaperTheorem8BStarRankedThresholdExactDropHistory model state midState)
    (rank : ℕ)
    (hclock :
      midState.clockPrice ≤
        paper_theorem8_bstar_threshold_bid
          model.value model.clickThroughRate (model.remaining + 1)
          (rank + 1))
    (hactive : midState.IsActive rank) :
    PaperTheorem8BStarRankedThresholdExactDropHistory model state
      (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
        (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock midState
          (paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1)))
        rank) := by
  exact
    PaperTheorem8BStarRankedThresholdExactDropHistory.trans model hhist
      (paper_theorem8_bstar_ranked_threshold_single_exact_drop_history
        model midState rank hclock hactive)

/--
Finite exact-drop schedules for EOS Theorem 8. A schedule is a concrete ordered
list of ranks. At each step, the clock advances to the next rank's finite
`B*` threshold and records that active rank's dropout; the tail schedule then
continues from the post-drop state.
-/
inductive PaperTheorem8BStarRankedThresholdExactDropSchedule
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate) :
    PaperTheorem8GeneralizedEnglishAuctionState ℕ → List ℕ →
      PaperTheorem8GeneralizedEnglishAuctionState ℕ → Prop
  | nil (state : PaperTheorem8GeneralizedEnglishAuctionState ℕ) :
      PaperTheorem8BStarRankedThresholdExactDropSchedule model state [] state
  | cons {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
      (rank : ℕ) (tailRanks : List ℕ) :
      state.clockPrice ≤
          paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1) →
        state.IsActive rank →
          PaperTheorem8BStarRankedThresholdExactDropSchedule model
            (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
              (PaperTheorem8GeneralizedEnglishAuctionState.advanceClock state
                (paper_theorem8_bstar_threshold_bid
                  model.value model.clickThroughRate (model.remaining + 1)
                  (rank + 1)))
              rank)
            tailRanks finalState →
            PaperTheorem8BStarRankedThresholdExactDropSchedule model state
              (rank :: tailRanks) finalState

/-- Every finite exact-drop schedule is an exact-drop history. -/
