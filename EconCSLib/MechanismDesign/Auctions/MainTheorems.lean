  have hH_pos : 0 < H := by
    dsimp [H]
    positivity
  have hs_pos : 0 < s := lt_of_lt_of_le (by norm_num : (0 : ℝ) < 2) hs_ge_two
  have hvalues_nonneg : ∀ i : Agent, 0 ≤ values i := by
    intro i
    linarith [hvalue_ge_one i]
