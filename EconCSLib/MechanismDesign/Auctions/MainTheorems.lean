    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    {state finalState : PaperTheorem8GeneralizedEnglishAuctionState ℕ}
    (hhist :
      PaperTheorem8BStarRankedThresholdExactDropHistory model state finalState)
    (hinitial_active : ∀ rank, state.IsActive rank)
    (hno_active : ∀ rank, ¬ finalState.IsActive rank) :
    ∀ rank,
      finalState.lastDropout rank =
        some
          (paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1)) := by
  intro rank
  exact
    paper_theorem8_bstar_ranked_threshold_exact_drop_history_final_record_eq_threshold
      model hhist (hinitial_active rank) (hno_active rank)

/--
The overshoot witness is not merely a different terminal record: it cannot be
viewed as an exact finite-`B*` dropout history. This is the formal guardrail
showing that a bare generated history does not supply the exact-record premise
needed by the terminal-record source endpoints.
-/
theorem paper_theorem8_bstar_ranked_threshold_ordinary_strategy_history_allows_overshoot_not_exact_drop_history
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (rank : ℕ) :
    let state :=
      paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
        model rank
    let finalState :=
      PaperTheorem8GeneralizedEnglishAuctionState.recordDropout state rank
    PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining)
        state finalState ∧
      PaperTheorem8GeneralizedEnglishAuctionState.StrategyTerminal
        (paper_theorem8_bstar_ranked_threshold_strategy
          model.value model.clickThroughRate model.remaining)
        finalState ∧
        ¬ PaperTheorem8BStarRankedThresholdExactDropHistory
          model state finalState := by
  dsimp
  have hwitness :=
    paper_theorem8_bstar_ranked_threshold_ordinary_strategy_history_allows_overshoot_record
      model rank
  refine ⟨hwitness.1, hwitness.2.1, ?_⟩
  intro hexact
  have hinitial_active :
      (paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
        model rank).IsActive rank := by
    simp [paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state,
      PaperTheorem8GeneralizedEnglishAuctionState.IsActive]
  have hfinal_inactive :
      ¬ (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
        (paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
          model rank) rank).IsActive rank := by
    simp [PaperTheorem8GeneralizedEnglishAuctionState.recordDropout,
      PaperTheorem8GeneralizedEnglishAuctionState.IsActive]
  have hrecord_exact :
      (PaperTheorem8GeneralizedEnglishAuctionState.recordDropout
        (paper_theorem8_bstar_ranked_threshold_single_active_overshoot_state
          model rank) rank).lastDropout rank =
        some
          (paper_theorem8_bstar_threshold_bid
            model.value model.clickThroughRate (model.remaining + 1)
            (rank + 1)) :=
    paper_theorem8_bstar_ranked_threshold_exact_drop_history_final_record_eq_threshold
      model hexact hinitial_active hfinal_inactive
  exact hwitness.2.2.2 hrecord_exact

