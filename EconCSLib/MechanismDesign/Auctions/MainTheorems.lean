    exact
      paper_theorem8_bstar_ranked_threshold_strategy_iff_of_one_step_best_response_and_drop_at_threshold
        model.localModel
        (model.pbe_one_step_best_response strategy hpbe)
        (model.pbe_drop_at_threshold strategy hpbe)
