/--
Local-deviation sequential-rationality target for the finite `B*`
ranked-threshold proof: a strategy is locally sequentially rational exactly
when it is a one-step best response and uses the paper's drop-at-threshold
tie-breaking convention.
-/
def paper_theorem8_bstar_ranked_threshold_local_deviation_sequential_rationality_statement
    (clickThroughRate value : ℕ → ℝ) (remaining : ℕ)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ) : Prop :=
  paper_theorem8_bstar_ranked_threshold_one_step_best_response_statement
      clickThroughRate value remaining strategy ∧
    paper_theorem8_bstar_ranked_threshold_drop_at_threshold_statement
      clickThroughRate value remaining strategy

/--
Source-shaped sequential-rationality target for the generalized-English
history model. The first component is the on-path one-step payoff condition at
states reachable from the initial state under the strategy. The second
component is the off-path belief/sequential-rationality obligation: at states
not generated by that history, the same local one-step comparison must still
hold. The last component is the paper's at-threshold drop convention.

This predicate gives the future concrete belief proof a state/history-shaped
target while remaining equivalent to the existing audited local-deviation
statement.
-/
def paper_theorem8_bstar_ranked_threshold_source_sequential_rationality_statement
    (clickThroughRate value : ℕ → ℝ) (remaining : ℕ)
    (initialState : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ) : Prop :=
  (∀ state,
    PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
        strategy initialState state →
      paper_theorem8_bstar_ranked_threshold_one_step_best_response_at_state
        clickThroughRate value remaining strategy state) ∧
    (∀ state,
      ¬ PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
          strategy initialState state →
        paper_theorem8_bstar_ranked_threshold_one_step_best_response_at_state
          clickThroughRate value remaining strategy state) ∧
      paper_theorem8_bstar_ranked_threshold_drop_at_threshold_statement
        clickThroughRate value remaining strategy

/--
The source-shaped reachable/off-path sequential-rationality target is
equivalent to the existing local-deviation target. This turns the future
belief proof into two state-local obligations, while preserving all downstream
theorems that already consume the local-deviation predicate.
-/
theorem paper_theorem8_bstar_ranked_threshold_source_sequential_rationality_iff_local_deviation
    (clickThroughRate value : ℕ → ℝ) (remaining : ℕ)
    (initialState : PaperTheorem8GeneralizedEnglishAuctionState ℕ)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ) :
    paper_theorem8_bstar_ranked_threshold_source_sequential_rationality_statement
        clickThroughRate value remaining initialState strategy ↔
      paper_theorem8_bstar_ranked_threshold_local_deviation_sequential_rationality_statement
        clickThroughRate value remaining strategy := by
  constructor
  · intro hsource
    constructor
    · intro state rank
      by_cases hreach :
          PaperTheorem8GeneralizedEnglishAuctionState.StrategyHistory
            strategy initialState state
      · exact hsource.1 state hreach rank
      · exact hsource.2.1 state hreach rank
    · exact hsource.2.2
  · intro hlocal
    constructor
    · intro state _hreach
      exact
        (paper_theorem8_bstar_ranked_threshold_one_step_best_response_statement_iff_forall_state
          clickThroughRate value remaining strategy).mp hlocal.1 state
    constructor
    · intro state _hoff_path
      exact
        (paper_theorem8_bstar_ranked_threshold_one_step_best_response_statement_iff_forall_state
          clickThroughRate value remaining strategy).mp hlocal.1 state
    · exact hlocal.2

/--
The named finite `B*` ranked-threshold strategy satisfies the local-deviation
