    rw [hF_eq, htotal]
    exact singlePriceRevenue_le_totalBidValue_of_nonneg values p hvalues_nonneg
  have hH_lt_total : H < totalValue := by
    nlinarith
  have hden_pos_agent :
      ∀ i : Agent, 0 < totalBidValue values - values i :=
