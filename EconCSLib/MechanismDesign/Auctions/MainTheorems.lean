/--
EOS Theorem 8 strict exact finite-`B*` dynamic-game certificate from local
optimality. The theorem exposes the named strict-threshold statement, the named
local-optimality statement, the exact finite `B*` threshold behavior, and the
unique-PBE/VCG-outcome conclusion.
-/
theorem paper_theorem8_bstar_ranked_threshold_strict_dynamic_game_unique_pbe_of_local_optimality_extensional_outcome_certificate
    {Belief : Type*}
    (model :
      PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameExtensionalOutcomeCertificate
        Belief) :
    paper_theorem8_bstar_ranked_threshold_strict_interval_statement
      model.strictModel.clickThroughRate model.strictModel.value
      model.strictModel.remaining ∧
    paper_theorem8_bstar_ranked_threshold_local_optimality_statement
      model.strictModel.clickThroughRate model.strictModel.value
      model.strictModel.remaining ∧
    (∀ state rank,
      paper_theorem8_ranked_threshold_dropout_strategy
          model.strictModel.clickThroughRate
          (fun k =>
            paper_theorem8_bstar_threshold_bid
              model.strictModel.value model.strictModel.clickThroughRate
              model.strictModel.remaining (k + 2))
          model.strictModel.value state rank ↔
        paper_theorem8_bstar_threshold_bid
          model.strictModel.value model.strictModel.clickThroughRate
          (model.strictModel.remaining + 1) (rank + 1) ≤ state.clockPrice) ∧
      ∃ equilibrium : PaperTheorem8GeneralizedEnglishStrategy ℕ,
        model.game.PerfectBayesianEquilibrium equilibrium ∧
          (∀ strategy,
            model.game.PerfectBayesianEquilibrium strategy →
              strategy = equilibrium) ∧
          model.game.outcomeOf equilibrium = model.game.vcgOutcome := by
  have hstrict :
      paper_theorem8_bstar_ranked_threshold_strict_interval_statement
        model.strictModel.clickThroughRate model.strictModel.value
        model.strictModel.remaining :=
    paper_theorem8_bstar_ranked_threshold_strict_interval_statement_of_certificate
      model.strictModel
  let localModel :
      PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate :=
    paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
      model.strictModel
  let bridgeModel :
      PaperTheorem8BStarRankedThresholdLocalOptimalityDynamicGameExtensionalOutcomeCertificate
        Belief :=
    { game := model.game
      localModel := localModel
      game_click_eq := by
        intro rank
        simpa [localModel,
          paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict]
          using model.game_click_eq rank
      game_value_eq := by
        intro rank
        simpa [localModel,
          paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict]
          using model.game_value_eq rank
      belief := model.belief
      equilibrium_consistent := by
        simpa [localModel,
          paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict,
          paper_theorem8_bstar_threshold_bid] using
          model.equilibrium_consistent
      local_optimality_implies_sequential_rationality := by
        intro hlocal
        simpa [localModel,
          paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict,
          paper_theorem8_bstar_threshold_bid] using
          model.local_optimality_implies_sequential_rationality hlocal
      pbe_bstar_threshold_characterization := by
        intro strategy hpbe state rank
        simpa [localModel,
          paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict,
          paper_theorem8_bstar_threshold_bid] using
          model.pbe_bstar_threshold_characterization strategy hpbe state rank
      equilibrium_same_slots_as_vcg := by
        intro i
        simpa [localModel,
          paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict,
          paper_theorem8_bstar_threshold_bid] using
          model.equilibrium_same_slots_as_vcg i
      equilibrium_same_payments_as_vcg := by
        intro i
        simpa [localModel,
          paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict,
          paper_theorem8_bstar_threshold_bid] using
          model.equilibrium_same_payments_as_vcg i }
  have hbridge :=
    paper_theorem8_bstar_ranked_threshold_dynamic_game_unique_pbe_of_local_optimality_extensional_outcome_certificate
      bridgeModel
  exact ⟨hstrict, by
    simpa [localModel,
      paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict,
      paper_theorem8_bstar_threshold_bid] using hbridge⟩

/--
Strict exact finite-`B*` dynamic-game PBE characterization from local
optimality. A strategy is a PBE iff it is the named finite `B*`
ranked-threshold strategy.
-/
theorem paper_theorem8_bstar_ranked_threshold_strict_dynamic_game_pbe_iff_strategy_eq_of_local_optimality_extensional_outcome_certificate
    {Belief : Type*}
    (model :
      PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameExtensionalOutcomeCertificate
        Belief)
    (strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ) :
    model.game.PerfectBayesianEquilibrium strategy ↔
      strategy =
        paper_theorem8_bstar_ranked_threshold_strategy
          model.strictModel.value model.strictModel.clickThroughRate
          model.strictModel.remaining := by
  constructor
  · intro hpbe
    funext state rank
    apply propext
    exact
      (model.pbe_bstar_threshold_characterization strategy hpbe state rank).trans
        (paper_theorem8_bstar_ranked_threshold_strategy_drops_iff_threshold_bid
          model.strictModel.value model.strictModel.clickThroughRate state rank
          model.strictModel.remaining
          (ne_of_gt (model.strictModel.click_pos rank))
          (ne_of_gt (model.strictModel.click_pos (rank + 1)))).symm
  · intro h
    rw [h]
    let localModel :
        PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate :=
      paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
        model.strictModel
    have hlocal :
        paper_theorem8_bstar_ranked_threshold_local_optimality_statement
          model.strictModel.clickThroughRate model.strictModel.value
          model.strictModel.remaining := by
      simpa [localModel,
        paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict]
        using
          paper_theorem8_bstar_ranked_threshold_local_optimality_statement_of_certificate
            localModel
    exact
      ⟨model.belief,
        by
          simpa [paper_theorem8_bstar_ranked_threshold_strategy,
            paper_theorem8_bstar_threshold_bid] using
            model.equilibrium_consistent,
        by
          simpa [paper_theorem8_bstar_ranked_threshold_strategy,
            paper_theorem8_bstar_threshold_bid] using
            model.local_optimality_implies_sequential_rationality hlocal⟩

