    intro rank hnot_scheduled
    have hnot_activeRanks : rank ∉ activeRanks := by
      intro hactiveRank
      exact hnot_scheduled ((hcover rank).mp hactiveRank)
    exact
      paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_lastDropout_of_not_mem
        model activeRanks hnot_activeRanks
  exact
    paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state_terminal_record_outcome_eq_bstar_of_clock_sorted_nodup_of_initial_unscheduled_records
      model initialState scheduledRanks hsorted hnodup hinitial_active
      hunscheduled_initial_records

/--
Finite-active exact-record source-game endpoint. The state-based
terminal-record source game has a unique PBE, namely the finite-`B*`
