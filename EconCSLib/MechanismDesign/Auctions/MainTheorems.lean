/--
Running-example Theorem 7 revenue-minimality calculation. Among all outcomes
with the same assignment that are slot-envy-free, the VCG-equivalent
locally-envy-free outcome has weakly minimal expected revenue.

The proof is the paper's two displayed envy constraints in arithmetic form:
bidder `2` not envying bidder `1`'s slot forces `p₁ ≥ 2`, and bidder `1` not
envying bidder `0`'s slot forces `p₀ ≥ 2 + p₁ / 2`; hence
`200 p₀ + 100 p₁ ≥ 800`.
-/
theorem paper_eos_running_example_vcg_equivalent_revenue_minimal
    (other : PositionOutcome (Fin 3) (Fin 2))
    (hother :
      other.SlotEnvyFree
        paper_eos_running_example_environment
        paper_eos_running_example_values3)
    (hsame :
      ∀ i,
        paper_eos_running_example_vcg_equivalent_outcome.slotOf i =
          other.slotOf i) :
    paper_eos_running_example_vcg_equivalent_outcome.revenue
        paper_eos_running_example_environment ≤
      other.revenue paper_eos_running_example_environment := by
  have hslot0 : other.slotOf (0 : Fin 3) = some (0 : Fin 2) := by
    simpa [paper_eos_running_example_vcg_equivalent_outcome] using
      (hsame (0 : Fin 3)).symm
  have hslot1 : other.slotOf (1 : Fin 3) = some (1 : Fin 2) := by
    simpa [paper_eos_running_example_vcg_equivalent_outcome] using
      (hsame (1 : Fin 3)).symm
  have hslot2 : other.slotOf (2 : Fin 3) = none := by
    simpa [paper_eos_running_example_vcg_equivalent_outcome] using
      (hsame (2 : Fin 3)).symm
  have hbidder2_no_envy := hother (2 : Fin 3) (1 : Fin 3) (1 : Fin 2) hslot1
  have hp1_ge : 2 ≤ other.paymentPerClick (1 : Fin 3) := by
    norm_num [PositionOutcome.utility, paper_eos_running_example_environment,
      paper_eos_running_example_values3, hslot2] at hbidder2_no_envy
    linarith
  have hbidder1_no_envy := hother (1 : Fin 3) (0 : Fin 3) (0 : Fin 2) hslot0
  have hp0_ge :
      2 + other.paymentPerClick (1 : Fin 3) / 2 ≤
        other.paymentPerClick (0 : Fin 3) := by
    norm_num [PositionOutcome.utility, paper_eos_running_example_environment,
      paper_eos_running_example_values3, hslot1] at hbidder1_no_envy
    linarith
  have hother_revenue :
      other.revenue paper_eos_running_example_environment =
        200 * other.paymentPerClick (0 : Fin 3) +
          100 * other.paymentPerClick (1 : Fin 3) := by
    rw [PositionOutcome.revenue, Finset.sum_fin_eq_sum_range]
    simp [Finset.sum_range_succ, PositionOutcome.revenueContribution,
      paper_eos_running_example_environment, hslot0, hslot1, hslot2]
  rw [paper_eos_running_example_vcg_equivalent_outcome_revenue_eq,
    hother_revenue]
  nlinarith

/--
Paper-facing ordered ranked certificate for EOS Theorem 7 with a derived
finite-tail lower-bound theorem. This removes the raw stable-assignment payment
lower-bound field: Lean derives it from finite VCG-tail equality, positive
click-through rates, and terminal nonnegative comparison total payments.
-/
structure PaperTheorem7OrderedRankedFiniteTailCertificate (n : ℕ) where
  value : ℕ → ℝ
  vcgTotalPayment : ℕ → ℝ
  clickThroughRate : ℕ → ℝ
  vcgOutcome : PositionOutcome (Fin n) (Fin n)
  click_nonneg : ∀ s : Fin n, 0 ≤ clickThroughRate s.val
  click_pos : ∀ s : Fin n, 0 < clickThroughRate s.val
  click_mono : ∀ k : ℕ, clickThroughRate (k + 1) ≤ clickThroughRate k
  value_mono : ∀ a b : ℕ, a ≤ b → value b ≤ value a
  vcg_rec :
    ∀ k : ℕ,
      vcgTotalPayment k =
        (clickThroughRate k - clickThroughRate (k + 1)) * value (k + 1) +
          vcgTotalPayment (k + 1)
  payment_le_value :
    ∀ i : Fin n,
      vcgTotalPayment i.val ≤ clickThroughRate i.val * value i.val
  tailRemaining : Fin n → ℕ
  tail_bound : ∀ i : Fin n, i.val + tailRemaining i < n
  vcg_tail_eq :
    ∀ i : Fin n,
      vcgTotalPayment i.val =
        paper_theorem7_ranked_vcg_tail_payment
          value clickThroughRate i.val (tailRemaining i)
  terminal_total_nonneg :
    ∀ other : PositionOutcome (Fin n) (Fin n),
      other.StableAssignment
          (paper_theorem7_ranked_environment clickThroughRate)
          (fun i : Fin n => value i.val) →
        (∀ i,
          (paper_theorem7_ranked_bstar_outcome
            value vcgTotalPayment clickThroughRate).slotOf i =
            other.slotOf i) →
          ∀ i : Fin n,
            0 ≤
              paper_theorem7_ranked_outcome_total_payment
                clickThroughRate other (i.val + tailRemaining i)
  same_slots_as_vcg :
    ∀ i,
      (paper_theorem7_ranked_bstar_outcome
        value vcgTotalPayment clickThroughRate).slotOf i =
        vcgOutcome.slotOf i
  same_payments_as_vcg :
    ∀ i,
      (paper_theorem7_ranked_bstar_outcome
        value vcgTotalPayment clickThroughRate).paymentPerClick i =
        vcgOutcome.paymentPerClick i

/--
EOS Theorem 7 finite-tail ordered ranked certificate form. Under the standard
sorted-rank assumptions, finite VCG-tail equality, and terminal nonnegative
comparison total payments, the ranked `B*` outcome is locally envy-free,
stable, VCG-equivalent, and weakly revenue-minimal among locally envy-free
outcomes with the same assignment.
-/
theorem paper_theorem7_ordered_ranked_finite_tail_vcg_equivalent_locally_envy_free
    {n : ℕ} (model : PaperTheorem7OrderedRankedFiniteTailCertificate n) :
    ∃ O : PositionOutcome (Fin n) (Fin n),
      O.SlotEnvyFree
          (paper_theorem7_ranked_environment model.clickThroughRate)
          (fun i : Fin n => model.value i.val) ∧
        O.StableAssignment
          (paper_theorem7_ranked_environment model.clickThroughRate)
          (fun i : Fin n => model.value i.val) ∧
        (∀ i, O.slotOf i = model.vcgOutcome.slotOf i) ∧
        (∀ i, O.paymentPerClick i = model.vcgOutcome.paymentPerClick i) ∧
        ∀ other : PositionOutcome (Fin n) (Fin n),
          other.FeasibleAssignment →
          other.IndividuallyRational
            (paper_theorem7_ranked_environment model.clickThroughRate)
            (fun i : Fin n => model.value i.val) →
          other.SlotEnvyFree
            (paper_theorem7_ranked_environment model.clickThroughRate)
            (fun i : Fin n => model.value i.val) →
            (∀ i, O.slotOf i = other.slotOf i) →
              O.revenue
                  (paper_theorem7_ranked_environment model.clickThroughRate) ≤
                other.revenue
                  (paper_theorem7_ranked_environment model.clickThroughRate) := by
  let O : PositionOutcome (Fin n) (Fin n) :=
    paper_theorem7_ranked_bstar_outcome (n := n)
      model.value model.vcgTotalPayment model.clickThroughRate
  have hclick_ne : ∀ i : Fin n, model.clickThroughRate i.val ≠ 0 :=
    fun i => ne_of_gt (model.click_pos i)
  have hlef :
      O.SlotEnvyFree
        (paper_theorem7_ranked_environment model.clickThroughRate)
        (fun i : Fin n => model.value i.val) :=
    paper_theorem7_ranked_bstar_outcome_slot_envy_free_of_ordered_values
      hclick_ne model.click_mono model.value_mono model.vcg_rec
  have hstable :
      O.StableAssignment
        (paper_theorem7_ranked_environment model.clickThroughRate)
        (fun i : Fin n => model.value i.val) :=
    paper_theorem7_ranked_bstar_outcome_stable_assignment_of_ordered_values
      hclick_ne model.click_mono model.value_mono model.vcg_rec
      model.payment_le_value
  refine ⟨O, hlef, hstable, model.same_slots_as_vcg,
    model.same_payments_as_vcg, ?_⟩
  intro other hfeasible hIR hother hsame
  have hstable_other :
      other.StableAssignment
        (paper_theorem7_ranked_environment model.clickThroughRate)
        (fun i : Fin n => model.value i.val) :=
    paper_position_slot_envy_free_stable_assignment
      (paper_theorem7_ranked_environment model.clickThroughRate)
      other (fun i : Fin n => model.value i.val)
      hfeasible hIR hother
  have hslots : ∀ i : Fin n, other.slotOf i = some i := by
    intro i
    simpa [O, paper_theorem7_ranked_bstar_outcome] using (hsame i).symm
  have hpay_le : ∀ i : Fin n, O.paymentPerClick i ≤ other.paymentPerClick i := by
    intro i
    exact
      paper_theorem7_ranked_bstar_payment_le_of_stable_assignment_tail
        other i (model.tailRemaining i) (model.vcg_tail_eq i)
        (model.click_pos i) (model.tail_bound i) hstable_other hslots
        (model.terminal_total_nonneg other hstable_other hsame i)
  exact
    paper_position_revenue_le_of_same_slots_payment_le
      (paper_theorem7_ranked_environment model.clickThroughRate)
      O other model.click_nonneg hsame hpay_le

