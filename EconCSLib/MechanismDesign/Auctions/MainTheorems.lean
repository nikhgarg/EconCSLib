/--
Strict constructed ranked-`B*` outcome certificates induce the strict
extensional-outcome certificate used by the main strict dynamic-game boundary.
-/
def paper_theorem8_bstar_ranked_threshold_strict_dynamic_game_extensional_outcome_certificate_of_constructed_outcome_certificate
    {Belief : Type*}
    (model :
      PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameConstructedOutcomeCertificate
        Belief) :
    PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameExtensionalOutcomeCertificate
      Belief where
  game := model.game
  strictModel := model.strictModel
  game_click_eq := model.game_click_eq
  game_value_eq := model.game_value_eq
  belief := model.belief
  equilibrium_consistent := by
    simpa [paper_theorem8_bstar_ranked_threshold_strategy,
      paper_theorem8_bstar_threshold_bid] using
      model.equilibrium_consistent
  local_optimality_implies_sequential_rationality := by
    intro hlocal
    simpa [paper_theorem8_bstar_ranked_threshold_strategy,
      paper_theorem8_bstar_threshold_bid] using
      model.local_optimality_implies_sequential_rationality hlocal
  pbe_bstar_threshold_characterization :=
    model.pbe_bstar_threshold_characterization
  equilibrium_same_slots_as_vcg := by
    intro i
    have hnamed :=
      congrArg (fun O : PositionOutcome ℕ ℕ => O.slotOf i)
        model.named_strategy_outcome_eq_bstar
    have hvcg :=
      congrArg (fun O : PositionOutcome ℕ ℕ => O.slotOf i)
        model.vcg_outcome_eq_bstar
    calc
      (model.game.outcomeOf
          (paper_theorem8_ranked_threshold_dropout_strategy
            model.strictModel.clickThroughRate
            (fun k =>
              paper_theorem8_bstar_threshold_bid
                model.strictModel.value model.strictModel.clickThroughRate
                model.strictModel.remaining (k + 2))
            model.strictModel.value)).slotOf i =
          (paper_theorem8_bstar_ranked_threshold_outcome
            model.strictModel.value model.strictModel.clickThroughRate
            model.strictModel.remaining).slotOf i := by
        simpa [paper_theorem8_bstar_ranked_threshold_strategy,
          paper_theorem8_bstar_threshold_bid] using hnamed
      _ = model.game.vcgOutcome.slotOf i := hvcg.symm
  equilibrium_same_payments_as_vcg := by
    intro i
    have hnamed :=
      congrArg (fun O : PositionOutcome ℕ ℕ => O.paymentPerClick i)
        model.named_strategy_outcome_eq_bstar
    have hvcg :=
      congrArg (fun O : PositionOutcome ℕ ℕ => O.paymentPerClick i)
        model.vcg_outcome_eq_bstar
    calc
      (model.game.outcomeOf
          (paper_theorem8_ranked_threshold_dropout_strategy
            model.strictModel.clickThroughRate
            (fun k =>
              paper_theorem8_bstar_threshold_bid
                model.strictModel.value model.strictModel.clickThroughRate
                model.strictModel.remaining (k + 2))
            model.strictModel.value)).paymentPerClick i =
          (paper_theorem8_bstar_ranked_threshold_outcome
            model.strictModel.value model.strictModel.clickThroughRate
            model.strictModel.remaining).paymentPerClick i := by
        simpa [paper_theorem8_bstar_ranked_threshold_strategy,
          paper_theorem8_bstar_threshold_bid] using hnamed
      _ = model.game.vcgOutcome.paymentPerClick i := hvcg.symm

/--
Integrated strict ordered terminal-dynamic PBE terminal behavior. Any PBE of the
certified strict ordered dynamic game has the terminal finite-`B*` dropout
behavior, its complement active-rank characterization, and concrete dropout
records at prices between the finite-`B*` threshold bid and the terminal clock.
