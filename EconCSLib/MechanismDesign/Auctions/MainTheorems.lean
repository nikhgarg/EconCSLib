          model
          (paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state
            model activeRanks)
          scheduledRanks).IsActive rank := by
  let initialState :=
    paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_state
      model activeRanks
  have hinitial_active :
      ∀ rank, rank ∈ scheduledRanks → initialState.IsActive rank := by
    intro rank hrank
    exact
      (paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_active_iff
        model activeRanks rank).mpr ((hcover rank).mpr hrank)
  let hsched :=
    paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_of_clock_sorted_nodup
      model initialState scheduledRanks hsorted hnodup hinitial_active
  have hrecords :=
    paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state_records_of_clock_sorted_nodup
      model initialState scheduledRanks hsorted hnodup hinitial_active
  intro rank hactive_final
  by_cases hrank : rank ∈ scheduledRanks
  · exact
      (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_inactive_of_mem
        model hsched rank hrank) hactive_final
  · have hnot_activeRanks : rank ∉ activeRanks := by
      intro hactiveRank
      exact hrank ((hcover rank).mp hactiveRank)
    have hinit_record :
        initialState.lastDropout rank =
          some
            (paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1)) := by
      exact
        paper_theorem8_bstar_ranked_threshold_finite_active_exact_record_cold_start_lastDropout_of_not_mem
          model activeRanks hnot_activeRanks
    have hfinal_record :
        (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
          model initialState scheduledRanks).lastDropout rank =
          some
            (paper_theorem8_bstar_threshold_bid
              model.value model.clickThroughRate (model.remaining + 1)
              (rank + 1)) := by
      rw [hrecords.2 rank hrank, hinit_record]
    have hnone :
        (paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state
          model initialState scheduledRanks).lastDropout rank = none := by
      simpa [PaperTheorem8GeneralizedEnglishAuctionState.IsActive] using
        hactive_final
    rw [hfinal_record] at hnone
    cases hnone

/--
Exact-record finite-active full terminal-record outcome bridge. When the
scheduled ranks cover exactly the finite active set, the deterministic final
state's terminal dropout-record outcome is the constructed ranked `B*` outcome
for all ranks, not only for scheduled ranks.
-/
theorem paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_final_state_terminal_record_outcome_eq_bstar_of_finite_active_exact_record_cold_start_covers
    (model : PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate)
    (activeRanks : Finset ℕ) (scheduledRanks : List ℕ)
    (hsorted :
      paper_theorem8_bstar_ranked_threshold_exact_drop_schedule_clock_sorted
        model
