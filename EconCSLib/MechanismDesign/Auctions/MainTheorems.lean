          finalState.clockPrice := by
  have hactive_iff :=
    paper_theorem8_bstar_ranked_threshold_strategy_terminal_history_active_iff_clock_lt_threshold_bid
      model hhist hterminal hinitial_active
  rw [hactive_iff]
  exact not_lt

/--
In a terminal finite-`B*` ranked-threshold-strategy-consistent history from an
initially active rank, final inactivity is equivalent to the named finite `B*`
