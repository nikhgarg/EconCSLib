field is discharged from the named local-optimality package. This is the
strongest current paper-facing Theorem 8 boundary: strict no-tie threshold
intervals, local threshold optimality, and the dynamic unique-PBE/VCG-outcome
conclusion are tied together in one certificate.
-/
structure PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameExtensionalOutcomeCertificate
    (Belief : Type*) where
  game :
    PaperTheorem8GeneralizedEnglishDynamicGame
      ℕ ℕ (PaperTheorem8GeneralizedEnglishStrategy ℕ) Belief
  strictModel :
    PaperTheorem8BStarRankedThresholdStrictLocalOptimalityCertificate
  game_click_eq :
    ∀ rank,
      game.environment.clickThroughRate rank =
        strictModel.clickThroughRate rank
  game_value_eq :
    ∀ rank, game.values rank = strictModel.value rank
  belief : Belief
  equilibrium_consistent :
    game.isConsistentBelief
      (paper_theorem8_ranked_threshold_dropout_strategy
        strictModel.clickThroughRate
        (fun k =>
          paper_theorem8_bstar_threshold_bid
            strictModel.value strictModel.clickThroughRate
            strictModel.remaining (k + 2))
        strictModel.value) belief
  local_optimality_implies_sequential_rationality :
    paper_theorem8_bstar_ranked_threshold_local_optimality_statement
        strictModel.clickThroughRate strictModel.value strictModel.remaining →
      game.isSequentiallyRational
        (paper_theorem8_ranked_threshold_dropout_strategy
          strictModel.clickThroughRate
          (fun k =>
            paper_theorem8_bstar_threshold_bid
              strictModel.value strictModel.clickThroughRate
              strictModel.remaining (k + 2))
          strictModel.value) belief
  pbe_bstar_threshold_characterization :
    ∀ strategy,
      game.PerfectBayesianEquilibrium strategy →
        ∀ state rank,
          strategy state rank ↔
            paper_theorem8_bstar_threshold_bid
              strictModel.value strictModel.clickThroughRate
              (strictModel.remaining + 1) (rank + 1) ≤ state.clockPrice
  equilibrium_same_slots_as_vcg :
    ∀ i,
      (game.outcomeOf
        (paper_theorem8_ranked_threshold_dropout_strategy
          strictModel.clickThroughRate
          (fun k =>
            paper_theorem8_bstar_threshold_bid
              strictModel.value strictModel.clickThroughRate
              strictModel.remaining (k + 2))
          strictModel.value)).slotOf i =
        game.vcgOutcome.slotOf i
  equilibrium_same_payments_as_vcg :
    ∀ i,
      (game.outcomeOf
        (paper_theorem8_ranked_threshold_dropout_strategy
          strictModel.clickThroughRate
          (fun k =>
            paper_theorem8_bstar_threshold_bid
              strictModel.value strictModel.clickThroughRate
              strictModel.remaining (k + 2))
          strictModel.value)).paymentPerClick i =
        game.vcgOutcome.paymentPerClick i

/--
The strict finite-`B*` local-optimality dynamic-game certificate exposes belief
consistency for the named finite-`B*` strategy.
-/
theorem paper_theorem8_bstar_ranked_threshold_strict_dynamic_game_named_strategy_consistent_belief_of_local_optimality_extensional_outcome_certificate
    {Belief : Type*}
    (model :
      PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameExtensionalOutcomeCertificate
        Belief) :
    model.game.isConsistentBelief
      (paper_theorem8_bstar_ranked_threshold_strategy
        model.strictModel.value model.strictModel.clickThroughRate
        model.strictModel.remaining)
      model.belief := by
  simpa [paper_theorem8_bstar_ranked_threshold_strategy] using
    model.equilibrium_consistent

/--
The strict finite-`B*` local-optimality dynamic-game certificate exposes
sequential rationality for the named finite-`B*` strategy once the strict local
optimality package is converted to the weak audited local-optimality statement.
-/
theorem paper_theorem8_bstar_ranked_threshold_strict_dynamic_game_named_strategy_sequentially_rational_of_local_optimality_extensional_outcome_certificate
    {Belief : Type*}
    (model :
      PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameExtensionalOutcomeCertificate
        Belief) :
    model.game.isSequentiallyRational
      (paper_theorem8_bstar_ranked_threshold_strategy
        model.strictModel.value model.strictModel.clickThroughRate
        model.strictModel.remaining)
      model.belief := by
  have hlocal :
      paper_theorem8_bstar_ranked_threshold_local_optimality_statement
        model.strictModel.clickThroughRate model.strictModel.value
        model.strictModel.remaining :=
    paper_theorem8_bstar_ranked_threshold_local_optimality_of_certificate
      (paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
        model.strictModel)
  simpa [paper_theorem8_bstar_ranked_threshold_strategy] using
    model.local_optimality_implies_sequential_rationality hlocal

/--
Terminal-history/PBE bridge for strict finite-`B*` dynamic certificates. If the
terminal-history certificate uses the weak local model induced by the strict
dynamic certificate, then every certified PBE strategy acts exactly on terminal
inactive ranks and every terminal PBE action has a concrete dropout record.
-/
theorem paper_theorem8_bstar_ranked_threshold_terminal_history_strict_pbe_strategy_behavior_with_records_of_local_optimality_extensional_outcome_certificate
    {Belief : Type*}
    (terminalCert :
      PaperTheorem8BStarRankedThresholdTerminalHistoryBehaviorCertificate)
    (dynamicCert :
      PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameExtensionalOutcomeCertificate
        Belief)
    (hmodel :
      paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
          dynamicCert.strictModel =
        terminalCert.localModel)
    {strategy : PaperTheorem8GeneralizedEnglishStrategy ℕ}
    (hpbe : dynamicCert.game.PerfectBayesianEquilibrium strategy) :
    (∀ rank, strategy terminalCert.finalState rank ↔
      ¬ terminalCert.finalState.IsActive rank) ∧
      (∀ rank, ¬ strategy terminalCert.finalState rank ↔
        terminalCert.finalState.IsActive rank) ∧
        (∀ rank,
          strategy terminalCert.finalState rank →
            ∃ price,
              terminalCert.finalState.lastDropout rank = some price ∧
                paper_theorem8_bstar_threshold_bid
                  terminalCert.localModel.value
                  terminalCert.localModel.clickThroughRate
                  (terminalCert.localModel.remaining + 1) (rank + 1) ≤
                  price ∧
                price ≤ terminalCert.finalState.clockPrice) := by
  exact
    paper_theorem8_bstar_ranked_threshold_terminal_history_cutoff_strategy_behavior_with_records
      terminalCert strategy
      (by
        intro state rank
        have hvalue :
            dynamicCert.strictModel.value = terminalCert.localModel.value := by
          have h :=
            congrArg
              PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate.value
              hmodel
          simpa [paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict]
            using h
        have hclick :
            dynamicCert.strictModel.clickThroughRate =
              terminalCert.localModel.clickThroughRate := by
          have h :=
            congrArg
              PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate.clickThroughRate
              hmodel
          simpa [paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict]
            using h
        have hremaining :
            dynamicCert.strictModel.remaining = terminalCert.localModel.remaining := by
          have h :=
            congrArg
              PaperTheorem8BStarRankedThresholdLocalOptimalityCertificate.remaining
              hmodel
          simpa [paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict]
            using h
        simpa [hvalue, hclick, hremaining] using
          dynamicCert.pbe_bstar_threshold_characterization
            strategy hpbe state rank)

/--
EOS Theorem 8 strict exact finite-`B*` dynamic-game certificate with a
constructed ranked-`B*` outcome boundary. It records that the named strict
generalized-English outcome and the VCG outcome both equal the canonical ranked
`B*` outcome.
-/
structure PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameConstructedOutcomeCertificate
    (Belief : Type*) where
  game :
    PaperTheorem8GeneralizedEnglishDynamicGame
      ℕ ℕ (PaperTheorem8GeneralizedEnglishStrategy ℕ) Belief
  strictModel :
    PaperTheorem8BStarRankedThresholdStrictLocalOptimalityCertificate
  game_click_eq :
    ∀ rank,
      game.environment.clickThroughRate rank =
        strictModel.clickThroughRate rank
  game_value_eq :
    ∀ rank, game.values rank = strictModel.value rank
  belief : Belief
  equilibrium_consistent :
    game.isConsistentBelief
      (paper_theorem8_bstar_ranked_threshold_strategy
        strictModel.value strictModel.clickThroughRate strictModel.remaining)
      belief
  local_optimality_implies_sequential_rationality :
    paper_theorem8_bstar_ranked_threshold_local_optimality_statement
        strictModel.clickThroughRate strictModel.value strictModel.remaining →
      game.isSequentiallyRational
        (paper_theorem8_bstar_ranked_threshold_strategy
          strictModel.value strictModel.clickThroughRate strictModel.remaining)
        belief
  pbe_bstar_threshold_characterization :
    ∀ strategy,
      game.PerfectBayesianEquilibrium strategy →
        ∀ state rank,
          strategy state rank ↔
            paper_theorem8_bstar_threshold_bid
              strictModel.value strictModel.clickThroughRate
              (strictModel.remaining + 1) (rank + 1) ≤ state.clockPrice
  named_strategy_outcome_eq_bstar :
    game.outcomeOf
        (paper_theorem8_bstar_ranked_threshold_strategy
          strictModel.value strictModel.clickThroughRate strictModel.remaining) =
      paper_theorem8_bstar_ranked_threshold_outcome
        strictModel.value strictModel.clickThroughRate strictModel.remaining
  vcg_outcome_eq_bstar :
    game.vcgOutcome =
      paper_theorem8_bstar_ranked_threshold_outcome
        strictModel.value strictModel.clickThroughRate strictModel.remaining

/--
Strict ordered constructed-outcome dynamic-game certificate for EOS Theorem 8.
This packages the strict finite-`B*` dynamic-game certificate together with the
ordered value assumptions needed for the constructed outcome's payment bounds,
individual rationality, and no-positive-transfers conclusions.
-/
structure PaperTheorem8BStarRankedThresholdStrictOrderedDynamicGameConstructedOutcomeCertificate
    (Belief : Type*) where
  base :
    PaperTheorem8BStarRankedThresholdStrictLocalOptimalityDynamicGameConstructedOutcomeCertificate
      Belief
  value_nonneg : ∀ rank, 0 ≤ base.strictModel.value rank
  value_mono : ∀ rank, base.strictModel.value (rank + 1) ≤ base.strictModel.value rank

/--
Strict ordered terminal-dynamic certificate for EOS Theorem 8. This packages
the terminal history certificate used for human-verifiable dropout records with
the strongest current strict ordered dynamic constructed-outcome certificate.
The model equality field is the explicit audit bridge saying that the terminal
history and dynamic-game certificates describe the same finite-`B*` local model.
-/
structure PaperTheorem8BStarRankedThresholdStrictOrderedTerminalDynamicCertificate
    (Belief : Type*) where
  terminal : PaperTheorem8BStarRankedThresholdTerminalHistoryBehaviorCertificate
  dynamic :
    PaperTheorem8BStarRankedThresholdStrictOrderedDynamicGameConstructedOutcomeCertificate
      Belief
  localModel_eq :
    paper_theorem8_bstar_ranked_threshold_local_optimality_certificate_of_strict
        dynamic.base.strictModel =
      terminal.localModel

/--
Strict ordered terminal-dynamic certificate whose terminal history carries
